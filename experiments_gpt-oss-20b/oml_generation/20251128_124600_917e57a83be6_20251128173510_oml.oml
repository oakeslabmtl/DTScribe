// Acting Components
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan controlled via MOSFET, voltage set to 12 V or 18 V, driven by low‑level driver on Raspberry Pi."
]

instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed heater controlled via MOSFET, implements bang‑bang logic with heating duration H, driven by low‑level driver."
]

// Physical Sensing Components
instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor positioned outside incubator to measure ambient room temperature."
    DTDFVocab:producedData AmbientTemperatureData
]

instance HotSpotTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor placed at hottest point inside the box."
    DTDFVocab:producedData HotSpotTemperatureData
]

instance ColdSpotTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor placed at coldest point inside the box."
    DTDFVocab:producedData ColdSpotTemperatureData
]

// Data Transmitted
instance AmbientTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

instance HotSpotTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HotSpotTemperatureSensor
]

instance ColdSpotTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ColdSpotTemperatureSensor
]

// Data
instance AmbientTemperatureReading : DTDFVocab:Data [
    base:desc "Ambient temperature data in °C, timestamped, forwarded to DT."
    DTDFVocab:fromData AmbientTemperatureData
    DTDFVocab:inputTo RabbitMQBroker, KalmanFilterEnabler, ModelBCalibrationEnabler, CoSimulationEnabler, SelfAdaptationEnabler
]

instance HotSpotTemperatureReading : DTDFVocab:Data [
    base:desc "Hot spot temperature data in °C, timestamped, forwarded to DT."
    DTDFVocab:fromData HotSpotTemperatureData
    DTDFVocab:inputTo RabbitMQBroker, KalmanFilterEnabler, ModelBCalibrationEnabler, CoSimulationEnabler, SelfAdaptationEnabler
]

instance ColdSpotTemperatureReading : DTDFVocab:Data [
    base:desc "Cold spot temperature data in °C, timestamped, forwarded to DT."
    DTDFVocab:fromData ColdSpotTemperatureData
    DTDFVocab:inputTo RabbitMQBroker, KalmanFilterEnabler, ModelBCalibrationEnabler, CoSimulationEnabler, SelfAdaptationEnabler
]

// Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker handling AMQP communication between PT and DT."
    DTDFVocab:enables RealTimeMonitoringService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter algorithm enabling anomaly detection and heatbed state estimation."
    DTDFVocab:enables AnomalyDetectionService
]

instance ModelBCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration routine enabling on‑demand fitting of ModelB parameters."
    DTDFVocab:enables CalibrationService
]

instance CoSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Co‑simulation framework enabling what‑if scenario execution."
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationEnabler : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop enabling dynamic reconfiguration of DT components."
    DTDFVocab:enables SelfAdaptationService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real‑time monitoring and visualization of temperature and actuator states via RabbitMQ and time‑series database."
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Service performing anomaly detection using Kalman filter and flagging deviations."
    DTDFVocab:provides AnomalyDetectionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service performing on‑demand calibration of ModelB using collected data."
    DTDFVocab:provides CalibrationAction
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Service running co‑simulation of physical and digital twin models for what‑if analysis."
    DTDFVocab:provides WhatIfSimulationInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Service orchestrating self‑adaptation loop: detecting changes, scheduling experiments, recalibrating, re‑optimizing controller."
    DTDFVocab:provides SelfAdaptationAction
]

// Insights / Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight showing real‑time temperature and actuator states on dashboard."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating detected anomalies and estimation errors."
]

instance CalibrationAction : DTDFVocab:Action [
    base:desc "Action to trigger ModelB calibration routine."
    DTDFVocab:IsAutomatic false
]

instance WhatIfSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight presenting results of what‑if simulation."
]

instance SelfAdaptationAction : DTDFVocab:Action [
    base:desc "Action to update controller parameters and reconfigure DT components."
    DTDFVocab:IsAutomatic true
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains FanActuator, HeatbedActuator, AmbientTemperatureSensor, HotSpotTemperatureSensor, ColdSpotTemperatureSensor, RaspberryPiController, LowLevelDriver, ModelB, KalmanFilter, CoSimulationEngine, SelfAdaptationLoop
]

// Components
instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 running controller logic and low‑level driver."
]

instance LowLevelDriver : DTDFVocab:Component [
    base:desc "Low‑level driver interfacing sensors and actuators via 1‑Wire bus and MOSFETs."
]

instance ModelB : DTDFVocab:Component [
    base:desc "Four‑parameter thermal model representing heatbed dynamics."
]

instance KalmanFilter : DTDFVocab:Component [
    base:desc "Kalman filter algorithm for state estimation."
]

instance CoSimulationEngine : DTDFVocab:Component [
    base:desc "Co‑simulation engine coupling physical and digital twin models."
]

instance SelfAdaptationLoop : DTDFVocab:Component [
    base:desc "Self‑adaptation loop orchestrating calibration, simulation, and controller updates."
]


instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are issued from the DT to the PT through the RabbitMQ broker. The controller component, also running on the Raspberry Pi, subscribes to command queues and receives control messages (e.g., turn heatbed on/off, fan on/off). These messages are forwarded by the low‑level driver to the PT via the GPIO pins, which drive MOSFETs and optocouplers to actuate the heatbed and fan. The low‑level driver incorporates a safe‑protocol to ensure that the PT remains in a safe state; however, the specific validation, authentication, conflict‑resolution, or execution‑confirmation mechanisms are not detailed in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin operates asynchronously via a RabbitMQ message broker. The low‑level driver periodically polls the DS18S20 temperature sensors and publishes the readings to RabbitMQ; the controller subscribes to these messages, processes the data, and publishes actuator commands (fan and heatbed control) back to RabbitMQ. No explicit polling interval, synchronization frequency, or latency requirements are specified in the documents; the temporal granularity is therefore message‑based rather than time‑synchronised."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is orchestrated around a RabbitMQ message broker that serves as the central communication backbone. The physical side consists of a Raspberry Pi 4 running the controller and low‑level driver, which read DS18S20 sensors and drive a MOSFET‑controlled heatbed and fan. The digital side comprises: (1) a real‑time dashboard that subscribes to RabbitMQ topics to plot temperature and actuator states; (2) an on‑demand calibration module that triggers a calibration routine (Model B) when requested; (3) a Kalman‑filter module that estimates the unmeasured heatbed temperature using Model B and the sensor data; (4) a what‑if simulation engine that performs co‑simulation using the calibrated model; and (5) a self‑adaptation loop that, upon detecting anomalies, schedules experiments, re‑calibrates, and re‑configures the controller. Resource management is implicit: all components share the same RabbitMQ broker and the local network; the controller and driver are CPU‑bound on the Pi, while the simulation and Kalman filter run on a separate host. Coordination is achieved through message topics and a simple state machine defined in the controller’s statechart."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin for the incubator is developed in a sequence of clearly defined phases that mirror the typical CPS development lifecycle. 1) **Conceptual modelling** – two thermal models (Model A with two free parameters and Model B with four free parameters) are formulated to capture the heatbed and box dynamics. 2) **Calibration and validation** – Model B is calibrated against experimental data to better predict the heatbed’s thermal inertia; on‑demand calibration is planned to be triggered automatically during operation. 3) **Integration** – the physical twin (heatbed, fan, sensors, Raspberry Pi controller) is wired to a low‑level driver that publishes sensor data to a RabbitMQ communication server; the controller implements a bang‑bang logic with parameters LL, UL, H, C. 4) **Deployment** – the software stack (RabbitMQ, controller, driver) is deployed on the Raspberry Pi and the data are streamed to a time‑series database for real‑time dashboard visualization. 5) **Operational monitoring** – a Kalman filter runs on the digital twin to estimate the unmeasured heatbed temperature and detect anomalies. 6) **Evolution / self‑adaptation** – a closed‑loop self‑adaptation routine is defined: when an anomaly is detected, an experiment is scheduled, new data are collected, Model B is re‑calibrated, the Kalman filter is re‑configured, what‑if simulations are run to re‑optimize controller parameters, and the controller is updated. 7) **Continuous improvement** – the loop above allows the twin to evolve with changing plant behaviour, ensuring the digital twin remains an accurate, up‑to‑date representation of the physical incubator."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing simulated temperature trajectories against measured data from the calibration experiment.  Model B, with four free parameters, demonstrates superior fidelity in capturing the heatbed’s thermal inertia.  Validation is performed through on‑demand calibration: the system automatically runs a parameter estimation routine that fits C_air, G_box, C_heater, and G_heater to the observed data.  Verification is supported by a Kalman filter that continuously estimates the unmeasured heatbed temperature and flags anomalies.  Uncertainty is implicitly quantified by the residuals of the calibration fit; error detection is achieved by monitoring deviations between model predictions and sensor readings.  Quality assurance includes real‑time visualization dashboards, periodic calibration, and a self‑adaptation loop that triggers re‑calibration and controller re‑configuration when anomalies are detected.  These processes collectively ensure that both the models and the underlying data maintain high fidelity and validity throughout the DT lifecycle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All communication between the DT components is carried over RabbitMQ, an AMQP 0‑9‑1 compliant message broker running on the same Raspberry Pi 4. The controller and the low‑level driver act as AMQP clients, publishing and subscribing to queues that carry sensor data and control commands. No explicit network topology beyond the local host is described; the system relies on the reliability features of RabbitMQ (message persistence and acknowledgements) but does not specify additional redundancy or security mechanisms."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed entirely on a single Raspberry Pi 4 Model B. The Raspberry Pi hosts the RabbitMQ broker, the controller, the low‑level driver, and a local time‑series database used for real‑time visualization of the incubator status. All components run on the Pi’s onboard resources; no external cloud or edge servers are used. The deployment is on‑premise, with the Pi acting as both the physical twin controller and the digital twin host."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The system integrates with external systems only through the RabbitMQ broker, which is a standard open‑source message‑broker supporting AMQP. No other external protocols (e.g., MQTT, OPC UA) are mentioned. The repository on GitHub provides the source code and configuration, but no integration with enterprise ERP, MES, or cloud services is described. Therefore, horizontal integration is limited to the local RabbitMQ broker and the GitHub repository for code distribution."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Not in Document.  The implementation uses RabbitMQ as the message broker and standard open‑source hardware (Raspberry Pi 4, DS18S20 sensors, MOSFETs, optocouplers) but does not reference any industry standards, certification requirements, or interoperability frameworks."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The system incorporates several safety‑centric mechanisms. The low‑level driver includes a safe protocol that ensures the device remains in a safe state by periodically reading temperature data, checking for controller commands, and uploading data to the communication server. The controller implements a bang‑bang control strategy with defined lower and upper temperature limits (LL, UL), heating duration (H), and waiting duration (C) to prevent overheating. The Digital Twin framework monitors real‑time data and uses a Kalman filter (Model B) for anomaly detection and heat‑bed state estimation; detected violations can trigger human or algorithmic intervention. The DT also performs real‑time visualization, on‑demand calibration, and what‑if simulations to maintain safe operation. No explicit cybersecurity protocols, authentication mechanisms, or data‑privacy measures are described in the documents."
]