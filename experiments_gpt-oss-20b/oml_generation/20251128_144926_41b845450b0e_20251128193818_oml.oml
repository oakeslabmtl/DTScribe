// Acting Components
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan actuator providing air circulation with voltage control (12V baseline, 18V uniform‑temperature experiment)."
]

instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed actuator driven via MOSFETs isolated by optocouplers, controlled by heating duration (H) and cooldown period (C)."
]

// Sensing Components
instance TemperatureSensorT1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor positioned outside the styrofoam box, measuring ambient room temperature."
    DTDFVocab:producedData TemperatureDataTransmittedT1
]

instance TemperatureSensorT2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor positioned inside the box near the heat‑bed, capturing local temperature."
    DTDFVocab:producedData TemperatureDataTransmittedT2
]

instance TemperatureSensorT3 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor positioned inside the box farthest from the heat‑bed, capturing temperature gradient."
    DTDFVocab:producedData TemperatureDataTransmittedT3
]

// Data Transmitted
instance TemperatureDataTransmittedT1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT1
    DTDFVocab:fromData TemperatureDataReadingT1
]

instance TemperatureDataTransmittedT2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT2
    DTDFVocab:fromData TemperatureDataReadingT2
]

instance TemperatureDataTransmittedT3 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT3
    DTDFVocab:fromData TemperatureDataReadingT3
]

// Data
instance TemperatureDataReadingT1 : DTDFVocab:Data [
    base:desc "Temperature reading from T1 sensor, published to RabbitMQ."
    DTDFVocab:inputTo EnablerRabbitMQ
]

instance TemperatureDataReadingT2 : DTDFVocab:Data [
    base:desc "Temperature reading from T2 sensor, published to RabbitMQ."
    DTDFVocab:inputTo EnablerRabbitMQ
]

instance TemperatureDataReadingT3 : DTDFVocab:Data [
    base:desc "Temperature reading from T3 sensor, published to RabbitMQ."
    DTDFVocab:inputTo EnablerRabbitMQ
]

// Enablers
instance EnablerRabbitMQ : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker facilitating communication between low‑level driver, controller, and DT services."
    DTDFVocab:enables ServiceMonitoring, ServiceDashboard, ServiceKalmanFilter, ServiceCalibration, ServiceWhatIfSimulation, ServiceSelfAdaptation
]

instance EnablerModelProcessing : DTDFVocab:Enabler [
    base:desc "Processing layer enabling services that require thermal model predictions."
    DTDFVocab:enables ServiceKalmanFilter, ServiceWhatIfSimulation, ServiceCalibration
]

// Services
instance ServiceMonitoring : DTDFVocab:Service [
    base:desc "Service ingesting temperature data streams for real‑time monitoring."
    DTDFVocab:provides InsightRealTimeStatus
]

instance ServiceDashboard : DTDFVocab:Service [
    base:desc "Dashboard rendering real‑time visualization of incubator status."
    DTDFVocab:provides InsightRealTimeStatus
]

instance ServiceKalmanFilter : DTDFVocab:Service [
    base:desc "Kalman filter fusing ModelB predictions with sensor data for anomaly detection and heat‑bed state estimation."
    DTDFVocab:provides InsightAnomalyDetection
]

instance ServiceCalibration : DTDFVocab:Service [
    base:desc "On‑demand calibration service for ModelA and ModelB using experimental temperature trajectories."
    DTDFVocab:provides InsightCalibrationResult
]

instance ServiceWhatIfSimulation : DTDFVocab:Service [
    base:desc "Co‑simulation service enabling what‑if analysis of controller parameters via ModelB."
    DTDFVocab:provides InsightWhatIfSimulationResult
]

instance ServiceSelfAdaptation : DTDFVocab:Service [
    base:desc "Self‑adaptation loop detecting behavioural changes, scheduling experiments, recalibrating models, and re‑optimising controller."
    DTDFVocab:provides ActionRecalibrateModel, ActionUpdateControllerParameters, ActionRunOptimization, ActionDeployUpdatedController
]

// Insights
instance InsightRealTimeStatus : DTDFVocab:Insight [
    base:desc "Real‑time status visualization of temperature, heat‑bed state, and controller status."
]

instance InsightAnomalyDetection : DTDFVocab:Insight [
    base:desc "Anomaly detection alerts based on Kalman filter innovation thresholds."
]

instance InsightCalibrationResult : DTDFVocab:Insight [
    base:desc "Result of on‑demand calibration of thermal models."
]

instance InsightWhatIfSimulationResult : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectories from what‑if co‑simulation."
]

instance InsightSelfAdaptationDecision : DTDFVocab:Insight [
    base:desc "Decision output of self‑adaptation loop for re‑deployment of controller."
]

// Actions
instance ActionRecalibrateModel : DTDFVocab:Action [
    base:desc "Recalibrate ModelB using latest experimental data."
    DTDFVocab:IsAutomatic true
]

instance ActionUpdateControllerParameters : DTDFVocab:Action [
    base:desc "Update controller parameters (LL, UL, H, C) based on optimisation results."
    DTDFVocab:IsAutomatic true
]

instance ActionRunOptimization : DTDFVocab:Action [
    base:desc "Run optimisation simulation to find optimal controller settings."
    DTDFVocab:IsAutomatic true
]

instance ActionDeployUpdatedController : DTDFVocab:Action [
    base:desc "Deploy updated controller configuration to Raspberry Pi."
    DTDFVocab:IsAutomatic true
]

// Models
instance ModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model with two free parameters: C_air = 616.56 J/K, G_box = 0.65 J/K."
    DTDFVocab:inputTo EnablerModelProcessing
]

instance ModelB : DTDFVocab:Model [
    base:desc "Analytical thermal model with four free parameters: C_air = 486.12 J/K, G_box = 0.856 J/K, C_heater = 33.65 J/K, G_heater = 0.87 J/K."
    DTDFVocab:inputTo EnablerModelProcessing
]

// Components
instance ComponentFanActuator : DTDFVocab:Component [
    base:desc "Fan actuator providing air circulation."
]

instance ComponentHeatBedActuator : DTDFVocab:Component [
    base:desc "Heat‑bed actuator driven by MOSFETs."
]

instance ComponentLowLevelDriver : DTDFVocab:Component [
    base:desc "Low‑level driver abstracting sensor bus and actuator control, publishing states to RabbitMQ."
]

instance ComponentController : DTDFVocab:Component [
    base:desc "Bang‑bang temperature controller implemented on Raspberry Pi 4 Model B."
]

instance ComponentRaspberryPi : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running controller and low‑level driver."
]

instance ComponentCustomPCB : DTDFVocab:Component [
    base:desc "Custom PCB driving heat‑bed via MOSFETs isolated by optocouplers."
]

instance ComponentRabbitMQBroker : DTDFVocab:Component [
    base:desc "RabbitMQ message broker for synchronisation."
]

instance ComponentTimeSeriesDatabase : DTDFVocab:Component [
    base:desc "Time‑series database storing historical sensor data."
]

instance ComponentDashboard : DTDFVocab:Component [
    base:desc "Dashboard rendering real‑time visualization."
]

instance ComponentKalmanFilterEngine : DTDFVocab:Component [
    base:desc "Kalman filter engine for anomaly detection."
]

instance ComponentWhatIfSimulationEngine : DTDFVocab:Component [
    base:desc "Co‑simulation engine for what‑if analysis."
]

instance ComponentSelfAdaptationLoop : DTDFVocab:Component [
    base:desc "Self‑adaptation loop orchestrating experiments and re‑deployment."
]

// Environment
instance EnvironmentIncubator : DTDFVocab:Environment [
    base:contains ComponentFanActuator, ComponentHeatBedActuator, ComponentLowLevelDriver, ComponentController, ComponentRaspberryPi, ComponentCustomPCB, ComponentRabbitMQBroker, ComponentTimeSeriesDatabase, ComponentDashboard, ComponentKalmanFilterEngine, ComponentWhatIfSimulationEngine, ComponentSelfAdaptationLoop
]


instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The controller, implemented on the Raspberry Pi, receives temperature measurements from the DT via RabbitMQ and executes a bang‑bang control strategy. When the measured temperature falls below the lower limit (LL) or rises above the upper limit (UL), the controller publishes a command message to RabbitMQ. The low‑level driver consumes these command messages, validates them against the safe‑protocol, and translates them into GPIO signals that drive MOSFETs (isolated by optocouplers) to switch the heatbed and fan on or off. The driver also publishes the current actuator state back to RabbitMQ so that the DT can monitor the physical state. Command execution confirmation is implicit in the state‑update messages; no explicit ACK mechanism is described."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT system is orchestrated around an asynchronous message broker (RabbitMQ) that decouples the physical twin (PT) components – a Raspberry Pi‑based controller and a low‑level driver – from the digital twin services. The controller consumes temperature readings published by the low‑level driver, executes a bang‑bang control loop, and publishes control commands back to RabbitMQ. Digital twin services subscribe to the same message stream: a Kalman‑filter module estimates the unmeasured heat‑bed temperature, a co‑simulation engine performs what‑if analyses using the calibrated Model B, and a self‑adaptation loop monitors anomalies, schedules experiments, recalibrates the model, and re‑configures the controller. All services run as independent processes (or containers) on the same host or distributed across the network, sharing a time‑series database for real‑time visualization. This event‑driven, message‑centric architecture enables modular scaling and clear separation of responsibilities between the PT and DT layers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The incubator Digital Twin follows a multi‑phase lifecycle that mirrors the classic CPS development cycle. 1) **Physical Twin (PT) construction** – the insulated styrofoam box, heatbed, fan, Raspberry Pi controller, DS18S20 temperature sensors, MOSFET driver board and optocouplers are assembled and wired (see Fig. 3‑5). 2) **Model development** – two lumped‑parameter thermal models are derived; Model A uses two free parameters, Model B uses four, capturing the heatbed’s thermal inertia. 3) **Calibration** – controlled experiments are run and the parameters of Model B are tuned using a calibration algorithm that minimizes the error between measured and simulated temperatures. 4) **Digital Twin deployment** – a RabbitMQ message broker (AMQP 0‑9‑1) runs on the Pi, the low‑level driver publishes sensor data and receives actuator commands, the controller implements a bang‑bang logic with H, C, LL, UL parameters, and the DT streams data to a time‑series database for real‑time dashboards. 5) **Runtime monitoring & adaptation** – a Kalman filter estimates the unmeasured heatbed temperature and flags anomalies; a self‑adaptation loop schedules experiments, re‑calibrates Model B, re‑configures the Kalman filter and controller, and runs what‑if co‑simulations to optimise controller settings. 6) **Evolution & governance** – all code and model artefacts are versioned in a public GitHub repository (https://github.com/INTO‑CPS‑Association/example‑incubator), enabling traceability, peer review and incremental updates.  Transitions between phases are managed by the calibration and adaptation algorithms, which replace model parameters and controller settings while preserving the PT‑DT coupling."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Calibration experiments were performed using the optimized sensor setup (Fig. 11) to generate a data trajectory. Model parameters were estimated (see Document 5) and the resulting models were validated by comparing simulated temperature profiles to measured data (Figure 13). Model B demonstrated a better fit for the heat‑bed inertia compared to Model A. The calibration process and validation results are documented, and the calibrated parameters are used to update the DT models. No explicit confidence intervals or residual‑based re‑calibration procedures are described in the documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT’s communication backbone is a single‑node RabbitMQ broker running on the same Raspberry Pi 4 B that hosts the controller and low‑level driver. Components communicate over the local network using the AMQP protocol. The broker is configured for lightweight, in‑memory queues suitable for the low‑latency requirements of the incubator control loop. No external network interfaces are used; all traffic stays within the local network segment. The documents do not specify bandwidth, latency, redundancy, or security mechanisms; the broker is assumed to be unsecured and non‑persistent, relying on the reliability of the Pi’s local storage."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire DT stack is deployed on a single Raspberry Pi 4 Model B. The Pi runs the RabbitMQ broker, the low‑level driver, and the controller logic. Sensor polling, message routing, and simple control logic are performed locally, eliminating the need for external cloud services. The deployment is on‑premise, edge‑based, and self‑contained. Scalability is limited to the Pi’s resources; for larger deployments, additional Pi nodes or a clustered RabbitMQ setup would be required, but such extensions are not described in the documents."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol that keeps the device in a safe state by periodically reading temperature data and validating commands from the controller via RabbitMQ. The controller implements a bang‑bang control strategy with defined lower and upper temperature limits, heating duration, and waiting duration to prevent overheating. No explicit cybersecurity protocols, access control, or authentication mechanisms are described in the documents."
]