// Sensing Components
instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor positioned outside the insulated incubator box to measure ambient room temperature."
    DTDFVocab:producedData AmbientTempDataTransmitted
]

instance HotSpotTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor placed inside the incubator at the hottest location."
    DTDFVocab:producedData HotSpotTempDataTransmitted
]

instance ColdSpotTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor placed inside the incubator at the coldest location."
    DTDFVocab:producedData ColdSpotTempDataTransmitted
]

// Data Transmitted
instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

instance HotSpotTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HotSpotTemperatureSensor
]

instance ColdSpotTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ColdSpotTemperatureSensor
]

// Data
instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Ambient temperature reading in °C published by AmbientTemperatureSensor."
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo LowLevelDriverEnabler
]

instance HotSpotTemperatureData : DTDFVocab:Data [
    base:desc "Hot‑spot temperature reading in °C published by HotSpotTemperatureSensor."
    DTDFVocab:fromData HotSpotTempDataTransmitted
    DTDFVocab:inputTo LowLevelDriverEnabler
]

instance ColdSpotTemperatureData : DTDFVocab:Data [
    base:desc "Cold‑spot temperature reading in °C published by ColdSpotTemperatureSensor."
    DTDFVocab:fromData ColdSpotTempDataTransmitted
    DTDFVocab:inputTo LowLevelDriverEnabler
]

// Model Output Data Transmitted
instance ModelAOutputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ModelAComponent
]

instance ModelBOutputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ModelBComponent
]

instance KalmanFilterOutputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom KalmanFilterComponent
]

instance CalibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CalibrationRoutineComponent
]

instance WhatIfSimulationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WhatIfSimulationComponent
]

instance SelfAdaptationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SelfAdaptationLoopComponent
]

// Model Output Data
instance ModelAOutputData : DTDFVocab:Data [
    base:desc "Output of ModelA used for predictive simulation."
    DTDFVocab:fromData ModelAOutputDataTransmitted
    DTDFVocab:inputTo ModelAEnabler
]

instance ModelBOutputData : DTDFVocab:Data [
    base:desc "Output of ModelB used for predictive simulation."
    DTDFVocab:fromData ModelBOutputDataTransmitted
    DTDFVocab:inputTo ModelBEnabler
]

instance KalmanFilterOutputData : DTDFVocab:Data [
    base:desc "Kalman filter estimate of heatbed temperature for anomaly detection and state estimation."
    DTDFVocab:fromData KalmanFilterOutputDataTransmitted
    DTDFVocab:inputTo KalmanFilterEnabler
]

instance CalibrationData : DTDFVocab:Data [
    base:desc "Calibration data for ModelB parameters obtained on demand."
    DTDFVocab:fromData CalibrationDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler
]

instance WhatIfSimulationData : DTDFVocab:Data [
    base:desc "Co‑simulation results for what‑if scenario analysis."
    DTDFVocab:fromData WhatIfSimulationDataTransmitted
    DTDFVocab:inputTo WhatIfSimulationEnabler
]

instance SelfAdaptationData : DTDFVocab:Data [
    base:desc "Data generated by the self‑adaptation loop for controller re‑deployment."
    DTDFVocab:fromData SelfAdaptationDataTransmitted
    DTDFVocab:inputTo SelfAdaptationEnabler
]

// Enablers
instance LowLevelDriverEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level driver abstracts sensor/actuator communication, enforces a safe protocol, and reads sensor data."
    DTDFVocab:enables RealTimeMonitoringService
]

instance ModelAEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for ModelA outputs used in predictive simulation."
    DTDFVocab:enables PredictiveSimulationService
]

instance ModelBEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for ModelB outputs used in predictive simulation."
    DTDFVocab:enables PredictiveSimulationService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for Kalman filter outputs used in anomaly detection and state estimation."
    DTDFVocab:enables AnomalyDetectionService, StateEstimationService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for calibration data used to update ModelB parameters."
    DTDFVocab:enables CalibrationService
]

instance WhatIfSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for what‑if simulation data used in scenario analysis."
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for self‑adaptation data used to trigger controller re‑deployment."
    DTDFVocab:enables SelfAdaptationService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature, fan, and heatbed status."
    DTDFVocab:provides RealTimeDashboardInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation using ModelA and ModelB to forecast temperature dynamics."
    DTDFVocab:provides PredictiveSimulationInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection using Kalman filter to identify deviations beyond threshold."
    DTDFVocab:provides AnomalyDetectionInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "State estimation of unmeasured heatbed temperature via Kalman filter."
    DTDFVocab:provides StateEstimationInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "On‑demand calibration of ModelB parameters against experimental data."
    DTDFVocab:provides CalibrationInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Co‑simulation of PT and DT for what‑if scenario analysis."
    DTDFVocab:provides WhatIfSimulationInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Self‑adaptation loop that schedules experiments, recalibrates models, re‑optimizes controller, and redeploys."
    DTDFVocab:provides AdaptiveDecisionLoopInsight
]

// Insights
instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Live temperature plots and controller status displayed via web dashboard."
]

instance PredictiveSimulationInsight : DTDFVocab:Insight [
    base:desc "Forecast temperature dynamics using ModelA and ModelB."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Kalman filter detects deviations beyond threshold and triggers alerts."
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Kalman filter estimates unmeasured heatbed temperature."
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "On‑demand calibration of ModelB parameters against experimental data."
]

instance WhatIfSimulationInsight : DTDFVocab:Insight [
    base:desc "Co‑simulation of PT and DT to explore alternative controller parameters."
]

instance AdaptiveDecisionLoopInsight : DTDFVocab:Insight [
    base:desc "Self‑adaptation loop schedules experiments, recalibrates models, re‑optimizes controller, and redeploys."
]

instance UserInteractionInsight : DTDFVocab:Insight [
    base:desc "Operators interact via dashboard, receive alerts, and can manually trigger experiments or override controller settings."
]

instance ConfidenceMeasureInsight : DTDFVocab:Insight [
    base:desc "Confidence inferred from Kalman filter estimation error covariance and calibration fit quality."
]

// Actions
instance ManualExperimentTriggerAction : DTDFVocab:Action [
    base:desc "Operator manually triggers an experiment via dashboard."
    DTDFVocab:IsAutomatic false
]

instance OverrideControllerSettingsAction : DTDFVocab:Action [
    base:desc "Operator overrides controller parameters LL, UL, H, C."
    DTDFVocab:IsAutomatic false
]

instance RedeployControllerAction : DTDFVocab:Action [
    base:desc "Redeploy updated controller to Raspberry Pi."
    DTDFVocab:IsAutomatic true
]

// Environments
instance RaspberryPiEnvironment : DTDFVocab:Environment [
    base:contains RaspberryPiComponent, LowLevelDriverComponent, BangBangControllerComponent, RabbitMQBrokerComponent, TimeSeriesDatabaseComponent, DashboardComponent, KalmanFilterComponent, ModelAComponent, ModelBComponent, CalibrationRoutineComponent, WhatIfSimulationComponent, SelfAdaptationLoopComponent
]

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains IncubatorBoxComponent, HeatbedComponent, FanComponent
]

// Components
instance RaspberryPiComponent : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B acting as controller."
]

