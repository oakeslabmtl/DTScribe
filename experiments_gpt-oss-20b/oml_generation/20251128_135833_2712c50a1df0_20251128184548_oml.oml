    base:desc "Low‑level driver on Raspberry Pi that reads sensors and issues actuator commands."
]

instance BangBangControllerComponent : DTDFVocab:Component [
    base:desc "Bang‑bang controller implemented on Raspberry Pi controlling heatbed."
]

instance RabbitMQBrokerComponent : DTDFVocab:Component [
    base:desc "RabbitMQ message broker running on Raspberry Pi for synchronization."
]

