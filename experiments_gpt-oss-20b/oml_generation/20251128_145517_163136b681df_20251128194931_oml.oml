// C2: Acting Components
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan powered at either 12 V or 18 V, commanded by the controller via RabbitMQ messages, used for airflow control."
]

instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed controlled by a bang‑bang controller with parameters LL, UL, H, C, turning heater on until temperature reaches UL then cooling for C."
]

// C3: Physical sensing components
instance TemperatureSensorT1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor positioned outside the insulated box to measure ambient room temperature."
    DTDFVocab:producedData TemperatureReadingT1
]

instance TemperatureSensorT2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor placed at the hottest point inside the box."
    DTDFVocab:producedData TemperatureReadingT2
]

instance TemperatureSensorT3 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor placed at the coldest point inside the box."
    DTDFVocab:producedData TemperatureReadingT3
]

// C4: Physical-to-virtual interaction
instance TemperatureReadingT1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT1
]

instance TemperatureReadingT2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT2
]

instance TemperatureReadingT3 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT3
]

// C10: Models/Data
instance TemperatureDataT1 : DTDFVocab:Data [
    base:desc "Temperature data for ambient temperature, derived from TemperatureReadingT1."
    DTDFVocab:fromData TemperatureReadingT1
    DTDFVocab:inputTo LowLevelDriverEnabler
]

instance TemperatureDataT2 : DTDFVocab:Data [
    base:desc "Temperature data for hot spot, derived from TemperatureReadingT2."
    DTDFVocab:fromData TemperatureReadingT2
    DTDFVocab:inputTo LowLevelDriverEnabler
]

instance TemperatureDataT3 : DTDFVocab:Data [
    base:desc "Temperature data for cold spot, derived from TemperatureReadingT3."
    DTDFVocab:fromData TemperatureReadingT3
    DTDFVocab:inputTo LowLevelDriverEnabler
]

instance ModelA : DTDFVocab:Model [
    base:desc "Two-parameter thermal model with C_air=616.56 J/K and G_box=0.65 J/K."
    DTDFVocab:inputTo WhatIfSimulationEngineEnabler
]

instance ModelB : DTDFVocab:Model [
    base:desc "Extended thermal model with additional parameters C_heater=33.65 J/K and G_heater=0.87 J/K, retaining C_air=486.12 J/K and G_box=0.856 J/K."
    DTDFVocab:inputTo WhatIfSimulationEngineEnabler
]

// C11: Enablers
instance LowLevelDriverEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level driver abstracts sensor/actuator communication, reads sensors, enforces safe protocol, publishes to RabbitMQ."
    DTDFVocab:enables RealTimeMonitoringService, OnDemandCalibrationService, AnomalyDetectionService, WhatIfSimulationService, SelfAdaptationService
]

instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on Raspberry Pi, routes control commands and sensor data."
    DTDFVocab:enables RealTimeMonitoringService, OnDemandCalibrationService, AnomalyDetectionService, WhatIfSimulationService, SelfAdaptationService
]

instance CalibrationRoutineEnabler : DTDFVocab:Enabler [
    base:desc "Automated calibration routine that updates ModelB parameters based on measured temperature data."
    DTDFVocab:enables OnDemandCalibrationService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter for heatbed state estimation and anomaly detection."
    DTDFVocab:enables AnomalyDetectionService
]

instance WhatIfSimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Co‑simulation engine that runs what‑if simulations with historical or live PT data."
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationLoopEnabler : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop that detects plant behaviour changes, schedules experiments, re‑calibrates, re‑configures, and optimizes performance."
    DTDFVocab:enables SelfAdaptationService
]

instance TimeSeriesDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Time‑series database (InfluxDB/Prometheus) storing sensor data for real‑time monitoring."
    DTDFVocab:enables RealTimeMonitoringService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard front‑end for real‑time visualization."
    DTDFVocab:enables RealTimeMonitoringService
]

instance CoSimulationFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Framework linking PT data stream to simulation models for scenario analysis."
    DTDFVocab:enables WhatIfSimulationService
]

instance GitHubRepositoryEnabler : DTDFVocab:Enabler [
    base:desc "GitHub repository hosting source code, documentation, datasets, and version control."
    DTDFVocab:enables OnDemandCalibrationService, SelfAdaptationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring and visualization of incubator status via time‑series database and dashboard."
    DTDFVocab:provides RealTimeDashboardInsight
]

instance OnDemandCalibrationService : DTDFVocab:Service [
    base:desc "On‑demand calibration of ModelB using automated routines."
    DTDFVocab:provides CalibrationUpdateAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection and heatbed state estimation via Kalman filter."
    DTDFVocab:provides AnomalyDetectionInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What‑if simulation capability running co‑simulations with historical or live PT data."
    DTDFVocab:provides WhatIfSimulationInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Self‑adaptation loop that detects changes, schedules experiments, re‑calibrates, re‑configures, and optimizes performance."
    DTDFVocab:provides SelfAdaptationInsight
]

// C17: Insights/Actions
instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time dashboard displaying incubator status."
]

instance CalibrationUpdateAction : DTDFVocab:Action [
    base:desc "Action to update ModelB parameters after calibration."
    DTDFVocab:IsAutomatic false
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight flagging deviations in heatbed temperature."
]

instance WhatIfSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight evaluating impact of controller parameter changes."
]

instance SelfAdaptationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating optimized controller settings after self‑adaptation."
]

// C3: Components
instance IncubatorPhysicalTwin : DTDFVocab:Component [
    base:desc "Laboratory incubator with insulated styrofoam box, heatbed, fan, sensors, Raspberry Pi controller."
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B acting as controller, running bang‑bang logic and communicating via RabbitMQ."
]

instance LowLevelDriverComponent : DTDFVocab:Component [
    base:desc "Low‑level driver interfacing sensors and MOSFET‑based heatbed driver via optocouplers."
]

instance RabbitMQBrokerComponent : DTDFVocab:Component [
    base:desc "RabbitMQ broker running on the Pi."
]

instance FanActuatorComponent : DTDFVocab:Component [
    base:desc "Fan actuator component."
]

instance HeatbedActuatorComponent : DTDFVocab:Component [
    base:desc "Heatbed actuator component."
]

// C17: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains IncubatorPhysicalTwin, RaspberryPiController, LowLevelDriverComponent, RabbitMQBrokerComponent, FanActuatorComponent, HeatbedActuatorComponent
]


instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The controller, running on the Raspberry Pi, sends control commands (heatbed on/off, fan on/off, heating duration, waiting duration) to the low‑level driver via RabbitMQ AMQP messages. The command payload is a structured message (likely JSON) containing the action and parameters. The low‑level driver validates the command against a safe protocol to prevent unsafe states, then actuates the MOSFET‑driven heatbed or fan. Feedback is provided by the driver publishing the updated control state back to RabbitMQ, allowing the controller to confirm execution. No explicit authentication or encryption is mentioned; safety is enforced by the driver’s protocol logic."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin operates on a time scale governed by the physical plant’s thermal dynamics and the controller’s bang‑bang logic. The low‑level driver reads temperature sensors periodically (frequency not specified in the documents) and publishes the readings to RabbitMQ. The controller receives these messages, applies a bang‑bang control strategy with heating duration (H) and waiting duration (C) parameters, and publishes actuator commands. The fan’s airflow is 0.02 m³/s in a 0.03 m³ box, implying an air‑mixing time of ≈2 s, which sets a lower bound on the control loop latency. No explicit synchronization frequency or latency requirement is stated, but the system relies on asynchronous message passing via RabbitMQ, which introduces negligible latency on a local network. The digital twin’s temporal granularity is therefore at the level of individual sensor readings and actuator commands, typically on the order of seconds."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation follows a publish/subscribe pattern orchestrated by RabbitMQ. The Raspberry Pi hosts three core components: the communication server (RabbitMQ broker), the low‑level driver (sensor/actuator abstraction), and the controller (bang‑bang logic). The digital twin’s simulation and estimation modules (Kalman filter, Model B calibration, what‑if co‑simulation) run as separate processes or services that consume the same message streams. Resource management is lightweight: the Raspberry Pi’s CPU and memory are shared among the broker, driver, controller, and twin services. System‑wide coordination is achieved by the message queues: each component publishes its state (e.g., temperature, actuator status) and consumes relevant commands, ensuring a loosely coupled, event‑driven architecture."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design & modeling: creation of the physical twin (insulated styrofoam box, heatbed, fan, Raspberry Pi 4, DS18S20 temperature sensors, PCB with MOSFETs and optocouplers) and development of two thermal simulation models (Model A with 2 free parameters, Model B with 4 free parameters). Calibration: on‑demand calibration of Model B using experimental data to update its parameters and improve prediction of heatbed inertia. Deployment: integration of the digital‑twin components—RabbitMQ communication server, low‑level driver, bang‑bang controller—on the Raspberry Pi, with all hardware schematics, firmware and simulation code released as open‑source on GitHub. Operation & monitoring: continuous real‑time data acquisition from the DS18S20 sensors via 1‑Wire bus, real‑time visualization of incubator status in a dashboard, and monitoring for safety and optimal performance. Adaptation & evolution: a self‑adaptation loop that detects anomalies via a Kalman filter, schedules experiments, re‑calibrates Model B, re‑configures the controller, runs what‑if simulations to optimize controller parameters, and finally updates the digital twin accordingly."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing simulated temperature trajectories from Model A and Model B against experimental data collected from the three sensors. Model B, with four free parameters, demonstrates superior predictive performance for the heatbed’s thermal inertia, as evidenced by lower temperature discrepancies (maximum 6 °C vs 7 °C). Calibration experiments provide quantified parameter values, serving as a validation step. Uncertainty sources include sensor noise, unmodeled heat losses, and actuator variability; these are implicitly addressed by the Kalman filter used for anomaly detection and heatbed state estimation. Error detection is performed by monitoring deviations between measured and predicted temperatures; anomalies trigger re‑calibration or controller adjustment. Quality assurance processes involve periodic calibration experiments, comparison of model outputs to real‑time sensor data, and the use of a safe protocol in the low‑level driver to prevent unsafe actuation. The DT framework thus incorporates continuous validation, uncertainty quantification, and corrective mechanisms to maintain model fidelity and data integrity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT communication backbone is a RabbitMQ message broker running locally on the Raspberry Pi 4. The broker implements the AMQP protocol over the Pi’s local network interface (Wi‑Fi or Ethernet). Messages are exchanged between the controller, low‑level driver, and any DT components (e.g., Kalman filter, dashboard) via dedicated queues. The documents do not specify network topology beyond the local host, nor do they provide explicit bandwidth, latency, reliability, redundancy, or security protocol details. The system relies on RabbitMQ’s built‑in message durability and acknowledgment features for reliable delivery."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed on an edge device: a Raspberry Pi 4 Model B (4 GB RAM, 1.5 GHz quad‑core). The communication server (RabbitMQ) and the controller/low‑level driver run directly on the Pi, making the deployment on‑premise and self‑contained. The open‑source repository (https://github.com/INTO-CPS-Association/example-incubator) provides the full hardware schematics, software code, and datasets, enabling replication or extension on similar edge hardware. No cloud or external hosting is described; scalability would require additional Pi nodes or a more powerful edge server, but such extensions are not detailed in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The system integrates with external systems only through RabbitMQ, which can be deployed on‑premises or in the cloud. No specific interoperability standards (e.g., OPC UA, MQTT) are mentioned beyond RabbitMQ’s AMQP protocol. The digital twin does not currently exchange data with other digital twins or enterprise systems; all communication is confined to the local incubator network. Future work may involve exposing the RabbitMQ topics to external services, but such integration is not described in the documents."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol that keeps the device in a safe state by periodically reading temperature data and validating commands from the controller via RabbitMQ. The controller implements a bang‑bang control strategy with defined lower and upper temperature limits, heating duration, and waiting duration to prevent overheating. No explicit cybersecurity protocols, access control, or authentication mechanisms are described in the documents."
]