// Acting Components
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan (12V–18V) for air circulation in the incubator, controlled by the controller via MOSFETs."
]

instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed with on/off capability, driven by MOSFETs and optocouplers on a custom PCB, controlled by the controller."
]

// Physical Sensing Components
instance TemperatureSensorT1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor positioned outside the box to measure ambient room temperature."
    DTDFVocab:producedData TemperatureDataT1
]

instance TemperatureSensorT2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor placed at the hottest point inside the box."
    DTDFVocab:producedData TemperatureDataT2
]

instance TemperatureSensorT3 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor placed at the coldest point inside the box."
    DTDFVocab:producedData TemperatureDataT3
]

// Data Transmitted
instance TemperatureDataT1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT1
]

instance TemperatureDataT2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT2
]

instance TemperatureDataT3 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT3
]

// Data
instance TemperatureReadingT1 : DTDFVocab:Data [
    base:desc "Raw temperature reading from TemperatureSensorT1, used by the controller and DT services."
    DTDFVocab:fromData TemperatureDataT1
    DTDFVocab:inputTo LowLevelDriver, KalmanFilter, CalibrationEngine, SimulationEngine, SelfAdaptationEngine
]

instance TemperatureReadingT2 : DTDFVocab:Data [
    base:desc "Raw temperature reading from TemperatureSensorT2, used by the controller and DT services."
    DTDFVocab:fromData TemperatureDataT2
    DTDFVocab:inputTo LowLevelDriver, KalmanFilter, CalibrationEngine, SimulationEngine, SelfAdaptationEngine
]

instance TemperatureReadingT3 : DTDFVocab:Data [
    base:desc "Raw temperature reading from TemperatureSensorT3, used by the controller and DT services."
    DTDFVocab:fromData TemperatureDataT3
    DTDFVocab:inputTo LowLevelDriver, KalmanFilter, CalibrationEngine, SimulationEngine, SelfAdaptationEngine
]

// Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model A with two free parameters: C_air = 616.56 J/K, G_box = 0.65 J/K, used for simulation."
    DTDFVocab:inputTo SimulationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Analytical thermal model B with four free parameters: C_air = 486.12 J/K, G_box = 0.856 J/K, C_heater = 33.65 J/K, G_heater = 0.87 J/K, used for simulation and Kalman filter."
    DTDFVocab:inputTo KalmanFilter, SimulationEngine, CalibrationEngine
]

// Enablers
instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Python low-level driver that abstracts sensor/actuator communication, publishes sensor data to RabbitMQ, and receives commands, enforcing safe protocol."
    DTDFVocab:enables RealTimeVisualizationService, CalibrationService, AnomalyDetectionService, WhatIfSimulationService, SelfAdaptationService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on the Raspberry Pi, handling AMQP messages for distributed control."
]

instance KalmanFilter : DTDFVocab:Enabler [
    base:desc "Kalman filter implementation that estimates unmeasured heatbed temperature and detects anomalies."
    DTDFVocab:enables AnomalyDetectionService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Automated calibration engine that updates model parameters based on sensor data."
    DTDFVocab:enables CalibrationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Co-simulation engine that runs real-time simulations of the incubator using thermal models."
    DTDFVocab:enables WhatIfSimulationService
]

instance Dashboard : DTDFVocab:Enabler [
    base:desc "Grafana-based dashboard that consumes time-series data from RabbitMQ for real-time visualization."
    DTDFVocab:enables RealTimeVisualizationService
]

instance SelfAdaptationEngine : DTDFVocab:Enabler [
    base:desc "Self-adaptation loop that detects behavioural changes, schedules experiments, recalibrates models, reconfigures Kalman filter and controller, and re-optimises parameters."
    DTDFVocab:enables SelfAdaptationService
]

// Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Service that provides real-time visualization of incubator status via a dashboard consuming time-series data."
    DTDFVocab:provides RealTimeDashboardInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that performs on-demand calibration of the thermal model using automated routines."
    DTDFVocab:provides CalibrationResultInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Service that uses the Kalman filter to detect anomalies and estimate heatbed state."
    DTDFVocab:provides AnomalyDetectedInsight, HeatbedStateEstimatedInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Service that runs what-if simulations with co-simulations of historical or live PT data to optimise controller parameters."
    DTDFVocab:provides WhatIfSimulationResultInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Service that triggers self-adaptation decisions such as reconfiguring controller, recalibrating models, and optimising control parameters."
    DTDFVocab:provides ReconfigureControllerAction, RecalibrateModelAction, OptimizeControlParametersAction, ScheduleExperimentAction
]

// Insights
instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Insight showing real-time status of temperature, fan, and heatbed state."
]

instance CalibrationResultInsight : DTDFVocab:Insight [
    base:desc "Insight summarising calibration results and updated model parameters."
]

instance AnomalyDetectedInsight : DTDFVocab:Insight [
    base:desc "Insight indicating detected anomalies in temperature readings."
]

instance HeatbedStateEstimatedInsight : DTDFVocab:Insight [
    base:desc "Insight estimating the unmeasured heatbed temperature via Kalman filter."
]

instance WhatIfSimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight presenting results of what-if simulation scenarios."
]

// Actions
instance ReconfigureControllerAction : DTDFVocab:Action [
    base:desc "Action to reconfigure controller parameters automatically."
    DTDFVocab:IsAutomatic true
]

instance RecalibrateModelAction : DTDFVocab:Action [
    base:desc "Action to recalibrate the thermal model automatically."
    DTDFVocab:IsAutomatic true
]

instance OptimizeControlParametersAction : DTDFVocab:Action [
    base:desc "Action to optimise controller parameters automatically."
    DTDFVocab:IsAutomatic true
]

instance ScheduleExperimentAction : DTDFVocab:Action [
    base:desc "Action to schedule experiments for model validation."
    DTDFVocab:IsAutomatic true
]

// Physical Components
instance HeatbedComponent : DTDFVocab:Component [
    base:desc "Physical heatbed component of the incubator."
]

instance FanComponent : DTDFVocab:Component [
    base:desc "Physical fan component of the incubator."
]

instance LowLevelDriverComponent : DTDFVocab:Component [
    base:desc "Physical low-level driver hardware component."
]

instance RabbitMQBrokerComponent : DTDFVocab:Component [
    base:desc "Physical RabbitMQ broker component running on the Pi."
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedComponent, FanComponent, TemperatureSensorT1, TemperatureSensorT2, TemperatureSensorT3, LowLevelDriverComponent, RabbitMQBrokerComponent
]


instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The controller component listens to RabbitMQ for control commands that target the fan and the heatbed. Commands are sent as AMQP messages and are interpreted by the controller to toggle the fan and heatbed via GPIO pins. The GPIO signals are isolated through optocouplers and drive MOSFETs that switch the 4 A current required by the heatbed. The controller publishes its current control state back to RabbitMQ, providing feedback to the DT. No explicit authentication, validation, or conflict‑resolution mechanisms are described in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin operates on a real‑time communication loop mediated by RabbitMQ (AMQP). The low‑level driver polls the DS18S20 temperature sensors and publishes the readings to RabbitMQ; the controller on the Raspberry Pi consumes these messages, executes a bang‑bang control logic with heating duration H and waiting duration C (as defined in Fig. 8), and publishes control commands back to RabbitMQ. The fan airflow (0.02 m³/s) and box volume (0.03 m³) imply that the air mixing time is about 2 s, which sets a lower bound on the control loop period. Latency between sensor read and command execution is dominated by RabbitMQ message delivery, typically < 10 ms in the local network. The simulation models (Model A and Model B) and the Kalman filter run at the same sampling rate, providing anomaly detection and heat‑bed state estimation. Thus, the overall time scale of the twin is on the order of seconds, with a sampling period of roughly 1 s and a control loop period of 2–3 s."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital‑twin constellation consists of: (1) Physical twin: styrofoam box, heatbed, fan, three DS18S20 temperature sensors, Raspberry Pi 4 controller, MOSFET/optocoupler PCB. (2) Communication layer: RabbitMQ message broker (AMQP) running on the Pi, used for bi‑directional message passing between the low‑level driver, controller, and digital‑twin services. (3) Data ingestion: low‑level driver publishes sensor readings to RabbitMQ; controller publishes control states. (4) Digital‑twin services: (a) Simulation models (Model A and Model B) that predict internal temperature; (b) Calibration engine that runs on demand to fit Model B parameters; (c) Kalman filter for anomaly detection and heat‑bed state estimation; (d) What‑if simulation engine that performs co‑simulation using historical or real‑time data; (e) Self‑adaptation loop that triggers experiments, re‑calibrates, and re‑configures the controller; (f) Real‑time dashboard that consumes RabbitMQ streams and stores data in a time‑series database. The architecture follows a publish/subscribe pattern with RabbitMQ, and the services are loosely coupled, orchestrated by message flows rather than a central controller."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The case study outlines a multi‑phase lifecycle for the incubator Digital Twin: (1) Physical Twin (PT) construction – insulated box, heatbed, fan, Raspberry Pi controller, DS18S20 sensors, PCB with MOSFETs and optocouplers; (2) Model development – two thermal models (Model A with two free parameters, Model B with four free parameters) built to predict internal temperature and heatbed inertia; (3) Calibration – automatic calibration routine (section 3.3) that adjusts Model B parameters using measured data; (4) Deployment – RabbitMQ communication server, low‑level driver, controller running on Raspberry Pi; (5) Runtime monitoring – real‑time visualization of PT status, Kalman‑filter based anomaly detection and heatbed state estimation; (6) Self‑adaptation – a closed‑loop loop that detects behavior change, schedules experiments, re‑calibrates Model B, re‑configures Kalman filter and controller, and runs what‑if simulations to optimize control; (7) Evolution – iterative refinement of models and control logic through repeated calibration and simulation cycles."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through a dedicated calibration experiment that generates a temperature trajectory used to estimate the free parameters of Models A and B. Model B, with four parameters, captures the heatbed’s thermal inertia more accurately, as evidenced by lower prediction error in the calibration results. Validation is performed by comparing simulated temperature profiles against experimental measurements; discrepancies trigger anomaly detection via a Kalman filter, which also estimates the unmeasured heatbed temperature. Uncertainty sources include sensor noise, model simplifications, and environmental variations; these are mitigated by the Kalman filter’s state estimation and by periodic re‑calibration. Quality assurance is supported by open‑source data and code repositories, enabling reproducibility and peer verification of the DT implementation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The communication backbone is a single‑node RabbitMQ broker running on the Raspberry Pi 4. The broker uses the AMQP protocol (the default for RabbitMQ). All PT–DT interactions occur over this local broker; no external network interfaces are used. The documents do not specify bandwidth, latency, reliability, redundancy, or security features such as TLS or authentication; the broker is assumed to be accessible only locally."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire DT stack (controller, low‑level driver, and RabbitMQ broker) is deployed on a Raspberry Pi 4 Model B. The Pi provides the necessary computation (quad‑core ARM Cortex‑A72, 4 GB RAM) and storage (SD card). The deployment is edge‑based, running on‑premise. No explicit scalability, high‑availability, or cloud integration is described; the system is intended as a single‑node, local deployment."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The system integrates with external systems via RabbitMQ (AMQP) for message exchange. The open‑source repository exposes the hardware and software specifications, allowing integration with other digital‑twin platforms or enterprise systems through standard protocols such as AMQP, HTTP (for dashboard APIs), and MQTT if needed. The time‑series database (not named but likely InfluxDB or similar) can be queried by external analytics tools. No proprietary interoperability standards are mentioned; the design relies on open‑source components and standard protocols, enabling easy integration with other DTs or enterprise systems."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the device in a safe state. It periodically reads temperature data from the incubator and checks for commands from the controller via RabbitMQ. The protocol enforces temperature limits (lower and upper bounds) and includes fail‑safe mechanisms that shut down the heatbed if unsafe conditions are detected. The controller implements a bang‑bang control strategy with defined heating and waiting durations (H and C) and temperature limits (LL and UL), ensuring that the temperature never exceeds the specified bounds. No explicit cybersecurity or authentication mechanisms are described in the documents."
]