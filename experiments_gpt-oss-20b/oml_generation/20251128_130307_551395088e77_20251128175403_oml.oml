// Acting Components
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "0.02 m3/s fan for air circulation"
]

instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed for temperature control"
]

// Sensing Components
instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor measuring ambient room temperature"
    DTDFVocab:producedData AmbientTempDataTransmitted
]

instance HotSpotTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor measuring hottest position inside incubator"
    DTDFVocab:producedData HotSpotTempDataTransmitted
]

instance ColdSpotTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor measuring coldest position inside incubator"
    DTDFVocab:producedData ColdSpotTempDataTransmitted
]

// Data Transmitted
instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
    DTDFVocab:inputTo RabbitMQBroker
]

instance HotSpotTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HotSpotTemperatureSensor
    DTDFVocab:inputTo RabbitMQBroker
]

instance ColdSpotTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ColdSpotTemperatureSensor
    DTDFVocab:inputTo RabbitMQBroker
]

// Data
instance AmbientTempRawData : DTDFVocab:Data [
    base:desc "Raw ambient temperature data stored in time-series database"
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo TimeSeriesDatabase, KalmanFilter, CoSimulationEngine
]

instance HotSpotTempRawData : DTDFVocab:Data [
    base:desc "Raw hot spot temperature data stored in time-series database"
    DTDFVocab:fromData HotSpotTempDataTransmitted
    DTDFVocab:inputTo TimeSeriesDatabase, KalmanFilter, CoSimulationEngine
]

instance ColdSpotTempRawData : DTDFVocab:Data [
    base:desc "Raw cold spot temperature data stored in time-series database"
    DTDFVocab:fromData ColdSpotTempDataTransmitted
    DTDFVocab:inputTo TimeSeriesDatabase, KalmanFilter, CoSimulationEngine
]

// Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker for inter-component communication"
    DTDFVocab:enables RealTimeVisualizationService, OnDemandCalibrationService, AnomalyDetectionService, HeatBedStateEstimationService, WhatIfSimulationService, SelfAdaptationService
]

instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Low-level driver interfacing with PT hardware and publishing actuator states to RabbitMQ"
    DTDFVocab:enables BangBangController
]

instance BangBangController : DTDFVocab:Enabler [
    base:desc "Bang-bang controller implementing LL, UL, H, C logic"
    DTDFVocab:enables FanActuator, HeatBedActuator
]

instance KalmanFilter : DTDFVocab:Enabler [
    base:desc "Kalman filter for anomaly detection and heatbed state estimation"
    DTDFVocab:enables AnomalyDetectionService, HeatBedStateEstimationService
]

instance CoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co-simulation engine for what-if scenarios"
    DTDFVocab:enables WhatIfSimulationService
]

instance Dashboard : DTDFVocab:Enabler [
    base:desc "Dashboard for real-time visualization of incubator status"
    DTDFVocab:enables RealTimeVisualizationService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time-series database storing raw sensor data"
    DTDFVocab:enables OnDemandCalibrationService
]

instance SelfAdaptationEngine : DTDFVocab:Enabler [
    base:desc "Self-adaptation loop for detecting behavioural changes and reconfiguring controller"
    DTDFVocab:enables SelfAdaptationService
]

// Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real-time visualization of incubator status via dashboard"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance OnDemandCalibrationService : DTDFVocab:Service [
    base:desc "On-demand calibration of thermal models using stored data"
    DTDFVocab:provides CalibrationInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection using Kalman filter"
    DTDFVocab:provides AnomalyDetectedInsight
]

instance HeatBedStateEstimationService : DTDFVocab:Service [
    base:desc "Heatbed state estimation using Kalman filter"
    DTDFVocab:provides HeatBedStateEstimateInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What-if simulations through co-simulation of historical or live data"
    DTDFVocab:provides WhatIfSimulationResultInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Self-adaptation loop that schedules experiments and reconfigures controller"
    DTDFVocab:provides SelfAdaptationAction
]

// Insights
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live dashboard view of incubator temperature and actuator states"
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Calibration results for ModelA and ModelB"
]

instance AnomalyDetectedInsight : DTDFVocab:Insight [
    base:desc "Anomaly detected by Kalman filter indicating abnormal temperature behavior"
]

instance HeatBedStateEstimateInsight : DTDFVocab:Insight [
    base:desc "Estimated heatbed temperature from Kalman filter"
]

instance WhatIfSimulationResultInsight : DTDFVocab:Insight [
    base:desc "Results of what-if simulation evaluating controller parameter sets"
]

instance SelfAdaptationAction : DTDFVocab:Action [
    base:desc "Action to schedule experiment, reconfigure controller, and redeploy updated controller"
    DTDFVocab:IsAutomatic true
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains FanActuator, HeatBedActuator, AmbientTemperatureSensor, HotSpotTemperatureSensor, ColdSpotTemperatureSensor, RaspberryPiComponent, CustomPCBComponent, MOSFETsComponent, OptocouplersComponent, RabbitMQBrokerComponent
]

// Components
instance RaspberryPiComponent : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B acting as controller host"
]

instance CustomPCBComponent : DTDFVocab:Component [
    base:desc "Custom PCB with MOSFETs and optocouplers"
]

instance MOSFETsComponent : DTDFVocab:Component [
    base:desc "MOSFETs driven through optocouplers"
]

instance OptocouplersComponent : DTDFVocab:Component [
    base:desc "Optocouplers on custom PCB"
]

instance RabbitMQBrokerComponent : DTDFVocab:Component [
    base:desc "RabbitMQ message broker running on Raspberry Pi"
]


instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The controller, running on the Raspberry Pi, receives the temperature measurements from RabbitMQ and decides on control actions (heatbed on/off, fan on/off). It publishes command messages to RabbitMQ, which the low‑level driver consumes. Commands are simple control signals (e.g., HEAT_ON, FAN_OFF) encoded in a lightweight format (JSON or binary). The low‑level driver validates the command against a safe protocol, executes the actuator via MOSFET/optocoupler circuitry, and can optionally publish an acknowledgment back to RabbitMQ. No explicit authentication or conflict‑resolution mechanisms are described."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The incubator’s Digital Twin operates on a second‑scale time horizon. The low‑level driver periodically polls the DS18S20 temperature sensors and publishes readings to RabbitMQ; the controller consumes these messages, applies a bang‑bang control logic, and publishes actuator commands. The fan’s airflow (0.02 m³/s) and the box volume (0.03 m³) imply an air‑mixing time of ≈2 s, which bounds the fastest observable temperature change. No explicit sampling frequency is specified, but the system is designed to react within a few seconds. RabbitMQ’s lightweight AMQP protocol provides sub‑second latency for message delivery, enabling near real‑time synchronization between the physical plant, the controller, the low‑level driver, and the Digital Twin. The Digital Twin updates its state, runs a Kalman filter, performs calibration, and executes what‑if simulations on a timescale of seconds to minutes, depending on the computational load."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration follows an event‑driven, message‑broker pattern. The Raspberry Pi hosts the controller, low‑level driver, and RabbitMQ server. Sensor readings and actuator commands are exchanged as AMQP messages. The digital twin layer consumes these messages, stores them in a time‑series database (e.g., InfluxDB or similar, though not named), runs a Kalman filter for heatbed state estimation, executes calibration of Model B, and performs what‑if co‑simulations. The self‑adaptation loop triggers new experiments, re‑configures the controller, and updates the twin. Resource management is handled by the Pi’s CPU and memory; computationally intensive tasks (Kalman filter, simulations) can be offloaded to a more powerful host if needed. System‑wide coordination is achieved through the RabbitMQ broker and a publish/subscribe pattern, ensuring loose coupling between physical and digital components."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through an on‑demand calibration experiment that generates a temperature trajectory used to fit the free parameters of Models A and B. The calibration results are compared against measured data (Figure 13) to validate the models. Uncertainty is implicitly addressed by the Kalman‑filter‑based anomaly detector, which estimates the unmeasured heat‑bed temperature and flags deviations. Error detection is performed by monitoring for violations of safety limits and by the Kalman filter’s residual analysis. Quality assurance includes periodic re‑calibration, co‑simulation of what‑if scenarios, and a self‑adaptation loop that schedules new experiments when anomalies are detected."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT infrastructure is built around a RabbitMQ broker running on the same Raspberry Pi that hosts the controller and low‑level driver. Communication uses the AMQP protocol over the local Wi‑Fi network (edge/on‑premise). The topology is a simple client‑server model: the controller and driver act as AMQP clients publishing/subscribing to queues. Bandwidth requirements are minimal (temperature data and control commands are a few bytes per message). Latency is not quantified but is expected to be low enough for the bang‑bang controller. RabbitMQ provides reliable message delivery and persistence; no explicit redundancy or security (TLS/SSL) is mentioned."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed on‑premise at the edge, running on a Raspberry Pi 4 Model B (1.5 GHz quad‑core, 4 GB RAM). Computational load is light: the controller and driver are simple Python/Node scripts, and RabbitMQ runs locally. Storage is local flash; the DT stores historical data in a time‑series database (not specified but implied). Scalability is limited to the single Pi; no horizontal scaling or cloud deployment is described. Availability is not quantified; the system relies on the Pi’s uptime and the reliability of RabbitMQ."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through the RabbitMQ broker, which can be deployed on premises or in the cloud. The digital twin publishes and consumes messages via AMQP, enabling interoperability with other components that can subscribe to the same broker. No explicit MES, SCADA, or other enterprise system integration is described in the documents."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Low‑level driver incorporates a safe protocol that keeps the device in a safe state by periodically reading temperature data and checking for controller commands via RabbitMQ. The DT framework includes monitoring components that evaluate whether the system is performing safely and optimally; anomalies are detected by a Kalman filter that uses Model B to estimate the unmeasured heatbed temperature. The controller implements a bang‑bang strategy with defined lower/upper temperature limits (LL, UL), heating duration (H) and waiting duration (C) to prevent overheating. Calibration algorithms update the physical and environment models, and the self‑adaptation loop schedules experiments, re‑configures the controller, and runs what‑if simulations to maintain safe operation. These mechanisms provide fail‑safe behaviour, real‑time safety monitoring, and adaptive safety‑critical control."
]