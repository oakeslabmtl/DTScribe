// Sensing Components
instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor positioned outside the incubator to measure ambient room temperature."
    DTDFVocab:producedData AmbientTempDataTransmitted
]

instance HotSpotTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor placed at the hottest point inside the incubator."
    DTDFVocab:producedData HotSpotTempDataTransmitted
]

instance ColdSpotTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor placed at the coldest point inside the incubator."
    DTDFVocab:producedData ColdSpotTempDataTransmitted
]

// Data Transmitted from Sensors
instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

instance HotSpotTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HotSpotTemperatureSensor
]

instance ColdSpotTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ColdSpotTemperatureSensor
]

// Data from Sensors
instance AmbientTempData : DTDFVocab:Data [
    base:desc "Ambient room temperature reading in °C."
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo LowLevelDriver, RabbitMQBroker, TimeSeriesDatabase, Dashboard
]

instance HotSpotTempData : DTDFVocab:Data [
    base:desc "Hot spot temperature reading in °C."
    DTDFVocab:fromData HotSpotTempDataTransmitted
    DTDFVocab:inputTo LowLevelDriver, RabbitMQBroker, TimeSeriesDatabase, Dashboard, KalmanFilter, CalibrationRoutine, WhatIfSimulation
]

instance ColdSpotTempData : DTDFVocab:Data [
    base:desc "Cold spot temperature reading in °C."
    DTDFVocab:fromData ColdSpotTempDataTransmitted
    DTDFVocab:inputTo LowLevelDriver, RabbitMQBroker, TimeSeriesDatabase, Dashboard, KalmanFilter, CalibrationRoutine, WhatIfSimulation
]

// Enablers
instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Python/C driver that abstracts low-level communication with the PT, implements a safe protocol, and publishes actuator states to RabbitMQ."
    DTDFVocab:enables RabbitMQBroker
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker handling routing keys such as 'controller.command' and 'driver.state'."
    DTDFVocab:enables RealTimeMonitoringService, CalibrationService, AnomalyDetectionService, WhatIfSimulationService, SelfAdaptationService, ControllerService
]

instance BangBangController : DTDFVocab:Enabler [
    base:desc "Python bang‑bang controller that receives temperature measurements via RabbitMQ, applies LL, UL, H, C logic, and publishes fan/heatbed commands."
    DTDFVocab:enables ControllerService
]

instance KalmanFilter : DTDFVocab:Enabler [
    base:desc "Kalman filter that processes ModelB predictions and sensor data to estimate unmeasured heatbed temperature and detect anomalies."
    DTDFVocab:enables AnomalyDetectionService
]

instance CalibrationRoutine : DTDFVocab:Enabler [
    base:desc "Automated calibration routine that adjusts ModelB parameters to fit measured temperature data."
    DTDFVocab:enables CalibrationService
]

instance WhatIfSimulation : DTDFVocab:Enabler [
    base:desc "Co‑simulation framework that runs what‑if scenarios using historical or real‑time PT data."
    DTDFVocab:enables WhatIfSimulationService
]

instance Dashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboard that visualizes live temperature, controller state, and Kalman filter estimates."
    DTDFVocab:enables RealTimeMonitoringService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "InfluxDB/TimescaleDB instance that stores telemetry for long‑term analysis."
    DTDFVocab:enables RealTimeMonitoringService
]

// Models
instance ModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model with two free parameters: C_air = 616.56 J/K, G_box = 0.65 J/K."
    DTDFVocab:inputTo KalmanFilter, CalibrationRoutine, WhatIfSimulation
]

instance ModelB : DTDFVocab:Model [
    base:desc "Analytical thermal model with four free parameters: C_air = 486.12 J/K, G_box = 0.856 J/K, C_heater = 33.65 J/K, G_heater = 0.87 J/K."
    DTDFVocab:inputTo KalmanFilter, CalibrationRoutine, WhatIfSimulation
]

// Data Transmitted from Models
instance ModelAOutputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ModelA
]

instance ModelBOutputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ModelB
]

// Data from Models
instance ModelATemperaturePredictionData : DTDFVocab:Data [
    base:desc "Predicted internal temperature from ModelA."
    DTDFVocab:fromData ModelAOutputDataTransmitted
    DTDFVocab:inputTo KalmanFilter, CalibrationRoutine, WhatIfSimulation
]

instance ModelBTemperaturePredictionData : DTDFVocab:Data [
    base:desc "Predicted internal temperature from ModelB."
    DTDFVocab:fromData ModelBOutputDataTransmitted
    DTDFVocab:inputTo KalmanFilter, CalibrationRoutine, WhatIfSimulation
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring and visualization of temperature and controller states via a time‑series database and dashboard."
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "On‑demand calibration of ModelB using automated calibration routines."
    DTDFVocab:provides CalibrationAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection and heatbed state estimation through a Kalman filter."
    DTDFVocab:provides AnomalyDetectionInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What‑if simulation capability using co‑simulation of the physical twin and digital twin."
    DTDFVocab:provides WhatIfSimulationInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Self‑adaptation loop that detects changes, schedules experiments, recalibrates, reconfigures, and optimizes controller parameters."
    DTDFVocab:provides DecisionLoopInsight, ExperimentSchedulingAction
]

instance ControllerService : DTDFVocab:Service [
    base:desc "Bang‑bang controller that publishes fan and heatbed commands."
    DTDFVocab:provides FanCommandAction, HeatbedCommandAction, ControllerReconfigurationAction
]

// Insights
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live dashboard plots temperature, controller state, and Kalman filter estimates."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Kalman filter flags deviations from predicted heatbed temperature."
]

instance WhatIfSimulationInsight : DTDFVocab:Insight [
    base:desc "Co‑simulation results evaluate controller parameter changes."
]

instance DecisionLoopInsight : DTDFVocab:Insight [
    base:desc "Anomalies trigger the self‑adaptation loop to update the controller and models."
]

// Actions
instance CalibrationAction : DTDFVocab:Action [
    base:desc "Automated calibration of ModelB parameters."
    DTDFVocab:IsAutomatic true
]

instance ExperimentSchedulingAction : DTDFVocab:Action [
    base:desc "Schedules experiments when plant behavior changes."
    DTDFVocab:IsAutomatic true
]

instance FanCommandAction : DTDFVocab:Action [
    base:desc "Publishes fan voltage command (12 V or 18 V) to the driver."
    DTDFVocab:IsAutomatic true
]

instance HeatbedCommandAction : DTDFVocab:Action [
    base:desc "Turns heatbed on/off according to bang‑bang logic."
    DTDFVocab:IsAutomatic true
]

instance ControllerReconfigurationAction : DTDFVocab:Action [
    base:desc "Updates controller parameters (LL, UL, H, C) based on calibration."
    DTDFVocab:IsAutomatic true
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator, FanActuator, ControllerComponent, LowLevelDriverComponent, RabbitMQServerComponent, RaspberryPiComponent, MOSFETDriverComponent, OptocouplerPCBComponent, ModelAComponent, ModelBComponent, KalmanFilterComponent, CalibrationRoutineComponent, WhatIfSimulationComponent, DashboardComponent, TimeSeriesDatabaseComponent
]

// Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed driven by MOSFETs and optocouplers on a custom PCB."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "0.02 m³/s fan powered at 12 V or 18 V as determined by the controller."
]

instance ControllerComponent : DTDFVocab:Component [
    base:desc "Bang‑bang controller implemented in Python on Raspberry Pi Model B."
]

instance LowLevelDriverComponent : DTDFVocab:Component [
    base:desc "Python/C driver that abstracts sensor/actuator I/O and publishes data to RabbitMQ."
]

instance RabbitMQServerComponent : DTDFVocab:Component [
    base:desc "RabbitMQ v3.x message broker hosted on the Raspberry Pi."
]

instance RaspberryPiComponent : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running Linux, hosting the driver, controller, and communication stack."
]

instance MOSFETDriverComponent : DTDFVocab:Component [
    base:desc "MOSFET drivers and optocouplers on a custom PCB for heatbed current isolation."
]

instance OptocouplerPCBComponent : DTDFVocab:Component [
    base:desc "Optocoupler PCB providing electrical isolation between Raspberry Pi and heatbed."
]

instance ModelAComponent : DTDFVocab:Component [
    base:desc "Implementation of ModelA in MATLAB/Simulink or Python."
]

instance ModelBComponent : DTDFVocab:Component [
    base:desc "Implementation of ModelB in MATLAB/Simulink or Python."
]

instance KalmanFilterComponent : DTDFVocab:Component [
    base:desc "Kalman filter for anomaly detection and heatbed temperature estimation."
]

instance CalibrationRoutineComponent : DTDFVocab:Component [
    base:desc "Automated calibration routine for ModelB."
]

instance WhatIfSimulationComponent : DTDFVocab:Component [
    base:desc "Co‑simulation framework for what‑if scenarios."
]

instance DashboardComponent : DTDFVocab:Component [
    base:desc "Grafana dashboard for real‑time visualization."
]

instance TimeSeriesDatabaseComponent : DTDFVocab:Component [
    base:desc "InfluxDB/TimescaleDB instance for telemetry storage."
]


instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the DT controller and are sent to the low‑level driver via RabbitMQ. The command payloads include fan on/off, heatbed on/off, heating duration (H), waiting duration (C), lower limit (LL) and upper limit (UL) for temperature. The low‑level driver validates each command using a safe protocol that ensures the PT remains in a safe state before execution. After executing a command, the driver publishes the resulting control state (e.g., fan status, heatbed status, current temperature) back to RabbitMQ so that the controller can observe the PT’s response. The documents do not describe explicit authentication tokens, conflict‑resolution logic, or acknowledgement mechanisms beyond this basic publish/subscribe flow."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "No explicit synchronization frequencies, time scales, latency requirements, or temporal granularity are specified in the documents. The only timing information is a 2 s fan circulation time (Doc 6) and that the low‑level driver periodically reads temperature data (Doc 2), but no concrete polling interval or message latency is given."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is implemented as an event‑driven, message‑based constellation. The Raspberry Pi runs a RabbitMQ server (AMQP) that serves as the communication backbone. The controller publishes control commands and receives sensor data via RabbitMQ; the low‑level driver publishes temperature readings and consumes control commands. The DT components subscribe to these topics: a Kalman filter module performs state estimation, a calibration module runs Model B parameter estimation, and a what‑if simulation module performs co‑simulation using the calibrated model. A time‑series database (not named but implied) stores the telemetry, and a dashboard visualizes real‑time status. Resource management is handled locally on the Pi; the architecture follows a publish/subscribe pattern with a single broker, enabling system‑wide coordination through message queues."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin lifecycle in the incubator case study follows four main phases: (1) Physical Twin Design and Build – construction of the insulated box, installation of heatbed, fan, Raspberry Pi, DS18S20 sensors, and PCB with MOSFETs and optocouplers; (2) Modelling and Simulation – development of two thermal models (Model A with two free parameters, Model B with four free parameters) to predict internal temperature and heatbed inertia; (3) Calibration and Integration – automatic on‑demand calibration of Model B using data from the low‑level driver and RabbitMQ communication, integration of the Kalman filter for heatbed state estimation, and deployment of the controller (bang‑bang with LL, UL, H, C parameters) on the Raspberry Pi; (4) Runtime Operation and Self‑Adaptation – real‑time visualization via time‑series database, anomaly detection, what‑if co‑simulation, and a self‑adaptation loop that schedules experiments, re‑calibrates the model, re‑configures the Kalman filter and controller, and closes the loop. Transition management is handled by the RabbitMQ message broker, which synchronises data between the physical twin, low‑level driver, controller, and digital twin components, while governance is supported by open‑source version control (GitHub) and documentation of each phase."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through calibration against experimental data: the free parameters of Model A and Model B are tuned to minimize the error between simulated and measured temperature trajectories. Validation is performed by comparing the calibrated models’ predictions to independent measurement runs, as shown in the calibration plots (Figure 13). Uncertainty in the models arises from parameter estimation errors and sensor noise; these are implicitly addressed by the calibration process. Error detection is handled by the DT’s monitoring component, which checks for unsafe or sub‑optimal system behavior and can trigger fault detectors or supervisory controllers. The low‑level driver’s safe protocol also provides a basic form of error correction by preventing unsafe actuation commands. No explicit Kalman filtering, self‑adaptation loop, or formal quality‑assurance procedures are described in the provided documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT’s communication backbone is a RabbitMQ 3.x broker running locally on the Raspberry Pi 4 Model B. The broker implements the AMQP 0‑9‑1 protocol. The network topology is a simple star: the Pi hosts the broker and all DT components (controller, low‑level driver, and any monitoring services) connect to it over the local Ethernet/Wi‑Fi interface. The documents do not specify bandwidth or latency requirements; RabbitMQ provides asynchronous message queuing. No redundancy, clustering, or TLS encryption is mentioned, so the setup is a single‑node, unencrypted broker."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components – the controller, low‑level driver, and RabbitMQ communication server – are deployed on a single Raspberry Pi 4 Model B. The Pi runs a Linux distribution (not specified) and hosts the message broker and application processes. No external cloud or edge hosting is described, and no scalability or redundancy mechanisms are mentioned. The deployment is therefore a single‑node on‑premise setup with no explicit high‑availability or load‑balancing provisions."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The system integrates with external systems primarily through RabbitMQ, which can be deployed on premises or in the cloud, enabling interoperability via the AMQP protocol. The DT publishes telemetry to a time‑series database and a dashboard, which could be external visualization services. No explicit use of industry standards (e.g., OPC UA) is mentioned. The architecture allows integration with other DTs or enterprise systems by exposing the same AMQP topics, but no concrete integration patterns are described beyond the message broker."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety measures include a safe protocol embedded in the low‑level driver that ensures the incubator remains in a safe state by periodically reading temperature data and enforcing safe limits before issuing actuator commands. The controller implements a bang‑bang control strategy with defined lower (LL) and upper (UL) temperature limits, heating duration (H), and waiting duration (C) to prevent overheating. Monitoring components in the DT continuously evaluate system performance against safety thresholds; anomalies detected by the Kalman filter trigger safety actions. The communication between controller, low‑level driver, and RabbitMQ server is synchronized to maintain safe operation, and the DT framework incorporates fail‑safe mechanisms by re‑configuring the controller after calibration or anomaly detection."
]