instance IncubatorTemperatureReadings : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor, HotSpotTemperatureSensor, ColdSpotTemperatureSensor
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire temperature sensor measuring ambient room temperature outside the insulated box"
    DTDFVocab:producedData IncubatorTemperatureReadings
]

instance HotSpotTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire temperature sensor positioned at the hottest point inside the incubator box"
    DTDFVocab:producedData IncubatorTemperatureReadings
]

instance ColdSpotTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire temperature sensor positioned at the coldest point inside the incubator box"
    DTDFVocab:producedData IncubatorTemperatureReadings
]

instance RawTemperatureData : DTDFVocab:Data [
    base:desc "Raw temperature data stream from the three DS18S20 sensors"
    DTDFVocab:inputTo RabbitMQBroker, TimeSeriesDatabase, KalmanFilterEngine, CalibrationEngine, WhatIfSimulationEngine, SelfAdaptationEngine
    DTDFVocab:fromData IncubatorTemperatureReadings
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker mediating communication between low-level driver, controller, and digital twin components"
    DTDFVocab:enables RealTimeMonitoringService, CalibrationService, AnomalyDetectionService, WhatIfSimulationService, SelfAdaptationService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time-series database storing telemetry data from the incubator"
    DTDFVocab:enables RealTimeMonitoringService
]

instance KalmanFilterEngine : DTDFVocab:Enabler [
    base:desc "Kalman filter engine performing state estimation and anomaly detection"
    DTDFVocab:enables AnomalyDetectionService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Automated calibration routine adjusting ModelB parameters"
    DTDFVocab:enables CalibrationService
]

instance WhatIfSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co-simulation engine running what-if analyses with historical or live data"
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationEngine : DTDFVocab:Enabler [
    base:desc "Self-adaptation loop scheduling experiments, recalibrating models, updating filters, and reconfiguring controller"
    DTDFVocab:enables SelfAdaptationService
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring and visualization of incubator status via dashboard"
    DTDFVocab:provides RealTimeDashboardInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "On-demand calibration of thermal model using automated routines"
    DTDFVocab:provides CalibrationResultInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection and heatbed state estimation via Kalman filter"
    DTDFVocab:provides AnomalyAlertInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What-if simulation capability running co-simulations with historical or live PT data"
    DTDFVocab:provides WhatIfResultInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Self-adaptation loop detecting behavioral changes and reconfiguring system"
    DTDFVocab:provides SelfAdaptationDecisionAction
]

instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Dashboard visualizing temperature, heater/fan state"
]

instance CalibrationResultInsight : DTDFVocab:Insight [
    base:desc "Result of model calibration with updated parameters"
]

instance AnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating deviation from expected behavior"
]

instance WhatIfResultInsight : DTDFVocab:Insight [
    base:desc "Simulation results showing controller performance under parameter changes"
]

instance SelfAdaptationDecisionAction : DTDFVocab:Action [
    base:desc "Decision to schedule experiment, recalibrate, run simulation, and reconfigure controller"
    DTDFVocab:IsAutomatic true
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan driven by 12V or 18V supply, controlled via low-level driver writing to RabbitMQ"
]

instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed controlled by bang-bang heater with duty cycle governed by controller state chart"
]

instance BangBangController : DTDFVocab:Component [
    base:desc "Bang-bang controller implementing LL, UL, H, C parameters"
]

instance LowLevelDriver : DTDFVocab:Component [
    base:desc "Low-level driver reading DS18S20 sensors, publishing to RabbitMQ, applying actuator commands"
]

instance ModelA : DTDFVocab:Model [
    base:desc "Single-parameter heat balance model with C_air=616.56 J/K and G_box=0.65 J/K"
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine
]

instance ModelB : DTDFVocab:Model [
    base:desc "Extended model with C_air=486.12 J/K, G_box=0.856 J/K, C_heater=33.65 J/K, G_heater=0.87 J/K"
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine
]

instance IncubatorPhysicalTwin : DTDFVocab:Component [
    base:desc "Laboratory incubator built as insulated styrofoam box with heatbed, fan, sensors"
]

instance DigitalTwinInstance : DTDFVocab:Component [
    base:desc "Digital twin mirroring incubator state, providing services"
]

instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains IncubatorPhysicalTwin, DigitalTwinInstance
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands for the heatbed and fan are sent from the DT to the Raspberry Pi controller via RabbitMQ messages. The controller receives these commands, translates them into GPIO signals that drive MOSFETs (isolated by optocouplers) to switch the heatbed and fan on or off. No explicit message format, authentication, or confirmation mechanism is described in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin operates on a time scale governed by the physical plant’s thermal dynamics and the controller’s bang‑bang logic. The low‑level driver reads temperature sensors periodically (frequency not specified in the documents) and publishes the readings to RabbitMQ. The controller receives these messages, applies a bang‑bang control strategy with heating duration (H) and waiting duration (C) parameters, and publishes actuator commands. The fan’s airflow is 0.02 m³/s in a 0.03 m³ box, implying an air‑mixing time of ≈2 s, which sets a lower bound on the control loop latency. No explicit synchronization frequency or latency requirement is stated, but the system relies on asynchronous message passing via RabbitMQ, which introduces negligible latency on a local network. The digital twin’s temporal granularity is therefore at the level of individual sensor readings and actuator commands, typically on the order of seconds."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The incubator digital twin is orchestrated as a set of loosely coupled components that communicate via RabbitMQ running on the Raspberry Pi. The controller, low‑level driver, and digital‑twin services (real‑time dashboard, on‑demand calibration, Kalman‑filter based anomaly detection, heat‑bed state estimation, what‑if simulation, and a self‑adaptation loop) all subscribe to and publish messages on RabbitMQ topics. Data from the PT is streamed to a time‑series database (e.g., InfluxDB or similar) and visualised in a dashboard. The DT uses Model B (four‑parameter thermal model) for state estimation and runs a Kalman filter to detect anomalies. Calibration is performed on‑demand by executing a calibration routine that updates Model B parameters. What‑if simulations are performed via co‑simulation that relays historical or real‑time PT data to optimise controller parameters. The entire stack is deployed on the Raspberry Pi, making the architecture effectively centralized but with a message‑driven, event‑based coordination pattern."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The incubator DT lifecycle is articulated in several distinct phases:
1. **Conceptual & Physical Twin (PT) Design** – selection of hardware (Raspberry Pi 4, DS18S20 sensors, MOSFET‑based PCB, fan, heatbed, styrofoam enclosure) and construction of the physical incubator.
2. **Digital Twin (DT) Modeling** – development of two thermal models: Model A (2 free parameters) and Model B (4 free parameters). Model B is chosen for its superior prediction of heatbed inertia.
3. **Calibration & Validation** – experimental runs to fit Model B parameters; calibration is performed on‑demand via a dedicated calibration routine.
4. **Deployment & Runtime Integration** – installation of RabbitMQ as the communication broker, implementation of a low‑level driver (sensor/actuator abstraction), and a bang‑bang controller (LL, UL, H, C parameters) on the Raspberry Pi.
5. **Runtime Monitoring & Insight Generation** – real‑time visualization of PT status in a dashboard, anomaly detection, and heatbed state estimation using a Kalman filter that fuses Model B with sensor data.
6. **Self‑Adaptation Loop** – detection of plant behavior change triggers an experiment schedule, re‑calibration of Model B, re‑configuration of the Kalman filter and controller, and what‑if simulations to re‑optimize control parameters.
7. **Evolution & Governance** – iterative refinement of models and algorithms, with all code and data released as open source (GitHub repository). Transition management is handled by calibration updates that replace model parameters and by the Kalman filter’s state updates, ensuring the DT remains aligned with the PT.

Representation types evolve from a purely physical system to a hybrid PT/DT system comprising hardware, simulation models, data streams, and control algorithms, with governance implied by the open‑source release and iterative calibration cycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model B is calibrated against experimental data from a controlled heating‑cooling cycle, ensuring that the model captures the thermal inertia of the heatbed. Validation is performed by comparing simulated temperature trajectories to the measured sensor data; discrepancies trigger anomaly detection via a Kalman filter that estimates the unmeasured heatbed temperature. When the filter residuals exceed a threshold, the self‑adaptation loop initiates a new calibration experiment, re‑configures the Kalman filter with updated parameters, and re‑optimizes the controller. Safety is guaranteed by the low‑level driver’s safe protocol, which prevents unsafe actuator commands. Data integrity and traceability are maintained through RabbitMQ message logging and persistent storage in a time‑series database, providing a reliable audit trail for model updates and control actions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system uses a local RabbitMQ message broker (AMQP) hosted on the Raspberry Pi 4 Model B. Sensors and actuators connect to the Pi via GPIO (1‑Wire for DS18S20 sensors, GPIO for MOSFET control). Communication between the low‑level driver, controller, and RabbitMQ occurs over the Pi’s Wi‑Fi interface. The documents do not specify bandwidth, latency, or redundancy requirements."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components – low‑level driver, controller, and RabbitMQ server – are deployed on a single Raspberry Pi 4 Model B running Linux. No cloud or edge‑cluster deployment is described; the setup is a single‑node on‑premise deployment with no explicit scalability or high‑availability mechanisms mentioned."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The system integrates with external systems only through RabbitMQ, which can be deployed on‑premises or in the cloud. No specific interoperability standards (e.g., OPC UA, MQTT) are mentioned beyond RabbitMQ’s AMQP protocol. The digital twin does not currently exchange data with other digital twins or enterprise systems; all communication is confined to the local incubator network. Future work may involve exposing the RabbitMQ topics to external services, but such integration is not described in the documents."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The system incorporates several safety mechanisms. The low‑level driver implements a safe protocol that ensures the physical twin remains in a safe state by periodically reading temperature data and checking for controller commands before issuing actuator states. The controller employs a bang‑bang strategy with defined lower and upper temperature limits (LL, UL), heating duration (H), and waiting duration (C) to prevent overheating. The digital twin framework includes real‑time monitoring and anomaly detection via a Kalman filter, which flags deviations from expected behavior and can trigger re‑configuration of the controller. Calibration algorithms update the models with the best parameter estimates, and the DT monitors check for safety violations, allowing human or algorithmic intervention. Communication between components is handled through RabbitMQ, a mature message broker, but the documents do not specify additional cybersecurity protocols, access control, or authentication mechanisms."
]