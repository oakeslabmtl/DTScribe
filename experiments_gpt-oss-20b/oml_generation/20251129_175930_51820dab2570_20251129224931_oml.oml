// Sensing Components
instance T1Sensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire temperature sensor measuring ambient room temperature outside the incubator"
    DTDFVocab:producedData T1DataTransmitted
]

instance T2Sensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire temperature sensor measuring hottest point near the heatbed inside the incubator"
    DTDFVocab:producedData T2DataTransmitted
]

instance T3Sensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire temperature sensor measuring coldest point inside the incubator"
    DTDFVocab:producedData T3DataTransmitted
]

// Data Transmitted
instance T1DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom T1Sensor
]

instance T2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom T2Sensor
]

instance T3DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom T3Sensor
]

// Data
instance T1TemperatureData : DTDFVocab:Data [
    base:desc "Temperature reading from T1 sensor, published via RabbitMQ"
    DTDFVocab:fromData T1DataTransmitted
    DTDFVocab:inputTo SimulationEnabler, KalmanFilterEnabler, CalibrationEnabler, ControllerEnabler, DashboardEnabler, TimeSeriesDBEnabler
]

instance T2TemperatureData : DTDFVocab:Data [
    base:desc "Temperature reading from T2 sensor, published via RabbitMQ"
    DTDFVocab:fromData T2DataTransmitted
    DTDFVocab:inputTo SimulationEnabler, KalmanFilterEnabler, CalibrationEnabler, ControllerEnabler, DashboardEnabler, TimeSeriesDBEnabler
]

instance T3TemperatureData : DTDFVocab:Data [
    base:desc "Temperature reading from T3 sensor, published via RabbitMQ"
    DTDFVocab:fromData T3DataTransmitted
    DTDFVocab:inputTo SimulationEnabler, KalmanFilterEnabler, CalibrationEnabler, ControllerEnabler, DashboardEnabler, TimeSeriesDBEnabler
]

// Models
instance ModelA : DTDFVocab:Model [
    base:desc "Two-parameter thermal model (C_air=616.56 J/K, G_box=0.65 J/K) capturing bulk air dynamics"
    DTDFVocab:inputTo SimulationEnabler
]

instance ModelB : DTDFVocab:Model [
    base:desc "Four-parameter thermal model (C_air=486.12 J/K, G_box=0.856 J/K, C_heater=33.65 J/K, G_heater=0.87 J/K) used for heatbed dynamics"
    DTDFVocab:inputTo SimulationEnabler, KalmanFilterEnabler
]

// Enablers
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for running co-simulation of PT and DT models for what-if analysis"
    DTDFVocab:enables WhatIfSimulationService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for Kalman filter used in heatbed temperature estimation and anomaly detection"
    DTDFVocab:enables AnomalyDetectionService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for on-demand calibration routine fitting ModelB parameters to recent temperature traces"
    DTDFVocab:enables CalibrationService
]

instance ControllerEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for bang-bang temperature controller with tunable parameters LL, UL, H, C"
    DTDFVocab:enables MonitoringService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for dashboard providing live visualization of sensor data and controller states"
    DTDFVocab:enables DashboardService
]

instance TimeSeriesDBEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for time-series database storing sensor streams for monitoring and calibration"
    DTDFVocab:enables MonitoringService
]

instance SelfAdaptationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for self-adaptation loop that detects behavior changes, schedules experiments, recalibrates models, and reconfigures controller"
    DTDFVocab:enables SelfAdaptationService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Service for real-time monitoring of temperature, fan, and heatbed status"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service for on-demand calibration of thermal model (ModelB) using collected data"
    DTDFVocab:provides CalibrationInsight, RecalibrateModelAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Service for anomaly detection and heatbed state estimation via Kalman filter"
    DTDFVocab:provides AnomalyDetectionInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Service for what-if simulation through co-simulation of PT and DT models to optimize controller parameters"
    DTDFVocab:provides WhatIfSimulationInsight, RunWhatIfSimulationAction
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Service for self-adaptation loop detecting behavioral changes, scheduling experiments, recalibrating models, and reconfiguring controller"
    DTDFVocab:provides SelfAdaptationInsight, TriggerExperimentAction
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Service for dashboard providing live visualization of sensor data and controller states"
    DTDFVocab:provides RealTimeMonitoringInsight
]

// Insights
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of temperature, fan, and heatbed status via dashboard"
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "On-demand calibration of thermal model (ModelB) using collected data"
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection and heatbed state estimation via Kalman filter"
]

instance WhatIfSimulationInsight : DTDFVocab:Insight [
    base:desc "What-if simulation through co-simulation of PT and DT models to optimize controller parameters"
]

instance SelfAdaptationInsight : DTDFVocab:Insight [
    base:desc "Self-adaptation loop detecting behavioral changes, scheduling experiments, recalibrating models, and reconfiguring controller"
]

// Actions
instance RecalibrateModelAction : DTDFVocab:Action [
    base:desc "Recalibrate ModelB parameters based on recent temperature traces"
    DTDFVocab:IsAutomatic true
]

instance ReconfigureControllerAction : DTDFVocab:Action [
    base:desc "Reconfigure bang-bang controller parameters after model recalibration"
    DTDFVocab:IsAutomatic true
]

instance RunWhatIfSimulationAction : DTDFVocab:Action [
    base:desc "Run what-if simulation to evaluate controller parameter changes"
    DTDFVocab:IsAutomatic false
]

instance TriggerExperimentAction : DTDFVocab:Action [
    base:desc "Trigger experiment to collect data for model recalibration"
    DTDFVocab:IsAutomatic false
]

// Components
instance HeatbedActuator : DTDFVocab:Component [
    base:desc "MOSFET-based heatbed driver controlled via RabbitMQ"
]

instance FanActuator : DTDFVocab:Component [
    base:desc "0.02 m³/s fan driven by MOSFET, controlled via RabbitMQ"
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running bang-bang controller and low-level driver"
]

instance LowLevelDriver : DTDFVocab:Component [
    base:desc "Low-level driver abstracting sensor/actuator I/O and enforcing safe protocol"
]

instance RabbitMQBroker : DTDFVocab:Component [
    base:desc "RabbitMQ message broker running on the Raspberry Pi for inter-component communication"
]

instance TimeSeriesDatabase : DTDFVocab:Component [
    base:desc "Time-series database storing sensor streams for monitoring and calibration"
]

instance Dashboard : DTDFVocab:Component [
    base:desc "Dashboard for live visualization of sensor data and controller states"
]

instance KalmanFilter : DTDFVocab:Component [
    base:desc "Kalman filter for heatbed temperature estimation and anomaly detection"
]

instance BangBangController : DTDFVocab:Component [
    base:desc "Bang-bang temperature controller with tunable parameters LL, UL, H, C"
]

instance CalibrationRoutine : DTDFVocab:Component [
    base:desc "On-demand calibration routine fitting ModelB parameters to recent temperature traces"
]

instance WhatIfSimulationEngine : DTDFVocab:Component [
    base:desc "Co-simulation engine enabling what-if analysis by running PT and DT models together"
]

instance SelfAdaptationLoop : DTDFVocab:Component [
    base:desc "Self-adaptation loop that detects behavior changes, schedules experiments, recalibrates models, and reconfigures controller"
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator, FanActuator, RaspberryPiController, LowLevelDriver, RabbitMQBroker, TimeSeriesDatabase, Dashboard, KalmanFilter, BangBangController, CalibrationRoutine, WhatIfSimulationEngine, SelfAdaptationLoop
]


instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The controller, also running on the Raspberry Pi 4, subscribes to command queues on the same RabbitMQ broker. Commands (e.g., enable/disable heatbed or fan) are received by the low‑level driver, which validates them against a safe protocol and actuates the hardware via MOSFETs and optocouplers. The driver executes the command and updates the broker with the new state, allowing the controller to confirm completion. No authentication or encryption of control messages is mentioned."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates on a message‑driven loop: the low‑level driver periodically polls the DS18S20 temperature sensors and publishes the readings to a RabbitMQ broker; the controller consumes these messages, executes its bang‑bang control logic, and publishes actuator commands back to the broker. Real‑time dashboards subscribe to the same message stream to provide live status. No explicit polling interval, sub‑second latency, or other quantitative time‑scale requirements are specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a message‑driven, event‑centric architecture. The physical twin comprises the heatbed, fan, and temperature sensors, all connected to a Raspberry Pi 4. The Raspberry Pi runs three software components: a low‑level driver that abstracts sensor/actuator communication, a controller that implements bang‑bang temperature regulation, and a RabbitMQ communication server that publishes sensor readings and consumes control commands. Digital twin services are decoupled from the physical twin via RabbitMQ: a real‑time visualization service subscribes to sensor and control messages and writes them to a time‑series database for dashboard display; a calibration service automatically runs on demand using the collected data; a Kalman filter module estimates unmeasured heatbed temperature; a what‑if simulation engine performs co‑simulations using the calibrated model; and a self‑adaptation loop orchestrates experiments, re‑calibration, and controller re‑configuration. The architecture is therefore a centralized, broker‑based constellation with clear separation of concerns and coordinated through message passing."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by performing calibration experiments that generate a temperature trajectory used to estimate the free parameters of Models A and B. Model B, with four parameters, better captures the thermal inertia of the heatbed and is preferred for further DT development. Validation is performed by comparing model predictions to experimental data; discrepancies are quantified and used to refine parameters. Uncertainty sources include sensor noise, unmodeled heat losses, and simplifications in the lumped‑parameter representation. A Kalman filter is employed for anomaly detection and heatbed state estimation, providing real‑time error correction. The DT framework supports on‑demand calibration, self‑adaptation loops that trigger re‑calibration when anomalies are detected, and continuous monitoring to detect violations of safety or performance constraints. These mechanisms collectively provide quality assurance for both models and data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All communication between the controller, low‑level driver, and the physical sensors/actuators is routed through a RabbitMQ broker hosted on the same Raspberry Pi 4. The broker implements the AMQP protocol (RabbitMQ default). The topology is a single‑node local host; no external network interfaces or redundancy are described. Bandwidth and latency requirements are not quantified in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin stack is deployed entirely on an on‑premise edge device: a Raspberry Pi 4 Model B. The Pi runs the controller, low‑level driver, and RabbitMQ broker, and hosts the physical twin (sensors and actuators). No cloud or external hosting is referenced, and scalability beyond the single Pi is not discussed."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is limited to the use of RabbitMQ (AMQP) for intra‑system communication and the public GitHub repository (https://github.com/INTO-CPS-Association/example-incubator) for code and data distribution. No REST APIs, OPC UA, or other enterprise interoperability standards are mentioned, and no integration with other external digital twins or enterprise systems is described."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the device in a safe state. The DT monitors use the data and models to check whether the system is performing safely and optimally. Anomalies detected by the Kalman filter trigger the self‑adaptation loop, which schedules experiments, re‑configures the controller, and runs what‑if simulations to optimize controller behavior. The controller is a bang‑bang controller with lower and upper temperature limits (LL, UL), heating duration (H), and waiting duration (C) to prevent overheating. The communication between the controller and low‑level driver is handled via RabbitMQ, which provides reliable message delivery but is not a security mechanism. No explicit cybersecurity protocols, access control, authentication, or threat mitigation strategies are described in the documents."
]