// C2: Acting Components
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan mounted inside the insulated box, powered by 12 V or 18 V supply; higher voltage increases airflow and improves temperature uniformity."
]

instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed controlled by a bang‑bang controller on a Raspberry Pi; heating commands turn the heatbed on for duration H seconds followed by waiting period C seconds."
]

// C3: Physical sensing components
instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located outside the insulated box to capture ambient temperature."
    DTDFVocab:producedData AmbientTemperatureDataTransmitted
]

instance HotSpotTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor positioned inside the box at the hottest point."
    DTDFVocab:producedData HotSpotTemperatureDataTransmitted
]

instance ColdSpotTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor positioned inside the box at the coldest point."
    DTDFVocab:producedData ColdSpotTemperatureDataTransmitted
]

// C4: Physical-to-virtual interaction
instance AmbientTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

instance HotSpotTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HotSpotTemperatureSensor
]

instance ColdSpotTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ColdSpotTemperatureSensor
]

// C10: Models/Data
instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Raw ambient temperature measurement transmitted via RabbitMQ."
    DTDFVocab:fromData AmbientTemperatureDataTransmitted
    DTDFVocab:inputTo RabbitMQEnabler, InfluxDBEnabler, KalmanFilterEnabler, ModelAEnabler, ModelBEnabler, CalibrationEnabler, WhatIfSimulatorEnabler, DashboardEnabler, SelfAdaptationEnabler
]

instance HotSpotTemperatureData : DTDFVocab:Data [
    base:desc "Raw hot‑spot temperature measurement transmitted via RabbitMQ."
    DTDFVocab:fromData HotSpotTemperatureDataTransmitted
    DTDFVocab:inputTo RabbitMQEnabler, InfluxDBEnabler, KalmanFilterEnabler, ModelAEnabler, ModelBEnabler, CalibrationEnabler, WhatIfSimulatorEnabler, DashboardEnabler, SelfAdaptationEnabler
]

instance ColdSpotTemperatureData : DTDFVocab:Data [
    base:desc "Raw cold‑spot temperature measurement transmitted via RabbitMQ."
    DTDFVocab:fromData ColdSpotTemperatureDataTransmitted
    DTDFVocab:inputTo RabbitMQEnabler, InfluxDBEnabler, KalmanFilterEnabler, ModelAEnabler, ModelBEnabler, CalibrationEnabler, WhatIfSimulatorEnabler, DashboardEnabler, SelfAdaptationEnabler
]

// C11: Enablers
instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source RabbitMQ message broker used for inter‑component communication between the physical twin and the digital twin."
    DTDFVocab:enables RealTimeMonitoringService, AnomalyDetectionService, PredictiveSimulationServiceA, PredictiveSimulationServiceB, CalibrationService, WhatIfSimulationService, VisualizationService, SelfAdaptationService, ControlService
]

instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database for storing raw sensor data and telemetry."
    DTDFVocab:enables DataStorageService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter implementation for anomaly detection and heatbed state estimation."
    DTDFVocab:enables AnomalyDetectionService
]

instance ModelAEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine (e.g., MATLAB/Simulink or Python SciPy) running the two‑parameter thermal inertia Model A."
    DTDFVocab:enables PredictiveSimulationServiceA
]

instance ModelBEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine running the four‑parameter thermal inertia Model B."
    DTDFVocab:enables PredictiveSimulationServiceB
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Automated calibration script that updates model parameters using latest sensor data."
    DTDFVocab:enables CalibrationService
]

instance WhatIfSimulatorEnabler : DTDFVocab:Enabler [
    base:desc "Co‑simulation tool for running what‑if scenarios through the physical twin and digital twin."
    DTDFVocab:enables WhatIfSimulationService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for visualising live telemetry."
    DTDFVocab:enables VisualizationService
]

instance SelfAdaptationEnabler : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop that detects changes, schedules experiments, recalibrates models, re‑optimises controller parameters, and updates the controller."
    DTDFVocab:enables SelfAdaptationService
]

instance ControllerEnabler : DTDFVocab:Enabler [
    base:desc "Bang‑bang controller on Raspberry Pi that receives temperature measurements via RabbitMQ and issues heating commands."
    DTDFVocab:enables ControlService
]

instance LowLevelDriverEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level driver that abstracts communication with the PT and implements a safe protocol to ensure actuators never exceed rated limits."
    DTDFVocab:enables ControlService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature, fan and heat‑bed status."
    DTDFVocab:provides TemperatureDashboardInsight, ControllerStateInsight, HeatbedStatusInsight
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Stores raw sensor data in InfluxDB."
    DTDFVocab:provides DataRetentionInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection using Kalman filter on Model B to estimate unmeasured heatbed temperature."
    DTDFVocab:provides AnomalyAlertAction, KalmanFilterCovarianceInsight
]

instance PredictiveSimulationServiceA : DTDFVocab:Service [
    base:desc "Predictive simulation using two‑parameter Model A."
    DTDFVocab:provides SimulationInsightA
]

instance PredictiveSimulationServiceB : DTDFVocab:Service [
    base:desc "Predictive simulation using four‑parameter Model B."
    DTDFVocab:provides SimulationInsightB
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "On‑demand calibration of the thermal model."
    DTDFVocab:provides ModelRecalibrationInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What‑if scenario simulation through co‑simulation of the PT and DT."
    DTDFVocab:provides SimulationConfidenceInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualization of live telemetry on a dashboard."
    DTDFVocab:provides TemperatureDashboardInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Self‑adaptation loop that detects changes, schedules experiments, recalibrates the model, re‑optimises controller parameters, and updates the controller."
    DTDFVocab:provides ExperimentSchedulingAction, ParameterOptimizationAction
]

instance ControlService : DTDFVocab:Service [
    base:desc "Bang‑bang controller that issues heating commands based on temperature measurements."
    DTDFVocab:provides ControllerStateInsight, HeatbedStatusInsight
]

// C17: Insights/Actions
instance TemperatureDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time dashboard of temperature, controller state, and heat‑bed status."
]

instance ControllerStateInsight : DTDFVocab:Insight [
    base:desc "Insight into the current state of the bang‑bang controller."
]

instance HeatbedStatusInsight : DTDFVocab:Insight [
    base:desc "Insight into the current status of the heatbed (on/off)."
]

instance AnomalyAlertAction : DTDFVocab:Action [
    base:desc "Alert triggered when Kalman filter detects temperature anomaly."
    DTDFVocab:IsAutomatic true
]

instance ModelRecalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that Model B has been recalibrated with new parameters."
]

instance SimulationConfidenceInsight : DTDFVocab:Insight [
    base:desc "Confidence intervals from what‑if simulation results."
]

instance ExperimentSchedulingAction : DTDFVocab:Action [
    base:desc "Action to schedule an experiment when anomalies are detected."
    DTDFVocab:IsAutomatic true
]

instance ParameterOptimizationAction : DTDFVocab:Action [
    base:desc "Action to re‑optimise controller parameters based on simulation results."
    DTDFVocab:IsAutomatic true
]

instance KalmanFilterCovarianceInsight : DTDFVocab:Insight [
    base:desc "Covariance matrix from Kalman filter indicating confidence in state estimation."
]

instance SimulationInsightA : DTDFVocab:Insight [
    base:desc "Simulation output from Model A predicting temperature trajectory."
]

instance SimulationInsightB : DTDFVocab:Insight [
    base:desc "Simulation output from Model B predicting temperature trajectory."
]

instance DataRetentionInsight : DTDFVocab:Insight [
    base:desc "Insight into data retention and archival status in InfluxDB."
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedComponent, FanComponent, RaspberryPiComponent, LowLevelDriverComponent, RabbitMQComponent, InfluxDBComponent, KalmanFilterComponent, ModelAComponent, ModelBComponent, CalibrationScriptComponent, WhatIfSimulatorComponent, DashboardComponent, SelfAdaptationLoopComponent
]

