    base:desc "Automated calibration script that updates model parameters."
]

instance WhatIfSimulatorComponent : DTDFVocab:Component [
    base:desc "Co‑simulation tool for running what‑if scenarios."
]

instance DashboardComponent : DTDFVocab:Component [
