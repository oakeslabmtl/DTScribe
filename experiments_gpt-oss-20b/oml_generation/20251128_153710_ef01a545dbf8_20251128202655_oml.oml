    base:desc "InfluxDB time‑series database for storing raw sensor data."
]

instance KalmanFilterComponent : DTDFVocab:Component [
    base:desc "Kalman filter implementation for anomaly detection and state estimation."
]

instance ModelAComponent : DTDFVocab:Component [
    base:desc "Simulation engine running the two‑parameter thermal inertia Model A."
]

instance ModelBComponent : DTDFVocab:Component [
    base:desc "Simulation engine running the four‑parameter thermal inertia Model B."
]

