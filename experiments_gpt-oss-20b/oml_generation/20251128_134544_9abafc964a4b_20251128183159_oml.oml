// Acting Components
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan actuator powered at 12V or 18V, state (on/off) controlled via RabbitMQ messages, used in calibration experiments."
]

instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed actuator driven by bang‑bang controller on Raspberry Pi, using LL, UL, H, C parameters, with safe protocol limiting temperature rise."
]

// Sensing Components
instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor positioned outside incubator to measure ambient room temperature."
    DTDFVocab:producedData AmbientTempDataTransmitted
]

instance HotSpotTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor placed at hottest point inside incubator."
    DTDFVocab:producedData HotSpotTempDataTransmitted
]

instance ColdSpotTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor placed at coldest point inside incubator."
    DTDFVocab:producedData ColdSpotTempDataTransmitted
]

// Data Transmitted
instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
    DTDFVocab:fromData AmbientTemperatureData
]

instance HotSpotTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HotSpotTemperatureSensor
    DTDFVocab:fromData HotSpotTemperatureData
]

instance ColdSpotTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ColdSpotTemperatureSensor
    DTDFVocab:fromData ColdSpotTemperatureData
]

// Data
instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Raw temperature reading from ambient sensor, forwarded to broker."
    DTDFVocab:inputTo LowLevelDriver, KalmanFilter, ModelBCalibrator, WhatIfSimulator, SelfAdaptationLoop, TimeSeriesDatabase, Dashboard
]

instance HotSpotTemperatureData : DTDFVocab:Data [
    base:desc "Raw temperature reading from hot‑spot sensor, forwarded to broker."
    DTDFVocab:inputTo LowLevelDriver, KalmanFilter, ModelBCalibrator, WhatIfSimulator, SelfAdaptationLoop, TimeSeriesDatabase, Dashboard
]

instance ColdSpotTemperatureData : DTDFVocab:Data [
    base:desc "Raw temperature reading from cold‑spot sensor, forwarded to broker."
    DTDFVocab:inputTo LowLevelDriver, KalmanFilter, ModelBCalibrator, WhatIfSimulator, SelfAdaptationLoop, TimeSeriesDatabase, Dashboard
]

instance FanVoltageData : DTDFVocab:Data [
    base:desc "Fan voltage measurement (12V or 18V)."
    DTDFVocab:inputTo LowLevelDriver, KalmanFilter, ModelBCalibrator, WhatIfSimulator, SelfAdaptationLoop, TimeSeriesDatabase, Dashboard
]

instance HeatbedStatusData : DTDFVocab:Data [
    base:desc "Heatbed status indicating whether heater is energized."
    DTDFVocab:inputTo LowLevelDriver, KalmanFilter, ModelBCalibrator, WhatIfSimulator, SelfAdaptationLoop, TimeSeriesDatabase, Dashboard
]

// Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ broker running on Raspberry Pi, mediating communication between components."
    DTDFVocab:enables RealTimeMonitoringService, CalibrationService, AnomalyDetectionService, WhatIfSimulationService, SelfAdaptationService
]

instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Low‑level driver that periodically reads sensors, uploads data to RabbitMQ, and implements safe protocol."
    DTDFVocab:enables CalibrationService
]

instance BangBangController : DTDFVocab:Enabler [
    base:desc "Bang‑bang controller on Raspberry Pi controlling heatbed using LL, UL, H, C parameters."
    DTDFVocab:enables SelfAdaptationService
]

instance KalmanFilter : DTDFVocab:Enabler [
    base:desc "Kalman filter fusing sensor data with ModelB for state estimation and anomaly detection."
    DTDFVocab:enables AnomalyDetectionService
]

instance ModelBCalibrator : DTDFVocab:Enabler [
    base:desc "Calibration routine that automatically calibrates ModelB using data from physical twin."
    DTDFVocab:enables CalibrationService
]

instance WhatIfSimulator : DTDFVocab:Enabler [
    base:desc "Co‑simulation infrastructure that runs what‑if scenarios of physical and digital twins."
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationLoop : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop detecting behavioral changes, scheduling experiments, recalibrating ModelB, updating Kalman filter, running what‑if optimizations, and reconfiguring controller."
    DTDFVocab:enables SelfAdaptationService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time‑series database storing telemetry data."
    DTDFVocab:enables RealTimeMonitoringService
]

instance Dashboard : DTDFVocab:Enabler [
    base:desc "Dashboard consuming time‑series data from RabbitMQ broker and displaying current temperature, heatbed state, and controller status."
    DTDFVocab:enables RealTimeMonitoringService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring and visualization of temperature and actuator states via time‑series database and dashboard."
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "On‑demand calibration of ModelA and ModelB using data from physical twin."
    DTDFVocab:provides RecalibrateModelBAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection and heatbed state estimation via Kalman filter fusing sensor data with ModelB."
    DTDFVocab:provides AnomalyDetectionInsight, UpdateKalmanFilterAction
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What‑if simulation capability running co‑simulations of physical and digital twins to evaluate controller parameter changes."
    DTDFVocab:provides WhatIfSimulationInsight, RunWhatIfOptimizationAction
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Self‑adaptation loop detecting behavioral changes, scheduling experiments, recalibrating ModelB, updating Kalman filter, running what‑if optimizations, and reconfiguring controller."
    DTDFVocab:provides SelfAdaptationDecisionInsight, IncreaseHeatingDurationAction, ReconfigureControllerAction, RecalibrateModelBAction, UpdateKalmanFilterAction, RunWhatIfOptimizationAction
]

// Insights
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of temperature and actuator states."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection and state estimation via Kalman filter."
]

instance WhatIfSimulationInsight : DTDFVocab:Insight [
    base:desc "Co‑simulation of physical and digital twins for what‑if scenarios."
]

instance SelfAdaptationDecisionInsight : DTDFVocab:Insight [
    base:desc "Decision support from self‑adaptation loop providing confidence‑rated recommendations."
]

// Actions
instance IncreaseHeatingDurationAction : DTDFVocab:Action [
    base:desc "Increase heating duration by 2 seconds."
    DTDFVocab:IsAutomatic true
]

instance ReconfigureControllerAction : DTDFVocab:Action [
    base:desc "Reconfigure controller parameters LL, UL, H, C."
    DTDFVocab:IsAutomatic true
]

instance RecalibrateModelBAction : DTDFVocab:Action [
    base:desc "Recalibrate ModelB."
    DTDFVocab:IsAutomatic true
]

instance UpdateKalmanFilterAction : DTDFVocab:Action [
    base:desc "Update Kalman filter parameters."
    DTDFVocab:IsAutomatic true
]

instance RunWhatIfOptimizationAction : DTDFVocab:Action [
    base:desc "Run what‑if optimization."
    DTDFVocab:IsAutomatic true
]

// Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "First‑order ODE with two free parameters: C_air=616.56 J/K, G_box=0.65 J/K."
    DTDFVocab:inputTo ModelBCalibrator, WhatIfSimulator, SelfAdaptationLoop
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "First‑order ODE with four free parameters: C_air=486.12 J/K, G_box=0.856 J/K, C_heater=33.65 J/K, G_heater=0.87 J/K."
    DTDFVocab:inputTo ModelBCalibrator, WhatIfSimulator, SelfAdaptationLoop
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains FanActuator, HeatbedActuator, AmbientTemperatureSensor, HotSpotTemperatureSensor, ColdSpotTemperatureSensor,
           LowLevelDriver, BangBangController, KalmanFilter, ModelBCalibrator, WhatIfSimulator, SelfAdaptationLoop,
           TimeSeriesDatabase, Dashboard, RabbitMQBroker
]

