// Acting Components
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan actuator (2 ft²) controlled via MOSFET driver on custom PCB, part of the incubator's airflow system."
]

instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed actuator (insulated heating element) controlled via MOSFET driver, responsible for maintaining temperature inside the incubator."
]

// Sensing Components
instance T1Sensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor positioned outside the insulated box to measure room temperature."
    DTDFVocab:producedData T1DataTransmitted
]

instance T2Sensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor placed at the hottest point inside the box."
    DTDFVocab:producedData T2DataTransmitted
]

instance T3Sensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor placed at the coldest point inside the box."
    DTDFVocab:producedData T3DataTransmitted
]

// Data Transmitted
instance T1DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom T1Sensor
]

instance T2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom T2Sensor
]

instance T3DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom T3Sensor
]

// Data
instance T1Data : DTDFVocab:Data [
    base:desc "Temperature data stream for room temperature, produced from T1DataTransmitted."
    DTDFVocab:fromData T1DataTransmitted
    DTDFVocab:inputTo RabbitMQBroker, KalmanFilter, ModelB, ModelA, CalibrationRoutine, WhatIfSimulationEngine, SelfAdaptationLoop
]

instance T2Data : DTDFVocab:Data [
    base:desc "Temperature data stream for hottest point inside the box, produced from T2DataTransmitted."
    DTDFVocab:fromData T2DataTransmitted
    DTDFVocab:inputTo RabbitMQBroker, KalmanFilter, ModelB, ModelA, CalibrationRoutine, WhatIfSimulationEngine, SelfAdaptationLoop
]

instance T3Data : DTDFVocab:Data [
    base:desc "Temperature data stream for coldest point inside the box, produced from T3DataTransmitted."
    DTDFVocab:fromData T3DataTransmitted
    DTDFVocab:inputTo RabbitMQBroker, KalmanFilter, ModelB, ModelA, CalibrationRoutine, WhatIfSimulationEngine, SelfAdaptationLoop
]

// Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on Raspberry Pi, handles routing of sensor data and control commands via AMQP."
    DTDFVocab:enables RealTimeMonitoringService, CalibrationService, AnomalyDetectionService, WhatIfSimulationService, SelfAdaptationService
]

instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Low‑level driver firmware on Raspberry Pi that reads DS18S20 sensors and publishes data to RabbitMQ, enforcing safe protocol."
    DTDFVocab:enables RealTimeMonitoringService
]

instance KalmanFilter : DTDFVocab:Enabler [
    base:desc "Kalman filter enabler that fuses measured sensor data with unmeasured heatbed temperature for state estimation."
    DTDFVocab:enables AnomalyDetectionService
]

instance ModelB : DTDFVocab:Enabler [
    base:desc "Four‑parameter thermal model (Model B) used for predicting heatbed thermal inertia, calibrated from sensor data."
    DTDFVocab:enables WhatIfSimulationService
]

instance ModelA : DTDFVocab:Enabler [
    base:desc "Two‑parameter thermal model (Model A) used for quick calibration and baseline predictions."
    DTDFVocab:enables CalibrationService
]

instance CalibrationRoutine : DTDFVocab:Enabler [
    base:desc "Calibration routine enabler that updates model parameters (C_air, G_box, C_heater, G_heater) by fitting to temperature trajectories."
    DTDFVocab:enables CalibrationService
]

instance WhatIfSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation engine that runs what‑if scenarios using historical or real‑time PT data to optimize controller parameters."
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationLoop : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop enabler that detects behavioral changes, schedules experiments, recalibrates models, re‑optimizes controller, and updates DT."
    DTDFVocab:enables SelfAdaptationService
]

instance BangBangController : DTDFVocab:Enabler [
    base:desc "Bang‑bang controller enabler that receives temperature measurements and sends heating commands based on LL, UL, H, C parameters."
    DTDFVocab:enables SelfAdaptationService
]

instance Dashboard : DTDFVocab:Enabler [
    base:desc "Real‑time dashboard component that visualizes temperature, fan, and heatbed status from time‑series database."
    DTDFVocab:enables RealTimeMonitoringService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "InfluxDB‑like time‑series database storing telemetry for monitoring, calibration, and simulation."
    DTDFVocab:enables RealTimeMonitoringService, CalibrationService, AnomalyDetectionService, WhatIfSimulationService, SelfAdaptationService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service that provides real‑time visualization of incubator status via dashboard."
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that performs on‑demand calibration of thermal models using automated experiments."
    DTDFVocab:provides UpdateModelParametersAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Service that detects anomalies and estimates heatbed state using Kalman filter."
    DTDFVocab:provides AnomalyDetectionInsight, HeatbedStateEstimationInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Service that runs what‑if co‑simulations to evaluate controller parameter changes."
    DTDFVocab:provides WhatIfSimulationInsight, RunWhatIfSimulationAction
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Service that implements self‑adaptation loop, triggering experiments, recalibration, and controller re‑optimization."
    DTDFVocab:provides SelfAdaptationInsight, ReconfigureControllerAction, ScheduleExperimentAction, UpdateModelParametersAction, RunWhatIfSimulationAction
]

// Insights
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight showing live temperature, fan, and heatbed status on dashboard."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating detected anomalies and heatbed state estimation."
]

instance HeatbedStateEstimationInsight : DTDFVocab:Insight [
    base:desc "Insight providing estimated heatbed temperature from Kalman filter."
]

instance WhatIfSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing results of what‑if simulation scenarios."
]

instance SelfAdaptationInsight : DTDFVocab:Insight [
    base:desc "Insight reflecting system adaptation decisions and updated controller parameters."
]

// Actions
instance ReconfigureControllerAction : DTDFVocab:Action [
    base:desc "Action to reconfigure bang‑bang controller parameters (LL, UL, H, C)."
    DTDFVocab:IsAutomatic true
]

instance ScheduleExperimentAction : DTDFVocab:Action [
    base:desc "Action to schedule automated calibration experiments."
    DTDFVocab:IsAutomatic true
]

instance UpdateModelParametersAction : DTDFVocab:Action [
    base:desc "Action to update thermal model parameters after calibration."
    DTDFVocab:IsAutomatic true
]

instance RunWhatIfSimulationAction : DTDFVocab:Action [
    base:desc "Action to execute a what‑if simulation run."
    DTDFVocab:IsAutomatic true
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains FanActuator, HeatbedActuator, T1Sensor, T2Sensor, T3Sensor, RaspberryPiComponent, CustomPCBComponent, LowLevelDriverComponent, BangBangControllerComponent, RabbitMQBrokerComponent, KalmanFilterComponent, ModelBComponent, ModelAComponent, CalibrationRoutineComponent, WhatIfSimulationEngineComponent, SelfAdaptationLoopComponent, DashboardComponent, TimeSeriesDatabaseComponent
]

