// C2: Acting Components
instance OccupancyActuator : DTDFVocab:ActingComponent [
    base:desc "Building control system actuator for occupancy-based lighting adjustment via adaptive control logic"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC system actuator for adaptive temperature and humidity control using reinforcement learning in BOREALIS"
]

instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator for adaptive lighting schedules based on occupancy and energy efficiency metrics"
]

// C3: Physical Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled occupancy sensor for real-time detection of building occupants"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental temperature sensor measuring room temperature and humidity parameters"
    DTDFVocab:producedData TemperatureHumidityData
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy CO₂ sensor for indoor air quality monitoring"
    DTDFVocab:producedData CO2DataTransmitted
]

instance LightIntensitySensor : DTDFVocab:SensingComponent [
    base:desc "Light level sensor measuring ambient light conditions for adaptive lighting control"
    DTDFVocab:producedData LightData
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Energy consumption sensor tracking real-time power usage metrics"
    DTDFVocab:producedData EnergyData
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureHumidityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance LightData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightIntensitySensor
]

instance EnergyData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

// C10: Models/Data
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing device modeling, sensor configurations, and control logic definitions"
]

instance RuntimeMetadataModel : DTDFVocab:Model [
    base:desc "Runtime metadata model containing sensor configurations and control logic extracted from BIM"
]

instance OperationalDataStore : DTDFVocab:Data [
    base:desc "Structured data repository for building components containing geometry, topology, and BCS elements"
    DTDFVocab:fromData TemperatureHumidityData, CO2DataTransmitted, LightData, EnergyData
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Real-time operational data stream containing sensor readings and control signals"
    DTDFVocab:fromData OccupancyDataTransmitted
]

// C11: Enablers
instance BIMEnrichmentTool : DTDFVocab:Enabler [
    base:desc "BIM tools (Revit/ArchiCAD) for device modeling and sensor configuration extraction"
]

instance ModelDrivenTransformation : DTDFVocab:Enabler [
    base:desc "Automated transformation pipeline converting BIM models into runtime artifacts using model-driven engineering principles"
    DTDFVocab:inputTo BIMEnrichmentTool
]

instance EclipseHonoMiddleware : DTDFVocab:Enabler [
    base:desc "Eclipse Hono/Ditto middleware for real-time bidirectional data exchange between physical building and DT"
    DTDFVocab:enables RealTimeMonitoringService
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3D visualization of the digital twin environment"
]

instance BOREALISReinforcementLearning : DTDFVocab:Enabler [
    base:desc "BOREALIS framework for adaptive control logic using reinforcement learning for HVAC and lighting optimization"
    DTDFVocab:enables ControlOptimizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring service providing live data visualization and immediate feedback from building sensors"
    DTDFVocab:provides OccupancyMonitoringInsight, EnvironmentalMonitoringInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service performing energy consumption forecasting and trend analysis"
    DTDFVocab:provides EnergyConsumptionForecast, OccupantComfortPrediction
]

instance ControlOptimizationService : DTDFVocab:Service [
    base:desc "Control optimization service implementing adaptive HVAC and lighting systems via reinforcement learning"
    DTDFVocab:provides AdaptiveHVACControl, DynamicLightingAdjustment
]

// C17: Insights/Actions
instance OccupancyMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time occupancy monitoring insights showing current building occupancy patterns and distribution"
]

instance EnvironmentalMonitoringInsight : DTDFVocab:Insight [
    base:desc "Environmental monitoring insights tracking temperature, humidity, and CO₂ levels for occupant comfort assessment"
]

instance EnergyConsumptionForecast : DTDFVocab:Insight [
    base:desc "Predictive energy consumption forecast based on current usage patterns and environmental conditions"
]

instance OccupantComfortPrediction : DTDFVocab:Insight [
    base:desc "Predictive model for occupant comfort levels based on environmental parameters and occupancy data"
]

instance AdaptiveHVACControl : DTDFVocab:Action [
    base:desc "Automatic adaptive HVAC control action adjusting temperature and humidity based on real-time conditions"
    DTDFVocab:IsAutomatic true
]

instance DynamicLightingAdjustment : DTDFVocab:Action [
    base:desc "Dynamic lighting adjustment action implementing adaptive lighting schedules based on occupancy and energy metrics"
    DTDFVocab:IsAutomatic true
]

// C17: Environment and Components
instance BuildingInfrastructureEnvironment : DTDFVocab:Environment [
    base:contains OccupancyActuator, HVACActuator, LightingDimmerActuator,
                 OccupancySensor, TemperatureSensor, CO2Sensor,
                 LightIntensitySensor, EnergyConsumptionSensor
]

instance StructuralComponents : DTDFVocab:Component [
    base:desc "Physical building structural elements forming the foundational framework"
]

instance HVACSystem : DTDFVocab:Component [
    base:desc "HVAC system components including actuators and sensors for temperature/humidity control"
    base:isContainedIn BuildingInfrastructureEnvironment
]

instance LightingSystem : DTDFVocab:Component [
    base:desc "Building lighting system including dimmers and sensors for adaptive lighting control"
    base:isContainedIn BuildingInfrastructureEnvironment
]

instance LivingLabFacility : DTDFVocab:SystemUnderStudy [
    base:desc "BIM-based building infrastructure used for AECO applications with real-time monitoring capabilities"
    DTDFVocab:hasEnvironment BuildingInfrastructureEnvironment
    DTDFVocab:hasEnvironment StructuralComponents
    DTDFVocab:hasEnvironment HVACSystem
    DTDFVocab:hasEnvironment LightingSystem
    DTDFVocab:hasEnvironment BIMEnrichedModel
    DTDFVocab:hasEnvironment OperationalDataStore
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Facilitates **control signal transmission** from the DT to physical actuators (e.g., lighting, HVAC systems) via **Eclipse Hono** and **Ditto**, enabling automated adjustments to operational parameters. The framework supports dynamic runtime configurations, allowing DT engineers to define control logic directly within BIM models, which are then transformed into deployable artifacts. This ensures bidirectional adaptability for real-time optimization (e.g., energy-efficient lighting control)."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin operates with **real-time synchronization**, ensuring bidirectional data exchange at high frequencies. The **Overall Digital Twin Entanglement (ODTE) metric** is used to validate the fidelity of the DT, though specific frequency details (e.g., 1Hz, 10Hz) are not explicitly quantified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrates a **modular DT ecosystem** where BIM models serve as the core semantic foundation. The DT constellation includes **centralized runtime interfaces** (via Eclipse Hono/Ditto) for bidirectional communication, **Unreal Engine-based visualization** for stakeholder interaction, and **service-oriented extension points** for integrating custom analytics and IoT devices. The Living Lab case study demonstrates a **scalable, interoperable DT** where components (e.g., lighting, HVAC) are dynamically integrated into a unified virtual representation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the **entire building life cycle**, from **design (ideal representation)** to **manufacturing (as-manufactured accuracy)** to **operation (real-time monitoring and optimization)**. The framework automates the transition from static BIM models to operational DTs, ensuring continuity across phases. The **BIM-centric approach** supports lifecycle-specific adaptations (e.g., post-occupancy data integration for BOREALIS adaptive lighting)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Ensures **high fidelity** via the **Overall Digital Twin Entanglement (ODTE) metric**, which evaluates the alignment between the DT and its physical counterpart. The framework addresses **semantic drift** by automating runtime synchronization (e.g., sensor data updates) and leveraging **BIM’s static-to-dynamic transformation** to maintain consistency. Verification/validation mechanisms include **model-to-model transformations** (e.g., from BIM to runtime interfaces) and **real-time data validation** via middleware (Eclipse Hono/Ditto)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Established via **Eclipse Hono** and **Ditto** protocols for **real-time, low-latency communication** between physical sensors/actuators and the DT. The network architecture supports **bidirectional data flows** (e.g., sensor readings → DT; DT → actuators) with standardized APIs. The framework integrates with **BIM’s spatial data** to define physical-to-virtual interactions, ensuring seamless synchronization."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployed as a **service-oriented platform** with **standardized extension points** for modularity. The DT is hosted on a **scalable infrastructure** supporting real-time operations, leveraging cloud-based middleware (Eclipse Hono/Ditto) and **Unreal Engine** for visualization. The framework automates deployment from BIM models, reducing manual effort while ensuring maintainability and interoperability with existing AECO systems."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Enables **interoperability with external systems** (e.g., IoT platforms, BIM tools) via standardized APIs (Eclipse Hono/Ditto) and **BIM’s semantic backbone**. The modular architecture supports integration with **third-party services** (e.g., analytics platforms) and **cross-DT communication** in larger infrastructure ecosystems. Horizontal integration is facilitated by **extension points** for custom service plugins."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership and privacy are **not explicitly detailed** in the documents. The framework focuses on interoperability and real-time synchronization but does not specify ownership models or privacy compliance mechanisms."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adheres to **AECO-specific standards** (e.g., BIM standards for building components, IoT interoperability protocols like MQTT via Eclipse Hono). The framework leverages **model-driven engineering (MDE)** to enforce standardized metadata extraction from BIM models, ensuring consistency across deployments. Standardized extension points enable **interoperability with existing DT frameworks** (e.g., Eclipse Ditto, Unreal Engine plugins)."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety considerations are **not explicitly detailed** in the documents. The framework emphasizes interoperability, real-time synchronization, and extensibility but does not address authentication, encryption, or safety protocols (e.g., isolated deployment) for remote operations."
]