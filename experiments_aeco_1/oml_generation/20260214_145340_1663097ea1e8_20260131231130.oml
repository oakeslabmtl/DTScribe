]

instance PredictiveAnalysisService : DTDFVocab:Service [
    base:desc "Predictive analytics service that applies time-series forecasting (ARIMA, LSTM) to sensor data for lifetime forecasting and failure prediction within building infrastructure."
    DTDFVocab:provides LifetimeForecastingInsight, FailurePredictionInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization service that renders 3D/4D/5D models with real-time sensor data overlays using Unity/Unreal Engine for remote inspection and training purposes."
    DTDFVocab:provides InspectionVisualizationInsight, TrainingVisualizationInsight
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Interactive dashboard service that presents real-time and historical data through Tableau/Power BI interfaces for facility managers and operational teams."
    DTDFVocab:provides OperationalDashboardInsight, AlertVisualizationInsight
]

instance DataProcessingService : DTDFVocab:Service [
    base:desc "Service for processing and validating incoming sensor data streams before integration into the digital twin system."
    DTDFVocab:provides DataValidationInsight, DataNormalizationInsight
]

instance StateSynchronizationService : DTDFVocab:Service [
    base:desc "Service that handles bidirectional synchronization of physical device states with digital twin representations."
    DTDFVocab:provides StateConsistencyInsight
]

instance MaintenanceService : DTDFVocab:Service [
    base:desc "Service that manages maintenance schedules and failure alerts based on predictive analytics."
    DTDFVocab:provides MaintenanceScheduleInsight, AlertGenerationInsight
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Service that generates compliance and reporting documents for regulatory requirements."
    DTDFVocab:provides ComplianceReportInsight, StandardizedReportInsight
]

instance ComplianceService : DTDFVocab:Service [
    base:desc "Service that ensures all data and operations comply with relevant standards and regulations."
    DTDFVocab:provides ComplianceValidationInsight
]

