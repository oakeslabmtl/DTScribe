// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the building envelope, streamed post‑occupancy to the Digital Twin"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor measuring light levels in occupied zones, streamed post‑occupancy to the Digital Twin"
    DTDFVocab:producedData IlluminanceDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]

// C5: Data instances
instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy information (present/absent) derived from OccupancySensor"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoConnector
]

instance IlluminanceData : DTDFVocab:Data [
    base:desc "Real‑time illuminance levels (lux) derived from IlluminanceSensor"
    DTDFVocab:fromData IlluminanceDataTransmitted
    DTDFVocab:inputTo EclipseHonoConnector
]

// C2: Acting components
instance DimmableLuminaireActuator : DTDFVocab:ActingComponent [
    base:desc "Dimmable luminaires capable of receiving set‑point commands from the Digital Twin"
]

instance LightingSwitchActuator : DTDFVocab:ActingComponent [
    base:desc "On/Off lighting switches integrated in the building control system"
]

// C11: Enablers
instance EclipseHonoConnector : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides MQTT/HTTPS connectivity for continuous streaming of sensor measurements to the twin"
    DTDFVocab:enables RealTimeMonitoringDashboardService, UnrealEngineVisualizationService
]

instance EclipseDittoStateManager : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages twin state, dispatches control commands and hosts reinforcement‑learning policies"
    DTDFVocab:enables AdaptiveLightingControlService, EnergyOptimizationService, PredictiveAnalyticsService
]

instance ModelDrivenPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation pipeline converts enriched BIM and control‑logic models into deployable DT artifacts"
    DTDFVocab:enables SimulationService
]

instance UnrealEngine5VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders immersive 3‑D visualizations of the living lab for operators"
    DTDFVocab:enables UnrealEngineVisualizationService
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with device metadata, runtime control logic and RL policies"
    DTDFVocab:inputTo ModelDrivenPipeline
]

instance RuntimeControlLogicModel : DTDFVocab:Model [
    base:desc "Executable control‑logic model governing lighting actuators and HVAC set‑points"
    DTDFVocab:inputTo EclipseDittoStateManager
]

instance ReinforcementLearningPolicyModel : DTDFVocab:Model [
    base:desc "RL policy model that adapts lighting strategies based on post‑occupancy sensor feedback"
    DTDFVocab:inputTo EclipseDittoStateManager
]

// C6: Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards presenting live occupancy and illuminance streams"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance UnrealEngineVisualizationService : DTDFVocab:Service [
    base:desc "3‑D interactive visualization of the building in Unreal Engine 5"
    DTDFVocab:provides VisualFeedbackInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics engine delivering forecasts of occupancy and energy demand"
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization service generating energy‑use reduction recommendations"
    DTDFVocab:provides EnergyOptimizationInsight, EnergySavingAction
]

instance AdaptiveLightingControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based adaptive lighting control adjusting dimming set‑points"
    DTDFVocab:provides AdaptiveLightingInsight, AdaptiveLightingAdjustmentAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service supporting design‑time and operational decision making"
    DTDFVocab:provides SimulationInsight
]

// C17: Insights
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Live view of occupancy and illuminance supports facility‑manager situational awareness"
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Forecasts of future occupancy patterns enable proactive energy management"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for reducing building energy consumption based on sensor trends"
]

instance AdaptiveLightingInsight : DTDFVocab:Insight [
    base:desc "Insight into optimal lighting levels per zone derived from reinforcement‑learning policies"
]

instance VisualFeedbackInsight : DTDFVocab:Insight [
    base:desc "Immersive visual feedback of the twin assists post‑occupancy planning and stakeholder communication"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results inform design‑time decisions and operational scenario analysis"
]

// C17: Actions
instance AdaptiveLightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of dimmable luminaires based on RL policy"
    DTDFVocab:IsAutomatic true
]

instance EnergySavingAction : DTDFVocab:Action [
    base:desc "Automatic execution of energy‑saving set‑points for HVAC and lighting"
    DTDFVocab:IsAutomatic true
]

// C9: Environment
instance LivingLabEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, IlluminanceSensor, DimmableLuminaireActuator, LightingSwitchActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command flow from the twin to the physical actuators using Eclipse Ditto to translate control commands (e.g., lighting set‑points, HVAC commands) into device‑level messages that drive the building control hardware."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates in real time; sensor updates and control actions are propagated within seconds as soon as messages are received by Hono/Ditto, enabling continuous synchronization."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A service‑oriented architecture composed of a BIM‑based semantic core, a middleware layer (Hono/Ditto) handling bidirectional data flow, and a visualization/interaction layer (Unreal Engine), all orchestrated through the model‑driven framework."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the full building lifecycle – it is instantiated from the design BIM, remains applicable during construction and commissioning, and continues to operate during the post‑occupancy phase, supporting refurbishment and adaptation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is employed to quantify how closely the twin mirrors its physical counterpart, addressing semantic drift and ensuring model‑physical alignment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time connectivity is realized through Eclipse Hono (supporting MQTT/HTTP/CoAP) and Eclipse Ditto, which together provide the protocol stack and state management for PT↔DT communication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Generated DT artifacts are automatically deployed onto the service‑oriented DT platform defined by the framework; the specific hosting environment (cloud vs. on‑premise) is not detailed in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized extension points enable integration of external services and systems, promoting interoperability beyond the core DT platform."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on BIM standards for semantic consistency, uses open‑source standards implemented by Eclipse Hono and Ditto, and defines standardized extension points to ensure interoperable service integration."
]