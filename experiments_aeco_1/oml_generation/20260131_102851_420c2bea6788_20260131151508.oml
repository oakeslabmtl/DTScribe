// Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor integrated into the building whose data streams are captured by the DT and used for predictive analytics."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor integrated into the building whose data streams are captured by the DT and used for predictive analytics."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO2 sensor integrated into the building whose data streams are captured by the DT and used for predictive analytics."
    DTDFVocab:producedData CO2DataTransmitted
]

// Physical-to-Virtual Interaction
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

// Live Sensor Data
instance OccupancyLiveData : DTDFVocab:Data [
    base:desc "Live occupancy data stream ingested by the DT via MQTT."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto, MDETools, HonoDittoConfigurator
]

instance TemperatureLiveData : DTDFVocab:Data [
    base:desc "Live temperature data stream ingested by the DT via MQTT."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto, MDETools, HonoDittoConfigurator
]

instance CO2LiveData : DTDFVocab:Data [
    base:desc "Live CO2 data stream ingested by the DT via MQTT."
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto, MDETools, HonoDittoConfigurator
]

// Models
instance BIMModel : DTDFVocab:Model [
    base:desc "BIM model transformed via model-to-model and model-to-text MDE pipelines."
    DTDFVocab:inputTo HonoDittoConfigurator
]

instance DittoDeviceModel : DTDFVocab:Model [
    base:desc "Ditto device models containing device and control metadata extracted from the BIM."
    DTDFVocab:inputTo EclipseDitto
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic object-oriented models for reinforcement learning control loops."
    DTDFVocab:inputTo MDETools
]

instance ReinforcementLearningPolicy : DTDFVocab:Model [
    base:desc "Reinforcement learning policy used to optimize energy and lighting schedules."
    DTDFVocab:inputTo EclipseDitto
]

// Acting Components
instance DimmingActuator : DTDFVocab:ActingComponent [
    base:desc "Illuminance control actuator embedded in BIM providing dimming controls to lighting fixtures."
]

instance OnOffActuator : DTDFVocab:ActingComponent [
    base:desc "On/off switch actuator embedded in BIM to control lighting fixture power states."
]

instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture actuator embedded in BIM that receives dimming and on/off commands from the DT."
]

// Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono enables secure IoT messaging via MQTT for data ingestion."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto provides device twin management for the DT."
    DTDFVocab:enables PredictiveAnalyticsService, OptimizationService
]

instance MDETools : DTDFVocab:Enabler [
    base:desc "MDE tools for model extraction and code generation in the twin process."
    DTDFVocab:enables OptimizationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 provides immersive 3D visualization of building performance."
    DTDFVocab:enables VisualizationService
]

instance HonoDittoConfigurator : DTDFVocab:Enabler [
    base:desc "Hono/Ditto Configurator automates deployment of twins and configuration."
    DTDFVocab:enables RealTimeMonitoringService, OptimizationService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service provides real-time monitoring of sensor data streams."
    DTDFVocab:provides OccupancyPatternInsight, TemperatureComfortInsight, CO2LevelInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service provides predictive analytics and optimization of energy and lighting schedules."
    DTDFVocab:provides OccupancyBasedDimmingInsight, LightingScheduleOptimizationInsight
    DTDFVocab:provides OccupancyBasedDimmingAction, LightingScheduleAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service optimizes energy consumption and lighting schedules using reinforcement learning."
    DTDFVocab:provides LightingScheduleOptimizationInsight, EnergyConsumptionOptimizationInsight
    DTDFVocab:provides EnergySavingAction, RLPolicyUpdateAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service enables immersive visualization through Unreal Engine 5."
    DTDFVocab:provides ImmersiveVisualizationAction
]

// Insights
instance OccupancyPatternInsight : DTDFVocab:Insight [
    base:desc "Insight into occupant presence patterns detected by predictive analytics."
]

instance TemperatureComfortInsight : DTDFVocab:Insight [
    base:desc "Insight into indoor thermal comfort derived from temperature sensor data."
]

instance CO2LevelInsight : DTDFVocab:Insight [
    base:desc "Insight into indoor air quality based on CO2 levels."
]

instance OccupancyBasedDimmingInsight : DTDFVocab:Insight [
    base:desc "Insight into optimal dimming levels derived from occupancy predictions."
]

instance LightingScheduleOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight into energy-efficient lighting schedule recommendations."
]

instance EnergyConsumptionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight into reduced energy consumption opportunities."
]

// Actions
instance OccupancyBasedDimmingAction : DTDFVocab:Action [
    base:desc "Action to adjust dimmer levels based on occupancy prediction."
    DTDFVocab:IsAutomatic true
]

instance LightingScheduleAction : DTDFVocab:Action [
    base:desc "Action to implement optimized lighting schedules."
    DTDFVocab:IsAutomatic true
]

instance EnergySavingAction : DTDFVocab:Action [
    base:desc "Action to reduce energy consumption by adjusting system parameters."
    DTDFVocab:IsAutomatic true
]

instance RLPolicyUpdateAction : DTDFVocab:Action [
    base:desc "Action to update reinforcement learning policies using post-occupancy data."
    DTDFVocab:IsAutomatic true
]

instance ImmersiveVisualizationAction : DTDFVocab:Action [
    base:desc "Action to launch immersive 3D visualization of building performance."
    DTDFVocab:IsAutomatic false
]

// Environment (optional)
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, TemperatureSensor, CO2Sensor, DimmingActuator, OnOffActuator, LightingFixtureActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT emits control signals back to the building automation system via Ditto to Hono forwarding, using MQTT to deliver actuator commands to the physical hardware, enabling bidirectional, low‑latency interaction."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization, with sensor data and control feedback exchanged online as part of the DT’s operational loop."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture comprising the Hono/Ditto Configurator, a BIM metadata extractor, a simulation engine, an analytics service, and a visualization gateway, orchestrated to provide end‑to‑end DT functionality."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin encapsulates design‑time BIM data, construction (manufactured) metadata, and operational data streams, thus operating across all lifecycle stages from ideal design, through installation, to ongoing operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric used to quantify physical‑digital alignment; simulation models validated against measured energy consumption; uncertainty propagated through sensor fusion."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT mediated by Eclipse Hono and Ditto middleware, enabling secure, standardized data exchange without specifying lower‑level protocols."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Utilizes BIM (IFC/ISO 16739) as the underlying data model; adherence to AECO sector practices is implied but no explicit standardization beyond BIM is described."
]