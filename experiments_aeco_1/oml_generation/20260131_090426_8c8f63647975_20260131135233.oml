// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor integrated within the building’s lighting infrastructure, transmitting occupancy status to the Digital Twin."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor embedded in lighting fixtures, publishing real‑time brightness measurements to the Digital Twin."
    DTDFVocab:producedData IlluminanceDataTransmitted
]

// C4: Data transmitted from physical sensors
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]

// C10: Data nodes that feed into enablers
instance OccupancyData : DTDFVocab:Data [
    base:desc "Structured occupancy data stream derived from OccupancySensor, used for occupancy‑based lighting control."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo HonoServer, DittoServer
]

instance IlluminanceData : DTDFVocab:Data [
    base:desc "Structured illuminance data stream derived from IlluminanceSensor, used for illumination‑adjustment calculations."
    DTDFVocab:fromData IlluminanceDataTransmitted
    DTDFVocab:inputTo HonoServer, DittoServer
]

// C11: Enablers that instantiate and orchestrate services
instance HonoServer : DTDFVocab:Enabler [
    base:desc "Eclipse Hono message broker, facilitating near‑real‑time ingestion of sensor data into the Digital Twin."
    DTDFVocab:enables LightingControlService, EnergyAnalyticsService, TaskPlanningService, ReinforcementLearningService
]

instance DittoServer : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin platform, synchronizing sensor streams and control commands between the physical building and its Digital Twin."
    DTDFVocab:enables LightingControlService, HVACControlService, ImmersiveVisualizationService
]

instance UnrealEngineInstance : DTDFVocab:Enabler [
    base:desc "Unreal Engine runtime engine providing immersive visualization and scenario simulation for the Digital Twin."
    DTDFVocab:enables ImmersiveVisualizationService
]

instance ModelDrivenEngine : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering tools that automate the transformation from enriched BIM to runtime artifact definitions."
    DTDFVocab:enables ReinforcementLearningService
]

// C6: Services that process data and generate insights or actions
instance LightingControlService : DTDFVocab:Service [
    base:desc "Service orchestrating dimming and on/off control of lighting fixtures via the Digital Twin."
    DTDFVocab:provides LightingOptimizationInsight, AdjustLightingAction
]

instance HVACControlService : DTDFVocab:Service [
    base:desc "Service optimizing HVAC schedules by applying reinforcement‑learning policies generated for efficiency."
    DTDFVocab:provides HVACScheduleOptimizationInsight, AdjustHVACAction
]

instance EnergyAnalyticsService : DTDFVocab:Service [
    base:desc "Service providing predictive analytics of building energy consumption and actionable recommendations."
    DTDFVocab:provides EnergyConsumptionPredictionInsight, GenerateRecommendationAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Service delivering immersive, Unreal Engine‑based scenario visualizations for decision support."
    DTDFVocab:provides ImmersionScenarioInsight
]

instance TaskPlanningService : DTDFVocab:Service [
    base:desc "Service planning facility management tasks based on current building state and operational goals."
    DTDFVocab:provides TaskPlanningInsight, PlanFacilityTaskAction
]

instance ReinforcementLearningService : DTDFVocab:Service [
    base:desc "Service managing the training and update of reinforcement‑learning policies (BOREALIS) for lighting and HVAC optimization."
    DTDFVocab:provides RLPolicyUpdateInsight
]

// Insights generated by services
instance LightingOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing optimal lighting levels derived from reinforcement‑learning policies."
]

instance HVACScheduleOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal HVAC schedule to reduce consumption while maintaining comfort."
]

instance EnergyConsumptionPredictionInsight : DTDFVocab:Insight [
    base:desc "Insight predicting future energy usage based on real‑time sensor feed and historical trends."
]

instance ImmersionScenarioInsight : DTDFVocab:Insight [
    base:desc "Insight detailing the results of an immersive scenario simulation executed in Unreal Engine."
]

instance TaskPlanningInsight : DTDFVocab:Insight [
    base:desc "Insight outlining prioritized facility management tasks derived from building operational state."
]

instance RLPolicyUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight reporting on the latest updates made to reinforcement‑learning policies."
]

// Actions produced by services
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Action to adjust lighting levels (dimming/on‑off) across the building via actuators."
    DTDFVocab:IsAutomatic false
]

instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Action to adjust HVAC settings (temperature setpoints, fan speeds) based on policy outputs."
    DTDFVocab:IsAutomatic false
]

instance GenerateRecommendationAction : DTDFVocab:Action [
    base:desc "Action to generate actionable recommendations for building operators regarding energy savings."
    DTDFVocab:IsAutomatic false
]

instance PlanFacilityTaskAction : DTDFVocab:Action [
    base:desc "Action to schedule and assign facility management tasks to maintenance staff."
    DTDFVocab:IsAutomatic false
]

// Acting component in the physical twin
instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Dimming and on/off actuator for a lighting fixture, modeled in BIM and controlled through the Digital Twin."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT – e.g., lighting level adjustments – are sent back to the physical actuators through Hono/Ditto, enabling bidirectional interaction."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data and control exchanges occur in real‑time, with end‑to‑end latency typically below a few seconds, supporting near‑instantaneous adjustments in the building’s lighting system."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central DT framework component orchestrating device registry, telemetry ingestion, control command dispatch, service plug‑in management, and visualization, with modular extension points for DT engineers to add custom analytics or control modules."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle spans design (ideal IFC BIM model), construction (enriched BIM with device metadata), and operation (live telemetry, real‑time control); the framework supports all three stages by generating runtime artifacts from the BIM model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation steps are performed to ensure semantic consistency; entanglement between the DT and PT is quantified using the ODTE metric, providing feedback on fidelity and guiding corrective actions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono serves as the MQTT-based message broker (as inferred by its IoT orientation) and Eclipse Ditto manages twin metadata and state synchronization, forming the core communication layer between physical assets and the virtual twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM provides the domain‑specific semantic standard, while Eclipse Ditto adheres to OMA Twin Registry specifications, ensuring interoperability across components."
]