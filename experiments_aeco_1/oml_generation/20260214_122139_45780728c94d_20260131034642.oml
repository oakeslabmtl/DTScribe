instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors providing temperature data through automated data acquisition pipelines for real-time synchronization with the digital twin."
    DTDFVocab:producedData TemperatureSensorDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors providing occupancy data through automated data acquisition pipelines for real-time synchronization with the digital twin."
    DTDFVocab:producedData OccupancySensorDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors providing environmental data through automated data acquisition pipelines for real-time synchronization with the digital twin."
    DTDFVocab:producedData EnvironmentalSensorDataTransmitted
]

instance TemperatureSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnvironmentalSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature measurements from physical sensors"
    DTDFVocab:fromData TemperatureSensorDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy data from physical sensors"
    DTDFVocab:fromData OccupancySensorDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Real-time environmental measurements from physical sensors"
    DTDFVocab:fromData EnvironmentalSensorDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC system actuators for physical adjustments via digital commands"
]

instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control actuators for physical adjustments via digital commands"
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for IoT data ingestion"
    DTDFVocab:enables RealTimeMonitoring, PredictiveAnalytics
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for digital twin management"
    DTDFVocab:enables RealTimeMonitoring, Simulation
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for 3D visualization"
    DTDFVocab:enables Interactive3DVisualization
]

instance BIMAuthoringTools : DTDFVocab:Enabler [
    base:desc "BIM authoring tools for model creation and management"
    DTDFVocab:enables BIMValidation, ExtractMetadata
]

instance ModelDrivenEngineeringFramework : DTDFVocab:Enabler [
    base:desc "Model-driven engineering frameworks for automated artifact generation from semantic BIM models"
    DTDFVocab:enables BIMValidation, ExtractMetadata, ModelTransformation, RuntimeConfigurationManagement
]

instance BIMModel : DTDFVocab:Model [
    base:desc "BIM models enriched with Building Control System (BCS) device semantics and middleware metadata for spatial, geometric, and operational information"
    DTDFVocab:inputTo ModelDrivenEngineeringFramework, BIMAuthoringTools
]

instance RealTimeMonitoring : DTDFVocab:Service [
    base:desc "Service for continuous real-time monitoring of building systems"
    DTDFVocab:provides MonitoringInsight
]

instance Simulation : DTDFVocab:Service [
    base:desc "Service for simulating building operations and performance"
    DTDFVocab:provides SimulationInsight
]

instance PredictiveAnalytics : DTDFVocab:Service [
    base:desc "Service for predictive analytics across energy, comfort, and health metrics"
    DTDFVocab:provides EnergyOptimizationInsight, VisualComfortInsight, HealthEffectInsight
]

instance EnergyConsumptionOptimization : DTDFVocab:Service [
    base:desc "Service for optimizing energy consumption through predictive analytics"
    DTDFVocab:provides EnergyOptimizationInsight, AdjustHVAC
]

instance VisualComfortManagement : DTDFVocab:Service [
    base:desc "Service for managing visual comfort in building environments"
    DTDFVocab:provides VisualComfortInsight, AdjustLighting
]

instance NonVisualHealthEffectAnalysis : DTDFVocab:Service [
    base:desc "Service for analyzing non-visual health effects of building environments"
    DTDFVocab:provides HealthEffectInsight
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "Interactive 3D visualization service for facility management"
    DTDFVocab:provides VisualizationInsight
]

instance BIMValidation : DTDFVocab:Service [
    base:desc "Service for validating BIM models for semantic correctness"
    DTDFVocab:provides BIMValidationInsight
]

instance ExtractMetadata : DTDFVocab:Service [
    base:desc "Service for automated metadata extraction from BIM models"
    DTDFVocab:provides ExtractMetadataInsight
]

instance ModelTransformation : DTDFVocab:Service [
    base:desc "Service for model-to-model transformations to generate runtime artifacts"
    DTDFVocab:provides ModelTransformationInsight
]

instance RuntimeConfigurationManagement : DTDFVocab:Service [
    base:desc "Service for runtime configuration management and twin evolution"
    DTDFVocab:provides RuntimeConfigurationManagementInsight
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Actionable insight for optimizing energy consumption in building operations"
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Actionable insight for optimizing visual comfort in building environments"
]

instance HealthEffectInsight : DTDFVocab:Insight [
    base:desc "Actionable insight for analyzing non-visual health effects in building environments"
]

instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring insights for current building conditions"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insights generated from building operation simulations"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insights derived from interactive 3D visualization of building systems"
]

instance AdjustHVAC : DTDFVocab:Action [
    base:desc "Digital command to adjust HVAC system settings for energy optimization"
    DTDFVocab:IsAutomatic true
]

instance AdjustLighting : DTDFVocab:Action [
    base:desc "Digital command to adjust lighting controls for visual comfort"
    DTDFVocab:IsAutomatic true
]

instance BIMValidationInsight : DTDFVocab:Insight [
    base:desc "Insight regarding BIM model semantic correctness"
]

instance ExtractMetadataInsight : DTDFVocab:Insight [
    base:desc "Insight from automated metadata extraction process"
]

instance ModelTransformationInsight : DTDFVocab:Insight [
    base:desc "Insight from model-to-model transformations"
]

instance RuntimeConfigurationManagementInsight : DTDFVocab:Insight [
    base:desc "Insight from runtime configuration management for twin evolution"
]

instance BuildingInfrastructure : DTDFVocab:Environment [
    base:desc "Unified virtual representation for real-time monitoring, simulation, and life cycle-encompassing optimization of physical building operations in AECO domain"
    base:contains TemperatureSensor, OccupancySensor, EnvironmentalSensor, HVACActuator, LightingControlActuator, ModularArchitecture
]

instance ModularArchitecture : DTDFVocab:Component [
    base:desc "Modular service-oriented architecture with standardized extension points for scalable integration of services"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals generated by the digital twin to adjust physical systems (e.g., lighting, HVAC) through bidirectional communication protocols using Eclipse Hono and Ditto, enabling closed-loop control of Building Control Systems (BCS)."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with continuous data exchange for immediate updates between physical and virtual systems, ensuring immediate response to operational changes."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An integrated system comprising BIM-based models, Eclipse Hono and Ditto for real-time data exchange, Unreal Engine 5 for visualization, and modular services with standardized extension points for scalable and interoperable digital twin deployment in AECO contexts."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers all building life cycle stages from initial design through construction, operation, and refurbishment, enabling life cycle-encompassing optimization of building operations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Evaluated using the Overall Digital Twin Entanglement (ODTE) metric to ensure interoperability and architectural soundness, with mechanisms to address semantic drift through synchronization techniques between digital and physical counterparts."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono and Ditto for bidirectional real-time data exchange between physical assets and the digital twin, leveraging IoT protocols for secure and scalable communication."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to Building Information Modeling (BIM) standards, Eclipse Hono and Ditto specifications, and standardized extension points for interoperable service integration across heterogeneous systems."
]