// ---------- Sensing Components ----------
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor integrated into enriched BIM, provides real‑time temperature telemetry via MQTT over TLS to Ditto."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor integrated into enriched BIM, streams humidity measurements to Ditto over secure MQTT."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in BIM, publishes occupancy counts through Eclipse Hono to Ditto."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance PowerConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Power‑consumption sensor added to BIM, sends electrical usage data via MQTT to Ditto."
    DTDFVocab:producedData PowerConsumptionDataTransmitted
]

instance FaultLogSensor : DTDFVocab:SensingComponent [
    base:desc "Fault‑log sensor metadata in BIM, reports fault events as JSON payloads over TLS‑MQTT to Ditto."
    DTDFVocab:producedData FaultLogDataTransmitted
]

// ---------- Data Transmitted ----------
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance PowerConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerConsumptionSensor
]

instance FaultLogDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FaultLogSensor
]

// ---------- Data ----------
instance TemperatureData : DTDFVocab:Data [
    base:desc "JSON payload containing temperature measurement, UTC ISO8601 timestamp, unit °C, validated by Ditto policy."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo HonoGatewayEnabler
]

instance HumidityData : DTDFVocab:Data [
    base:desc "JSON payload with humidity percentage, UTC timestamp, validated by Ditto policy."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo HonoGatewayEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "JSON payload containing occupancy counts, UTC timestamp, validated by Ditto policy."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo HonoGatewayEnabler
]

instance PowerConsumptionData : DTDFVocab:Data [
    base:desc "JSON payload with power consumption in Watts, UTC timestamp, validated by Ditto policy."
    DTDFVocab:fromData PowerConsumptionDataTransmitted
    DTDFVocab:inputTo HonoGatewayEnabler
]

instance FaultLogData : DTDFVocab:Data [
    base:desc "JSON fault‑log entry, UTC timestamp, validated by Ditto policy."
    DTDFVocab:fromData FaultLogDataTransmitted
    DTDFVocab:inputTo HonoGatewayEnabler
]

// ---------- Enablers ----------
instance HonoGatewayEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono gateway that validates, converts units, timestamps UTC ISO8601, and filters anomalies before persisting telemetry to Ditto."
    DTDFVocab:enables TelemetryIngestionService, CommandDispatchService, AnomalyHandlingService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that provides the immersive visualization portal for facility managers."
    DTDFVocab:enables VisualizationDashboardService
]

instance SemanticMappingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that maps BIM entities (sensors, actuators, geometry) to twin components using the semantic model."
    DTDFVocab:enables BuildingOntologyService
]

// ---------- Services ----------
instance TelemetryIngestionService : DTDFVocab:Service [
    base:desc "Service that ingests validated telemetry from Ditto, synchronises with BIM, and triggers monitoring insights."
    DTDFVocab:provides TemperatureMonitoringInsight, HumidityMonitoringInsight, OccupancyMonitoringInsight, PowerMonitoringInsight, FaultLogMonitoringInsight
]

instance CommandDispatchService : DTDFVocab:Service [
    base:desc "Service that dispatches actuator commands to physical devices via Ditto over MQTT."
]

instance AnomalyHandlingService : DTDFVocab:Service [
    base:desc "Service that processes fault‑log anomalies and generates automated reports."
    DTDFVocab:provides GenerateAnomalyReportAction
]

instance BuildingOntologyService : DTDFVocab:Service [
    base:desc "Service that exposes the building’s semantic model to the twin."
    DTDFVocab:provides BuildingOntologyInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Service that renders immersive dashboards for facility managers, supporting filtering and drill‑down."
    DTDFVocab:provides VisualizationInsight
]

// ---------- Insights ----------
instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight that displays real‑time temperature trend and alerts on threshold crossings."
]

instance HumidityMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight that shows humidity levels and notifies when limits are exceeded."
]

instance OccupancyMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight visualising real‑time occupancy counts for each zone."
]

instance PowerMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight depicting power consumption and highlighting abnormal spikes."
]

instance FaultLogMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight that aggregates fault‑log entries and links them to BIM components."
]

instance BuildingOntologyInsight : DTDFVocab:Insight [
    base:desc "Insight that visualises building geometry and device locations within the digital twin."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight that provides the immersive dashboard for facility managers."
]

// ---------- Actions ----------
instance GenerateAnomalyReportAction : DTDFVocab:Action [
    base:desc "Automated action that compiles fault‑log anomalies into a report for facility managers."
    DTDFVocab:IsAutomatic true
]

// ---------- Modeling ----------
instance BuildingSemanticModel : DTDFVocab:Model [
    base:desc "Semantic representation extracted from enriched BIM, including geometry, sensor definitions, and control logic."
    DTDFVocab:inputTo SemanticMappingEnabler
]

// ---------- Acting Components ----------
instance HVACUnitActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC unit actuator defined in BIM, receives control commands via Ditto over MQTT, constrained by safety ranges specified in metadata."
]

instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture actuator defined in BIM, controlled by the twin over Ditto MQTT."
]

instance GenericActuator : DTDFVocab:ActingComponent [
    base:desc "Generic actuator defined in BIM for miscellaneous control actions."
]

// ---------- Environment ----------
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, HumiditySensor, OccupancySensor, PowerConsumptionSensor, FaultLogSensor,
    HVACUnitActuator, LightingFixtureActuator, GenericActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands flow from the Digital Twin to the physical infrastructure through the same Eclipse Hono channel in the reverse direction. Commands are expressed as JSON messages encapsulated in MQTT QoS 1 payloads, containing action identifiers (e.g., 'SET_TEMPERATURE', 'ACTIVATE_VALVE'), target device IDs, and parameters. Each command is signed with a JSON Web Token (JWT) issued by an authentication server, ensuring integrity and origin authenticity. Upon receipt, the BCS (Building Control System) validates the signature, checks authorization, and forwards the instruction via a proprietary protocol (e.g., BACnet/IP). The BCS replies with a status packet indicating execution success or failure; the DT acknowledges receipt and logs the outcome. Conflict resolution is handled by the DT engine, which queues overlapping commands and enforces priority based on asset criticality or user‑defined rules."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange capabilities enable continuous synchronization between the physical building and its digital twin. The framework continuously pushes and pulls operational data at runtime, ensuring that the digital representation reflects the current state of the physical asset. The documents do not specify exact synchronization frequencies, latency thresholds, or granular temporal resolutions."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is orchestrated through a modular, service‑oriented architecture with a central DT Framework core that exposes standardized extension points for device modelling, data ingestion, analytics, and control. Runtime configuration management is employed to adjust operational parameters without full redeployment, allowing the system to evolve with changing operational requirements. The framework coordinates bidirectional data exchange, enabling a holistic lifecycle perspective across initial design, construction, operation, and refurbishment stages."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Stage 1 – Asset Digitisation: The Building Control Engineer enriches the BIM model with sensor, actuator and controller primitives (BCS components) to form a unified physical‑to‑digital mapping. Stage 2 – Model‑Driven Transformation: Model‑Driven Engineering (MDE) rules extract these BCS definitions from the BIM, normalise them into a canonical ontology and generate deployable service artefacts. Stage 3 – Deployment & Operation: The Digital Twin Engine consumes the artefacts, establishes bidirectional data links with the physical building and exposes an immersive visualisation portal for monitoring and control. Stage 4 – Evolution & Governance: Custom DT services are attached through the framework’s standardized extension points; versioning and rollback are managed in a source‑control repository, ensuring all updates remain synchronized with the legacy BIM and ERP data."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by a validation step applied to the enriched BIM before deployment, checking consistency of geometric and semantic information. During runtime, Eclipse Ditto enforces policy‑based validation of sensor data ranges and unit consistency, and of actuator command limits, preventing unsafe or invalid operations. Fault tolerance is achieved through Eclipse Hono’s at‑least‑once message delivery and Ditto’s persistent event storage, which safeguard against network failures or service disruptions, thereby maintaining synchronization and operational safety between bricks and the digital twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin’s network infrastructure is built on a hybrid enterprise topology consisting of a central cloud‑hosted Ditto service connected to edge gateways via MQTT over TLS. MQTT brokers (Hono) sit at the edge, aggregating sensor streams and forwarding them to Ditto over secure WebSockets. Bandwidth requirements are modest (≈200 kB/s for dense sensor arrays) but latency must stay below 150 ms to support real‑time monitoring; this is achieved using edge computing nodes with 1 Gbps links to the cloud. Reliability is ensured through MQTT QoS 1+/2 and TLS‑based transport, with fail‑over to secondary brokers. Network redundancy uses dual ISP connections and automatic failover. Security is enforced through mutual TLS authentication, role‑based access control in Ditto, and network segmentation to isolate critical control paths."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The framework enables horizontal integration via bidirectional data exchange between the digital twin and external systems such as BIM tools and facility management consoles. Standardized extension points provide interoperability across heterogeneous platforms, while runtime services can be integrated to extend analytics and control capabilities. No specific protocols are detailed, but interoperability across heterogeneous systems and integration patterns with enterprise systems are explicitly supported."
]