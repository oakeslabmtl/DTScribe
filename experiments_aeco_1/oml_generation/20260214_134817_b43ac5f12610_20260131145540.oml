// Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor integrated into the building’s physical control system, sampling ambient temperature"
    DTDFVocab:producedData TemperatureReading
]

instance LightingLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting level sensor measuring illuminance to support lighting comfort monitoring"
    DTDFVocab:producedData LightingLevelReading
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor detecting presence for adaptive lighting and energy control"
    DTDFVocab:producedData OccupancyReading
]

// Data Transmitted
instance TemperatureReading : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance LightingLevelReading : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingLevelSensor
]

instance OccupancyReading : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature data received from the dwelling’s temperature sensor"
    DTDFVocab:fromData TemperatureReading
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance LightingLevelData : DTDFVocab:Data [
    base:desc "Illuminance data received from the lighting level sensor"
    DTDFVocab:fromData LightingLevelReading
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy data received from the occupancy sensor"
    DTDFVocab:fromData OccupancyReading
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "Aggregated energy consumption data computed from sensor streams and building operation"
    DTDFVocab:inputTo EclipseDittoEnabler
]

// Models
instance BIMIFCModel : DTDFVocab:Model [
    base:desc "BIM (IFC) model supplying geometric and functional data for the Living Lab building"
    DTDFVocab:inputTo MDEToolEnabler, EclipseDittoEnabler
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulation model generating simulation data from analytical modules of the Digital Twin"
    DTDFVocab:inputTo EclipseDittoEnabler
]

// Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono multi‑tenant MQTT broker handling real‑time sensor data streams"
    DTDFVocab:enables MonitoringDashboardService, LightingScheduleOptimizationService, MaintenanceTaskPlanningService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto device twin platform synchronizing sensor readings and actuator states"
    DTDFVocab:enables MonitoringDashboardService, PerformanceSimulationService, LightingScheduleOptimizationService, MaintenanceTaskPlanningService, VisualizationUnrealEngineService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 environment rendering immersive visualizations of the living lab building"
    DTDFVocab:enables VisualizationUnrealEngineService
]

instance MDEToolEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation tool orchestrating semantic extraction from BIM and runtime configuration"
    DTDFVocab:enables MonitoringDashboardService, PerformanceSimulationService
]

instance ScriptingEngineEnabler : DTDFVocab:Enabler [
    base:desc "Automated script engine configuring device twins through Ditto configurator"
    DTDFVocab:enables LightingScheduleOptimizationService, MaintenanceTaskPlanningService
]

// Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards presenting energy consumption and lighting comfort"
    DTDFVocab:provides EnergyConsumptionInsight, LightingComfortInsight
]

instance PerformanceSimulationService : DTDFVocab:Service [
    base:desc "Performance simulation service using the simulation model to forecast building behavior"
    DTDFVocab:provides SimulationInsight
]

instance LightingScheduleOptimizationService : DTDFVocab:Service [
    base:desc "Optimization service applying reinforcement learning to derive efficient lighting schedules"
    DTDFVocab:provides OptimizationRecommendationInsight, AdjustLightingScheduleAction
]

instance MaintenanceTaskPlanningService : DTDFVocab:Service [
    base:desc "Task planning service generating predictive maintenance schedules based on sensor analytics"
    DTDFVocab:provides PredictiveMaintenanceScheduleInsight, PlanMaintenanceTaskAction
]

instance VisualizationUnrealEngineService : DTDFVocab:Service [
    base:desc "Immersive visualization service enabling real‑time walkthroughs of the digital twin in Unreal Engine 5"
]

// Insights
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight into real‑time energy consumption across the building"
]

instance LightingComfortInsight : DTDFVocab:Insight [
    base:desc "Insight into lighting comfort levels derived from illuminance and occupancy data"
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight providing optimal lighting schedule recommendations obtained via reinforcement learning"
]

instance PredictiveMaintenanceScheduleInsight : DTDFVocab:Insight [
    base:desc "Insight exposing predicted maintenance events for building elements"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight showing simulated building performance and energy use scenarios"
]

// Actions
instance AdjustLightingScheduleAction : DTDFVocab:Action [
    base:desc "Automatic action adjusting lighting schedules per optimization recommendations"
    DTDFVocab:IsAutomatic true
]

instance PlanMaintenanceTaskAction : DTDFVocab:Action [
    base:desc "Action planning maintenance tasks based on predictive maintenance schedules"
    DTDFVocab:IsAutomatic false
]

// Acting Components
instance LightingDimmer : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator configured within the BIM model and controlled via building control system"
]

instance LightingSwitch : DTDFVocab:ActingComponent [
    base:desc "Lighting switch actuator enabling manual on/off control of lighting fixtures"
]

// Environment
instance LivingLabBuildingEnvironment : DTDFVocab:Environment [
    base:contains LightingDimmer, LightingSwitch
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin are sent back to the building’s control system through Ditto, which forwards them via Eclipse Hono to the respective actuators in the physical building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization; data and command exchanges occur immediately upon availability without a fixed interval."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centrally managed DT constellation where each physical asset is represented by a Ditto twin, all interconnected via Hono, and rendered through Unreal Engine; the constellation is modular and expandable with additional service plug‑ins."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (ideal BIM), Construction (manufactured with BIM‑based device profiles), and Operation (live PT–DT synchronization), with the framework supporting each phase through model extraction and runtime deployment."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The entanglement of the Digital Twin with its physical counterpart is quantified using the Overall Digital Twin Entanglement (ODTE) metric."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the physical building and the twin is enabled by Eclipse Hono’s broker, which transports messages (e.g., sensor data and control commands) to and from Ditto device twins."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin is deployed in a modular, service‑oriented environment that can be scaled across cloud or edge nodes; the architecture supports repeated, reproducible deployments via automated MDE pipelines."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability with external building automation and management platforms through Eclipse Hono/Ditto; standardized integration points allow additional data sources and services to be incorporated."
]