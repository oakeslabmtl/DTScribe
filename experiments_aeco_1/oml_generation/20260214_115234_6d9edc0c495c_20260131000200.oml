// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in BIM with measurement range, accuracy and precision."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor defined in BIM with measurement range, accuracy and precision."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor defined in BIM with measurement range, accuracy and precision."
    DTDFVocab:producedData CO2DataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in BIM with measurement range, accuracy and precision."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance PowerMeterSensor : DTDFVocab:SensingComponent [
    base:desc "Power meter sensor defined in BIM with measurement range, accuracy and precision."
    DTDFVocab:producedData PowerMeterDataTransmitted
]

// C4: DataTransmitted
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance PowerMeterDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerMeterSensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature readings streamed via MQTT/CoAP from Eclipse Hono."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo HonoIngestionEnabler
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Real‑time humidity readings streamed via MQTT/CoAP from Eclipse Hono."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo HonoIngestionEnabler
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Real‑time CO₂ concentration readings streamed via MQTT/CoAP from Eclipse Hono."
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo HonoIngestionEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy counts streamed via MQTT/CoAP from Eclipse Hono."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo HonoIngestionEnabler
]

instance PowerMeterData : DTDFVocab:Data [
    base:desc "Real‑time power consumption measurements streamed via MQTT/CoAP from Eclipse Hono."
    DTDFVocab:fromData PowerMeterDataTransmitted
    DTDFVocab:inputTo HonoIngestionEnabler
]

// C11: Enablers
instance HonoIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT/CoAP ingestion pipeline that receives sensor streams and forwards them to Eclipse Ditto."
]

instance PersistenceEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto persistence layer that stores live sensor data and maintains synchronization with BIM element IDs."
    DTDFVocab:enables SimulationService, AnalysisService, OptimizationService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service providing real‑time building performance models."
    DTDFVocab:provides RealTimeInsight, ControlCommandAction
]

instance AnalysisService : DTDFVocab:Service [
    base:desc "Analysis service delivering predictive analytics and optimization recommendations."
    DTDFVocab:provides PredictiveAnalyticsInsight, DecisionSupportInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service generating actionable control setpoints for energy efficiency."
    DTDFVocab:provides ControlCommandAction
]

// C17: Insights
instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight derived from live sensor data, visualized in 3‑D for Facility Managers."
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics insight forecasting future building states and energy consumption."
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Decision‑support insight presenting recommendations to stakeholders throughout the building life‑cycle."
]

// C17: Actions
instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Control command issued to actuators (e.g., HVAC valve, lighting dimmer) via the Hono/Ditto pipeline."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve actuator modeled in BIM with unique identifier, setpoint range, ramp rates and safety temperature limits."
]

instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator modeled in BIM with unique identifier, on/off capability and dimming range."
]

instance MotorizedBlindActuator : DTDFVocab:ActingComponent [
    base:desc "Motorized blind actuator modeled in BIM with unique identifier, position setpoint and minimum ventilation constraints."
]

// C10: Models
instance GeometricBIMModel : DTDFVocab:Model [
    base:desc "Static geometric BIM model providing spatial context for the digital twin."
    DTDFVocab:inputTo PersistenceEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral control logic extracted from enriched BIM artifacts via Model‑Driven Engineering."
    DTDFVocab:inputTo PersistenceEnabler
]

instance AnalyticalServiceModel : DTDFVocab:Model [
    base:desc "Analytical service definitions (simulation, analysis, optimization) packaged as DT artifacts."
    DTDFVocab:inputTo PersistenceEnabler
]

// C5: Environment (container for components)
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, HumiditySensor, CO2Sensor, OccupancySensor, PowerMeterSensor,
                 HVACValveActuator, LightingDimmerActuator, MotorizedBlindActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Through the DT Framework’s bidirectional data exchange, the digital twin can send control commands back to building devices, enabling Facility Managers to monitor and control physical systems in real time."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin maintains a live, real‑time synchronization with the physical asset; runtime sensor data is ingested via Eclipse Hono and immediately propagated to the digital representation through Eclipse Ditto, providing continuous updates as data becomes available (near‑zero latency)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is organized around a central DT Framework that acts as the hub for all components. Device connectivity is handled by Eclipse Hono, twin state management by Eclipse Ditto, and immersive visualization by Unreal Engine. The architecture follows a modular, service‑oriented pattern with standardized extension points, enabling independent services to be plugged into the hub and coordinated centrally."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a four‑phase lifecycle: (1) Device modelling in the BIM environment where sensors, actuators and controllers are added; (2) Model‑driven transformation using Model‑Driven Engineering (MDE) to extract a structured representation and automatically generate deployable DT artifacts; (3) Deployment and runtime operation where the generated twin runs, maintains real‑time data exchange with the physical building and provides interactive visualization; (4) Evolution through the modular architecture’s standardized extension points that allow custom services, analytics and control logic to be added, producing new twin versions while preserving the underlying semantic model. Governance is exercised by the Building Control Engineer, Facility Manager and DT Engineer roles, which respectively own modelling, operation and extension."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is quantified using the Overall Digital Twin Entanglement (ODTE) metric, which measures the degree of alignment between the physical asset and its digital counterpart after deployment. Validation occurs at multiple stages: (1) static model validation during the MDE pipeline checks BIM consistency and the correctness of sensor/actuator metadata; (2) unit tests verify individual sensor and actuator model behaviours; (3) integration tests exercise the full control logic within a simulated runtime environment. Uncertainty sources such as sensor noise, latency in actuation, and simplifications in analytical models are captured in the metadata as error bounds. Continuous quality assurance is achieved through runtime monitoring in Eclipse Ditto, which detects state mismatches, logs errors, and can trigger corrective actions or model updates to maintain high entanglement throughout the DT lifecycle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The solution relies on a modular architecture with standardized extension points and runtime configuration management, allowing heterogeneous components to interoperate. The network is described as supporting interoperability, scalability from component to infrastructure level, and reliability through low‑overhead updates, but specific communication protocols, topology, bandwidth, latency, redundancy, or security mechanisms are not enumerated."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through the framework’s standardized extension points, allowing additional services or enterprise applications to be connected to the DT platform; the document does not specify concrete protocols or standards."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is built on the AECO‑specific BIM standard for model representation and explicitly declares “standardized extension points” to ensure interoperability of custom DT services. By re‑using BIM’s data schema and providing a common plugin interface, the framework aligns with industry‑wide BIM compliance requirements and supports integration with other BIM‑compatible tools."
]