// C11: Enablers
instance EfemMDETransformationEnabler : DTDFVocab:Enabler [
    base:desc "EMF-based metamodel with ATL transformations extracting domain semantics from BIM"
    DTDFVocab:enables MonitoringDashboardService, LightingOptimizationService, HVACControlPolicyService, MaintenancePlanningService
]

instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware for bidirectional MQTT/CoAP transport"
    DTDFVocab:enables MonitoringDashboardService, LightingOptimizationService, HVACControlPolicyService, MaintenancePlanningService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for device shadowing and real‑time data binding"
    DTDFVocab:enables MonitoringDashboardService, LightingOptimizationService, HVACControlPolicyService, MaintenancePlanningService, ImmersiveVisualizationService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3D visualization"
    DTDFVocab:enables ImmersiveVisualizationService
]

instance AutomatedCodeGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Automated code generators for runtime artifacts"
    DTDFVocab:enables MonitoringDashboardService
]

// C6: Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards reporting energy consumption, comfort indices, and predictive alerts"
    DTDFVocab:provides EnergyConsumptionInsight, ComfortIndexInsight, PredictiveAlertInsight
]

instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Predictive optimization of lighting schedules based on sensor data"
    DTDFVocab:provides AdjustLightingAction
]

instance HVACControlPolicyService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based HVAC control policies"
    DTDFVocab:provides AdjustHVACAction
]

instance MaintenancePlanningService : DTDFVocab:Service [
    base:desc "Task planning for maintenance events"
    DTDFVocab:provides ScheduleMaintenanceAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3‑D visualization powered by Unreal Engine 5"
    DTDFVocab:provides RenderVisualizationAction
]

// C17: Insights
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight reporting real‑time energy consumption"
]

instance ComfortIndexInsight : DTDFVocab:Insight [
    base:desc "Insight reporting indoor comfort indices"
]

instance PredictiveAlertInsight : DTDFVocab:Insight [
    base:desc "Insight providing predictive alerts for anomalies"
]

// C17: Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting dimmers to optimize schedule"
    DTDFVocab:IsAutomatic true
]

instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of HVAC setpoints via dampers"
    DTDFVocab:IsAutomatic true
]

instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Scheduling of maintenance events based on predictive models"
    DTDFVocab:IsAutomatic false
]

instance RenderVisualizationAction : DTDFVocab:Action [
    base:desc "Action to render immersive 3‑D visualization in Unreal Engine 5"
    DTDFVocab:IsAutomatic false
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental temperature sensor mapped to BIM element and represented as Ditto sensor twin"
    DTDFVocab:producedData TemperatureTelemetry
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Environmental humidity sensor"
    DTDFVocab:producedData HumidityTelemetry
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Environmental CO₂ sensor"
    DTDFVocab:producedData CO2Telemetry
]

instance LuminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Luminance sensor for lighting intensity"
    DTDFVocab:producedData LuminanceTelemetry
]

instance OccupancyMotionDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy motion detector"
    DTDFVocab:producedData OccupancyTelemetry
]

// C4: Data transmitted
instance TemperatureTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance CO2Telemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance LuminanceTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LuminanceSensor
]

instance OccupancyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyMotionDetector
]

// C10: Models/Data
instance BIMIFCModel : DTDFVocab:Model [
    base:desc "Core BIM IFC model of the living laboratory building"
    DTDFVocab:inputTo EclipseDittoEnabler, EclipseHonoEnabler
]

instance DittoTwinDefinitionModel : DTDFVocab:Model [
    base:desc "Runtime twin data models (Ditto twin definitions) for device shadows"
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C10: Data
instance TemperatureTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series data of temperature readings"
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
    DTDFVocab:fromData TemperatureTelemetry
]

instance HumidityTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series data of humidity readings"
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
    DTDFVocab:fromData HumidityTelemetry
]

instance CO2TimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series data of CO₂ readings"
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
    DTDFVocab:fromData CO2Telemetry
]

instance LuminanceTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series data of luminance readings"
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
    DTDFVocab:fromData LuminanceTelemetry
]

instance OccupancyTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series data of occupancy detections"
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
    DTDFVocab:fromData OccupancyTelemetry
]

instance CommandLogData : DTDFVocab:Data [
    base:desc "Command logs of control actions sent to actuators"
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance SimulationArtifactData : DTDFVocab:Data [
    base:desc "Simulation artifacts (lighting energy consumption curves) for predictive modeling"
    DTDFVocab:inputTo UnrealEngine5Enabler
]

// C2: Acting Components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Hardware actuator for lighting dimmers, controlled via MQTT over TLS through Eclipse Hono"
]

instance HVACDamperActuator : DTDFVocab:ActingComponent [
    base:desc "Hardware actuator for HVAC dampers, controlled via MQTT over TLS"
]

instance PlugLoadModuleActuator : DTDFVocab:ActingComponent [
    base:desc "Hardware plug‑load module, controlled via MQTT over TLS"
]

// C20: Environment hierarchy
instance BuildingTwin : DTDFVocab:Environment [
    base:desc "Top‑level building twin containing subsystem twins"
    base:contains LightingSubsystemTwin, HVACSubsystemTwin, EnvelopeSubsystemTwin
]

instance LightingSubsystemTwin : DTDFVocab:Component [
    base:desc "Lighting subsystem twin encapsulating lighting device twins"
]

instance HVACSubsystemTwin : DTDFVocab:Component [
    base:desc "HVAC subsystem twin encapsulating HVAC device twins"
]

instance EnvelopeSubsystemTwin : DTDFVocab:Component [
    base:desc "Building envelope subsystem twin encapsulating envelope device twins"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control decisions or optimization actions generated by the DT are published back through Ditto to Hono, carrying desired actuator states (e.g., light level setpoints) which propagate to the physical control devices with sub‑minute latency."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sub‑second real‑time data bus (latency < 1 s); optimisation cycles run every 5‑10 minutes, with visualisation refreshed continuously."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Central orchestrator: Ditto twin manager; connectivity hub: Hono gateway; data analytics engine; optional cloud analytics service; immersive front‑end: Unreal Engine; all coordinated via micro‑service architecture."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Lifecycle stages covered: (1) design (BIM authoring), (2) construction (device configuration extraction), (3) operation (real‑time monitoring and dynamic control); the DT is primarily instantiated for the operated phase."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Semantic fidelity monitored through the Overall Digital Twin Entanglement (ODTE) metric; simulation validation against field measurements; uncertainty quantified via error bounds on sensor data; discrepancy handling via automated reconciliation scripts."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT over TLS 1.3 for device‑to‑gateway communication; HTTP/REST for twin inventory queries; WebSocket for real‑time velocity streaming; Hono enables scalable, secure routing to Ditto."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Containerised microservices running on a Kubernetes cluster in a private cloud; Ditto and Hono deployed in Docker containers; Unreal Engine rendering node on a dedicated GPU server; time‑series database (e.g., InfluxDB) shared via secure API."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "RESTful APIs expose twin data to downstream systems (BMS, ERP, asset management) and enable import of external IoT data streams into the twin; extension points for third‑party analytics services."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM using IFC 4.x; MQTT V3.1.1/5 for data transport; Ditto following Its REST API spec; adherence to ISO/IEC 30141 (Digital Twin Definition) through the framework’s ontology."
]