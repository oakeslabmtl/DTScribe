// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental temperature sensor represented in the BIM model, streams live temperature readings"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Environmental CO₂ sensor represented in the BIM model, streams live CO₂ concentration"
    DTDFVocab:producedData CO2DataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Environmental humidity sensor represented in the BIM model, streams live humidity data"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor represented in the BIM model, streams live occupancy counts"
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C2: Acting components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator modeled in BIM, accepts bidirectional control commands via middleware"
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in BIM, accepts bidirectional control commands via middleware"
]

instance WindowShadeActuator : DTDFVocab:ActingComponent [
    base:desc "Window shade actuator modeled in BIM, accepts bidirectional control commands via middleware"
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Data
instance TemperatureLiveData : DTDFVocab:Data [
    base:desc "Live temperature stream originating from TemperatureSensor"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]

instance CO2LiveData : DTDFVocab:Data [
    base:desc "Live CO₂ concentration stream originating from CO2Sensor"
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]

instance HumidityLiveData : DTDFVocab:Data [
    base:desc "Live humidity stream originating from HumiditySensor"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]

instance OccupancyLiveData : DTDFVocab:Data [
    base:desc "Live occupancy count stream originating from OccupancySensor"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]

// C10: Models
instance BIMStructuralModel : DTDFVocab:Model [
    base:desc "BIM model serving as the structural and semantic backbone of the Living Lab building"
    DTDFVocab:inputTo BIMEnabler, MDEEnabler, UnrealEngine5Enabler
]

instance RuntimeSemanticsModel : DTDFVocab:Model [
    base:desc "BIM‑enriched model containing device definitions, control logic, and middleware metadata"
    DTDFVocab:inputTo MDEEnabler, ConfiguratorEnabler
]

// C11: Enablers
instance BIMEnabler : DTDFVocab:Enabler [
    base:desc "BIM toolchain used for semantic backbone and model persistence"
    DTDFVocab:enables BuildingPerformanceSimulationService, PredictiveAnalyticsService
]

instance MDEEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering engine generating runtime artifacts from the BIM model"
    DTDFVocab:enables RealTimeMonitoringDashboardService, CustomControlStrategyService
]

instance HonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware handling ingestion of sensor streams"
    DTDFVocab:enables RealTimeMonitoringDashboardService, CustomControlStrategyService
]

instance DittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto middleware providing digital twin state management and command routing"
    DTDFVocab:enables RealTimeMonitoringDashboardService, CustomControlStrategyService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 used for high‑fidelity 3D visualization of the twin"
    DTDFVocab:enables Interactive3DVisualizationService
]

instance ConfiguratorEnabler : DTDFVocab:Enabler [
    base:desc "Configurator extracts device metadata from BIM and deploys generated artifacts"
    DTDFVocab:enables EnergyOptimizationService, CustomControlStrategyService
]

// C6: Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards presenting live sensor data and events"
    DTDFVocab:provides EnergyConsumptionTrendInsight, ComfortLevelAssessmentInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization of the building in Unreal Engine 5"
    DTDFVocab:provides ComfortLevelAssessmentInsight
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance using the enriched BIM model"
    DTDFVocab:provides ComfortLevelAssessmentInsight, OptimizationRecommendationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics on historic and live data to forecast energy use"
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of energy consumption based on analytics and simulation results"
    DTDFVocab:provides OptimizationRecommendationInsight, AdjustHVACAction, AdjustLightingAction
]

instance CustomControlStrategyService : DTDFVocab:Service [
    base:desc "Extensible service allowing facility managers to deploy custom control strategies"
    DTDFVocab:provides AdjustHVACAction, AdjustLightingAction
]

// C17: Insights
instance EnergyConsumptionTrendInsight : DTDFVocab:Insight [
    base:desc "Insight detailing energy‑consumption trends over time for decision support"
]

instance ComfortLevelAssessmentInsight : DTDFVocab:Insight [
    base:desc "Insight assessing indoor comfort levels based on temperature, CO₂, and occupancy"
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight offering recommendations to improve energy efficiency and occupant comfort"
]

// C17: Actions
instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Action to adjust HVAC set‑points automatically or manually"
    DTDFVocab:IsAutomatic true
]

instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Action to dim or switch lighting based on occupancy and daylight levels"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., set‑point adjustments, lighting control signals) are sent back to the physical actuators through the same Hono/Ditto middleware, enabling closed‑loop operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular service‑oriented architecture comprising an enriched BIM model, a Hono/Ditto middleware layer for bidirectional communication, a runtime configurator, and an Unreal Engine visual front‑end, with defined extension points for additional services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the full building lifecycle—design, construction, commissioning, operation, and refurbishment—by leveraging BIM as a semantic backbone throughout."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validity is ensured through a validation step before deployment; fidelity of the twin to its physical counterpart is measured using the Overall Digital Twin Entanglement (ODTE) metric."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time connectivity is realized through Eclipse Hono (messaging) and Eclipse Ditto (digital twin platform), which together provide the communication backbone between physical devices and the virtual twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach follows BIM standards for building data, utilizes open‑source IoT standards implemented by Eclipse Hono and Ditto, and adheres to model‑driven engineering principles for standardized artifact generation."
]