// C3: Physical sensing components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor modelled in BIM for luminance measurement."
    DTDFVocab:producedData LightingDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modelled in BIM to detect presence of occupants."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modelled in BIM for environment temperature monitoring."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor modelled in BIM for humidity and CO₂ measurements."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance LightingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C10: Data
instance LightingData : DTDFVocab:Data [
    base:desc "Realtime luminance values streamed from LightingSensor."
    DTDFVocab:fromData LightingDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Realtime occupancy counts streamed from OccupancySensor."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Realtime temperature readings streamed from TemperatureSensor."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Realtime humidity and CO₂ readings streamed from EnvironmentalSensor."
    DTDFVocab:fromData EnvironmentalDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides secure, scalable IoT connectivity for streaming sensor measurements."
    DTDFVocab:enables RealTimeMonitoringDashboard
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto stores and manages digital‑twin state, ingesting streamed data from Hono."
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalyticsService, EnergyOptimizationAlgorithm, DeploymentService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders immersive 3‑D visualization of the building twin."
    DTDFVocab:enables UnrealVisualization
]

instance BIMAuthoringTool : DTDFVocab:Enabler [
    base:desc "BIM authoring tools (e.g., Revit) create the enriched BIM model."
    DTDFVocab:enables ModelGeneration
]

instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipelines automate transformation of BIM models to runtime artifacts."
    DTDFVocab:enables ModelGeneration
]

instance Configurator : DTDFVocab:Enabler [
    base:desc "Automated configurator deploys device‑level twins via Hono/Ditto."
    DTDFVocab:enables DeploymentService
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Dashboard visualizes live sensor data for facility managers."
    DTDFVocab:provides EnergyConsumptionInsight, VisualComfortInsight
]

instance UnrealVisualization : DTDFVocab:Service [
    base:desc "Immersive 3‑D building visualization in Unreal Engine 5."
    DTDFVocab:provides VisualComfortInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Runs predictive analytics for facility management using historical and live data."
    DTDFVocab:provides PredictiveFacilityManagementInsight
]

instance EnergyOptimizationAlgorithm : DTDFVocab:Service [
    base:desc "Optimizes building energy consumption based on sensor inputs and simulation models."
    DTDFVocab:provides EnergyOptimizationAction
]

instance CustomExtensionService : DTDFVocab:Service [
    base:desc "Extensible custom service added via defined extension points."
    DTDFVocab:provides CustomAction
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Deploys device‑level twins and updates control strategies."
    DTDFVocab:provides ControlStrategyAdjustmentAction
]

instance ModelGeneration : DTDFVocab:Service [
    base:desc "Generates runtime artifacts from the enriched BIM model via model‑to‑model and model‑to‑text transformations."
    DTDFVocab:provides ModelingInsight
]

// C17: Insights
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Provides optimization insight on building energy consumption."
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Provides insight on visual comfort based on lighting and occupancy data."
]

instance PredictiveFacilityManagementInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics insight for facility management."
]

instance ModelingInsight : DTDFVocab:Insight [
    base:desc "Insight about consistency and completeness of generated runtime artifacts."
]

// C17: Actions
instance EnergyOptimizationAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of HVAC and lighting to reduce energy use."
    DTDFVocab:IsAutomatic true
]

instance CustomAction : DTDFVocab:Action [
    base:desc "User‑defined custom action invoked via extension points."
    DTDFVocab:IsAutomatic false
]

instance ControlStrategyAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjusts control strategies based on reinforcement‑learning updates (BOREALIS project)."
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modelled in BIM, receives commands from the twin to control luminance."
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC control valve modelled in BIM, receives commands for temperature regulation."
]

// C10: Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing static geometry, spatial relationships, and runtime semantics."
    DTDFVocab:inputTo BIMAuthoringTool, ModelDrivenEngineeringPipeline
]

instance EnergySimulationModel : DTDFVocab:Model [
    base:desc "Thermal simulation model derived from BIM for energy‑optimization calculations."
    DTDFVocab:inputTo EclipseDitto
]

// C17: Environment
instance UniversityLivingLabEnvironment : DTDFVocab:Environment [
    base:contains LightingSensor, OccupancySensor, TemperatureSensor, EnvironmentalSensor, LightingActuator, HVACValveActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command transmission from the Digital Twin to building actuators through Ditto’s command API, routed via Eclipse Hono to the physical control devices."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization between physical and virtual representations (sub‑second update cycle supported by Hono/Ditto)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized DT framework hub that orchestrates bidirectional data flow (Hono ↔ Ditto), executes services, and presents the building twin through Unreal Engine; services are plugged in via standardized extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the full building lifecycle: design (BIM authoring), construction (model validation and deployment), and operation (runtime data integration and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation is performed before deployment; the Overall Digital Twin Entanglement (ODTE) metric is used to quantify the fidelity of the twin relative to its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Realtime data exchange is implemented through Eclipse Hono and Eclipse Ditto, using the standard IoT protocols supported by Hono (e.g., MQTT/HTTP) to connect physical devices with the twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework relies on BIM standards for geometric and semantic data, and defines standardized extension points for service integration, ensuring compliance with AECO interoperability guidelines."
]