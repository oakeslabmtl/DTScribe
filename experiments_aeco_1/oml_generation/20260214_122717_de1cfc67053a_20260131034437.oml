namespace DTDFVocab = "http://example.org/DTDFVocab"
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for environmental monitoring, including temperature",
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for environmental monitoring, including light",
    DTDFVocab:producedData LightDataTransmitted
]
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for environmental monitoring, including occupancy",
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance LightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature readings from environmental monitoring",
    DTDFVocab:fromData TemperatureDataTransmitted
]
instance LightData : DTDFVocab:Data [
    base:desc "Light intensity readings from environmental monitoring",
    DTDFVocab:fromData LightDataTransmitted
]
instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy status data from environmental monitoring",
    DTDFVocab:fromData OccupancyDataTransmitted
]
instance BIMModel : DTDFVocab:Model [
    base:desc "Building Information Modeling (BIM) models containing geometric, spatial, and functional characteristics of building components, used as the semantic backbone for generating runtime artifacts and enabling data-driven operations.",
    DTDFVocab:inputTo BIMTool, Ditto
]
instance BIMTool : DTDFVocab:Enabler [
    base:desc "BIM tools for modeling",
    DTDFVocab:enables Simulation
]
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for IoT device connectivity",
    DTDFVocab:enables RealTimeMonitoring
]
instance Ditto : DTDFVocab:Enabler [
    base:desc "Ditto for digital twin management",
    DTDFVocab:enables RealTimeMonitoring, Simulation, PredictiveAnalytics, ReinforcementLearningOptimization
]
instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for 3D visualization",
    DTDFVocab:enables RealTimeMonitoring
]
instance RealTimeMonitoring : DTDFVocab:Service [
    base:desc "Real-time monitoring of building systems for operational status and environmental conditions",
    DTDFVocab:provides RealTimeMonitoringInsight
]
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time operational status data for building systems"
]
instance Simulation : DTDFVocab:Service [
    base:desc "Simulation for performance analysis of building operations",
    DTDFVocab:provides PerformanceAnalysisInsight
]
instance PerformanceAnalysisInsight : DTDFVocab:Insight [
    base:desc "Performance analysis insights for building operations"
]
instance PredictiveAnalytics : DTDFVocab:Service [
    base:desc "Predictive analytics for forecasting system behavior",
    DTDFVocab:provides PredictiveInsight
]
instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Predictive insights for system behavior"
]
instance ReinforcementLearningOptimization : DTDFVocab:Service [
    base:desc "Reinforcement learning-based optimization of energy consumption, visual comfort, and non-visual health effects",
    DTDFVocab:provides EnergyOptimizationInsight, VisualComfortImprovementInsight, NonVisualHealthManagementInsight, AdjustLightingAction
]
instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insights for energy optimization"
]
instance VisualComfortImprovementInsight : DTDFVocab:Insight [
    base:desc "Insights for visual comfort improvement"
]
instance NonVisualHealthManagementInsight : DTDFVocab:Insight [
    base:desc "Insights for non-visual health effect management"
]
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automated adjustment of lighting systems based on optimization algorithms",
    DTDFVocab:IsAutomatic true
]
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuators and controllers within Building Control Systems (BCS) for lighting systems, modeled and configured in BIM for operational control."
]
instance BuildingEnvironment : DTDFVocab:Environment [
    base:desc "Building infrastructure in the AECO domain, demonstrated through a Living Lab case study for real-time monitoring, simulation, and optimization of building operations.",
    base:contains TemperatureSensor, LightSensor, OccupancySensor, LightingActuator
]
instance BuildingSystem : DTDFVocab:SystemUnderStudy [
    base:desc "Building infrastructure in the AECO domain, specifically demonstrated through a Living Lab case study for real-time monitoring, simulation, and optimization of building operations.",
    DTDFVocab:hasEnvironment BuildingEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals generated by the digital twin for Building Control Systems (BCS), such as lighting adjustments or HVAC commands, transmitted back to physical actuators through the same communication channels."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with continuous data updates from sensors, enabling immediate response to physical changes in the building environment."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A framework where BIM serves as the semantic backbone, integrated with Eclipse Hono and Ditto for bidirectional data exchange, Unreal Engine for interactive visualization, and standardized extension points for modular service integration to support building life cycle management."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers all life cycle stages from initial design through construction, operation, and refurbishment, with BIM serving as a semantic backbone for continuous data integration."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity assessed using the Overall Digital Twin Entanglement (ODTE) metric to measure the alignment between the digital twin and its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real-time data exchange via Eclipse Hono and Ditto for IoT connectivity and digital twin management."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems such as AI analytics platforms and sensor networks, facilitated through standardized extension points for service-oriented architecture."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to Building Information Modeling (BIM) standards for semantic representation, with standardized extension points for interoperable service integration."
]