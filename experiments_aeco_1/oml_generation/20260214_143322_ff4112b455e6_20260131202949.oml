// C2: Acting Components
instance OccupancyLightActuator : DTDFVocab:ActingComponent [
    base:desc "Building control device for occupancy-based lighting adjustment in the Living Lab building, modeled within BIM environment for automated commissioning and real-time control logic integration via Eclipse Hono middleware"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC system actuator for real-time temperature and airflow control in the Living Lab building, explicitly defined by Building Control Engineers for bidirectional communication with physical systems"
    DTDFVocab:producedData HVACControlDataTransmitted
]

instance EnergyOptimizationActuator : DTDFVocab:ActingComponent [
    base:desc "Custom actuator for energy optimization control policies in the Living Lab building, enabling data-driven adjustments to HVAC and lighting systems based on real-time operational data"
    DTDFVocab:producedData EnergyOptimizationControlDataTransmitted
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor embedded within the physical building infrastructure for occupancy status monitoring in the Living Lab building, integrated into BIM model for metadata extraction"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor for real-time monitoring of environmental conditions in the Living Lab building, embedded within physical infrastructure and linked to BIM metadata"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Energy consumption sensor for tracking power usage patterns in the Living Lab building, integrated with BIM for tenant-specific endpoint addressing"
    DTDFVocab:producedData EnergyDataTransmitted
]

instance LightingStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting status sensor for monitoring occupancy-based lighting conditions in the Living Lab building, embedded in physical infrastructure for real-time data acquisition"
    DTDFVocab:producedData LightingDataTransmitted
]

// C4: Data transmission
instance HVACControlDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACActuator
]

instance EnergyOptimizationControlDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyOptimizationActuator
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance LightingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingStatusSensor
]

// C10: Models/Data
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "Enriched BIM model for the Living Lab building containing embedded runtime semantics including sensor configurations and control logic, transformed via model-driven engineering principles"
    DTDFVocab:inputTo UnrealEngine5
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Real-time operational data stream containing sensor readings (occupancy, temperature, energy) and control signals processed via Ditto middleware for bidirectional synchronization with physical assets"
    DTDFVocab:fromData OccupancyDataTransmitted, TemperatureDataTransmitted, EnergyDataTransmitted, LightingDataTransmitted, HVACControlDataTransmitted, EnergyOptimizationControlDataTransmitted
]

instance VisualizationModel : DTDFVocab:Model [
    base:desc "Immersive 3D visualization model created in Unreal Engine 5 for interactive monitoring of the Living Lab building's digital twin, enabling real-time spatial data representation"
    DTDFVocab:inputTo UnrealEngine5
]

instance OperationalInsightsData : DTDFVocab:Data [
    base:desc "Processed analytics data containing real-time operational insights (energy consumption trends, occupancy patterns) derived from sensor data for decision-making support"
    DTDFVocab:fromData RealTimeOperationalData
]

// C11: Enablers
instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 platform for creating immersive 3D visualization models of the Living Lab building's digital twin, enabling interactive monitoring and spatial data representation"
]

instance DittoMiddleware : DTDFVocab:Enabler [
    base:desc "Ditto middleware for real-time data exchange between physical sensors and the digital twin, processing sensor data and enabling bidirectional synchronization with BIM models"
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono framework for real-time data transmission from physical sensors to the digital twin, automating metadata extraction from BIM models for standardized endpoint addressing"
]

instance RevitBIMTool : DTDFVocab:Enabler [
    base:desc "Revit BIM tool for device modeling within the Living Lab building infrastructure, enabling metadata extraction for sensor and actuator integration"
    DTDFVocab:inputTo BIMEnrichedModel
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring service providing live visualization of the Living Lab building's operational state through Unreal Engine 5 immersive interface"
    DTDFVocab:enables VisualizationModel
    DTDFVocab:provides VisualizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service offering operational optimization insights (energy efficiency trends, occupancy patterns) derived from real-time sensor data"
    DTDFVocab:provides EnergyOptimizationInsight, OccupancyPatternInsight
]

instance CustomServiceIntegration : DTDFVocab:Service [
    base:desc "Modular service integration framework allowing DT Engineers to add domain-specific services (e.g., reinforcement learning-based control policies from BOREALIS) for evolving digital twin functionality"
    DTDFVocab:provides CustomAction
]

// C17: Insights/Actions
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "3D spatial representation of the Living Lab building's operational state showing real-time sensor data visualization through Unreal Engine interface"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Real-time energy consumption trends and efficiency metrics derived from sensor data for HVAC and lighting optimization decisions"
]

instance OccupancyPatternInsight : DTDFVocab:Insight [
    base:desc "Occupancy patterns analysis enabling data-driven adjustments to lighting and HVAC systems based on tenant activity levels"
]

instance CustomAction : DTDFVocab:Action [
    base:desc "Domain-specific automated actions triggered by predictive analytics (e.g., reinforcement learning-based control policies from BOREALIS) for continuous building optimization"
    DTDFVocab:IsAutomatic true
]

instance PredictiveMaintenanceAction : DTDFVocab:Action [
    base:desc "Automated predictive maintenance actions triggered by sensor data patterns indicating potential equipment failures in the Living Lab building"
    DTDFVocab:IsAutomatic true
]

// C17: Environment
instance LivingLabBuildingEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, TemperatureSensor, EnergyConsumptionSensor,
                LightingStatusSensor, OccupancyLightActuator, HVACActuator,
                EnergyOptimizationActuator, BIMEnrichedModel, RealTimeOperationalData,
                VisualizationModel, OperationalInsightsData
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Facilitates control signal transmission from the digital twin to physical actuators via **Eclipse Hono** and Ditto. The framework automates the generation of runtime interfaces from BIM models, allowing the DT to execute control logic (e.g., adaptive lighting, HVAC adjustments) based on real-time operational data, ensuring seamless synchronization with physical building systems."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Operates on a **real-time (sub-second to near-real-time) time scale** for bidirectional data synchronization between physical and virtual systems. The framework ensures low-latency communication via optimized middleware (Eclipse Hono/Ditto) and automated model transformations, enabling continuous updates and adaptive control strategies."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A **service-oriented DT architecture** with a centralized deployment model, orchestrated via the DT Framework. The constellation includes the **BIM-based physical model**, **runtime middleware (Eclipse Hono/Ditto)**, **visualization layer (Unreal Engine)**, and **custom services** (e.g., adaptive lighting controls from BOREALIS). The framework supports horizontal integration with external systems (e.g., IoT platforms) via standardized APIs."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the entire **building life cycle**, from **design (ideal representation)** through **manufacturing (as-manufactured validation)** to **operation (real-time monitoring and optimization)**. The framework automates transitions between these stages by leveraging BIM as a semantic backbone and model-driven transformations to maintain consistency across phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Ensures **high fidelity** by validating BIM models against physical assets and measuring **Overall Digital Twin Entanglement (ODTE)** to quantify alignment between virtual and physical systems. The framework addresses **uncertainty** through automated data normalization and **verification/validation** mechanisms, ensuring robustness in real-time operations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Utilizes **Eclipse Hono** and **Ditto** for bidirectional communication protocols, enabling low-latency data exchange between physical sensors/actuators and the digital twin. The technical connection employs **standardized APIs** for interoperability with BIM tools and IoT platforms, ensuring seamless integration across heterogeneous systems."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployed as a **scalable, cloud-based or edge-computing solution**, leveraging the DT Framework’s modular architecture. The framework supports **standardized extension points** for hosting custom services, enabling flexible deployment configurations (e.g., centralized cloud hosting or distributed edge nodes). Unreal Engine provides a **local visualization layer** for immersive interaction."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Supports integration with **external information systems** (e.g., IoT platforms, building management systems) via standardized APIs and middleware (Eclipse Hono/Ditto). The framework enables **seamless data exchange** with other DTs or operational systems, facilitating cross-domain collaboration in AECO workflows."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not explicitly detailed in the documents, but implied to follow **BIM-centric governance models** where data ownership is primarily tied to the **physical building owner**. Privacy is managed through **standardized data protocols** (e.g., Ditto’s secure data exchange) and **role-based access controls** within the DT Framework."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adheres to **AECO-specific standards** like **BIM (Building Information Modeling)** for semantic consistency, **Eclipse Hono/Ditto** for real-time data exchange, and **Unreal Engine** for visualization. The framework includes **standardized extension points** for modular service integration, ensuring interoperability with existing AECO tools and IoT platforms."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Implements **cybersecurity measures** via Ditto’s secure data protocols and Eclipse Hono’s middleware for protecting real-time data transmission. The framework ensures **safety** by enabling remote control of physical systems only under validated conditions, with **human-in-the-loop validation** for critical operations (e.g., HVAC adjustments)."
]