// C3: Physical sensing components
instance BuildingEnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors are introduced in the BIM model as semantic objects that describe the measured physical quantity a real‑time data‑exchange channel continuously streams the sensed values from the physical devices to the Digital Twin.",
    DTDFVocab:producedData BuildingSensorDataTransmitted
]

// C4: Data transmitted from sensors
instance BuildingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingEnvironmentalSensor
]

// C11: Data produced by the transmission
instance BuildingSensorData : DTDFVocab:Data [
    base:desc "Continuous stream of sensor readings synchronised in real time with the Digital Twin.",
    DTDFVocab:fromData BuildingSensorDataTransmitted,
    DTDFVocab:inputTo EclipseDittoEnabler, UnrealEngineVisualizationEnabler
]

// C2: Physical acting components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator modelled inside the enriched BIM defines remotely executable commands for HVAC control that can be invoked via the Twin interface.",
    DTDFVocab:producedData ActuatorStateDataTransmitted
]

// C4: Data transmitted from actuators
instance ActuatorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACActuator
]

// C11: Actuator state data
instance ActuatorStateData : DTDFVocab:Data [
    base:desc "Real‑time feedback of actuator command execution status.",
    DTDFVocab:fromData ActuatorStateDataTransmitted,
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C11: Enablers
instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages twin state and provides MQTT‑based real‑time data exchange between physical building control system and the Digital Twin.",
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, DecisionSupportDashboardService, ActuationControlService
]

instance UnrealEngineVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine renders high‑fidelity interactive visualisations of the building twin.",
    DTDFVocab:enables Interactive3DSimulationService
]

instance MDETransformationEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering transformations extract enriched BIM artefacts and generate runtime models and code for the twin.",
    DTDFVocab:enables LifecycleOptimizationService, CustomPluginService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Delivers continuous real‑time monitoring of sensor data synchronised with the twin.",
    DTDFVocab:provides PerformanceInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Applies analytics extensions to predict faults and forecast performance.",
    DTDFVocab:provides FaultDetectionInsight
]

instance DecisionSupportDashboardService : DTDFVocab:Service [
    base:desc "Interactive dashboards for facility managers to view insights and issue control commands.",
    DTDFVocab:provides RecommendationInsight
]

instance Interactive3DSimulationService : DTDFVocab:Service [
    base:desc "Provides immersive 3‑D simulation and visual interaction with the building twin.",
    DTDFVocab:provides VisualizationInsight
]

instance LifecycleOptimizationService : DTDFVocab:Service [
    base:desc "Optimises building operations across the whole lifecycle using model‑based analysis.",
    DTDFVocab:provides OptimizationInsight
]

instance CustomPluginService : DTDFVocab:Service [
    base:desc "Extensible plug‑in architecture allowing custom services to be added at runtime.",
    DTDFVocab:provides CustomControlAction
]

instance ActuationControlService : DTDFVocab:Service [
    base:desc "Forwards facility‑manager commands from the Twin to physical actuators.",
    DTDFVocab:provides ActuatorCommandAction
]

// C17: Insights
instance PerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight into current building performance derived from continuous sensor streams."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Predictive insight flagging potential faults before they occur."
]

instance RecommendationInsight : DTDFVocab:Insight [
    base:desc "System‑generated recommendations presented through the visualization interface for operational improvement."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual feedback of building state within the immersive 3‑D environment."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending lifecycle‑wide optimisation actions for energy and operational efficiency."
]

// C17: Actions
instance CustomControlAction : DTDFVocab:Action [
    base:desc "Custom action invoked by a plug‑in service to interact with building subsystems.",
    DTDFVocab:IsAutomatic false
]

instance ActuatorCommandAction : DTDFVocab:Action [
    base:desc "Command sent from the Twin to a physical actuator (e.g., HVAC) to change its operating state.",
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance GeometricBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model supplying geometric layout, asset locations, and embedded device metadata.",
    DTDFVocab:inputTo MDETransformationEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model extracting control algorithms from the enriched BIM for runtime execution.",
    DTDFVocab:inputTo MDETransformationEnabler
]

instance OccupancyForecastModel : DTDFVocab:Model [
    base:desc "Analytical model forecasting occupancy patterns used for predictive analytics.",
    DTDFVocab:inputTo PredictiveAnalyticsService
]

// C14: Environment (the building)
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains BuildingEnvironmentalSensor, HVACActuator, GeometricBIMModel, ControlLogicModel, OccupancyForecastModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional data exchange allows the digital twin to send control commands back to the physical building for monitoring and actuation, enabling Facility Managers to perform real‑time control. The document mentions this capability but does not provide details on command types, message formats, validation or authentication mechanisms, feedback loops, conflict‑resolution strategies, or confirmation of command execution."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT is designed to operate on a real‑time scale: physical sensor streams are ingested continuously and fed to the digital replica with low latency, enabling live synchronization and immediate analytical feedback. The architecture requires that data be synchronized as soon as it becomes available, supporting real‑time insights and predictive analytics; no explicit synchronization interval is prescribed."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a model‑driven orchestration pattern centred on a central integration hub. Static BIM models are combined with runtime IoT data through bidirectional data exchange facilitated by Eclipse Hono (for protocol translation and connectivity) and Eclipse Ditto (for digital twin state management). The hub orchestrates services that expose standardized REST/WS APIs, enabling the Unreal Engine visualisation component to render the virtual environment. Resource management, component integration and system‑wide coordination are handled within this modular hub, which links the data acquisition, state management and visualisation layers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a model‑driven lifecycle that starts with device modeling in the BIM environment by the Building Control Engineer (definition of sensors, actuators, controllers). Enriched BIM models are then processed by model‑driven engineering (MDE) tooling to extract a structured semantic representation. The MDE step automatically generates deployable Digital Twin artifacts (ontology instances, service descriptors) which are instantiated in the runtime environment. During operation the Twin is kept in continuous synchronization with the physical building via real‑time data exchange. The Twin provides interactive visualization for monitoring and control. Extensions can be added through standardized plug‑in points, enabling evolution of the Twin throughout its operational phase. Governance is realized through role‑based responsibilities (Building Control Engineer, Facility Manager, DT Engineer) and the modular architecture that isolates lifecycle stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by binding the enriched BIM semantic model to live sensor/actuator streams through the MDE‑driven transformation pipeline; any deviation between the physical state and its digital representation is detected by the continuous real‑time synchronization layer. Validation is performed implicitly when the generated DT artifacts are deployed: the framework checks that each BIM‑defined device has a corresponding runtime endpoint and that control logic can be instantiated without manual intervention. Uncertainty sources such as stale sensor readings are mitigated by the ongoing synchronization, while semantic consistency between the BIM model and the twin is the primary quality‑assurance criterion described in the document."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system is built on a modular architecture with standardized extension points that support interoperability across heterogeneous systems and scalability from component to infrastructure level. Runtime configuration management further enhances adaptability. However, the document does not detail the underlying communication protocols, network topology, bandwidth or latency requirements, reliability or redundancy mechanisms, nor the security protocols used for network communication."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is built on Building Information Modeling (BIM), which the document cites as the emerging industry standard for construction data exchange. The framework leverages BIM as the foundational representation, enriches it with control‑logic semantics, and uses standardized extension points to ensure interoperability of custom services. No additional external standards (e.g., OPC UA, ISO 19650) are mentioned in the provided text."
]