instance BuildingTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor in building infrastructure"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance AirFlowSensor : DTDFVocab:SensingComponent [
    base:desc "Airflow sensor in HVAC system"
    DTDFVocab:producedData AirFlowDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Light level sensor for building illumination"
    DTDFVocab:producedData LightLevelDataTransmitted
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingTemperatureSensor
]

instance AirFlowDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirFlowSensor
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature readings from building sensors"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono, Ditto
]

instance AirFlowData : DTDFVocab:Data [
    base:desc "Real-time airflow data from building sensors"
    DTDFVocab:fromData AirFlowDataTransmitted
    DTDFVocab:inputTo EclipseHono, Ditto
]

instance LightLevelData : DTDFVocab:Data [
    base:desc "Real-time light level data from building sensors"
    DTDFVocab:fromData LightLevelDataTransmitted
    DTDFVocab:inputTo EclipseHono, Ditto
]

instance BuildingInformationModel : DTDFVocab:Model [
    base:desc "Building Information Modeling for device modeling of sensors, actuators, and controllers"
    DTDFVocab:inputTo UnrealEngine
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Integrates Eclipse Hono for real-time data exchange"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance Ditto : DTDFVocab:Enabler [
    base:desc "Integrates Ditto for real-time data exchange"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance UnrealEngine : DTDFVocab:Enabler [
    base:desc "Leverages Unreal Engine for rich, interactive visualization using BIM models"
    DTDFVocab:enables InteractiveVisualizationService
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring through insights"
    DTDFVocab:provides RealTimeInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for forecasting"
    DTDFVocab:provides PredictiveForecastInsight
]

instance OperationalOptimizationService : DTDFVocab:Service [
    base:desc "Operational optimization"
    DTDFVocab:provides OptimizationInsight
]

instance EnhancedDecisionMakingService : DTDFVocab:Service [
    base:desc "Enhanced decision-making capabilities"
    DTDFVocab:provides DecisionSupportInsight
]

instance ImprovedStakeholderCollaborationService : DTDFVocab:Service [
    base:desc "Improved stakeholder collaboration across the building lifecycle phases"
    DTDFVocab:provides CollaborationInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization for Facility Managers to monitor system states and operate infrastructure"
    DTDFVocab:provides VisualizationInsight
]

instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Continuous monitoring of building systems for real-time status"
]

instance PredictiveForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasting future conditions based on historical and real-time data"
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimizing building operations for efficiency and cost"
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Supporting data-driven decisions for facility management"
]

instance CollaborationInsight : DTDFVocab:Insight [
    base:desc "Enhancing collaboration among stakeholders during design, construction, and operations phases"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive visualization interfaces for system monitoring and control"
]

instance CentralDTFrameworkHub : DTDFVocab:Component [
    base:desc "Central hub coordinating multiple DT instances for building infrastructure"
]

instance AECOBuildingEnvironment : DTDFVocab:Environment [
    base:contains CentralDTFrameworkHub, EclipseHono, Ditto, UnrealEngine, BuildingTemperatureSensor, AirFlowSensor, LightLevelSensor, TemperatureDataTransmitted, AirFlowDataTransmitted, LightLevelDataTransmitted, TemperatureData, AirFlowData, LightLevelData, BuildingInformationModel, RealTimeMonitoringService, PredictiveAnalyticsService, OperationalOptimizationService, EnhancedDecisionMakingService, ImprovedStakeholderCollaborationService, InteractiveVisualizationService, RealTimeInsight, PredictiveForecastInsight, OptimizationInsight, DecisionSupportInsight, CollaborationInsight, VisualizationInsight
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication mechanisms feed control signals back to Building Control Systems (BCS), allowing Facility Managers to interact with the deployed DT for real-time monitoring and control of physical assets."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time data exchange capabilities ensure continuous synchronization between physical buildings and their digital counterparts"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Modular architecture with standardized extension points for custom service integration; central DT Framework hub facilitating bidirectional data exchange and holistic building lifecycle management through coordinated roles"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle encompasses initial design (BIM-based device modeling by Building Control Engineers), deployment (automated artifact generation via Model-Driven Engineering), operational monitoring (real-time data synchronization and interactive visualization), and evolution (custom service integration). Transition between phases is managed through MDE-driven transformations from static BIM models to dynamic DTs, with governance enforced by role-specific responsibilities (Building Control Engineers, Facility Managers, DT Engineers) as per Table I."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The framework employs a layered system architecture coupling BIM with middleware for automated commissioning, integrating Eclipse Hono and Ditto for real-time data exchange, ensuring reliable and scalable connectivity between physical devices and the digital twin."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "A model-driven framework enables scalable DT deployment with automated processes that reduce manual intervention, supporting modular architecture with runtime configuration management for adjustments without full redeployment and scalability from individual components to entire infrastructure systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework adheres to AECO-specific standards, particularly Building Information Modeling (BIM), for initial device modeling and representation of building control system components. It implements standardized extension points to ensure interoperability and modular integration of custom services, aligning with industry requirements for DT system compatibility and data exchange protocols."
]