instance EnvironmentalConditionInsight : DTDFVocab:Insight [
    base:desc "Real-time insight into temperature, humidity, and air quality conditions enabling immediate assessment of occupant comfort and system performance."
]

instance OccupancyPatternInsight : DTDFVocab:Insight [
    base:desc "Analysis of real-time and historical occupancy patterns for adaptive space utilization and energy optimization strategies."
]

