// C3: Physical sensing components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor defined in BIM, providing post-occupancy sensor data for the DT"
    DTDFVocab:producedData LightingSensorDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in BIM, feeding the DT for control policy adaptation"
    DTDFVocab:producedData TemperatureSensorDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in BIM, contributing to control policy adaptation of the DT"
    DTDFVocab:producedData OccupancySensorDataTransmitted
]

// C4: Physical-to-virtual interaction
instance LightingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance TemperatureSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C5: Data instances
instance LightingSensorData : DTDFVocab:Data [
    base:desc "Real‑time lighting sensor measurements"
    DTDFVocab:inputTo EclipseHono
    DTDFVocab:fromData LightingSensorDataTransmitted
]

instance TemperatureSensorData : DTDFVocab:Data [
    base:desc "Real‑time temperature sensor measurements"
    DTDFVocab:inputTo EclipseHono
    DTDFVocab:fromData TemperatureSensorDataTransmitted
]

instance OccupancySensorData : DTDFVocab:Data [
    base:desc "Real‑time occupancy sensor measurements"
    DTDFVocab:inputTo EclipseHono
    DTDFVocab:fromData OccupancySensorDataTransmitted
]

// C10: Models/Data
instance BIMIFCModel : DTDFVocab:Model [
    base:desc "BIM model in IFC format enriched with device metadata"
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance DittoRuntimeEntityGraphModel : DTDFVocab:Model [
    base:desc "Runtime entity graph generated by Eclipse Ditto"
    DTDFVocab:inputTo EclipseDitto
]

instance SensorMetadataModel : DTDFVocab:Model [
    base:desc "Metadata for sensors extracted from the BIM"
    DTDFVocab:inputTo EclipseDitto
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model for lighting actuators"
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance ReinforcementLearningControllerParametersModel : DTDFVocab:Model [
    base:desc "Reinforcement learning controller parameters"
    DTDFVocab:inputTo ReinforcementLearningFramework
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono, middleware for telemetry ingestion via MQTT/HTTP"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto, twin platform for device state and data management"
    DTDFVocab:enables LightingControlOptimizationService, ImmersiveVisualizationService
]

instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline converting BIM to twin assets"
    DTDFVocab:enables LightingControlOptimizationService
]

instance ReinforcementLearningFramework : DTDFVocab:Enabler [
    base:desc "Framework for deploying reinforcement‑learning based control policies"
    DTDFVocab:enables ReinforcementLearningPolicyImprovementService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards"
    DTDFVocab:provides RealTimeDashboardInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for building performance"
    DTDFVocab:provides PredictiveAnalyticsInsight, PredictiveMaintenanceAlertInsight
]

instance LightingControlOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of lighting control"
    DTDFVocab:provides EnergySavingLightingScheduleInsight, AdjustLightingAction
]

instance ReinforcementLearningPolicyImprovementService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning‑based policy improvement"
    DTDFVocab:provides RLPolicyInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization in Unreal Engine 5"
    DTDFVocab:provides ImmersiveVisualizationInsight
]

// C17: Insights
instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Dashboard showing real‑time building metrics"
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics results for building performance"
]

instance PredictiveMaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance alerts for building components"
]

instance EnergySavingLightingScheduleInsight : DTDFVocab:Insight [
    base:desc "Energy‑saving lighting schedules derived from DT analysis"
]

instance RLPolicyInsight : DTDFVocab:Insight [
    base:desc "Reinforcement‑learning‑derived control policy recommendations"
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive visualization of building data in Unreal Engine 5"
]

// C17: Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting settings as per optimization"
    DTDFVocab:IsAutomatic true
]

instance SendMaintenanceAlertAction : DTDFVocab:Action [
    base:desc "Automatic notification of predictive maintenance events"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., lighting setpoints, HVAC schedules) are sent back to the PT through the same Hono/Ditto middleware, allowing bidirectional communication with the building’s control system."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data ingestion and command propagation occur in real‑time (sub‑second to second latency) while higher‑level optimization and simulation tasks run on a longer timescale (minutes to hourly)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "centralized orchestration of the BIM semantic backbone, middleware (Hono/Ditto), rendering engine (Unreal), and custom services integrated via modular extension points"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle covers the design‑time phase (BIM model creation), the manufacturing/installation phase (device configuration and middleware deployment), and the operational phase (ongoing data exchange, analytics, and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT’s fidelity is assessed through the Overall Digital Twin Entanglement (ODTE) metric, which evaluates the quantitative alignment between PT and DT data streams, model consistency, and semantic congruence, providing validation checkpoints and uncertainty quantification."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication relies on MQTT (over TLS) via Eclipse Hono brokers, with Ditto’s REST/WS endpoints consuming and publishing JSON payloads; session persistence and QoS levels are configured to ensure reliable data transfer between PT and DT."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital twin services are deployed in a cloud‑native environment (e.g., Kubernetes on a public cloud), with micro‑service containers for Hono, Ditto, and the custom analytics services, orchestrated by a central DT framework hosted on the same platform."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with building information modeling (BIM) standards (IFC schema), adherence to MQTT‑based IoT standards via Eclipse Hono, and JSON schema validation within Ditto; the framework also follows model‑driven engineering best practices."
]