// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Physical temperature sensor modelled as a semantic object within the BIM environment, includes type temperature and spatial location."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Physical occupancy sensor modelled as a semantic object within the BIM environment, includes type occupancy and spatial location."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Physical humidity sensor modelled as a semantic object within the BIM environment, includes type humidity and spatial location."
    DTDFVocab:producedData HumidityDataTransmitted
]

// C4: Data transmitted from sensors
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

// C10: Data objects
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature measurement streamed from the physical temperature sensor."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy measurement streamed from the physical occupancy sensor."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Real‑time humidity measurement streamed from the physical humidity sensor."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// C2: Acting components
instance HVACDamperActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator captured as device entity in the enriched BIM model, linked to controller logic for HVAC damper control."
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Unified geometric‑behavioral BIM model enriched with semantic extensions for building control system components."
    DTDFVocab:inputTo EclipseDittoEnabler, UnrealEngine5Enabler
]

instance ControlSystemLogicModel : DTDFVocab:Model [
    base:desc "Control logic authored by Building Control Engineer, defining controller behavior for sensors and actuators."
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides device connectivity and ingestion of telemetry from IoT sensors."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital twin state and synchronises real‑time data with the twin."
    DTDFVocab:enables WhatIfSimulationService, DecisionSupportAnalyticsService, ControlLoopService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 delivers high‑fidelity interactive visualisation of the building model."
    DTDFVocab:enables VisualizationDashboardService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of building parameters, keeping digital and physical assets synchronised."
    DTDFVocab:provides EnergyOptimizationInsight, ComfortOptimizationInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Simulates “what‑if” scenarios for building operation and performance."
    DTDFVocab:provides EnergyOptimizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Runs predictive analytics for energy and comfort optimisation based on streamed sensor data."
    DTDFVocab:provides EnergyOptimizationInsight, ComfortOptimizationInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Offers immersive interactive visualisation dashboards for stakeholders and facility managers."
    DTDFVocab:provides OperationalDecisionInsight
]

instance DecisionSupportAnalyticsService : DTDFVocab:Service [
    base:desc "Delivers decision‑support analytics to enhance operational decisions."
    DTDFVocab:provides OperationalDecisionInsight
]

instance ControlLoopService : DTDFVocab:Service [
    base:desc "Implements control‑loop capabilities that feed back optimisation set‑points to the physical system."
    DTDFVocab:provides ActuationCommandAction
]

// C17: Insights
instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight that identifies opportunities to reduce energy consumption based on real‑time data."
]

instance ComfortOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight that recommends actions to improve occupant comfort using occupancy and environmental data."
]

instance OperationalDecisionInsight : DTDFVocab:Insight [
    base:desc "Insight delivering live visual feedback to support facility manager operational decisions."
]

// C17: Actions
instance ActuationCommandAction : DTDFVocab:Action [
    base:desc "Action that issues actuation commands from the digital twin to physical actuators."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication is supported: the DT Framework can issue control commands from the digital twin back to the building control systems, enabling Facility Managers to monitor and actuate physical infrastructure in real time. The document mentions the exchange of control signals but does not detail command formats, validation/authentication mechanisms, conflict resolution, or explicit confirmation of command execution."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework keeps the digital twin in live synchronization with the physical asset by using Eclipse Hono for real‑time ingestion of sensor data and Eclipse Ditto for immediate propagation of state changes to the twin model. Updates are applied as soon as data are received, supporting real‑time monitoring and simulation; the document does not specify explicit latency values or update frequencies, and the temporal granularity follows the underlying sensor sampling rate."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a model‑driven, service‑oriented constellation. A conceptual model defines the DT components and their interactions. Eclipse Hono is used as the IoT connectivity layer for ingesting real‑time telemetry, while Eclipse Ditto provides the digital twin management backend (state persistence, property updates, command handling). The 3D visualisation and simulation layer is realised with Unreal Engine, which consumes the twin state via standardized APIs. Coordination between these components is achieved through well‑defined extension points and REST/WS‑based interfaces, allowing independent scaling and resource allocation of each service."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports the full Digital Twin life‑cycle, starting with device modelling by Building Control Engineers directly inside the BIM environment (definition of sensors, actuators and controllers), followed by a model‑driven transformation step that uses Model‑Driven Engineering (MDE) to extract a structured representation and automatically generate deployable DT artefacts. The generated twin is then deployed, synchronised in real time with the physical building, and operated by Facility Managers through interactive visualisation. Runtime operation is complemented by a modular architecture with standardized extension points that allow DT Engineers to add custom services and analytics, enabling continuous evolution of the twin after deployment."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The proposed approach includes a validation step in which the generated Digital Twin is assessed against the physical building using the Overall Digital Twin Entanglement (ODTE) metric. This metric quantifies how closely the twin reflects the real‑world asset, thereby providing a fidelity measure. Model validation is performed after the MDE‑driven generation of artifacts, and any discrepancies identified by the ODTE evaluation trigger corrective actions to improve model accuracy. The framework thus incorporates systematic verification of both structural (BIM‑derived) and dynamic (real‑time data) aspects of the twin to ensure high quality and trustworthy operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between physical devices and the digital twin relies on the Eclipse Hono protocol stack for device ingestion and Eclipse Ditto for twin state synchronization, forming a central‑hub architecture. The modular, service‑oriented design supports interoperability across heterogeneous systems. Network requirements such as bandwidth, latency, redundancy, and security protocols are not explicitly quantified in the document, although the non‑functional requirements emphasize scalability, reliability, and security."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment follows a model‑driven approach where the DT Framework serves as a central hub, supporting modular components that can be scaled from individual devices to whole infrastructure systems. The framework allows low‑overhead updates and runtime reconfiguration, but the document does not specify the hosting environment (cloud, edge, on‑premise), computational or storage sizing, specific scalability mechanisms, deployment models, or availability/reliability guarantees."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External integration is realised through Eclipse Hono for standardized, protocol‑agnostic data exchange (e.g., MQTT, HTTP) and Eclipse Ditto for interoperable twin state exposure (JSON‑LD, WebSocket). The framework offers standardized extension points that enable plug‑in of additional enterprise systems such as BIM platforms or facility‑management solutions, adhering to open interoperability standards for data models and communication."
]