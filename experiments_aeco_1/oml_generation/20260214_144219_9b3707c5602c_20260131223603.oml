// C2: Acting Components
instance OccupancyControlActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control actuator embedded in the building's occupancy detection system, configured via BIM for adaptive lighting strategies in LEED Platinum academic spaces"
]

instance HVACControlActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC control unit integrated within the building's Building Control System (BCS), modeled in BIM for real-time temperature and humidity regulation"
]

instance AdaptiveLightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control unit implementing reinforcement learning-based strategies (BOREALIS project) for energy-efficient adaptive lighting in tenant zones"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental temperature sensor deployed in post-occupancy monitoring of the LEED Platinum academic building, feeding real-time data to the digital twin"
    DTDFVocab:producedData TemperatureDataStream
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Relative humidity sensor embedded in the building's environmental monitoring system, providing real-time humidity readings for indoor air quality assessment"
    DTDFVocab:producedData HumidityDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy detection sensor in tenant spaces, configured via BIM to trigger adaptive lighting and HVAC responses based on real-time occupancy patterns"
    DTDFVocab:producedData OccupancyDataStream
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Indoor air quality sensor measuring CO₂ levels in the LEED Platinum academic building, integrated with the digital twin for ventilation optimization"
    DTDFVocab:producedData CO2DataStream
]

instance LightIntensitySensor : DTDFVocab:SensingComponent [
    base:desc "Ambient light intensity sensor deployed in tenant zones for natural lighting integration with adaptive artificial lighting systems"
    DTDFVocab:producedData LightIntensityDataStream
]

// C4: Physical-to-virtual interaction
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance CO2DataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance LightIntensityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightIntensitySensor
]

// C10: Models/Data
instance StaticBIMModel : DTDFVocab:Model [
    base:desc "3D spatial and functional representation of the LEED Platinum academic building components (geometry, topology, relationships) serving as the semantic backbone of the digital twin"
]

instance RuntimeBIMModel : DTDFVocab:Model [
    base:desc "Automatically generated runtime model derived from StaticBIMModel via model-to-model transformations, enabling bidirectional communication with physical assets"
]

instance SensorMetadataModel : DTDFVocab:Model [
    base:desc "Extracted metadata from BIM containing tenant IDs, endpoint addresses, and device configurations for real-time data exchange"
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Domain-specific control strategies embedded directly in BIM by Building Control Engineers (e.g., adaptive lighting rules with reinforcement learning)"
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Unified real-time operational data stream combining sensor readings (temperature, humidity, occupancy, CO₂, light intensity) from the physical building"
    DTDFVocab:fromData TemperatureDataStream, HumidityDataStream,
                          OccupancyDataStream, CO2DataStream, LightIntensityDataStream
    DTDFVocab:inputTo PredictiveAnalyticsEngine
]

// C11: Enablers
instance BIMModelTransformationPipeline : DTDFVocab:Enabler [
    base:desc "Model-driven engineering framework automating transformations from StaticBIMModel to RuntimeBIMModel via model-to-model/model-to-text approaches"
    DTDFVocab:inputTo RuntimeInterfaceGeneration
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Middleware platform enabling real-time bidirectional data exchange between physical sensors/actuators and the digital twin via tenant-specific endpoint configurations"
    DTDFVocab:inputTo RealTimeDataExchange
]

instance DittoPlatform : DTDFVocab:Enabler [
    base:desc "Standardized platform for digital twin deployment and service orchestration, supporting interoperability across heterogeneous systems in the LEED Platinum building"
    DTDFVocab:inputTo ServiceIntegration
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Immersive 3D visualization environment (Unreal Engine 5) for interactive monitoring and simulation of the building's operational state in real-time"
    DTDFVocab:inputTo InteractiveVisualization
]

instance ReinforcementLearningController : DTDFVocab:Enabler [
    base:desc "Adaptive control strategy implementation (BOREALIS project) using reinforcement learning to optimize energy efficiency and occupant comfort through dynamic parameter updates"
    DTDFVocab:inputTo AdaptiveControlOptimization
]

instance BIMToolsRevit : DTDFVocab:Enabler [
    base:desc "BIM modeling tool (Revit) used by Building Control Engineers to model devices and define control logic directly within the BIM environment"
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real-time monitoring and visualization of the LEED Platinum academic building's operational state via Unreal Engine 5 immersive environment"
    DTDFVocab:provides LiveBuildingDiagnostics
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service enabling real-time data analysis for predictive analytics (energy consumption patterns, occupancy trends) to support proactive decision-making"
    DTDFVocab:provides EnergyConsumptionForecasting
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service implementing adaptive control strategies (reinforcement learning-based) to generate parameter updates and plans for improving building performance"
    DTDFVocab:provides EnergyEfficiencyOptimization, ComfortAdjustmentPlanning
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service enabling end-to-end automation of the digital twin pipeline (excluding initial BIM modeling) to simulate building performance across life cycle stages"
    DTDFVocab:provides DesignOptimizationSimulation, RefurbishmentPerformanceAnalysis
]

instance CustomServiceIntegration : DTDFVocab:Service [
    base:desc "Modular service extension point allowing DT Engineers to integrate custom services (IoT, analytics plugins) via standardized extension points"
    DTDFVocab:provides DomainSpecificServiceDeployment
]

// C17: Insights/Actions
instance LiveBuildingDiagnostics : DTDFVocab:Insight [
    base:desc "Real-time visualization of building operational parameters (temperature, humidity, occupancy) enabling Facility Managers to monitor system performance"
]

instance EnergyConsumptionForecasting : DTDFVocab:Insight [
    base:desc "Predictive analytics of energy consumption patterns to enable proactive energy management strategies"
]

instance EnergyEfficiencyOptimization : DTDFVocab:Action [
    base:desc "Automated parameter updates from reinforcement learning to optimize HVAC and lighting systems for maximum energy efficiency"
    DTDFVocab:IsAutomatic true
]

instance ComfortAdjustmentPlanning : DTDFVocab:Action [
    base:desc "Dynamic adjustment plans for HVAC and lighting systems based on real-time comfort feedback from occupants"
    DTDFVocab:IsAutomatic true
]

instance DesignOptimizationSimulation : DTDFVocab:Insight [
    base:desc "Simulation results from end-to-end DT pipeline to evaluate design alternatives and optimize building performance"
]

instance RefurbishmentPerformanceAnalysis : DTDFVocab:Insight [
    base:desc "Performance analysis supporting refurbishment planning by comparing current and proposed building configurations"
]

instance DomainSpecificServiceDeployment : DTDFVocab:Action [
    base:desc "Modular deployment of custom services (IoT integrations, analytics plugins) via standardized extension points in the DT architecture"
    DTDFVocab:IsAutomatic true
]

// Supporting Environment and Component Definitions
instance LEEDPlatinumAcademicBuilding : DTDFVocab:Environment [
    base:contains StaticBIMModel, RuntimeBIMModel,
                  OccupancyControlActuator, HVACControlActuator,
                  AdaptiveLightingActuator,
                  TemperatureSensor, HumiditySensor, OccupancySensor,
                  CO2Sensor, LightIntensitySensor
]

instance AECOStakeholderCollaboration : DTDFVocab:Environment [
    base:contains BuildingControlEngineers, FacilityManagers, DTEngineers
]

instance BOREALISReinforcementLearningSystem : DTDFVocab:Environment [
    base:contains ReinforcementLearningController, EnergyEfficiencyOptimization,
                  ComfortAdjustmentPlanning
]

// New instances to resolve all unresolved references
instance PredictiveAnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Predictive analytics engine processing real-time operational data for energy consumption forecasting and optimization strategies"
    DTDFVocab:enables PredictiveAnalyticsService
]

instance RuntimeInterfaceGeneration : DTDFVocab:Service [
    base:desc "Service generating runtime interfaces from BIM models for bidirectional communication with physical assets"
    DTDFVocab:provides RuntimeInterfaceGeneration
]

instance RealTimeDataExchange : DTDFVocab:Service [
    base:desc "Service facilitating real-time bidirectional data exchange between physical sensors and the digital twin"
    DTDFVocab:enables EclipseHono
]

instance ServiceIntegration : DTDFVocab:Service [
    base:desc "Service enabling integration of various DT services and enablers"
    DTDFVocab:enables DittoPlatform
]

instance InteractiveVisualization : DTDFVocab:Service [
    base:desc "Service providing immersive 3D visualization capabilities for building monitoring"
    DTDFVocab:enables UnrealEngineVisualization
]

instance AdaptiveControlOptimization : DTDFVocab:Service [
    base:desc "Service implementing adaptive control optimization strategies for energy efficiency and comfort"
    DTDFVocab:enables OptimizationService
]

instance BuildingControlEngineers : DTDFVocab:Component [
    base:desc "Building Control Engineers responsible for modeling devices and defining control logic in BIM"
]

instance FacilityManagers : DTDFVocab:Component [
    base:desc "Facility Managers overseeing building operations and maintenance"
]

instance DTEngineers : DTDFVocab:Component [
    base:desc "Digital Twin Engineers managing the DT architecture and service deployment"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals and optimization commands generated by the digital twin are transmitted back to the physical building infrastructure via the same middleware (Eclipse Hono/Ditto) to execute real-time adjustments. This includes automated control logic for lighting systems, HVAC adjustments, and other building automation tasks. The framework ensures seamless integration with BCS components by embedding domain-specific control semantics directly into BIM models (e.g., TwinLight project), enabling automated commissioning and bidirectional communication."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates on a **real-time synchronization scale**, ensuring **sub-second latency** for critical data exchanges between physical assets and the DT. Real-time data integration via **Eclipse Hono/Ditto middleware** enables continuous bidirectional communication, supporting **live monitoring, predictive analytics, and adaptive control** without latency-induced delays."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated as a **service-oriented platform** with a layered architecture that couples BIM with middleware (Eclipse Hono/Ditto) for real-time data synchronization. It enables modular integration of custom services and sub-twins, facilitating a decentralized yet interoperable deployment model where each component communicates via standardized interfaces."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin spans all life cycle stages of the building: 1. **Design phase**: Enriched BIM models incorporate static and dynamic BCS components (e.g., sensors/actuators) for pre-deployment simulation and clash detection. 2. **Construction phase**: Automated extraction of device metadata from BIM enables real-time commissioning and integration of physical sensors/actuators. 3. **Operation phase**: Continuous synchronization with real-time operational data (e.g., post-occupancy sensor feedback) for adaptive control and performance optimization (e.g., BOREALIS’s iterative reinforcement learning). 4. **Refurbishment phase**: The modular architecture supports dynamic updates and integration of new services without redeployment."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured through **model-driven transformations** that automate the alignment of BIM models with runtime data. The **ODTE metric** quantifies the DT’s entanglement with the physical system, addressing semantic drift by validating consistency between static BIM and dynamic operational data. Model-driven engineering (MDE) enhances maintainability and reduces cognitive overhead, though uncertainty management is not explicitly addressed in the provided context."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT employs a **layered system architecture** that integrates BIM with middleware (Eclipse Hono/Ditto) for bidirectional communication. The technical connection relies on **real-time protocols** (e.g., for sensor-to-DT data exchange) and a modular design that supports extensibility via standardized interfaces. Network protocols are abstracted through middleware, ensuring scalability and interoperability across heterogeneous systems."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is hosted on a **scalable, service-oriented platform** with the following deployment characteristics: 1. **Middleware integration**: Eclipse Hono and Ditto provide real-time data exchange and service orchestration. 2. **Visualization**: Unreal Engine 5 enables interactive 3D visualization of the building’s operational state. 3. **Modular deployment**: Standardized extension points allow DT Engineers to integrate custom services (e.g., IoT plugins, analytics tools) without redeploying the core DT. 4. **Runtime configuration**: Dynamic adjustments are supported via middleware and modular architecture, enabling adaptability to evolving operational requirements."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The digital twin integrates horizontally with: 1. **External DTs**: Via standardized extension points to enable interoperability with other digital twin ecosystems (e.g., IoT platforms, analytics tools). 2. **Building Information Modeling (BIM) systems**: Seamless integration with BIM tools (e.g., Revit) for enriched modeling and real-time synchronization. 3. **IoT and sensor networks**: Middleware (Eclipse Hono/Ditto) facilitates bidirectional communication with physical sensors/actuators deployed across the building infrastructure. 4. **Analytics and control systems**: Custom services can integrate with third-party analytics tools or reinforcement learning frameworks (e.g., BOREALIS) for advanced optimization."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adheres to **Building Information Modeling (BIM)** standards as the semantic backbone and leverages **Model-Driven Engineering (MDE)** principles for abstraction and automation. Standardized extension points facilitate interoperability with middleware (Eclipse Hono/Ditto) and other AECO tools, though specific protocols (e.g., IFC, COBie) are not explicitly mentioned."
]