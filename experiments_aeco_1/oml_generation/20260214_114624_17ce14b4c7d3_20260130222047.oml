// C2: Acting Components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for HVAC system controlling temperature and airflow in the building control systems."
]
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for lighting fixtures enabling dimming and on/off control."
]
instance BuildingController : DTDFVocab:ActingComponent [
    base:desc "Controller coordinating HVAC and lighting actuators as part of the building control system."
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in BIM to provide runtime temperature measurements."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in BIM to provide real‑time occupancy counts."
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor defined in BIM to measure ambient light levels."
    DTDFVocab:producedData LightingDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance LightingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

// C10: Models/Data (static model and runtime data)
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with device metadata (sensors, actuators, controllers) serving as the static semantic model."
    DTDFVocab:inputTo DittoTwinManager
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Stream of temperature measurements originating from TemperatureSensor."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DittoTwinManager
]
instance OccupancyData : DTDFVocab:Data [
    base:desc "Stream of occupancy counts originating from OccupancySensor."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo DittoTwinManager
]
instance LightingData : DTDFVocab:Data [
    base:desc "Stream of ambient light levels originating from LightingSensor."
    DTDFVocab:fromData LightingDataTransmitted
    DTDFVocab:inputTo DittoTwinManager
]

// C11: Enablers
instance BIMModelingTool : DTDFVocab:Enabler [
    base:desc "BIM tooling used to create and enrich the building information model with device metadata."
    DTDFVocab:enables RealTimeMonitoringService, PhysicsBasedSimulationService, OperationalOptimizationService, ImmersiveVisualizationService
]
instance HonoConnector : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware providing IoT connectivity and streaming sensor measurements to the twin."
    DTDFVocab:enables RealTimeMonitoringService, PhysicsBasedSimulationService, OperationalOptimizationService, ImmersiveVisualizationService
]
instance DittoTwinManager : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto managing digital twin state, ingesting data from Hono and exposing APIs to services."
    DTDFVocab:enables RealTimeMonitoringService, PhysicsBasedSimulationService, OperationalOptimizationService, ImmersiveVisualizationService
]
instance UnrealVisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 rendering the twin as an immersive 3D environment for facility managers."
    DTDFVocab:enables ImmersiveVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides continuous monitoring dashboards of building performance."
    DTDFVocab:provides MonitoringDashboardInsight
]
instance PhysicsBasedSimulationService : DTDFVocab:Service [
    base:desc "Runs physics‑based simulations using BIM and sensor data to predict building behavior."
    DTDFVocab:provides SimulationOutcomeInsight
]
instance OperationalOptimizationService : DTDFVocab:Service [
    base:desc "Analyzes data to generate optimization recommendations for energy and comfort."
    DTDFVocab:provides OptimizationRecommendationInsight
]
instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Delivers an interactive 3D visualization of the building twin."
    DTDFVocab:provides VisualizationExperienceAction
]

// C17: Insights/Actions
instance MonitoringDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time dashboards showing temperature, occupancy, and lighting status for facility managers."
]
instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Simulation results indicating predicted thermal comfort and energy usage."
]
instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Suggested control set‑points and schedules to improve energy efficiency."
]
instance VisualizationExperienceAction : DTDFVocab:Action [
    base:desc "User‑driven interaction within the Unreal Engine 5 environment to explore building states."
    DTDFVocab:IsAutomatic false
]

// C13: Environment (optional aggregation)
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, OccupancySensor, LightingSensor, HVACActuator, LightingActuator, BuildingController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points, HVAC adjustments) are sent back to the physical devices through the same bidirectional Hono/Ditto communication layer."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization (live data exchange) between physical assets and the twin."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where the enriched BIM model is processed by a model‑driven pipeline, middleware (Hono/Ditto) provides bidirectional data flow, and a Unreal Engine front‑end visualizes the twin; extension points allow additional services to be plugged in."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin spans the design, construction and operational phases of the building, reflecting BIM data from initial design through post‑occupancy operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Entanglement between physical and digital counterparts is quantified using the Overall Digital Twin Entanglement (ODTE) metric to assess fidelity of the twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication is realized through Eclipse Hono and Eclipse Ditto, which handle device identification, tenant information and data exchange between PT and DT."
]