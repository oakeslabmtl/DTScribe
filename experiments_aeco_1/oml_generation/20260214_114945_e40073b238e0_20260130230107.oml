// C3: Physical sensing components
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor embedded in the BIM model to measure real‑time illumination levels in the Living Lab building."
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor integrated in the BIM model that measures real‑time energy consumption of the lighting infrastructure."
    DTDFVocab:producedData EnergyDataTransmitted
]

instance EnvironmentalConditionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor represented in the enriched BIM model that captures environmental conditions (e.g., temperature, humidity) relevant to lighting performance."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// C4: Data transmitted from sensors
instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalConditionSensor
]

// C5: Data objects derived from transmissions
instance IlluminationData : DTDFVocab:Data [
    base:desc "Continuous illumination measurement stream used by monitoring and analytics services."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance EnergyData : DTDFVocab:Data [
    base:desc "Real‑time energy consumption data stream from lighting fixtures."
    DTDFVocab:fromData EnergyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Live environmental condition data (temperature, humidity) influencing lighting control decisions."
    DTDFVocab:fromData EnvironmentalDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

// C10: Models/Data derived from BIM
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM file containing geometric building elements and semantic extensions for devices, control logic, and performance rules."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance LightingControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model extracted from BIM that defines control logic for lighting actuators."
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C2: Acting components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator entity modeled in BIM to remotely control lighting fixtures via the digital twin interface."
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides secure, scalable IoT data ingestion from lighting sensors."
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages the digital twin state and offers a unified data API for services."
    DTDFVocab:enables RealTimeMonitoringService,
                      PredictiveAnalyticsService,
                      OptimizationService,
                      VisualizationService
]

instance UnrealEngineEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine renders an immersive photorealistic 3‑D visualization of the building and its lighting systems."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuously monitors illumination, energy consumption, and environmental conditions, delivering up‑to‑date state information."
    DTDFVocab:provides RealTimeInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Applies predictive analytics to forecast future lighting performance and energy usage."
    DTDFVocab:provides ForecastInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimizes lighting schedules and energy consumption based on real‑time and forecast data."
    DTDFVocab:provides OptimizationInsight,
                      ControlAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Delivers an interactive 3‑D visualization for facility managers to observe system states and initiate actions."
    DTDFVocab:provides VisualizationInsight
]

// C17: Insights
instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Provides facility managers with live state information of illumination, energy usage, and environmental conditions."
]

instance ForecastInsight : DTDFVocab:Insight [
    base:desc "Predicts future performance of lighting systems, enabling proactive decision making."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommends optimal lighting configurations to reduce energy consumption while maintaining required illumination levels."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Shows an immersive, up‑to‑date 3‑D view of the building and lighting system status."
]

// C17: Action
instance ControlAction : DTDFVocab:Action [
    base:desc "Allows facility managers to command lighting actuators remotely through the digital twin."
    DTDFVocab:IsAutomatic false
]

// Environment containing components
instance BuildingLivingLabEnvironment : DTDFVocab:Environment [
    base:contains IlluminationSensor,
                 EnergyConsumptionSensor,
                 EnvironmentalConditionSensor,
                 LightingActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Through the same bidirectional data‑exchange hub, the Digital Twin can emit control signals back to the building control systems, enabling Facility Managers to monitor and adjust building operations from the virtual environment. Control commands are sent from the DT to physical actuators or control interfaces, though the document does not detail command formats, validation, or acknowledgment mechanisms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in a real‑time mode, continuously ingesting sensor streams and updating the virtual model as soon as new measurements arrive. Synchronisation between the physical asset and its digital counterpart is performed with low latency to support live monitoring and fast feedback loops, although exact update frequencies are not quantified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a model‑driven framework that orchestrates a modular, service‑oriented DT platform. Standardised extension points expose reusable services that can be composed to form the full twin, and coordinated roles (e.g., data acquisition, model execution, analytics, and visualisation) are mapped to distinct system components. Resource management is handled centrally within the framework to ensure scalable deployment across heterogeneous infrastructure."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports the full Digital Twin life‑cycle, starting with device‑modeling within the BIM environment where sensors, actuators and controllers are defined (semantic enrichment of BIM). The enriched BIM model is then processed by Model‑Driven Engineering (MDE) transformations that extract a structured representation (domain model) and automatically generate deployable DT artefacts (runtime services, data‑exchange interfaces). After deployment, a runtime phase provides continuous real‑time data exchange and interactive visualisation for operation monitoring and control. Subsequent phases allow the integration of custom services via standardized extension points, enabling evolutionary updates. Transition between phases is orchestrated automatically by the MDE pipeline, and lifecycle governance is enforced by the functional requirement set (F_X) and the modular architecture that prescribes representation types and hand‑off rules."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution addresses the lack of standard integration by defining a modeling methodology that standardises BIM semantics for building control systems and by exposing standardized extension points for custom services. These extension points follow a common interface specification, enabling interoperability between the DT core and third‑party analytics or control plugins. The framework’s modular architecture and functional requirement set (F_X) provide a compliance framework that enforces consistent use of the standardised BIM extensions across the deployment lifecycle."
]