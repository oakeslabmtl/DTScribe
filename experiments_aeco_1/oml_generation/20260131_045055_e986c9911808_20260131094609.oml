// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor integrated into the building, as described in the BIM metadata."
    DTDFVocab:producedData TemperatureSensorDataTransmitted
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector installed in each zone, extracted from the BIM model."
    DTDFVocab:producedData OccupancySensorDataTransmitted
]

instance LightIntensitySensor : DTDFVocab:SensingComponent [
    base:desc "Light intensity sensor measuring illumination levels, described in the BIM."
    DTDFVocab:producedData LightIntensitySensorDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor monitoring air quality, defined in the BIM metadata."
    DTDFVocab:producedData CO2SensorDataTransmitted
]

instance MotionSensor : DTDFVocab:SensingComponent [
    base:desc "Motion sensor for presence detection, included in the BIM file."
    DTDFVocab:producedData MotionSensorDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance LightIntensitySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightIntensitySensor
]

instance CO2SensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance MotionSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionSensor
]

// C4: Data instances
instance TemperatureData : DTDFVocab:Data [
    base:desc "Runtime temperature data stream produced by the temperature sensor."
    DTDFVocab:fromData TemperatureSensorDataTransmitted
    DTDFVocab:inputTo HonoMQTTBroker, ReinforcementLearningEngine, PredictiveAnalyticsEngine
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Runtime occupancy data stream generated by the occupancy detector."
    DTDFVocab:fromData OccupancySensorDataTransmitted
    DTDFVocab:inputTo HonoMQTTBroker, ReinforcementLearningEngine, PredictiveAnalyticsEngine
]

instance LightIntensityData : DTDFVocab:Data [
    base:desc "Runtime light intensity data stream captured by the light sensor."
    DTDFVocab:fromData LightIntensitySensorDataTransmitted
    DTDFVocab:inputTo HonoMQTTBroker, ReinforcementLearningEngine, PredictiveAnalyticsEngine
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Runtime CO₂ data stream emitted by the CO₂ sensor."
    DTDFVocab:fromData CO2SensorDataTransmitted
    DTDFVocab:inputTo HonoMQTTBroker, ReinforcementLearningEngine, PredictiveAnalyticsEngine
]

instance MotionData : DTDFVocab:Data [
    base:desc "Runtime motion data stream from the motion sensor."
    DTDFVocab:fromData MotionSensorDataTransmitted
    DTDFVocab:inputTo HonoMQTTBroker, ReinforcementLearningEngine, PredictiveAnalyticsEngine
]

// C2: Acting Components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer unit controlled via the DT through Ditto twin endpoints."
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve actuator managed by the DT for zone temperature control."
]

instance ZoneDamperActuator : DTDFVocab:ActingComponent [
    base:desc "Zone damper actuator for airflow regulation in the building."
]

// C11: Enablers
instance HonoMQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT broker providing secure real‑time telemetry transport."
    DTDFVocab:enables MonitoringService, RealTimeDashboardService, EnergyOptimizationService
]

instance ReinforcementLearningEngine : DTDFVocab:Enabler [
    base:desc "Reinforcement learning engine that optimizes energy consumption from sensor data."
    DTDFVocab:enables EnergyOptimizationService
]

instance PredictiveAnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Predictive analytics engine powering maintenance prediction from runtime data."
    DTDFVocab:enables PredictiveMaintenanceService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 instance visualizing the digital twin in real time."
    DTDFVocab:enables ImmersiveVisualizationService
]

instance MDETransformationTool : DTDFVocab:Enabler [
    base:desc "Model‑to‑Model transformation tool converting BIM to runtime artifacts."
]

// C10: Models/Data
instance BIMIfcModel : DTDFVocab:Model [
    base:desc "BIM IFC model extracted from the Revit project."
    DTDFVocab:inputTo MDETransformationTool
]

instance DittoTwinDescriptionModel : DTDFVocab:Model [
    base:desc "Ditto twin description model derived from the BIM IFC model."
    DTDFVocab:inputTo MDETransformationTool
]

instance HonoDeviceConfigModel : DTDFVocab:Model [
    base:desc "Eclipse Hono device configuration model generated from BIM."
    DTDFVocab:inputTo MDETransformationTool
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model produced by the reinforcement learning engine."
    DTDFVocab:inputTo MDETransformationTool
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitoring service providing real‑time fault detection and status updates."
    DTDFVocab:provides FaultAlertInsight, UpdateControlPolicyAction
]

instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Real‑time dashboard service presenting building performance metrics."
    DTDFVocab:provides RealTimeBuildingPerformanceInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy optimization service utilizing reinforcement learning to reduce consumption."
    DTDFVocab:provides EnergySavingRecommendationInsight, UpdateControlPolicyAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance service that generates maintenance schedules."
    DTDFVocab:provides MaintenanceScheduleInsight, ScheduleMaintenanceAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization service displaying the building twin in Unreal Engine 5."
    DTDFVocab:provides ImmersiveVisualizationInsight, VisualizeInUnrealAction
]

instance ControlActuationService : DTDFVocab:Service [
    base:desc "Actuation service that executes control commands on building actuators."
    DTDFVocab:provides AdjustLightingAction, AdjustHVACAction, AdjustZoneDamperAction
]

// C17: Insights/Actions
instance FaultAlertInsight : DTDFVocab:Insight [
    base:desc "Insight indicating detected faults or abnormal sensor readings."
]

instance EnergySavingRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight providing energy‑saving recommendations based on reinforcement learning."
]

instance MaintenanceScheduleInsight : DTDFVocab:Insight [
    base:desc "Insight detailing recommended maintenance schedules for building assets."
]

instance RealTimeBuildingPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight presenting real‑time building performance metrics."
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful immersive visualization rendering."
]

instance UpdateControlPolicyAction : DTDFVocab:Action [
    base:desc "Automated action to update control policies for building systems."
    DTDFVocab:IsAutomatic true
]

instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Automated action to schedule maintenance tasks for building equipment."
    DTDFVocab:IsAutomatic true
]

instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automated action to adjust lighting dimmer levels via actuator."
    DTDFVocab:IsAutomatic true
]

instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Automated action to modify HVAC valve positions through actuator."
    DTDFVocab:IsAutomatic true
]

instance AdjustZoneDamperAction : DTDFVocab:Action [
    base:desc "Automated action to control zone damper positions."
    DTDFVocab:IsAutomatic true
]

instance VisualizeInUnrealAction : DTDFVocab:Action [
    base:desc "Manual action to trigger visualization of the building twin in Unreal Engine 5."
    DTDFVocab:IsAutomatic false
]

// C17: Environment
instance LivingLabEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, OccupancyDetector, LightIntensitySensor, CO2Sensor, MotionSensor,
           LightingDimmerActuator, HVACValveActuator, ZoneDamperActuator,
           HonoMQTTBroker, ReinforcementLearningEngine, PredictiveAnalyticsEngine,
           UnrealEngine5Visualization, MDETransformationTool
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originating from the DT, such as setpoint adjustments or lighting schedules, are serialized through Ditto twin updates, transmitted over MQTT to Hono, and delivered to the physical actuators to modify building operations."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near‑real‑time synchronization with data exchange intervals of a few seconds, supporting real‑time monitoring, control, and adaptive optimization within the DT lifecycle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An integrated constellation comprising the BIM‑derived runtime models, the Hono middleware, the Ditto twin registry, the DT services layer, and the visualization layer, all coordinated by the central DT orchestrator."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans all lifecycle stages: design (as ideal), manufacturing (construction), and operation (building life cycle), providing a unified digital representation from BIM through operational runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured through the Overall Digital Twin Entanglement (ODTE) metric, semantic validation of BIM metadata, and runtime consistency checks; validity is maintained via continuous verification against physical measurements and controlled convergence."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT employs MQTT over TLS for device telemetry, HTTP/REST APIs for twin queries, and Hono’s Kafka backend for scalable message routing; Ditto provides a durable event store."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT infrastructure is deployed as containerized micro‑services (Docker) orchestrated by Kubernetes, running on cloud or on‑premise data centers, with Hono broker, Ditto server, and visualization service instances."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems such as building information management platforms, facility management software, energy analytics services, and other DTs through standard APIs and shared data models."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data produced by the building’s sensors remains owned by the physical asset owner; the DT provider manages access under secure protocols, ensuring privacy through encrypted transport and role‑based authorization."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The engineering follows BIM IFC standards for structural and spatial data, MQTT for runtime communication, and Ditto’s twin JSON schema, aligning with industry best practices in AECO digital twins."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security is addressed via TLS‑encrypted MQTT, OAuth2/JWT authentication, role‑based access control, and segregation of control networks; safety considerations include fail‑safe mechanisms to prevent unsafe actuator commands and monitoring of critical system health."
]