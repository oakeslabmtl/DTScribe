// C3: Physical Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "IoT sensor for detecting occupancy in building spaces, integrated with BIM model as part of enriched semantics for real-time data acquisition."
    DTDFVocab:producedData OccupancyTelemetry
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "IoT sensor measuring ambient light levels in building zones, used for adaptive lighting control and energy optimization."
    DTDFVocab:producedData LightLevelTelemetry
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "IoT sensor monitoring indoor temperature, integrated with BAS for HVAC control and energy efficiency analysis."
    DTDFVocab:producedData TemperatureTelemetry
]

instance EnergyMeter : DTDFVocab:SensingComponent [
    base:desc "Building automation system sensor measuring real-time energy consumption across building systems, used for operational analytics."
    DTDFVocab:producedData EnergyConsumptionData
]

instance BASControlLogSensor : DTDFVocab:SensingComponent [
    base:desc "Building automation system sensor capturing control system feedback, actuator states, and system alerts for validation and diagnostics."
    DTDFVocab:producedData ControlSystemFeedback
]

// C4: Physical-to-Virtual Interaction
instance OccupancyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
    base:desc "Real-time occupancy data transmitted via MQTT/AMQP protocols through Eclipse Hono for ingestion into digital twin management system."
]

instance LightLevelTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
    base:desc "Ambient light level measurements transmitted in real-time using Eclipse Hono's policy-based access control for secure ingestion."
]

instance TemperatureTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
    base:desc "Temperature data streamed via IoT protocols to Eclipse Hono for normalization and validation before DT processing."
]

instance EnergyConsumptionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeter
    base:desc "Energy consumption telemetry transmitted from BAS sensors through Eclipse Hono for operational trend analysis."
]

instance ControlSystemFeedback : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BASControlLogSensor
    base:desc "Building control system logs and actuator states transmitted via Eclipse Hono for validation against digital twin models."
]

// C10: Models/Data
instance BIMEnrichedSemanticModel : DTDFVocab:Model [
    base:desc "Building Information Model enriched with runtime semantics including sensor/actuator metadata, control logic, and spatial relationships for operational bridging."
    DTDFVocab:inputTo ModelDrivenEngineeringTool, EclipseDitto
]

instance LightingControlLogicModel : DTDFVocab:Model [
    base:desc "TwinLight project's control logic definitions for occupancy-based lighting automation, generated via model-to-text transformations from BIM."
    DTDFVocab:inputTo ModelDrivenEngineeringTool, ReinforcementLearningFramework
]

instance ReinforcementLearningPolicyModel : DTDFVocab:Model [
    base:desc "BOREALIS project's reinforcement learning models for adaptive control policy optimization, integrated with sensor feedback loops."
    DTDFVocab:inputTo ReinforcementLearningFramework
]

instance OperationalSensorTelemetryData : DTDFVocab:Data [
    base:desc "Real-time sensor telemetry including occupancy, light levels, temperature, and energy consumption stored in Eclipse Ditto's digital twin management system."
    DTDFVocab:fromData OccupancyTelemetry, LightLevelTelemetry, TemperatureTelemetry, EnergyConsumptionData
    DTDFVocab:inputTo EclipseDitto
]

instance ControlSystemFeedbackData : DTDFVocab:Data [
    base:desc "Processed building automation system logs and actuator states validated against digital twin models for system health monitoring."
    DTDFVocab:fromData ControlSystemFeedback
    DTDFVocab:inputTo EclipseDitto
]

instance HistoricalEnergyConsumptionData : DTDFVocab:Data [
    base:desc "Archived energy consumption patterns for trend analysis, validation, and long-term optimization scenarios."
    DTDFVocab:fromData EnergyConsumptionData
    DTDFVocab:inputTo EclipseDitto
]

instance VisualizationAssets : DTDFVocab:Data [
    base:desc "3D visualization assets including interactive building system representations generated for Unreal Engine 5 integration."
    DTDFVocab:inputTo UnrealEngine5
]

// C11: Enablers
instance ModelDrivenEngineeringTool : DTDFVocab:Enabler [
    base:desc "Model-driven engineering tools for automated extraction of BIM semantics and generation of runtime artifacts via model-to-model transformations."
    DTDFVocab:enables RealTimeDataIngestionService, ControlLogicGenerationService, VisualizationAssetGenerationService
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "IoT middleware providing real-time data ingestion from heterogeneous sensor networks using MQTT/AMQP protocols with policy-based access control."
    DTDFVocab:enables RealTimeDataIngestionService, DataValidationService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Digital twin management system offering twin lifecycle management, bidirectional synchronization, and standardized JSON-based twin descriptions."
    DTDFVocab:enables DigitalTwinLifecycleManagementService, DataStorageService, TwinSynchronizationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Immersive 3D visualization platform enabling real-time rendering and physics-based interactions for building system monitoring."
    DTDFVocab:enables ImmersiveVisualizationService, InteractiveControlService
]

instance ReinforcementLearningFramework : DTDFVocab:Enabler [
    base:desc "Machine learning framework for adaptive control policy optimization in BOREALIS, integrating sensor feedback loops for dynamic adjustments."
    DTDFVocab:enables AdaptiveControlOptimizationService, PolicyRefinementService
]

// C6: Services
instance RealTimeDataIngestionService : DTDFVocab:Service [
    base:desc "Service handling real-time data ingestion from IoT sensors and BAS through Eclipse Hono with protocol translation and access control."
    DTDFVocab:provides SensorDataIngestionInsight
]

instance DataValidationService : DTDFVocab:Service [
    base:desc "Service validating and normalizing incoming sensor data against BIM semantics before ingestion into digital twin management system."
    DTDFVocab:provides DataConsistencyInsight
]

instance DigitalTwinLifecycleManagementService : DTDFVocab:Service [
    base:desc "Service managing digital twin lifecycle including creation, updates, and decommissioning through Eclipse Ditto's standardized interfaces."
    DTDFVocab:provides TwinLifecycleInsight
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Service storing operational and historical data in Eclipse Ditto's digital twin management system with versioning support."
    DTDFVocab:provides DataArchivalInsight
]

instance TwinSynchronizationService : DTDFVocab:Service [
    base:desc "Service maintaining bidirectional synchronization between physical building systems and digital twin representations."
    DTDFVocab:provides SynchronizationAlignmentInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Service providing 3D visualization of building operations in Unreal Engine 5 with real-time rendering capabilities."
    DTDFVocab:provides VisualizationInsight
]

instance InteractiveControlService : DTDFVocab:Service [
    base:desc "Service enabling facility managers to interact with building systems through Unreal Engine 5's physics-based interface."
    DTDFVocab:provides InteractiveControlInsight
]

instance ControlLogicGenerationService : DTDFVocab:Service [
    base:desc "Service generating control logic definitions from BIM models for automated deployment to building systems."
    DTDFVocab:provides ControlLogicInsight
]

instance AdaptiveControlOptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing building control policies using reinforcement learning with real-time sensor feedback."
    DTDFVocab:provides OptimizationPolicyInsight
]

instance PolicyRefinementService : DTDFVocab:Service [
    base:desc "Service iteratively refining control policies based on post-occupancy sensor data and operational feedback."
    DTDFVocab:provides PolicyRefinementInsight
]

instance VisualizationAssetGenerationService : DTDFVocab:Service [
    base:desc "Service generating 3D visualization assets from BIM models for integration with Unreal Engine 5."
    DTDFVocab:provides VisualizationAssetInsight
]

