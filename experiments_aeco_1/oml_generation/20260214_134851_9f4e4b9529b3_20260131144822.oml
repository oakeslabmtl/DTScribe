// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor integrated into the BIM model to capture post‑occupancy data."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor integrated into the BIM model to capture post‑occupancy environmental data."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// C4: Data transmitted
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C10: Data
instance OccupancyPostData : DTDFVocab:Data [
    base:desc "Post‑occupancy occupancy data received via Eclipse Hono message router."
    DTDFVocab:inputTo HonoMessageRouter, DittoTwinBroker
    DTDFVocab:fromData OccupancyDataTransmitted
]

instance EnvironmentalPostData : DTDFVocab:Data [
    base:desc "Post‑occupancy environmental data received via Eclipse Hono message router."
    DTDFVocab:inputTo HonoMessageRouter, DittoTwinBroker
    DTDFVocab:fromData EnvironmentalDataTransmitted
]

// C11: Enablers
instance HonoMessageRouter : DTDFVocab:Enabler [
    base:desc "Eclipse Hono message router for publishing sensor data to Eclipse Ditto registry."
    DTDFVocab:enables MonitoringDashboardService, PredictiveAnalyticsService
]

instance DittoTwinBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin broker providing real‑time synchronization between physical and virtual twins."
    DTDFVocab:enables MonitoringDashboardService, PredictiveAnalyticsService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 real‑time rendering engine for immersive 3D visualization."
    DTDFVocab:enables ImmersiveVisualizationService
]

instance ModelDrivenEngineeringTooling : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering tooling for model‑to‑text transformations generating runtime interfaces."
    DTDFVocab:enables RuntimeInterfaceService
]

instance UMLDomainSpecificLanguagesForBIM : DTDFVocab:Enabler [
    base:desc "UML/Domain‑Specific Modeling languages for BIM augmentation."
    DTDFVocab:enables ModelGenerationService
]

// C10: Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with sensor/actuator semantics and embedded control logic."
    DTDFVocab:inputTo UMLDomainSpecificLanguagesForBIM
]

instance EmbeddedControlLogicModel : DTDFVocab:Model [
    base:desc "Model embedding control logic for lighting and other building systems."
    DTDFVocab:inputTo UMLDomainSpecificLanguagesForBIM
]

instance ReinforcementLearningLightingPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning policy model for adaptive lighting control."
    DTDFVocab:inputTo HonoMessageRouter, DittoTwinBroker
]

instance RuntimeInterfaceModel : DTDFVocab:Model [
    base:desc "Runtime interface model generated via model‑to‑text transformations for Eclipse Hono and Ditto."
    DTDFVocab:inputTo ModelDrivenEngineeringTooling
]

// C11: Services
instance ModelGenerationService : DTDFVocab:Service [
    base:desc "Service that generates enriched BIM and control logic models using UML/Domain‑Specific Modeling languages."
    DTDFVocab:provides EnrichedBIMModel, EmbeddedControlLogicModel
]

instance RuntimeInterfaceService : DTDFVocab:Service [
    base:desc "Service to generate runtime interfaces for Hono and Ditto communication."
    DTDFVocab:provides RuntimeInterfaceModel
]

instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards for occupancy and environmental data."
    DTDFVocab:provides OccupancyDashboardInsight, EnvironmentalDashboardInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics and simulation modules for energy optimization and lighting strategy."
    DTDFVocab:provides EnergyConsumptionOptimizationInsight, LightingControlStrategyInsight, PredictiveMaintenanceScheduleAction
]

instance RLControlOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning-based control optimization for lighting."
    DTDFVocab:provides RLPolicyAction
]

instance TaskPlanningService : DTDFVocab:Service [
    base:desc "Task planning service for maintenance scheduling."
    DTDFVocab:provides MaintenanceTaskPlanningAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D visualization service utilizing Unreal Engine 5."
    DTDFVocab:provides ThreeDVisualizationInsight
]

// C17: Insights
instance EnergyConsumptionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight into energy consumption patterns enabling optimization via data‑driven models."
]

instance LightingControlStrategyInsight : DTDFVocab:Insight [
    base:desc "Insight about optimal lighting control strategies derived from sensor data."
]

instance DesignPhaseSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from design‑phase simulation for stakeholder decision support."
]

instance OccupancyDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time occupancy data visualization on monitoring dashboard."
]

instance EnvironmentalDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time environmental data visualization on monitoring dashboard."
]

instance ThreeDVisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive 3D visualization rendered via Unreal Engine 5."
]

// C17: Actions
instance PredictiveMaintenanceScheduleAction : DTDFVocab:Action [
    base:desc "Action to generate predictive maintenance schedules for lighting systems."
    DTDFVocab:IsAutomatic true
]

instance RLPolicyAction : DTDFVocab:Action [
    base:desc "Action to deploy reinforcement‑learning based lighting control policy."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceTaskPlanningAction : DTDFVocab:Action [
    base:desc "Action to plan task scheduling for maintenance using predictive analytics."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimming actuator embedded in the BIM model for real‑time manipulation of the building's internal environment via the digital twin."
]

// C0: Environment
instance TwinLightLivingLabBuilding : DTDFVocab:Environment [
    base:contains OccupancySensor, EnvironmentalSensor, LightingDimmerActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the digital twin (e.g., lighting setpoints, HVAC adjustments) are transmitted through Eclipse Ditto to the building automation system via Eclipse Hono, enabling bidirectional interaction."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time synchronization where sensor updates and control actions are processed immediately upon receipt, ensuring near real‑time consistency between the physical building and its digital twin."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation consists of a BIM‑based virtual representation, an Eclipse Ditto twin registry, an Eclipse Hono message broker, and an Unreal Engine visualisation layer, orchestrated through a modular, service‑oriented architecture."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (planning and BIM creation), construction (data extraction and model validation), and operation (real‑time monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation performed using the Overall Digital Twin Entanglement (ODTE) metric, comparing the DT’s simulated state against real sensor streams to quantify alignment and detect model drift."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication relies on Eclipse Hono as a message broker and Eclipse Ditto as a twin registry, facilitating real‑time data exchange between the physical building and its digital twin."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardised extension points expose APIs, allowing third‑party services and external information systems to plug into the digital twin ecosystem, supporting horizontal data exchange beyond the core DT stack."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM serves as the semantic backbone with its industry‑standardised property sets; communication follows ICT standards such as MQTT and the Eclipse Hono/​Ditto ecosystem, providing interoperability across building‑automation devices and software components."
]