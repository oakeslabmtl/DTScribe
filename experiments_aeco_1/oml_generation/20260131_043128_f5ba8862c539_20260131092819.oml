// Acting Components (Actuatables)
instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture actuator modeled in the BIM and controlled via Eclipse Ditto."
]
instance HVACDamperActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC damper actuator modeled in the BIM and controlled via Eclipse Ditto."
]
instance MotorisedBlindActuator : DTDFVocab:ActingComponent [
    base:desc "Motorised blinds actuator modeled in the BIM and controlled via Eclipse Ditto."
]
instance MotorisedFanActuator : DTDFVocab:ActingComponent [
    base:desc "Motorised fan actuator modeled in the BIM and controlled via Eclipse Ditto."
]

// Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor node attached to building envelope, temperature, humidity, CO2, light, occupancy and power meters."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor node attached to building envelope."
    DTDFVocab:producedData HumidityDataTransmitted
]
instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor node attached to building envelope."
    DTDFVocab:producedData CO2DataTransmitted
]
instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Light level sensor node attached to building envelope."
    DTDFVocab:producedData LightLevelDataTransmitted
]
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor node attached to building envelope."
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance PowerMeterSensor : DTDFVocab:SensingComponent [
    base:desc "Power meter sensor node attached to building envelope."
    DTDFVocab:producedData PowerMeterDataTransmitted
]

// Data Transmitted Instances
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]
instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]
instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance PowerMeterDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerMeterSensor
]

// Data Instances
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature telemetry stream."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoBrokerEnabler
]
instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity telemetry stream."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseHonoBrokerEnabler
]
instance CO2Data : DTDFVocab:Data [
    base:desc "CO₂ telemetry stream."
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseHonoBrokerEnabler
]
instance LightLevelData : DTDFVocab:Data [
    base:desc "Light level telemetry stream."
    DTDFVocab:fromData LightLevelDataTransmitted
    DTDFVocab:inputTo EclipseHonoBrokerEnabler
]
instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy telemetry stream."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoBrokerEnabler
]
instance PowerMeterData : DTDFVocab:Data [
    base:desc "Power meter telemetry stream."
    DTDFVocab:fromData PowerMeterDataTransmitted
    DTDFVocab:inputTo EclipseHonoBrokerEnabler
]

// Enablers
instance EclipseHonoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono cloud‑native MQTT broker for ingesting sensor telemetry."
    DTDFVocab:enables RealTimeMonitoringDashboardService
]
instance EclipseDittoServiceEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for device twin state updates and control command routing."
    DTDFVocab:enables SimulationModuleService
]
instance UnrealEngineVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine for immersive 3D visualization of the Digital Twin."
    DTDFVocab:enables Immersive3DVisualizationService
]
instance EclipseEMFTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Modeling Framework for model transformations."
]
instance BIMtoDTMetamodelEnabler : DTDFVocab:Enabler [
    base:desc "Custom BIM‑to‑DT metamodel for integrating BIM into the Digital Twin."
]

// Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard service exposing REST/GraphQL APIs."
    DTDFVocab:provides EnergyConsumptionInsight, OccupantComfortInsight, PredictiveFaultWarningInsight, AdjustSetpointsAction, ScheduleMaintenanceAction
]
instance SimulationModuleService : DTDFVocab:Service [
    base:desc "Simulation module service for occupancy forecasting and control logic validation."
    DTDFVocab:provides OccupancyForecastInsight
]
instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy optimization service that balances HVAC and lighting subsystems."
    DTDFVocab:provides EnergyOptimizationInsight
]
instance Immersive3DVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3‑D visualization service in Unreal Engine."
]

// Insights
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight on total energy consumption derived from telemetry streams."
]
instance OccupantComfortInsight : DTDFVocab:Insight [
    base:desc "Insight on occupant comfort based on temperature, humidity, and light level data."
]
instance PredictiveFaultWarningInsight : DTDFVocab:Insight [
    base:desc "Predictive fault warning insight generated from anomaly detection in sensor data."
]
instance OccupancyForecastInsight : DTDFVocab:Insight [
    base:desc "Occupancy forecasting insight generated from historical occupancy telemetry."
]
instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight on optimal energy usage derived from simulation outputs."
]

// Actions
instance AdjustSetpointsAction : DTDFVocab:Action [
    base:desc "Action to adjust HVAC and lighting setpoints based on analytics."
    DTDFVocab:IsAutomatic false
]
instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Action to schedule maintenance tasks for actuators and sensors."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated in the DT (e.g., set light level, adjust HVAC setpoints) are published over MQTT via Hono to the corresponding Ditto device twin, then forwarded to the physical actuator endpoints on the building’s control bus."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data propagation within 100‑ms latency, with measurement intervals ranging from every second to every minute depending on device type. Simulations run at higher frequency (up to 10 Hz) for control loops."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated platform comprising the BIM‑based asset model, the Hono message broker, the Ditto twin registry, and the Unreal Engine front‑end. Service components such as the optimization engine and reinforcement‑learning policy server are plugged in via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Designed (BIM model generation), manufactured (equipment lists and installation metadata), and operated (live operation of the building). The twin supports all stages through lifecycle‑aware annotations in the BIM and runtime configuration files."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin’s fidelity is validated using the Overall Digital Twin Entanglement (ODTE) metric, comparing live telemetry against the BIM model. Verification is performed through unit tests on the transformation code, while integration tests ensure correct message routing. Uncertainty is mitigated via calibration routines and sensor fusion."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "IoT devices communicate via MQTT over TLS 1.2, mediated by Eclipse Hono partitions. Ditto exposes WebSocket, HTTP, and MQTT endpoints for reliable duplex communication. The physical side uses Modbus/TCP or BACnet/IP to interface with building systems."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT stack is deployed in a cloud‑native environment (e.g., Kubernetes on AWS/GCP) with edge gateways for latency‑critical devices. Ditto services run as stateful pods; Hono runs as a message broker cluster; Unreal Engine serves as a web‑based client via WebGL."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The twin can connect to external systems such as enterprise asset management (EAM), energy management systems (EMS), and research platforms (BOREALIS, TwinLight) via REST/GraphQL and MQTT bridges, enabling cross‑domain dataflow."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adopts IFC for building model data, ETL standards for sensor metadata, MQTT/CoAP for messaging, and IEC 61334‑7‑1 for device‑twin representation. Framework complies with ETSI M2M positioning and follows the ODTE measurement standard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Communication is secured with TLS and OAuth2 authentication; Ditto enforces tenant‑based access control. The twin’s control logic is sandboxed to prevent unsafe commands, and risk assessment is performed before deploying new control policies."
]