// ---------- Sensing Components ----------
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors embedded in the building that detect space occupancy, configured in the enriched BIM model and streamed via Eclipse Hono."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors measuring illumination levels within building zones, configured in the BIM model and streamed via MQTT."
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors that capture ambient temperature in rooms and HVAC ducts, represented in the semantic BIM model."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance EnergyMeterSensor : DTDFVocab:SensingComponent [
    base:desc "Electrical energy meters that record power consumption of building systems, linked to the digital twin through Ditto."
    DTDFVocab:producedData EnergyDataTransmitted
]

// ---------- Data Transmitted ----------
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeterSensor
]

// ---------- Data ----------
instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy measurements streamed from the building to the twin."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Live illumination level readings supplied by BIM‑linked light sensors."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Current temperature values collected by room and duct sensors."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance EnergyData : DTDFVocab:Data [
    base:desc "Instantaneous power consumption values reported by building energy meters."
    DTDFVocab:fromData EnergyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

// ---------- Enablers ----------
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides MQTT‑based ingestion of sensor streams and forwards them to Eclipse Ditto."
    DTDFVocab:enables RealTimeMonitoringDashboard
]

instance ModelTransformationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation engine that auto‑generates configuration for Hono/Ditto and produces runtime artifacts."
    DTDFVocab:enables PredictiveAnalyticsService
    DTDFVocab:enables BuildingPerformanceSimulationService
    DTDFVocab:enables EnergyOptimizationService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders the 3‑D immersive visualization of the digital twin."
    DTDFVocab:enables Interactive3DVisualizationService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages twin state, persisting incoming data and exposing it to services."
    DTDFVocab:enables RealTimeMonitoringDashboard
]

// ---------- Models ----------
instance BIMModel : DTDFVocab:Model [
    base:desc "The BIM model acts as the semantic backbone, expressing geometry, spaces and building services."
    DTDFVocab:inputTo ModelTransformationEngineEnabler
]

instance DeviceMetadataModel : DTDFVocab:Model [
    base:desc "Enriched BIM data that captures device configurations, IDs and MQTT topics."
    DTDFVocab:inputTo ModelTransformationEngineEnabler
]

instance ControlSemanticsModel : DTDFVocab:Model [
    base:desc "Model describing control logic, actuator commands and their mapping to building services."
    DTDFVocab:inputTo ModelTransformationEngineEnabler
]

instance RuntimeArtifactsModel : DTDFVocab:Model [
    base:desc "Artifacts generated by the model‑driven pipeline (e.g., Hono topic configs, Ditto policies)."
    DTDFVocab:inputTo ModelTransformationEngineEnabler
]

// ---------- Services ----------
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Interactive dashboards that show live sensor streams and twin state."
    DTDFVocab:provides VisualDecisionSupportInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics that forecast energy usage and comfort based on historical and live data."
    DTDFVocab:provides PredictiveAnalyticsOutcomeInsight
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance under varying operational scenarios."
    DTDFVocab:provides SimulationResultInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization engine that generates energy‑saving recommendations for facility managers."
    DTDFVocab:provides OptimizationRecommendationInsight
    DTDFVocab:provides ControlCommandAction
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "3‑D immersive visualization rendered in Unreal Engine 5 for decision support."
    DTDFVocab:provides VisualDecisionSupportInsight
]

// ---------- Insights ----------
instance VisualDecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Insight delivering visual decision‑support dashboards and immersive views to operators."
]

instance PredictiveAnalyticsOutcomeInsight : DTDFVocab:Insight [
    base:desc "Insight presenting forecasted energy consumption and occupant comfort trends."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight providing actionable energy‑optimization recommendations."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight delivering simulation results of building performance under proposed scenarios."
]

// ---------- Actions ----------
instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Action to send control commands (e.g., lighting or HVAC set‑points) from the twin to actuators."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication from the twin to the building: control logic executed in the twin generates command messages that are sent through Ditto and Eclipse Hono back to the actuators in the physical system."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near‑real‑time synchronization, with sensor updates and control commands exchanged continuously at sub‑second to second intervals."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where the DT framework acts as a central hub: enriched BIM models are transformed into runtime artifacts, Hono ingests sensor streams, Ditto maintains twin state, and Unreal Engine visualises the twin; extension points allow additional services to be plugged in."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the full building lifecycle: design (BIM creation), construction (device configuration), operation (continuous monitoring and control), and refurbishment/adaptation phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to quantify how closely the twin reflects its physical counterpart, providing a measure of fidelity and guiding validation efforts."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time data exchange is realized through the Eclipse Hono middleware coupled with Eclipse Ditto, enabling continuous bidirectional communication between physical devices and the digital twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on BIM standards for semantic consistency and defines standardized extension points to ensure interoperable, service‑oriented digital twin components."
]