// Sensing components
instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Streams environmental sensor data, including temperature and humidity, into the DT via the real‑time ingestion layer."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

instance OperationalSensor : DTDFVocab:SensingComponent [
    base:desc "Streams operational sensor data such as occupancy levels and equipment status using MQTT into the DT."
    DTDFVocab:producedData OperationalDataTransmitted
]

instance DeviceStatusProvider : DTDFVocab:SensingComponent [
    base:desc "Provides device status updates through Eclipse Hono to keep the DT synchronized with physical device states."
    DTDFVocab:producedData DeviceStatusDataTransmitted
]

// Data transmitted instances
instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance OperationalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalSensor
]

instance DeviceStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DeviceStatusProvider
]

// Data instances
instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Environmental sensor readings received via Eclipse Hono, validated by Ditto policies before being stored in the DT."
    DTDFVocab:inputTo DittoEnabler
    DTDFVocab:fromData EnvironmentalDataTransmitted
]

instance OperationalData : DTDFVocab:Data [
    base:desc "Operational sensor data streamed through Eclipse Hono, routed to Ditto for policy-based validation."
    DTDFVocab:inputTo HonoEnabler
    DTDFVocab:fromData OperationalDataTransmitted
]

instance DeviceStatusData : DTDFVocab:Data [
    base:desc "Device status updates loaded from Hono, validated by Ditto and persisted for state retention."
    DTDFVocab:inputTo HonoEnabler
    DTDFVocab:fromData DeviceStatusDataTransmitted
]

// Enabler instances
instance DittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto connectivity layer enforcing policy-based validation and providing persistent event storage."
    DTDFVocab:enables MonitoringService, OptimizationService
]

instance HonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware synchronizing data streams between sensors/actuators and the DT."
    DTDFVocab:enables MonitoringService, ControlService
]

instance MDEGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering transformation engine that validates and generates DT artifacts from the enriched BIM."
    DTDFVocab:enables ModelGenerationService
] // TODO: Fix the error on this line using the following error message: 'Couldn't resolve reference to NamedInstance 'ModelGenerationService'.

instance ModelGenerationService : DTDFVocab:Service [
    base:desc "Generates Digital Twin artifacts from the enriched BIM model."
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous, real‑time acquisition of device state data through Hono and Ditto."
    DTDFVocab:provides EnergyConsumptionInsight, SystemHealthInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Execution of control logic defined by Building Control Engineers to actuate building devices."
    DTDFVocab:provides LightControlAction, HVACControlAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Algorithmic analysis of aggregated data to recommend energy‑saving schedules and operational improvements."
    DTDFVocab:provides EnergyEfficiencyInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Predictive analytics that forecast equipment failures and environmental conditions."
    DTDFVocab:provides TemperatureForecastInsight, FailurePredictionInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive, interactive interfaces (Unreal Engine 5) displaying the building’s physical and digital states."
]

// Insights
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Analysis of energy consumption trends from monitoring data to flag high‑usage periods."
]

instance SystemHealthInsight : DTDFVocab:Insight [
    base:desc "Status of critical devices aggregated from device status updates."
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Recommendations for energy‑saving schedules derived from optimization algorithms."
]

instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasting temperature swings to anticipate HVAC load adjustments."
]

instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive model outputs identifying potential equipment failures before they occur."
]

// Actions
instance LightControlAction : DTDFVocab:Action [
    base:desc "Command to adjust brightness and color temperature of lighting fixtures (0–100% and 2700–6500 K)."
    DTDFVocab:IsAutomatic false
]

instance HVACControlAction : DTDFVocab:Action [
    base:desc "Command to adjust HVAC setpoints based on optimization outputs."
    DTDFVocab:IsAutomatic true
]

// Acting components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Represents light fixtures, enabling on/off control, brightness adjustment, and color temperature modulation via LightControlAction."
]

instance UnrealTwinController : DTDFVocab:ActingComponent [
    base:desc "Brooks messages to the DittoController, translating user commands from the Unreal Engine visualization."
]

instance DittoController : DTDFVocab:ActingComponent [
    base:desc "Sends validated payloads to physical devices via DittoDevice interfaces, ensuring at‑least‑once delivery."
]

// Model
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched Building Information Model embedding geometric data and detailed device metadata for HVAC, lighting, and other building services."
    DTDFVocab:inputTo MDEGeneratorEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control messages originating from the Digital Twin are transmitted back to physical building devices through the same bidirectional communication channel. The DT Framework maps virtual command intents (e.g., HVAC setpoint changes, lighting level adjustments, fault interventions) to device‑specific command formats via adapters provided in the modular architecture. Validation and authentication are performed by the framework’s runtime policy engine, ensuring only authorized commands are forwarded. Physical devices acknowledge execution, and the DT records the confirmation in the digital model, enabling conflict resolution based on priority rules defined in the deployment configuration."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated by a modular framework positioned as a central hub that facilitates bidirectional data exchange between physical buildings and their digital counterparts. The architecture follows a component-based pattern with standardized extension points that allow for the integration of custom services and analytics. Runtime configuration management is employed to enable dynamic adaptation without full redeployments, and the framework supports both centralized control of operational data and scalable deployment across the building life cycle. The framework coordinates roles such as Building Control Engineers, Facility Managers, and DT Engineers, allowing device modelling, real‑time monitoring, and extension of capabilities through service integration."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Enrichment – Building Control Engineers model devices, actuators and control logic directly within BIM, producing enriched BIM models that capture building component‑system (BCS) elements. Extraction – Using model‑driven engineering (MDE) principles, the framework automatically extracts structured, semantic representations from the enriched BIM (e.g., GIS‑compatible data structures). Deployment – The extracted models are compiled into deployable Digital Twin artifacts (containers, microservices) with minimal manual intervention; DT Engineers deploy these artifacts to a runtime environment. Operation – Real‑time data‑exchange protocols (e.g., MQTT or OPC UA) continuously sync sensor/actuator streams between the physical building and the DT, enabling Facility Managers to monitor status and issue control commands via interactive visualization dashboards. Extension – Custom services, analytics and plugins are added through standardized extension points, leveraging a modular architecture that isolates new functionality while preserving core runtime integrity. Maintenance – Lifecycle governance relies on automated transformation pipelines and versioned BIM artifacts; manual intervention is limited to configuration changes, and incremental updates to BIM models trigger regeneration of the Corresponding DT artifacts, ensuring consistency across lifecycle stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through multiple layers of validation: enriched BIM models are syntactically verified against IFC schema extensions and semantically checked by custom validators that confirm completeness of device metadata. Runtime data integrity is maintained by Eclipse Ditto’s policy‑based value and unit validation, which flags or rejects out‑of‑range sensor readings before propagation to the Digital Twin. Fault tolerance uses Eclipse Hono’s at‑least‑once delivery semantics combined with Ditto’s persistent event storage, allowing the Twin to recover messages after network failures. Verification of control logic is performed by comparing executed device states with the expected outcomes derived from the embedded behavioral models, while any discrepancy triggers an automated alert. Uncertainty quantification is managed by enumerating measurement precision and sensor accuracy within the Ditto policies, e.g., specifying ±0.5 % for luminance sensors. Overall quality assurance follows a CI/CD pipeline where MDE transformation scripts are unit‑tested, and the resulting artifacts undergo integration tests against a simulated building environment before deployment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Underlying network connectivity relies on the framework’s modular connectors which support industry‑standard IoT protocols as defined by the underlying open‑source DT platforms Eclipse Ditto and BaSyx. The architecture enables real‑time, low‑latency data exchange between physical sensors and the Digital Twin, with secure communication via TLS/SSL. Network topology is client‑server‑style with optional edge gateways for local aggregation; redundancy mechanisms include multiple connector instances to preserve reliability. Specific bandwidth, latency and topology details remain unspecified in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "In the described architecture, horizontal integration is addressed through interoperability across heterogeneous systems. The framework utilizes standardized extension points and bidirectional data exchange mechanisms to interface with external BIM tools, monitoring and control systems, and enterprise applications. While explicit protocols are not specified in the documents, the design supports integration patterns that enable the Digital Twin to connect with other Digital Twins and enterprise systems, thereby facilitating data sharing and coordinated decision‑making."
]