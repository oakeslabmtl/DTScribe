// Acting component
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator representing an LED fixture, exposing power state, brightness (0-100 %) and colour temperature (2500-6500 K)."
]

// Sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring ambient temperature in the building."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor measuring relative humidity within the building."
    DTDFVocab:producedData HumidityDataTransmitted
]
instance PowerConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Power consumption sensor capturing electrical usage of building equipment."
    DTDFVocab:producedData PowerConsumptionDataTransmitted
]
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor detecting presence in occupied spaces."
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance EquipmentStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Equipment status sensor reporting operational state of critical building systems."
    DTDFVocab:producedData EquipmentStatusDataTransmitted
]

// Data transmitted (raw payloads) from sensors
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]
instance PowerConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerConsumptionSensor
]
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance EquipmentStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EquipmentStatusSensor
]

// Structured data schemas
instance TemperatureData : DTDFVocab:Data [
    base:desc "Schema for ambient temperature data, validated by Eclipse Ditto."
    DTDFVocab:inputTo EclipseHono
]
instance HumidityData : DTDFVocab:Data [
    base:desc "Schema for relative humidity data, validated by Eclipse Ditto."
    DTDFVocab:inputTo EclipseHono
]
instance PowerConsumptionData : DTDFVocab:Data [
    base:desc "Schema for power consumption data, validated by Eclipse Ditto."
    DTDFVocab:inputTo EclipseHono
]
instance OccupancyData : DTDFVocab:Data [
    base:desc "Schema for occupancy data, validated by Eclipse Ditto."
    DTDFVocab:inputTo EclipseHono
]
instance EquipmentStatusData : DTDFVocab:Data [
    base:desc "Schema for equipment status data, validated by Eclipse Ditto."
    DTDFVocab:inputTo EclipseHono
]

// Enablers (middleware components)
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "MQTT style secure transport broker for real‑time sensor data ingestion."
    DTDFVocab:enables DataIngestionService
]
instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Policy‑based validation engine enforcing value ranges, compatibility checks, and persistence of twin state."
    DTDFVocab:enables LightControlService, VisualizationService
]

// Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service that ingests validated sensor data from Eclipse Hono into the twin state."
    DTDFVocab:provides RealTimeMonitoringInsight
]
instance LightControlService : DTDFVocab:Service [
    base:desc "Service that routes lighting actuator commands through Eclipse Ditto/Hono to physical devices."
    DTDFVocab:provides LightStateAction, LightBrightnessAction, LightColorTemperatureAction
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that presents real‑time building state in a 3D Unreal Engine 5 dashboard."
    DTDFVocab:provides RealTimeMonitoringInsight
]

// Insights
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight providing continuous monitoring of building operational parameters."
]

// Actions
instance LightStateAction : DTDFVocab:Action [
    base:desc "Toggle lighting power state (on/off) via Eclipse Ditto/Hono MQTT transport."
    DTDFVocab:IsAutomatic false
]
instance LightBrightnessAction : DTDFVocab:Action [
    base:desc "Set lighting brightness (0–100 %) via Eclipse Ditto/Hono MQTT transport."
    DTDFVocab:IsAutomatic false
]
instance LightColorTemperatureAction : DTDFVocab:Action [
    base:desc "Set lighting colour temperature (2500–6500 K) via Eclipse Ditto/Hono MQTT transport."
    DTDFVocab:IsAutomatic false
]

// Environment (building asset)
instance BuildingAsset : DTDFVocab:Environment [
    base:contains LightTwinComponent, TemperatureSensor, HumiditySensor, PowerConsumptionSensor, OccupancySensor, EquipmentStatusSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin (e.g., HVAC setpoints, lighting levels, actuator activations) are emitted as JSON payloads via Ditto’s command interface. These messages are routed through Eclipse Hono to the device gateways, which translate them into the device‑specific protocol used by the Building Control System (e.g., BACnet, Modbus, or OPC UA). Command messages are validated against a schema, authenticated through Ditto’s security module (using OAuth 2.0 or JWT tokens signed by the tenant’s authority), and authorised according to the user role (Facility Manager or DT Engineer). Feedback is collected by the physical devices and sent back through the same channel as telemetry updates, which overwrite the twin’s “status” or “execution_state” properties to confirm command execution or report failures. In cases of conflicting commands, a central conflict‑resolution service applies predefined priority rules (e.g., manual override has precedence) and logs the resolution. Execution confirmations are explicitly acknowledged by the gateway sending an ACK message that updates the twin’s state."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange capabilities ensure continuous synchronization between the physical building and its digital twin, but the documents do not specify exact synchronization frequencies, latency requirements or temporal granularity. The architecture is designed to support real‑time updates and continuous convergence between the physical and virtual domains."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a model‑driven engineering architecture pattern: enriched BIM models are transformed into structured representations, from which deployable DT artifacts are automatically generated. The modular architecture comprises a central hub, component‑level device twins, custom service plug‑ins, and analytics modules. Resource management is handled through runtime configuration management, enabling dynamic scaling and low‑overhead updates, while system‑wide coordination relies on bidirectional data exchange and standardized integration points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows a model‑driven sequence beginning with **Design** where Building Control Engineers enrich BIM models with device, sensor, and controller definitions. It continues to **Model‑to‑Artifact Transformation** employing Model‑Driven Engineering (MDE) principles to extract structured representations and generate deployable DT artifacts. The next phase, **Automated Deployment**, is governed by requirement C2 and reduces manual configuration, enabling reproducible DT setups. During **Runtime Operation**, real‑time data integration via Eclipse Hono and Ditto (C3) ensures continuous synchronization and interactive visualization, supporting Facility Managers in monitoring and control. Finally, **Evolution & Extensibility** are facilitated by a modular, service‑oriented architecture with standardized extension points (C4), allowing DT Engineers to inject custom services and plugins while maintaining version consistency through BIM model revisions and DT artifact repositories."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The framework implements rigorous fidelity and validity checks at multiple layers. Device and state data are validated by Ditto’s policy engine, which enforces unit consistency and permissible value ranges; any violation triggers an exception and blocks the affected command. Eclipse Hono guarantees at‑least‑once delivery, while Ditto’s persistent event store ensures availability of state history for rollback and auditing. Model integrity is verified during the Model Checking phase, where structural constraints of BIM and TwinComponents are evaluated before deployment. Operational performance is quantified using the Overall Digital Twin Entanglement (ODTE) metric, whose components—timeliness (0.997), reliability (1.0), and availability (1.0)—are measured over a 12‑minute window with a 1‑second heartbeat. The resulting ODTE score (0.997) confirms that the twin remains tightly coupled to its physical counterpart, with negligible lag and no message loss. In case of synchronous failures, the system’s fault‑tolerant design—using event replay and state restoration—maintains continuity and preserves model validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin framework relies on Eclipse Hono for robust, scalable messaging between physical devices and the twin platform. Hono exposes MQTT for device clients and HTTP/AMQP for broker services, enabling secure, asynchronous communication. Messages are routed by tenant ID to dedicated instances of Eclipse Ditto, which maintains twin state via REST and AMQP APIs. The network topology is a hybrid star: devices connect to local gateways that forward data through Hono to a clustered broker, ensuring persistence, QoS 1/2, and fail‑over. Bandwidth requirements remain modest per sensor (<10 kB/s) but aggregate metrics scale with asset count. Latency targets are sub‑200 ms to satisfy real‑time control loops. Reliability is achieved through Hono’s persistent sessions, broker clustering, and Ditto’s state replication to persistent storage (e.g., PostgreSQL). Redundancy is provided by deploying dual Hono brokers and local edge gateways to act independently in case of broker outage. All communication layers enforce TLS 1.2+ encryption; devices authenticate with X.509 certificates or JWTs, and server‑to‑server interactions use OAuth 2.0 for secure credential exchange."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability across heterogeneous systems is addressed through non‑functional requirements NF_X, providing integration with external enterprise systems, BIM tools, sensor networks, and facility management platforms. The framework exposes standardized extension points and modular components that facilitate data exchange with other digital twins and enterprise systems, leveraging common integration patterns and open data protocols (details not specified in the documents)."
]