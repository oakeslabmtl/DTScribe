// C3: Physical sensing components
instance BuildingOperationalSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor defined in the enriched BIM model by the Building Control Engineer, continuously streaming measured values from the physical building."
    DTDFVocab:producedData OperationalSensorStream
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance OperationalSensorStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingOperationalSensor
]

// C5: Data produced from sensor stream
instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Real‑time operational measurements streamed from BuildingOperationalSensor."
    DTDFVocab:fromData OperationalSensorStream
    DTDFVocab:inputTo RealTimeSyncEngine
]

// C11: Enablers
instance RealTimeSyncEngine : DTDFVocab:Enabler [
    base:desc "Engine that ingests real‑time sensor streams, synchronizes physical state to the digital twin, and feeds data to downstream services."
    DTDFVocab:enables SimulationAnalysisOptimizationService
]

// C6: Services
instance SimulationAnalysisOptimizationService : DTDFVocab:Service [
    base:desc "Provides simulation, analysis, and optimization services delivering real‑time insights, predictive analytics, and decision‑support throughout the asset lifecycle."
    DTDFVocab:provides RealTimeDashboardInsight, Immersive3DVisualizationInsight, IssueControlCommandAction
]

// C17: Insights
instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Dashboard insight presenting real‑time sensor readings and system states for facility managers."
]

instance Immersive3DVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visual context insight reflecting current sensor readings and actuator statuses for interactive decision making."
]

// C17: Actions
instance IssueControlCommandAction : DTDFVocab:Action [
    base:desc "Action that issues remote control commands to actuators from the twin interface."
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance BuildingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator modelled in BIM as an executable control point, remotely invocable by the Facility Manager through the twin."
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing geometric information and semantic definitions of sensors, actuators, and controllers, extracted via Model‑Driven Engineering."
    DTDFVocab:inputTo RealTimeSyncEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated in the digital twin are sent back to building actuators through the framework’s bidirectional communication channels. Runtime configuration management validates and applies these commands without requiring full redeployment, and the digital twin receives feedback confirming execution of the physical actions."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports a full DT lifecycle that begins with device modeling inside BIM (defining sensors, actuators, and controllers), proceeds to model‑driven engineering where structured representations are extracted via Model‑Driven Engineering (MDE), then automatic generation of deployable DT artifacts, followed by deployment and runtime operation with real‑time data exchange and interactive visualization, and finally evolution through modular extensions via standardized extension points. Lifecycle governance is implied by the model‑driven approach that maintains a single source of truth from BIM through to the running twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin system is built on a modular, service‑oriented architecture with standardized extension points that expose network interfaces for component interaction. This design supports interoperability across heterogeneous subsystems and scalability from single devices to whole infrastructure, while runtime configuration management allows dynamic adjustment of connections to maintain reliability."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework builds on Building Information Modeling (BIM), an established industry standard for representing building geometry and assets, and extends it by standardising BIM semantics for control system components (sensors, actuators, controllers). It introduces standardized extension points within its modular architecture to enable interoperable integration of custom services, analytics, and external tools. While no external certification schemes or specific interoperability standards (e.g., IFC, ISO 19650) are cited, the approach aligns with industry practice by using BIM as the canonical data source and providing a uniform, standards‑based integration layer for Digital Twin extensions."
]