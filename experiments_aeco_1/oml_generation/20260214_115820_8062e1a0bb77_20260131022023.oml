// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Dimmable lighting actuator (luminaire) modeled in BIM, receives control commands from the twin."
]

instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Building control system controller managing lighting actuators, represented in BIM for command execution."
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the building, streams occupancy counts post‑occupancy via Eclipse Hono."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor measuring light levels, streams real‑time illuminance data via Eclipse Hono."
    DTDFVocab:producedData IlluminanceDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]

// C5: Data
instance OccupancyData : DTDFVocab:Data [
    base:desc "Stream of occupancy counts used for occupancy‑aware analytics."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoConnector
]

instance IlluminanceData : DTDFVocab:Data [
    base:desc "Stream of illuminance measurements used for lighting control and visualization."
    DTDFVocab:fromData IlluminanceDataTransmitted
    DTDFVocab:inputTo EclipseHonoConnector
]

// C11: Enablers
instance EclipseHonoConnector : DTDFVocab:Enabler [
    base:desc "Eclipse Hono service providing MQTT/HTTPS connectivity for streaming sensor data into the twin."
    DTDFVocab:enables RealTimeMonitoringDashboard, AdaptiveLightingControlService
]

instance EclipseDittoStateManager : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto managing digital twin state, applying control logic and persisting actuator states."
    DTDFVocab:enables AdaptiveLightingControlService, EnergyOptimizationService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 engine rendering interactive 3‑D visualizations of the twin."
    DTDFVocab:enables Interactive3DVisualization
]

instance PredictiveAnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Engine executing predictive analytics models for energy usage forecasting."
    DTDFVocab:enables PredictiveAnalyticsService
]

instance EnergyOptimizationEngine : DTDFVocab:Enabler [
    base:desc "Engine applying optimization algorithms to generate energy‑saving recommendations."
    DTDFVocab:enables EnergyOptimizationService
]

instance ReinforcementLearningEngine : DTDFVocab:Enabler [
    base:desc "Reinforcement‑learning service updating lighting policies based on occupancy and illuminance feedback."
    DTDFVocab:enables AdaptiveLightingControlService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation service executing design‑time and operational scenario models."
    DTDFVocab:enables SimulationService
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Web‑based dashboard displaying live occupancy and illuminance streams."
    DTDFVocab:provides MonitoringInsight
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "Immersive 3‑D view of the building twin in Unreal Engine 5."
    DTDFVocab:provides VisualizationFeedback
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Provides forecasts of future energy consumption based on sensor data."
    DTDFVocab:provides EnergyUsageForecastInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Generates recommendations to reduce energy use and optimize HVAC/lighting schedules."
    DTDFVocab:provides EnergyOptimizationRecommendation
]

instance AdaptiveLightingControlService : DTDFVocab:Service [
    base:desc "Uses RL policy to adapt lighting levels in real time."
    DTDFVocab:provides AdaptiveLightingStrategy, AdjustLightingCommand
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs simulation scenarios for design‑time decision support and operational planning."
    DTDFVocab:provides DesignDecisionSupportInsight
]

// C10: Models
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "BIM model enriched with device metadata, sensor definitions, and actuator specifications."
]

instance RuntimeControlLogicModel : DTDFVocab:Model [
    base:desc "Executable control logic model governing actuator command generation."
    DTDFVocab:inputTo EclipseDittoStateManager
]

instance PredictiveAnalyticsModel : DTDFVocab:Model [
    base:desc "Statistical model predicting energy usage from occupancy and illuminance data."
    DTDFVocab:inputTo PredictiveAnalyticsEngine
]

instance EnergyOptimizationModel : DTDFVocab:Model [
    base:desc "Optimization model calculating energy‑saving setpoints for lighting and HVAC."
    DTDFVocab:inputTo EnergyOptimizationEngine
]

instance ReinforcementLearningPolicyModel : DTDFVocab:Model [
    base:desc "RL policy model (BOREALIS scenario) that learns adaptive lighting actions from sensor feedback."
    DTDFVocab:inputTo ReinforcementLearningEngine
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulation model used for design‑time and operational scenario analysis."
    DTDFVocab:inputTo SimulationEngine
]

// C17: Insights/Actions
instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Live insight into building occupancy and illumination levels for facility managers."
]

instance VisualizationFeedback : DTDFVocab:Insight [
    base:desc "Visual feedback in the 3‑D immersive view reflecting current sensor states."
]

instance EnergyUsageForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of energy consumption over the next planning horizon."
]

instance EnergyOptimizationRecommendation : DTDFVocab:Insight [
    base:desc "Recommendation to adjust lighting schedules for reduced energy use."
]

instance AdaptiveLightingStrategy : DTDFVocab:Insight [
    base:desc "Strategy recommending optimal dimming setpoints based on real‑time occupancy."
]

instance AdjustLightingCommand : DTDFVocab:Action [
    base:desc "Automatic command sent to LightingActuator to change luminance level."
    DTDFVocab:IsAutomatic true
]

instance DesignDecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Insight from simulation supporting design‑time decisions and operational planning."
]

// C12: Environment
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, IlluminanceSensor, LightingActuator, LightingController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command flow from the twin to the physical actuators using Eclipse Ditto to translate control commands (e.g., lighting set‑points, HVAC commands) into device‑level messages that drive the building control hardware."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates in real time; sensor updates and control actions are propagated within seconds as soon as messages are received by Hono/Ditto, enabling continuous synchronization."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A service‑oriented architecture composed of a BIM‑based semantic core, a middleware layer (Hono/Ditto) handling bidirectional data flow, and a visualization/interaction layer (Unreal Engine), all orchestrated through the model‑driven framework."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the full building lifecycle – it is instantiated from the design BIM, remains applicable during construction and commissioning, and continues to operate during the post‑occupancy phase, supporting refurbishment and adaptation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is employed to quantify how closely the twin mirrors its physical counterpart, addressing semantic drift and ensuring model‑physical alignment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time connectivity is realized through Eclipse Hono (supporting MQTT/HTTP/CoAP) and Eclipse Ditto, which together provide the protocol stack and state management for PT↔DT communication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Generated DT artifacts are automatically deployed onto the service‑oriented DT platform defined by the framework; the specific hosting environment (cloud vs. on‑premise) is not detailed in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized extension points enable integration of external services and systems, promoting interoperability beyond the core DT platform."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on BIM standards for semantic consistency, uses open‑source standards implemented by Eclipse Hono and Ditto, and defines standardized extension points to ensure interoperable service integration."
]