// C2: Acting Components
instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture actuator modeled in BIM, controlled via Eclipse Ditto device twin and translated into Hono commands"
]
instance HvacDamperActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC damper actuator modeled in BIM, receives control commands through Ditto/Hono"
]
instance MotorisedBlindActuator : DTDFVocab:ActingComponent [
    base:desc "Motorised blind actuator modeled in BIM, actuated via Ditto/Hono command stream"
]
instance MotorisedFanActuator : DTDFVocab:ActingComponent [
    base:desc "Motorised fan actuator modeled in BIM, controlled through Ditto/Hono and ET"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor node attached to the building, modeled as a BIM component"
    DTDFVocab:producedData MqttTemperatureTelemetry
]
instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor node attached to the building, modeled as a BIM component"
    DTDFVocab:producedData MqttHumidityTelemetry
]
instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor node attached to the building, modeled as a BIM component"
    DTDFVocab:producedData MqttCO2Telemetry
]
instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Light level sensor node attached to the building, modeled as a BIM component"
    DTDFVocab:producedData MqttLightLevelTelemetry
]
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor node attached to the building, modeled as a BIM component"
    DTDFVocab:producedData MqttOccupancyTelemetry
]
instance PowerMeterSensor : DTDFVocab:SensingComponent [
    base:desc "Power meter sensor node attached to the building, modeled as a BIM component"
    DTDFVocab:producedData MqttPowerMeterTelemetry
]

// C4: Physical-to-virtual interaction
instance MqttTemperatureTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance MqttHumidityTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]
instance MqttCO2Telemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]
instance MqttLightLevelTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]
instance MqttOccupancyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance MqttPowerMeterTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerMeterSensor
]

// C10: Models/Data
instance IfcBimModel : DTDFVocab:Model [
    base:desc "IFC-based BIM model exported to proprietary database as part of twinning process"
    DTDFVocab:inputTo CustomBimToDtMetamodelTool
]
instance ControlLogicUMLModel : DTDFVocab:Model [
    base:desc "Control logic expressed in UML, transformed by EMF into executable descriptors"
    DTDFVocab:inputTo EMFModelTransformationTool
]
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature time‑series telemetry produced by the building temperature sensor"
    DTDFVocab:fromData MqttTemperatureTelemetry
    DTDFVocab:inputTo EclipseHonoBroker
]
instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity time‑series telemetry produced by the building humidity sensor"
    DTDFVocab:fromData MqttHumidityTelemetry
    DTDFVocab:inputTo EclipseHonoBroker
]
instance CO2Data : DTDFVocab:Data [
    base:desc "CO₂ time‑series telemetry produced by the building CO₂ sensor"
    DTDFVocab:fromData MqttCO2Telemetry
    DTDFVocab:inputTo EclipseHonoBroker
]
instance LightLevelData : DTDFVocab:Data [
    base:desc "Light level time‑series telemetry produced by the building light level sensor"
    DTDFVocab:fromData MqttLightLevelTelemetry
    DTDFVocab:inputTo EclipseHonoBroker
]
instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy event stream produced by the building occupancy sensor"
    DTDFVocab:fromData MqttOccupancyTelemetry
    DTDFVocab:inputTo EclipseHonoBroker
]
instance PowerMeterData : DTDFVocab:Data [
    base:desc "Power consumption time‑series telemetry produced by the building power meter"
    DTDFVocab:fromData MqttPowerMeterTelemetry
    DTDFVocab:inputTo EclipseHonoBroker
]
instance ControlCommandHistoryData : DTDFVocab:Data [
    base:desc "Historical log of control commands issued to actuators, stored in Ditto"
    DTDFVocab:inputTo EclipseDittoService
]
instance MaintenanceLogData : DTDFVocab:Data [
    base:desc "Maintenance event log generated by facility managers, stored in Ditto"
    DTDFVocab:inputTo EclipseDittoService
]
instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Output produced by simulation modules, forwarded to visualization"
    DTDFVocab:inputTo UnrealEngine5Visualization
]

// C11: Enablers
instance EclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Hono: cloud‑native MQTT broker carrying raw telemetry and command messages"
]
instance EclipseDittoService : DTDFVocab:Enabler [
    base:desc "Ditto: device twin service that stores statistics, command history and decision logs"
]
instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5: immersive 3D visualization platform for simulation outputs"
]
instance EMFModelTransformationTool : DTDFVocab:Enabler [
    base:desc "Eclipse Modeling Framework for model transformation"
]
instance CustomBimToDtMetamodelTool : DTDFVocab:Enabler [
    base:desc "Custom BIM‑to‑DT metamodel: validates IFC against metamodel and generates deployment descriptors"
]

// C6: Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards expose KPIs such as energy consumption and occupant comfort"
    DTDFVocab:provides EnergyConsumptionInsight, OccupantComfortInsight
]
instance SimulationModuleService : DTDFVocab:Service [
    base:desc "Simulation module executes building behaviour models and generates output for analytics"
    DTDFVocab:provides SimulationOutputData
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics module forecasts occupancy and predicts fault warnings"
    DTDFVocab:provides PredictiveFaultWarningInsight
]
instance UnrealEngine5VisualizationService : DTDFVocab:Service [
    base:desc "Unreal Engine 5 visualization service binds simulation outputs to interactive 3D representation"
    DTDFVocab:provides SimulationOutputData
]
instance ApiService : DTDFVocab:Service [
    base:desc "REST/GraphQL API enabling command issuance and data retrieval from the digital twin"
    DTDFVocab:provides AdjustSetpointAction, ScheduleMaintenanceAction, LogDecisionAction
]
instance CentralOrchestratorService : DTDFVocab:Service [
    base:desc "Central DT orchestrator service manages sub‑twins for HVAC, lighting, and electrical systems via Ditto broker"
]

// C12: Environments & Components
instance BuildingSystemsEnvironment : DTDFVocab:Environment [
    base:desc "Central environment containing sub‑twins for HVAC, lighting, and electrical systems"
    base:contains HvacSubsystem, LightingSubsystem, ElectricalSubsystem
]
instance HvacSubsystem : DTDFVocab:Component [
    base:desc "HVAC system subsystem twin managed by the central orchestrator"
]
instance LightingSubsystem : DTDFVocab:Component [
    base:desc "Lighting system subsystem twin managed by the central orchestrator"
]
instance ElectricalSubsystem : DTDFVocab:Component [
    base:desc "Electrical system subsystem twin managed by the central orchestrator"
]
instance LivingLabBuilding : DTDFVocab:Environment [
    base:desc "Living Lab building – academic facility serving as AECO digital twin test bed"
    base:contains BuildingEnvelope, HvacSystem, LightingSystem, OccupancyInfrastructure
]
instance BuildingEnvelope : DTDFVocab:Component [
    base:desc "Building envelope component: walls, roof, and fenestration"
]
instance HvacSystem : DTDFVocab:Component [
    base:desc "HVAC system component modeled in BIM and exposed via Actuating components"
]
instance LightingSystem : DTDFVocab:Component [
    base:desc "Lighting system component modeled in BIM, includes actuators and sensors"
]
instance OccupancyInfrastructure : DTDFVocab:Component [
    base:desc "Occupancy infrastructure component comprising occupancy sensors and data integration"
]

// C17: Insights and Actions
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight displaying real‑time and historical energy consumption"
]
instance OccupantComfortInsight : DTDFVocab:Insight [
    base:desc "Insight revealing occupant comfort levels derived from temperature, humidity, and lighting data"
]
instance PredictiveFaultWarningInsight : DTDFVocab:Insight [
    base:desc "Predictive warning generated by analytics indicating potential maintenance issues"
]
instance AdjustSetpointAction : DTDFVocab:Action [
    base:desc "Adjusts HVAC or lighting setpoints based on analytics recommendations"
    DTDFVocab:IsAutomatic false
]
instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Schedules maintenance tasks for facility managers"
    DTDFVocab:IsAutomatic false
]
instance LogDecisionAction : DTDFVocab:Action [
    base:desc "Logs commands and decisions into audit trail stored in Ditto"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated in the DT (e.g., set light level, adjust HVAC setpoints) are published over MQTT via Hono to the corresponding Ditto device twin, then forwarded to the physical actuator endpoints on the building’s control bus."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data propagation within 100‑ms latency, with measurement intervals ranging from every second to every minute depending on device type. Simulations run at higher frequency (up to 10 Hz) for control loops."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated platform comprising the BIM‑based asset model, the Hono message broker, the Ditto twin registry, and the Unreal Engine front‑end. Service components such as the optimization engine and reinforcement‑learning policy server are plugged in via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Designed (BIM model generation), manufactured (equipment lists and installation metadata), and operated (live operation of the building). The twin supports all stages through lifecycle‑aware annotations in the BIM and runtime configuration files."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin’s fidelity is validated using the Overall Digital Twin Entanglement (ODTE) metric, comparing live telemetry against the BIM model. Verification is performed through unit tests on the transformation code, while integration tests ensure correct message routing. Uncertainty is mitigated via calibration routines and sensor fusion."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "IoT devices communicate via MQTT over TLS 1.2, mediated by Eclipse Hono partitions. Ditto exposes WebSocket, HTTP, and MQTT endpoints for reliable duplex communication. The physical side uses Modbus/TCP or BACnet/IP to interface with building systems."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT stack is deployed in a cloud‑native environment (e.g., Kubernetes on AWS/GCP) with edge gateways for latency‑critical devices. Ditto services run as stateful pods; Hono runs as a message broker cluster; Unreal Engine serves as a web‑based client via WebGL."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The twin can connect to external systems such as enterprise asset management (EAM), energy management systems (EMS), and research platforms (BOREALIS, TwinLight) via REST/GraphQL and MQTT bridges, enabling cross‑domain dataflow."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adopts IFC for building model data, ETL standards for sensor metadata, MQTT/CoAP for messaging, and IEC 61334‑7‑1 for device‑twin representation. Framework complies with ETSI M2M positioning and follows the ODTE measurement standard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Communication is secured with TLS and OAuth2 authentication; Ditto enforces tenant‑based access control. The twin’s control logic is sandboxed to prevent unsafe commands, and risk assessment is performed before deploying new control policies."
]