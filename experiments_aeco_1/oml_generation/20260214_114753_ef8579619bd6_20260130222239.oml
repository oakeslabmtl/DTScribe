// C2: Acting Components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator receiving commands from the twin to adjust illumination levels"
]

instance HVACControlValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC control valve actuator for regulating airflow based on twin decisions"
]

instance EmbeddedController : DTDFVocab:ActingComponent [
    base:desc "Embedded controller that interfaces building control system actuators with twin commands"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental temperature sensor measuring indoor air temperature in the Living Lab building"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance LuminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Luminance sensor measuring ambient light levels for occupancy comfort"
    DTDFVocab:producedData LuminanceDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor capturing indoor carbon‑dioxide concentration for air‑quality monitoring"
    DTDFVocab:producedData CO2DataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy (presence) sensor detecting space usage and occupant count"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor reporting current illumination intensity in zones"
    DTDFVocab:producedData LightingDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance LuminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LuminanceSensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

// C5: Data (processed streams)
instance TemperatureData : DTDFVocab:Data [
    base:desc "Stream of temperature readings in °C from building environment sensors"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance LuminanceData : DTDFVocab:Data [
    base:desc "Stream of luminance measurements in lux from ambient light sensors"
    DTDFVocab:fromData LuminanceDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Stream of CO₂ concentration values in ppm from air‑quality sensors"
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Binary/ count data indicating presence of occupants in each monitored zone"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance LightingData : DTDFVocab:Data [
    base:desc "Current illumination intensity reported by zone lighting sensors"
    DTDFVocab:fromData LightingDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides MQTT/HTTP connectivity for building sensors to transmit telemetry"
    DTDFVocab:enables RealTimeMonitoringDashboard, BuildingPerformanceSimulation
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital twin state ingestion and synchronization"
    DTDFVocab:enables EnergyOptimizationRLLightingControl, PredictiveAnalyticsFacilityManagement
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders immersive 3D visualization of the BIM model and live sensor data"
    DTDFVocab:enables UnrealEngine5Visualization
]

instance ModelDrivenEngineeringTool : DTDFVocab:Enabler [
    base:desc "MDE tools automate model‑to‑text transformations for deployment artifacts and standardized extension points"
    DTDFVocab:enables TwinningConfiguratorService
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Dashboard displaying real‑time sensor streams and key performance indicators"
    DTDFVocab:provides EnergySavingLightingScheduleRecommendation, PredictiveAlertForAnomalies
]

instance BuildingPerformanceSimulation : DTDFVocab:Service [
    base:desc "Simulation of building performance using sensor data and BIM semantics"
    DTDFVocab:provides FacilityManagerDecisionSupport
]

instance EnergyOptimizationRLLightingControl : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based lighting control optimizing energy consumption"
    DTDFVocab:provides ReinforcementLearningControlPolicy, SuggestLightingAdjustment
]

instance PredictiveAnalyticsFacilityManagement : DTDFVocab:Service [
    base:desc "Predictive analytics generating alerts and maintenance recommendations for facility management"
    DTDFVocab:provides PredictiveAlertForAnomalies
]

instance UnrealEngine5Visualization : DTDFVocab:Service [
    base:desc "Immersive 3D visualization of the building and live telemetry in Unreal Engine 5"
    DTDFVocab:provides FacilityManagerDecisionSupport
]

instance TwinningConfiguratorService : DTDFVocab:Service [
    base:desc "Hono/Ditto configurator auto‑generates deployment artifacts and supports standardized extension points"
    DTDFVocab:provides ExtensionCapabilityInsight
]

// C17: Insights
instance EnergySavingLightingScheduleRecommendation : DTDFVocab:Insight [
    base:desc "Optimization recommendation for energy‑saving lighting schedules"
]

instance PredictiveAlertForAnomalies : DTDFVocab:Insight [
    base:desc "Predictive alert indicating potential anomalies in environmental conditions"
]

instance ReinforcementLearningControlPolicy : DTDFVocab:Insight [
    base:desc "Control policy derived from reinforcement learning for intelligent lighting control"
]

instance FacilityManagerDecisionSupport : DTDFVocab:Insight [
    base:desc "Decision‑support insight for facility managers without direct actuation of building systems"
]

instance ExtensionCapabilityInsight : DTDFVocab:Insight [
    base:desc "Insight describing available standardized extension points for adding new services to the twin"
]

// C17: Actions
instance SuggestLightingAdjustment : DTDFVocab:Action [
    base:desc "Suggested lighting adjustment to be approved by the facility manager"
    DTDFVocab:IsAutomatic false
]

// C10: Models/Data
instance BIMIfcModel : DTDFVocab:Model [
    base:desc "Static BIM model (IFC‑based) providing geometric and semantic building data"
    DTDFVocab:inputTo ModelDrivenEngineeringTool
]

instance RuntimeTwinModel : DTDFVocab:Model [
    base:desc "Runtime twin model capturing sensor streams and control logic"
    DTDFVocab:inputTo EclipseDitto
]

instance ODTEMetricModel : DTDFVocab:Model [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric quantifying model‑physical alignment"
    DTDFVocab:inputTo ModelDrivenEngineeringTool
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points, HVAC set‑points) are dispatched back to actuators through the Hono/Ditto middleware, enabling live actuation of the physical building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Live, real‑time synchronization (sub‑second to second granularity) between physical sensors/actuators and the Digital Twin via the Hono/Ditto data pipeline."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where enriched BIM models feed a configurator that generates Hono/Ditto runtime artifacts; middleware mediates bidirectional data flow; services and visualisation are plugged in via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the entire building lifecycle: design (BIM model creation), construction (device configuration), operation (runtime monitoring and control), and refurbishment/adaptation phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to evaluate how accurately the twin reflects its physical counterpart, providing a quantitative fidelity assessment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time communication is realized through Eclipse Hono (supporting MQTT/HTTPS protocols) coupled with Eclipse Ditto (HTTP/WebSocket API) for twin state management and command dissemination."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution is built on BIM standards (ISO 19650/IFC) and utilizes open integration protocols provided by Eclipse Hono and Ditto, aligning with industry‑wide interoperability standards."
]