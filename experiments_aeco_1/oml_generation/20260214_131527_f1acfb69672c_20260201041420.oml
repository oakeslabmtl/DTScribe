// Sensing Components
instance PhotometricSensor : DTDFVocab:SensingComponent [
    base:desc "Photometric sensor on lighting fixtures providing lux and CRI measurements."
    DTDFVocab:producedData LightingLuxTelemetry
]

instance OccupancyProbe : DTDFVocab:SensingComponent [
    base:desc "Occupancy probe installed in occupancy beds returning occupancy count."
    DTDFVocab:producedData OccupancyTelemetry
]

instance TemperatureSensorHVAC : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in HVAC unit providing readings in °C."
    DTDFVocab:producedData TemperatureTelemetry
]

// Data Transmitted
instance LightingLuxTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhotometricSensor
]

instance OccupancyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyProbe
]

instance TemperatureTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorHVAC
]

// Data
instance LightingLuxData : DTDFVocab:Data [
    base:desc "Lux value stream from photometric sensor."
    DTDFVocab:inputTo DittoHonoEnabler
    DTDFVocab:fromData LightingLuxTelemetry
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy count data from occupancy probe."
    DTDFVocab:inputTo DittoHonoEnabler
    DTDFVocab:fromData OccupancyTelemetry
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature reading in °C from HVAC unit."
    DTDFVocab:inputTo DittoHonoEnabler
    DTDFVocab:fromData TemperatureTelemetry
]

// Enabler
instance DittoHonoEnabler : DTDFVocab:Enabler [
    base:desc "Policy-enforced Ditto and Hono middleware validating telemetry and propagating commands."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveMaintenanceService, ControlService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of building states and asset performance using Ditto stored telemetry."
    DTDFVocab:provides InsightRealTimeStatus
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance analytics service leveraging synchronized data."
    DTDFVocab:provides InsightPredictiveMaintenance
]

instance ControlService : DTDFVocab:Service [
    base:desc "Control service enabling facility managers to issue commands to HVAC, lighting and other building systems through the twin."
    DTDFVocab:provides ActionHVACActuate, ActionLightingActuate
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization service rendering the twin in interactive dashboards and 3D models."
    DTDFVocab:provides InsightVisualizationInteractive
]

// Insights
instance InsightRealTimeStatus : DTDFVocab:Insight [
    base:desc "Current status of building components, derived from sensor telemetry."
]

instance InsightPredictiveMaintenance : DTDFVocab:Insight [
    base:desc "Recommendation for maintenance actions based on predictive models, including confidence score."
]

instance InsightCostImpactEstimate : DTDFVocab:Insight [
    base:desc "Estimator output indicating potential cost savings from proposed changes."
]

instance InsightVisualizationInteractive : DTDFVocab:Insight [
    base:desc "Interactive dashboard and 3D simulation allowing user to drill into scenarios."
]

// Actions
instance ActionHVACActuate : DTDFVocab:Action [
    base:desc "Command to HVAC system to adjust temperature or dampers."
    DTDFVocab:IsAutomatic false
]

instance ActionLightingActuate : DTDFVocab:Action [
    base:desc "Command to lighting units to change on/off, dimming, or color temperature."
    DTDFVocab:IsAutomatic false
]

// Acting Components
instance LEDLightingUnit : DTDFVocab:ActingComponent [
    base:desc "LED lighting unit supporting on/off, dimming 0‑100%, and color temperature 2700‑6500 K."
]

instance HVACDamperUnit : DTDFVocab:ActingComponent [
    base:desc "HVAC damper controlling airflow for temperature and pressure regulation."
]

// Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing geometric, behavioral, and analytical data extracted from Revit annotations."
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance DeliveryPipelineModel : DTDFVocab:Model [
    base:desc "MDE-centric workflow generating deployable artifacts, validated against schemas."
    DTDFVocab:inputTo VersionControlEnabler
]

// Enablers for Model Processing
instance MDEPipelineEnabler : DTDFVocab:Enabler [
    base:desc "MDE pipeline that transforms enriched BIM into structured representations."
    DTDFVocab:enables BIMTransformationService
]

instance BIMTransformationService : DTDFVocab:Service [
    base:desc "Service that turns enhanced BIM annotations into geometric, behavioral and analytical models."
]

instance VersionControlEnabler : DTDFVocab:Enabler [
    base:desc "Version control system ensuring lineage and rollback of model artefacts."
    DTDFVocab:enables DeploymentService
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Service that deploys containerised services and APIs derived from BIM models."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time bi‑directional data exchange is employed to keep the digital twin synchronized with its physical counterpart, enabling real‑time monitoring, control, and predictive analytics. The framework supports runtime re‑configuration of synchronization frequency to adapt to changing operational requirements, though specific latency thresholds or update intervals are not defined in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a modular, service‑oriented architecture centered around a DT Framework that serves as the central hub for bi‑directional data exchange. The framework exposes standardized extension points for integrating custom analytics and services, enabling dynamic scaling from single building components to whole‑infrastructure deployments. Roles such as Building Control Engineers, Facility Managers, and DT Engineers coordinate through this framework to manage device modeling, deployment, monitoring, and continuous configuration, thereby enhancing adaptability without requiring full redeployment."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Development lifecycle of the model‑driven DT framework proceeds in four key phases:
(1) BIM‑enrichment – the Building Control Engineer models sensors, actuators, and controllers within the BIM environment, yielding a semantically rich representation;
(2) MDE extraction – Model‑Driven Engineering principles automatically transform the enriched BIM into a structured digital representation (e.g., graph‑based or JSON schema) that preserves topology, control logic, and data flow;
(3) Artifact generation and deployment – the framework synthesizes deployable DT artefacts such as micro‑services, data pipelines, and visualization dashboards, through a minimal‑manual, template‑based pipeline;
(4) Runtime operation and evolution – real‑time data exchange (e.g., MQTT or WebSocket) synchronizes the twin with the physical building, while the modular architecture and standardized extension points allow the DT Engineer to inject custom analytics or control services.
Governance across these stages is codified by the defined stakeholder roles – Building Control Engineer (modeling), Facility Manager (monitoring & control), and DT Engineer (service extension)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is achieved by enriching BIM with exact device metadata (e.g. photometric values) and by applying Model‑Driven Engineering transformations that preserve semantic relationships between geometry, control logic, and physical capabilities. Verification is performed through Eclipse Ditto’s policy‑based validation layer, which enforces value ranges, units, and schema conformance prior to accepting sensor telemetry or actuator commands. Fault tolerance is provided by Hono’s at‑least‑once message delivery semantics and Ditto’s persistent event store, ensuring that network partitions or failures do not result in data loss. Safety constraints are embedded as pre‑execution checks on actuator command payloads, preventing conflicts or unsafe operations. While explicit uncertainty quantification or sampling‑frequency coverage is not documented, the architecture’s modular extension points allow for integration of analytics that could inject statistical quality‑assurance metrics into the twin’s state."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is accomplished via a set of standardized extension points within the DT Framework, which supports bidirectional data exchange and interoperability across heterogeneous built‑environment technologies. The framework enables modular integration of custom analytics and services, allowing seamless connection to external BIM tools, facility management software, and other Digital Twins or enterprise systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The documents explicitly note the absence of a defined compliance framework; there is no mention of specific industry standards (e.g., IFC, Industry Foundation Classes for BIM, or IIoT interoperability standards).
The framework’s reliance on generic MDE transformations and real‑time data exchange protocols suggests potential alignment with open standards, but the implementation details and certification requirements are not described."
]