// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in BIM and exposed through runtime interfaces"
    base:isContainedIn BuildingTwinEnvironment
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator modeled in BIM and exposed through runtime interfaces"
    base:isContainedIn BuildingTwinEnvironment
]

instance ControlDevice : DTDFVocab:ActingComponent [
    base:desc "Generic control device modeled in BIM and exposed through runtime interfaces"
    base:isContainedIn BuildingTwinEnvironment
]

// C3: Physical sensing components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for lighting measurements modeled in BIM data streamed via Eclipse Hono"
    DTDFVocab:producedData LightingSensorDataTransmitted
    base:isContainedIn BuildingTwinEnvironment
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for environmental conditions (temperature, humidity, etc.) modeled in BIM data streamed via Eclipse Hono"
    DTDFVocab:producedData EnvironmentalSensorDataTransmitted
    base:isContainedIn BuildingTwinEnvironment
]

instance BuildingControlSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for building‑control‑system measurements modeled in BIM data streamed via Eclipse Hono"
    DTDFVocab:producedData BuildingControlSensorDataTransmitted
    base:isContainedIn BuildingTwinEnvironment
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LightingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance EnvironmentalSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance BuildingControlSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingControlSensor
]

// C10: Data
instance LightingSensorData : DTDFVocab:Data [
    base:desc "Live lighting measurement stream"
    DTDFVocab:fromData LightingSensorDataTransmitted
    DTDFVocab:inputTo EclipseDittoPlatform
]

instance EnvironmentalSensorData : DTDFVocab:Data [
    base:desc "Live environmental condition stream (temperature, humidity, CO₂, etc.)"
    DTDFVocab:fromData EnvironmentalSensorDataTransmitted
    DTDFVocab:inputTo EclipseDittoPlatform
]

instance BuildingControlSensorData : DTDFVocab:Data [
    base:desc "Live building‑control‑system measurement stream"
    DTDFVocab:fromData BuildingControlSensorDataTransmitted
    DTDFVocab:inputTo EclipseDittoPlatform
]

// C11: Enablers
instance EclipseHonoMessaging : DTDFVocab:Enabler [
    base:desc "Eclipse Hono messaging broker that receives continuous sensor streams"
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoPlatform : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital‑twin platform synchronising streamed data"
    DTDFVocab:enables RealTimeMonitoringService
    DTDFVocab:enables EnergyOptimizationService
    DTDFVocab:enables PredictiveAnalyticsService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime for 3‑D visualisation of twin state"
    DTDFVocab:enables VisualizationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine used for predictive analyses"
    DTDFVocab:enables SimulationService
]

instance StandardizedExtensionPoints : DTDFVocab:Enabler [
    base:desc "Standardised extension points enabling modular custom services"
    DTDFVocab:enables CustomServiceSupport
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring dashboards"
    DTDFVocab:provides StatusDashboardInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimises energy consumption based on live data"
    DTDFVocab:provides OptimizationRecommendationAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Generates predictive alerts from sensor trends"
    DTDFVocab:provides PredictiveAlertAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Delivers 3‑D visualisation of energy consumption trends"
    DTDFVocab:provides EnergyConsumptionTrendInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs simulation models for what‑if analyses"
    DTDFVocab:provides SimulationResultInsight
]

instance CustomServiceSupport : DTDFVocab:Service [
    base:desc "Framework for integrating domain‑specific custom services"
    DTDFVocab:provides CustomAction
]

// C17: Insights
instance StatusDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time status dashboard presented to facility managers"
]

instance EnergyConsumptionTrendInsight : DTDFVocab:Insight [
    base:desc "Trend visualisation of building energy consumption"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Results from simulation models used for analysis"
]

// C17: Actions
instance OptimizationRecommendationAction : DTDFVocab:Action [
    base:desc "Recommended actions to reduce energy usage"
    DTDFVocab:IsAutomatic false
]

instance PredictiveAlertAction : DTDFVocab:Action [
    base:desc "Predictive alert signalling potential future fault or inefficiency"
    DTDFVocab:IsAutomatic true
]

instance CustomAction : DTDFVocab:Action [
    base:desc "User‑defined custom action enabled via extension points"
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance BIMInformationModel : DTDFVocab:Model [
    base:desc "Core BIM information model enriched with device definitions and control logic"
    DTDFVocab:inputTo EclipseDittoPlatform
]

instance RuntimeSemanticsModel : DTDFVocab:Model [
    base:desc "Runtime semantics model describing device behaviours"
    DTDFVocab:inputTo EclipseDittoPlatform
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulation model used for predictive analytics and what‑if scenarios"
    DTDFVocab:inputTo SimulationEngine
]

// C17: Environment (overall twin)
instance BuildingTwinEnvironment : DTDFVocab:Environment [
    base:contains LightingSensor, EnvironmentalSensor, BuildingControlSensor,
                 LightingActuator, HVACActuator, ControlDevice,
                 BIMInformationModel, RuntimeSemanticsModel, SimulationModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points, HVAC adjustments) are sent back to the physical devices through the same Hono/Ditto channel, enabling actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (sub‑second) synchronization between physical sensors and the twin as enabled by the Hono/Ditto data pipeline."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where the DT framework acts as a central hub connecting BIM‑derived device twins, the Hono/Ditto communication layer, and the Unreal Engine visualisation, with roles for building‑control engineers, facility managers and DT engineers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin supports the full building lifecycle: design (ideal BIM model), construction/manufacturing, and operational phases (post‑occupancy), allowing updates from each stage."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The overall digital‑twin entanglement (ODTE) metric is used to quantify how well the twin reflects its physical counterpart; the approach also addresses semantic drift through synchronization mechanisms."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication is realized through Eclipse Hono (messaging) and Eclipse Ditto (digital‑twin state management), providing a real‑time link between physical devices and the virtual model."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Generated runtime artifacts are deployed on a server‑based platform that hosts Eclipse Hono, Eclipse Ditto and the Unreal Engine visualization component as part of the DT framework."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution leverages BIM standards for building data, uses standardized extension points for modularity, and adopts open‑source frameworks (Eclipse Hono, Ditto) that follow industry interoperability specifications."
]