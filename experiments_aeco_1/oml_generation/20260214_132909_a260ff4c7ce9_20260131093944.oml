// C3: Physical sensing components
instance OccupancyPressureSensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy and air pressure sensor distributed across the building for occupancy detection and pressure monitoring"
    DTDFVocab:producedData OccupancyPressureDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring ambient air temperature throughout the building"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance CO2HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Combined CO₂ and relative humidity sensor for indoor air quality monitoring"
    DTDFVocab:producedData CO2HumidityDataTransmitted
]

instance LuxMeter : DTDFVocab:SensingComponent [
    base:desc "Lux meter located in each lighting zone to measure illuminance levels"
    DTDFVocab:producedData LuxMeterDataTransmitted
]

instance EnergyMeter : DTDFVocab:SensingComponent [
    base:desc "Energy metering device capturing real‑time electrical consumption of the building"
    DTDFVocab:producedData EnergyMeterDataTransmitted
]

instance DoorWindowContact : DTDFVocab:SensingComponent [
    base:desc "Door/window contact sensor reporting open/closed state for occupancy and security"
    DTDFVocab:producedData DoorWindowContactDataTransmitted
]

instance AmbientMicrophone : DTDFVocab:SensingComponent [
    base:desc "Ambient microphone array for acoustic monitoring and occupancy detection"
    DTDFVocab:producedData AmbientMicrophoneDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance OccupancyPressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyPressureSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance CO2HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2HumiditySensor
]

instance LuxMeterDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LuxMeter
]

instance EnergyMeterDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeter
]

instance DoorWindowContactDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DoorWindowContact
]

instance AmbientMicrophoneDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientMicrophone
]

// Data instances from transmitted data
instance OccupancyPressureData : DTDFVocab:Data [
    base:desc "Continuous stream of occupancy‑pressure readings (1 s cadence or on change)"
    DTDFVocab:fromData OccupancyPressureDataTransmitted
    DTDFVocab:inputTo EclipseHonoMiddlewareEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Continuous temperature readings (1 s cadence or on change)"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoMiddlewareEnabler
]

instance CO2HumidityData : DTDFVocab:Data [
    base:desc "Continuous CO₂ and humidity readings (1 s cadence or on change)"
    DTDFVocab:fromData CO2HumidityDataTransmitted
    DTDFVocab:inputTo EclipseHonoMiddlewareEnabler
]

instance LuxMeterData : DTDFVocab:Data [
    base:desc "Continuous illuminance readings from lux meters"
    DTDFVocab:fromData LuxMeterDataTransmitted
    DTDFVocab:inputTo EclipseHonoMiddlewareEnabler
]

instance EnergyMeterData : DTDFVocab:Data [
    base:desc "Continuous electricity consumption data"
    DTDFVocab:fromData EnergyMeterDataTransmitted
    DTDFVocab:inputTo EclipseHonoMiddlewareEnabler
]

instance DoorWindowContactData : DTDFVocab:Data [
    base:desc "Door/window status events"
    DTDFVocab:fromData DoorWindowContactDataTransmitted
    DTDFVocab:inputTo EclipseHonoMiddlewareEnabler
]

instance AmbientMicrophoneData : DTDFVocab:Data [
    base:desc "Ambient microphone audio samples for acoustic monitoring"
    DTDFVocab:fromData AmbientMicrophoneDataTransmitted
    DTDFVocab:inputTo EclipseHonoMiddlewareEnabler
]

// C10: Models and Data
instance BIMIFCModel : DTDFVocab:Model [
    base:desc "IFC BIM model enriched with device, control, and sensor metadata for the LEED Platinum Living Lab building"
    DTDFVocab:inputTo RevitArchicadModelingEnabler
]

instance JSONDeviceTwinDefinitions : DTDFVocab:Data [
    base:desc "JSON device twin definitions generated by the Hono/Ditto configurator"
    DTDFVocab:inputTo CodeGeneratorToolEnabler
    DTDFVocab:inputTo EclipseDittoPlatformEnabler
]

instance ContinuousSensorDataStream : DTDFVocab:Data [
    base:desc "Uncurated stream of all sensor outputs for analytics and simulation"
    DTDFVocab:inputTo EclipseHonoMiddlewareEnabler
]

instance ONNXPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement learning policy in ONNX format used by the BOREALIS predictive analytics module"
    DTDFVocab:inputTo ModelDrivenEngineeringFrameworkEnabler
]

instance PythonPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement learning policy in Python object form used by the BOREALIS predictive analytics module"
    DTDFVocab:inputTo ModelDrivenEngineeringFrameworkEnabler
]

instance UnrealEngine5SimulationModel : DTDFVocab:Model [
    base:desc "Unreal Engine 5 blueprint simulation model for immersive building visualization"
    DTDFVocab:inputTo UnrealEngine5VisualizerEnabler
]

// C11: Enablers
instance ModelDrivenEngineeringFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering framework generating runtime artifacts from BIM and device metadata"
    DTDFVocab:enables PredictiveAnalyticsService, LightingOptimizationService
]

instance EclipseHonoMiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware managing bi‑directional MQTT communication over TLS"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance EclipseDittoPlatformEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto platform for device twin management and event publication"
    DTDFVocab:enables RealTimeMonitoringService, AutomaticCommissioningService
]

instance UnrealEngine5VisualizerEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 visualizer providing interactive 3D visualization of the building"
    DTDFVocab:enables RealTimeMonitoringService, SimulationWhatIfService
]

instance RevitArchicadModelingEnabler : DTDFVocab:Enabler [
    base:desc "Revit/Archicad tooling for BIM model creation and enrichment"
]

instance CodeGeneratorToolEnabler : DTDFVocab:Enabler [
    base:desc "Code generator transforming BIM to Hono/Ditto configuration and JSON twin definitions"
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard accessible via web interface and Unreal Engine 5 visualizer"
    DTDFVocab:provides InsightDashboard, ActionSendAlert
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics module using reinforcement learning to balance energy and comfort"
    DTDFVocab:provides InsightAnomalyAlert, InsightLightingSetPointRecommendation, ActionExportAnalyticsReport, ActionSendAlert
]

instance SimulationWhatIfService : DTDFVocab:Service [
    base:desc "Simulation and what‑if scenario execution within Unreal Engine 5"
    DTDFVocab:provides InsightSimulationResults
]

instance AutomaticCommissioningService : DTDFVocab:Service [
    base:desc "Automatic commissioning workflow for building system validation"
    DTDFVocab:provides InsightCommissioningReport
]

instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes lighting product placement and control logic using simulation data"
    DTDFVocab:provides InsightLightingPlacementOptimization
]

// C17: Insights and Actions
instance InsightDashboard : DTDFVocab:Insight [
    base:desc "Dashboards summarizing energy consumption versus occupant comfort metrics"
]

instance InsightAnomalyAlert : DTDFVocab:Insight [
    base:desc "Automated alerts for anomalous sensor readings detected by predictive analytics"
]

instance InsightLightingSetPointRecommendation : DTDFVocab:Insight [
    base:desc "Recommendation engine proposing lighting set‑point adjustments to optimize comfort and energy use"
]

instance InsightSimulationResults : DTDFVocab:Insight [
    base:desc "Results of what‑if simulation scenarios executed in Unreal Engine 5"
]

instance InsightCommissioningReport : DTDFVocab:Insight [
    base:desc "Summary of automatic commissioning test results"
]

instance InsightLightingPlacementOptimization : DTDFVocab:Insight [
    base:desc "Insights for optimal lighting product placement derived from simulation"
]

instance ActionSendAlert : DTDFVocab:Action [
    base:desc "Automatic notification action sent to facility operators on anomalous events"
    DTDFVocab:IsAutomatic true
]

instance ActionExportAnalyticsReport : DTDFVocab:Action [
    base:desc "Exports data analytics reports to CSV/Excel for management review"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance SmartLightingActuator : DTDFVocab:ActingComponent [
    base:desc "Smart lighting fixture with dimmer and photometric control modules integrated into the BIM model"
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve actuator controlling airflow within the building, embedded in the BIM model"
]

instance HVACDamperActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC damper actuator for zone ventilation control, embedded in the BIM model"
]

instance BlindsActuator : DTDFVocab:ActingComponent [
    base:desc "Automated blinds actuator providing light and privacy control, exposed as an actuator in the twin"
]

instance HVACFanActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC fan controller actuator for zone airflow regulation, exposed as an actuator in the twin"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., desired luminance levels, HVAC set‑points) are published to the corresponding Ditto device twin; Ditto propagates the command to Eclipse Hono, which sends the instruction via MQTT (or REST) to the actuator gateway; the physical actuator receives the instruction within a few seconds"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous streaming of sensor data with sub‑second latency; control loop executed at a 5‑second refresh rate; simulation and optimization runs can be scheduled at hourly or daily intervals depending on the task"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated around a central service layer that couples the Hono message broker to the Ditto twin registry; each device twin represents a physical asset; the Unreal Engine instance subscribes to Ditto topics for rendering; the optimization engine subscribes to sensor streams and publishes new set‑points to Ditto"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (BIM creation), Construction (validation and deployment of device models), Commissioning (automation of commissioning via Hono), Operation (runtime data exchange, optimization, monitoring), Maintenance & Adaptation (continuous refinement of control policies and device models)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric used to quantify alignment between the virtual model and the physical asset; validity checks include schema validation of IFC metadata, consistency checks between Hono topic definitions and Ditto twin schemas, and statistical validation of sensor data streams; uncertainty quantified through simulation variance in Unreal Engine"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono broker implements MQTT over TLS 1.2 for sensor and command transport; Ditto devices expose REST/HTTP endpoints for twin management and WebSocket for real‑time updates; Unreal Engine connects to Ditto via a dedicated WebSocket client; building gateway bridges BACnet or Modbus to Hono using custom adapters"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Containerized deployment of Eclipse Hono and Ditto on Kubernetes; Unreal Engine rendering server hosted on a dedicated GPU node; all services can be deployed on public cloud (AWS EKS/GKE) or on‑premises private cloud; the entire stack is orchestrated via Helm charts"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external BIM repositories via IFC import/export APIs; linkage to enterprise ERP systems for asset lifecycle data; connection to outside analytics services (e.g., cloud ML services) through REST APIs; standardised data exchange using JSON schemas"
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "All sensor data is owned by the physical asset owner; the DT provider holds a processed, anonymised derivative set subject to the PT owner’s consent; communications are encrypted using TLS and access controlled via OAuth2 and role‑based permissions"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adheres to Industry Foundation Classes (IFC) for BIM data, MQTT 3.1.1 over TLS for messaging, JSON schema for twin definitions, and ISO/IEC 27001‑based security controls at the middleware level"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "TLS encryption for all MQTT and HTTP traffic; authentication via JWT tokens issued by Hono; role‑based access control in Ditto; safety mechanisms such as fail‑safe default states for lighting and HVAC (e.g., fallback to 0 lux or 20 % set‑point) to prevent accidents; logging and audit trails for all command and sensor events"
]