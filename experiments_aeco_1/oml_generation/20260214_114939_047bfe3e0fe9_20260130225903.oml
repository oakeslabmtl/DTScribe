// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor defined in the enriched BIM model for measuring temperature"
    DTDFVocab:producedData TempDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor defined in the enriched BIM model for measuring illumination levels"
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor defined in the enriched BIM model for detecting occupancy"
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance TempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C5: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature values streamed from the building"
    DTDFVocab:fromData TempDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchange
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Real‑time illumination measurements streamed from the building"
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchange
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy detection data streamed from the building"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchange
]

// C11: Enablers
instance RealTimeDataExchange : DTDFVocab:Enabler [
    base:desc "Continuous real‑time data exchange layer that synchronizes physical measurements with the digital twin"
    DTDFVocab:enables RealTimeMonitoringService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "High‑fidelity simulation engine used for building and lighting performance analysis"
    DTDFVocab:enables HighFidelitySimulationService
]

instance PredictiveAnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Analytics engine that predicts energy consumption and lighting usage"
    DTDFVocab:enables PredictiveAnalyticsService
]

instance OptimizationEngine : DTDFVocab:Enabler [
    base:desc "Automated optimization service that computes optimal lighting set‑points for energy efficiency"
    DTDFVocab:enables AutomatedOptimizationService
]

instance ControlEngine : DTDFVocab:Enabler [
    base:desc "Closed‑loop control engine that issues actuation commands based on occupancy and daylight"
    DTDFVocab:enables ClosedLoopControlService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Immersive 3D visualization platform for interactive monitoring and scenario exploration"
    DTDFVocab:enables ImmersiveVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of sensor data (temperature, illumination, occupancy)"
    DTDFVocab:provides SystemStateInsight
]

instance HighFidelitySimulationService : DTDFVocab:Service [
    base:desc "Runs high‑fidelity simulation of building and lighting performance"
    DTDFVocab:provides LightingPerformanceInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predicts energy consumption and lighting usage based on streamed sensor data"
    DTDFVocab:provides EnergyConsumptionInsight, LightingUsageInsight
]

instance AutomatedOptimizationService : DTDFVocab:Service [
    base:desc "Automatically optimizes lighting set‑points to improve overall energy efficiency"
    DTDFVocab:provides OptimizeEnergyEfficiencyAction
]

instance ClosedLoopControlService : DTDFVocab:Service [
    base:desc "Executes closed‑loop control actions to adjust lighting levels based on occupancy and daylight"
    DTDFVocab:provides AdjustLightingSetpointAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Delivers immersive 3D visualization for interactive monitoring and scenario exploration"
    DTDFVocab:provides ScenarioExplorationInsight
]

// C17: Insights
instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Continuous insight into the current state of building systems for facility managers"
]

instance LightingPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight into lighting performance derived from high‑fidelity simulation"
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Predicted energy consumption insight generated by predictive analytics"
]

instance LightingUsageInsight : DTDFVocab:Insight [
    base:desc "Predicted lighting usage patterns insight generated by predictive analytics"
]

instance ScenarioExplorationInsight : DTDFVocab:Insight [
    base:desc "Insight from interactive scenario exploration within the 3D visualization"
]

// C17: Actions
instance AdjustLightingSetpointAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting set‑points based on occupancy and daylight"
    DTDFVocab:IsAutomatic true
]

instance OptimizeEnergyEfficiencyAction : DTDFVocab:Action [
    base:desc "Automated optimization of lighting configuration to minimize energy consumption"
    DTDFVocab:IsAutomatic true
]

instance IssueControlCommandAction : DTDFVocab:Action [
    base:desc "Issue control commands to actuators for real‑time lighting adjustments"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator modelled as a first‑class entity in BIM, capable of receiving control commands to adjust lighting levels"
]

// C10: Models/Data
instance BIMDerivedModel : DTDFVocab:Model [
    base:desc "Enriched BIM model that includes semantic definitions of sensors, actuators, and controllers"
    DTDFVocab:inputTo RealTimeDataExchange, SimulationEngine, PredictiveAnalyticsEngine, ControlEngine
]

instance LightingPerformanceModel : DTDFVocab:Model [
    base:desc "Computational model derived from BIM for simulating lighting performance"
    DTDFVocab:inputTo SimulationEngine
]

instance EnergyConsumptionModel : DTDFVocab:Model [
    base:desc "Computational model derived from BIM for predicting energy consumption"
    DTDFVocab:inputTo PredictiveAnalyticsEngine
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral control logic extracted from BIM for closed‑loop lighting control"
    DTDFVocab:inputTo ControlEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated in the digital twin (e.g., via Facility Managers’ interaction) and transmitted back through the DT Framework to the building control systems. This bidirectional exchange supports real‑time monitoring and actuation, letting the twin feed control signals to physical devices and receive confirmation of execution."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports a full Digital Twin lifecycle that starts with device modeling inside the BIM environment—building control engineers define sensors, actuators and controllers to create a unified semantic foundation. Next, Model‑Driven Engineering (MDE) principles are applied to extract structured representations from the enriched BIM model and automatically generate deployable DT artefacts with minimal manual effort. The lifecycle then moves to the operational phase, where real‑time data exchange continuously synchronises the physical building with its digital counterpart. Throughout operation, the modular architecture with standardized extension points enables the integration of custom services and analytics, allowing the twin to evolve over time. Lifecycle governance is reflected in the role‑based workflow (Building Control Engineer, Facility Manager, DT Engineer) that orchestrates modeling, deployment, monitoring and extension activities."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The solution employs a layered, modular architecture that ensures interoperability across heterogeneous systems. Standardised extension points and runtime configuration management provide a flexible technical connection, while the non‑functional requirements (NF_X) address scalability, maintainability, and accessibility. No explicit network protocols, topology, bandwidth, latency, or security mechanisms are detailed in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The proposal relies on BIM as the canonical data model and exposes “standardized extension points” that define a common API for plug‑ins and custom services, ensuring interoperability between the twin and external analytics or control modules. While no specific industry standards (e.g., IEC, ISO) are enumerated, compliance is achieved through adherence to the BIM‑based data exchange paradigm and the use of a regulated modular architecture that supports certified extensions."
]