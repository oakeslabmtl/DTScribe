// Sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM, converted to a DittoThing for real‑time occupancy monitoring."
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor modeled in BIM, converted to a DittoThing for real‑time illumination level measurement."
    DTDFVocab:producedData IlluminationDataTransmitted
]

// Data transmitted from sensors
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

// Streamed data to digital twin
instance OccupancyData : DTDFVocab:Data [
    base:desc "Streaming occupancy value sent from the occupancy sensor to the digital twin via Eclipse Hono."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo HonoBrokerEnabler
]
instance IlluminationData : DTDFVocab:Data [
    base:desc "Streaming illumination value sent from the illumination sensor to the digital twin via Eclipse Hono."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo HonoBrokerEnabler
]

// Enablers
instance HonoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono broker that receives sensor streams and forwards them to Eclipse Ditto."
    DTDFVocab:enables RealTimeMonitoringService, AutomatedControlService
]
instance DittoControllerEnabler : DTDFVocab:Enabler [
    base:desc "Ditto controller that validates actuator command policies and routes them to physical actuators."
    DTDFVocab:enables AutomatedControlService
]
instance UEEngineVisualizerEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine visualizer consuming Ditto real‑time API for immersive building interaction."
    DTDFVocab:enables ImmersiveVisualizationService
]
instance AnalyticsEngineEnabler : DTDFVocab:Enabler [
    base:desc "Analytics engine performing predictive analytics and optimization for energy efficiency."
    DTDFVocab:enables PredictiveAnalyticsService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service delivering real‑time monitoring of sensor data and visualization dashboards."
    DTDFVocab:provides TrendDetectionInsight, AnomalyDetectionInsight, AlertNotificationInsight
]
instance AutomatedControlService : DTDFVocab:Service [
    base:desc "Service that automatically controls lighting actuators based on sensor inputs."
    DTDFVocab:provides BrightnessIncreaseAction, BrightnessDecreaseAction, EnergyOptimizationAction
]
instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Service offering immersive visualization through Unreal Engine dashboards."
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service performing predictive analytics to optimize energy usage and asset health."
    DTDFVocab:provides EnergyOptimizationInsight
]

// Insights
instance TrendDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight that detects trends in real‑time sensor data for proactive facility management."
]
instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight that flags anomalous sensor readings or actuator behaviors."
]
instance AlertNotificationInsight : DTDFVocab:Insight [
    base:desc "Insight that surfaces alerts and suggestions for operators directly on dashboards."
]
instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight that recommends energy‑saving actions based on predictive models."
]

// Actions
instance BrightnessIncreaseAction : DTDFVocab:Action [
    base:desc "Action to increase lighting brightness via dimming actuator."
    DTDFVocab:IsAutomatic true
]
instance BrightnessDecreaseAction : DTDFVocab:Action [
    base:desc "Action to decrease lighting brightness via dimming actuator."
    DTDFVocab:IsAutomatic true
]
instance EnergyOptimizationAction : DTDFVocab:Action [
    base:desc "Action to adjust lighting schedules for optimal energy consumption."
    DTDFVocab:IsAutomatic true
]

// Models
instance BuildingInformationModel : DTDFVocab:Model [
    base:desc "Enriched Building Information Model (BIM) containing geometry, sensors, actuators, and controllers."
    DTDFVocab:inputTo HonoBrokerEnabler
]
instance LightingControlLogicModel : DTDFVocab:Model [
    base:desc "Model of lighting control logic derived from BIM and encapsulating safety constraints."
    DTDFVocab:inputTo DittoControllerEnabler
]
instance EnergyEfficiencyModel : DTDFVocab:Model [
    base:desc "Predictive model for energy efficiency and asset health based on sensor data."
    DTDFVocab:inputTo AnalyticsEngineEnabler
]

// Acting component
instance DimmingActuator : DTDFVocab:ActingComponent [
    base:desc "Dimmer actuator represented as a DittoThing; supports brightness and color temperature control."
]

// Components
instance Building : DTDFVocab:Component [
    base:desc "Physical building structure served by the digital twin."
]
instance LightingFixture : DTDFVocab:Component [
    base:desc "Lighting fixture integrated within the building model."
]
instance OccupancySensorComponent : DTDFVocab:Component [
    base:desc "Component representing the occupancy sensor in the building."
]
instance IlluminationSensorComponent : DTDFVocab:Component [
    base:desc "Component representing the illumination sensor in the building."
]
instance DimmingActuatorComponent : DTDFVocab:Component [
    base:desc "Component representing the dimming actuator in the building."
]

// Environment
instance LivingLabEnvironment : DTDFVocab:Environment [
    base:contains Building, LightingFixture, OccupancySensorComponent, IlluminationSensorComponent, DimmingActuatorComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Facility managers use the system to issue control commands from digital twins to actual building equipment. Command types and message formats are not specified, and the documents lack details on validation, authentication, or feedback mechanisms. The framework is said to provide real‑time monitoring and control, but specific flow and conflict resolution details are absent."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system adopts a modular, service‑oriented architecture where a central Digital Twin Framework hub orchestrates bidirectional data exchange between enriched BIM models and the physical building’s sensor fleet, while exposing standardized extension points for custom analytics and service integration. Runtime configuration management allows the framework to adapt to evolving operational needs without full redeployment, providing dynamic orchestration and resource management across the Digital Twin lifecycle."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Phases: 1) Initial device modeling directly within BIM, defining sensors, actuators, and controller logic; 2) Transformation via Model‑Driven Engineering (MDE) principles to extract structured representations; 3) Automatic generation of deployable DT artifacts with minimal manual intervention; 4) Real‑time bidirectional data exchange ensuring continuous synchronization; 5) Interactive visualization and monitoring; 6) Extension of functionality through custom services via standardized extension points. Transitions are managed through automated artifact extraction and deployment pipelines, with governance enforced by verification against the enriched BIM baseline."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is preserved by validating enriched BIM models against a set of structural and semantic rules during the validation step of the conversion pipeline. Eclipse Ditto’s policy engine performs continuous verification of incoming sensor data and actuator commands, ensuring that all values respect predefined bounds and units. Fault tolerance is achieved through Eclipse Hono’s at‑least‑once message delivery guarantee and Ditto’s persistent event storage, providing resilience against network interruptions. Error detection is handled by policy violations that trigger alerts or message rejections, while error correction is achieved by either resetting the device state or reverting to the last stable state stored in Ditto. Quality assurance of the DT system is supported by the modular architecture, which enables adding custom analytics services to monitor fidelity metrics and enforce consistency between the physical assets and their digital twins.}"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The documents mention interoperability across heterogeneous systems and a modular architecture with standardized extension points. They do not provide concrete network protocols (e.g., MQTT, REST), topology, bandwidth, latency, reliability or security specifics for the Digital Twin network. Hence these details are not provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment infrastructure is broadly described: the DT Framework acts as a central hub facilitating bidirectional data exchange. The documents do not specify whether the deployment is on‑premise, edge or cloud, nor do they state computational, storage requirements, scalability or availability mechanisms. Therefore such details are not available."
]