// C3: Physical sensing components
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded illumination level sensor modelled in the BIM that captures illumination levels in the building."
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded occupancy presence sensor modelled in the BIM that detects occupant presence in rooms."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded environmental sensor modelled in the BIM that measures temperature, humidity and other variables."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C10: Data
instance IlluminationData : DTDFVocab:Data [
    base:desc "Continuously streamed illumination measurements received via Eclipse Hono."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Continuously streamed occupancy presence data received via Eclipse Hono."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Continuously streamed environmental variables (temperature, humidity) received via Eclipse Hono."
    DTDFVocab:fromData EnvironmentalDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono streams sensor measurements from the physical building to the Digital Twin in real time."
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalyticsService, EnergyOptimizationAlgorithm, BuildingPerformanceSimulation
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto stores incoming sensor data as twin properties, enabling real‑time synchronization of the twin."
    DTDFVocab:enables RealTimeMonitoringDashboard, EnergyOptimizationAlgorithm
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders the 3D interactive visualization of the building twin."
    DTDFVocab:enables Interactive3DVisualization
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Dashboard that visualises live sensor streams and key performance indicators."
    DTDFVocab:provides EnergyConsumptionTrendsInsight, ComfortViolationsInsight
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "3D interactive visualization of the BIM‑derived twin rendered in Unreal Engine 5."
    DTDFVocab:provides SpatialVisualizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics that forecast energy usage and comfort conditions."
    DTDFVocab:provides PredictiveEnergyUsageInsight, AnticipatedComfortIssuesInsight
]

instance EnergyOptimizationAlgorithm : DTDFVocab:Service [
    base:desc "Algorithm that computes optimized lighting set‑points and can trigger actuation."
    DTDFVocab:provides OptimizedLightingSetpointsInsight, AdjustLightingSetpointAction
]

instance BuildingPerformanceSimulation : DTDFVocab:Service [
    base:desc "Simulation of building performance for scenario analysis."
    DTDFVocab:provides SimulatedPerformanceMetricsInsight
]

// C17: Insights
instance EnergyConsumptionTrendsInsight : DTDFVocab:Insight [
    base:desc "Energy‑consumption trends derived from continuous illumination and occupancy data."
]

instance ComfortViolationsInsight : DTDFVocab:Insight [
    base:desc "Detected comfort violations such as insufficient lighting or occupancy mismatches."
]

instance PredictiveEnergyUsageInsight : DTDFVocab:Insight [
    base:desc "Forecast of future energy usage based on current sensor patterns."
]

instance AnticipatedComfortIssuesInsight : DTDFVocab:Insight [
    base:desc "Prediction of upcoming comfort issues (e.g., glare, under‑lighting)."
]

instance OptimizedLightingSetpointsInsight : DTDFVocab:Insight [
    base:desc "Optimized lighting set‑points calculated to balance energy efficiency and occupant comfort."
]

instance SimulatedPerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Performance metrics generated by building simulation models."
]

instance SpatialVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time spatial representation of the building twin for operator situational awareness."
]

// C17: Actions
instance AdjustLightingSetpointAction : DTDFVocab:Action [
    base:desc "Automatically adjusts lighting dimmers to the optimized set‑point."
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Actuating dimmer device modelled in BIM that receives control commands to adjust illumination levels."
]

instance LightingSwitchActuator : DTDFVocab:ActingComponent [
    base:desc "Actuating switch device modelled in BIM that can turn lighting zones on or off."
]

// C10: Models/Data (dt_models_and_data)
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM representation enriched with device metadata and runtime semantics for the building."
    DTDFVocab:inputTo EclipseHono, EclipseDitto, UnrealEngine5
]

instance DeviceMetadataModel : DTDFVocab:Model [
    base:desc "Model capturing sensor and actuator configurations stored as runtime semantics in the BIM."
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C10: Additional Data representing twin properties
instance TwinPropertyData : DTDFVocab:Data [
    base:desc "Twin properties persisted in Eclipse Ditto reflecting the latest sensor state."
    DTDFVocab:fromData IlluminationDataTransmitted, OccupancyDataTransmitted, EnvironmentalDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

// C17: Environment
instance LivingLabBuildingEnvironment : DTDFVocab:Environment [
    base:contains IlluminationSensor, OccupancySensor, EnvironmentalSensor, LightingDimmerActuator, LightingSwitchActuator
]

// C8: Twinning process & DT evolution (as a service)
instance TwinningDeploymentPipeline : DTDFVocab:Service [
    base:desc "Model‑driven deployment pipeline that enriches BIM, validates models, generates Hono/Ditto configuration and deploys twin artifacts."
]

// C9: System under study (as a component)
instance LivingLabBuilding : DTDFVocab:Component [
    base:desc "The physical building infrastructure (Living Lab academic building) represented as a cyber‑physical system."
    DTDFVocab:hasEnvironment LivingLabBuildingEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command flow from the twin to physical actuators through Eclipse Ditto and Eclipse Hono, allowing the twin to issue control signals back to the building control system."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (sub‑second) synchronization of sensor data and control commands between the physical asset and the twin."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central hub linking the enriched BIM model, Hono/Ditto middleware, and Unreal Engine visualization; modular extension points allow additional services to be plugged in."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Supports the design, construction, and operation phases; the twin persists from as‑designed BIM through as‑built to as‑operated representations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric is employed to quantify the fidelity of the twin to its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication is realized through Eclipse Hono and Eclipse Ditto, providing real‑time data exchange between physical assets and the twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Built on BIM/IFC standards and open IoT standards implemented by Eclipse Hono and Ditto."
]