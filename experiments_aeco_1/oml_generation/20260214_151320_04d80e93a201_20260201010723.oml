    base:desc "Motorized HVAC valve actuator defined within BIM environment for remote control of heating/cooling flows, with safety constraints managed through BIM-integrated modeling pipeline"
]

instance LightingControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting system controller actuator configured via BIM models to manage illumination levels, incorporating domain-specific control semantics from TwinLight project"
]

instance MotorizedShadeActuator : DTDFVocab:ActingComponent [
    base:desc "Motorized window shade actuator integrated into BIM models for automated window treatment control, enabling energy optimization through DT synchronization"
]

// C3: Physical Sensing Components
instance EnvironmentalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined within BIM environment capturing environmental conditions for real-time building control system monitoring"
    DTDFVocab:producedData EnvironmentalTemperatureDataTransmitted
]

instance RelativeHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor configured in BIM models to measure relative humidity levels for HVAC system regulation and occupant comfort monitoring"
    DTDFVocab:producedData RelativeHumidityDataTransmitted
]

instance OccupancyMotionSensor : DTDFVocab:SensingComponent [
    base:desc "Motion detection sensor integrated into BIM models for occupancy monitoring, enabling energy-efficient lighting and HVAC control"
    DTDFVocab:producedData OccupancyMotionDataTransmitted
]

instance CO2ConcentrationSensor : DTDFVocab:SensingComponent [
    base:desc "CO2 concentration sensor defined in BIM environment for indoor air quality monitoring and ventilation system optimization"
    DTDFVocab:producedData CO2ConcentrationDataTransmitted
]

instance EnergyConsumptionMeter : DTDFVocab:SensingComponent [
    base:desc "Building energy consumption meter configured via BIM models to track real-time energy usage patterns for optimization analysis"
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance EnvironmentalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalTemperatureSensor
]

instance RelativeHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RelativeHumiditySensor
]

instance OccupancyMotionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyMotionSensor
]

instance CO2ConcentrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2ConcentrationSensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionMeter
]

// C10: Models/Data
instance BIMBuildingModel : DTDFVocab:Model [
    base:desc "Static geometric and structural foundation model created in BIM environment serving as initial representation of physical building infrastructure"
    DTDFVocab:inputTo BIMEnrichmentEnabler
]

instance EnrichedBIMControlModel : DTDFVocab:Model [
    base:desc "Semantically enhanced BIM model incorporating behavioral control logic for sensors, actuators, and controllers defined by Building Control Engineers"
    DTDFVocab:inputTo ModelDrivenEngineeringEnabler, RealTimeDataExchangeEnabler
]

instance DeployableDTArtifact : DTDFVocab:Model [
    base:desc "Automatically generated deployable Digital Twin components created via MDE principles from enriched BIM models for real-time synchronization"
    DTDFVocab:inputTo DeploymentAutomationEnabler
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Processed environmental data including temperature, humidity, and CO2 concentrations derived from sensor readings for building control analysis"
    DTDFVocab:fromData EnvironmentalTemperatureDataTransmitted, RelativeHumidityDataTransmitted, CO2ConcentrationDataTransmitted
    DTDFVocab:inputTo InteractiveVisualizationEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy patterns data collected from motion sensors enabling energy-efficient building operation optimization"
    DTDFVocab:fromData OccupancyMotionDataTransmitted
    DTDFVocab:inputTo InteractiveVisualizationEnabler
]

instance EnergyPerformanceData : DTDFVocab:Data [
    base:desc "Building energy consumption and performance metrics derived from consumption meters for predictive maintenance and optimization analysis"
    DTDFVocab:fromData EnergyConsumptionDataTransmitted
    DTDFVocab:inputTo InteractiveVisualizationEnabler
]

// C11: Enablers
instance ModelDrivenEngineeringEnabler : DTDFVocab:Enabler [
    base:desc "Core MDE framework transforming enriched BIM models into structured, deployable DT artifacts with automated extraction of semantic representations"
    DTDFVocab:enables DeviceModelingService, AutomatedArtifactGenerationService
]

instance BIMEnrichmentEnabler : DTDFVocab:Enabler [
    base:desc "BIM environment platform enabling semantic modeling of BCS components and control logic definition by Building Control Engineers"
    DTDFVocab:enables DeviceModelingService, InteractiveVisualizationService
]

instance RealTimeDataExchangeEnabler : DTDFVocab:Enabler [
    base:desc "Bidirectional synchronization mechanism maintaining continuous alignment between physical BCS components and Digital Twin via MQTT/HTTP protocols"
    DTDFVocab:enables RealTimeDataExchangeService, LifecycleManagementService
]

instance ModularArchitectureEnabler : DTDFVocab:Enabler [
    base:desc "Runtime extensibility framework featuring standardized interfaces for integrating custom services, plugins, and analytics modules"
    DTDFVocab:enables CustomServiceIntegrationService, InteractiveVisualizationService
]

instance InteractiveVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Immersive visualization tools providing user-friendly dashboards for monitoring and controlling building operations via MDE-generated artifacts"
    DTDFVocab:enables InteractiveVisualizationService
]

instance DeploymentAutomationEnabler : DTDFVocab:Enabler [
    base:desc "MDE-driven workflows automating generation and deployment of DT components from BIM models, reducing manual configuration"
    DTDFVocab:enables AutomatedArtifactGenerationService
]

instance EclipseHonoIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono/Ditto integration providing standardized APIs for bidirectional communication between physical systems and Digital Twin"
    DTDFVocab:enables RealTimeDataExchangeService
]

// C6: Services
instance DeviceModelingService : DTDFVocab:Service [
    base:desc "Semantic modeling and control logic definition service enabling direct modeling of sensors, actuators, and controllers within BIM environments"
    DTDFVocab:provides DeviceConfigurationInsight, ControlLogicAction
]

instance RealTimeDataExchangeService : DTDFVocab:Service [
    base:desc "Bidirectional synchronization service ensuring continuous alignment between physical BCS components and Digital Twin via real-time data exchange"
    DTDFVocab:provides SystemStateInsight, DataConsistencyAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive monitoring and control interface service providing real-time visualization of building operations for Facility Managers"
    DTDFVocab:provides OperationalOverviewInsight, PhysicalOperationAction
]

instance CustomServiceIntegrationService : DTDFVocab:Service [
    base:desc "Extensible analytics and automation service supporting modular architecture with standardized extension points for custom plugins"
    DTDFVocab:provides PredictiveMaintenanceInsight, EnergyOptimizationAction
]

instance AutomatedArtifactGenerationService : DTDFVocab:Service [
    base:desc "Model-driven deployment service automatically generating deployable DT artifacts from enriched BIM models with minimal manual intervention"
    DTDFVocab:provides StandardizedRepresentationInsight
]

instance LifecycleManagementService : DTDFVocab:Service [
    base:desc "End-to-end DT operations service supporting entire lifecycle from initial device modeling to runtime operation and extension"
    DTDFVocab:provides LifecycleGovernanceInsight
]

// C17: Insights/Actions
instance DeviceConfigurationInsight : DTDFVocab:Insight [
    base:desc "Semantic representation of device configurations enabling unified foundation for DT artifacts"
]

