// Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor providing temperature readings for TwinLight and BOREALIS control policies."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor measuring relative humidity within the building for TwinLight and BOREALIS control policies."
    DTDFVocab:producedData HumidityDataTransmitted
]
instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor monitoring indoor air quality for TwinLight and BOREALIS control policies."
    DTDFVocab:producedData CO2DataTransmitted
]
instance LightIntensitySensor : DTDFVocab:SensingComponent [
    base:desc "Light intensity sensor capturing ambient light levels for TwinLight and BOREALIS control policies."
    DTDFVocab:producedData LightIntensityDataTransmitted
]
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor detecting presence of occupants for post-occupancy analysis in TwinLight and BOREALIS control policies."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// Acting Components
instance LEDLightingActuator : DTDFVocab:ActingComponent [
    base:desc "LED luminaires acting as lighting fixtures in the building automation system."
]
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuators regulating air handling units within the building automation system."
]

// Data Transmitted Instances
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]
instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]
instance LightIntensityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightIntensitySensor
]
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// Data Instances
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature data streamed via Eclipse Hono’s MQTT broker."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]
instance HumidityData : DTDFVocab:Data [
    base:desc "Real-time humidity data streamed via Eclipse Hono’s MQTT broker."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]
instance CO2Data : DTDFVocab:Data [
    base:desc "Real-time CO₂ data streamed via Eclipse Hono’s MQTT broker."
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]
instance LightIntensityData : DTDFVocab:Data [
    base:desc "Real-time light intensity data streamed via Eclipse Hono’s MQTT broker."
    DTDFVocab:fromData LightIntensityDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]
instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy data streamed via Eclipse Hono’s MQTT broker."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT broker acting as the service gateway for sensor data ingestion."
    DTDFVocab:enables Service_MonitoringDashboard
]
instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin asset management system for twin state updates."
    DTDFVocab:enables Service_MonitoringDashboard, Service_PredictiveAnalytics, Service_EnergyUsageOptimization, Service_ReinforcementLearningLightingControl, Service_BuildingPerformanceSimulation, Service_Immersive3DVisualization
]
instance UnrealEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine for immersive 3D visualization of the digital twin."
    DTDFVocab:enables Service_Immersive3DVisualization
]
instance EMFModelTransformationTools : DTDFVocab:Enabler [
    base:desc "EMF-based model transformation tools for extracting control logic from enriched BIM models."
    DTDFVocab:enables Service_ReinforcementLearningLightingControl, Service_BuildingPerformanceSimulation
]
instance AutodeskRevit : DTDFVocab:Enabler [
    base:desc "Autodesk Revit BIM authoring tool for creating enriched BIM models with device semantics."
    DTDFVocab:enables Service_MonitoringDashboard
]

// Models
instance Model_IFC_BIM_with_DeviceSemantics : DTDFVocab:Model [
    base:desc "IFC BIM model enriched with device semantics used as the source architecture for the digital twin."
    DTDFVocab:inputTo AutodeskRevit
]
instance RuntimeStateModel : DTDFVocab:Model [
    base:desc "Runtime state model representing the current state of each actuator and sensor in the building."
    DTDFVocab:inputTo EMFModelTransformationTools
]
instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model extracted by model-driven transformation from the enriched BIM model."
    DTDFVocab:inputTo EMFModelTransformationTools
]
instance ReinforcementLearningPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement learning policy model generated for lighting control optimization."
    DTDFVocab:inputTo EMFModelTransformationTools
]

// Services
instance Service_MonitoringDashboard : DTDFVocab:Service [
    base:desc "Real-time monitoring dashboard providing energy consumption summaries and setpoint histories."
    DTDFVocab:provides Insight_EnergyConsumptionSummary, Insight_ThermostatSetpointHistory, Insight_PredictiveMaintenanceAlert, Insight_LightingScheduleRecommendation, Insight_HVACSetpointRecommendation
]
instance Service_PredictiveAnalytics : DTDFVocab:Service [
    base:desc "Predictive analytics service generating predictive maintenance alerts for facility managers."
    DTDFVocab:provides Insight_PredictiveMaintenanceAlert
]
instance Service_EnergyUsageOptimization : DTDFVocab:Service [
    base:desc "Energy usage optimization service that recommends and automatically implements energy-saving actions."
    DTDFVocab:provides Action_OptimizeEnergyUsage
]
instance Service_ReinforcementLearningLightingControl : DTDFVocab:Service [
    base:desc "Reinforcement learning service that generates lighting control policies for TwinLight."
    DTDFVocab:provides Action_GenerateLightingControlPolicy
]
instance Service_BuildingPerformanceSimulation : DTDFVocab:Service [
    base:desc "Building performance simulation service producing performance reports and optimization plans."
    DTDFVocab:provides Insight_PerformanceReport, Insight_OptimizationPlan
]
instance Service_Immersive3DVisualization : DTDFVocab:Service [
    base:desc "Immersive 3D visualization service rendering the building model via Unreal Engine."
    DTDFVocab:provides Insight_3DVisualization
]

// Insights
instance Insight_EnergyConsumptionSummary : DTDFVocab:Insight [
    base:desc "Energy consumption summary dashboard showing real‑time usage."
]
instance Insight_ThermostatSetpointHistory : DTDFVocab:Insight [
    base:desc "Historical record of thermostat setpoints over time."
]
instance Insight_PredictiveMaintenanceAlert : DTDFVocab:Insight [
    base:desc "Alert indicating impending maintenance needs based on predictive analytics."
]
instance Insight_LightingScheduleRecommendation : DTDFVocab:Insight [
    base:desc "Recommendation for optimised lighting schedules from the reinforcement learning policy."
]
instance Insight_HVACSetpointRecommendation : DTDFVocab:Insight [
    base:desc "Recommendation for optimal HVAC setpoints derived from energy usage optimisation."
]
instance Insight_PerformanceReport : DTDFVocab:Insight [
    base:desc "Performance report generated from building simulation analyses."
]
instance Insight_OptimizationPlan : DTDFVocab:Insight [
    base:desc "Optimization plan outlining actionable steps for improving building performance."
]
instance Insight_3DVisualization : DTDFVocab:Insight [
    base:desc "Real‑time 3D visualization of the building model."
]

// Actions
instance Action_OptimizeEnergyUsage : DTDFVocab:Action [
    base:desc "Automatic adjustment of HVAC and lighting subsystems to achieve energy savings."
    DTDFVocab:IsAutomatic true
]
instance Action_GenerateLightingControlPolicy : DTDFVocab:Action [
    base:desc "Automated generation of lighting control policies using reinforcement learning."
    DTDFVocab:IsAutomatic true
]
instance Action_AdjustLightingSchedule : DTDFVocab:Action [
    base:desc "Manual adjustment of lighting schedules based on recommendations."
    DTDFVocab:IsAutomatic false
]
instance Action_AdjustHVACSetpoint : DTDFVocab:Action [
    base:desc "Manual adjustment of HVAC setpoints as per optimal recommendations."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (lighting setpoints, HVAC modes) generated by the Digital Twin and transmitted back to physical actuators through the Hono/Ditto bidirectional channel."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization, with sensor updates and control messages processed on a scale of milliseconds to seconds for near‑real‑time interaction."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (BIM model creation), Construction (manufacturing and installation data), and Operation (runtime monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "ODTE metric quantifies entanglement, semantic drift mitigation through regular synchronization, validation by comparing twin states with sensor readings, and uncertainty bounded by sensor error specifications."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono implements MQTT (device‑to‑cloud) and HTTP/REST APIs; Eclipse Ditto stores device twins and exposes WebSocket/REST interfaces; network architecture includes an MQTT broker, Ditto server, and visualization client connected over secure channels."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM IFC for building models; MQTT, HTTPS/REST, and JSON schema for IoT communication; adherence to open model‑driven engineering standards (EMF)."
]