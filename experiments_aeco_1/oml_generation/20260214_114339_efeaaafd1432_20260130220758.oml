// =============================
// Acting Components (Actuators)
// =============================

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator modeled in BIM as part of the device‑modeling layer, provides on‑off control for lighting zones."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator modeled in BIM as part of the device‑modeling layer, provides set‑point adjustments and scheduling for the HVAC system."
]

// =============================
// Physical Sensing Components
// =============================

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Semantic temperature sensor object embedded in the enriched BIM model, positioned according to BIM placement."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Semantic occupancy sensor object embedded in the enriched BIM model, positioned according to BIM placement."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Semantic humidity sensor object embedded in the enriched BIM model, positioned according to BIM placement."
    DTDFVocab:producedData HumidityDataTransmitted
]

// =============================
// Data Transmitted (Physical → Virtual)
// =============================

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

// =============================
// Data (Virtual)
// =============================

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature measurement stream received from the physical temperature sensor."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DataIngestionLayer
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy measurement stream received from the physical occupancy sensor."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo DataIngestionLayer
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Real‑time humidity measurement stream received from the physical humidity sensor."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo DataIngestionLayer
]

// =============================
// Models (Derived from BIM)
// =============================

instance BuildingGeometryModel : DTDFVocab:Model [
    base:desc "Geometric model representing the BIM building geometry enriched with device definitions."
    DTDFVocab:inputTo VisualizationDashboardEngine
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model encoding the control logic authored by building control engineers."
    DTDFVocab:inputTo ControlLogicEngine
]

instance PerformanceAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model derived for performance evaluation of building systems."
    DTDFVocab:inputTo AnalyticsEngine
]

// =============================
// Enablers
// =============================

instance DataIngestionLayer : DTDFVocab:Enabler [
    base:desc "Data ingestion layer that aggregates sensor streams, timestamps them, and makes them available for downstream processing."
    DTDFVocab:enables RealTimeMonitoringService
]

instance ControlLogicEngine : DTDFVocab:Enabler [
    base:desc "Engine executing the behavioral control logic model to generate actuation commands."
    DTDFVocab:enables RealTimeControlService
]

instance AnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Analytics engine that runs simulation, predictive, and optimization models on incoming data."
    DTDFVocab:enables SimulationAnalysisService, PredictiveAnalyticsService, OptimizationService
]

instance VisualizationDashboardEngine : DTDFVocab:Enabler [
    base:desc "Visualization engine that renders BIM geometry together with live sensor data for operator dashboards."
    DTDFVocab:enables VisualizationDashboardService
]

// =============================
// Services
// =============================

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real‑time monitoring of building state by integrating static BIM models with runtime sensor data."
    DTDFVocab:provides BuildingStateInsight
]

instance RealTimeControlService : DTDFVocab:Service [
    base:desc "Service delivering real‑time control commands to actuators based on control logic outputs."
    DTDFVocab:provides EnergyOptimizationInsight
]

instance SimulationAnalysisService : DTDFVocab:Service [
    base:desc "Service delivering simulation‑based analysis using behavioral and analytical models."
    DTDFVocab:provides PerformanceSimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service offering predictive analytics for forecasting building performance."
    DTDFVocab:provides EnergyForecastInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service executing optimization routines for energy and operational efficiency."
    DTDFVocab:provides EnergyOptimizationInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Service that supplies interactive visualization dashboards supporting decision‑making throughout the building lifecycle."
    DTDFVocab:provides InteractiveVisualizationInsight
]

// =============================
// Insights
// =============================

instance BuildingStateInsight : DTDFVocab:Insight [
    base:desc "Insight reflecting the current operational state of the building derived from live sensor streams."
]

instance PerformanceSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight generated from simulation runs indicating predicted performance under given scenarios."
]

instance EnergyForecastInsight : DTDFVocab:Insight [
    base:desc "Insight providing short‑term and long‑term energy consumption forecasts."
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending control set‑points and schedules to improve energy efficiency."
]

instance InteractiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight visualized on dashboards enabling operators to explore spatial and temporal building data."
]

// =============================
// Additional Action (example of automatic action)
// =============================

instance SetpointAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic action that adjusts HVAC set‑points based on optimization recommendations."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Through the same bidirectional data exchange, the digital twin can issue control commands to the physical building for monitoring and control. Facility managers interact with the deployed DT to send commands that affect physical devices. The document does not detail command formats, validation, authentication, feedback loops, conflict resolution or execution confirmation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a lifecycle comprising (1) device modeling within BIM where sensors, actuators, and controllers are added; (2) model enrichment and extraction using model‑driven engineering (MDE) to produce structured representations; (3) automatic generation of deployable DT artifacts; (4) deployment of the twin and establishment of real‑time data exchange for continuous synchronization; (5) runtime operation with interactive visualization; and (6) post‑deployment extension via standardized extension points for custom services. Transition between phases is managed automatically by the MDE pipeline, and lifecycle governance is assigned to the three actor roles—Building Control Engineer (modeling and control‑logic definition), Facility Manager (monitoring and operation), and DT Engineer (service integration)."
]