// C3: Physical Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors monitoring occupancy data within building spaces, integrated into BIM models for real-time environmental tracking."
    DTDFVocab:producedData OccupancyDataStream
]

instance EnvironmentalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors measuring temperature across building zones, providing real-time thermal data for control systems."
    DTDFVocab:producedData TemperatureDataStream
]

instance StructuralHealthSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors monitoring structural integrity parameters (e.g., vibration, strain) in critical building components."
    DTDFVocab:producedData StructuralHealthDataStream
]

instance HVACSystemSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors embedded in HVAC systems to track operational metrics (e.g., airflow, pressure, energy consumption)."
    DTDFVocab:producedData HVACSystemDataStream
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors measuring real-time energy consumption across building systems and zones."
    DTDFVocab:producedData EnergyConsumptionDataStream
]

// C4: Physical-to-Virtual Interaction (DataTransmitted)
instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    base:desc "Real-time occupancy data transmitted from physical sensors to the Digital Twin framework for synchronization."
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    base:desc "Continuous temperature readings from environmental sensors, synchronized bidirectionally with the Digital Twin."
    DTDFVocab:producedFrom EnvironmentalTemperatureSensor
]

instance StructuralHealthDataStream : DTDFVocab:DataTransmitted [
    base:desc "Structural health metrics transmitted in real-time to maintain dynamic alignment between physical and digital models."
    DTDFVocab:producedFrom StructuralHealthSensor
]

instance HVACSystemDataStream : DTDFVocab:DataTransmitted [
    base:desc "Telemetry data from HVAC components, including operational logs and performance metrics."
    DTDFVocab:producedFrom HVACSystemSensor
]

instance EnergyConsumptionDataStream : DTDFVocab:DataTransmitted [
    base:desc "High-frequency energy consumption data streamed to the Digital Twin for real-time monitoring and optimization."
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

// C10: Models/Data
instance BimGeometricModel : DTDFVocab:Model [
    base:desc "Static geometric representation of building structures derived from BIM, serving as the foundational spatial layer for the Digital Twin."
    DTDFVocab:inputTo ModelDrivenEngineeringFramework
]

instance BcsBehavioralModel : DTDFVocab:Model [
    base:desc "Dynamic behavioral models encoding control logic for Building Control Systems (BCS) components, defined within the BIM environment."
    DTDFVocab:inputTo ModelDrivenEngineeringFramework
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Deployable simulation models generated via MDE principles, enabling real-time operational predictions and scenario testing."
    DTDFVocab:inputTo ModelDrivenEngineeringFramework
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Structured occupancy data extracted from BIM and synchronized with real-time sensor streams for immersive visualization."
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo RealTimeDataSynchronizationEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Normalized temperature data integrated from physical sensors and BIM annotations, used for control logic validation."
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo RealTimeDataSynchronizationEnabler
]

instance StructuralHealthData : DTDFVocab:Data [
    base:desc "Processed structural health metrics combined with BIM structural models for predictive maintenance insights."
    DTDFVocab:fromData StructuralHealthDataStream
    DTDFVocab:inputTo RealTimeDataSynchronizationEnabler
]

instance HvacControlData : DTDFVocab:Data [
    base:desc "Operational data from HVAC systems, synchronized bidirectionally to enable real-time control adjustments."
    DTDFVocab:fromData HVACSystemDataStream
    DTDFVocab:inputTo RealTimeDataSynchronizationEnabler
]

instance EnergyOptimizationData : DTDFVocab:Data [
    base:desc "Aggregated energy consumption data used for real-time optimization and predictive analytics within the Digital Twin."
    DTDFVocab:fromData EnergyConsumptionDataStream
    DTDFVocab:inputTo RealTimeDataSynchronizationEnabler
]

// C11: Enablers
instance ModelDrivenEngineeringFramework : DTDFVocab:Enabler [
    base:desc "Core MDE framework automating the transformation of enriched BIM models into deployable Digital Twin artifacts with minimal manual intervention."
    DTDFVocab:enables BimToDtTransformationService, ControlLogicDeploymentService
]

instance RealTimeDataSynchronizationEnabler : DTDFVocab:Enabler [
    base:desc "Bidirectional synchronization mechanism ensuring operational parity between physical buildings and their Digital Twins via continuous data exchange."
    DTDFVocab:enables RealTimeMonitoringService, OperationalControlService
]

instance SemanticInteroperabilityEnabler : DTDFVocab:Enabler [
    base:desc "Unified semantic foundation enabling seamless transformations and integrations across BIM, BCS, and Digital Twin components."
    DTDFVocab:enables DeviceModelingService, DataVisualizationService
]

instance ModularArchitectureEnabler : DTDFVocab:Enabler [
    base:desc "Standardized extension points supporting plug-and-play integration of custom services, plugins, and analytics modules."
    DTDFVocab:enables CustomServiceDevelopmentService, PredictiveAnalyticsService
]

// C6: Services
instance DeviceModelingService : DTDFVocab:Service [
    base:desc "Service enabling Building Control Engineers to semantically model BCS components (sensors, actuators, controllers) within the BIM environment."
    DTDFVocab:provides DeviceConfigurationInsight, ControlLogicDefinitionAction
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous synchronization service ensuring real-time state mirroring between physical buildings and their Digital Twins."
    DTDFVocab:provides SystemStateInsight, OperationalAlertAction
]

instance OperationalControlService : DTDFVocab:Service [
    base:desc "Service allowing Facility Managers to interact with physical infrastructure through the Digital Twin for remote or automated control actions."
    DTDFVocab:provides ControlAuthorityInsight, ActuationCommandAction
]

instance CustomServiceDevelopmentService : DTDFVocab:Service [
    base:desc "Modular service enabling DT Engineers to integrate custom services, plugins, and analytics via standardized extension points."
    DTDFVocab:provides ServiceExtensionInsight, PluginIntegrationAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Analytics service supporting domain-specific applications like predictive maintenance and energy optimization."
    DTDFVocab:provides PredictiveMaintenanceInsight, EnergyOptimizationAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization service providing 3D BIM-based interfaces for monitoring and control."
    DTDFVocab:provides InteractiveDashboardInsight, VisualizationCustomizationAction
]

instance BimToDtTransformationService : DTDFVocab:Service [
    base:desc "Automated transformation pipeline converting enriched BIM models into deployable Digital Twin artifacts."
    DTDFVocab:provides ModelTransformationInsight, ArtifactDeploymentAction
]

instance ControlLogicDeploymentService : DTDFVocab:Service [
    base:desc "Service deploying control logic executables generated from behavioral models within the Digital Twin framework."
    DTDFVocab:provides LogicDeploymentInsight, ControlValidationAction
]

// C17: Insights/Actions
instance DeviceConfigurationInsight : DTDFVocab:Insight [
    base:desc "Semantic configuration details of BCS components, including device types, control parameters, and spatial relationships within BIM."
]

instance ControlLogicDefinitionAction : DTDFVocab:Action [
    base:desc "Definition of control logic (e.g., PID controllers, rule-based triggers) directly tied to physical assets within the Digital Twin."
    DTDFVocab:IsAutomatic false
]

instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Real-time operational state of the physical building, dynamically synchronized with the Digital Twin for monitoring purposes."
]

instance OperationalAlertAction : DTDFVocab:Action [
    base:desc "Automated alerts triggered by threshold breaches or scheduled maintenance events, ensuring proactive facility management."
    DTDFVocab:IsAutomatic true
]

instance ControlAuthorityInsight : DTDFVocab:Insight [
    base:desc "Facility Manager's operational authority over physical systems, mediated through the Digital Twin interface."
]

instance ActuationCommandAction : DTDFVocab:Action [
    base:desc "Remote or automated actuation commands (e.g., valve adjustments, thermostat setpoints) executed via the Digital Twin."
    DTDFVocab:IsAutomatic false
]

instance ServiceExtensionInsight : DTDFVocab:Insight [
    base:desc "Modular extension points available for integrating custom services, plugins, and analytics within the Digital Twin framework."
]

instance PluginIntegrationAction : DTDFVocab:Action [
    base:desc "Integration of third-party plugins or custom services into the Digital Twin's modular architecture."
    DTDFVocab:IsAutomatic false
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics identifying potential failures or maintenance needs based on real-time and historical data."
]

instance EnergyOptimizationAction : DTDFVocab:Action [
    base:desc "Automated energy optimization actions derived from real-time consumption data and predictive models."
    DTDFVocab:IsAutomatic true
]

instance InteractiveDashboardInsight : DTDFVocab:Insight [
    base:desc "Immersive 3D visualization of building operations, enabling spatial and operational awareness for Facility Managers."
]

instance VisualizationCustomizationAction : DTDFVocab:Action [
    base:desc "Customization of visualization interfaces to highlight specific operational metrics or control parameters."
    DTDFVocab:IsAutomatic false
]

instance ModelTransformationInsight : DTDFVocab:Insight [
    base:desc "Structured representations extracted from BIM via MDE, ensuring alignment between physical and digital assets."
]

instance ArtifactDeploymentAction : DTDFVocab:Action [
    base:desc "Automated deployment of Digital Twin artifacts (e.g., simulation models, control logic) to operational environments."
    DTDFVocab:IsAutomatic true
]

instance LogicDeploymentInsight : DTDFVocab:Insight [
    base:desc "Deployed control logic executables validated against behavioral models within the Digital Twin framework."
]

instance ControlValidationAction : DTDFVocab:Action [
    base:desc "Validation of control logic against real-time operational data to ensure system integrity."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "Motorized valve controlling airflow within HVAC systems, configured with PID controllers and safety constraints."
]

instance MotorizedDamperActuator : DTDFVocab:ActingComponent [
    base:desc "Adjustable damper for HVAC ductwork, enabling real-time modulation of airflow based on Digital Twin commands."
]

instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator managing motorized shades and lighting systems, integrated with occupancy and environmental sensors."
]

instance EmergencyProtocolActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator triggering emergency protocols (e.g., fire suppression, evacuation systems) based on Digital Twin alerts."
]

instance TemperatureControlActuator : DTDFVocab:ActingComponent [
    base:desc "Thermostat and HVAC system actuators adjusting heating/cooling setpoints in response to real-time data."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The **virtual-to-physical interaction** in this DT system enables **real-time control commands** from the digital twin to physical building systems, executed via the **DT Framework** as a central hub. Command types include **actuation signals (e.g., HVAC adjustments, lighting control, security system triggers)**, derived from **analytical insights or user inputs** (e.g., Facility Managers). Control messages are formatted to align with **standardized protocols** (unspecified but implied to be interoperable with building automation systems). **Validation and authentication mechanisms** ensure command integrity, though specifics (e.g., cryptographic methods, access controls) are not detailed. A **feedback system** provides confirmation of command execution (e.g., acknowledgment tokens, status updates) and resolves conflicts via **runtime configuration management**, allowing dynamic adjustments without redeployment. The system prioritizes **safety and reliability**, though explicit conflict resolution algorithms (e.g., priority-based arbitration) are not described."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system in the AECO domain follows a **cyber-physical information construct architecture**, integrating **static models** (e.g., BIM—Building Information Modeling) with **runtime data** to create a **virtual representation** of physical assets like buildings. The orchestration involves **carefully designed integration** of heterogeneous models and data sources, likely leveraging **service-oriented architectures (SOA)** or **microservices** to modularize components (e.g., simulation, analytics, and optimization modules). **Resource management** is implied to address the **fragmented nature of models and data**, requiring mechanisms like **data federation**, **ontology-based alignment**, or **semantic interoperability layers** (e.g., using standards like **IFC—Industry Foundation Classes** or **CityGML**) to ensure seamless coordination. System-wide coordination may rely on **event-driven architectures** or **publish-subscribe models** to propagate real-time updates across the constellation, though specific protocols (e.g., MQTT, OPC UA) are not mentioned. The document highlights the need for **tangible deployment strategies** to manage complexity, suggesting a **hybrid centralized-decentralized** approach where domain-specific twins operate autonomously while aligning under a unified governance framework."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin (DT) lifecycle in this model-driven deployment framework spans from **initial device modeling** to **custom DT service development**, addressing the gap between static BIM representations and dynamic DT requirements. Key phases include:
  1. **Device Modeling & Configuration**: Building Control Engineers define sensors, actuators, and controllers within the BIM environment, creating a **semantic foundation** for subsequent transformations (F_X requirements in Table III).
  2. **Model Transformation & Artifact Generation**: Leveraging **Model-Driven Engineering (MDE) principles**, the framework extracts structured representations from enriched BIM models and **automatically generates deployable DT artifacts** with minimal manual intervention.
  3. **DT Deployment & Synchronization**: Real-time data exchange ensures **continuous synchronization** between physical buildings and their digital counterparts, enabling dynamic updates.
  4. **Operational Monitoring & Control**: Facility Managers interact with the DT to monitor system states and operate physical infrastructure via the twin.
  5. **Custom Service Integration & Evolution**: DT Engineers extend functionality through **modular architecture** with standardized extension points, supporting **runtime customization** and analytics integration. The lifecycle is governed by a **use-case-driven approach** (Table II), ensuring alignment with stakeholder needs (Building Control Engineers, Facility Managers, DT Engineers)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin framework addresses **fidelity and validity** through a combination of **model-driven validation**, **real-time synchronization**, and **quality assurance processes**:
  - **Model fidelity requirements**: Achieved by enriching BIM’s static geometry with **dynamic BCS components** (sensors, actuators, controllers) via **semantic modeling**, ensuring the DT accurately represents physical behavior. The framework supports **complete lifecycle validation**, from initial device modeling to operational deployment.
  - **Validation and verification methods**: Leverages **Model-Driven Engineering (MDE)** to automate the transformation of BIM models into deployable DT artifacts, reducing manual errors. **Continuous synchronization** between physical and digital systems ensures data consistency.
  - **Uncertainty sources and quantification**: Not explicitly detailed in the document, but implied through the need for **real-time data exchange** to mitigate discrepancies between physical and digital states.
  - **Error detection and correction mechanisms**: Enabled by the DT’s **interactive visualization** layer, which allows **Facility Managers** to monitor system states and manually intervene if discrepancies arise. The **modular architecture** supports pluggable analytics for anomaly detection (e.g., sensor drift, control logic failures).
  - **Quality assurance processes**: Embedded in the **functional requirements (F_X)** of the framework, ensuring that DT artifacts meet operational standards before deployment. The **standardized extension points** for custom services also enforce modular validation, where third-party plugins must adhere to predefined interfaces for integration."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for this DT system is designed to support **interoperability across heterogeneous systems** and **scalability** from individual components to entire infrastructure networks. The architecture leverages a **modular, service-oriented topology** with **standardized extension points** for seamless integration of custom services. Communication protocols are not explicitly named but must adhere to **real-time data exchange requirements**, implying low-latency, high-bandwidth connections (e.g., MQTT, OPC UA, or proprietary protocols). **Reliability and redundancy mechanisms** are inferred from the framework’s emphasis on **low-overhead maintainability** and **runtime adaptability**, though specifics (e.g., failover clusters, message queuing) are absent. **Security protocols** are critical but not detailed; the system prioritizes **accessibility for users with varying technical expertise**, suggesting role-based access controls (RBAC) or similar mechanisms. The network must accommodate **bidirectional, high-frequency data flows** between physical devices and the DT Framework."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **deployment infrastructure** for this DT system is **modular and adaptable**, supporting **cloud, edge, and on-premise hosting models** to align with operational needs. Computational requirements are driven by **real-time analytics, immersive visualization, and service integration**, necessitating scalable resources (e.g., containerized microservices, distributed databases). **Scalability mechanisms** include **runtime configuration management**, enabling adjustments without full redeployment, and **standardized extension points** for modular service addition. Storage requirements are implied to be **high-capacity and low-latency**, accommodating enriched BIM models and operational data. **Availability/reliability assurance** is achieved through the framework’s **low-overhead maintainability** and **interoperability** across heterogeneous systems, though explicit redundancy strategies (e.g., multi-region replication) are not specified. The system supports **life-cycle management** from BIM model enrichment to operational DT deployment, with *Building Control Engineers* initiating deployment via BIM tools and *Facility Managers* interacting with the live system."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system in the AECO domain requires **horizontal integration** with **external systems** to overcome the **fragmented nature of models and data**, leveraging **interoperability standards** and **data exchange protocols** for seamless collaboration. Key integration patterns include:
  1. **Enterprise Systems**: Integration with **ERP (Enterprise Resource Planning)**, **CMMS (Computerized Maintenance Management Systems)**, or **facility management platforms** via **APIs** or **standardized data formats** (e.g., **IFC, COBie, or JSON/XML schemas**) to ensure bidirectional data flow.
  2. **Domain-Specific Tools**: Connection to **BIM tools** (e.g., Revit, ArchiCAD), **IoT sensors**, and **simulation engines** (e.g., EnergyPlus, ANSYS) using **open protocols** like **OPC UA** or **MQTT** for real-time data ingestion.
  3. **Cross-DT Collaboration**: Interoperability with **other Digital Twins** (e.g., twins for adjacent buildings, smart grids, or urban infrastructure) through **semantic web technologies** (e.g., **RDF/OWL ontologies**) or **federated data models** to enable **predictive analytics** and **cross-domain optimization**.
  Dependencies on external systems are critical, as the document emphasizes that **real-time insights** and **decision-making** rely on **heterogeneous data sources**. However, specific protocols or technologies for integration are not detailed, though the context implies adherence to **AECO-specific standards** (e.g., **ISO 19650**, **buildingSMART**) to ensure compatibility."
]