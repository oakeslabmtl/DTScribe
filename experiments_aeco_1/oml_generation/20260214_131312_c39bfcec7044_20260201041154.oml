// Sensing component: Real‑time temperature sensor collecting building data
instance ZoneTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Real‑time temperature sensor providing sensor data updates from building sensors."
    DTDFVocab:producedData ZoneTemperatureDataTransmitted
]

// Data transmitted from the sensor over Hono MQTT‑like bus
instance ZoneTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ZoneTemperatureSensor
]

// Dataset consumed by services
instance ZoneTemperatureData : DTDFVocab:Data [
    base:desc "Temperature data stream used by digital twin services for monitoring and control."
    DTDFVocab:fromData ZoneTemperatureDataTransmitted
    DTDFVocab:inputTo MDEExtractionEnabler
]

// Model: Geometric representation extracted from BIM
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Geometric representation extracted from BIM files for virtual building layout."
    DTDFVocab:inputTo DittoIntegrationEnabler
]

// Model: Behavioral logic defined by Building Control Engineer
instance ControlLogicBehaviorModel : DTDFVocab:Model [
    base:desc "Control logic behavior model extracted from BIM files, defining closed‑loop rules."
    DTDFVocab:inputTo DittoIntegrationEnabler
]

// Model: Live simulation artifacts for Unreal Engine 5
instance UESimulationModel : DTDFVocab:Model [
    base:desc "Dynamic digital twin artifacts generated for live simulation in Unreal Engine 5."
    DTDFVocab:inputTo DittoIntegrationEnabler
]

// Enabler: Model‑Driven Engineering extraction pipeline
instance MDEExtractionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that transforms enriched BIM models into deployable digital twin artifacts."
    DTDFVocab:enables MonitoringService, ControlService
]

// Enabler: Eclipse Ditto integration for event storing and state sync
instance DittoIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that integrates Eclipse Ditto for persistent event streams and state synchronization."
    DTDFVocab:enables MonitoringService, ControlService, OptimizationService, PredictionService, VisualizationService
]

// Enabler: Eclipse Hono MQTT‑like message bus for real‑time command ingestion
instance HonoMessagingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that uses Eclipse Hono for at‑least‑once message bus facilitating real‑time actuator command ingestion."
    DTDFVocab:enables ControlService
]

// Service: Monitoring of physical states
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous real‑time monitoring of physical states via sensor data streams."
    DTDFVocab:provides EfficiencyMetricInsight, CostPredictionInsight, SafetyComplianceInsight
]

// Service: Control of actuators and controllers
instance ControlService : DTDFVocab:Service [
    base:desc "Closed‑loop control service issuing commands to actuators defined in BIM."
    DTDFVocab:provides AdjustLightCommand, TuneHVACCommand
]

// Service: Optimization of HVAC, lighting, and energy schedules
instance OptimizationService : DTDFVocab:Service [
    base:desc "Data‑driven tuning of HVAC, lighting, and energy schedules based on real‑time and historical data."
    DTDFVocab:provides CostPredictionInsight
]

// Service: Prediction of system behavior and failure modes
instance PredictionService : DTDFVocab:Service [
    base:desc "Short‑term forecasting of system behavior and failure modes for proactive maintenance."
    DTDFVocab:provides SafetyComplianceInsight
]

// Service: Immersive BIM‑based 3D visualization
instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D display of current status and simulation results using UE5."
    DTDFVocab:provides EfficiencyMetricInsight
]

// Insight: Efficiency metric derived from monitoring data
instance EfficiencyMetricInsight : DTDFVocab:Insight [
    base:desc "Metric indicating lighting and HVAC energy efficiency derived from real‑time sensor data."
]

// Insight: Cost prediction based on operational data
instance CostPredictionInsight : DTDFVocab:Insight [
    base:desc "Prediction of operational costs based on temperature and HVAC usage trends."
]

// Insight: Safety compliance status
instance SafetyComplianceInsight : DTDFVocab:Insight [
    base:desc "Assessment of building safety compliance derived from sensor and control data."
]

// Action: Adjust light parameters via LightTwinComponent
instance AdjustLightCommand : DTDFVocab:Action [
    base:desc "Command to toggle, adjust brightness, or change color temperature of a UE5 light source via LightTwinComponent."
    DTDFVocab:IsAutomatic false
]

// Action: Tune HVAC system based on control logic
instance TuneHVACCommand : DTDFVocab:Action [
    base:desc "Command to adjust HVAC setpoints for demand‑controlled ventilation using ControlLogicBehaviorModel."
    DTDFVocab:IsAutomatic false
]

// Acting component: LightTwinComponent controlling UE5 light
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "LightTwinComponent controls a UE5 light source using Revit photometric values supplied in BIM metadata. Supports on/off toggling, brightness adjustment, and colour temperature changes, all driven by messages brokered by UnrealTwinController via DittoController and DittoConnection. Dismisses unsafe operations through Eclipse Ditto policy rules."
]

// Environment representing the office building
instance OfficeBuildingEnvironment : DTDFVocab:Environment [
    base:desc "Commercial office building equipped with a Building Control System integrated into the BIM."
    base:contains ZoneTemperatureSensor, BuildingControlSystemComponent, LightTwinComponent
]

// Component: Building Control System
instance BuildingControlSystemComponent : DTDFVocab:Component [
    base:desc "Building Control System (BCS) comprising embedded sensors, actuators, and controllers integrated into the BIM."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time continuous synchronization between the physical building and its digital twin via continuous data exchange; latency requirements and temporal granularity are not specified in the provided documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is organized around a modular architecture with a central DT framework hub that mediates bidirectional data exchange. Roles such as Building Control Engineers (device modelling and deployment initiation), Facility Managers (real‑time monitoring and control), and DT Engineers (service integration) coordinate through standardized extension points, allowing the framework to incorporate custom services and analytics while maintaining a holistic lifecycle perspective from enriched BIM models to operational DTs."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a Digital‑Twin lifecycle that begins with Building Control Engineers enriching BIM models on which devices (sensors, actuators, controllers) and control logic are defined. Enriched BIM models are processed by a Model‑Driven Engineering (MDE) pipeline that extracts a semantic representation and automatically generates deployable Digital‑Twin artifacts (configuration bundles, runtime services) with minimal manual intervention. These artifacts are deployed into a runtime environment where the twin is synchronized with the physical building via real‑time data exchange. The framework’s modular architecture provides standardized extension points that allow DT Engineers to attach custom services, thereby enabling iterative evolution of the twin. Each lifecycle stage is clearly separated—modeling, transformation, deployment, runtime operation—to support governance and traceability."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validity is ensured by Eclipse Ditto’s policy‑based validation, which enforces sensor data ranges, units, and pre‑execution checks on actuator commands. Fault tolerance and data integrity are achieved through Hono’s at‑least‑once message delivery and Ditto’s persistent event storage, preserving message history across network failures. Validation processes include automatic checks during the conversion phase of enriched BIM models and runtime verification against defined policies, providing continuous assurance of data quality and model consistency."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework aligns with AECO‑centric BIM standards (Revit/IFC‑based BIM) for device and control logic definition. It adopts open telemetry standards for real‑time data exchange and leverages recognized open‑source Digital‑Twin platforms such as Eclipse Ditto and BaSyx to provide connectivity and standard compliance, thereby ensuring interoperability across heterogeneous building assets."
]