instance AECOBuildingSystem : DTDFVocab:Environment [
    base:desc "Infrastructure assets in the Architecture, Engineering, Construction, and Operations (AECO) domain, specifically buildings, characterized by integration of static models with real-time operational data to enable simulation, analysis, and optimization across the entire building lifecycle from design to operation phases."
    base:contains BCSSensor, BCSActuator, BIMEnrichedModel
]

instance BCSSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors defined by Building Control Engineers in BIM, with endpoint addresses extracted as metadata for device addressing. Data collection involves real-time transmission of sensor readings via standardized protocols."
]

instance BCSRealTimeData : DTDFVocab:DataTransmitted [
    base:desc "Real-time sensor readings from Building Control System components"
]

instance BCSRealTimeDataInstance : DTDFVocab:Data [
    base:desc "Real-time sensor readings from Building Control System components"
]

instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "BIM-based geometric models enriched with Building Control System (BCS) components (sensors, actuators, controllers) defined by Building Control Engineers"
]

instance BCSActuator : DTDFVocab:ActingComponent [
    base:desc "Actuators modeled by Building Control Engineers within BIM, with endpoint addresses extracted as metadata during MDE-based transformation. These addresses enable precise addressing and remote control of physical actuators through standardized communication protocols."
]

instance MDETransformation : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering (MDE) principles to extract structured representations from enriched BIM models and generate deployable Digital Twin artifacts with minimal manual intervention modular architecture with standardized extension points for integrating custom services and analytics enabling adaptation to operational changes"
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Interactive visualization tools for immersive monitoring and control interfaces"
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring insights for building operations"
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for maintenance and operational optimization"
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation capabilities for building performance analysis"
]

instance AnalysisService : DTDFVocab:Service [
    base:desc "Analysis capabilities for infrastructure management"
]

instance DecisionMakingService : DTDFVocab:Service [
    base:desc "Enhanced decision-making capabilities for data-driven infrastructure management, including remote actuator control"
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization providing immersive interfaces for monitoring and control"
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of building systems for operational oversight"
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive insights for maintenance scheduling and fault detection"
]

instance OperationalOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insights for optimizing building operations and energy usage"
]

instance BuildingSimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results for building performance under various scenarios"
]

instance InfrastructureAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analysis of infrastructure health and performance metrics"
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Data-driven insights supporting facility management decisions"
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive visualization for real-time building monitoring and control"
]

instance RemoteControlAction : DTDFVocab:Action [
    base:desc "Precise addressing and remote control of physical actuators through standardized communication protocols"
]

instance DTFramework : DTDFVocab:Enabler [
    base:desc "Facilitates bidirectional data exchange between physical buildings and digital counterparts for synchronization"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system employs real-time monitoring and live synchronization between physical assets and their digital counterparts, with continuous data exchange to support immediate insights and decision-making."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated via a model-driven framework with modular architecture, integrating Eclipse Hono and Ditto for IoT data management and leveraging Unreal Engine for high-fidelity visualization to ensure seamless component integration and system-wide coordination."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle encompasses initial device modeling within BIM environments by Building Control Engineers, Model-Driven Engineering (MDE) transformation to generate deployable artifacts, real-time data exchange for synchronization with physical systems, interactive visualization for Facility Manager operations, and evolution through DT Engineers integrating custom services via modular extensions. Lifecycle governance is structured across stakeholder roles with automated phase transitions."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Modular architecture with standardized extension points supports integration of custom services and analytics, enabling DTs to evolve with changing operational requirements. Runtime configuration management allows adjustments without requiring full redeployment, addressing scalability from individual components to entire infrastructure systems and maintainability through low-overhead updates."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integrates external systems through standardized frameworks, enabling bidirectional communication between virtual and physical assets using Eclipse Hono and Ditto for real-time data exchange and interoperability with enterprise systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework implements a modular architecture with standardized extension points to enable integration of custom services and analytics, though no specific industry standards, compliance frameworks, or interoperability specifications are detailed in the document."
]