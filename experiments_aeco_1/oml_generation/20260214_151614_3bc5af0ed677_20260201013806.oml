// C3: Physical Sensing Components
instance PermafrostTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "IoT temperature sensor deployed in building infrastructure that collects real-time environmental conditions and transmits data via standardized middleware protocols. Automatically extracts metadata (e.g., device IDs) from BIM model for seamless integration."
    DTDFVocab:producedData PermafrostTemperatureDataTransmitted
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "IoT occupancy detector that monitors human presence in building spaces and transmits occupancy status data to the DT via bidirectional communication channels."
    DTDFVocab:producedData OccupancyStatusDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "IoT light sensor measuring ambient light levels within building spaces, providing data for visual comfort optimization and energy management."
    DTDFVocab:producedData LightLevelDataTransmitted
]

instance EnergyConsumptionMeter : DTDFVocab:SensingComponent [
    base:desc "IoT energy consumption meter tracking real-time energy usage across building systems, enabling operational efficiency analysis and predictive analytics."
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

// C4: Data Transmitted
instance PermafrostTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PermafrostTemperatureSensor
]

instance OccupancyStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionMeter
]

// C10: Models/Data
instance BuildingInformationModel : DTDFVocab:Model [
    base:desc "Semantic-rich 3D BIM model representing building geometry, topology, and component relationships serving as the semantic backbone for the DT."
    DTDFVocab:inputTo BimToRuntimeTransformer
]

instance RuntimeOperationalData : DTDFVocab:Data [
    base:desc "Dynamic operational data including sensor readings, control signals, and runtime configurations ingested via Eclipse Hono/Ditto middleware."
    DTDFVocab:fromData PermafrostTemperatureDataTransmitted, OccupancyStatusDataTransmitted, LightLevelDataTransmitted, EnergyConsumptionDataTransmitted
    DTDFVocab:inputTo DataProcessingEngine, VisualizationEngine
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "BIM-defined control logic models (e.g., TwinLight lighting policies) transformed into executable artifacts for adaptive building control."
    DTDFVocab:inputTo ControlLogicExecutor
]

instance PredictiveSimulationModel : DTDFVocab:Model [
    base:desc "Simulation models used for forecasting energy consumption, maintenance needs, and operational efficiency based on historical and real-time data."
    DTDFVocab:inputTo AnalyticsEngine
]

instance UnrealEngineVisualizationAssets : DTDFVocab:Model [
    base:desc "Interactive 3D visualization assets in Unreal Engine 5 enabling immersive monitoring and control of building operations."
    DTDFVocab:inputTo VisualizationEngine
]

// C11: Enablers
instance EclipseHonoMiddleware : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware platform facilitating real-time bidirectional data exchange between IoT sensors and the DT, with automated metadata extraction from BIM."
    DTDFVocab:enables RealTimeDataIngestionService, DeviceConfigurationService
]

instance EclipseDittoMiddleware : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto middleware enabling device twin management and bidirectional communication between physical and virtual components with model-driven transformations."
    DTDFVocab:enables TwinSynchronizationService
]

instance BimToRuntimeTransformer : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering tool transforming BIM models into runtime artifacts through model-to-model and model-to-text techniques."
    DTDFVocab:enables DeviceModelingService
]

instance DataProcessingEngine : DTDFVocab:Enabler [
    base:desc "Runtime engine processing ingested sensor data through automated synchronization and model-driven transformations to maintain consistency between physical and virtual states."
    DTDFVocab:enables OperationalEfficiencyService, PredictiveAnalyticsService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5-based visualization engine providing immersive 3D interaction with building data for monitoring and control."
    DTDFVocab:enables ImmersiveMonitoringService, StakeholderCollaborationService
]

instance ControlLogicExecutor : DTDFVocab:Enabler [
    base:desc "Runtime environment executing control logic policies including reinforcement learning-based adaptive control (e.g., BOREALIS lighting optimization)."
    DTDFVocab:enables AutomatedCommissioningService
]

instance AnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Predictive analytics engine processing historical and real-time data to generate optimization recommendations and maintenance forecasts."
    DTDFVocab:enables OptimizationRecommendationService
]

// C6: Services
instance RealTimeDataIngestionService : DTDFVocab:Service [
    base:desc "Service ingesting real-time sensor data from physical components via Eclipse Hono middleware and synchronizing with virtual representations."
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance TwinSynchronizationService : DTDFVocab:Service [
    base:desc "Service maintaining bidirectional synchronization between physical states and virtual twins through automated model-driven transformations."
    DTDFVocab:provides EntanglementValidationAction
]

instance OperationalEfficiencyService : DTDFVocab:Service [
    base:desc "Service analyzing real-time energy consumption, occupancy patterns, and environmental conditions to provide operational efficiency metrics."
    DTDFVocab:provides OperationalEfficiencyInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service forecasting maintenance needs and energy savings based on historical data patterns and predictive simulation models."
    DTDFVocab:provides PredictiveMaintenanceInsight, EnergySavingsInsight
]

instance OptimizationRecommendationService : DTDFVocab:Service [
    base:desc "Service generating adaptive control policies (e.g., lighting schedules, HVAC setpoints) for visual comfort and energy savings optimization."
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance ImmersiveMonitoringService : DTDFVocab:Service [
    base:desc "Service providing 3D immersive visualization of building operations through Unreal Engine 5 for facility managers."
    DTDFVocab:provides VisualComfortInsight
]

instance StakeholderCollaborationService : DTDFVocab:Service [
    base:desc "Service enabling facility managers to monitor and adjust building operations through interactive visualization interfaces."
    DTDFVocab:provides OperationalControlAction
]

instance AutomatedCommissioningService : DTDFVocab:Service [
    base:desc "Service executing automated commissioning procedures and control logic execution including reinforcement learning-based policies."
    DTDFVocab:provides ControlSignalAction
]

instance DeviceConfigurationService : DTDFVocab:Service [
    base:desc "Service managing device configurations (e.g., tenant IDs, device endpoints) extracted from BIM and deployed to runtime environment."
    DTDFVocab:provides DeviceConfigurationAction
]

// C17: Insights/Actions
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of current building operational states including temperature, occupancy, and energy consumption metrics."
]

instance OperationalEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Comprehensive metrics on operational efficiency including energy consumption patterns, occupancy utilization, and environmental condition trends."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Forecasted maintenance requirements based on historical data analysis and degradation pattern recognition."
]

instance EnergySavingsInsight : DTDFVocab:Insight [
    base:desc "Predicted energy savings potential through optimized control policies and operational adjustments."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Adaptive control policy suggestions for improving visual comfort while maintaining energy efficiency targets."
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Analysis of visual comfort conditions based on lighting levels and occupancy patterns to inform control decisions."
]

instance EntanglementValidationAction : DTDFVocab:Action [
    base:desc "Automated validation of physical-virtual synchronization using Overall Digital Twin Entanglement (ODTE) metric to assess fidelity."
    DTDFVocab:IsAutomatic true
]

instance OperationalControlAction : DTDFVocab:Action [
    base:desc "Facility manager adjustments to building operations based on visualization insights (e.g., manual override of control policies)."
    DTDFVocab:IsAutomatic false
]

instance ControlSignalAction : DTDFVocab:Action [
    base:desc "Execution of control signals to physical actuators (e.g., lighting adjustment, HVAC setpoint modification) based on virtual analysis."
    DTDFVocab:IsAutomatic true
]

instance DeviceConfigurationAction : DTDFVocab:Action [
    base:desc "Dynamic deployment of device configurations (e.g., tenant-specific settings, control logic parameters) to physical components."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Building Control System actuator controlling lighting levels based on virtual analysis and reinforcement learning policies (e.g., BOREALIS adaptive lighting)."
]

instance HVACController : DTDFVocab:ActingComponent [
    base:desc "Building Control System controller adjusting HVAC setpoints to optimize energy efficiency while maintaining comfort conditions."
]

// C1: Physical Environment
instance BuildingInfrastructure : DTDFVocab:Environment [
    base:desc "Physical building infrastructure including HVAC systems, lighting networks, and sensor networks that interact with the digital twin."
    base:contains LightingActuator, HVACController, PermafrostTemperatureSensor, OccupancyDetector, LightLevelSensor, EnergyConsumptionMeter
]

// C5: Component Relationships
instance LightingSubsystem : DTDFVocab:Component [
    base:desc "Building subsystem responsible for lighting control including sensors, actuators, and control logic for visual comfort optimization."
    base:contains LightingActuator, LightLevelSensor
    base:isContainedIn BuildingInfrastructure
]

instance HVACSubsystem : DTDFVocab:Component [
    base:desc "Building subsystem managing heating, ventilation, and air conditioning including temperature sensors and control actuators."
    base:contains HVACController, PermafrostTemperatureSensor
    base:isContainedIn BuildingInfrastructure
]

instance EnergyManagementSubsystem : DTDFVocab:Component [
    base:desc "Building subsystem tracking and optimizing energy consumption across all building systems."
    base:contains EnergyConsumptionMeter
    base:isContainedIn BuildingInfrastructure
]

instance OccupancyManagementSubsystem : DTDFVocab:Component [
    base:desc "Building subsystem monitoring occupancy patterns to inform operational decisions and energy management."
    base:contains OccupancyDetector
    base:isContainedIn BuildingInfrastructure
]

// Added missing DeviceModelingService instance
instance DeviceModelingService : DTDFVocab:Service [
    base:desc "Service responsible for modeling physical devices based on BIM metadata and transforming them into runtime artifacts for the digital twin."
    DTDFVocab:provides DeviceModelingInsight
]

instance DeviceModelingInsight : DTDFVocab:Insight [
    base:desc "Insight providing validation of device models and their synchronization with physical components."
]

instance BuildingSystem : DTDFVocab:SystemUnderStudy [
    base:desc "Building Infrastructure Digital Twin system representing the entire building infrastructure."
    DTDFVocab:hasEnvironment BuildingInfrastructure
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Virtual-to-physical interaction occurs via **control signals** generated by the DT and transmitted back to the physical system through actuators and controllers. These signals are derived from virtual simulations, optimization algorithms, or user-defined control logic (e.g., adaptive lighting policies). The framework supports **bidirectional communication** using middleware (Eclipse Hono/Ditto) to execute commands on physical devices, ensuring real-time adjustments to operational parameters (e.g., adjusting HVAC setpoints or lighting schedules)."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twinning time scale spans from **near-real-time synchronization** (milliseconds to seconds for critical control loops) to **life-cycle optimization** (hours to years for strategic decision-making). The DT supports **real-time data exchange** for operational monitoring and control (e.g., adaptive lighting adjustments), while also enabling **long-term analytics** for performance trends, predictive maintenance, and lifecycle planning. The framework ensures that time-sensitive interactions (e.g., sensor-to-DT data ingestion) occur with minimal latency, while non-critical services (e.g., historical trend analysis) operate on broader time horizons."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated as a **service-oriented architecture** with the following components:
   - **BIM Core**: The semantic foundation for device modeling and control logic.
   - **Middleware Layer**: Eclipse Hono/Ditto for data ingestion, processing, and actuation.
   - **Visualization Layer**: Unreal Engine 5 for user interaction.
   - **Service Layer**: Modular plugins (e.g., energy optimization, reinforcement learning) connected via standardized APIs.
   The constellation supports **scalable deployment** across building infrastructures, with **bidirectional data flows** ensuring synchronization between virtual and physical systems."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans **multiple lifecycle stages**, including:
   - **Design phase**: Integration of BIM models with device configurations and control logic.
   - **Construction phase**: Validation and deployment of DT artifacts (e.g., runtime interfaces, visualization assets).
   - **Operation phase**: Real-time monitoring, optimization, and adaptive control (e.g., reinforcement learning in BOREALIS).
   - **Maintenance/Adaptation phase**: Continuous updates to models and services (e.g., adding new sensors or control policies).
   The DT covers representations from **as-designed (ideal)** to **as-operated**, ensuring alignment with physical changes over time."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
   - **Model validation**: Verification of BIM models against physical assets (e.g., device configurations).
   - **Real-time synchronization**: Continuous alignment of virtual and physical states via middleware (Hono/Ditto).
   - **ODTE metric**: Quantitative assessment of twin fidelity, measuring the degree of synchronization between PT and DT.
   - **Uncertainty handling**: Addressed via adaptive control policies (e.g., reinforcement learning in BOREALIS) to mitigate semantic drift over time. Validation mechanisms include **post-occupancy sensor data** for refining control logic."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Technical connections include:
    - **Middleware-based communication** (Eclipse Hono/Ditto) for real-time data exchange between PT and DT.
    - **Standardized protocols** (e.g., for sensor/actuator integration) to ensure interoperability.
    - **Bidirectional APIs** for seamless interaction between virtual and physical systems."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin is deployed using a **modular, scalable architecture** that supports both **on-premise** and **cloud-based** hosting configurations, though explicit details (e.g., cloud-edge hybrid) are not provided in the document. The framework emphasizes:
   - **Scalable Deployment**: Modular design allows the DT to scale from individual components to entire infrastructure systems.
   - **Middleware-Based Orchestration**: **Eclipse Hono/Ditto** enable distributed deployment of DT services across heterogeneous environments.
   - **Low-Overhead Updates**: Runtime configuration management allows dynamic adjustments without full redeployment, ensuring maintainability and adaptability. The deployment strategy prioritizes **interoperability** and **extensibility** to accommodate evolving operational requirements."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin framework supports **horizontal integration** through:
   - **Standardized Middleware (Eclipse Hono/Ditto)**: Enables seamless communication with external IoT platforms, third-party analytics tools, or other Digital Twins by adhering to open standards.
   - **Modular Service Architecture**: Standardized extension points allow integration with external systems (e.g., ERP, CMMS) via APIs or middleware bridges.
   - **BIM-Centric Data Exchange**: Facilitates interoperability with other AECO tools (e.g., CAD, project management software) through shared data schemas derived from BIM models. However, explicit mention of integration with **external IoT platforms, third-party analytics, or other DTs** is not detailed in the provided documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin framework adheres to the following standards and practices:
   - **Building Information Modeling (BIM)**: Serves as the foundational semantic framework for modeling and integrating building data.
   - **Middleware Standards**: Leverages **Eclipse Hono** and **Ditto** for real-time data exchange, which comply with open-source and industry-standard protocols (e.g., MQTT-like interfaces, though not explicitly named).
   - **Model-Driven Engineering (MDE)**: Uses standardized modeling methodologies to ensure consistency and interoperability across deployment pipelines.
   - **Extension Points**: Follows a **service-oriented architecture** with well-defined interfaces for modular integration, though specific standards (e.g., IFC, COBie, OPC UA) are not explicitly referenced in the document. The framework prioritizes **scalability** and **interoperability** to align with AECO-specific workflows."
]