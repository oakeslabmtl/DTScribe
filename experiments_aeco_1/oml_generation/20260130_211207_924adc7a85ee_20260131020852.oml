// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in the BIM environment to capture space usage in the building"
    DTDFVocab:producedData OccupancyDataTransmission
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor modeled in the BIM environment to measure lighting levels in rooms"
    DTDFVocab:producedData IlluminationDataTransmission
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in the BIM environment to monitor indoor air temperature"
    DTDFVocab:producedData TemperatureDataTransmission
]

// C4: Physical-to-virtual interaction – data transmitted
instance OccupancyDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance TemperatureDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C10: Data generated from transmissions
instance OccupancyLiveData : DTDFVocab:Data [
    base:desc "Live occupancy measurement stream flowing from the physical building into the twin"
    DTDFVocab:fromData OccupancyDataTransmission
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance IlluminationLiveData : DTDFVocab:Data [
    base:desc "Live illumination measurement stream flowing from the physical building into the twin"
    DTDFVocab:fromData IlluminationDataTransmission
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance TemperatureLiveData : DTDFVocab:Data [
    base:desc "Live temperature measurement stream flowing from the physical building into the twin"
    DTDFVocab:fromData TemperatureDataTransmission
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// C2: Acting components
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator defined in the BIM model to switch lighting zones on/off via commands from the twin"
]

instance LightingControlController : DTDFVocab:ActingComponent [
    base:desc "Controller defined in the BIM model that implements lighting control logic and receives set‑points from the twin"
]

// C10: Models / Data (static and simulation)
instance BaseBIMModel : DTDFVocab:Model [
    base:desc "Base BIM model supplying geometric, spatial and functional data of the building"
    DTDFVocab:inputTo BIMEnabler
]

instance EnrichedRuntimeSemanticsModel : DTDFVocab:Model [
    base:desc "BIM model enriched with sensor configurations and control logic for runtime execution"
    DTDFVocab:inputTo ModelDrivenEngineeringEnabler
]

instance BuildingPerformanceSimulationModel : DTDFVocab:Model [
    base:desc "Thermal and energy performance simulation model generated at runtime for predictive analytics"
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance LifeCycleOptimizationModel : DTDFVocab:Model [
    base:desc "Life‑cycle optimisation model (energy minimisation, comfort optimisation) used for decision support"
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C11: Enablers / tooling
instance BIMEnabler : DTDFVocab:Enabler [
    base:desc "Building Information Modeling (BIM) platform serving as the semantic backbone of the twin"
    DTDFVocab:enables RealTimeMonitoringService, InteractiveVisualizationService
]

instance ModelDrivenEngineeringEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline that automatically generates runtime artifacts from enriched BIM"
    DTDFVocab:enables BuildingPerformanceSimulationService, LifeCycleOptimizationService
]

instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono component ingesting device telemetry (sensor measurements) from the physical building"
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin platform handling digital representations and event processing"
    DTDFVocab:enables RealTimeMonitoringService, InteractiveVisualizationService, BuildingPerformanceSimulationService, LifeCycleOptimizationService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 providing immersive 3‑D visualization of the building twin for facility managers"
    DTDFVocab:enables InteractiveVisualizationService
]

// C6: Services offered by the twin
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring service delivering live status of occupancy, illumination and temperature"
    DTDFVocab:provides RealTimeInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3‑D visualization (Unreal Engine 5) enabling users to explore building state in VR/AR"
    DTDFVocab:provides RealTimeInsight
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation service that predicts building energy performance and comfort based on live data"
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance LifeCycleOptimizationService : DTDFVocab:Service [
    base:desc "Life‑cycle optimisation service that suggests energy‑saving and comfort‑adjustment actions"
    DTDFVocab:provides OptimizationRecommendationInsight, EnergySavingAction, ComfortAdjustmentAction
]

// C17: Insights generated by services
instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight showing current occupancy, lighting level and temperature conditions"
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics insight forecasting future energy consumption and occupant comfort"
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimisation recommendation insight offering actionable measures for energy reduction and comfort improvement"
]

// C17: Actions derived from insights
instance EnergySavingAction : DTDFVocab:Action [
    base:desc "Automatic action to dim lighting or adjust HVAC set‑points to reduce energy use"
    DTDFVocab:IsAutomatic true
]

instance ComfortAdjustmentAction : DTDFVocab:Action [
    base:desc "Manual or semi‑automatic action prompting facility managers to adjust temperature or lighting for occupant comfort"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command transmission from the Digital Twin to physical actuators/controllers through the same Hono/Ditto middleware, enabling runtime control actions such as lighting adjustments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (continuous) synchronization between physical sensors/actuators and the Digital Twin, supporting immediate feedback loops for monitoring and control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized DT framework that aggregates enriched BIM data, connects physical devices via Hono/Ditto, hosts simulation and optimisation services, and delivers visualization through Unreal Engine, orchestrating the full set of twins and services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin spans the building life‑cycle phases addressed in the paper: design (BIM authoring), construction, and operation (runtime monitoring and optimisation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is employed to assess how well the Digital Twin reflects its physical counterpart, providing a quantitative measure of interoperability and architectural soundness."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time connectivity is achieved through Eclipse Hono (device ingestion) coupled with Eclipse Ditto (digital twin representation), forming the communication backbone between physical assets and the Digital Twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is grounded in BIM standards for building data representation and leverages the ODTE metric for standardized evaluation of twin fidelity."
]