// C3: Physical Sensing Components
instance CarbonDioxideSensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled CO2 sensor for real-time indoor air quality monitoring in academic buildings, integrated via BACnet/MS-TP networks"
    DTDFVocab:producedData IndoorAirQualityDataTransmitted
]

instance ParticulateMatterSensor : DTDFVocab:SensingComponent [
    base:desc "PM2.5/PM10 particulate matter sensor for indoor environmental quality monitoring, connected via LoRaWAN for long-range coverage"
    DTDFVocab:producedData IndoorAirQualityDataTransmitted
]

instance TemperatureHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Combined temperature and humidity sensor for thermal comfort monitoring, integrated with building automation systems via BACnet"
    DTDFVocab:producedData EnvironmentalConditionDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "PIR-based occupancy sensor for space utilization tracking, providing real-time occupancy data for adaptive control systems"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightingLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Lux meter for indoor lighting level monitoring, enabling daylight harvesting and energy optimization"
    DTDFVocab:producedData LightingConditionDataTransmitted
]

instance HVACPerformanceSensor : DTDFVocab:SensingComponent [
    base:desc "Comprehensive HVAC system sensor suite monitoring chiller performance, airflow rates, and system pressures via Modbus protocol"
    DTDFVocab:producedData HVACSystemDataTransmitted
]

instance StructuralHealthSensor : DTDFVocab:SensingComponent [
    base:desc "Vibration and strain sensors for structural health monitoring of civil infrastructure assets, integrated with BIM models"
    DTDFVocab:producedData StructuralConditionDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance IndoorAirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CarbonDioxideSensor, ParticulateMatterSensor
    base:desc "Real-time indoor air quality data including CO2 levels and particulate matter concentrations transmitted via BACnet/MS-TP and LoRaWAN"
]

instance EnvironmentalConditionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureHumiditySensor
    base:desc "Real-time temperature and humidity data for thermal comfort analysis, transmitted at 1-minute intervals via BACnet"
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
    base:desc "Real-time occupancy data for space utilization tracking, enabling occupancy-based control strategies"
]

instance LightingConditionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingLevelSensor
    base:desc "Continuous lighting level measurements for daylight harvesting and energy optimization"
]

instance HVACSystemDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACPerformanceSensor
    base:desc "Comprehensive HVAC system performance metrics including chiller efficiency, airflow rates, and system pressures"
]

instance StructuralConditionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralHealthSensor
    base:desc "Structural health monitoring data including vibration patterns and strain measurements for civil infrastructure"
]

// C10: Models/Data
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "Semantically rich BIM model incorporating geometric, spatial, and functional characteristics of building components in IFC/COBie format"
    DTDFVocab:inputTo BASYXFramework, itwinJsPlatform
]

instance BASYSDataModel : DTDFVocab:Model [
    base:desc "Standardized BASYS data model for asset-centric digital twins enabling interoperability across platforms"
    DTDFVocab:inputTo BASYXFramework
]

instance CityGMLGeospatialModel : DTDFVocab:Model [
    base:desc "Geospatial model for civil infrastructure assets using CityGML standard for lifecycle management"
    DTDFVocab:inputTo itwinJsPlatform
]

instance IndoorEnvironmentSimulationModel : DTDFVocab:Model [
    base:desc "Multi-physics simulation model for thermal, air quality, and structural analysis integrated with real-time sensor data"
    DTDFVocab:inputTo EnergyPlusSimulationEngine, OpenModelicaEngine
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Aggregated real-time sensor data from all physical sensing components"
    DTDFVocab:fromData IndoorAirQualityDataTransmitted, EnvironmentalConditionDataTransmitted, OccupancyDataTransmitted, LightingConditionDataTransmitted, HVACSystemDataTransmitted, StructuralConditionDataTransmitted
    DTDFVocab:inputTo EclipseHonoIngestion, EclipseDittoStateManagement
]

instance HistoricalPerformanceData : DTDFVocab:Data [
    base:desc "Time-series historical data for energy consumption, system performance, and occupant behavior analysis"
    DTDFVocab:fromData IndoorAirQualityDataTransmitted, HVACSystemDataTransmitted
    DTDFVocab:inputTo TimescaleDatabase, InfluxDBStorage
]

instance SimulationResults : DTDFVocab:Data [
    base:desc "Output data from multi-physics simulations including thermal performance, air flow patterns, and structural analysis"
    DTDFVocab:fromData IndoorEnvironmentSimulationModel
    DTDFVocab:inputTo VisualizationService
]

// C11: Enablers
instance BASYXFramework : DTDFVocab:Enabler [
    base:desc "Open-source digital twin framework providing standardized BASYS data models, Asset Administration Shell, and OPC UA interoperability"
    DTDFVocab:enables DigitalTwinDeploymentService, ModelDrivenAutomationService
]

instance itwinJsPlatform : DTDFVocab:Enabler [
    base:desc "JavaScript library for developing infrastructure digital twins with 3D/4D visualization and real-time synchronization"
    DTDFVocab:enables VisualizationService
]

instance EclipseHonoIngestion : DTDFVocab:Enabler [
    base:desc "IoT data ingestion platform for real-time sensor data collection and processing"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance EclipseDittoStateManagement : DTDFVocab:Enabler [
    base:desc "Digital twin state management system for bidirectional synchronization between physical and virtual domains"
    DTDFVocab:enables ControlAutomationService
]

instance EnergyPlusSimulationEngine : DTDFVocab:Enabler [
    base:desc "Building energy simulation engine for thermal and air flow analysis"
    DTDFVocab:enables SimulationTestingService
]

instance OpenModelicaEngine : DTDFVocab:Enabler [
    base:desc "Modelica-based multi-domain simulation engine for structural and system-level analysis"
    DTDFVocab:enables StructuralHealthMonitoringService
]

instance TimescaleDatabase : DTDFVocab:Enabler [
    base:desc "Time-series database optimized for IoT sensor data storage and analysis"
]

instance InfluxDBStorage : DTDFVocab:Enabler [
    base:desc "Time-series database for storing and querying sensor data with high write throughput"
]

instance ModelDrivenEngineeringTools : DTDFVocab:Enabler [
    base:desc "Model-driven engineering tools including EMF, Sirius, and Acceleo for automated code generation and digital twin development"
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous indoor environmental monitoring service providing real-time dashboards and alerts for CO2 levels, particulate matter, temperature, humidity, and occupancy"
    DTDFVocab:provides IndoorAirQualityInsight, ThermalComfortInsight, OccupancyPatternInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Machine learning-based service for predicting HVAC failures, energy consumption trends, and indoor air quality degradation"
    DTDFVocab:provides EnergyConsumptionForecastInsight, HVACFailurePredictionInsight, AirQualityDegradationInsight, PredictiveMaintenanceAction, EnergyOptimizationAction
]

instance SimulationTestingService : DTDFVocab:Service [
    base:desc "Multi-physics simulation service for testing design changes, occupancy scenarios, and energy-efficient strategies"
    DTDFVocab:provides DesignChangeValidationInsight, OccupancyScenarioAnalysisInsight, EnergyEfficiencyScenarioInsight
]

instance ControlAutomationService : DTDFVocab:Service [
    base:desc "Closed-loop automated control service for HVAC, lighting, and shading systems based on real-time sensor data and predictive models"
    DTDFVocab:provides AutomatedDemandResponseAction, DynamicZoningAction, FaultDetectionAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D/4D digital twin dashboards for real-time visualization of building performance, sensor data, and simulation results"
    DTDFVocab:provides BuildingPerformanceVisualizationInsight, SensorDataOverlayInsight, SimulationResultVisualizationInsight
]

instance DataDrivenInsightsService : DTDFVocab:Service [
    base:desc "Service generating automated reports for energy audits, compliance certificates, and maintenance logs"
    DTDFVocab:provides EnergyAuditInsight, ComplianceCertificateInsight, MaintenanceLogInsight
]

instance DigitalTwinDeploymentService : DTDFVocab:Service [
    base:desc "Service for deploying enriched BIM models as operational digital twins with real-time synchronization capabilities"
    DTDFVocab:provides DigitalTwinDeploymentInsight
]

instance ModelDrivenAutomationService : DTDFVocab:Service [
    base:desc "Model-driven automation framework for bidirectional data exchange between physical and virtual domains"
    DTDFVocab:provides AutomationWorkflowInsight
]

instance StructuralHealthMonitoringService : DTDFVocab:Service [
    base:desc "Service for structural health monitoring of civil infrastructure assets using vibration and strain sensors"
    DTDFVocab:provides StructuralIntegrityInsight, DamageDetectionInsight
]

