    base:desc "Service enabling real-time transmission of sensor data via Eclipse Hono's MQTT protocol."
]

instance ActuatorCommandRoutingService : DTDFVocab:Service [
    base:desc "Service for routing commands to physical actuators through Eclipse Hono."
]

instance TwinManagementService : DTDFVocab:Service [
    base:desc "Service for managing digital twin instances and their lifecycle through Eclipse Ditto."
]

instance MetadataSynchronizationService : DTDFVocab:Service [
    base:desc "Service for synchronizing metadata between physical devices and their digital twins."
]

instance ImmersiveMonitoringService : DTDFVocab:Service [
    base:desc "Service providing immersive 3D monitoring of building operations through Unreal Engine 5."
]

instance SimulationServices : DTDFVocab:Service [
    base:desc "Service enabling simulation of building operations and scenarios."
]

