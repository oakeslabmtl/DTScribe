// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator and controller for building lighting, modeled as a device in the BIM model and addressed by middleware for control commands."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator and controller for HVAC systems, modeled as a device in the BIM model and addressed by middleware for control commands."
]

// C3: Physical sensing components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor embedded in the BIM model and installed in the building to measure lighting levels for the BOREALIS reinforcement‑learning loop."
    DTDFVocab:producedData LightingSensorDataTransmitted
]

instance EnvironmentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor embedded in the BIM model and installed in the building to collect environmental condition measurements (temperature, humidity, CO₂) post‑occupancy."
    DTDFVocab:producedData EnvironmentSensorDataTransmitted
]

// C4: Physical‑to‑virtual interaction – Data transmitted
instance LightingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance EnvironmentSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentSensor
]

// C5: Data artefacts
instance LightingSensorData : DTDFVocab:Data [
    base:desc "Live streaming of lighting level measurements from the physical building."
    DTDFVocab:fromData LightingSensorDataTransmitted
    DTDFVocab:inputTo EclipseDittoStore
]

instance EnvironmentSensorData : DTDFVocab:Data [
    base:desc "Live streaming of environmental condition measurements (temperature, humidity, CO₂) from the physical building."
    DTDFVocab:fromData EnvironmentSensorDataTransmitted
    DTDFVocab:inputTo EclipseDittoStore
]

// C10: Models/Data
instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "Static BIM model of the Living Lab academic building enriched with runtime semantics (device metadata, control logic)."
    DTDFVocab:inputTo BIMAuthoringTool
    DTDFVocab:inputTo MDEPipeline
]

instance RuntimeArtifactsModel : DTDFVocab:Model [
    base:desc "Generated runtime artifacts (code, configuration) produced by model‑driven transformations."
    DTDFVocab:inputTo MDEPipeline
]

// C11: Enablers
instance BIMAuthoringTool : DTDFVocab:Enabler [
    base:desc "BIM authoring tool used to create and enrich the building information model with device metadata."
    DTDFVocab:enables RealTimeMonitoringDashboardService
]

instance MDEPipeline : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline that validates enriched BIM models, generates runtime artifacts and configures services."
    DTDFVocab:enables EnergyConsumptionOptimizationService
    DTDFVocab:enables PredictiveAnalyticsService
]

instance EclipseDittoStore : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital‑twin store that ingests live sensor streams and maintains current twin state."
    DTDFVocab:enables RealTimeMonitoringDashboardService
    DTDFVocab:enables ImmersiveVisualizationService
]

instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono IoT protocol gateway that streams sensor data to Ditto and forwards control commands to actuators."
    DTDFVocab:enables AdaptiveLightingControlService
]

instance UnrealEngine5Viz : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 used for 3‑D immersive visualization of the digital twin."
    DTDFVocab:enables ImmersiveVisualizationService
]

instance ExtensionPointFramework : DTDFVocab:Enabler [
    base:desc "Standardized extension points that allow modular addition of new twin services."
    DTDFVocab:enables RealTimeMonitoringDashboardService
    DTDFVocab:enables ImmersiveVisualizationService
    DTDFVocab:enables EnergyConsumptionOptimizationService
    DTDFVocab:enables PredictiveAnalyticsService
    DTDFVocab:enables AdaptiveLightingControlService
]

// C6: Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards visualizing live sensor data and system status."
    DTDFVocab:provides LightingOptimizationRecommendationInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "3‑D immersive visualization of the building state using Unreal Engine 5."
    DTDFVocab:provides AdaptiveLightingPolicyInsight
]

instance EnergyConsumptionOptimizationService : DTDFVocab:Service [
    base:desc "Service that analyses energy consumption and generates optimization recommendations."
    DTDFVocab:provides LightingOptimizationRecommendationInsight
    DTDFVocab:provides EnergyPredictiveAnalyticsInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service that forecasts future energy usage and environmental conditions."
    DTDFVocab:provides EnergyPredictiveAnalyticsInsight
]

instance AdaptiveLightingControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based adaptive lighting control service that issues automatic lighting policies."
    DTDFVocab:provides AdjustLightingAction
    DTDFVocab:provides AdaptiveLightingPolicyInsight
]

// C17: Insights
instance LightingOptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendation suggesting lighting set‑points that reduce energy use while maintaining occupant comfort."
]

instance EnergyPredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics insight forecasting energy consumption trends for proactive management."
]

instance AdaptiveLightingPolicyInsight : DTDFVocab:Insight [
    base:desc "Control policy derived from the reinforcement‑learning loop indicating optimal lighting actions per zone."
]

// C17: Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting actuator set‑points according to the learned policy."
    DTDFVocab:IsAutomatic true
]

// C12: Environment
instance LivingLabBuildingEnvironment : DTDFVocab:Environment [
    base:contains LightingSensor, EnvironmentSensor, LightingActuator, HVACActuator
]

// C13: Components (generic)
instance BuildingComponent : DTDFVocab:Component [
    base:desc "Generic building component representing any structural element within the BIM model."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional control commands generated by the twin are transmitted back to the physical actuators through the same Hono/Ditto middleware, allowing the twin to influence lighting (and other) building systems in real time."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (continuous) synchronization between physical sensor streams and the twin; control actions are applied with minimal latency through the middleware."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated architecture where the enriched BIM model feeds a configurator that produces device metadata, which is consumed by Hono/Ditto for bidirectional communication; services and visualization components plug into this core via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Supports the full building life‑cycle: design (as‑built BIM), construction, operation (live sensor data), and post‑occupancy adaptation, enabling continuous updates from design to refurbishment phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric is applied to quantify how closely the twin reflects its physical counterpart; model validation is performed before deployment to ensure semantic correctness."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Technical connectivity is realized through Eclipse Hono (gateway for device telemetry) and Eclipse Ditto (digital twin store and API gateway), which together provide the communication backbone between physical sensors/actuators and the digital twin."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Runtime artifacts and services are deployed on a service‑oriented platform that hosts Hono, Ditto and the Unreal Engine visualization; the framework provides automated deployment of these components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Relies on BIM as a standardized building information model; uses open‑source standards provided by Eclipse Hono/Ditto and defines standardized extension points for service integration."
]