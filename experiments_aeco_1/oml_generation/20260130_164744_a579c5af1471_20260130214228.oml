// C2: Acting Components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Controls on/off state, brightness level, and color-temperature (Kelvin) of a physical lighting fixture"
]

// C3: Physical sensing components
instance BuildingSensorArray : DTDFVocab:SensingComponent [
    base:desc "Embedded building sensors defined in enriched BIM metadata that stream measurements into Eclipse Hono for real-time twin synchronization"
    DTDFVocab:producedData BuildingSensorDataTransmitted
]

// C4: Physical-to-virtual interaction
instance BuildingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingSensorArray
]

// Data instances
instance BuildingSensorData : DTDFVocab:Data [
    base:desc "Live sensor measurement data (e.g., temperature, occupancy, energy) streamed from the physical building"
    DTDFVocab:fromData BuildingSensorDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance LightDeviceMetadata : DTDFVocab:Data [
    base:desc "Photometric values (e.g., lumen, color temperature) stored in BIM and consumed by LightTwinComponent"
    DTDFVocab:inputTo EclipseDittoEnabler
]

// Model instances
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched Building Information Model containing geometry, sensor, actuator and controller definitions"
    DTDFVocab:inputTo EclipseDittoEnabler, EclipseHonoEnabler
]

instance DeviceSemanticModel : DTDFVocab:Model [
    base:desc "Semantic model derived from BIM that defines IFC‑based device descriptions for automatic DT artifact generation"
    DTDFVocab:inputTo EclipseDittoEnabler
]

// Enabler instances
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono ingestion gateway that receives real‑time sensor streams and forwards them to the twin platform"
    DTDFVocab:enables RealTimeSynchronizationService, DeviceStateMonitoringService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin platform managing digital twin state, providing bidirectional synchronization and command validation"
    DTDFVocab:enables RealTimeSynchronizationService, ControlExecutionService, VisualizationService, AnalyticsService
]

instance UE5VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 engine delivering interactive 3D/immersive visualization for operators"
    DTDFVocab:enables VisualizationService
]

// Service instances
instance RealTimeSynchronizationService : DTDFVocab:Service [
    base:desc "Delivers real‑time data exchange for continuous synchronization between the physical building and its virtual twin"
    DTDFVocab:provides LiveTwinStateInsight
]

instance DeviceStateMonitoringService : DTDFVocab:Service [
    base:desc "Monitors device states and health, exposing current status to operators"
    DTDFVocab:provides DeviceHealthInsight
]

instance ControlExecutionService : DTDFVocab:Service [
    base:desc "Executes control commands on actuators via UnrealTwinController, DittoDevice and validates them in Eclipse Ditto"
    DTDFVocab:provides CommandValidationInsight, ExecuteControlAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides interactive 3D and immersive visualization of the building twin using UE5"
    DTDFVocab:provides Immersive3DVisualizationInsight
]

instance AnalyticsService : DTDFVocab:Service [
    base:desc "Runs analytics for prediction, optimization and decision support on twin data"
    DTDFVocab:provides PredictiveAnalyticsInsight, OptimizationAction, DecisionSupportInsight
]

// Insight instances
instance LiveTwinStateInsight : DTDFVocab:Insight [
    base:desc "Insight on the current synchronization status and latency between physical and virtual twin"
]

instance DeviceHealthInsight : DTDFVocab:Insight [
    base:desc "Insight on health, connectivity and operational status of building devices"
]

instance CommandValidationInsight : DTDFVocab:Insight [
    base:desc "Insight on safety checks (range, unit consistency) performed before command execution"
]

instance Immersive3DVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight on visual representation completeness and user interaction within the UE5 environment"
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Insight from predictive models forecasting energy consumption, occupancy trends and equipment wear"
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Insight providing recommendations for building operation and refurbishment based on analytics"
]

// Action instances
instance ExecuteControlAction : DTDFVocab:Action [
    base:desc "Action to send on/off, brightness and color‑temperature commands to a lighting actuator"
    DTDFVocab:IsAutomatic false
]

instance OptimizationAction : DTDFVocab:Action [
    base:desc "Automatic optimization of lighting settings for energy efficiency while maintaining user comfort"
    DTDFVocab:IsAutomatic true
]

// Environment (optional aggregation)
instance BuildingTwinEnvironment : DTDFVocab:Environment [
    base:contains LightTwinComponent, BuildingSensorArray, RealTimeSynchronizationService, VisualizationService, AnalyticsService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional data exchange is supported by the DT Framework that not only receives sensor data but also feeds control commands back to the Building Control System (Document 1). The digital twin can issue runtime control signals to physical devices, enabling Facility Managers to operate the infrastructure through the twin as described in the use‑case roles (Document 4). Specific command formats or authentication mechanisms are not detailed in the provided texts."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange that continuously synchronizes the physical building with its digital counterpart, implying an ongoing low‑latency data flow; however, the documents do not specify concrete synchronization frequencies, latency bounds, or temporal granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The proposed system follows a modular architecture centred on a DT Framework that acts as a central hub for bidirectional data exchange. It exposes standardized extension points for custom services and analytics, supports runtime configuration management to adjust behaviour without redeployment, and leverages a model‑driven pipeline that transforms enriched BIM models into deployable DT artifacts, orchestrating device modelling, data ingestion, and control logic across the twin lifecycle."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The proposed framework supports the full DT life‑cycle, beginning with device modeling directly in the BIM environment (sensors, actuators, controllers), followed by model‑driven engineering (MDE) that extracts structured representations and automatically generates deployable DT artifacts. An automated deployment step (R2) provisions the twin with minimal manual effort. Once deployed, the twin operates in a runtime phase with continuous real‑time data exchange (R3) and interactive visualization for monitoring and control. The architecture further allows post‑deployment evolution through custom services and analytics added via defined extension points (R4). Governance of the life‑cycle is assigned to three actor roles – Building Control Engineer (modeling and control‑logic definition), Facility Manager (operational monitoring and interaction), and DT Engineer (service extension)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is measured using the Overall Digital Twin Entanglement (ODTE) metric, composed of timeliness (0.997), reliability (1.0) and availability (1.0). Validation is performed by Eclipse Ditto’s policy‑based validation, which checks sensor value ranges and units, and by pre‑execution checks on actuator commands. Uncertainty due to network latency is quantified by the timeliness score (≈3 % delay). Error detection is provided by Ditto’s persistent event storage and Hono’s at‑least‑once delivery guarantee, enabling replay of lost messages. Quality assurance includes automated model checking (5.53 s), parsing (8.7 s) and a 1 Hz heartbeat mechanism used during experiments to verify bidirectional synchronization."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connectivity relies on a modular architecture with defined extension points (R4, Document 3) that integrates Eclipse Hono and Eclipse Ditto (R3, Document 3). Hono provides protocol handling for incoming IoT data, while Ditto manages the twin state and exposes APIs for interaction. This combination satisfies the real‑time connectivity and extensibility requirements (Document 3) and conforms to the non‑functional interoperability and scalability goals (Document 1). No explicit network topology, bandwidth, latency, or security protocol specifications are given."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment is model‑driven and automated, reducing manual effort and enabling reproducible DT setups (R2, Document 3). The framework supports runtime configuration management that allows adjustments without full redeployment (Document 1). While the hosting environment (cloud, edge, on‑premise) and resource sizing are not specified, the modular architecture and automated deployment process provide a scalable foundation for deploying operational control twins in the AECO domain."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The approach targets interoperability across heterogeneous systems by using standardized extension points and runtime configuration, and it integrates BIM models, sensor networks, and AI services. It references existing open‑source DT frameworks such as Eclipse Ditto and BaSyx, which are built on established industry standards, to enable connectivity and data exchange with external enterprise systems, although specific data exchange protocols (e.g., OPC‑UA, MQTT) are not detailed in the documents."
]