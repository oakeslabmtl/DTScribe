// C2: Physical Acting Components
instance OccupancyControlActuator : DTDFVocab:ActingComponent [
    base:desc "Building control device for occupancy-based lighting and HVAC actuation, explicitly defined by Building Control Engineers in the BIM environment"
]

instance HVACController : DTDFVocab:Actuator [
    base:desc "HVAC system controller integrated with BIM for real-time temperature and airflow management, with metadata including tenant IDs and endpoint addresses"
]

instance LightingAutomationSystem : DTDFVocab:Actuator [
    base:desc "Building automation system for adaptive lighting control, modeled in BIM with sensor-actuator coordination for energy-efficient operation"
]

instance SmartThermostat : DTDFVocab:Actuator [
    base:desc "Smart thermostat device with BIM-enriched metadata for bidirectional communication with the digital twin via Eclipse Hono/Ditto"
]

// C3: Physical Sensing Components
instance OccupancySensorNetwork : DTDFVocab:SensingComponent [
    base:desc "Sensor network embedded within BIM capturing real-time occupancy data for building digital twin synchronization"
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor network embedded within BIM capturing real-time energy consumption data (e.g., HVAC, lighting) for predictive analytics"
]

instance EnvironmentalParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor network embedded within BIM capturing real-time environmental parameters (temperature, humidity, CO2) for building monitoring"
]

instance TemperatureSensorNetwork : DTDFVocab:SensingComponent [
    base:desc "Sensor network embedded within BIM capturing real-time temperature readings across building zones for adaptive control"
]

instance AirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor network embedded within BIM capturing real-time air quality metrics (particulate matter, VOCs) for occupant health monitoring"
]

// C3: Produced Data
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensorNetwork
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalParameterSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorNetwork
]

instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualitySensor
]

// C4: Data
instance OccupancyRealTimeData : DTDFVocab:Data [
    base:desc "Real-time occupancy data processed from BIM-enriched sensor networks",
    DTDFVocab:fromData OccupancyDataTransmitted
]

instance EnergyConsumptionRealTimeData : DTDFVocab:Data [
    base:desc "Real-time energy consumption data processed from BIM sensor networks",
    DTDFVocab:fromData EnergyDataTransmitted
]

instance EnvironmentalParametersRealTimeData : DTDFVocab:Data [
    base:desc "Real-time environmental parameter data processed from BIM sensor networks",
    DTDFVocab:fromData EnvironmentalDataTransmitted
]

instance TemperatureRealTimeData : DTDFVocab:Data [
    base:desc "Real-time temperature data processed from BIM sensor networks",
    DTDFVocab:fromData TemperatureDataTransmitted
]

instance AirQualityRealTimeData : DTDFVocab:Data [
    base:desc "Real-time air quality data processed from BIM sensor networks",
    DTDFVocab:fromData AirQualityDataTransmitted
]

// C10: Models/Data
instance BIMEnrichedBuildingModel : DTDFVocab:Model [
    base:desc "BIM model augmented with device metadata and control logic by Building Control Engineers, serving as semantic backbone for DT deployment"
]

instance RuntimeDeviceMetadataModel : DTDFVocab:Model [
    base:desc "Model generated from BIM via Eclipse Hono/Ditto Configurator containing runtime-ready device configurations and control logic"
]

instance OperationalDataSchema : DTDFVocab:Model [
    base:desc "Structured representation of data schemas derived from BIM for interoperability with AECO standards (IFC, COBie)"
]

// C11: Enablers
instance BIMConfigurator : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering tool that automates BIM enrichment with device metadata and control logic for DT deployment"
]

instance EclipseHonoMiddleware : DTDFVocab:Enabler [
    base:desc "Real-time data exchange middleware (Eclipse Hono) enabling bidirectional communication between physical building components and digital twin"
]

instance DittoConfigurator : DTDFVocab:Enabler [
    base:desc "Middleware configurator that extracts runtime artifacts (service configurations, data schemas) from BIM models for DT deployment"
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Immersive 3D visualization platform (Unreal Engine 5) for interactive DT monitoring and simulation"
]

instance BIMToolsPlatform : DTDFVocab:Enabler [
    base:desc "Generic BIM platform tools for device modeling, configuration, and metadata enrichment in building digital twin"
]

// C6: DT Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring and visualization service using Unreal Engine for immersive 3D interaction with building digital twin"
]

instance PredictiveOptimizationService : DTDFVocab:Service [
    base:desc "Predictive analytics and optimization service for energy efficiency, adaptive lighting, and operational cost reduction using reinforcement learning (BOREALIS)"
]

instance InteractiveSimulationService : DTDFVocab:Service [
    base:desc "Interactive simulation service for performance analysis and decision-making support across building life cycle"
]

instance CustomPluginService : DTDFVocab:Service [
    base:desc "Standardized extension point for domain-specific plugins (IoT analytics, AI-driven control strategies) by DT Engineers"
]

// C17: Insights/Actions
instance OccupancyVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization of real-time occupancy patterns within building zones for spatial analysis"
]

instance EnergyUsageInsight : DTDFVocab:Insight [
    base:desc "Real-time energy consumption analytics with predictive trends for HVAC and lighting systems"
]

instance EnergyOptimizationAction : DTDFVocab:Action [
    base:desc "Automated energy optimization adjustments via reinforcement learning (BOREALIS) based on predictive analytics",
    DTDFVocab:IsAutomatic true
]

instance ComfortAdaptationAction : DTDFVocab:Action [
    base:desc "Adaptive HVAC and lighting control strategies to maintain occupant comfort based on real-time environmental data",
    DTDFVocab:IsAutomatic true
]

instance RefurbishmentAnalysisInsight : DTDFVocab:Insight [
    base:desc "Interactive simulation results for refurbishment planning and cost-benefit analysis"
]

instance OccupancyForecastingInsight : DTDFVocab:Insight [
    base:desc "Predictive modeling of future occupancy patterns for operational planning"
]

instance DomainSpecificAnalyticsAction : DTDFVocab:Action [
    base:desc "Custom analytics execution via domain-specific plugins integrated through standardized extension points",
    DTDFVocab:IsAutomatic false
]

// C12: Environment
instance BuildingInfrastructureEnvironment : DTDFVocab:Environment [
    base:contains OccupancyControlActuator, HVACController, LightingAutomationSystem, SmartThermostat,
              OccupancySensorNetwork, EnergyConsumptionSensor, EnvironmentalParameterSensor,
              TemperatureSensorNetwork, AirQualitySensor
]

instance DigitalTwinCoreEnvironment : DTDFVocab:Environment [
    base:contains BIMEnrichedBuildingModel, RuntimeDeviceMetadataModel, OperationalDataSchema,
              EclipseHonoMiddleware, DittoConfigurator, UnrealEngineVisualization
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The **virtual-to-physical interaction** is enabled through **service-oriented architecture** with standardized extension points, allowing the DT to generate control signals and commands for physical actuators. The framework integrates with **Unreal Engine** for visualization and **Eclipse Hono/Ditto** for real-time actuation, ensuring seamless feedback loops between the digital and physical worlds. Control logic is embedded directly into BIM models by **Building Control Engineers**, enabling automated commissioning and adaptive adjustments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The **twinning time scale** is **real-time**, with synchronization between the physical and virtual twins occurring at **sub-second intervals** for critical operational data (e.g., sensor readings, control commands). The framework supports **low-latency bidirectional communication** via **Eclipse Hono** and **Ditto**, ensuring that the DT remains dynamically aligned with the physical building’s operational state. The **Overall Digital Twin Entanglement (ODTE) metric** is used to evaluate the fidelity of this synchronization."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **DT constellation** is structured as a **service-oriented ecosystem** with:
  - A **centralized DT framework** acting as the orchestrator, integrating BIM models, middleware, and visualization tools.
  - **Modular components** (e.g., lighting control modules, energy optimization services) deployed via standardized extension points.
  - **Hierarchical relationships** between individual devices (e.g., sensors) and higher-level services (e.g., adaptive lighting systems), ensuring scalability and interoperability across the entire infrastructure."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The **life-cycle stages** covered by the DT span:
  1. **Design phase**: BIM models are enriched with device metadata and control logic by **Building Control Engineers**.
  2. **Construction phase**: Automated validation ensures compliance with BIM standards and real-time data integration readiness.
  3. **Operation phase**: The DT provides real-time monitoring, predictive analytics, and adaptive control (e.g., via **BOREALIS**’ reinforcement learning) to optimize energy efficiency and occupant comfort.
  4. **Refurbishment phase**: The DT supports dynamic updates and service evolution via standardized extension points, ensuring longevity and adaptability."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The **fidelity and validity considerations** are addressed through:
  - **Overall Digital Twin Entanglement (ODTE) metric** to evaluate alignment between the DT and its physical counterpart.
  - **Model validation** to ensure BIM data consistency and completeness before deployment.
  - **Automated commissioning** to verify real-time data synchronization and control logic execution.
  - **Uncertainty management** via structured data flows and middleware (e.g., **Eclipse Hono/Ditto**), ensuring robustness against sensor drift or network latency."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT employs **Eclipse Hono** and **Ditto** for real-time data exchange, leveraging standardized protocols for bidirectional communication. The technical connection ensures low-latency synchronization between physical assets and the DT, with no additional unsupported protocols (e.g., MQTT, WebSockets) mentioned."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed via a **modular, service-oriented architecture** with standardized extension points. The framework supports **runtime configuration management**, enabling adjustments to services (e.g., control logic) without redeployment. Unreal Engine is used for visualization, but deployment specifics (e.g., cloud/edge computing) are not detailed."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT integrates horizontally with **AECO-specific systems and standards** (e.g., BIM) and **middleware platforms** (Eclipse Hono/Ditto) for interoperability. While not explicitly mentioning IFC/COBie, the framework emphasizes **standardized extension points** for modular service integration across heterogeneous systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT adheres to **AECO-specific standards** (e.g., BIM) and **model-driven engineering (MDE)** principles. Standardized extension points enable interoperability with existing AECO tools, though no explicit mention of IFC/COBie is provided."
]