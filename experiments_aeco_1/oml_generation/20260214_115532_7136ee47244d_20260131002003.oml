// ---------------------------
// Insights (C17)
instance EnergyConsumptionPredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive insight on future energy consumption derived from temperature data and the thermal behavior model."
]

instance OccupancyPatternInsight : DTDFVocab:Insight [
    base:desc "Insight on occupancy patterns derived from occupancy sensor data, aiding space utilization decisions."
]

// ---------------------------
// Actions (C17)
instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Control action to adjust HVAC setpoints via BCS actuators based on optimization recommendations.",
    DTDFVocab:IsAutomatic false
]

// ---------------------------
// Services (C6)
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides live visualization dashboards and immersive interface for facility managers.",
    DTDFVocab:provides OccupancyPatternInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Processes temperature data to generate predictive energy consumption insights.",
    DTDFVocab:provides EnergyConsumptionPredictionInsight
]

instance SimulationOptimizationService : DTDFVocab:Service [
    base:desc "Runs simulations and optimization algorithms to suggest control actions for building systems.",
    DTDFVocab:provides AdjustHVACAction
]

// ---------------------------
// Enablers (C11)
instance EclipseHonoIngestion : DTDFVocab:Enabler [
    base:desc "Standardized data ingestion endpoint using MQTT/AMQP (Eclipse Hono) for real‑time sensor streams.",
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoPersistence : DTDFVocab:Enabler [
    base:desc "Digital twin persistence layer (Eclipse Ditto) storing twin instances and state.",
    DTDFVocab:enables RealTimeMonitoringService
]

instance AnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Analytics engine that processes incoming data streams, runs predictive models and supports services.",
    DTDFVocab:enables PredictiveAnalyticsService, SimulationOptimizationService
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Immersive 3D rendering engine (Unreal Engine) used for visualizing the digital twin.",
    DTDFVocab:enables RealTimeMonitoringService
]

// ---------------------------
// Data Transmitted (C4)
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingTemperatureSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingOccupancySensor
]

// ---------------------------
// Models / Data (C10)
instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "Static BIM geometric model representing the building's architecture, structural and MEP components.",
    DTDFVocab:inputTo EclipseDittoPersistence
]

instance ThermalBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model derived via model‑driven engineering that simulates thermal dynamics of the building.",
    DTDFVocab:inputTo AnalyticsEngine
]

instance ActuatorDeviceModel : DTDFVocab:Model [
    base:desc "Semantic extension of the BIM model describing sensor and actuator devices, their types and capabilities.",
    DTDFVocab:inputTo EclipseHonoIngestion
]

instance TemperatureMeasurementData : DTDFVocab:Data [
    base:desc "Live temperature measurement values streamed from the physical sensor to the digital twin.",
    DTDFVocab:fromData TemperatureDataStream,
    DTDFVocab:inputTo AnalyticsEngine, EclipseDittoPersistence
]

instance OccupancyMeasurementData : DTDFVocab:Data [
    base:desc "Live occupancy counts streamed from the physical sensor to the digital twin.",
    DTDFVocab:fromData OccupancyDataStream,
    DTDFVocab:inputTo UnrealEngineVisualization, EclipseDittoPersistence
]

// ---------------------------
// Sensing Components (C3)
instance BuildingTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor incorporated into the BIM model as an explicit sensor entity linked to its physical location within the building.",
    DTDFVocab:producedData TemperatureDataStream
]

instance BuildingOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor incorporated into the BIM model as an explicit sensor entity linked to its physical location within the building.",
    DTDFVocab:producedData OccupancyDataStream
]

// ---------------------------
// Acting Components (C2)
instance BCSActuator : DTDFVocab:ActingComponent [
    base:desc "Actuating element modeled in the BIM as a BCS actuator, capable of receiving control signals from the Digital Twin."
]

instance BuildingController : DTDFVocab:ActingComponent [
    base:desc "Controller entity that orchestrates BCS actuators within the building control system."
]

// ---------------------------
// Environment (optional aggregation)
instance BuildingTwin : DTDFVocab:Environment [
    base:contains 
        BuildingTemperatureSensor,
        BuildingOccupancySensor,
        BCSActuator,
        BuildingController,
        BuildingBIMModel,
        ThermalBehaviorModel,
        ActuatorDeviceModel,
        TemperatureDataStream,
        OccupancyDataStream,
        TemperatureMeasurementData,
        OccupancyMeasurementData,
        EclipseHonoIngestion,
        EclipseDittoPersistence,
        AnalyticsEngine,
        UnrealEngineVisualization,
        RealTimeMonitoringService,
        PredictiveAnalyticsService,
        SimulationOptimizationService,
        EnergyConsumptionPredictionInsight,
        OccupancyPatternInsight,
        AdjustHVACAction
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication enables the digital twin to issue control commands back to physical building systems. Facility managers use the DT interface to adjust building operations; commands are transmitted through the same modular framework via the standardized extension points to the underlying devices. The description does not provide details about specific command types, message formats, validation or authentication mechanisms, feedback loops, conflict‑resolution strategies, or execution confirmations."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports the full DT lifecycle from initial device modeling in the BIM environment, through model‑driven engineering (MDE) extraction of structured representations, automatic generation of deployable DT artifacts, deployment, and runtime operation with real‑time data exchange and interactive visualization. At the modeling stage sensors, actuators and controllers are defined within BIM; the transformation stage creates an enriched semantic model; the generation stage produces code‑level DT artifacts; the deployment stage instantiates the twin; the operation stage maintains synchronization and enables monitoring. Transition between stages is managed automatically by the MDE‑based transformation pipeline, requiring minimal manual intervention."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by aligning the enriched BIM models (geometric and behavioral) with live data from the physical building through continuous synchronization. Validation occurs as the framework automatically reconciles runtime sensor and actuator data with the corresponding model elements, detecting mismatches that indicate fidelity loss. Quality assurance is achieved by the automated generation of DT artifacts from the verified BIM models and by maintaining up‑to‑date semantic links, thereby supporting ongoing verification of model accuracy during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The solution adopts a modular architecture with defined extension points that supports interoperability across heterogeneous building‑system components. Runtime configuration management facilitates dynamic adaptation of connections without full redeployment. While the document highlights scalability from individual components to whole infrastructure and mentions reliability through low‑overhead updates, it does not detail the underlying network protocols, topology, bandwidth or latency requirements, redundancy mechanisms, or security protocols employed for network communication."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution is built around BIM, the de‑facto industry standard for AECO data, and requires that all device definitions and control logic be expressed as BIM extensions. It introduces standardized extension points in the twin’s architecture to ensure interoperability of custom services and analytics. While specific standards (e.g., IFC, ISO 19650) are not cited, the framework explicitly targets compatibility with existing AECO‑specific standards and adopts a model‑driven, standards‑aware approach to integration."
]