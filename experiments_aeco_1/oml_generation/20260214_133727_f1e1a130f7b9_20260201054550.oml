// Sensing Components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor defined within the enriched BIM model, streamed via Eclipse Hono to Ditto."
    DTDFVocab:producedData LightDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined within the enriched BIM model, streamed via Eclipse Hono to Ditto."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance AirflowSensor : DTDFVocab:SensingComponent [
    base:desc "Airflow sensor defined within the enriched BIM model, streamed via Eclipse Hono to Ditto."
    DTDFVocab:producedData AirflowDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined within the enriched BIM model, streamed via Eclipse Hono to Ditto."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance ConsumablesSensor : DTDFVocab:SensingComponent [
    base:desc "Consumables sensor defined within the enriched BIM model, streamed via Eclipse Hono to Ditto."
    DTDFVocab:producedData ConsumablesDataTransmitted
]

// Data Transmitted
instance LightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance AirflowDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirflowSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance ConsumablesDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ConsumablesSensor
]

// Data (telemetry)
instance LightData : DTDFVocab:Data [
    base:desc "Light level data including on/off state, brightness level, and color temperature in kelvin."
    DTDFVocab:fromData LightDataTransmitted
    DTDFVocab:inputTo HonoDeviceExchange, DittoRegistry, DataAnalyticsEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature data from built‑in temperature sensors."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo HonoDeviceExchange, DittoRegistry, DataAnalyticsEnabler
]

instance AirflowData : DTDFVocab:Data [
    base:desc "Airflow data from HVAC sensors."
    DTDFVocab:fromData AirflowDataTransmitted
    DTDFVocab:inputTo HonoDeviceExchange, DittoRegistry, DataAnalyticsEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy data from occupancy sensors."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo HonoDeviceExchange, DittoRegistry, DataAnalyticsEnabler
]

instance ConsumablesData : DTDFVocab:Data [
    base:desc "Consumables usage data from related sensors."
    DTDFVocab:fromData ConsumablesDataTransmitted
    DTDFVocab:inputTo HonoDeviceExchange, DittoRegistry, DataAnalyticsEnabler
]

// Enablers
instance HonoDeviceExchange : DTDFVocab:Enabler [
    base:desc "Eclipse Hono integration for publishing sensor streams and subscribing to actuation commands."
    DTDFVocab:enables MonitoringService
]

instance DittoRegistry : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto device registry and event store maintaining twin state."
    DTDFVocab:enables ControlService, VisualizationService, OptimizationService
]

instance DataAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Analytics pipeline enabling machine‑learning based failure prediction and energy optimisation forecasts."
    DTDFVocab:enables PredictiveAnalyticsService
]

instance MDEPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline auto‑generating DT artifacts from enriched BIM models."
    DTDFVocab:enables MonitoringService, PredictiveAnalyticsService, ControlService, VisualizationService, OptimizationService
]

instance BIMMetadataEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for enriching BIM models with device metadata."
    DTDFVocab:enables MonitoringService, PredictiveAnalyticsService, ControlService, VisualizationService, OptimizationService
]

instance DataExchangeEnabler : DTDFVocab:Enabler [
    base:desc "Enabler managing data exchange between physical building assets and digital twin."
    DTDFVocab:enables MonitoringService, ControlService
]

instance ModularArchitectureEnabler : DTDFVocab:Enabler [
    base:desc "Modular architecture permitting integration of custom analytics or services."
    DTDFVocab:enables MonitoringService, PredictiveAnalyticsService, ControlService, VisualizationService, OptimizationService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time telemetry of device states (temperature, airflow, occupancy, consumables) aggregated from the BIM‑defined sensor network."
    DTDFVocab:provides MonitoringInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Machine‑learning based failure prediction and energy optimisation forecasts."
    DTDFVocab:provides FailurePredictionInsight, EnergyOptimizationForecastInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Direct actuation of building equipment through the twin, allowing facility managers to issue commands translated to device‑level instructions."
    DTDFVocab:provides ActuationCommandAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3‑D rendering of the BIM model with live data overlays."
    DTDFVocab:provides BuildingVisualizationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Recommendation engines proposing efficient control strategies to meet energy, comfort or operational objectives."
    DTDFVocab:provides OptimizationRecommendationAction
]

// Insights / Actions
instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Exposes telemetry and status indicators that enable operators to monitor live system states."
]

instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive failure insights derived from machine‑learning models."
]

instance EnergyOptimizationForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasts for energy optimisation based on predictive analytics."
]

instance ActuationCommandAction : DTDFVocab:Action [
    base:desc "Action to actuate building equipment via Ditto over MQTT."
    DTDFVocab:IsAutomatic false
]

instance BuildingVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of building in UE5 with live data overlays."
]

instance OptimizationRecommendationAction : DTDFVocab:Action [
    base:desc "Action providing recommended control strategies for optimal performance."
    DTDFVocab:IsAutomatic false
]

// Acting Component
instance LightTwinComponentActuator : DTDFVocab:ActingComponent [
    base:desc "Light actuator twin component instantiated within BIM, controlled by building control logic."
]

// Physical Components
instance LightComponent : DTDFVocab:Component [
    base:desc "Light fixture represented in BIM, acted upon by LightTwinComponentActuator."
]

instance HVACComponent : DTDFVocab:Component [
    base:desc "HVAC unit represented in BIM with control logic."
]

// Environment
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains LightComponent, HVACComponent
]

// Model
instance BIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model encoding geometric, behavioural, and control‑logic information for building components."
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional data exchange allows the digital twin to send control commands back to physical building systems, enabling real‑time monitoring and control by facility managers via the central DT framework hub."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange capabilities ensure continuous synchronization between physical buildings and their digital counterparts, with the Digital Twin designed to generate bidirectional data feeds at update intervals driven by operational monitoring requirements; while precise numeric frequencies or latency bounds are not specified in the documents, the architecture supports real‑time monitoring and control with low‑latency update cycles."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular architecture centered around a DT Framework hub that orchestrates data exchange, runtime configuration, and service integration. Standardized extension points enable custom analytics services to be integrated without full redeployment, while component integration is managed through the framework’s runtime configuration management, allowing dynamic resource allocation and coordinated operation across the lifecycle of a building asset."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework follows a six‑stage lifecycle: (1) Enrichment – Building Control Engineers extend BIM with sensors, actuators and controllers; (2) Transformation – Model‑Driven Engineering extracts structured semantic representations; (3) Generation – Deployable DT artifacts (e.g., OPC UA nodes, REST/GraphQL services) are automatically created; (4) Deployment – These artifacts are deployed within a modular runtime that supports real‑time bidirectional data exchange; (5) Extension – DT Engineers add custom analytics or control services through defined extension points; (6) Monitoring and Governance – Facility Managers monitor physical infrastructure via immersive visualisation, while versioned BIM models provide traceability and change management."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation occurs during the deployment pipeline’s validation component, ensuring that BIM models conform to expected schemas prior to code generation. The real‑time data exchange between the physical building and the twin is monitored for consistency, but the document does not detail explicit fault‑tolerance, error quantification, or iterative verification mechanisms beyond the initial deployment validation."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration is achieved through standardized extension points that facilitate interoperability across heterogeneous AECO systems, supporting bidirectional data exchange between enriched BIM models and operational DTs. The framework’s non‑functional requirements emphasize interoperability, scalability, and maintainability, implying the use of common enterprise APIs and data‑exchange protocols, although specific protocols are not enumerated."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework’s primary data model is BIM; it adheres to the semantic structures defined by the BIM ecosystem. Connectivity is handled through open‑source components such as Eclipse Ditto, and the architecture exposes standardized extension points that permit integration of additional services and custom analytics. No further industry certifications or interoperability frameworks are described in the documents."
]