// Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensors instrumented to detect presence within zones"
    DTDFVocab:producedData PTTelemetryData
]
instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensors measuring light levels within zones"
    DTDFVocab:producedData PTTelemetryData
]
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensors measuring ambient temperature"
    DTDFVocab:producedData PTTelemetryData
]
instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensors measuring relative humidity"
    DTDFVocab:producedData PTTelemetryData
]
instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO2 sensors measuring indoor air quality"
    DTDFVocab:producedData PTTelemetryData
]

// Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting luminaires modeled as Actuator entities enabling automatic lighting control"
]
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuators embedded throughout the building for temperature and airflow control"
]

// Data Transmitted
instance PTTelemetryData : DTDFVocab:DataTransmitted [
    base:desc "Real-time telemetry from PT streamed over MQTT via Eclipse Hono serialized as JSON and stored in broker"
    DTDFVocab:producedFrom OccupancySensor, IlluminanceSensor, TemperatureSensor, HumiditySensor, CO2Sensor
]

// Data
instance SensorTelemetryData : DTDFVocab:Data [
    base:desc "Continuous sensor readings serialized as JSON payloads"
    DTDFVocab:fromData PTTelemetryData
    DTDFVocab:inputTo HonoBrokerEnabler, DittoManagerEnabler
]
instance EventLogData : DTDFVocab:Data [
    base:desc "Event logs generated by building automation systems"
    DTDFVocab:fromData PTTelemetryData
    DTDFVocab:inputTo DittoManagerEnabler
]

// Models
instance IFCModel : DTDFVocab:Model [
    base:desc "Base IFC BIM schema transformed into Ditto thing twins"
    DTDFVocab:inputTo DittoManagerEnabler
]
instance JSONSchemaModel : DTDFVocab:Model [
    base:desc "Runtime JSON schemas for sensor data and control logic configurations"
    DTDFVocab:inputTo DittoManagerEnabler
]
instance ControlLogicConfigModel : DTDFVocab:Model [
    base:desc "Control logic configuration for lighting and HVAC within the DT runtime"
    DTDFVocab:inputTo DittoManagerEnabler
]

// Enablers
instance HonoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT broker facilitating real-time telemetry ingestion"
    DTDFVocab:enables MonitoringDashboardService
]
instance DittoManagerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto thing twin manager for twin lifecycle and data processing"
    DTDFVocab:enables MonitoringDashboardService, EnergyAnalyticsService, LightingRLOptimizationService, PerformanceSimulationService
]
instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3D visualization of the building"
    DTDFVocab:enables Immersive3DVisualizationService
]
instance ModelDrivenToolEnabler : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering tools for model transformation of BIM to DT twins"
    DTDFVocab:enables BIMTransformationService
]
instance BIMAuthoringToolEnabler : DTDFVocab:Enabler [
    base:desc "BIM authoring tool (e.g., Autodesk Revit) for creating enriched building models"
    DTDFVocab:enables BIMTransformationService
]

// Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real-time monitoring dashboards"
    DTDFVocab:provides EnergyUsageInsight, LightingOptimizationInsight
]
instance EnergyAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy consumption"
    DTDFVocab:provides EnergyUsageInsight, PredictiveMaintenanceInsight, HVACMaintenanceScheduleAction
]
instance LightingRLOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement learning based lighting control optimization"
    DTDFVocab:provides LightingOptimizationInsight, RLLightingAdjustmentAction
]
instance PerformanceSimulationService : DTDFVocab:Service [
    base:desc "Performance simulation of building systems"
    DTDFVocab:provides PerformanceSimulationInsight
]
instance Immersive3DVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D visualization via Unreal Engine"
    DTDFVocab:provides ThreeDVisualizationInsight
]
instance BIMTransformationService : DTDFVocab:Service [
    base:desc "Model transformation of BIM to Ditto twin format"
]

// Insights
instance EnergyUsageInsight : DTDFVocab:Insight [
    base:desc "Occupancy‑based energy usage reports"
]
instance LightingOptimizationInsight : DTDFVocab:Insight [
    base:desc "Lighting optimization recommendations"
]
instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance alerts for HVAC components"
]
instance PerformanceSimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results for building performance"
]
instance ThreeDVisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive 3D visualization models"
]

// Actions
instance RLLightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated lighting control adjustments based on RL model"
    DTDFVocab:IsAutomatic true
]
instance HVACMaintenanceScheduleAction : DTDFVocab:Action [
    base:desc "Schedule HVAC maintenance based on predictive analytics"
    DTDFVocab:IsAutomatic false
]
instance HVACControlAction : DTDFVocab:Action [
    base:desc "Manual real-time HVAC control commands"
    DTDFVocab:IsAutomatic false
]

// Environment
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains LightingActuator, HVACActuator, OccupancySensor, IlluminanceSensor, TemperatureSensor, HumiditySensor, CO2Sensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., lighting dimming, HVAC set‑point adjustment) are published to Ditto thing twins, then forwarded over MQTT to building PLCs/actuators, serving as the source of actuated actions."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Whole‑building twin operates in real‑time with sub‑second latency; control loops run at a 1 Hz update rate with typical MQTT latency below 100 ms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated system where enriched BIM models are converted into Ditto thing twins; twins communicate via Hono MQTT broker; visualization nodes (Unreal Engine) consume twin state; control logic modules exchange state via Ditto."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Twin spans all lifecycle phases: design (ideal BIM model), construction (manufactured building validated against BIM), and operation (runtime with live sensor data and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity assessed by the Overall Digital Twin Entanglement (ODTE) metric; validity ensured through IFC metamodel validation, runtime consistency checks, and synchronization monitoring."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT-based communication via Eclipse Hono with TLS encryption; Ditto exposes HTTP/REST endpoints and WebSocket streams; mapping between MQTT topics (e.g., /sensor/+/data) and Ditto thing twins."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted on a cloud‑based middleware stack (Hono & Ditto) deployed on Kubernetes; visualization server (Unreal Engine) runs on a GPU‑enabled workstation; all components orchestrated via Docker containers."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external BIM workflows, IoT device registries, and other service platforms via REST APIs; partner systems consume Ditto thing data for cross‑building analytics."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with IFC BIM standards (Industry Foundation Classes), Open Protocols of Eclipse Hono (MQTT, AMQP) and Ditto (JSON, REST), adherence to ISO 14001 for environmental reporting, and Model‑Driven Engineering best practices."
]