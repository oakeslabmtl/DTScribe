// C2: Acting Components
instance LightingDriverActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting driver embedded in building control system, modeled in BIM, exposed via Eclipse Ditto twin interfaces for command execution."
]

instance HVACDamperActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC damper embedded in building control system, modeled in BIM, exposed via Eclipse Ditto twin interfaces for command execution."
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in building, transmits readings via Eclipse Hono over MQTT."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in building, transmits readings via Eclipse Hono over MQTT."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Light level sensor embedded in building, transmits readings via Eclipse Hono over MQTT."
    DTDFVocab:producedData LightLevelDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

// C10: Models/Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature readings captured by the embedded sensor, including value in Celsius and timestamp."
    DTDFVocab:inputTo EclipseHonoEnabler
    DTDFVocab:fromData TemperatureDataTransmitted
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy readings captured by the embedded sensor, including occupancy count and timestamp."
    DTDFVocab:inputTo EclipseHonoEnabler
    DTDFVocab:fromData OccupancyDataTransmitted
]

instance LightLevelData : DTDFVocab:Data [
    base:desc "Light level readings captured by the embedded sensor, including lux value and timestamp."
    DTDFVocab:inputTo EclipseHonoEnabler
    DTDFVocab:fromData LightLevelDataTransmitted
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware for secure ingestion of sensor data over MQTT."
    DTDFVocab:enables MonitoringDashboardService, PredictiveAnalyticsService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto platform providing twin interfaces for actuator command execution."
    DTDFVocab:enables ActuatorControlService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine5 enabling immersive visualization of the building and simulation results."
    DTDFVocab:enables ImmersiveVisualizationService
]

instance DomainSpecificBSMEnabler : DTDFVocab:Enabler [
    base:desc "Domain-specific modeling language enabler for building control system descriptions."
    DTDFVocab:enables ControlLogicModelingService
]

// C6: Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real-time monitoring dashboard that visualises live sensor feeds from the building twin."
    DTDFVocab:provides TemperatureAnomalyDetectionInsight, OccupancyAnomalyDetectionInsight, LightLevelAnomalyDetectionInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service that forecasts energy consumption and occupant comfort from historical data."
    DTDFVocab:provides EnergyEfficiencyInsight, ComfortLevelInsight
]

instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Optimization engine that computes optimal lighting schedules to minimize energy."
    DTDFVocab:provides LightingScheduleOptimizationInsight
]

instance HVACOptimizationService : DTDFVocab:Service [
    base:desc "Optimization engine that computes optimal HVAC setpoints for energy and comfort balance."
    DTDFVocab:provides HVACSetpointOptimizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service enabling what-if analysis of building scenarios."
    DTDFVocab:provides SimulationResultInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization service using Unreal Engine5 to render building models and simulation results interactively."
    DTDFVocab:provides ImmersiveVisualizationInsight
]

instance ActuatorControlService : DTDFVocab:Service [
    base:desc "Service that sends actuator commands to building devices through Eclipse Ditto twin interfaces."
    DTDFVocab:provides ActuatorCommandExecutionInsight
]

instance ControlLogicModelingService : DTDFVocab:Service [
    base:desc "Service that handles control logic models embedded in BIM via domain-specific modeling language."
    DTDFVocab:provides ControlLogicInsight
]

// C17: Insights
instance TemperatureAnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting temperature anomalies beyond threshold."
]

instance OccupancyAnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting abnormal occupancy patterns."
]

instance LightLevelAnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting light level anomalies affecting occupant comfort."
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Predictive insight for energy efficiency opportunities."
]

instance ComfortLevelInsight : DTDFVocab:Insight [
    base:desc "Insight assessing occupant comfort based on environmental conditions."
]

instance LightingScheduleOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized lighting schedule recommendation to reduce energy consumption."
]

instance HVACSetpointOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized HVAC setpoints recommendation for cost-efficiency."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Result of simulation analysis providing impact assessment."
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight enabling immersive view of building model and simulation in Unreal Engine5."
]

instance ActuatorCommandExecutionInsight : DTDFVocab:Insight [
    base:desc "Insight confirming actuator command execution status."
]

instance ControlLogicInsight : DTDFVocab:Insight [
    base:desc "Insight on execution of control logic models embedded in BIM."
]

// C17: Actions
instance ManualAdjustmentAction : DTDFVocab:Action [
    base:desc "Manual adjustment action performed by facility manager based on insights."
    DTDFVocab:IsAutomatic false
]

instance AutomatedPolicyUpdateAction : DTDFVocab:Action [
    base:desc "Automated policy update action triggered by optimization insight."
    DTDFVocab:IsAutomatic true
]

// Environment container
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains LightingDriverActuator, HVACDamperActuator, TemperatureSensor, OccupancySensor, LightLevelSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT—e.g., lighting schedules or HVAC set‑points—are sent as twin updates over MQTT to the physical devices via Ditto, which forwards them to the actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, event‑driven real‑time synchronization with sub‑second latency between PT and DT achieved via MQTT broker."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A master building twin aggregates data from multiple device twins; Hono/Ditto orchestrate communication; visualization front‑ends interact via WebSocket/REST; overall architecture relies on MQTT for data flow."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Lifecycle phases covered are Design (BIM creation), Construction (device modeling and commissioning), and Operation (runtime monitoring, analytics, and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity assessed using the Overall Digital Twin Entanglement (ODTE) metric; validation performed by comparing virtual states to physical sensor data; semantic drift mitigated by synchronization mechanisms; uncertainties quantified by sensor error bounds."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Network connection employs MQTT broker in Eclipse Hono; Ditto twin updates exchanged over WebSocket/REST; communications secured with TLS and OAuth2 authentication via Hono."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Ditto and Hono services are containerized microservices deployed on a Kubernetes cluster; Unreal Engine visualizer runs on a dedicated GPU server, interfacing via WebSocket with the Ditto instance."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external building management systems and other digital twins is achieved via Ditto’s event bus and standardized APIs, enabling inter‑system data exchange and joint analytics."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Ownership of data remains with the PT owner; access is controlled through OAuth2 scopes in Hono/Ditto, and personal data are anonymized following GDPR guidelines."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adheres to BIM standards (ISO 19650, IFC schema), IoT middleware standards (MQTT, OCF), Ditto compatibility, and the ODTE metric for entanglement assessment."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Secure MQTT/TLS channels, role‑based access control in Hono/Ditto, runtime safety checks to prevent unsafe command propagation, and authentication‑gated remote command execution to avoid human‑near hazards."
]