// C3: Physical sensing components
instance LightingSensorEmbedded : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor embedded in the building, modeled in BIM and streamed via Eclipse Hono"
    DTDFVocab:producedData LightingSensorDataTx
]

instance OccupancySensorEmbedded : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the building, modeled in BIM and streamed via Eclipse Hono"
    DTDFVocab:producedData OccupancySensorDataTx
]

instance EnergyMeterEmbedded : DTDFVocab:SensingComponent [
    base:desc "Energy meter embedded in the building, modeled in BIM and streamed via Eclipse Hono"
    DTDFVocab:producedData EnergyMeterDataTx
]

// C4: Physical-to-virtual interaction
instance LightingSensorDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensorEmbedded
]

instance OccupancySensorDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensorEmbedded
]

instance EnergyMeterDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeterEmbedded
]

// C10: Data
instance LightingMeasurementData : DTDFVocab:Data [
    base:desc "Stream of illuminance measurements from the lighting sensor"
    DTDFVocab:fromData LightingSensorDataTx
    DTDFVocab:inputTo EclipseDittoTwinPlatform
]

instance OccupancyMeasurementData : DTDFVocab:Data [
    base:desc "Stream of occupancy counts from the occupancy sensor"
    DTDFVocab:fromData OccupancySensorDataTx
    DTDFVocab:inputTo EclipseDittoTwinPlatform
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "Stream of power consumption values from the energy meter"
    DTDFVocab:fromData EnergyMeterDataTx
    DTDFVocab:inputTo EclipseDittoTwinPlatform
]

// C11: Enablers
instance EclipseHonoMessaging : DTDFVocab:Enabler [
    base:desc "Eclipse Hono messaging middleware transports sensor measurements to the twin"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, BuildingOperationOptimizationService, ScenarioSimulationService, AdaptiveLightingRLService
]

instance EclipseDittoTwinPlatform : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital‑twin platform ingests data streams and updates the virtual building representation"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, BuildingOperationOptimizationService, ScenarioSimulationService, AdaptiveLightingRLService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 provides immersive 3‑D visualization of the digital twin"
    DTDFVocab:enables ImmersiveVisualizationService
]

instance ModelDrivenPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering transformation pipeline generates configurations and deploys artifacts"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, BuildingOperationOptimizationService, ScenarioSimulationService, ImmersiveVisualizationService, AdaptiveLightingRLService
]

instance BOREALISReinforcementLearningEngine : DTDFVocab:Enabler [
    base:desc "BOREALIS reinforcement‑learning engine enables adaptive lighting control policies"
    DTDFVocab:enables AdaptiveLightingRLService
]

instance ExtensionPointsFramework : DTDFVocab:Enabler [
    base:desc "Standardized extension points for modular addition of services"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, BuildingOperationOptimizationService, ScenarioSimulationService, ImmersiveVisualizationService, AdaptiveLightingRLService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building performance"
    DTDFVocab:provides EnergyConsumptionInsight, LightingComfortInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy usage and comfort trends"
    DTDFVocab:provides EnergyConsumptionInsight
]

instance BuildingOperationOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of building operation based on sensor data"
    DTDFVocab:provides AdaptiveLightingControlAction
]

instance ScenarioSimulationService : DTDFVocab:Service [
    base:desc "Simulation of building operation scenarios"
    DTDFVocab:provides FacilityManagerInterventionAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3‑D visualization in Unreal Engine 5"
    DTDFVocab:provides LightingComfortInsight
]

instance AdaptiveLightingRLService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based adaptive lighting control (BOREALIS)"
    DTDFVocab:provides AdaptiveLightingControlAction, EnergyConsumptionInsight
]

// C17: Insights
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into building energy consumption"
]

instance LightingComfortInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into lighting comfort levels"
]

// C17: Actions
instance AdaptiveLightingControlAction : DTDFVocab:Action [
    base:desc "Automatic adaptive lighting control policy"
    DTDFVocab:IsAutomatic true
]

instance FacilityManagerInterventionAction : DTDFVocab:Action [
    base:desc "Manual intervention by facility manager based on simulation outcomes"
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance BIMModelEnriched : DTDFVocab:Model [
    base:desc "Static BIM model enriched with device metadata"
    DTDFVocab:inputTo EclipseDittoTwinPlatform, ModelDrivenPipeline
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model for building management system"
    DTDFVocab:inputTo EclipseDittoTwinPlatform, ModelDrivenPipeline
]

instance RLPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning policy model used by BOREALIS"
    DTDFVocab:inputTo BOREALISReinforcementLearningEngine
]

// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in BIM, receives control commands via Hono/Ditto"
]

instance BuildingControlSystemActuator : DTDFVocab:ActingComponent [
    base:desc "General building control system actuator modeled in BIM"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command propagation from the twin to the physical building through Eclipse Ditto to Eclipse Hono, delivering control signals (e.g., lighting set‑points) to actuators defined in the BIM model."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (continuous) synchronization between physical sensors and the twin; no explicit sampling rate is given, but the framework is described as supporting live data exchange."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture where a central DT Framework mediates between enriched BIM, middleware (Hono/Ditto), and the 3‑D visual front‑end; roles (building control engineer, facility manager, DT engineer) interact with the constellation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the full building lifecycle: design (BIM model creation), construction (model validation and deployment), and operation (runtime monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to assess how closely the twin reflects its physical counterpart, providing a quantitative fidelity evaluation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time connectivity is realised through Eclipse Hono (IoT messaging) linked to Eclipse Ditto; the exact transport protocols are not specified in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployed as a modular platform integrating the DT Framework, Hono, Ditto and Unreal Engine; hosting details (cloud/on‑premise) are not described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized extension points allow integration of additional services and external systems, but specific external integrations are not detailed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework builds on BIM as a standardized architectural modelling standard and employs standardized extension points; however, specific standards (e.g., IFC, ISO 19650) are not mentioned."
]