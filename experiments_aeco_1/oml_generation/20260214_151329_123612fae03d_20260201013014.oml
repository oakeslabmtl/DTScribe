// C2: Acting Components
instance LightingController : DTDFVocab:ActingComponent [
    base:desc "BCS actuator configured within BIM for adaptive lighting control via reinforcement learning policies deployed through Eclipse Hono/Ditto middleware"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Building Control System actuator integrated with BIM model for environmental regulation, receiving control commands from DT runtime policies"
]

instance WindowActuator : DTDFVocab:ActingComponent [
    base:desc "IoT-enabled window actuator modeled in BIM with bidirectional communication capabilities for automated climate control optimization"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "IoT sensor deployed across building infrastructure capturing real-time environmental temperature data for energy optimization"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Presence detection sensor integrated with BIM model providing occupancy patterns for space utilization analytics"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient light sensor configured in BIM to monitor natural lighting conditions for adaptive lighting control strategies"
    DTDFVocab:producedData LightLevelDataTransmitted
]

instance EnergyMonitor : DTDFVocab:SensingComponent [
    base:desc "Building energy consumption meter capturing real-time energy usage metrics for operational analytics and optimization"
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMonitor
]

// C10: Models/Data
instance BIMCoreModel : DTDFVocab:Model [
    base:desc "Semantic-rich 3D BIM model representing building geometry, topology, and component relationships enriched with runtime metadata including sensor/actuator configurations"
    DTDFVocab:inputTo ModelDrivenEngineeringFramework
]

instance RuntimeDataLayer : DTDFVocab:Data [
    base:desc "Normalized streaming telemetry from IoT sensors including temperature readings, occupancy status, and control commands"
    DTDFVocab:fromData TemperatureDataTransmitted, OccupancyDataTransmitted, LightLevelDataTransmitted, EnergyConsumptionDataTransmitted
    DTDFVocab:inputTo UnrealEngine5
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Declarative policies for building control systems (e.g., lighting control strategies) defined within BIM and deployed via middleware"
    DTDFVocab:inputTo Ditto
]

instance VisualizationModel : DTDFVocab:Model [
    base:desc "Unreal Engine 5 assets providing interactive 3D rendering of DT with real-time data overlays including sensor heatmaps and control states"
    DTDFVocab:inputTo UnrealEngine5
]

instance ServiceModelPlugin : DTDFVocab:Model [
    base:desc "Modular plugin architecture for analytics and AI-driven insights developed by DT engineers with standardized extension points"
    DTDFVocab:inputTo EclipseHono
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Device connectivity middleware for telemetry ingestion and real-time data exchange with physical sensors and actuators"
]

instance Ditto : DTDFVocab:Enabler [
    base:desc "Runtime configuration framework enabling bidirectional communication between DT and physical building systems"
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Immersive 3D visualization platform integrating real-time data overlays for interactive monitoring of building operations"
]

instance ModelDrivenEngineeringFramework : DTDFVocab:Enabler [
    base:desc "MDE framework automating transformation of BIM models into runtime artifacts including control logic and visualization assets"
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization service providing immersive monitoring of building operations through Unreal Engine"
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Time-series analysis service generating alerts for sensor failures and efficiency drops based on runtime data"
]

instance ControlOptimizationService : DTDFVocab:Service [
    base:desc "AI-driven optimization service suggesting energy-saving adjustments through reinforcement learning policies"
]

instance LifecycleManagementService : DTDFVocab:Service [
    base:desc "Post-occupancy analysis service informing retrofit strategies and long-term maintenance schedules"
]

instance StakeholderCollaborationService : DTDFVocab:Service [
    base:desc "Shared DT interface enabling cross-disciplinary decision-making across architecture, engineering, and facility management"
]

// C17: Insights/Actions
instance OperationalAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Real-time visualizations of energy consumption, occupancy patterns, and environmental conditions for data-driven adjustments"
]

instance RealTimeDataVisualizationAction : DTDFVocab:Action [
    base:desc "Dynamic 3D visualization updates in Unreal Engine showing current sensor readings and system states"
    DTDFVocab:IsAutomatic true
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Alerts for sensor failures and efficiency drops derived from time-series analysis of runtime data"
]

instance MaintenanceAlertAction : DTDFVocab:Action [
    base:desc "Automated notifications to facility management about detected anomalies requiring attention"
    DTDFVocab:IsAutomatic true
]

instance PolicyImprovementInsight : DTDFVocab:Insight [
    base:desc "AI-driven suggestions for optimizing control policies based on post-occupancy data analysis"
]

instance AdaptiveControlAction : DTDFVocab:Action [
    base:desc "Automated adjustment of building systems (e.g., lighting, HVAC) based on reinforcement learning policies"
    DTDFVocab:IsAutomatic true
]

instance RetrofitRecommendationInsight : DTDFVocab:Insight [
    base:desc "Identification of energy-efficient upgrades based on lifecycle analysis of building performance data"
]

instance MaintenanceSchedulingAction : DTDFVocab:Action [
    base:desc "Automated generation of long-term maintenance schedules based on predictive analytics"
    DTDFVocab:IsAutomatic true
]

instance ConsolidatedPerformanceInsight : DTDFVocab:Insight [
    base:desc "Unified views of building performance metrics accessible to all stakeholders for collaborative decision-making"
]

instance CrossDisciplinaryAction : DTDFVocab:Action [
    base:desc "Facilitation of cross-disciplinary discussions through shared DT interfaces"
    DTDFVocab:IsAutomatic false
]

// C12: Environments/Components
instance BuildingInfrastructureEnvironment : DTDFVocab:Environment [
    base:contains PhysicalBuildingComponents
]

instance PhysicalBuildingComponents : DTDFVocab:Component [
    base:desc "Physical assets including sensors, actuators, and building systems integrated with the DT through bidirectional middleware"
    base:isContainedIn BuildingInfrastructureEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Virtual-to-physical interaction is achieved through **runtime control logic** embedded within the DT, which processes data and generates **control commands** (e.g., adjusting lighting levels, HVAC setpoints) to be sent back to physical actuators. The framework supports **declarative control policies** (e.g., adaptive lighting strategies) defined within the BIM model and deployed via the middleware (Hono/Ditto). These commands are transmitted to **physical BCS components** (e.g., smart lighting systems) to enact real-time adjustments. The BOREALIS project demonstrates this interaction by using **reinforcement learning** to optimize energy consumption and visual comfort, where the DT dynamically adjusts control parameters based on sensor feedback and operational goals."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twinning time scale is **real-time**, with continuous synchronization between the physical and virtual systems to ensure operational fidelity. The framework supports **low-latency data exchange** (as implied by the use of Eclipse Hono/Ditto for real-time telemetry) and evaluates synchronization quality using the **Overall Digital Twin Entanglement (ODTE) metric**. While specific sampling rates (e.g., 1-10 seconds or 0.1-1 second) are not explicitly mentioned, the system is designed for **high-frequency data ingestion and processing** to enable responsive control and monitoring."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated as a **service-oriented architecture** with the following components:
   - **Core DT Hub**: Centralized representation of the building infrastructure, integrating **BIM semantics**, **runtime data**, and **control logic**.
   - **Middleware Layer**: **Eclipse Hono/Ditto** facilitates **bidirectional communication** between the DT and physical devices, ensuring **real-time synchronization**.
   - **Visualization Layer**: **Unreal Engine 5** provides an interactive interface for stakeholders to monitor and interact with the DT.
   - **Service Layer**: **Modular plugins** (e.g., analytics, optimization) developed by DT engineers, connected via standardized extension points.
   - **Device Twins**: **Individual device representations** (e.g., sensor/actuator twins) managed by Ditto, contributing to the overarching DT. The constellation supports **scalable deployment** across heterogeneous building systems while maintaining **interoperability** through standardized protocols (e.g., MQTT over Hono)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans **all life-cycle stages** of the building infrastructure, from **design and construction** (where BIM models are enriched with runtime semantics) to **operation and refurbishment** (where the DT evolves with post-occupancy data). The framework supports:
   - **As-designed phase**: Initial BIM model enrichment with device configurations and control logic.
   - **As-manufactured phase**: Validation and commissioning of physical devices via automated middleware integration.
   - **As-operated phase**: Continuous synchronization with runtime data, iterative optimization (e.g., BOREALIS’s reinforcement learning), and stakeholder-driven updates. The DT also supports **adaptive evolution** (e.g., adding new services or sensors) without full redeployment, enabling long-term compatibility with evolving building systems."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
   - **Semantic Alignment**: The BIM model’s **rich semantics** (e.g., spatial relationships, component properties) are preserved in the DT, reducing **semantic drift** between virtual and physical representations.
   - **Real-Time Synchronization**: **Eclipse Hono/Ditto** enforce **low-latency data exchange**, with **ODTE metric** evaluations to quantify synchronization accuracy.
   - **Validation Mechanisms**: Automated checks (e.g., model consistency validation) ensure the DT’s **logical correctness** and **data integrity**. The framework also supports **uncertainty quantification** (e.g., sensor noise, model inaccuracies) to inform decision-making.
   - **Post-Occupancy Refinement**: The DT evolves using **runtime data** (e.g., BOREALIS’s iterative policy optimization) to adapt to real-world conditions, improving long-term validity. **Verification and validation (V&V) protocols** are applied at each deployment stage to mitigate errors."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT system uses **Eclipse Hono** for device connectivity and telemetry ingestion, enabling bidirectional communication between physical sensors/actuators and the DT. While specific protocols like **MQTT** or **RESTful APIs** are not explicitly mentioned, the middleware layer (Hono/Ditto) supports **standardized connectivity frameworks** for real-time data exchange. The system is designed for **low-latency, high-throughput** interactions to ensure responsive control and monitoring."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT system is designed for **integration with heterogeneous systems**, though specific examples (e.g., ERP/CRM, cloud platforms) are not mentioned. The framework supports **standardized extension points** for connecting to external systems, enabling data exchange with other digital platforms (e.g., IoT gateways, analytics engines). The middleware layer (Eclipse Hono/Ditto) facilitates interoperability with diverse data sources, ensuring seamless integration across the AECO ecosystem."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT system adheres to **AECO-specific standards**, particularly **Building Information Modeling (BIM)**, which provides a unified semantic framework for data representation. The framework also supports **standardized integration frameworks** (e.g., middleware protocols for real-time data exchange) to ensure interoperability. While specific standards like **IFC, COBie, OPC UA, or MQTT** are not explicitly mentioned, the use of **Eclipse Hono/Ditto** aligns with industry-standard connectivity solutions."
]