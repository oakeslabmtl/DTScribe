]

instance RealTimeSynchronizationInsight : DTDFVocab:Insight [
    base:desc "Confirmation of continuous bidirectional synchronization between physical and digital twins, ensuring data consistency and operational alignment."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insights derived from immersive visualization of Digital Twin models with real-time operational overlays, enabling stakeholders to explore building performance and make data-driven decisions."
]

instance CollaborativeDecisionMakingAction : DTDFVocab:Action [
    base:desc "Facilitation of multi-stakeholder decision-making through immersive visualization and shared access to Digital Twin data, enabling aligned strategic planning and operational adjustments."
