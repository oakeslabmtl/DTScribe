// C2: Acting Components
instance BimIntegratedHVACActuator : DTDFVocab:ActingComponent [
    base:desc "Physical actuator integrated within BIM environment for HVAC system control, configured via enriched BIM models with device metadata and control logic definitions by Building Control Engineers. Supports remote operation through Digital Twin framework with device-specific actuation ranges and safety constraints enforced via runtime validation."
]

instance BimIntegratedLightingActuator : DTDFVocab:ActingComponent [
    base:desc "Physical actuator integrated within BIM environment for lighting system control, configured via enriched BIM models with device metadata and control logic definitions by Building Control Engineers. Enables remote dimming, scheduling, and occupancy-based control through Digital Twin framework."
]

instance BimIntegratedShadeActuator : DTDFVocab:ActingComponent [
    base:desc "Physical actuator integrated within BIM environment for motorized window shades, configured via enriched BIM models with device metadata and control logic definitions by Building Control Engineers. Supports automated positioning based on environmental conditions and occupancy patterns."
]

// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "IoT-based temperature sensor integrated within BIM environment, representing spatial distribution via BIM-based placement. Part of enriched BIM model with device metadata for real-time environmental monitoring and control logic synchronization."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "IoT-based humidity sensor integrated within BIM environment, representing spatial distribution via BIM-based placement. Part of enriched BIM model with device metadata for real-time environmental monitoring and control logic synchronization."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "IoT-based occupancy sensor integrated within BIM environment, representing spatial distribution via BIM-based placement. Part of enriched BIM model with device metadata for real-time space utilization monitoring and control logic synchronization."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance StructuralHealthMonitoringSensor : DTDFVocab:SensingComponent [
    base:desc "Advanced IoT sensor for structural health monitoring integrated within BIM environment, representing spatial distribution via BIM-based placement. Captures vibration, strain, and deformation data for predictive maintenance and structural integrity analysis."
    DTDFVocab:producedData StructuralHealthDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Smart meter integrated within BIM environment for energy consumption monitoring, representing spatial distribution via BIM-based placement. Captures real-time energy usage data for HVAC systems, lighting, and other building services."
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance StructuralHealthDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralHealthMonitoringSensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance BimModelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BimGeometricModel
]

instance DeviceMetadataDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DeviceMetadataIntegration
]

// C10: Models/Data
instance BimGeometricModel : DTDFVocab:Model [
    base:desc "Static 3D geometric model derived from BIM (Autodesk Revit, Graphisoft ArchiCAD, or Bentley Systems) representing spatial configurations, structural elements, and facility layouts. Serves as foundational representation for enriched Digital Twin models."
    DTDFVocab:inputTo BimEnrichmentEnabler
]

instance BimBehavioralModel : DTDFVocab:Model [
    base:desc "Dynamic behavioral model defined by Building Control Engineers within BIM environment, representing control logic, device configurations, and operational workflows for HVAC, lighting, and other building systems."
    DTDFVocab:inputTo ControlLogicSimulationEnabler
]

instance BimAnalyticalModel : DTDFVocab:Model [
    base:desc "Performance simulation model generated via Model-Driven Engineering principles from enriched BIM representations, enabling energy consumption analysis, structural load testing, and operational optimization scenarios."
    DTDFVocab:inputTo PerformanceSimulationEnabler
]

instance EnrichedBimModel : DTDFVocab:Model [
    base:desc "Augmented BIM model incorporating device metadata (sensors, actuators, controllers) and semantic annotations to create unified semantic foundation for Digital Twin deployment. Generated through automated MDE pipelines."
    DTDFVocab:inputTo DigitalTwinDeploymentEnabler
]

instance OperationalDataStore : DTDFVocab:Data [
    base:desc "Centralized repository for real-time operational data including sensor readings, environmental metrics, equipment status, and facility management records. Synchronized with physical twin via standardized extension points."
    DTDFVocab:fromData BimModelDataTransmitted, DeviceMetadataDataTransmitted, TemperatureDataTransmitted, HumidityDataTransmitted, OccupancyDataTransmitted, StructuralHealthDataTransmitted, EnergyConsumptionDataTransmitted
    DTDFVocab:inputTo DataIntegrationEnabler
]

instance HistoricalPerformanceData : DTDFVocab:Data [
    base:desc "Historical dataset containing past operational performance metrics, maintenance records, and energy consumption patterns stored in data lake (AWS S3 or Azure Data Lake) for trend analysis and predictive modeling."
