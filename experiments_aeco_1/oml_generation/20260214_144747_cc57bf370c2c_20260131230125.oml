    DTDFVocab:inputTo PredictiveAnalyticsEnabler
]

// C11: Enablers
instance BimEnrichmentEnabler : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering pipeline that extracts and augments BIM models with device metadata (sensors, actuators, controllers) and semantic annotations to create enriched representations for Digital Twin deployment."
    DTDFVocab:enables BimToDigitalTwinTransformationService
]

instance ControlLogicSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Physics-based simulation engine (ANSYS Simcenter or AnyLogic) that executes behavioral models defined in BIM environment, enabling validation of control logic and device configurations before physical deployment."
    DTDFVocab:enables ControlLogicValidationService
]

instance PerformanceSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Digital Twin simulation platform (Siemens Digital Twin Hub or Dassault 3DEXPERIENCE) that executes analytical models to perform energy consumption analysis, structural load testing, and operational optimization scenarios."
    DTDFVocab:enables PerformanceOptimizationService
]

instance DigitalTwinDeploymentEnabler : DTDFVocab:Enabler [
    base:desc "Automated deployment framework that generates deployable Digital Twin artifacts from enriched BIM models with minimal manual intervention, ensuring seamless integration of geometric, behavioral, and analytical models."
    DTDFVocab:enables DigitalTwinRuntimeService
]

instance DataIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Modular data integration pipeline using ETL tools (Talend or Informatica) and API gateways (MuleSoft) to unify BIM models, IoT sensor data, and facility management systems into standardized operational data store."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveMaintenanceService
]

instance PredictiveAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "AI/ML platform (IBM Watson IoT or SAP Predictive Analytics) that processes historical and real-time data to generate time-series forecasts, anomaly detection, and remaining useful life predictions for building components."
    DTDFVocab:enables PredictiveMaintenanceService, EnergyOptimizationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Immersive visualization platform (Autodesk Forge or Unity) that renders 3D/4D/5D models with real-time operational overlays, enabling AR/VR exploration and collaborative decision-making across stakeholders."
    DTDFVocab:enables DigitalTwinVisualizationService
]

instance IoTSensorIngestionEnabler : DTDFVocab:Enabler [
    base:desc "IoT platform (AWS IoT Core or Microsoft Azure IoT Hub) that ingests real-time sensor data via OPC UA and MQTT protocols, preprocessing and validating data before synchronization with Digital Twin."
    DTDFVocab:enables RealTimeMonitoringService
]

// C6: Services
instance BimToDigitalTwinTransformationService : DTDFVocab:Service [
    base:desc "Model-Driven Engineering service that transforms static BIM models into enriched Digital Twin representations by adding device metadata, semantic annotations, and control logic definitions."
    DTDFVocab:provides BimEnrichmentInsight, DigitalTwinFoundationAction
]

instance ControlLogicValidationService : DTDFVocab:Service [
    base:desc "Simulation service that validates control logic and device configurations defined in BIM environment against physical constraints and operational requirements before deployment."
    DTDFVocab:provides ControlLogicValidationInsight
]

instance PerformanceOptimizationService : DTDFVocab:Service [
    base:desc "Analytical service that executes performance simulations to identify energy consumption patterns, structural vulnerabilities, and operational inefficiencies for targeted optimization."
    DTDFVocab:provides PerformanceAnalysisInsight, OptimizationRecommendationAction
]

instance DigitalTwinRuntimeService : DTDFVocab:Service [
    base:desc "Runtime execution framework that maintains real-time synchronization between physical and digital twins, enabling bidirectional control and monitoring of building systems."
    DTDFVocab:provides RealTimeSynchronizationInsight, OperationalControlAction
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring service that aggregates and visualizes real-time operational data from sensors and building systems to track performance metrics and detect anomalies."
    DTDFVocab:provides OperationalMetricsInsight, AnomalyDetectionInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive analytics service that forecasts equipment failures and degradation patterns using machine learning models trained on historical and real-time operational data."
    DTDFVocab:provides MaintenanceAlertInsight, PredictiveRepairAction
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that applies model predictive control to dynamically adjust HVAC systems, lighting, and other building services for energy efficiency while maintaining occupant comfort."
    DTDFVocab:provides EnergyConsumptionInsight, OptimizationRecommendationAction
]

instance DigitalTwinVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization service that renders 3D/4D/5D Digital Twin models with real-time operational overlays, enabling stakeholders to explore building performance and make data-driven decisions."
    DTDFVocab:provides VisualizationInsight
]

// C17: Insights/Actions
instance BimEnrichmentInsight : DTDFVocab:Insight [
    base:desc "Insight into the enriched BIM model's semantic completeness and device integration readiness, validating that all sensors, actuators, and controllers are properly configured within the Digital Twin foundation."
]

instance DigitalTwinFoundationAction : DTDFVocab:Action [
    base:desc "Automated deployment of Digital Twin foundation from enriched BIM models, establishing the unified semantic framework for subsequent model transformations and runtime synchronization."
    DTDFVocab:IsAutomatic true
]

instance ControlLogicValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results for control logic and device configurations, identifying potential operational conflicts or physical constraints that could impact system performance."
]

instance PerformanceAnalysisInsight : DTDFVocab:Insight [
    base:desc "Comprehensive analysis of building performance metrics including energy consumption, structural integrity, and operational efficiency derived from analytical simulations."
]

instance OperationalMetricsInsight : DTDFVocab:Insight [
    base:desc "Real-time operational metrics including temperature, humidity, occupancy levels, and equipment status, providing immediate feedback on building system performance."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of deviations from normal operational patterns in sensor data, indicating potential equipment failures or environmental issues requiring attention."
]

instance MaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive alerts indicating impending equipment failures or degradation patterns based on machine learning models trained on historical and real-time operational data."
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Detailed analysis of energy consumption patterns across building systems, identifying opportunities for optimization and cost reduction."
]

