// === Physical sensing components and data flow ===
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor embedded in the building measuring illumination levels."
    DTDFVocab:producedData LightSensorDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the building measuring ambient temperature."
    DTDFVocab:producedData TemperatureSensorDataTransmitted
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector embedded in the building detecting presence of occupants."
    DTDFVocab:producedData OccupancyDetectorDataTransmitted
]

instance BuildingIoTNode : DTDFVocab:SensingComponent [
    base:desc "Generic IoT node aggregating miscellaneous telemetry such as humidity or CO₂."
    DTDFVocab:producedData IoTNodeDataTransmitted
]

// Data transmitted from sensors
instance LightSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance TemperatureSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDetectorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance IoTNodeDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingIoTNode
]

// Data ingested into Ditto
instance LightSensorData : DTDFVocab:Data [
    base:desc "Latest light sensor reading with timestamp."
    DTDFVocab:fromData LightSensorDataTransmitted
    DTDFVocab:inputTo DittoReplication
]

instance TemperatureSensorData : DTDFVocab:Data [
    base:desc "Latest temperature sensor reading with timestamp."
    DTDFVocab:fromData TemperatureSensorDataTransmitted
    DTDFVocab:inputTo DittoReplication
]

instance OccupancyDetectorData : DTDFVocab:Data [
    base:desc "Latest occupancy detection status with timestamp."
    DTDFVocab:fromData OccupancyDetectorDataTransmitted
    DTDFVocab:inputTo DittoReplication
]

instance IoTNodeData : DTDFVocab:Data [
    base:desc "Aggregated miscellaneous telemetry from generic IoT node."
    DTDFVocab:fromData IoTNodeDataTransmitted
    DTDFVocab:inputTo DittoReplication
]

// === Models and procedural data ===
instance IFCBIMModel : DTDFVocab:Model [
    base:desc "BIM model in IFC format for the living laboratory building."
    DTDFVocab:inputTo DittoReplication
]

instance MDERuntimeDescriptor : DTDFVocab:Model [
    base:desc "Runtime interface descriptor generated via MDE for the twin."
    DTDFVocab:inputTo DittoReplication
]

instance SensorActuatorMetadata : DTDFVocab:Model [
    base:desc "Metadata repository for all sensor and actuator devices."
    DTDFVocab:inputTo DittoReplication
]

instance ControlLogicProceduralModel : DTDFVocab:Model [
    base:desc "Procedural model representing control logic for building systems."
    DTDFVocab:inputTo DittoReplication
]

// === Actuating components (physical acting components) ===
instance ProgrammableLightingFixture : DTDFVocab:ActingComponent [
    base:desc "Programmable lighting fixture that can receive dimming and color commands."
]

instance HvacVent : DTDFVocab:ActingComponent [
    base:desc "HVAC vent capable of opening/closing and airflow regulation."
]

instance BuildingControlSystemComponent : DTDFVocab:ActingComponent [
    base:desc "Building control system component that implements programmed logic."
]

// === Enablers and tooling ===
instance MDEDescriptorGenerationService : DTDFVocab:Service [
    base:desc "Service for generating runtime interface descriptors via MDE tooling."
]

instance MDETool : DTDFVocab:Enabler [
    base:desc "Model-to-text generation tooling for creating runtime interface descriptors."
    DTDFVocab:enables MDEDescriptorGenerationService
] 

instance HonoMiddleware : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware for MQTT telemetry ingestion."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, BuildingPerformanceSimulationService
]

instance DittoReplication : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto data replication to maintain twin state."
    DTDFVocab:enables BuildingPerformanceSimulationService, EnergyOptimizationService, KnowledgeBasedTaskPlanningService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3D visualization of building performance."
    DTDFVocab:enables Immersive3DVisualizationService
]

instance HonoDittoOrchestrator : DTDFVocab:Enabler [
    base:desc "Custom orchestrator integrating Eclipse Hono and Ditto configurations."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, BuildingPerformanceSimulationService, EnergyOptimizationService, KnowledgeBasedTaskPlanningService, Immersive3DVisualizationService
]

instance RevitAuthoringTool : DTDFVocab:Enabler [
    base:desc "Autodesk Revit authoring tool for building BIM creation."
]

// === Services ===
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring dashboards powered by reported sensor data."
    DTDFVocab:provides DiagnosticReportInsight, OccupancyDashboardInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for identifying maintenance needs and forecasting energy usage."
    DTDFVocab:provides PredictiveMaintenanceAlertInsight, EnergyConsumptionForecastInsight
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance based on procedural control logic."
    DTDFVocab:provides BuildingPerformanceSimulationResultInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimisation of energy consumption through data‑driven recommendations."
    DTDFVocab:provides EnergyOptimizationRecommendationInsight, ApplyEnergyOptimizationAction
]

instance KnowledgeBasedTaskPlanningService : DTDFVocab:Service [
    base:desc "Knowledge‑based task planning for facility management."
    DTDFVocab:provides TaskPlanningRecommendationInsight
]

instance Immersive3DVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D visualization rendered by Unreal Engine 5."
    DTDFVocab:provides Immersive3DVisualizationInsight
]

// === Insights and Actions ===
instance DiagnosticReportInsight : DTDFVocab:Insight [
    base:desc "Diagnostic report summarising current building system health."
]

instance OccupancyDashboardInsight : DTDFVocab:Insight [
    base:desc "Dashboard showing occupancy levels over time."
]

instance PredictiveMaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when predictive analytics indicate impending maintenance."
]

instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of energy consumption for upcoming periods."
]

instance BuildingPerformanceSimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation results depicting expected building performance metrics."
]

instance EnergyOptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation for adjusting control parameters to optimise energy usage."
]

instance TaskPlanningRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation for task scheduling based on knowledge‑based planning."
]

instance Immersive3DVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time 3D rendering of building systems in Unreal Engine 5."
]

instance ApplyEnergyOptimizationAction : DTDFVocab:Action [
    base:desc "Automated action to adjust HVAC and lighting settings for energy optimisation."
    DTDFVocab:IsAutomatic true
]

// === Physical components and environment ===
instance LightingFixtureComponent : DTDFVocab:Component [
    base:desc "Component representing a lighting fixture within the building."
]

instance HvacVentComponent : DTDFVocab:Component [
    base:desc "Component representing an HVAC vent within the building."
]

instance BuildingControlSystemComponentComp : DTDFVocab:Component [
    base:desc "Component representing the building control system."
]

instance BuildingEnvironment : DTDFVocab:Environment [
    base:desc "Environment encapsulating the building's physical system."
    base:contains LightingFixtureComponent, HvacVentComponent, BuildingControlSystemComponentComp
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control messages originating from the DT’s runtime services that are sent back to the building’s actuators through Hono’s MQTT topics and transmitted via Ditto’s device handlers, enabling state changes in lighting, HVAC, etc."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular service‑oriented architecture where a central Twin Engine aggregates BIM‑derived models, communicates with physical devices through Hono/Ditto, provides visualization via Unreal Engine, and exposes RESTful services for external stakeholders."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the complete lifecycle: design (ideal BIM), construction (manufactured elements), and operation (runtime monitoring and optimization)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The overall Digital Twin Entanglement (ODTE) metric is employed to quantify the alignment between the digital and physical representations, coupled with runtime verification of sensor data integrity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Network communication is based on MQTT over TLS for secure data exchange via Eclipse Hono, with Ditto using WebSocket endpoints for real‑time synchronization and JSON payloads."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Containerized deployment orchestrated by Kubernetes, with persistent storage for twin registries and policy definitions, and scalable MQTT broker instances for high‑throughput telemetry."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external BIM and building automation systems through standard REST APIs, IFC exchange, and the Hono/Ditto pub/sub middleware to enable cross‑system data flow."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership resides with the building owner; the DT service provider processes data under strict anonymity policies, ensuring that personal or sensitive information is not disclosed beyond the authorized platform."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to IFC for BIM interchange, ETS/ISO 17025 for sensor calibration, and ETSI standards for MQTT to guarantee interoperability across vendors."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Secure MQTT/TLS channels, role‑based access control in Ditto, audit logging of all commands, and runtime safety checks to prevent unsafe actuator states during remote operation."
]