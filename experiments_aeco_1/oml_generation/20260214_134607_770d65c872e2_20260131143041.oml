// Sensing component for lighting telemetry
instance LightingLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Provides telemetry streams of lighting levels gathered from embedded dimmer actuators in the building’s lighting infrastructure"
    DTDFVocab:producedData LightingLevelDataTransmitted
]

// Data transmitted from the sensor
instance LightingLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingLevelSensor
    base:desc "Streaming data of lighting levels produced by LightingLevelSensor for real‑time monitoring"
]

// Aggregated lighting data stored for analytics
instance LightingLevelData : DTDFVocab:Data [
    base:desc "Aggregated lighting telemetry data stored in the digital twin for monitoring, predictive maintenance, and optimization"
    DTDFVocab:inputTo DittoTwinEnabler
    DTDFVocab:inputTo HonoMessagingEnabler
    DTDFVocab:fromData LightingLevelDataTransmitted
]

// BIM model enriched with control metadata
instance IFCBasedBIMModel : DTDFVocab:Model [
    base:desc "IFC‑based BIM geometry enriched with control metadata describing lighting fixtures and other building systems"
    DTDFVocab:inputTo DittoTwinEnabler
    DTDFVocab:inputTo HonoMessagingEnabler
]

// Acting component: lighting dimmer actuator
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Embedded dimmer actuator that allows the digital twin to adjust light levels in real time"
]

// Enablers
instance HonoMessagingEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono messaging services that ingest telemetry streams and expose MQTT topics for digital twin integration"
    DTDFVocab:enables MonitoringDashboardService, EnergyForecastingService, LightingScheduleOptimizationService
]

instance DittoTwinEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin abstraction services that store static BIM geometry and dynamic state from telemetry streams"
    DTDFVocab:enables MonitoringDashboardService, EnergyForecastingService, LightingScheduleOptimizationService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 rendering pipeline for high‑fidelity 3D immersive visualizations of the building interior"
    DTDFVocab:enables ImmersiveVisualizationService
]

// Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Realtime monitoring dashboards displaying lighting telemetry and integrated predictive alerts"
    DTDFVocab:provides EnergySavingScheduleInsight, OccupantComfortReport, PredictiveMaintenanceAlert
]

instance EnergyForecastingService : DTDFVocab:Service [
    base:desc "Predictive analytics service forecasting energy consumption using machine learning models on stored telemetry data"
    DTDFVocab:provides EnergyConsumptionForecastInsight
]

instance LightingScheduleOptimizationService : DTDFVocab:Service [
    base:desc "Optimization engine scheduling lighting dimmers via reinforcement learning to maximize energy savings and occupant comfort"
    DTDFVocab:provides LightingScheduleOptimizationAction, RetrofitCostBenefitAnalysis
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D visualization service that renders the building in Unreal Engine 5 for stakeholder engagement and decision support"
    DTDFVocab:provides ImmersiveVisualizationAction
]

// Insights
instance EnergySavingScheduleInsight : DTDFVocab:Insight [
    base:desc "Insight derived from optimized lighting schedules that indicate potential energy savings and cost reductions"
]

instance PredictiveMaintenanceAlert : DTDFVocab:Insight [
    base:desc "Alert generated when predictive analytics indicate imminent failure of lighting or HVAC components"
]

instance OccupantComfortReport : DTDFVocab:Insight [
    base:desc "Report summarizing occupant comfort metrics derived from telemetry and user feedback data"
]

instance RetrofitCostBenefitAnalysis : DTDFVocab:Insight [
    base:desc "Cost‑benefit analysis for retrofit proposals based on projected energy savings and investment returns"
]

instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of future energy consumption based on historical telemetry and predictive modeling"
]

// Actions
instance LightingScheduleOptimizationAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting dimmers to follow an optimized schedule"
    DTDFVocab:IsAutomatic true
]

instance ImmersiveVisualizationAction : DTDFVocab:Action [
    base:desc "Trigger to launch an immersive 3D walkthrough of the building scenario in Unreal Engine 5"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT—such as lighting dimming directives or HVAC set‑point adjustments—are published through Ditto to the Hono broker and routed to the building’s control layer, enabling the BCS to enact the desired state changes."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, near real‑time synchronization; updates are propagated to the DT as soon as sensor data arrives and control commands are acknowledged."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where the building‑level twin orchestrates sensor and actuator twins via Ditto, Hono broker, and a real‑time control engine. Service plug‑ins (e.g., RL optimizer, anomaly detector) subscribe to twin events and publish new state. The constellation provides end‑to‑end data flow from PT to DT and back."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle covers (1) Design – BIM representation of intended (ideal) building; (2) Construction – real‑time data collection during construction; (3) Commissioning – validation of control logic; (4) Operation – ongoing runtime data streaming and optimization; (5) Renovation – updating the BIM and DT with as‑built modifications. Each stage leverages the same model‑to‑text transformation pipeline."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Semantic drift is mitigated by periodic re‑validation of BIM against physical sensor data; the ODTE metric quantifies the entanglement between DT and PT; validation of control logic is performed through simulation in Unreal Engine before live deployment; uncertainty is modeled via stochastic input ranges for sensors."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication uses the Eclipse Hono and Ditto protocols; the DT communicates with physical devices via device twins and brokers, without specifying low‑level transport protocols in the text."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The twin framework exposes standardized APIs that enable integration with external systems (e.g., HVAC BMS, energy management platforms). The use of open protocols and data models (e.g., MQTT, JSON, IFC) facilitates horizontal interoperability across heterogeneous infrastructure components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture adheres to AECO standards: BIM/IFC for geometric and semantic data, Eclipse Ditto and Hono for IoT integration (standardized MQTT/HTTPS APIs), and Unreal Engine for visualization. Extension points are defined to conform to future open standards."
]