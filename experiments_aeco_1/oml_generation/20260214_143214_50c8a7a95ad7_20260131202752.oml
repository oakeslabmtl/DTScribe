// C2: Acting Components
instance OccupancyLightingActuator : DTDFVocab:ActingComponent [
    base:desc "Building control actuator for lighting dimming based on occupancy patterns from BIM-enriched device metadata"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Building control actuator for HVAC system adjustments integrating with real-time environmental sensor data"
]

instance EnergyOptimizationActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for automated energy optimization policies using reinforcement learning in BOREALIS framework"
]

// C3: Physical Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy occupancy detector embedded in building infrastructure with BIM-enriched tenant ID metadata"
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental temperature/humidity sensor feeding live operational data to DT via Ditto middleware"
]

instance LightingLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting level sensor measuring occupancy patterns and energy consumption metrics"
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Energy consumption sensor providing real-time operational data for predictive analytics"
]

// C4: Data Transmission
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance LightingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingLevelSensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

// C10: Models/Data
instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "3D spatial and functional BIM representation of building components (rooms, lighting fixtures) with control logic definitions"
]

instance RuntimeMetadataModel : DTDFVocab:Model [
    base:desc "Extracted runtime metadata from BIM for device configurations (sensor/actuator endpoints), control logic, and middleware integration"
]

instance OccupancyPatternData : DTDFVocab:Data [
    base:desc "Derived occupancy patterns from real-time sensor data for adaptive control policies"
    DTDFVocab:fromData OccupancyDataTransmitted
]

instance EnergyConsumptionReport : DTDFVocab:Data [
    base:desc "Energy efficiency reports generated from aggregated sensor data for facility management"
    DTDFVocab:fromData EnergyDataTransmitted
]

instance ControlParameterUpdate : DTDFVocab:Data [
    base:desc "Updated control parameters for HVAC/lighting systems generated by DT services"
    DTDFVocab:fromData EnergyDataTransmitted
]

// C11: Enablers
instance BIMEnrichmentTool : DTDFVocab:Enabler [
    base:desc "Autodesk Revit or similar BIM tool for device modeling and control logic definition"
]

instance ModelDrivenEngineeringTool : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering framework automating BIM semantics extraction and runtime interface generation (Hono/Ditto configurations)"
]

instance EclipseHonoMiddleware : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware enabling real-time bidirectional communication between physical devices and DT"
    DTDFVocab:enables PredictiveAnalyticsService
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 platform for immersive DT visualization and interactive monitoring dashboards"
]

instance BOREALISReinforcementLearning : DTDFVocab:Enabler [
    base:desc "BOREALIS framework implementing reinforcement learning for adaptive control policies"
    DTDFVocab:enables PredictiveAnalyticsService
]

instance CustomAnalyticsPlugin : DTDFVocab:Enabler [
    base:desc "Standardized extension point for domain-specific IoT analytics plugins"
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Facility manager dashboard providing real-time visualization of operational metrics (energy consumption, occupancy patterns)"
    DTDFVocab:provides FacilityManagerDashboard
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Energy optimization service using reinforcement learning in BOREALIS to optimize lighting/energy policies"
    DTDFVocab:provides AdaptiveControlPolicy
    DTDFVocab:enables BOREALISReinforcementLearning
]

instance InteractiveControlService : DTDFVocab:Service [
    base:desc "Interactive control interface for facility managers to adjust building systems via DT"
    DTDFVocab:provides ManualControlInterface
]

// C17: Insights/Actions
instance FacilityManagerDashboard : DTDFVocab:Insight [
    base:desc "Immersive visualization interface showing real-time operational metrics (energy consumption, occupancy patterns) for facility management"
]

instance AdaptiveControlPolicy : DTDFVocab:Insight [
    base:desc "Reinforcement learning-generated control policies for optimized lighting/energy management based on post-occupancy sensor data"
]

instance ManualControlInterface : DTDFVocab:Insight [
    base:desc "Interactive dashboard allowing facility managers to manually adjust building systems via DT"
]

instance MaintenanceAlertService : DTDFVocab:Action [
    base:desc "AI-driven maintenance alerts generated from IoT analytics for predictive maintenance scheduling"
    DTDFVocab:IsAutomatic true
]

instance EnergyEfficiencyReport : DTDFVocab:Action [
    base:desc "Generated energy efficiency reports from aggregated sensor data for operational improvement"
    DTDFVocab:IsAutomatic true
]

instance ControlParameterUpdateAction : DTDFVocab:Action [
    base:desc "Automated updates to control parameters for HVAC/lighting systems based on DT analysis"
    DTDFVocab:IsAutomatic true
]

instance MaintenanceScheduleUpdate : DTDFVocab:Action [
    base:desc "Updated maintenance schedules derived from predictive analytics and IoT data"
    DTDFVocab:IsAutomatic true
]

// C12: Environment
instance BuildingInfrastructureEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, TemperatureSensor, LightingLevelSensor,
                 EnergyConsumptionSensor, OccupancyLightingActuator,
                 HVACActuator, EnergyOptimizationActuator
]

instance LivingLabEnvironment : DTDFVocab:Environment [
    base:contains BuildingBIMModel, RuntimeMetadataModel,
            OccupancyPatternData, EnergyConsumptionReport,
            ControlParameterUpdate, FacilityManagerDashboard,
            RealTimeMonitoringService, PredictiveAnalyticsService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Facilitates **control signal propagation** from the DT to physical actuators via middleware (Eclipse Hono/Ditto), enabling automated adjustments to building systems (e.g., adaptive lighting, HVAC optimization). The framework automates runtime interface generation from BIM models to ensure seamless integration with legacy BCS systems, minimizing manual configuration."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Operates on a **real-time to near-real-time** scale, with synchronization rates aligned to operational needs (e.g., sensor refresh cycles of milliseconds to seconds for lighting control). The framework prioritizes **low-latency data exchange** to ensure responsive DT-to-physical interactions, particularly for critical control systems (e.g., adaptive lighting in BOREALIS)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A **centralized DT architecture** with a **service-oriented design**, where the DT is orchestrated as a unified system comprising:
  - A **core DT layer** (hosted on the DT framework) integrating BIM models, middleware, and visualization tools.
  - **Modular services** (e.g., lighting control, energy analytics) deployed via extension points, enabling scalability.
  - **Bidirectional communication** between the DT and physical building via Hono/Ditto, ensuring real-time synchronization across the constellation. The Living Lab case study demonstrates this as a **single DT instance** with potential sub-twins for specialized functions."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the **entire building lifecycle**:
  1. **Design Phase**: BIM models are enriched with device metadata and control logic (e.g., lighting automation rules).
  2. **Construction Phase**: Physical devices are configured and integrated with the DT via middleware (Eclipse Hono/Ditto).
  3. **Operation Phase**: Real-time monitoring, adaptive control (e.g., BOREALIS reinforcement learning), and custom services are deployed. The DT evolves dynamically via runtime configuration management, enabling iterative improvements (e.g., energy optimization policies)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Ensures **high fidelity** through:
  - **Overall Digital Twin Entanglement (ODTE) metric**: Quantifies the alignment between the DT and physical building, validating real-time synchronization.
  - **Verification/Validation**: Automated checks during model transformation to detect semantic drift (e.g., mismatches between BIM and runtime data).
  - **Uncertainty Handling**: Assumes real-time data streams (e.g., sensor inputs) are processed with minimal latency to preserve fidelity.
  The framework emphasizes **dynamic synchronization** to mitigate drift between static BIM models and operational data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Established via:
  - **Network Protocols**: Middleware (Eclipse Hono/Ditto) uses standardized protocols for data exchange (e.g., MQTT, WebSockets).
  - **Architecture**: A **layered system** with:
    1. **BIM-to-Runtime Interface Layer**: Transforms BIM models into runtime configurations.
    2. **Middleware Layer**: Handles real-time data streaming (Hono/Ditto).
    3. **Visualization Layer**: Unreal Engine for interactive DT visualization.
  The connection ensures **low-latency, bidirectional communication** between physical devices and the DT."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployed as a **scalable, cloud-native DT platform** with:
  - **Modular Hosting**: Extension points allow integration with existing IT infrastructures (e.g., cloud services, on-premise servers).
  - **Runtime Artifacts**: Generated automatically from BIM models (e.g., Hono/Ditto configurations) to reduce manual effort.
  - **Unreal Engine Integration**: Hosted within the DT framework for interactive visualization, ensuring seamless user experience."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Enables integration with:
  - **External Systems**: Other DTs or IoT platforms via standardized APIs (e.g., Hono/Ditto middleware).
  - **BIM Standards**: Adheres to AECO-specific standards (e.g., IFC, COBIE) to ensure interoperability with legacy systems.
  - **Stakeholder Collaboration**: Facilitates real-time data sharing among **Building Control Engineers**, **Facility Managers**, and **DT Engineers** via unified interfaces."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not explicitly detailed in the documents, but the framework assumes:
  - **Data Ownership**: Primarily held by the **building owner/operator**, with DT services acting as intermediaries for processing.
  - **Privacy Compliance**: Middleware (Eclipse Hono/Ditto) likely adheres to **data protection regulations** (e.g., GDPR) for sensor data, though specifics are not provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adheres to:
  - **AECO Standards**: BIM standards (e.g., IFC, COBIE) for semantic integration.
  - **Middleware Standards**: Eclipse Hono/Ditto for real-time data exchange.
  - **Model-Driven Engineering (MDE)**: Follows industry practices for automated transformations (e.g., model-to-model, model-to-text).
  The framework emphasizes **standardized extension points** to enable modular, interoperable DT development."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Addressed via:
  - **Cybersecurity**: Middleware (Hono/Ditto) likely includes authentication/authorization mechanisms to prevent unauthorized access to physical devices.
  - **Safety**: DT services are designed to operate **remotely** but with safeguards to avoid accidental harm (e.g., emergency shutdown protocols for critical systems).
  The framework prioritizes **secure, low-latency communication** to ensure reliable DT-to-physical interactions."
]