// C3: Physical Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in BIM building device, measures presence using RF/Zigbee."
    DTDFVocab:producedData OccupancySensorMQTT
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor measuring light levels in the Living Lab building, integrated in BIM devices."
    DTDFVocab:producedData IlluminanceSensorMQTT
]

instance TempHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Temperature and humidity sensor mounted on HVAC ducts, part of the BIM device suite."
    DTDFVocab:producedData TempHumiditySensorMQTT
]

instance PowerMeter : DTDFVocab:SensingComponent [
    base:desc "Power meter attached to lighting fixtures and HVAC units, reporting consumption via IoT node."
    DTDFVocab:producedData PowerMeterMQTT
]

// C4: Physical‑to‑Virtual Interaction
instance OccupancySensorMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminanceSensorMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]

instance TempHumiditySensorMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TempHumiditySensor
]

instance PowerMeterMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerMeter
]

instance OccupancySensorData : DTDFVocab:Data [
    base:desc "Raw occupancy data received over MQTT via Eclipse Hono, processed by Ditto."
    DTDFVocab:inputTo EclipseDitto
    DTDFVocab:fromData OccupancySensorMQTT
]

instance IlluminanceSensorData : DTDFVocab:Data [
    base:desc "Raw illuminance data received over MQTT via Eclipse Hono, processed by Ditto."
    DTDFVocab:inputTo EclipseDitto
    DTDFVocab:fromData IlluminanceSensorMQTT
]

instance TempHumiditySensorData : DTDFVocab:Data [
    base:desc "Raw temperature–humidity data received over MQTT via Eclipse Hono, processed by Ditto."
    DTDFVocab:inputTo EclipseDitto
    DTDFVocab:fromData TempHumiditySensorMQTT
]

instance PowerMeterData : DTDFVocab:Data [
    base:desc "Raw power consumption data received over MQTT via Eclipse Hono, processed by Ditto."
    DTDFVocab:inputTo EclipseDitto
    DTDFVocab:fromData PowerMeterMQTT
]

// C2: Acting Components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator controlling brightness of LED fixtures, defined in BIM."
]

instance LEDLightsActuator : DTDFVocab:ActingComponent [
    base:desc "LED lighting actuator switching on/off and regulating intensity per schedule."
]

instance VentilationDamperActuator : DTDFVocab:ActingComponent [
    base:desc "Ventilation damper actuator controlling airflow through HVAC ducts."
]

instance FanSpeedControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Fan speed controller actuator regulating HVAC fan velocity."
]

instance BACnetGatewayActuator : DTDFVocab:ActingComponent [
    base:desc "BACnet gateway acting as building automation controller for networked devices."
]

// C17: Insights
instance LightingScheduleOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight on optimal lighting schedules derived from aggregated telemetry and simulation outputs."
]

instance HVACSetpointOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight on HVAC setpoint adjustments based on occupancy and temperature data."
]

instance CommissioningPlanInsight : DTDFVocab:Insight [
    base:desc "Insight on commissioning plans to validate system performance and calibration."
]

instance EnergySavingRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight offering energy‑saving recommendations from predictive analytics."
]

instance OccupancyHeatMapInsight : DTDFVocab:Insight [
    base:desc "Heat map of occupancy levels visualized on the live monitoring dashboard."
]

instance EnergyUseHeatMapInsight : DTDFVocab:Insight [
    base:desc "Heat map of energy use across the building for real‑time analysis."
]

// C17: Actions
instance LightingScheduleAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatically adjust lighting schedule for fixtures based on optimization insight."
    DTDFVocab:IsAutomatic true
]

instance HVACSetpointAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatically adjust HVAC setpoints based on optimization insight."
    DTDFVocab:IsAutomatic true
]

instance CommissioningPlanExecutionAction : DTDFVocab:Action [
    base:desc "Execute commissioning plan steps as outlined by the insight."
    DTDFVocab:IsAutomatic false
]

instance FaultDetectionAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjust fault‑detection thresholds or trigger alarms in real‑time fault detection service."
    DTDFVocab:IsAutomatic true
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware facilitating device connectivity via MQTT and forwarding to Ditto."
    DTDFVocab:enables LiveMonitoringDashboard, UnrealEngineVisualization, PredictiveAnalyticsRL, AutomatedCommissioning, EventDrivenBuildingSimulation, RealTimeStatusReportingFaultDetection
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto platform managing digital twins and processing telemetry streams."
    DTDFVocab:enables LiveMonitoringDashboard, UnrealEngineVisualization, PredictiveAnalyticsRL, AutomatedCommissioning, EventDrivenBuildingSimulation, RealTimeStatusReportingFaultDetection
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 rendering engine providing interactive building visualization."
]

instance ModelToModelTransformationEngine : DTDFVocab:Enabler [
    base:desc "Model‑to‑model transformation engine generating twin definitions from enriched BIM models."
]

instance RevitAuthoringTool : DTDFVocab:Enabler [
    base:desc "Standard BIM authoring tool (Revit) used for creating the IFC model."
]

// C10: Models/Data
instance BimIfcModel : DTDFVocab:Model [
    base:desc "BIM 3‑D IFC model of the Living Lab building enriched with device metadata (tenant, device ID, Hono endpoint)."
    DTDFVocab:inputTo EclipseDitto, ModelToModelTransformationEngine
]

// C6: Services
instance LiveMonitoringDashboard : DTDFVocab:Service [
    base:desc "Live monitoring dashboard displaying telemetry, heat maps, and scheduling insights."
    DTDFVocab:provides LightingScheduleOptimizationInsight, OccupancyHeatMapInsight
]

instance UnrealEngineVisualization : DTDFVocab:Service [
    base:desc "Interactive Unreal Engine 5 visualization of building performance and simulation outputs."
    DTDFVocab:provides OccupancyHeatMapInsight, EnergyUseHeatMapInsight
]

instance PredictiveAnalyticsRL : DTDFVocab:Service [
    base:desc "Predictive analytics service performing reinforcement‑learning‑based lighting optimization."
    DTDFVocab:provides EnergySavingRecommendationInsight, LightingScheduleOptimizationInsight
]

instance AutomatedCommissioning : DTDFVocab:Service [
    base:desc "Automated commissioning service executing validation plans and providing commissioning insights."
    DTDFVocab:provides CommissioningPlanInsight, CommissioningPlanExecutionAction
]

instance EventDrivenBuildingSimulation : DTDFVocab:Service [
    base:desc "Event‑driven simulation service generating building performance predictions."
    DTDFVocab:provides EnergyUseHeatMapInsight
]

instance RealTimeStatusReportingFaultDetection : DTDFVocab:Service [
    base:desc "Real‑time status reporting and fault detection service monitoring device health."
    DTDFVocab:provides FaultDetectionAdjustmentAction
]

// C7: Environment
instance LivingLabBuilding : DTDFVocab:Environment [
    base:contains LightingDimmerActuator, LEDLightsActuator, VentilationDamperActuator, FanSpeedControllerActuator, BACnetGatewayActuator, OccupancySensor, IlluminanceSensor, TempHumiditySensor, PowerMeter
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated from the virtual twin (e.g., dimming level, fan speed) are sent back to devices through Ditto’s event channels over MQTT, routed via Hono to the building control system"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous synchronization with sub‑second to 1 s update intervals; event‑driven changes reflected within milliseconds; historical archival for daily/weekly logs"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Central DT hub orchestrating communication between individual component twins via Ditto; service‑oriented architecture with modular extension points for custom analytics services; integrated visualization console"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design‑time (BIM model), manufactured‑time (as‑built BIM enrichment with device metadata), operational‑time (runtime twin running in the field)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric used to quantify alignment between virtual twin and physical counterpart; semantic drift mitigation via synchronization rules; formal validation of sensor data against BIM constraints"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication via MQTT over TLS, utilizing Eclipse Hono as the MQTT broker and Ditto as the twin data store; Hono routes messages to/from specific device endpoints; Ditto exposes REST and WebSocket APIs for twin state retrieval"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Built upon the IFC/BIM standard for building models, MQTT and JSON for data exchange, and the Open Interconnect Architecture via Eclipse Ditto; framework provides extension points aligned with ISO 16739 for BIM content"
]