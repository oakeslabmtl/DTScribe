// C3: Physical sensing components
instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor device captured in the BIM model, reporting measurements via Eclipse Hono to the Ditto platform."
    DTDFVocab:producedData EnvironmentalSensorDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor device captured in the BIM model, reporting occupancy status via Eclipse Hono to the Ditto platform."
    DTDFVocab:producedData OccupancySensorDataTransmitted
]

// C4: Physical-to-virtual interaction
instance EnvironmentalSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance OccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Models/Data
instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Real-time environmental sensor data stream published to the digital twin."
    DTDFVocab:fromData EnvironmentalSensorDataTransmitted
    DTDFVocab:inputTo DittoPlatform, EclipseHonoBroker
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy data stream published to the digital twin."
    DTDFVocab:fromData OccupancySensorDataTransmitted
    DTDFVocab:inputTo DittoPlatform, EclipseHonoBroker
]

instance BIMGeometryTopologyModel : DTDFVocab:Model [
    base:desc "BIM geometry and topology model representing the building structure."
    DTDFVocab:inputTo DittoPlatform, MDETransformationTool
]

instance RuntimeControlLogicModel : DTDFVocab:Model [
    base:desc "Runtime control logic model for building operations."
    DTDFVocab:inputTo DittoPlatform, EclipseHonoBroker
]

instance AnalyticsResultsModel : DTDFVocab:Model [
    base:desc "Analytics results model integrating sensor analytics and simulation outcomes."
    DTDFVocab:inputTo DittoPlatform, UnrealEngine5Visualization
]

// C11: Enablers
instance DittoPlatform : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto platform hosting device twins and facilitating data exchange."
    DTDFVocab:enables SimulationService, PredictiveAnalyticsService, RLLightingOptimizationService, EnergyConsumptionAnalyticsService, Immersive3DVisualizationService, MDEPipelineService
]

instance EclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono message broker providing MQTT-like transport between physical devices and the Ditto platform."
    DTDFVocab:enables SimulationService, RLLightingOptimizationService
]

instance MDETransformationTool : DTDFVocab:Enabler [
    base:desc "Model-driven transformation tool that converts BIM geometry into runtime artefacts and twin definitions."
    DTDFVocab:enables MDEPipelineService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3D visualization of the building digital twin."
    DTDFVocab:enables Immersive3DVisualizationService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Service providing simulation of building dynamics using BIM geometry."
    DTDFVocab:provides RealTimeOperationalInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service performing predictive analytics on building operation data."
    DTDFVocab:provides EnergyConsumptionOptimizationInsight
]

instance RLLightingOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based lighting optimization service."
    DTDFVocab:provides IlluminationEfficiencyInsight, LightingAdjustmentAction
]

instance EnergyConsumptionAnalyticsService : DTDFVocab:Service [
    base:desc "Service analyzing energy consumption patterns in the building."
    DTDFVocab:provides EnergyConsumptionInsight, HVACAdjustmentAction
]

instance Immersive3DVisualizationService : DTDFVocab:Service [
    base:desc "Service rendering the building digital twin in Unreal Engine 5."
    DTDFVocab:provides ImmersiveVisualizationInsight
]

instance MDEPipelineService : DTDFVocab:Service [
    base:desc "Service orchestrating the automated MDE pipeline for twin evolution."
    DTDFVocab:provides PipelineExecutionInsight
]

// C17: Insights
instance RealTimeOperationalInsight : DTDFVocab:Insight [
    base:desc "Real‑time operational insights derived from live sensor data for immediate decision‑making."
]

instance EnergyConsumptionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Predictive insight enabling optimization of building energy consumption."
]

instance IlluminationEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight into lighting efficiency obtained through reinforcement learning."
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight on energy consumption trends derived from analytics."
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from immersive 3D visualization rendered in Unreal Engine 5."
]

instance PipelineExecutionInsight : DTDFVocab:Insight [
    base:desc "Insight on the status and performance of the automated MDE pipeline."
]

// C17: Actions
instance LightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic lighting adjustment based on reinforcement learning optimization."
    DTDFVocab:IsAutomatic true
]

instance HVACAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic HVAC adjustment to optimize building comfort and energy usage."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator device controlling lighting systems, managed via Eclipse Hono/Ditto."
]

instance HVACControlActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator device controlling HVAC systems, managed via Eclipse Hono/Ditto."
]

// C15: Components and Environment
instance WallTwin : DTDFVocab:Component [
    base:desc "Device twin representing the wall element derived from BIM."
]

instance FloorTwin : DTDFVocab:Component [
    base:desc "Device twin representing the floor element derived from BIM."
]

instance LobbyTwin : DTDFVocab:Component [
    base:desc "Device twin representing the lobby element derived from BIM."
]

instance BuildingFacultyTwin : DTDFVocab:Environment [
    base:contains WallTwin, FloorTwin, LobbyTwin
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin forwards control commands to the building control system through Eclipse Hono/Ditto, influencing actuators such as lighting or other controlled devices."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time synchronization between physical and virtual entities; updates occur as sensor data streams are transmitted, with no specific time granularity defined in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central service hub composed of the Ditto twin registry, Hono messaging layer, MDE transformation engine, and visualization front‑end, collectively managing device twins and runtime services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans all lifecycle phases: design‑time BIM models (idealised), as‑built models captured during construction, and operated models reflecting live sensor data during facility operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Entanglement measured by the Overall Digital Twin Entanglement (ODTE) metric; consistency checks between BIM models and runtime state; verification of control logic against design specifications; validation of sensor data streams against physical measurements."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between physical assets and the Digital Twin is mediated through Eclipse Hono and Ditto services, facilitating bidirectional transmission of sensor data and control commands."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to AECO‑specific standards such as BIM for building information; use of Eclipse Hono and Ditto as standard middleware for messaging and twin management; no further standards are specified."
]