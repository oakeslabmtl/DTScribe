// C2: Acting Components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator defined in the enriched BIM model and addressable by the DT for actuation"
]

instance HVACControlValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC control valve actuator defined in the enriched BIM model and addressable by the DT for actuation"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in BIM; measurements ingested via Eclipse Hono"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM; measurements ingested via Eclipse Hono"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor modeled in BIM; measurements ingested via Eclipse Hono"
    DTDFVocab:producedData IlluminationDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

// C5: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature measurements stream"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseDittoTwinStore
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy detection stream"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDittoTwinStore
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Live illumination level measurements stream"
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseDittoTwinStore
]

// C10: Models/Data
instance BIMModel : DTDFVocab:Model [
    base:desc "Building Information Model supplying geometric, spatial and semantic information"
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoTwinStore, ModelDrivenEngineeringTool
]

instance DeviceMetadataModel : DTDFVocab:Model [
    base:desc "Metadata of devices generated from enriched BIM, used for automatic configurator generation"
    DTDFVocab:inputTo ModelDrivenEngineeringTool
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic artifacts (e.g., HVAC set‑point rules) generated by the model‑driven pipeline"
    DTDFVocab:inputTo ModelDrivenEngineeringTool
]

// C11: Enablers
instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono protocol gateway ingests sensor measurements from the physical building"
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoTwinStore : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto stores the evolving twin state and provides read/write access for services"
    DTDFVocab:enables EnergyOptimizationService, TaskPlanningService, SimulationPredictiveAnalyticsService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders an immersive 3‑D interactive visualization of the twin"
    DTDFVocab:enables InteractiveVisualization3DService
]

instance ModelDrivenEngineeringTool : DTDFVocab:Enabler [
    base:desc "MDE tool automates model‑to‑text generation of device metadata and control logic"
    DTDFVocab:enables SimulationPredictiveAnalyticsService
]

instance BIMSemanticBackbone : DTDFVocab:Enabler [
    base:desc "BIM acts as the semantic backbone linking geometry, spaces and device semantics"
    DTDFVocab:enables RealTimeMonitoringService, EnergyOptimizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building sensor streams"
    DTDFVocab:provides RealTimeInsights
]

instance InteractiveVisualization3DService : DTDFVocab:Service [
    base:desc "3‑D interactive visualization of the building twin using Unreal Engine 5"
    DTDFVocab:provides VisualizationInsight
]

instance SimulationPredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Simulation and predictive analytics based on control‑logic model"
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy‑optimization analytics delivering recommendations for HVAC and lighting"
    DTDFVocab:provides EnergyOptimizationRecommendation
]

instance TaskPlanningService : DTDFVocab:Service [
    base:desc "Task‑planning service generating actionable schedules for facility managers"
    DTDFVocab:provides TaskPlanningRecommendation
]

// C17: Insights/Actions
instance RealTimeInsights : DTDFVocab:Insight [
    base:desc "Real‑time insights derived from live sensor data (e.g., temperature anomalies)"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insightful visual cues (heat maps, occupancy overlays) in the 3‑D visualization"
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics insights forecasting future energy consumption and comfort levels"
]

instance EnergyOptimizationRecommendation : DTDFVocab:Insight [
    base:desc "Optimization recommendations for HVAC set‑points and lighting dimming to reduce energy use"
]

instance TaskPlanningRecommendation : DTDFVocab:Insight [
    base:desc "Actionable task‑planning recommendations for facility manager workflows"
]

// Environment containing components
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, OccupancySensor, IlluminationSensor,
                 LightingDimmerActuator, HVACControlValveActuator,
                 BIMModel, DeviceMetadataModel, ControlLogicModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication that sends control commands from Ditto back through Hono to the physical actuators, enabling the DT to influence building operations."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real‑time synchronization; data exchange occurs continuously with latency suitable for operational control (no explicit numeric rate provided)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central DT framework that orchestrates the enriched BIM model, Hono/Ditto middleware, and Unreal Engine visualizer, with standardized extension points for adding further services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Supports the design stage (BIM authoring), construction/commissioning stage (device configuration), and operation stage (runtime monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is employed to quantify how faithfully the digital twin reflects its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time connectivity is achieved through Eclipse Hono, which handles device protocol translation (e.g., MQTT/HTTP) and forwards messages to Eclipse Ditto, which maintains the digital twin state."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized extension points allow integration with external analytics, services, or other DT platforms, supporting a service‑oriented architecture."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Relies on industry‑standard BIM for building data, and on the standardized APIs of Eclipse Hono and Eclipse Ditto; the overall approach follows Model‑Driven Engineering best practices for interoperability."
]