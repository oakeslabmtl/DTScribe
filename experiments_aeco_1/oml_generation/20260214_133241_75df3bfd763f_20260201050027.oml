// Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor listed in the BIM environment, mirrored as a Ditto device and streaming telemetry via Hono QoS1."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor listed in the BIM environment, mirrored as a Ditto device and streaming telemetry via Hono QoS1."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EquipmentStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Equipment status sensor listed in the BIM environment, mirrored as a Ditto device and streaming telemetry via Hono QoS1."
    DTDFVocab:producedData EquipmentStatusDataTransmitted
]

// Data Transmitted
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EquipmentStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EquipmentStatusSensor
]

// Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "TemperatureData represents the actual temperature value received from the sensor, validated by Ditto's policy engine."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo HonoDittoIntegration
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "OccupancyData represents the occupancy level received from the sensor, validated by Ditto's policy engine."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo HonoDittoIntegration
]

instance EquipmentStatusData : DTDFVocab:Data [
    base:desc "EquipmentStatusData represents equipment operational state, validated by Ditto's policy engine."
    DTDFVocab:fromData EquipmentStatusDataTransmitted
    DTDFVocab:inputTo HonoDittoIntegration
]

// Enabler
instance HonoDittoIntegration : DTDFVocab:Enabler [
    base:desc "HonoDittoIntegration combines Eclipse Hono for message routing and Eclipse Ditto for persistent event storage, ensuring at‑least‑once delivery and policy‑based validation."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, OptimizationService, VisualizationDashboardService, BidirectionalCommandService
]

// Models (optional for completeness)
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched Building Information Model (BIM) that explicitly annotates sensors, actuators, and controllers."
    DTDFVocab:inputTo HonoDittoIntegration
]

instance MDETransformation : DTDFVocab:Model [
    base:desc "Model‑Driven Engineering pipeline that validates, converts, and configures the enriched BIM into structured, machine‑readable representations."
    DTDFVocab:inputTo HonoDittoIntegration
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building operational parameters such as temperature, occupancy, and equipment status."
    DTDFVocab:provides StatusInsight, MonitoringDashboardInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for asset performance and fault detection, ingesting sensor streams via Hono and processing within Ditto."
    DTDFVocab:provides MaintenancePredictionInsight, FaultDetectionInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization services that suggest energy‑saving schedules based on analytics."
    DTDFVocab:provides EnergySavingScheduleInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Interactive visualization dashboards rendered by UE5, providing immersive control interfaces."
    DTDFVocab:provides MonitoringDashboardInsight
]

instance BidirectionalCommandService : DTDFVocab:Service [
    base:desc "Bidirectional command capability allowing facility managers to issue control actions to the physical building via the digital twin."
    DTDFVocab:provides ActuatorCommandAction
]

// Insights
instance StatusInsight : DTDFVocab:Insight [
    base:desc "Insight into current building state (e.g., temperature, occupancy) derived from real‑time data."
]

instance MonitoringDashboardInsight : DTDFVocab:Insight [
    base:desc "Insight displaying consolidated monitoring information on the dashboard."
]

instance MaintenancePredictionInsight : DTDFVocab:Insight [
    base:desc "Insight predicting maintenance needs based on predictive analytics."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting faults in equipment performance."
]

instance EnergySavingScheduleInsight : DTDFVocab:Insight [
    base:desc "Insight providing suggested energy‑saving schedules."
]

// Actions
instance ActuatorCommandAction : DTDFVocab:Action [
    base:desc "Action representing the execution of actuator commands sent from the digital twin to the physical building."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time continuous synchronization between the physical building and its digital twin is supported by the framework’s data exchange layer; the documentation does not specify a fixed update interval, latency bound, or temporal granularity for individual services."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a model‑driven engineering architecture that automatically transforms enriched BIM models into deployable Digital Twin artefacts. It consists of: (1) a BIM enrichment layer where Building Control Engineers model sensors, actuators and controllers; (2) a transformation layer that extracts structured representations via MDE techniques; (3) a central DT Framework hub that orchestrates bidirectional data exchange, runtime configuration management, and module integration through standardized extension points; and (4) an analytics/visualization layer providing interactive interfaces and real‑time monitoring. Coordination is achieved by the hub, which manages component dependencies and resource allocation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Lifecycle stages include: (1) Device and Control Modeling – Building Control Engineers embed sensors, actuators, and controllers directly into BIM models, creating semantically enriched representations; (2) Deployment Automation – The model‑driven framework applies MDE principles to transform the enriched BIM into structured artefacts and automatically generates deployable Digital Twin components, realizing the automated deployment process described in R2 (C2) and enabling reproducible setups; (3) Runtime Operation and Synchronization – Real‑time data exchange is achieved through Eclipse Hono (for MQTT/HTTP messaging) and Eclipse Ditto, enabling continuous bidirectional synchronization between physical assets and the twin; (4) Extension & Evolution – A modular architecture with defined extension points allows DT Engineers to plug in custom services (analytics, AI modules, control logic) and evolve the twin over time. Lifecycle governance is defined through explicit stakeholder roles—Building Control Engineer initiates deployment, Facility Manager monitors and operates the twin, and DT Engineer extends functionality—ensuring structured version control and reproducibility."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Deployment performance was quantified with model‑checking (5.53 s), model‑parsing (8.7 s) and initialization (0.3 s), for a total of 14.53 s.  Synchronization quality was measured by the Overall Digital Twin Entanglement (ODTE) metric over a twelve‑minute window: timeliness 0.997, reliability 1.0, availability 1.0, yielding an overall ODTE of 0.997.  Fault tolerance is achieved through Hono’s at‑least‑once delivery and Ditto’s persistent storage, while policy‑based validation ensures data quality.  No divergence between the physical building and its twin was observed during the Living Lab test.|"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Hono serves as the IoT connectivity layer while Ditto provides the digital twin repository. Together they create a bidirectional data exchange path that links physical device telemetry to twin state changes. The documents mention that the DT framework supports modular extension points for connectivity, but do not specify network topology, bandwidth, latency, reliability, redundancy, or security protocols beyond the standard mechanisms implied by using Eclipse Hono and Ditto."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not in Document."
]