instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for capturing post-occupancy status in building infrastructure"
    DTDFVocab:producedData OccupancyDataTransmission
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for capturing light level data in building infrastructure"
    DTDFVocab:producedData IlluminanceDataTransmission
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for capturing thermal comfort data in building infrastructure"
    DTDFVocab:producedData TemperatureDataTransmission
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for capturing humidity data in building infrastructure"
    DTDFVocab:producedData HumidityDataTransmission
]

instance OccupancyDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
    base:desc "Real-time sensor data transmitted via Eclipse Hono and Ditto protocols for live synchronization between physical assets and digital twin"
]

instance IlluminanceDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
    base:desc "Real-time sensor data transmitted via Eclipse Hono and Ditto protocols for live synchronization between physical assets and digital twin"
]

instance TemperatureDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
    base:desc "Real-time sensor data transmitted via Eclipse Hono and Ditto protocols for live synchronization between physical assets and digital twin"
]

instance HumidityDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
    base:desc "Real-time sensor data transmitted via Eclipse Hono and Ditto protocols for live synchronization between physical assets and digital twin"
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Post-occupancy sensor data for building conditions"
    DTDFVocab:fromData OccupancyDataTransmission
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance IlluminanceData : DTDFVocab:Data [
    base:desc "Illuminance sensor data for visual comfort optimization"
    DTDFVocab:fromData IlluminanceDataTransmission
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature sensor data for energy optimization"
    DTDFVocab:fromData TemperatureDataTransmission
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity sensor data for comfort adjustments"
    DTDFVocab:fromData HumidityDataTransmission
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting system components modeled within BIM for physical interaction in TwinLight project"
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono protocol for IoT device connectivity and data ingestion"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, AdaptiveLightingOptimizationService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto protocol for digital twin management and device modeling"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, AdaptiveLightingOptimizationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for interactive 3D visualization"
    DTDFVocab:enables Interactive3DVisualizationService
]

instance BIMAuthoringTools : DTDFVocab:Enabler [
    base:desc "BIM authoring tools for model creation and validation"
    DTDFVocab:enables BIMValidationService
]

instance ModelDrivenEngineering : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering methodologies for BIM model validation, automated metadata extraction, and runtime artifact generation with ODTE metric evaluation"
    DTDFVocab:enables BIMValidationService, ModelDeploymentService
]

instance BIMSemanticModel : DTDFVocab:Model [
    base:desc "BIM-based semantic models enriched with device metadata for sensors and actuators"
    DTDFVocab:inputTo BIMAuthoringTools, ModelDrivenEngineering
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of building conditions using sensor data in modular, service-oriented architecture with standardized extension points for scalable deployment"
    DTDFVocab:provides BuildingConditionMonitoringInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance scenarios for energy and comfort analysis in modular, service-oriented architecture"
    DTDFVocab:provides SimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy optimization and comfort adjustments in modular, service-oriented architecture"
    DTDFVocab:provides EnergyOptimizationInsight, ComfortAdjustmentInsight
]

instance AdaptiveLightingOptimizationService : DTDFVocab:Service [
    base:desc "Adaptive lighting optimization for energy consumption and visual comfort in modular, service-oriented architecture"
    DTDFVocab:provides LightingAdjustmentAction
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization of building models using Unreal Engine 5 in modular, service-oriented architecture"
    DTDFVocab:provides VisualizationInsight
]

instance BIMValidationService : DTDFVocab:Service [
    base:desc "Service for validating BIM models to ensure accuracy and compliance with standards"
    DTDFVocab:provides BIMValidationInsight
]

instance ModelDeploymentService : DTDFVocab:Service [
    base:desc "Service for deploying digital twin artifacts with ODTE metric evaluation"
    DTDFVocab:provides ModelDeploymentInsight
]

instance BuildingConditionMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring data for building operational conditions"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulated building performance scenarios for analysis"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Non-directive recommendations for energy optimization based on predictive analytics"
]

instance ComfortAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Non-directive recommendations for comfort adjustments based on predictive analytics"
]

instance LightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting systems based on sensor data and optimization algorithms"
    DTDFVocab:IsAutomatic true
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D visualization of building infrastructure for facility management"
]

instance BIMValidationInsight : DTDFVocab:Insight [
    base:desc "Insight from BIM model validation process indicating compliance and accuracy"
]

instance ModelDeploymentInsight : DTDFVocab:Insight [
    base:desc "Insight related to model deployment process and ODTE metric evaluation"
]

instance LivingLabBuildingEnvironment : DTDFVocab:Environment [
    base:desc "Building infrastructure in AECO domain, demonstrated through a Living Lab case study"
    base:contains OccupancySensor, IlluminanceSensor, TemperatureSensor, HumiditySensor, LightingActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals generated by the DT and sent to Building Control Systems (BCS) via Eclipse Hono and Ditto for actuator operations."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with sensor data and control signals processed continuously without specified fixed intervals."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated integration of BIM models, Hono/Ditto for data exchange, Unreal Engine for visualization, and modular services via standardized extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers all building life cycle phases including design, construction, operation, and refurbishment."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Evaluated using Overall Digital Twin Entanglement (ODTE) metric to measure interoperability and architectural soundness, addressing semantic drift through model synchronization."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono and Ditto for real-time data exchange; no specific communication protocols documented in the source text."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperable with external BIM tools and IoT platforms through standardized extension points for seamless data exchange."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM as the primary standard for semantic modeling; standardized integration frameworks for interoperability across heterogeneous systems."
]