// C3: Physical sensing components
instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector sensor extracted from the BIM model, provides live occupancy status"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor embedded in the building, streams ambient light levels"
    DTDFVocab:producedData IlluminanceDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor from the BIM, delivers real‑time indoor temperature readings"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor defined in the BIM, reports carbon‑dioxide concentration continuously"
    DTDFVocab:producedData CO2DataTransmitted
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance IlluminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

// C5: Data
instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy stream generated by OccupancyDetector"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo DittoTwinManager
]

instance IlluminanceData : DTDFVocab:Data [
    base:desc "Ambient light level stream from IlluminanceSensor"
    DTDFVocab:fromData IlluminanceDataTransmitted
    DTDFVocab:inputTo DittoTwinManager
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Indoor temperature stream supplied by TemperatureSensor"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DittoTwinManager
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Carbon‑dioxide concentration stream from CO2Sensor"
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo DittoTwinManager
]

// C2: Acting components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator integrated in the building control system, receives set‑point commands"
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve actuator that can be commanded to regulate airflow"
]

instance MotorisedShadingActuator : DTDFVocab:ActingComponent [
    base:desc "Motorised shading device controllable via digital twin commands"
]

// C11: Enablers
instance HonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono protocol gateway handling MQTT/AMQP streams from physical sensors"
]

instance DittoTwinManager : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital‑twin manager that synchronises live data and executes services"
    DTDFVocab:enables RealTimeMonitoringService,
                     PredictiveAnalyticsService,
                     AdaptiveLightingOptimizationService,
                     BuildingPerformanceSimulationService,
                     TaskPlanningService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 engine providing 3‑D immersive visualization of the building twin"
    DTDFVocab:enables VisualizationService
]

instance BIMExtractionTool : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering tool that extracts BIM geometry and extensions for twin creation"
]

instance IFCFormatEnabler : DTDFVocab:Enabler [
    base:desc "Standard IFC format parser used as semantic backbone for BIM data"
]

// C10: Models/Data
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Semantic BIM geometry and topology model extracted from the IFC file"
    DTDFVocab:inputTo UnrealEngine5Visualization
]

instance EnrichedBIMExtensionModel : DTDFVocab:Model [
    base:desc "BIM extensions describing sensors and actuators, enriched with runtime metadata"
    DTDFVocab:inputTo DittoTwinManager
]

instance RuntimeControlModel : DTDFVocab:Model [
    base:desc "Runtime control model governing building‑control logic"
    DTDFVocab:inputTo DittoTwinManager
]

instance ReinforcementLearningPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning policy model for adaptive lighting optimisation"
    DTDFVocab:inputTo DittoTwinManager
]

instance PredictiveMaintenanceModel : DTDFVocab:Model [
    base:desc "Predictive maintenance model used by predictive analytics service"
    DTDFVocab:inputTo DittoTwinManager
]

instance BuildingPerformanceSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of building performance used for scenario analysis"
    DTDFVocab:inputTo DittoTwinManager
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring dashboards aggregating live sensor data"
    DTDFVocab:provides MonitoringDashboardInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Delivers 3‑D interactive visualization of the digital twin in Unreal Engine 5"
    DTDFVocab:provides ImmersiveVisualizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Executes predictive analytics to generate maintenance alerts and policy updates"
    DTDFVocab:provides PredictiveMaintenanceAlert,
                     PolicyUpdateInsight
]

instance AdaptiveLightingOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based service that optimises lighting set‑points adaptively"
    DTDFVocab:provides LightingOptimizationRecommendation
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Runs building performance simulations for what‑if scenario evaluation"
    DTDFVocab:provides SimulationResultInsight
]

instance TaskPlanningService : DTDFVocab:Service [
    base:desc "Offers task‑planning support for facility‑manager workflows"
    DTDFVocab:provides TaskPlanningRecommendation
]

// C17: Insights / Actions
instance MonitoringDashboardInsight : DTDFVocab:Insight [
    base:desc "Insight summarising current building state for facility‑manager dashboards"
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight delivering immersive 3‑D view of the building twin"
]

instance PredictiveMaintenanceAlert : DTDFVocab:Insight [
    base:desc "Alert indicating imminent equipment failure derived from predictive analytics"
]

instance PolicyUpdateInsight : DTDFVocab:Insight [
    base:desc "Recommendation to update building‑control policies based on reinforcement‑learning outcomes"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Resulting insight from building performance simulations (e.g., energy savings estimate)"
]

instance TaskPlanningRecommendation : DTDFVocab:Insight [
    base:desc "Suggested task sequence for facility‑manager to execute maintenance or optimisation actions"
]

instance LightingOptimizationRecommendation : DTDFVocab:Action [
    base:desc "Proposes optimal lighting set‑points for energy efficiency and occupant comfort"
    DTDFVocab:IsAutomatic false
]

instance PolicyUpdateAction : DTDFVocab:Action [
    base:desc "Executes policy update in the building control system based on learned RL policy"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., lighting set‑points, HVAC set‑points) are sent back to the physical actuators through the same Hono/Ditto middleware, enabling bidirectional, real‑time actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data exchange and command propagation occur in real‑time, with continuous streaming and sub‑second latency sufficient for live monitoring and control loops."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where BIM serves as the source of truth, a model‑driven pipeline automatically generates configuration artefacts, Hono/Ditto provide bidirectional connectivity, and Unreal Engine renders the virtual environment; extension points allow insertion of additional services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the full building lifecycle: design (BIM creation), construction (model enrichment with device metadata), operation (live sensor integration and control), and post‑occupancy adaptation (reinforcement‑learning updates)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is quantified using the Overall Digital Twin Entanglement (ODTE) metric; the framework emphasizes validation of the BIM‑derived model before deployment to ensure semantic consistency between PT and DT."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time connectivity is realised through Eclipse Hono and Eclipse Ditto, which together provide standard IoT messaging and state management for the twin’s data exchange layer."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach leverages BIM industry standards (e.g., IFC) as the semantic backbone and builds on open IoT standards supported by Eclipse Hono and Ditto for interoperability."
]