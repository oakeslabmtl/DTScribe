    base:desc "Analysis of historical operational trends to identify long-term patterns and inform strategic decision-making."
]

instance ScenarioOutcomeInsight : DTDFVocab:Insight [
    base:desc "Evaluation of hypothetical scenario outcomes to assess system resilience and performance under varying conditions."
