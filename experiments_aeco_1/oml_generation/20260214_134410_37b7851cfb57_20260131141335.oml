// Acting Components
instance SmartLightingController : DTDFVocab:ActingComponent [
    base:desc "Acting component controlling the smart lighting system within the building, deployed via Eclipse Hono/Ditto."
]
instance HeatingVentDamperController : DTDFVocab:ActingComponent [
    base:desc "Acting component controlling HVAC dampers for zone temperature regulation, coordinated through Eclipse Ditto."
]
instance RoomSensorActuatorPair : DTDFVocab:ActingComponent [
    base:desc "Combined sensor–actuator pair embedded in a room for occupancy detection and climate control, managed by Eclipse Hono."
]
instance ElectricalDeviceController : DTDFVocab:ActingComponent [
    base:desc "Acting component controlling generic electrical devices such as fans, pumps, or circuit breakers, interfaced via Eclipse Ditto."
]

// Physical Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensing component capturing building occupancy data, transmitted through Eclipse Hono."
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance EnvironmentalConditionSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensing component assessing temperature, humidity, and CO₂ levels, sent to the twin via Eclipse Hono."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]
instance LightingLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensing component measuring lighting levels within a zone, forwarded to the twin through Eclipse Hono."
    DTDFVocab:producedData LightingLevelDataTransmitted
]

// Data Transmitted
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalConditionSensor
]
instance LightingLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingLevelSensor
]

// Data
instance OccupancyData : DTDFVocab:Data [
    base:desc "Room occupancy data derived from the OccupancySensor stream."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]
instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Environmental condition data (temperature, humidity, CO₂) sourced from EnvironmentalConditionSensor."
    DTDFVocab:fromData EnvironmentalDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]
instance LightingLevelData : DTDFVocab:Data [
    base:desc "Lighting level data obtained from LightingLevelSensor."
    DTDFVocab:fromData LightingLevelDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// Models/Data
instance BIMModelWithAnnotations : DTDFVocab:Model [
    base:desc "BIM IFC model enriched with extended annotations for control devices, runtime configurations, and sensor–actuator metadata."
    DTDFVocab:inputTo MDEToolsEnabler
]
instance RuntimeConfigurationDocument : DTDFVocab:Model [
    base:desc "Runtime configuration document extracted from BIM and used to provision device twins via Eclipse Ditto."
    DTDFVocab:inputTo MDEToolsEnabler
]
instance DeviceMetadataRegistry : DTDFVocab:Model [
    base:desc "Registry of device metadata (IDs, locations, capabilities) compiled from BIM annotations."
    DTDFVocab:inputTo MDEToolsEnabler
]
instance SensorActuatorDataStreamModel : DTDFVocab:Model [
    base:desc "Model of sensor and actuator data streams defined in the BIM, supporting real‑time telemetry."
    DTDFVocab:inputTo MDEToolsEnabler
]
instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model specifying rules for lighting and HVAC devices derived from BIM annotations."
    DTDFVocab:inputTo MDEToolsEnabler
]
instance UnrealEngineSceneModel : DTDFVocab:Model [
    base:desc "Unreal Engine 5 scene representation of the building, used for interactive 3D visualization."
    DTDFVocab:inputTo UnrealEngine5Enabler
]

// Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware enabling reception of real‑time telemetry from physical devices."
    DTDFVocab:enables RealTimeMonitoringDashboardService, PredictiveAnalyticsService
]
instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto enabling digital twin state management and command distribution."
    DTDFVocab:enables DecisionSupportIndicatorsService, Interactive3DVisualizationService, ReinforcementLearningControlService
]
instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 enabling rendering of the building scene for interactive visualization."
    DTDFVocab:enables Interactive3DVisualizationService
]
instance MDEToolsEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering tools for model extraction and code generation from BIM."
    DTDFVocab:enables BuildingPerformanceSimulationService, LightingHVACOptimizationService
]
instance BIMAuthoringEnabler : DTDFVocab:Enabler [
    base:desc "BIM authoring software (Revit/BIM360) enabling creation and editing of IFC models with control annotations."
]
instance MetricsODTEEnabler : DTDFVocab:Enabler [
    base:desc "ODTE metrics tool evaluating model fidelity and validity."
    DTDFVocab:enables DecisionSupportIndicatorsService
]

// Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard displaying occupancy, environmental, and lighting data streams."
    DTDFVocab:provides EnergySavingRecommendationInsight, PredictiveMaintenanceAlertInsight
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service generating maintenance alerts and capacity planning data."
    DTDFVocab:provides PredictiveMaintenanceAlertInsight, CapacityPlanningDataInsight
]
instance LightingHVACOptimizationService : DTDFVocab:Service [
    base:desc "Optimization service for lighting schedules and HVAC settings to maximize energy efficiency."
    DTDFVocab:provides OptimizedLightingScheduleInsight, EnergySavingRecommendationInsight
]
instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation service modeling building performance based on BIM and control logic models."
    DTDFVocab:provides BuildingSimulationScenarioInsight
]
instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization service rendering the Unreal Engine scene with real‑time data overlays."
    DTDFVocab:provides Interactive3DVisualizationInsight
]
instance ReinforcementLearningControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based control adaptation service recommending adaptive control actions."
    DTDFVocab:provides AdjustLightingScheduleAction
]
instance DecisionSupportIndicatorsService : DTDFVocab:Service [
    base:desc "Decision‑support service delivering capacity, maintenance, and energy insights to facility operators."
    DTDFVocab:provides DecisionSupportInsight
]

// Insights
instance EnergySavingRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation for reducing energy consumption based on real‑time and predictive data."
]
instance OptimizedLightingScheduleInsight : DTDFVocab:Insight [
    base:desc "Optimized lighting schedule generated by the lighting optimization engine."
]
instance PredictiveMaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Maintenance alert triggered by predictive analytics on device health and performance."
]
instance CapacityPlanningDataInsight : DTDFVocab:Insight [
    base:desc "Capacity planning data generated by predictive models for future occupancy trends."
]
instance BuildingSimulationScenarioInsight : DTDFVocab:Insight [
    base:desc "Scenario simulation results showing building performance under various control strategies."
]
instance Interactive3DVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insightful overlay information provided by the 3D visualization, e.g., energy use heatmaps."
]
instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Overall decision‑support indicators, including capacity and maintenance recommendations."
]

// Actions
instance AdjustLightingScheduleAction : DTDFVocab:Action [
    base:desc "Action to adjust the lighting schedule based on reinforcement‑learning recommendations."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting level adjustments, HVAC set‑point changes) are sent via Ditto to the physical devices through Hono, enabling bidirectional synchronization and runtime control."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, near‑real‑time synchronization (seconds to milliseconds) for sensor data and control messages, with model transformation and deployment steps occurring offline or in staged releases."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated system comprising the BIM model as the semantic backbone, the Hono/Ditto middleware bridge between PT and DT, the Twin Engine that hosts runtime models, the visualization environment (Unreal), and auxiliary services for analytics/optimization."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Designed (static BIM), Manufactured (construction data integrated into the model), Operated (runtime data and control), and Evolved (continuous improvement via RL, model updates)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Use of the Overall Digital Twin Entanglement (ODTE) metric to quantify alignment between PT and DT; validation of data streams against model predictions; attention to semantic drift and sensor uncertainties; formal verification of control logic where applicable."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical–digital communication uses Eclipse Hono as the MQTT gateway; Ditto twin registry stores state; messages are JSON over MQTT topics identified by tenant and device IDs; the system supports publish/subscribe semantics."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not explicitly specified; typically the building owner holds ownership of physical data, while the DT service provider manages the telemetry within agreed privacy and security contracts."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework adheres to BIM semantics and Model‑Driven Engineering standards; it integrates with recognized AECO practices for data modeling though no specific ISO or building code standard is cited."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Not fully addressed in the document; however, the middleware (Hono/Ditto) supports authentication and encryption, and the architecture is designed to avoid unsafe remote execution on the PT by enforcing control policies and safety checks."
]