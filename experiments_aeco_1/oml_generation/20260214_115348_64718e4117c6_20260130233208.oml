import DTDFVocab

// C2: Acting Components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator introduced in the BIM model to control HVAC equipment, addressable through the Digital Twin remote service endpoint"
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator introduced in the BIM model to control lighting systems, addressable through the Digital Twin remote service endpoint"
]

instance GeneralBuildingActuator : DTDFVocab:ActingComponent [
    base:desc "Generic actuator entity for other MEP systems, linked to controller logic defined by the Building Control Engineer"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor modeling temperature measurement, placed in building zones, data format defined in the enriched BIM model",
    DTDFVocab:producedData TemperatureDataStream
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor modeling humidity measurement, placed in building zones, data format defined in the enriched BIM model",
    DTDFVocab:producedData HumidityDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor detecting occupancy presence, used for real‑time space utilization monitoring",
    DTDFVocab:producedData OccupancyDataStream
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting electrical energy consumption of building services",
    DTDFVocab:producedData EnergyConsumptionDataStream
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyConsumptionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

// C5: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature values streamed from TemperatureSensor",
    DTDFVocab:fromData TemperatureDataStream,
    DTDFVocab:inputTo EclipseHonoGateway
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Live humidity values streamed from HumiditySensor",
    DTDFVocab:fromData HumidityDataStream,
    DTDFVocab:inputTo EclipseHonoGateway
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy status streamed from OccupancySensor",
    DTDFVocab:fromData OccupancyDataStream,
    DTDFVocab:inputTo EclipseHonoGateway
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "Live energy consumption readings streamed from EnergyConsumptionSensor",
    DTDFVocab:fromData EnergyConsumptionDataStream,
    DTDFVocab:inputTo EclipseHonoGateway
]

// C10: Models/Data
instance BuildingInformationModel : DTDFVocab:Model [
    base:desc "Geometric BIM model enriched with semantic definitions of devices, forming the static backbone of the Digital Twin",
    DTDFVocab:inputTo EclipseDittoPlatform, UnrealEngineVisualization
]

instance SemanticEnrichmentModel : DTDFVocab:Model [
    base:desc "Model that adds sensor, actuator and controller semantics to the BIM geometry",
    DTDFVocab:inputTo EclipseDittoPlatform
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Executable control logic defined by Building Control Engineers, linked to actuator entities",
    DTDFVocab:inputTo EclipseDittoPlatform
]

// C11: Enablers
instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono IoT gateway providing secure, scalable MQTT/HTTP ingestion of sensor telemetry",
    DTDFVocab:enables RealTimeMonitoringService, ActuatorControlService, PredictiveMaintenanceService, EnergyComfortOptimizationService
]

instance EclipseDittoPlatform : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto core platform hosting the digital twin model, synchronizing live data and exposing remote control interfaces",
    DTDFVocab:enables RealTimeMonitoringService, ActuatorControlService, PredictiveMaintenanceService, EnergyComfortOptimizationService
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 based high‑fidelity 3D visualization environment for immersive interaction with the twin",
    DTDFVocab:enables InteractiveVisualizationService, WhatIfSimulationService
]

instance MQTTIngestion : DTDFVocab:Enabler [
    base:desc "Standard MQTT broker used by Eclipse Hono for real‑time sensor data transport",
    DTDFVocab:enables RealTimeMonitoringService
]

instance HTTPIngestion : DTDFVocab:Enabler [
    base:desc "HTTP endpoint used for control command submission to actuators via the Digital Twin",
    DTDFVocab:enables ActuatorControlService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service delivering continuous real‑time monitoring of all sensor streams",
    DTDFVocab:provides EnergyEfficiencyInsight, ComfortInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Service providing interactive 3D visualization of current building state inside Unreal Engine",
    DTDFVocab:provides VisualInspectionInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Service enabling “what‑if” scenario simulations for energy and comfort performance",
    DTDFVocab:provides EnergyEfficiencyInsight, ComfortInsight
]

instance EnergyComfortOptimizationService : DTDFVocab:Service [
    base:desc "Service performing life‑cycle wide optimization of energy use and occupant comfort",
    DTDFVocab:provides EnergyEfficiencyInsight, ComfortInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Service applying predictive analytics to anticipate maintenance needs of building equipment",
    DTDFVocab:provides MaintenanceAlertInsight
]

instance ActuatorControlService : DTDFVocab:Service [
    base:desc "Service exposing remote control endpoints for actuators, allowing Facility Managers to issue actions",
    DTDFVocab:provides AdjustHVACAction, AdjustLightingAction
]

// C17: Insights/Actions
instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight recommending energy‑saving measures based on live sensor data and simulation results"
]

instance ComfortInsight : DTDFVocab:Insight [
    base:desc "Insight indicating occupant comfort status and suggesting adjustments to HVAC or lighting"
]

instance MaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Insight generating alerts when predictive models forecast imminent equipment failure"
]

instance VisualInspectionInsight : DTDFVocab:Insight [
    base:desc "Insight allowing Facility Managers to visually inspect building components through the 3D environment"
]

instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Action to modify HVAC set‑points or operational mode via the actuator interface",
    DTDFVocab:IsAutomatic false
]

instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Action to change lighting levels or zones via the actuator interface",
    DTDFVocab:IsAutomatic false
]

// C21: Environment (optional grouping)
instance LivingLabEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, HumiditySensor, OccupancySensor, EnergyConsumptionSensor,
                 HVACActuator, LightingActuator, GeneralBuildingActuator,
                 BuildingInformationModel, SemanticEnrichmentModel, ControlLogicModel,
                 EclipseHonoGateway, EclipseDittoPlatform, UnrealEngineVisualization,
                 RealTimeMonitoringService, InteractiveVisualizationService,
                 WhatIfSimulationService, EnergyComfortOptimizationService,
                 PredictiveMaintenanceService, ActuatorControlService
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange that continuously synchronizes the physical building with its digital replica. Updates are propagated as soon as sensor readings or control actions occur, implying a near‑zero latency loop suitable for device‑level monitoring and control. Temporal granularity is at the level of individual building devices (e.g., HVAC units, lighting fixtures). No explicit numerical frequency is specified."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, service‑oriented architecture with standardized extension points. Core components (BIM enrichment, data acquisition, visualization, runtime configuration) are plugged into the central DT Framework, which orchestrates their interaction. Resource management is handled at runtime through configuration changes without redeployment. System‑wide coordination is achieved via the hub that routes data between physical devices, BIM models, and custom analytics services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a full DT lifecycle that starts with device modeling directly in the BIM environment (defining sensors, actuators, controllers), proceeds to model‑driven engineering (MDE) that extracts a structured representation and automatically generates deployable DT artifacts, followed by runtime operation where continuous real‑time data exchange keeps the physical building and its digital counterpart synchronized, and interactive 3‑D visualization enables monitoring and control. The lifecycle is extensible through standardized extension points that allow integration of custom services, supporting ongoing evolution and governance of the twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The framework evaluates the correspondence between the DT and its physical counterpart using the Overall Digital Twin Entanglement (ODTE) metric, which quantifies how well the generated DT reflects the real building. Validation is performed by comparing runtime telemetry (sensor streams, actuator states) against the modeled expectations, enabling detection of deviations. Uncertainty sources such as modeling gaps in BIM are acknowledged, and the ODTE score serves as a quality‑assurance indicator guiding further refinement of models and data pipelines."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed through non‑functional requirements that demand compatibility with heterogeneous systems. The framework relies on standardized extension points and open interfaces to integrate external services, analytics, and enterprise systems. Specific data exchange protocols are not enumerated, but the design emphasizes modular integration and bidirectional communication with external components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution is built to be compatible with existing AECO‑specific standards such as BIM, ensuring that device models and control logic are anchored in industry‑accepted building information models. For interoperability and real‑time data exchange, the framework integrates Eclipse Hono and Eclipse Ditto, leveraging their IoT communication and digital twin protocols to connect physical devices with the twin. The architecture also follows a modular, standardized extension‑point model to facilitate compliance with broader interoperability frameworks."
]