// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator component for dynamic lighting control within the LEED Platinum academic building's digital twin, enabling occupancy-aware and energy-efficient illumination adjustments based on real-time sensor data and control semantics."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator component integrated with the building's Building Control Systems (BCS) for thermal regulation and air quality management, supporting dynamic adjustments based on environmental sensor inputs."
]

// C3: Physical Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Real-time occupancy detection sensor integrated into the lighting infrastructure, providing occupancy data for dynamic lighting control and energy optimization."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor measuring ambient light levels within the building, used for adaptive lighting control and energy performance optimization."
    DTDFVocab:producedData LightLevelDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Thermal sensor monitoring indoor temperature conditions, critical for HVAC system optimization and occupant comfort validation."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor providing real-time relative humidity data for environmental control and air quality management within the building."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Carbon dioxide sensor measuring indoor air quality, essential for ventilation system optimization and occupant health monitoring."
    DTDFVocab:producedData CO2DataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

// C10: Models/Data
instance BIMModel : DTDFVocab:Model [
    base:desc "Semantically rich 3D Building Information Model (BIM) serving as the foundational computational framework for the digital twin, encapsulating geometric, spatial, and functional characteristics of building components."
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance EnvironmentalSimulationModel : DTDFVocab:Model [
    base:desc "Model-driven simulation engine for environmental control validation, enabling what-if scenario testing of lighting schedules, occupancy patterns, and energy-efficiency strategies."
    DTDFVocab:inputTo UnrealEngineEnabler, ControlSemanticsValidationEnabler
]

instance OccupancyPatternModel : DTDFVocab:Model [
    base:desc "Behavioral model predicting occupancy patterns based on historical data and real-time sensor inputs, supporting dynamic control optimization."
    DTDFVocab:inputTo UnrealEngineEnabler, EnergyOptimizationEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy data stream processed from physical sensors, enriched with contextual information for dynamic lighting and HVAC control."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo UnrealEngineEnabler, ControlSemanticsValidationEnabler
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Aggregated environmental data including temperature, humidity, and CO2 levels, processed for real-time building performance monitoring and control."
    DTDFVocab:fromData TemperatureDataTransmitted, HumidityDataTransmitted, CO2DataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler, EnergyOptimizationEnabler
]

instance LightingControlData : DTDFVocab:Data [
    base:desc "Processed lighting control data combining real-time sensor inputs with simulation outputs for dynamic illumination management."
    DTDFVocab:fromData LightLevelDataTransmitted
    DTDFVocab:inputTo UnrealEngineEnabler, LightingOptimizationEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono IoT connectivity framework enabling secure, scalable device management and MQTT-based communication with physical sensors for real-time data ingestion."
    DTDFVocab:enables IoTDataIngestionService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin enabler providing asset modeling and real-time data synchronization as the central data hub for the system."
    DTDFVocab:enables DigitalTwinSynchronizationService
]

instance UnrealEngineEnabler : DTDFVocab:Enabler [
    base:desc "High-performance 3D rendering engine enabling real-time, interactive visualization of the building's digital twin with physics simulations and user-driven exploration."
    DTDFVocab:enables InteractiveVisualizationService, ScenarioTestingService
]

instance ControlSemanticsValidationEnabler : DTDFVocab:Enabler [
    base:desc "Model-driven engineering framework for validating control semantics and energy-efficiency strategies through rule-based and AI-driven simulations."
    DTDFVocab:enables ControlAlgorithmTestingService
]

instance LightingOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Specialized enabler for dynamic lighting control optimization, integrating sensor data with simulation models for occupancy-aware illumination management."
    DTDFVocab:enables DynamicLightingControlService
]

instance EnergyOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Energy performance optimization framework combining real-time data with predictive analytics to minimize energy consumption while maintaining occupant comfort."
    DTDFVocab:enables EnergyConsumptionTrackingService, OccupancyAwareControlService
]

// C6: Services
instance IoTDataIngestionService : DTDFVocab:Service [
    base:desc "Service for secure, scalable IoT data ingestion from physical sensors using Eclipse Hono, enabling low-latency communication for real-time monitoring."
    DTDFVocab:provides RealTimeDataStreamInsight
]

instance DigitalTwinSynchronizationService : DTDFVocab:Service [
    base:desc "Service ensuring bidirectional data synchronization between physical assets and their digital representations using Eclipse Ditto."
    DTDFVocab:provides SynchronizationConsistencyInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Service providing immersive, real-time 3D visualization of the building's digital twin using Unreal Engine, allowing navigation and inspection of virtual representations."
    DTDFVocab:provides VisualizationInterfaceInsight
]

instance ScenarioTestingService : DTDFVocab:Service [
    base:desc "Service enabling what-if scenario testing of lighting schedules, occupancy patterns, and environmental conditions through model-driven simulations."
    DTDFVocab:provides ScenarioAnalysisInsight
]

instance ControlAlgorithmTestingService : DTDFVocab:Service [
    base:desc "Service for validating control semantics and energy-efficiency strategies using rule-based or AI-driven models."
    DTDFVocab:provides ControlValidationInsight
]

instance DynamicLightingControlService : DTDFVocab:Service [
    base:desc "Service implementing occupancy-aware dynamic lighting control based on real-time sensor data and simulation outputs."
    DTDFVocab:provides LightingAdjustmentAction
    DTDFVocab:IsAutomatic true
]

instance EnergyConsumptionTrackingService : DTDFVocab:Service [
    base:desc "Service monitoring and tracking energy consumption patterns in real-time for performance optimization."
    DTDFVocab:provides EnergyUsageInsight
]

instance OccupancyAwareControlService : DTDFVocab:Service [
    base:desc "Service optimizing HVAC and lighting systems based on real-time occupancy data to improve energy efficiency."
    DTDFVocab:provides OccupancyOptimizationAction
    DTDFVocab:IsAutomatic true
]

// C17: Insights/Actions
instance RealTimeDataStreamInsight : DTDFVocab:Insight [
    base:desc "Insight providing continuous event-driven data streams for occupancy detection, lighting control adjustments, and energy consumption tracking."
]

instance SynchronizationConsistencyInsight : DTDFVocab:Insight [
    base:desc "Insight ensuring consistency between physical assets and their digital representations through real-time synchronization."
]

instance VisualizationInterfaceInsight : DTDFVocab:Insight [
    base:desc "Insight enabling customizable dashboards for real-time KPI monitoring of energy savings, CO2 levels, and building performance metrics."
]

instance ScenarioAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight providing analysis results from what-if scenario testing of lighting schedules, occupancy patterns, and environmental conditions."
]

instance ControlValidationInsight : DTDFVocab:Insight [
    base:desc "Insight validating control semantics and energy-efficiency strategies through rule-based and AI-driven model simulations."
]

instance LightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated action adjusting lighting levels based on real-time occupancy and environmental conditions to optimize energy use."
    DTDFVocab:IsAutomatic true
]

instance EnergyUsageInsight : DTDFVocab:Insight [
    base:desc "Insight tracking and analyzing energy consumption patterns to identify optimization opportunities."
]

instance OccupancyOptimizationAction : DTDFVocab:Action [
    base:desc "Automated action optimizing HVAC and lighting systems based on real-time occupancy data to improve energy efficiency."
    DTDFVocab:IsAutomatic true
]

// C1: Environment
instance AcademicBuildingEnvironment : DTDFVocab:Environment [
    base:desc "LEED Platinum academic building serving as the physical environment for the research-oriented Living Lab Digital Twin."
    base:contains LightingSystemComponent, EnvironmentalControlSystemComponent
]

// C5: Components
instance LightingSystemComponent : DTDFVocab:Component [
    base:desc "Modular lighting infrastructure including sensors, actuators, and control nodes for real-time occupancy and environmental monitoring within the academic building."
    base:isContainedIn AcademicBuildingEnvironment
]

instance EnvironmentalControlSystemComponent : DTDFVocab:Component [
    base:desc "Unified control framework integrating indoor environmental sensors (CO2, thermal, air quality) for dynamic building performance optimization."
    base:isContainedIn AcademicBuildingEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The **virtual-to-physical interaction** in this DT system enables **facility managers** to exert control over physical infrastructure via the digital twin, facilitated by **bidirectional communication** between the DT and physical assets. The framework supports **command execution** for operational adjustments (e.g., HVAC adjustments, lighting control) but does not specify **control message formats** (e.g., JSON, XML) or **validation/authentication mechanisms**. **Feedback systems** are implied through the real-time synchronization loop, though **conflict resolution** or **command execution confirmation** protocols are not detailed. The system’s **modular architecture** and **runtime configuration management** allow dynamic adjustments to control logic without redeployment, ensuring adaptability to operational changes. Interaction roles (e.g., *Facility Managers*) are defined to manage physical control via the DT interface."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system supports **real-time data exchange capabilities**, ensuring continuous synchronization between physical buildings and their digital counterparts with **low-latency requirements** to maintain operational relevance. The framework emphasizes **dynamic operational needs** over static BIM representations, enabling **high-frequency updates** (implied by 'continuous synchronization') for monitoring and control. Runtime configuration management allows adjustments without redeployment, suggesting adaptability to varying temporal granularity demands (e.g., millisecond-level for control systems or second-level for analytics). Latency constraints are not explicitly quantified, but the emphasis on real-time implies sub-second synchronization intervals for critical operational services (e.g., HVAC, lighting)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a **centralized hub-and-spoke architecture** with **coordinated roles and system components** (as depicted in Figure 1). The framework acts as a **central hub** enabling bidirectional data exchange between enriched BIM models and operational twins, orchestrating interactions among **Building Control Engineers**, **Facility Managers**, and **DT Engineers**. Resource management is implied through **runtime configuration management**, allowing dynamic adjustments without full redeployment. Component integration is supported via **standardized extension points**, ensuring modularity and adaptability. System-wide coordination relies on **bidirectional synchronization** and **service-oriented design**, enabling holistic building lifecycle management with **low-overhead updates** for maintainability."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "
The Digital Twin (DT) system described in the provided documents supports a **model-driven life cycle** spanning **device modeling, deployment, runtime synchronization, and operational extension**, addressing BIM’s limitations in dynamic representation. The lifecycle begins with **Building Control Engineers** defining **sensors, actuators, and controllers** within enriched BIM models, creating a **unified semantic foundation** for subsequent transformations. This phase leverages **Model-Driven Engineering (MDE)** principles to extract structured representations from BIM, enabling automated generation of deployable DT artifacts with minimal manual intervention.

Transitioning to **runtime**, the framework ensures **real-time data exchange** between physical infrastructure and the DT, synchronized via standardized interfaces. **Facility Managers** interact with the twin for monitoring and control, while **DT Engineers** extend functionality through **custom services and plugins**, integrated via modular architecture with **standardized extension points**. The lifecycle governance emphasizes **continuous synchronization** and **immersive visualization** (e.g., Unreal Engine) for operational oversight. However, explicit phases like **retirement or legacy migration** are not detailed in the documents.
"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system addresses fidelity and validity through **real-time data synchronization** using **Eclipse Hono** and **Eclipse Ditto**, which minimize discrepancies between physical assets and their digital representations by enabling live updates. Validation is implicitly supported by the **semantic coherence** of BIM-based models, ensuring consistency between design-time and runtime data. However, explicit **fidelity metrics** (e.g., quantitative error quantification or uncertainty assessments) are not detailed in the provided documents. The system does not explicitly mention **error detection mechanisms**, **uncertainty quantification**, or **quality assurance processes** beyond the foundational reliance on **policy and regulatory mandates** for BIM adoption, which indirectly support data integrity. The **Overall Digital Twin Entanglement (ODTE) metric** (referenced in abstracts or related work) is not described in the provided context documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **DT hosting and deployment** framework is designed around a **model-driven approach**, emphasizing **scalability** (NF_X) and **maintainability** through low-overhead updates. While specific **hosting platforms** (cloud/edge/on-premise) are not mentioned, the system supports **scalability from individual components to entire infrastructure systems** via its **modular architecture** and **standardized extension points**. **Deployment models** are implied to align with operational needs, with a focus on **runtime configuration management** to enable adjustments without full redeployment. **Computational and storage requirements** are not specified, but the framework prioritizes **accessibility for users with varying technical expertise** (NF_X), ensuring usability across roles (e.g., *Building Control Engineers*, *Facility Managers*). **Availability/reliability assurance** is addressed indirectly through interoperability and modularity, though explicit redundancy or failover mechanisms are not detailed."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin framework prioritizes **interoperability across heterogeneous systems** through non-functional requirements (NF_X) addressing cross-platform compatibility and standardized extension points. It supports **scalability from individual components to entire infrastructure systems**, enabling integration with external tools and enterprise systems via unspecified protocols. The framework does not explicitly mention specific data exchange standards (e.g., IFC, OPC UA) or dependencies on external systems beyond the implied need for **bidirectional data flow** with BIM tools (e.g., Revit) and operational systems. Horizontal integration is framed as a **requirements-driven approach** to bridge static BIM representations and dynamic operational needs, with a focus on low-overhead updates and accessibility."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "
The framework adheres to **BIM standards** as its foundational data model but does not explicitly reference **IFC 4.0**, **gbXML**, or **OPC UA v1.04**. **Connectivity standards** are implied through mentions of **Eclipse Hono and Ditto** for IoT integration, but protocols like **CoAP** or **STEP-AP 242** are not detailed. **Security compliance** is not addressed beyond general mentions of **DT deployment frameworks**, and frameworks like **ISO 27001** or **FIPS 140-2** are not referenced. The system emphasizes **interoperability** via modular design but lacks explicit standardization profiles beyond BIM and IoT connectivity.
"
]