// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modelled in the BIM, receives commands from the twin."
]

instance HvacController : DTDFVocab:ActingComponent [
    base:desc "HVAC control unit modeled in the BIM, receives control signals from the twin."
]

// C3: Physical sensing components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor embedded in the building, configuration stored in the enriched BIM model."
    DTDFVocab:producedData LightingTelemetry
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the building, configuration stored in the enriched BIM model."
    DTDFVocab:producedData OccupancyTelemetry
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor (temperature, humidity, CO₂) embedded in the building, configuration stored in the enriched BIM model."
    DTDFVocab:producedData EnvironmentalTelemetry
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LightingTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance OccupancyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnvironmentalTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C5: Data
instance LightingData : DTDFVocab:Data [
    base:desc "Telemetry data from lighting sensors (luminosity, status) transmitted in real time."
    DTDFVocab:fromData LightingTelemetry
    DTDFVocab:inputTo HonoAdapter, DittoPlatform
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Telemetry data from occupancy sensors (presence count, motion events) transmitted in real time."
    DTDFVocab:fromData OccupancyTelemetry
    DTDFVocab:inputTo HonoAdapter, DittoPlatform
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Telemetry data from environmental sensors (temperature, humidity, CO₂) transmitted in real time."
    DTDFVocab:fromData EnvironmentalTelemetry
    DTDFVocab:inputTo HonoAdapter, DittoPlatform
]

// C10: Models/Data
instance BaseBIMModel : DTDFVocab:Model [
    base:desc "Base BIM model providing geometric, spatial and functional data of the building."
    DTDFVocab:inputTo ModelDrivenPipelineEnabler
]

instance EnrichedRuntimeMetadataModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing metadata for sensors, actuators and control logic."
    DTDFVocab:inputTo HonoAdapter, DittoPlatform
]

instance RLPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement learning policies generated by BOREALIS for adaptive lighting control."
    DTDFVocab:inputTo BOREALISEngine
]

instance EnergyOptimizationModel : DTDFVocab:Model [
    base:desc "Optimization model for energy consumption used by the EnergyOptimizationService."
    DTDFVocab:inputTo DittoPlatform, ModelDrivenPipelineEnabler
]

instance UnrealEngine3DVisualModel : DTDFVocab:Model [
    base:desc "3D visual model exported to Unreal Engine 5 for interactive visualization."
    DTDFVocab:inputTo UnrealEngine5Visualization
]

// C11: Enablers
instance HonoAdapter : DTDFVocab:Enabler [
    base:desc "Eclipse Hono protocol adapters (MQTT/HTTP/CoAP) streaming sensor telemetry to the twin."
    DTDFVocab:enables RealTimeMonitoringService, AdaptiveLightingControlService
]

instance DittoPlatform : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin platform storing and synchronising twin state."
    DTDFVocab:enables RealTimeMonitoringService, AnalyticsDashboardService, EnergyOptimizationService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 rendering engine providing interactive 3D visualization of the building twin."
    DTDFVocab:enables InteractiveVisualizationService
]

instance BOREALISEngine : DTDFVocab:Enabler [
    base:desc "BOREALIS reinforcement learning engine updating adaptive lighting control policies."
    DTDFVocab:enables AdaptiveLightingControlService
]

instance ModelDrivenPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline that validates enriched BIM, generates configurators and deploys runtime artifacts."
    DTDFVocab:enables EnergySimulationService, EnergyOptimizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring service aggregating live sensor telemetry."
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization service using Unreal Engine 5."
    DTDFVocab:provides VisualAnalyticsInsight
]

instance EnergySimulationService : DTDFVocab:Service [
    base:desc "Simulation service for building energy performance."
    DTDFVocab:provides EnergySimulationInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization service reducing energy consumption based on simulation results."
    DTDFVocab:provides EnergyConsumptionOptimizationInsight
]

instance AdaptiveLightingControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based adaptive lighting control service."
    DTDFVocab:provides AdaptiveLightingPolicyInsight, UpdateLightingActuatorAction
]

instance AnalyticsDashboardService : DTDFVocab:Service [
    base:desc "Analytics dashboard for facility managers delivering insights and recommendations."
    DTDFVocab:provides FacilityManagementInsight
]

// C17: Insights
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Live status and health of building systems derived from sensor streams."
]

instance VisualAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Visual analytics of building performance presented in the 3D twin."
]

instance EnergySimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results of thermal and energy behavior of the building."
]

instance EnergyConsumptionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for reducing energy consumption while maintaining occupant comfort."
]

instance AdaptiveLightingPolicyInsight : DTDFVocab:Insight [
    base:desc "Adapted lighting control policies generated by reinforcement learning."
]

instance FacilityManagementInsight : DTDFVocab:Insight [
    base:desc "Operational insights and parameter recommendations for facility managers."
]

// C18: Actions
instance UpdateLightingActuatorAction : DTDFVocab:Action [
    base:desc "Command to update lighting actuator setpoints based on adaptive policy."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command transmission from the twin to physical actuators using Ditto's command API routed through Eclipse Hono to the device endpoints, enabling remote control of lighting, HVAC, etc."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (continuous) data exchange and control loop; updates occur as soon as sensor messages are received and commands are dispatched, supporting near‑instantaneous synchronization."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central DT framework that ingests enriched BIM, generates Hono/Ditto configuration, streams data via Hono, persists twin state in Ditto, and exposes interactive visualisation through Unreal Engine; modular services plug into defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers design (BIM as‑designed), construction (BIM enriched with device metadata), commissioning, and operational phases (as‑operated), thus spanning the full building lifecycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation before deployment, use of the Overall Digital Twin Entanglement (ODTE) metric to quantify alignment between physical and virtual states, and mechanisms to mitigate semantic drift through synchronization routines."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensors/actuators connect to Eclipse Hono via protocol adapters (MQTT, HTTP, CoAP); Ditto provides REST/WEBsocket APIs for twin state access and command issuance; communication is secured by the underlying Hono transport layer."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Cloud‑hosted deployment of Eclipse Hono and Ditto services with Unreal Engine clients connecting for visualization; the DT framework orchestrates these components as a service‑oriented stack."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized extension points enable integration with external building management systems, other enterprise information systems, and potentially other Digital Twins, facilitating cross‑domain data exchange."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Leverages BIM standards for geometry and semantics, uses open protocols supported by Eclipse Hono (MQTT/HTTP/CoAP), adheres to the Overall Digital Twin Entanglement (ODTE) metric, and follows model‑driven engineering principles for interoperability."
]