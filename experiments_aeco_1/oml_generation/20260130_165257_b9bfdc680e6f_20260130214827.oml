// C3: Physical sensing components
instance BIMDefinedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor defined in the enriched BIM model and linked to TwinComponents receiving real-time measurements."
    DTDFVocab:producedData BuildingSensorDataStream
]

// C4: Data transmitted from sensors
instance BuildingSensorDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BIMDefinedSensor
]

// C5: Data generated from transmitted stream
instance BuildingSensorData : DTDFVocab:Data [
    base:desc "Sensor measurement data streamed via Eclipse Hono and stored in Eclipse Ditto."
    DTDFVocab:fromData BuildingSensorDataStream
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoStore
]

// C10: Models / Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing geometric building information and device definitions (sensors, actuators, controllers)."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance BIMToTwinMapping : DTDFVocab:Model [
    base:desc "Mapping tables associating BIM components with UE5 TwinComponents and DittoDevice identifiers for bidirectional synchronization."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

// C11: Enablers
instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline that validates, converts, and configures enriched BIM data into deployable Digital Twin artifacts."
    DTDFVocab:enables RealTimeSynchronizationService, InteractiveVisualizationService, ControlAndCommandService, CustomAnalyticsService
]

instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono gateway providing at‑least‑once MQTT/AMQP transport for ingesting sensor data."
    DTDFVocab:enables RealTimeSynchronizationService
]

instance EclipseDittoStore : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto policy‑based twin management service storing and versioning real‑time data."
    DTDFVocab:enables ControlAndCommandService
]

instance UnrealTwinController : DTDFVocab:Enabler [
    base:desc "UnrealTwinController synchronizes DT state with the UE5 visualization layer."
    DTDFVocab:enables InteractiveVisualizationService
]

instance AnalyticsEngineEnabler : DTDFVocab:Enabler [
    base:desc "Modular extension point enabling custom analytics and optimisation services."
    DTDFVocab:enables CustomAnalyticsService
]

// C6: Services
instance RealTimeSynchronizationService : DTDFVocab:Service [
    base:desc "Provides real‑time data exchange and continuous synchronization between the physical building and its digital twin."
    DTDFVocab:provides EnergyTrendInsight, FaultDetectionInsight, OptimizationRecommendationInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Enables interactive UE5 visualisation of building performance and system states."
    DTDFVocab:provides EnergyTrendInsight, FaultDetectionInsight
]

instance ControlAndCommandService : DTDFVocab:Service [
    base:desc "Allows control of sensors, actuators and controllers via the twin, enforcing policy validation before command execution."
    DTDFVocab:provides LightControlAction
]

instance CustomAnalyticsService : DTDFVocab:Service [
    base:desc "Custom analytics and optimisation services plugged in by DT engineers to process streamed sensor data."
    DTDFVocab:provides EnergyTrendInsight, FaultDetectionInsight, OptimizationRecommendationInsight
]

// C17: Insights
instance EnergyTrendInsight : DTDFVocab:Insight [
    base:desc "Operational insight on energy‑use trends derived from continuous sensor data."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of faults in building systems based on anomalies in real‑time measurements."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Generation of optimisation recommendations for building performance."
]

// C17: Actions
instance LightControlAction : DTDFVocab:Action [
    base:desc "Command to adjust a lighting actuator via DittoDevice after policy validation."
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance BIMDefinedActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator modelled in the BIM environment, instantiated as a TwinComponent (e.g., LightTwinComponent) and controlled through the UnrealTwinController."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT Framework provides a bidirectional data exchange where commands generated in the digital twin are transmitted to physical devices to enable real‑time monitoring and control (Document 1). Facility Managers interact with the deployed DT for control actions, and the framework acts as a central hub for sending these control messages to the field. No concrete command formats, authentication, or execution‑confirmation procedures are described in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange that ensures continuous (i.e., near‑zero‑latency) synchronization between the physical building and its digital twin; synchronization is performed continuously as runtime data arrive, without a defined fixed interval, supporting real‑time monitoring and control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, service‑oriented architecture with standardized extension points; the central DT Framework mediates bidirectional data exchange, supports runtime configuration management, and allows DT Engineers to plug in custom analytics services, achieving coordinated orchestration of components across the building lifecycle."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The proposed model‑driven deployment framework supports the complete Digital Twin life‑cycle. It begins with device modeling where Building Control Engineers enrich BIM models with explicit definitions of sensors, actuators and controllers, creating a unified semantic foundation. A Model‑Driven Engineering (MDE) transformation then extracts structured representations from these enriched BIM models and automatically generates deployable DT artifacts with minimal manual effort. The next stage is deployment and runtime operation, characterised by continuous real‑time data exchange that keeps the physical building and its digital counterpart synchronised. Interactive visualisation provides immersive monitoring and control interfaces for Facility Managers. Finally, the modular architecture with standardized extension points permits integration of custom services and analytics, allowing the twin to evolve over time. Transition between stages is managed automatically by the MDE pipeline, and lifecycle governance is anchored in the role‑based responsibilities (Building Control Engineer, Facility Manager, DT Engineer) defined in Table I."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by a validation pipeline that checks enriched BIM models for completeness (presence of sensor/actuator definitions) and correctness (unit consistency) before generating twin artifacts. Eclipse Ditto enforces policy‑based validation of both incoming sensor values and outgoing actuator commands, providing error detection and automatic rejection of out‑of‑range data. Fault tolerance is achieved through Eclipse Hono’s at‑least‑once message delivery and Ditto’s persistent event storage, which together guarantee data integrity and resilience to network failures. Uncertainty sources such as sensor noise or model approximations are not quantified in the documents, but the combination of runtime validation, persistent storage and policy checks constitutes the quality assurance process for models and data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connectivity relies on a modular architecture that incorporates Eclipse Hono and Eclipse Ditto (R3, Document 3). Hono handles protocol translation and device connectivity, while Ditto stores and exposes the twin state via its APIs. The network topology, bandwidth, latency, redundancy, and security protocols are not explicitly specified in the provided material."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "An automated, model‑driven deployment process is defined (R2, Document 3) to create reproducible DT setups and supports runtime configuration changes without full redeployment (Document 1). The documents mention a modular framework and extension points but do not specify the underlying hosting platform (cloud, edge, on‑premise), computational or storage sizing, scalability mechanisms, or availability guarantees."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed through standardized extension points and adherence to heterogeneous system standards, enabling integration of BIM models, sensor networks, and external analytics services; the framework is designed to interoperate via open‑source DT platforms (e.g., Eclipse Ditto, BaSyx) and enterprise systems using common communication protocols, though specific protocols are not enumerated."
]