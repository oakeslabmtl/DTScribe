namespace base = "http://www.w3.org/2000/01/rdf-schema#"
namespace DTDFVocab = "http://example.com/DTDFVocab"
instance BuildingTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring ambient temperature in building spaces",
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance HVACHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring humidity levels in HVAC systems",
    DTDFVocab:producedData HumidityDataTransmitted
]
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor detecting room occupancy for space utilization",
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance AirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring indoor air quality parameters",
    DTDFVocab:producedData AirQualityDataTransmitted
]
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling heating, ventilation, and air conditioning systems"
]
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator managing building lighting systems"
]
instance ControllerUnit : DTDFVocab:ActingComponent [
    base:desc "Central control unit for managing building systems"
]
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Transmitted temperature data from BuildingTemperatureSensor",
    DTDFVocab:producedFrom BuildingTemperatureSensor
]
instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Transmitted humidity data from HVACHumiditySensor",
    DTDFVocab:producedFrom HVACHumiditySensor
]
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Transmitted occupancy data from OccupancySensor",
    DTDFVocab:producedFrom OccupancySensor
]
instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Transmitted air quality data from AirQualitySensor",
    DTDFVocab:producedFrom AirQualitySensor
]
instance RealTimeTemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature readings from building sensors",
    DTDFVocab:fromData TemperatureDataTransmitted,
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]
instance RealTimeHumidityData : DTDFVocab:Data [
    base:desc "Real-time humidity data from HVAC systems",
    DTDFVocab:fromData HumidityDataTransmitted,
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]
instance RealTimeOccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy data for space management",
    DTDFVocab:fromData OccupancyDataTransmitted,
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]
instance RealTimeAirQualityData : DTDFVocab:Data [
    base:desc "Real-time air quality measurements for indoor environment",
    DTDFVocab:fromData AirQualityDataTransmitted,
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]
instance BIMModel : DTDFVocab:Model [
    base:desc "Geometric and semantic representation of building structure and systems from BIM",
    DTDFVocab:inputTo VisualizationEnabler
]
instance CustomAnalyticalModel : DTDFVocab:Model [
    base:desc "Custom analytical models integrated for evolving operational requirements",
    DTDFVocab:inputTo ModularAnalyticsEnabler
]
instance RealTimeDataExchangeEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for real-time data synchronization between physical and digital entities",
    DTDFVocab:enables MonitoringService, VisualizationService
]
instance ModularAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Modular architecture for integrating custom analytics services",
    DTDFVocab:enables PredictiveAnalyticsService, OptimizationService
]
instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for interactive visualization interfaces",
    DTDFVocab:enables VisualizationService
]
instance MonitoringService : DTDFVocab:Service [
    base:desc "Service for real-time monitoring of building systems",
    DTDFVocab:provides BuildingStateInsight
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization interface for facility managers to monitor and control building systems",
    DTDFVocab:provides BuildingStateInsight
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service for predictive analytics in maintenance and energy efficiency",
    DTDFVocab:provides MaintenancePredictionInsight
]
instance OptimizationService : DTDFVocab:Service [
    base:desc "Service for optimizing operational processes and energy usage",
    DTDFVocab:provides OperationalOptimizationInsight, HVACControlAction
]
instance BuildingStateInsight : DTDFVocab:Insight [
    base:desc "Real-time state of building systems for monitoring and control"
]
instance MaintenancePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive insights for maintenance scheduling"
]
instance OperationalOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization of building operational processes"
]
instance HVACControlAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of HVAC system based on sensor data",
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle includes initial device modeling within BIM environments where Building Control Engineers define sensors, actuators, and controllers, followed by Model-Driven Engineering (MDE) transformation of enriched BIM models into structured representations, automatic generation of deployable DT artifacts, real-time data exchange for continuous synchronization, interactive visualization for monitoring and control, and modular integration of custom services to support operational evolution."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework employs standardized extension points within its modular architecture to ensure interoperability and facilitate the integration of custom services and analytics."
]