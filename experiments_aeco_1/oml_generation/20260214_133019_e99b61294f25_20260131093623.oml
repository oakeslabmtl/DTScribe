// C2: Acting Components
instance ProgrammableLuminaire : DTDFVocab:ActingComponent [
    base:desc "Programmable luminaire represented as BIM element with device ID for integration into Eclipse Ditto"
]

instance HVACDamper : DTDFVocab:ActingComponent [
    base:desc "HVAC damper embedded in the building, modeled as BIM element with device ID for Ditto integration"
]

instance ElectricBlind : DTDFVocab:ActingComponent [
    base:desc "Electric blind actuated via API-enabled control unit, BIM element with device ID for Ditto"
]

instance APIEnabledHVACControlUnit : DTDFVocab:ActingComponent [
    base:desc "API-enabled HVAC control unit, BIM element with device ID, integrated into Eclipse Ditto"
]

// C3: Physical Sensing Components
instance LightingOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Lighting occupancy sensor configured in BIM with metadata for Hono registration"
    DTDFVocab:producedData OccupancyDataStream
]

instance IlluminanceMeter : DTDFVocab:SensingComponent [
    base:desc "Illuminance meter sensor for lighting level monitoring, BIM element linked to Hono"
    DTDFVocab:producedData IlluminanceDataStream
]

instance TempHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Temperature and humidity sensor embedded in the building, BIM element with Hono metadata"
    DTDFVocab:producedData TempHumidityDataStream
]

instance CO2Monitor : DTDFVocab:SensingComponent [
    base:desc "CO₂ monitor sensor for indoor air quality, BIM element and Hono registration"
    DTDFVocab:producedData CO2DataStream
]

// C4: Physical-to-virtual interaction (data transmitted)
instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingOccupancySensor
]

instance IlluminanceDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceMeter
]

instance TempHumidityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TempHumiditySensor
]

instance CO2DataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Monitor
]

instance HVACDamperDataStream : DTDFVocab:DataTransmitted [
]

instance BlindControlDataStream : DTDFVocab:DataTransmitted [
]

instance HVACControlUnitDataStream : DTDFVocab:DataTransmitted [
]

// C5: Data
instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy data captured by the lighting occupancy sensor"
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo InfluxDB, PostgreSQL
]

instance IlluminanceData : DTDFVocab:Data [
    base:desc "Real-time illuminance level data from the lighting metering sensor"
    DTDFVocab:fromData IlluminanceDataStream
    DTDFVocab:inputTo InfluxDB, PostgreSQL
]

instance TempHumidityData : DTDFVocab:Data [
    base:desc "Real-time temperature and humidity data captured by the sensor"
    DTDFVocab:fromData TempHumidityDataStream
    DTDFVocab:inputTo InfluxDB, PostgreSQL
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Real-time CO₂ concentration data from the indoor air quality sensor"
    DTDFVocab:fromData CO2DataStream
    DTDFVocab:inputTo InfluxDB, PostgreSQL
]

// C10: Models/Data
instance BuildingIfcModelEnriched : DTDFVocab:Model [
    base:desc "IFC model of the LEED Platinum Living Lab building enriched with control annotations for Ditto integration"
    DTDFVocab:inputTo DittoConfigurator
]

instance BIMValidationModel : DTDFVocab:Model [
    base:desc "Validated BIM model converted via ATL rules into Ditto twin specifications"
    DTDFVocab:inputTo DittoConfigurator
]

instance ODTELifecycleMetricsModel : DTDFVocab:Model [
    base:desc "Lifecycle metrics model tracked via ODTE for digital twin evolution"
    DTDFVocab:inputTo ODTELifecycleTracker
]

// C11: Enablers
instance EclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT broker facilitating continuous ingestion of sensor telemetry"
]

instance EclipseDittoPlatform : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin platform hosting device twins and exposing REST/WebSocket APIs"
    DTDFVocab:enables SimulationEngineService
]

instance InfluxDB : DTDFVocab:Enabler [
    base:desc "InfluxDB time-series database for storing continuous sensor streams"
    DTDFVocab:enables PerformanceAnalyticsDashboardService, PredictiveHeatMapService, OptimizationAlgorithmService
]

instance PostgreSQL : DTDFVocab:Enabler [
    base:desc "PostgreSQL database for storing historical operation logs"
]

instance DockerKubernetesDeployment : DTDFVocab:Enabler [
    base:desc "Docker/Kubernetes deployment orchestrator for the digital twin services"
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3D visualization of the building"
]

instance ContinuousIntegrationPipeline : DTDFVocab:Enabler [
    base:desc "Continuous integration pipeline triggering redeployments on BIM model changes"
]

instance DittoConfigurator : DTDFVocab:Enabler [
    base:desc "Ditto Configurator auto-spawning twin specifications from transformed BIM models"
]

instance ODTELifecycleTracker : DTDFVocab:Enabler [
    base:desc "ODTE-based lifecycle metrics tracker for digital twin evolution and compliance"
]

// C6: Services
instance PerformanceAnalyticsDashboardService : DTDFVocab:Service [
    base:desc "Aggregates performance analytics and surfaces them through dashboards"
    DTDFVocab:provides PerformanceAnalyticsInsight
]

instance PredictiveHeatMapService : DTDFVocab:Service [
    base:desc "Generates predictive heat maps guiding facility manager adjustments"
    DTDFVocab:provides PredictiveHeatMapInsight
]

instance OptimizationAlgorithmService : DTDFVocab:Service [
    base:desc "Optimizes lighting schedules and HVAC control via reinforcement‑learning policies, generating recommendation logs"
    DTDFVocab:provides GenerateRecommendationLogsAction
]

instance SimulationEngineService : DTDFVocab:Service [
    base:desc "Simulates building physics and environmental dynamics using sensor telemetry"
    DTDFVocab:provides LiveSimulationInsight
]

// C17: Insights/Actions
instance PerformanceAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Insight derived from aggregated occupancy, illuminance, temperature, and humidity data"
]

instance PredictiveHeatMapInsight : DTDFVocab:Insight [
    base:desc "Heat map indicating predicted thermal performance across building zones"
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight conveying optimization algorithm recommendations for building schedules"
]

instance LiveSimulationInsight : DTDFVocab:Insight [
    base:desc "Real-time simulation insight visualized in Unreal Engine 5"
]

instance GenerateRecommendationLogsAction : DTDFVocab:Action [
    base:desc "Automated action that generates recommendation logs feeding back into BIM schedules"
    DTDFVocab:IsAutomatic true
]

// C18: Environment
instance BuildingLevelTwinEnvironment : DTDFVocab:Environment [
    base:desc "Building-level twin orchestrating over 200 device twins within the LEED Platinum Living Lab academic building"
    base:contains ProgrammableLuminaire, HVACDamper, ElectricBlind, APIEnabledHVACControlUnit, LightingOccupancySensor, IlluminanceMeter, TempHumiditySensor, CO2Monitor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Command messages generated by the DT’s control logic are transmitted over Ditto’s MQTT endpoint to Hono, which routes them to the corresponding actuator devices, enabling real‑time actuation of lighting, HVAC, and shading systems."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with micro‑second to millisecond latency end‑to‑end, supported by MQTT QoS 1, ensuring that sensor updates and actuator commands propagate within <10 ms under normal network conditions."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "System architecture comprising BIM model repository, middleware (Hono + Ditto), data storage (InfluxDB/PostgreSQL), analytical services (Python/Node.js), and visualization layer (Unreal Engine), with APIs exposing state and control."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Captures the entire asset lifecycle: design‑time (BIM model), construction‑time (manufacturing data export), and operation‑time (live monitoring and control); each stage generates specific data feeds into the DT."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validity enforced through IFC conformance checks, semantic drift monitored using ODTE metric, runtime verification of control logic against safety constraints, uncertainty quantified via sensor calibration reports."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication stack: MQTT over TCP/IP using Hono for device connectivity, Ditto’s MQTT endpoint for twin synchronization, RESTful APIs for data queries, optional WebSocket for real‑time dashboards."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted in containerized microservices on a private Kubernetes cluster within the building’s data center; Ditto instance runs in a replicated deployment with HA enabled, time‑series database in a dedicated pod."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized data exchange using IFC services and ABIM, connectivity to external Building Management Systems via OPC‑UA gateways; interoperability with other DTs achieved through Ditto’s tenant isolation and shared topics."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with IFC 4X for BIM, MQTT/TLS for secure messaging, Ditto entity schema following W3C Web of Things standards, MDE processes conform to ISO/IEC 42010."
]