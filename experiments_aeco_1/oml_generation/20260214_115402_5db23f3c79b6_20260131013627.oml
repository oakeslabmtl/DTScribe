// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator modelled in the BIM that enables control of building lighting systems."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator modelled in the BIM that enables control of heating, ventilation and air‑conditioning services."
]

instance BuildingController : DTDFVocab:ActingComponent [
    base:desc "Controller modelled in the BIM that coordinates actuator actions for the building control system (BCS)."
]

// C3: Physical Sensing Components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Building sensor embedded in the BIM for measuring illumination levels."
    DTDFVocab:producedData LightingDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Building sensor embedded in the BIM for detecting presence of occupants."
    DTDFVocab:producedData OccupancyDataStream
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Building sensor embedded in the BIM for measuring temperature, humidity and CO₂."
    DTDFVocab:producedData EnvironmentalDataStream
]

// C4: Physical‑to‑Virtual Interaction – Data Transmitted
instance LightingDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnvironmentalDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C10: Models & Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing geometry, topology and device metadata."
    DTDFVocab:inputTo ModelDrivenEngine, BIMSemanticBackbone
]

instance RuntimeSemanticsModel : DTDFVocab:Model [
    base:desc "Runtime semantics model describing sensor configurations, control logic and deployment artifacts."
    DTDFVocab:inputTo ModelDrivenEngine, BIMSemanticBackbone
]

instance LightingData : DTDFVocab:Data [
    base:desc "Live illumination measurements streamed from LightingSensor."
    DTDFVocab:fromData LightingDataStream
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy events streamed from OccupancySensor."
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Live temperature, humidity and CO₂ readings streamed from EnvironmentalSensor."
    DTDFVocab:fromData EnvironmentalDataStream
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C11: Enablers
instance BIMSemanticBackbone : DTDFVocab:Enabler [
    base:desc "BIM used as the semantic backbone for the digital twin."
    DTDFVocab:enables RealTimeMonitoringDashboard, Interactive3DVisualization
]

instance ModelDrivenEngine : DTDFVocab:Enabler [
    base:desc "Model‑to‑model/text transformation engine generating deployment artifacts for Hono, Ditto and visualization components."
    DTDFVocab:enables RealTimeMonitoringDashboard, Interactive3DVisualization, SimulationService, PredictiveAnalyticsService, EnergyOptimizationService, CustomPluginPlatform
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono IoT broker that receives MQTT/HTTP streams from building sensors."
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalyticsService, EnergyOptimizationService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin platform that stores device twins and propagates status updates."
    DTDFVocab:enables RealTimeMonitoringDashboard, SimulationService, PredictiveAnalyticsService, EnergyOptimizationService, CustomPluginPlatform
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 provides interactive 3D visualization of the building twin."
    DTDFVocab:enables Interactive3DVisualization
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Web‑based dashboard showing live sensor readings and actuator states."
    DTDFVocab:provides OperationalInsights, AdjustBuildingControls
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "Immersive 3D view of the building with real‑time overlay of sensor data."
    DTDFVocab:provides OperationalInsights
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs physics‑based simulations using the BIM and runtime semantics."
    DTDFVocab:provides PredictiveAnalyticsInsights, RefurbishmentDecisionSupport
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Analytics service that generates forecasts and anomaly detection for energy consumption."
    DTDFVocab:provides PredictiveAnalyticsInsights, EnergyOptimizationRecommendations
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization engine that recommends control set‑points to improve energy efficiency."
    DTDFVocab:provides EnergyOptimizationRecommendations, AdjustBuildingControls
]

instance CustomPluginPlatform : DTDFVocab:Service [
    base:desc "Extension point allowing deployment of bespoke facility‑management services."
    DTDFVocab:provides CustomAction
]

// C17: Insights / Actions
instance OperationalInsights : DTDFVocab:Insight [
    base:desc "Real‑time operational insight into building performance generated from live data."
]

instance PredictiveAnalyticsInsights : DTDFVocab:Insight [
    base:desc "Predictive insight derived from historical trends and simulation outputs."
]

instance EnergyOptimizationRecommendations : DTDFVocab:Insight [
    base:desc "Recommendation to adjust HVAC and lighting schedules for reduced energy usage."
]

instance RefurbishmentDecisionSupport : DTDFVocab:Insight [
    base:desc "Insight supporting refurbishment decisions based on model‑driven analysis."
]

instance AdjustBuildingControls : DTDFVocab:Action [
    base:desc "Automatic action to modify actuator set‑points according to optimization recommendations."
    DTDFVocab:IsAutomatic true
]

instance CustomAction : DTDFVocab:Action [
    base:desc "User‑defined action invoked by custom plug‑ins."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional control messages generated by the Digital Twin are sent back to physical actuators through the same Hono/Ditto middleware, enabling the twin to issue commands (e.g., lighting adjustments, HVAC set‑points) to the building control system."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time synchronization (sub‑second update rates) between physical sensor streams and the Digital Twin, driven by the Hono/Ditto real‑time data exchange layer."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central DT framework hub orchestrating bidirectional data flow between enriched BIM models, Hono/Ditto middleware, and visualization services; modular components connect through defined interfaces to form the overall twin ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin spans the building life‑cycle stages of design (ideal BIM model), construction/manufacturing (as‑built BIM enrichment), and operation (runtime‑aware twin incorporating live sensor data and control logic)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is employed to assess how faithfully the twin mirrors its physical counterpart, providing a quantitative measure of entanglement and model validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication relies on Eclipse Hono (supporting MQTT and HTTP) and Eclipse Ditto (exposing REST/HTTP and WebSocket APIs), establishing the network link between physical sensors/actuators and the Digital Twin services."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin components (Hono broker, Ditto platform, Unreal Engine client) are hosted on server infrastructure that runs the middleware services and provides the visualization front‑end; deployment is automated via the model‑driven framework."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach leverages BIM standards for building information, and adopts industry‑wide IoT communication standards (MQTT, REST/HTTP) via Eclipse Hono and Ditto; extension points follow service‑oriented architectural standards."
]