// Acting Component
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Dimmable lighting fixture, accepts on/off, brightness (0‑100 %) and color‑temperature commands transmitted as JSON over Ditto via Eclipse Hono, guaranteeing at‑least‑once delivery."
]

// Data Transmitted (commands)
instance LightCommandTransmitted : DTDFVocab:DataTransmitted [
    // DTDFVocab:producedFrom LightTwinComponent  // removed due to range mismatch
]

// Data (command payload)
instance LightCommandData : DTDFVocab:Data [
    base:desc "JSON payload containing on/off, brightness, and color‑temperature values sent by LightTwinComponent."
    DTDFVocab:fromData LightCommandTransmitted
    DTDFVocab:inputTo HonoEnabler
]

// Sensing Component (lighting power sensor)
instance LightingPowerSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring lighting power consumption, sending telemetry to Ditto."
    DTDFVocab:producedData LightingPowerTelemetryTransmitted
]

// Data Transmitted (telemetry)
instance LightingPowerTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingPowerSensor
]

// Data (telemetry payload)
instance LightingPowerTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data stream of lighting power consumption in watts."
    DTDFVocab:fromData LightingPowerTelemetryTransmitted
    DTDFVocab:inputTo DittoEnabler
]

// Models
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "3D Building Information Model (Revit/IFC) enriched with photometric values for lighting fixtures."
    DTDFVocab:inputTo MdeConversionEngine
]

instance BIMBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model encoding sensors, actuators, and controllers as semantic annotations within BIM, enabling building control engineers to specify device relationships."
    DTDFVocab:inputTo MdeConversionEngine
]

instance AnalyticalDataModel : DTDFVocab:Model [
    base:desc "Model aggregating real‑time telemetry and command streams, producing analytic data objects in Ditto."
    DTDFVocab:inputTo DittoEnabler
]

// Enablers
instance DittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto data store publishing modeled entities, ensuring real‑time data exchange for consistency checking."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, InteractiveVisualizationService
]

instance HonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono message broker providing at‑least‑once delivery for telemetry and command messages between physical devices and the twin."
    DTDFVocab:enables AutomatedControlService
]

instance UE5VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "UE 5 engine enabling immersive visualization of the digital twin through dashboards."
    DTDFVocab:enables InteractiveVisualizationService
]

instance MdeConversionEngine : DTDFVocab:Enabler [
    base:desc "MDE conversion engine validating, normalizing, and transforming enriched BIM into CoAP/MQTT compliant representations."
    DTDFVocab:enables RealTimeMonitoringService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building system states (HVAC, lighting) using telemetry streams."
    DTDFVocab:provides EnergyConsumptionInsight, EquipmentHealthInsight
]

instance AutomatedControlService : DTDFVocab:Service [
    base:desc "Automated control logic for HVAC and lighting actuators via command streams."
    DTDFVocab:provides LightingControlAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy consumption forecasting and equipment health monitoring."
    DTDFVocab:provides EnergyConsumptionPredictionInsight, EquipmentHealthPredictionInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization via immersive interfaces for Facility Managers to interpret insights and make control decisions."
    DTDFVocab:provides ControlDecisionInsight
]

// Insights
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight on real‑time energy consumption derived from telemetry."
]

instance EquipmentHealthInsight : DTDFVocab:Insight [
    base:desc "Insight on equipment health extracted from predictive analytics."
]

instance EnergyConsumptionPredictionInsight : DTDFVocab:Insight [
    base:desc "Future energy consumption forecast generated by predictive analytics."
]

instance EquipmentHealthPredictionInsight : DTDFVocab:Insight [
    base:desc "Forecasted equipment health status."
]

instance ControlDecisionInsight : DTDFVocab:Insight [
    base:desc "Insight facilitating control decisions by Facility Managers presented through immersive dashboards."
]

// Actions
instance LightingControlAction : DTDFVocab:Action [
    base:desc "Action to adjust lighting parameters (on/off, brightness, color temperature)."
    DTDFVocab:IsAutomatic true
]

instance HVACControlAction : DTDFVocab:Action [
    base:desc "Action to modify HVAC setpoints."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time bidirectional data exchange ensures continuous synchronization between the physical building and its digital twin; the design allows for arbitrarily high update rates, but specific time‑step frequencies, latency budgets, or temporal granularities are not disclosed in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated around a central DT Framework hub that provides a modular architecture with standardized extension points. The framework facilitates bidirectional data exchange between the physical building and the digital twin, integrates device‑level models (initiated by Building Control Engineers), exposes monitoring and control interfaces to Facility Managers, and enables extensibility through DT Engineers adding custom services or analytics. Resource management and runtime configuration are handled centrally, allowing adjustments without full redeployment and supporting scalability from individual components to entire facility systems."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework delineates a multi‑phase lifecycle that begins with BIM enrichment by Building Control Engineers, who embed sensors, actuators, and controllers into the BIM model. MDE principles then transform the enriched BIM into a structured semantic representation. Automated generators convert this representation into deployable DT artifacts that are provisioned in a runtime environment. Continuous real‑time data exchange maintains state synchronization during operation, allowing Facility Managers to monitor and control the twin. The modular architecture permits DT Engineers to inject custom services and analytics, thereby evolving the twin without re‑engineering the core model. Transition management is achieved through automated model extraction and deployment pipelines, and lifecycle governance is enforced through clearly defined stakeholder roles (engineer, manager, and DT engineer) and the use of standardized extension points."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through a multi‑stage validation pipeline.  Enriched BIM models undergo a formal *validation component* that checks consistency against a pre‑defined ontology (units, ranges, topology).  During runtime, Eclipse Ditto’s policy engine validates sensor telemetry against declared value ranges and units, generating violations if null, out‑of‑range, or malformed data are received.  Similarly, actuator commands trigger pre‑execution checks to prevent unsafe operations.  Uncertainty in sensor readings originates from device calibration and wireless link jitter; these uncertainties are not quantified explicitly but are mitigated by the policy layer, which may throttle or discard data beyond tolerance.  Fault tolerance is achieved by Eclipse Hono’s at‑least‑once message delivery and Ditto’s persistent event store, ensuring that lost or delayed messages are redelivered and persisted for audit.  Model verification is performed when the twin is instantiated: the conversion engine emits diagnostic logs and the Kafka‑style event stream from Ditto is monitored for policy violations and message sequencing errors, providing a continuous quality‑assurance loop that keeps the digital and physical systems aligned."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability across heterogeneous systems is addressed through the architecture’s standardized extension points, enabling data exchange with legacy BIM systems and operational platforms. While the documents do not specify particular protocols or detailed integration patterns with external enterprise systems, they emphasize support for heterogeneous technologies and bidirectional data exchange within the Digital Twin ecosystem."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework is built upon BIM, which adheres to Industry Foundation Classes (IFC) data models, enabling interoperability across architectural, engineering, and construction tools. Model‑Driven Engineering ensures that the enrichment and transformation processes conform to standardized semantic models derived from BIM. The runtime layer is compatible with open‑source Digital‑Twin frameworks such as Eclipse Ditto, BaSyx, and iTwin.js, thereby adopting their communication protocols and data schemas. However, explicit compliance with normative standards (ISO 13249‑3, IEC 61334‑5‑1, etc.) or certification requirements is not addressed in the provided documents."
]