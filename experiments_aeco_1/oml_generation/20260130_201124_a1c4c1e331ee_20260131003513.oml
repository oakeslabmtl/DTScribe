// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in the BIM model as a first‑class object, annotated with location, tenant and device ID."
    DTDFVocab:producedData TemperatureDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in the BIM model as a first‑class object, annotated with location, tenant and device ID."
    DTDFVocab:producedData OccupancyDataStream
]

// C4: Data transmitted from sensors
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C5: Data objects
instance TemperatureMeasurement : DTDFVocab:Data [
    base:desc "Real‑time temperature measurement streamed from the physical building sensor."
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance OccupancyMeasurement : DTDFVocab:Data [
    base:desc "Real‑time occupancy count streamed from the building sensor."
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// C2: Acting components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator modeled in the BIM model, configured by the Building Control Engineer and remotely operated by the Facility Manager via the digital twin."
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in the BIM model, configurable and controllable through the digital twin interface."
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM geometric model enriched with sensor, actuator and controller definitions."
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance ThermalSimulationModel : DTDFVocab:Model [
    base:desc "Thermal simulation model derived from the enriched BIM for evaluating heat flows."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance PredictiveAnalyticsModel : DTDFVocab:Model [
    base:desc "Predictive analytics model linking historical measurements to future performance forecasts."
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono receives sensor telemetry from the physical infrastructure and forwards it to Eclipse Ditto."
    DTDFVocab:enables RealTimeMonitoringService,
                     BuildingSimulationService,
                     PredictiveAnalyticsService,
                     EnergyOptimizationService,
                     DecisionSupportVisualizationService,
                     CollaborativeToolService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto synchronizes incoming sensor measurements with the digital twin state and supports downstream analytics."
    DTDFVocab:enables RealTimeMonitoringService,
                     BuildingSimulationService,
                     PredictiveAnalyticsService,
                     EnergyOptimizationService,
                     DecisionSupportVisualizationService,
                     CollaborativeToolService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of sensor and operational data for the building."
    DTDFVocab:provides TemperatureInsight, OccupancyInsight
]

instance BuildingSimulationService : DTDFVocab:Service [
    base:desc "Simulates building behaviour using the enriched BIM and thermal models."
    DTDFVocab:provides SimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Runs predictive analytics to forecast building performance."
    DTDFVocab:provides PerformanceForecastInsight, EnergySavingAction
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimises energy and resource use based on analytics and simulation results."
    DTDFVocab:provides EnergySavingAction
]

instance DecisionSupportVisualizationService : DTDFVocab:Service [
    base:desc "Delivers decision‑support visualisations for stakeholders across the building life‑cycle."
    DTDFVocab:provides VisualizationInsight
]

instance CollaborativeToolService : DTDFVocab:Service [
    base:desc "Enables collaborative tools for co‑editing and annotating the digital twin throughout its lifecycle."
    DTDFVocab:provides CollaborationAction
]

// C17: Insights
instance TemperatureInsight : DTDFVocab:Insight [
    base:desc "Current temperature trends and alerts derived from continuous sensor streams."
]

instance OccupancyInsight : DTDFVocab:Insight [
    base:desc "Live occupancy levels and occupancy‑based alerts for space utilisation."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results of thermal performance and occupant comfort for scenario analysis."
]

instance PerformanceForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of future energy consumption and comfort metrics based on predictive analytics."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive dashboards visualising key performance indicators of the building."
]

// C17: Actions
instance EnergySavingAction : DTDFVocab:Action [
    base:desc "Automatically adjusts HVAC and lighting actuators to reduce energy consumption based on analytics."
    DTDFVocab:IsAutomatic true
]

instance CollaborationAction : DTDFVocab:Action [
    base:desc "Allows multiple stakeholders to co‑edit, comment and approve changes in the digital twin model."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT Framework enables bidirectional data exchange, allowing Facility Managers to issue real‑time monitoring and control commands from the digital twin to the physical building infrastructure. Commands are transmitted via the same modular, configurable runtime, but the document does not detail command formats, validation, authentication, feedback systems, conflict resolution, or execution confirmation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The platform provides continuous, real‑time synchronization between the physical asset and its digital counterpart. Sensor data are ingested via Eclipse Hono and immediately propagated to the Eclipse Ditto twin, enabling live synchronization with low latency (exact latency not quantified). This supports services that require up‑to‑date state such as simulation, analysis and optimization, thus operating on a real‑time time scale."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a central‑hub architecture where the DT Framework acts as the core orchestrator. It exposes standardized extension points for modular service integration, mediates bidirectional data exchange, and centrally manages resources. Eclipse Hono provides device connectivity and telemetry ingestion, while Eclipse Ditto supplies the twin management layer; together they form an orchestrated constellation of components integrated through the DT Framework."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a four‑stage life‑cycle for a building Digital Twin: (1) **Device Modeling** – Building Control Engineers enrich BIM models with explicit sensor, actuator and controller entities, creating a semantically‑rich BIM representation; (2) **Model Transformation** – Model‑Driven Engineering (MDE) extracts a platform‑independent structured representation (e.g., domain‑specific metamodel) from the enriched BIM and automatically generates deployable DT artifacts; (3) **Deployment & Runtime** – The generated artifacts are instantiated as a live Twin, with real‑time data exchange synchronising physical devices and the digital counterpart; (4) **Operation & Evolution** – Facility Managers monitor and control the system via interactive visualisation, while DT Engineers add custom services through standardized extension points. Transition between stages is automated by the model‑driven pipeline, and governance is enforced through role‑based responsibilities (Control Engineer, Facility Manager, DT Engineer) and the functional‑requirement checklist (Table III)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed using the Overall Digital Twin Entanglement (ODTE) metric, which quantifies the degree of alignment between the enriched BIM model and the physical system. Prior to deployment, models undergo a validation step (referencing prior work [65]) to ensure correctness; only validated models are passed to the Hono/Ditto configurator. Model‑driven engineering contributes to governance by enforcing compliance, encouraging reuse, and supporting quality‑assurance processes throughout the DT lifecycle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection is described as a modular architecture with standardized extension points and runtime configuration, supporting interoperability across heterogeneous systems, scalability, maintainability, and accessibility (NF_X). No concrete communication protocols, network topology, bandwidth, latency, redundancy mechanisms, or security protocols are enumerated in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration is achieved through interoperability standards with external BIM environments. The DT framework consumes and produces Building Information Modeling data using standard formats (e.g., IFC) and offers generic APIs for bidirectional communication with enterprise systems, allowing the twin to be linked to other digital twins or operational management platforms without specifying particular transport protocols."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is grounded in the Building Information Modeling (BIM) standard, using BIM as the primary source of semantic data for device definition and control logic. The framework adopts standardized extension points for plug‑in integration, providing a consistent interface for extending functionality. No additional industry specifications, certification schemes, or interoperability standards are explicitly cited in the document."
]