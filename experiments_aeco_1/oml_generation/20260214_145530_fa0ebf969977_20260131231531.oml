// C13: Service-Insight/Action Relationships
instance ScenarioTestingService : DTDFVocab:Service [
    base:desc "Service for testing different scenarios on digital twin models"
    DTDFVocab:provides ScenarioAnalysisInsight, RetrofittingRecommendationAction
]

instance ThermalAnalysisService : DTDFVocab:Service [
    base:desc "Service for performing thermal analysis on building systems"
    DTDFVocab:provides ThermalAnalysisInsight, EnergyOptimizationInsight
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Service for storing and managing data in time-series databases"
    DTDFVocab:provides DataStorageInsight, HistoricalAnalysisInsight
]

instance HistoricalAnalyticsService : DTDFVocab:Service [
    base:desc "Service for performing historical analytics on stored data"
    DTDFVocab:provides HistoricalAnalyticsInsight, TrendAnalysisInsight
]

instance LongTermTrendService : DTDFVocab:Service [
    base:desc "Service for analyzing long-term trends in sensor data"
    DTDFVocab:provides TrendAnalysisInsight, PredictiveMaintenanceInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Service for detecting anomalies in sensor data"
    DTDFVocab:provides AnomalyDetectionInsight, PredictiveMaintenanceInsight
]

instance IoTInteroperabilityService : DTDFVocab:Service [
    base:desc "Service for ensuring interoperability between IoT devices and digital twin platform"
    DTDFVocab:provides InteroperabilityInsight, CommunicationInsight
]

instance RealTimeCommunicationService : DTDFVocab:Service [
    base:desc "Service for enabling real-time communication between components"
    DTDFVocab:provides CommunicationInsight, SynchronizationInsight
]

instance ImmersiveTrainingService : DTDFVocab:Service [
    base:desc "Service for providing immersive training experiences using digital twins"
    DTDFVocab:provides TrainingInsight, MaintenanceInsight
]

instance MaintenanceVisualizationService : DTDFVocab:Service [
    base:desc "Service for visualizing maintenance information in digital twins"
    DTDFVocab:provides MaintenanceInsight, VisualizationInsight
]

