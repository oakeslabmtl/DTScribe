// C3: Physical sensing components
instance BuildingTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor telemetry from physical building components ingested by Eclipse Hono as described in the Physical‑to‑Virtual Interaction characteristic."
    DTDFVocab:producedData BuildingTelemetryDataTransmitted
]

// C4: Data transmitted from sensors
instance BuildingTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingTelemetrySensor
]

// C5: Processed data within the twin
instance BuildingTelemetryData : DTDFVocab:Data [
    base:desc "Normalized building telemetry (e.g., temperature, occupancy, CO₂) made available to downstream services after validation and enrichment."
    DTDFVocab:fromData BuildingTelemetryDataTransmitted
    DTDFVocab:inputTo HonoIngestEnabler, DittoTwinEnabler
]

// C10: Models/Data
instance IfcBimModel : DTDFVocab:Model [
    base:desc "Geometric BIM model exported as IFC and enriched with device metadata (Instance General UUID, IFC‑type, photometric values)."
    DTDFVocab:inputTo SemanticExtractionEnabler
]

instance SemanticRepresentationModel : DTDFVocab:Model [
    base:desc "Structured semantic representation derived from the enriched IFC model that links each BIM element to a TwinComponent and captures control logic."
    DTDFVocab:inputTo HonoIngestEnabler, DittoTwinEnabler
]

// C11: Enablers
instance HonoIngestEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono service that ingests real‑time device streams, validates them and forwards them to Eclipse Ditto via at‑least‑once semantics."
    DTDFVocab:enables RealTimeIntegrationService, DeviceModelingService
]

instance DittoTwinEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto micro‑service platform that persists device state, enforces policy‑based validation and exposes a WebSocket API for UE5."
    DTDFVocab:enables ControlManagementService, Visualization3DService, AnalyticsPluginService
]

instance BasyxEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse BaSyx utilities for extending the twin with custom OPC UA or Asset Administration Shell integrations."
    DTDFVocab:enables DeviceModelingService
]

instance iTwinJsEnabler : DTDFVocab:Enabler [
    base:desc "iTwin.js library used to bind the digital twin data to the Unreal Engine 5 visualization layer."
    DTDFVocab:enables Visualization3DService
]

instance ModularArchitectureEnabler : DTDFVocab:Enabler [
    base:desc "Framework‑level extension points that allow plug‑ins for analytics, optimization and reporting to be added without disrupting existing services."
    DTDFVocab:enables AnalyticsPluginService
]

instance SemanticExtractionEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven extraction step (F2) that transforms enriched IFC into the SemanticRepresentationModel."
    DTDFVocab:enables DeviceModelingService
]

// C6: Services
instance DeviceModelingService : DTDFVocab:Service [
    base:desc "Device‑modeling service enabling building control engineers to define sensors, actuators and control logic directly in the BIM model."
    DTDFVocab:provides DeviceModelInsight
]

instance RealTimeIntegrationService : DTDFVocab:Service [
    base:desc "Real‑time data integration and synchronization service that keeps physical devices and the twin in continuous alignment."
    DTDFVocab:provides SynchronizationInsight
]

instance Visualization3DService : DTDFVocab:Service [
    base:desc "Interactive 3‑D visualization service for monitoring building states via UE5."
    DTDFVocab:provides VisualizationInsight, VisualizationAction
]

instance ControlManagementService : DTDFVocab:Service [
    base:desc "Control service that allows facility managers to operate HVAC, lighting and other subsystems through command APIs."
    DTDFVocab:provides ControlAction
]

instance AnalyticsPluginService : DTDFVocab:Service [
    base:desc "Extensible analytics/custom‑service plug‑in framework for prediction, optimization and reporting."
    DTDFVocab:provides AnalyticsInsight, OptimizationAction
]

// C17: Insights/Actions
instance DeviceModelInsight : DTDFVocab:Insight [
    base:desc "Insight confirming that device definitions in the BIM model are correctly represented in the twin."
]

instance SynchronizationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful bidirectional synchronization of sensor readings and actuator states."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight that the 3‑D visual representation matches the current physical state of the building."
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Action to issue HVAC, lighting or other subsystem commands from the twin to the physical devices."
    DTDFVocab:IsAutomatic false
]

instance AnalyticsInsight : DTDFVocab:Insight [
    base:desc "Insight derived from analytics plug‑ins such as energy consumption forecasts or fault detection."
]

instance OptimizationAction : DTDFVocab:Action [
    base:desc "Action that applies optimization recommendations (e.g., set‑points adjustments) back to the building control system."
    DTDFVocab:IsAutomatic true
]

instance VisualizationAction : DTDFVocab:Action [
    base:desc "Action that triggers an interactive 3‑D view update in UE5 based on the latest twin state."
    DTDFVocab:IsAutomatic true
]

// C2: Acting components (example for completeness)
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Twin representation of a luminaire (IFCLIGHTFIXTURETYPE) whose state (on/off, brightness, colour‑temperature) is controlled via commands brokered by the UnrealTwinController."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the DT interface (UE5) and transmitted to physical devices through Eclipse Ditto over the same WebSocket channel. Upon issuing a command, the framework waits for an execution confirmation from the device before updating the twin’s state, ensuring command execution acknowledgment. Commands are limited to device‑level actions such as switch toggles."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system uses a 1‑second heartbeat mechanism to coordinate data exchange and state updates between the physical building and its digital twin. ODTE measurements show a timeliness score of 0.997, indicating a sub‑second delay in propagation of state changes, with reliability and availability both at 1.0. Deployment performance is quantified: model checking takes 5.53 s, model parsing 8.7 s, and initialization & setup 0.3 s, yielding a total automated deployment time of 14.53 s."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture is model‑driven and modular, centered on a DT Framework that acts as a hub for bidirectional data exchange. Enriched BIM models are transformed via MDE principles into deployable runtime artifacts with minimal manual effort. The framework defines standardized extension points that support scalable, service‑oriented development, allowing custom services and analytics to be plugged in. Real‑time connectivity is provided by Eclipse Hono and Eclipse Ditto, enabling live synchronization. Actor roles (Building Control Engineer, Facility Manager, DT Engineer) coordinate the lifecycle from device modeling to operation, all within an automated deployment pipeline that reduces manual setup."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a full DT life‑cycle anchored in BIM. It starts with device modeling by Building Control Engineers using Autodesk Revit custom families and property sets; each modeled device receives an Instance General UUID and an IFC‑type (e.g., IFCLIGHTFIXTURETYPE). The enriched BIM model is exported as IFC and passed through a dedicated IFC model checker that validates required metadata. In the next stage, the Semantic Model Extraction (F2) automatically derives a domain‑specific semantic model from the IFC file. A one‑click deployment (F3) then generates, configures and launches the DT artifacts, creating runtime instances that are linked to physical assets via Eclipse Hono/Ditto middleware (F4). During operation, live bidirectional data exchange (F4) and interactive 3‑D visualization (F5) keep the physical and digital twins synchronized. Runtime Configuration Management (F7) allows dynamic re‑configuration without redeployment, and modular service integration (F6) enables extension throughout the operational phase. Governance is realised through the roles defined in Table I (Building Control Engineer, Facility Manager, DT Engineer) that handle modeling, monitoring, and service extension respectively."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by a model‑checking step that verifies required metadata (e.g., presence of Instance General UUID) using a custom IFC rule before deployment. Runtime data validity is enforced by Eclipse Ditto’s policy‑based validation, which checks sensor value ranges and units, and by pre‑execution checks for actuator commands. Fault tolerance is provided by Eclipse Hono’s at‑least‑once message delivery and Ditto’s persistent event storage, guaranteeing data continuity during network interruptions. Synchronisation quality is quantified by the Overall Digital Twin Entanglement (ODTE) metric, composed of timeliness (0.997), reliability (1.0), and availability (1.0), measured over a 12‑minute run with a 1 s heartbeat, indicating near‑real‑time, loss‑free operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical communication stack consists of an IP‑based network where Eclipse Hono receives telemetry (via its configured endpoints) and forwards it to Eclipse Ditto. UE5 interacts with Ditto using HTTP POST for initial provisioning and a persistent WebSocket for ongoing data and command exchange. The architecture follows a modular, service‑oriented design with defined extension points, but the documents do not specify bandwidth, latency, redundancy, or security protocols."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The deployment pipeline transforms an enriched BIM model into runtime artifacts that automatically provision Eclipse Hono and Ditto services and a UE5 visualization instance. The framework runs these components on a host capable of supporting the Hono/Ditto services and the UE5 engine, but the specific hosting platform (cloud, edge, on‑premise), scalability mechanisms, or availability guarantees are not described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External integration is achieved through Eclipse Hono (providing IoT gateway connectivity) and Eclipse Ditto (offering a digital‑twin platform), which together enable real‑time data integration between the twin and physical assets. The framework’s non‑functional requirements (NF_X) explicitly address interoperability across heterogeneous systems, scalability, and maintainability. BIM models serve as the primary source of semantic data, and the modular extension points allow the insertion of custom services that can interoperate with other enterprise systems or external digital twins."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution complies with open BIM and IFC standards – the BIM model is authored in Autodesk Revit and exported as Industry Foundation Classes (IFC) files, which serve as the canonical data exchange format. Interoperability (NF1) is achieved by supporting heterogeneous BIM tools, IoT protocols (via Eclipse Hono) and visualization platforms (Unreal Engine 5). Real‑time connectivity uses standard MQTT/AMQP‑based messaging provided by Eclipse Hono and Eclipse Ditto, ensuring at‑least‑once delivery and broker persistence. The framework’s extension points follow a service‑oriented architecture that aligns with ISO 19650‑based information management concepts for BIM, although explicit certification requirements are not mentioned. Overall, the stack relies on widely accepted open standards (IFC, MQTT/AMQP, BIM) to guarantee cross‑tool compatibility and future extensibility."
]