// C2: Acting Components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Actuator modeled in the BIM environment and instantiated in the twin as LightTwinComponent; commands are brokered by UnrealTwinController via DittoDevice with policy‑based safety checks"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in the enriched BIM model and linked to a TwinComponent for real‑time measurements"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor defined in the enriched BIM model and linked to a TwinComponent for real‑time measurements"
    DTDFVocab:producedData LightIntensityDataTransmitted
]

// C4: Data transmitted from sensors
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance LightIntensityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

// C5: Data objects derived from transmitted data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature values received via Eclipse Hono, validated by Ditto policies and stored with unit/range checks"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DittoStore, DataAnalyticsEngine
]

instance LightIntensityData : DTDFVocab:Data [
    base:desc "Light intensity values received via Eclipse Hono, validated by Ditto policies and stored with unit/range checks"
    DTDFVocab:fromData LightIntensityDataTransmitted
    DTDFVocab:inputTo DittoStore, DataAnalyticsEngine
]

// C6: Enablers (middleware components)
instance HonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono gateway guaranteeing at‑least‑once delivery of sensor data over MQTT/AMQP to Ditto"
    DTDFVocab:enables RealTimeSyncService
]

instance DittoStore : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin management service providing policy‑based validation, persistence and versioning of incoming data"
    DTDFVocab:enables RealTimeSyncService, ControlExecutionService
]

instance UnrealTwinController : DTDFVocab:Enabler [
    base:desc "Unreal Engine controller that brokers command messages between TwinComponents and Ditto devices"
    DTDFVocab:enables ControlExecutionService
]

instance DataAnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Analytics engine that consumes validated sensor data to generate higher‑level operational insights"
    DTDFVocab:enables AnalyticsService
]

// C7: Services
instance RealTimeSyncService : DTDFVocab:Service [
    base:desc "Service that synchronizes real‑time sensor data from Ditto to the UE5 visualization layer"
    DTDFVocab:provides CurrentTemperatureInsight, CurrentLightLevelInsight
]

instance ControlExecutionService : DTDFVocab:Service [
    base:desc "Service that validates and forwards actuation commands from the twin to physical actuators via Ditto policies"
    DTDFVocab:provides AdjustLightingAction, AdjustTemperatureAction
]

instance AnalyticsService : DTDFVocab:Service [
    base:desc "Modular analytics service processing streamed sensor data to produce operational insights"
    DTDFVocab:provides EnergyUseTrendInsight
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Service that deploys generated digital‑twin artifacts to the runtime environment"
    DTDFVocab:provides DeploymentInsight
]

// C8: Insights
instance CurrentTemperatureInsight : DTDFVocab:Insight [
    base:desc "Insight presenting the latest temperature reading within the digital‑twin UI"
]

instance CurrentLightLevelInsight : DTDFVocab:Insight [
    base:desc "Insight presenting the latest light intensity reading within the digital‑twin UI"
]

instance EnergyUseTrendInsight : DTDFVocab:Insight [
    base:desc "Analytics insight showing energy‑consumption trends derived from streamed sensor data"
]

instance DeploymentInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful deployment of digital‑twin components"
]

// C9: Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Action to modify lighting level on LightTwinComponent via a Ditto command"
    DTDFVocab:IsAutomatic false
]

instance AdjustTemperatureAction : DTDFVocab:Action [
    base:desc "Action to change HVAC temperature setpoint via a Ditto command"
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing geometry, device definitions, photometric values and control logic"
    DTDFVocab:inputTo MDEPipeline
]

instance MDEPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline that validates, converts and configures BIM data into deployable DT artifacts"
    DTDFVocab:enables DeploymentService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT Framework provides a bidirectional data exchange where commands generated in the digital twin are transmitted to physical devices to enable real‑time monitoring and control (Document 1). Facility Managers interact with the deployed DT for control actions, and the framework acts as a central hub for sending these control messages to the field. No concrete command formats, authentication, or execution‑confirmation procedures are described in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange that ensures continuous (i.e., near‑zero‑latency) synchronization between the physical building and its digital twin; synchronization is performed continuously as runtime data arrive, without a defined fixed interval, supporting real‑time monitoring and control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, service‑oriented architecture with standardized extension points; the central DT Framework mediates bidirectional data exchange, supports runtime configuration management, and allows DT Engineers to plug in custom analytics services, achieving coordinated orchestration of components across the building lifecycle."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The proposed model‑driven deployment framework supports the complete Digital Twin life‑cycle. It begins with device modeling where Building Control Engineers enrich BIM models with explicit definitions of sensors, actuators and controllers, creating a unified semantic foundation. A Model‑Driven Engineering (MDE) transformation then extracts structured representations from these enriched BIM models and automatically generates deployable DT artifacts with minimal manual effort. The next stage is deployment and runtime operation, characterised by continuous real‑time data exchange that keeps the physical building and its digital counterpart synchronised. Interactive visualisation provides immersive monitoring and control interfaces for Facility Managers. Finally, the modular architecture with standardized extension points permits integration of custom services and analytics, allowing the twin to evolve over time. Transition between stages is managed automatically by the MDE pipeline, and lifecycle governance is anchored in the role‑based responsibilities (Building Control Engineer, Facility Manager, DT Engineer) defined in Table I."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by a validation pipeline that checks enriched BIM models for completeness (presence of sensor/actuator definitions) and correctness (unit consistency) before generating twin artifacts. Eclipse Ditto enforces policy‑based validation of both incoming sensor values and outgoing actuator commands, providing error detection and automatic rejection of out‑of‑range data. Fault tolerance is achieved through Eclipse Hono’s at‑least‑once message delivery and Ditto’s persistent event storage, which together guarantee data integrity and resilience to network failures. Uncertainty sources such as sensor noise or model approximations are not quantified in the documents, but the combination of runtime validation, persistent storage and policy checks constitutes the quality assurance process for models and data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connectivity relies on a modular architecture that incorporates Eclipse Hono and Eclipse Ditto (R3, Document 3). Hono handles protocol translation and device connectivity, while Ditto stores and exposes the twin state via its APIs. The network topology, bandwidth, latency, redundancy, and security protocols are not explicitly specified in the provided material."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "An automated, model‑driven deployment process is defined (R2, Document 3) to create reproducible DT setups and supports runtime configuration changes without full redeployment (Document 1). The documents mention a modular framework and extension points but do not specify the underlying hosting platform (cloud, edge, on‑premise), computational or storage sizing, scalability mechanisms, or availability guarantees."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed through standardized extension points and adherence to heterogeneous system standards, enabling integration of BIM models, sensor networks, and external analytics services; the framework is designed to interoperate via open‑source DT platforms (e.g., Eclipse Ditto, BaSyx) and enterprise systems using common communication protocols, though specific protocols are not enumerated."
]