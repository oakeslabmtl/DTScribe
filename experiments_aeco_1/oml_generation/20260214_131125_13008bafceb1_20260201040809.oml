// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in BIM with measurement capability in degrees Celsius"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor defined in BIM measuring relative humidity (%)"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in BIM detecting presence at working places"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor defined in BIM measuring concentration (ppm)"
    DTDFVocab:producedData CO2DataTransmitted
]

// C4: Data transmitted from sensors
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

// C10: Models / Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model including device metadata for building control components"
    DTDFVocab:inputTo EnablerModelDrivenEngineering
]

// C6: Services
instance ServiceRealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring service ingesting sensor streams for anomaly detection and state estimation"
    DTDFVocab:provides InsightAnomalyDetection, ActionAdjustTemperatureControl
]

instance ServiceOptimizationAnalyticsService : DTDFVocab:Service [
    base:desc "Optimization and predictive analytics service forecasting HVAC loads and recommending energy‑saving schedules"
    DTDFVocab:provides InsightEnergyForecast, ActionRecommendSchedule
]

instance ServiceControlService : DTDFVocab:Service [
    base:desc "Control service enabling facility managers to issue commands to actuators via the building automation system"
    DTDFVocab:provides ActionTurnOnLight, ActionSetBrightness, ActionSetColorTemperature, ActionSetHVACSchedule
]

instance ServiceImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization service rendering BIM model with live status overlays for interactive exploration"
    DTDFVocab:provides InsightVisualizationDashboard
]

instance ServiceCustomAnalyticsService : DTDFVocab:Service [
    base:desc "Custom analytics service extensible through plugins added by DT engineers"
    DTDFVocab:provides ActionAddCustomPlugin
]

// C5: Data
instance TemperatureReading : DTDFVocab:Data [
    base:desc "Real‑time temperature reading published via Eclipse Hono"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EnablerDittoPlatform
]

instance HumidityReading : DTDFVocab:Data [
    base:desc "Real‑time humidity reading published via Eclipse Hono"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EnablerDittoPlatform
]

instance OccupancyReading : DTDFVocab:Data [
    base:desc "Real‑time occupancy reading published via Eclipse Hono"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EnablerDittoPlatform
]

instance CO2Reading : DTDFVocab:Data [
    base:desc "Real‑time CO₂ reading published via Eclipse Hono"
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EnablerDittoPlatform
]

instance HistoricalTemperatureData : DTDFVocab:Data [
    base:desc "Historical temperature dataset aggregated for predictive analytics"
    DTDFVocab:inputTo EnablerModelDrivenEngineering, EnablerTwinLightFramework
]

// C17: Insights
instance InsightAnomalyDetection : DTDFVocab:Insight [
    base:desc "Detection of anomalous temperature readings indicating potential faults"
]

instance InsightEnergyForecast : DTDFVocab:Insight [
    base:desc "Forecasted HVAC load and energy‑saving schedule recommendations"
]

instance InsightVisualizationDashboard : DTDFVocab:Insight [
    base:desc "Live visualization dashboard of building health with BIM overlay"
]

// C17: Actions
instance ActionAdjustTemperatureControl : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting temperature based on anomaly detection"
    DTDFVocab:IsAutomatic true
]

instance ActionRecommendSchedule : DTDFVocab:Action [
    base:desc "Recommended HVAC schedule changes for energy optimisation"
    DTDFVocab:IsAutomatic false
]

instance ActionTurnOnLight : DTDFVocab:Action [
    base:desc "Command to turn on lighting fixture via DittoDevice"
    DTDFVocab:IsAutomatic false
]

instance ActionSetBrightness : DTDFVocab:Action [
    base:desc "Command to set lighting brightness level (0–100%)"
    DTDFVocab:IsAutomatic false
]

instance ActionSetColorTemperature : DTDFVocab:Action [
    base:desc "Command to set lighting color temperature (2000–6500 K)"
    DTDFVocab:IsAutomatic false
]

instance ActionSetHVACSchedule : DTDFVocab:Action [
    base:desc "Command to update HVAC operation schedule"
    DTDFVocab:IsAutomatic false
]

instance ActionAddCustomPlugin : DTDFVocab:Action [
    base:desc "DLL or module plugin added to extend analytics capabilities"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Light twin component representing a physical lighting fixture with on/off, brightness, and color temperature control"
]

// C11: Enablers
instance EnablerDittoPlatform : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto platform managing digital twin entities and event store"
    DTDFVocab:enables ServiceRealTimeMonitoringService, ServiceOptimizationAnalyticsService, ServiceControlService, ServiceImmersiveVisualizationService
]

instance EnablerEclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono message broker handling real‑time data streams between physical devices and Ditto"
    DTDFVocab:enables ServiceRealTimeMonitoringService, ServiceControlService
]

instance EnablerTwinLightFramework : DTDFVocab:Enabler [
    base:desc "TwinLight research framework providing tooling for mapping enriched BIM into TwinComponents and generating Ditto artifacts"
    DTDFVocab:enables ServiceCustomAnalyticsService, ServiceOptimizationAnalyticsService
]

instance EnablerBorealisFramework : DTDFVocab:Enabler [
    base:desc "BOREALIS framework providing development tools and plugin support for digital twin deployment"
    DTDFVocab:enables ServiceCustomAnalyticsService
]

instance EnablerUE5UnrealTwinController : DTDFVocab:Enabler [
    base:desc "UE5 UnrealTwinController mediating bidirectional message flow between TwinComponents and physical devices"
    DTDFVocab:enables ServiceImmersiveVisualizationService
]

instance EnablerModelDrivenEngineering : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline extracting structured representations from enriched BIM for twin generation"
    DTDFVocab:enables ServiceCustomAnalyticsService
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized DT framework employing a modular micro‑service architecture with standardized extension points. The core hub manages bidirectional data exchange between enriched BIM models and operational DT instances, orchestrating resource allocation, runtime configuration, and low‑overhead lifecycle updates."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin lifecycle in the proposed framework follows four explicit phases. First, the Device Modeling stage involves building control engineers enriching a native BIM model (Level 3/4) with sensor, actuator, and controller entities (BCS components). Second, the Transformation stage applies Model‑Driven Engineering (MDE) techniques to automatically map the enriched BIM elements onto a structured semantic representation (e.g., ontology‑aligned JSON or UML models). Third, the Deployment stage generates executable DT artifacts—containerised micro‑services or runtime modules—that embody the control logic and can be instantiated on an edge or cloud platform. Finally, the Runtime Monitoring & Control stage synchronises real‑time telemetry from the physical building via bidirectional data‑exchange protocols, updates the digital twin state, and provides facility‑manager‑centric visualization interfaces. Transition between stages is governed by automated validation of BIM constraints and registration of the generated artifacts in a deployment registry, while governance is achieved through role‑based access controls for Building Control Engineers, Facility Managers, and DT Engineers."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is maintained by tightly coupling the BIM‑derived geometric model to the twin artefacts; geometric integrity is preserved via IFC export and UE 5 rendering, while behavioral fidelity is driven by the TwinComponent/FeatureParser correspondence.  Validation occurs at multiple stages: the conversion pipeline checks metadata completeness; Ditto enforces value‑range and unit policies for sensor data; pre‑execution checks guarantee that actuator commands cannot violate safety bounds.  Fault tolerance is achieved through Eclipse Hono’s at‑least‑once delivery semantics and Ditto’s persistent event storage, ensuring resilience against network or service failures.  Continuous synchronization between physical devices and twin state, combined with the aforementioned policies and validation layers, forms the system’s quality‑assurance loop for models and data."
]