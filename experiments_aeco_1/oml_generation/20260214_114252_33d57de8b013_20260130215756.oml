// C3: Physical sensing components (derived from real‑time sensor readings mentioned)
instance RealTimeEnvironmentSensor : DTDFVocab:SensingComponent [
    base:desc "Real‑time sensor readings from building sensors (e.g., temperature, occupancy, lighting levels) used for continuous synchronization"
    DTDFVocab:producedData RealTimeSensorDataStream
]

// C4: Data transmitted from sensing component
instance RealTimeSensorDataStream : DTDFVocab:DataTransmitted [
    base:desc "Continuous data exchange that keeps the twin and the physical asset synchronized"
    DTDFVocab:producedFrom RealTimeEnvironmentSensor
]

// C10: Data produced from the transmitted stream
instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Timestamped sensor measurement values transmitted in real time"
    DTDFVocab:fromData RealTimeSensorDataStream
    DTDFVocab:inputTo ModelDrivenEngineeringToolchain, DittoStateRepository
]

// C3: Acting component (lighting actuator)
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "TwinComponent subclass representing a lighting fixture, exposing commands for power, brightness, and colour‑temperature"
]

// C4: Data transmitted from acting component
instance ActuatorStateDataStream : DTDFVocab:DataTransmitted [
    base:desc "State updates from lighting actuators (on/off, brightness, colour‑temperature)"
]

// C10: Actuator state data
instance ActuatorStateData : DTDFVocab:Data [
    base:desc "Current actuator state values transmitted to the twin for monitoring and control"
    DTDFVocab:fromData ActuatorStateDataStream
    DTDFVocab:inputTo DittoStateRepository, HonoMessagingBroker
]

// C4: Data transmitted for photometric values (derived from BIM)
instance PhotometricDataStream : DTDFVocab:DataTransmitted [
    base:desc "Stream of photometric values extracted from the enriched BIM model"
]

// C10: Photometric value data
instance PhotometricValueData : DTDFVocab:Data [
    base:desc "Revit photometric values (lumens, distribution) used by lighting twin components"
    DTDFVocab:fromData PhotometricDataStream
    DTDFVocab:inputTo ModelDrivenEngineeringToolchain
]

// C10: Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with device definitions, serving as geometric and semantic foundation for the twin"
    DTDFVocab:inputTo ModelDrivenEngineeringToolchain, UnrealEngine5Renderer
]

instance DeviceMetadataModel : DTDFVocab:Model [
    base:desc "Metadata for sensors, actuators and controllers embedded in the BIM model"
    DTDFVocab:inputTo ModelDrivenEngineeringToolchain
]

instance UE5TwinComponentModel : DTDFVocab:Model [
    base:desc "TwinComponent subclasses in Unreal Engine 5 (e.g., LightTwinComponent) representing building elements"
    DTDFVocab:inputTo UnrealEngine5Renderer
]

// C11: Enablers (tooling and middleware)
instance ModelDrivenEngineeringToolchain : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering tool chain that parses enriched BIM models and automatically generates deployable DT artifacts"
    DTDFVocab:enables RealTimeSynchronizationService, VisualizationService, ControlService
]

instance DittoStateRepository : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital‑twin state repository with policy‑based validation and persistent event storage"
    DTDFVocab:enables RealTimeSynchronizationService, ControlService
]

instance HonoMessagingBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT/AMQP broker providing at‑least‑once delivery for sensor and actuator messages"
    DTDFVocab:enables RealTimeSynchronizationService, ControlService
]

instance UnrealEngine5Renderer : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime that visualises BIM geometry through TwinComponent objects"
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance RealTimeSynchronizationService : DTDFVocab:Service [
    base:desc "Provides continuous bidirectional synchronization between the digital twin and physical building assets"
    DTDFVocab:provides DecisionSupportInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides interactive, immersive 3D visualisations allowing facility managers to monitor system states"
    DTDFVocab:provides DecisionSupportInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Enables issuing control commands to actuators (lights) directly from the twin interface"
    DTDFVocab:provides ControlAction
]

// C17: Insights / Actions
instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Operational decision support based on up‑to‑date status information from real‑time data exchange"
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Command to change actuator state such as power on/off, brightness, or colour‑temperature"
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real-time data exchange capabilities that ensure continuous synchronization between the physical building and its digital counterpart. While exact synchronization frequencies, latency bounds, or temporal granularity are not quantified, the term “real-time” indicates that updates occur as soon as operational data become available, supporting ongoing alignment of the twin with the asset."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular architecture with standardized extension points, enabling integration of custom services and analytics. Runtime configuration management allows the DT to be re‑configured without full redeployment. The central DT Framework orchestrates component interaction, handling device modeling, deployment, monitoring, and control, and provides the overall coordination for the building life‑cycle management."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a complete DT lifecycle that begins with device modeling inside the BIM environment (sensors, actuators, controllers), continues with model‑driven engineering (MDE) transformation that extracts a structured semantic representation and automatically generates deployable DT artifacts, proceeds to deployment and runtime operation where real‑time data exchange keeps the physical building and its digital twin synchronized, and ends with evolution through a modular architecture that exposes standardized extension points for custom services and analytics. Governance is realized through role‑based responsibilities (Building Control Engineer, Facility Manager, DT Engineer) that oversee modeling, operation, and extension respectively."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by a validation pipeline that checks enriched BIM models for completeness, runs policy‑based validation in Eclipse Ditto to enforce sensor value ranges, units and actuator command constraints, and performs pre‑execution safety checks. Uncertainty is mitigated through Ditto’s persistent event storage and Hono’s at‑least‑once message delivery, providing fault tolerance against network loss. Errors detected during validation result in rejection of the offending update, preserving synchronization integrity. The framework’s modular architecture also allows custom validation services to be plugged in via extension points. Quality assurance relies on automated generation of DT artifacts from the BIM model, reducing manual transcription errors."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed through non‑functional requirements that target integration across heterogeneous systems. The framework supports bidirectional data exchange with external BIM tools used by Building Control Engineers for device modeling, and facilitates incorporation of external analytics services via the standardized extension points. Specific data exchange protocols or standards are not enumerated, but the design emphasizes interoperability and extensibility with enterprise and BIM ecosystems."
]