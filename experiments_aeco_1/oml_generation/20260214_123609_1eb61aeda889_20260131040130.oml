instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors deployed in physical building infrastructure for environmental metrics, specifically temperature"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors deployed in physical building infrastructure for environmental metrics, specifically humidity"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Sensors deployed in physical building infrastructure for environmental metrics, specifically CO2 levels"
    DTDFVocab:producedData CO2DataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors deployed in physical building infrastructure for occupancy metrics"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors deployed in physical building infrastructure for visual comfort metrics, specifically light levels"
    DTDFVocab:producedData LightLevelDataTransmitted
]

instance EnergyMeter : DTDFVocab:SensingComponent [
    base:desc "Sensors deployed in physical building infrastructure for system performance metrics, specifically energy consumption"
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

instance HVACPerformanceSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors deployed in physical building infrastructure for system performance metrics related to HVAC"
    DTDFVocab:producedData HVACPerformanceDataTransmitted
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeter
]

instance HVACPerformanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACPerformanceSensor
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature data for predictive analytics and energy optimization"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo ModelDrivenEngineeringTool
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Real-time humidity data for building comfort analysis"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo ModelDrivenEngineeringTool
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Real-time CO2 data for indoor air quality monitoring"
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo ModelDrivenEngineeringTool
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy data for space utilization analysis"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo ModelDrivenEngineeringTool
]

instance LightLevelData : DTDFVocab:Data [
    base:desc "Real-time light level data for visual comfort optimization"
    DTDFVocab:fromData LightLevelDataTransmitted
    DTDFVocab:inputTo ModelDrivenEngineeringTool
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "Real-time energy consumption data for optimization"
    DTDFVocab:fromData EnergyConsumptionDataTransmitted
    DTDFVocab:inputTo ModelDrivenEngineeringTool
]

instance HVACPerformanceData : DTDFVocab:Data [
    base:desc "Real-time HVAC performance data for system monitoring"
    DTDFVocab:fromData HVACPerformanceDataTransmitted
    DTDFVocab:inputTo ModelDrivenEngineeringTool
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for MQTT-based real-time data exchange"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance Ditto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for MQTT-based real-time data exchange"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for 3D visualization"
    DTDFVocab:enables Interactive3DVisualizationService
]

instance Revit : DTDFVocab:Enabler [
    base:desc "BIM authoring tool for model creation"
    DTDFVocab:enables BIMModelCreationService
]

instance ModelDrivenEngineeringTool : DTDFVocab:Enabler [
    base:desc "Model-driven engineering tools for automated transformation of BIM to runtime artifacts"
    DTDFVocab:enables SimulationService, PredictiveAnalyticsService, EnergyOptimizationService, VisualComfortOptimizationService, AutomatedControlLogicExecutionService
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of building operations using sensor data"
    DTDFVocab:provides TemperatureMonitoringInsight, OccupancyMonitoringInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building energy consumption and thermal dynamics"
    DTDFVocab:provides EnergySimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy optimization and health effect management"
    DTDFVocab:provides EnergyOptimizationInsight, HealthEffectManagementInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of energy consumption based on predictive analytics"
    DTDFVocab:provides EnergySavingsRecommendation
]

instance VisualComfortOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of visual comfort through lighting adjustments"
    DTDFVocab:provides LightLevelAdjustmentInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization of building systems via Unreal Engine 5"
    DTDFVocab:provides BuildingVisualizationInsight
]

instance AutomatedControlLogicExecutionService : DTDFVocab:Service [
    base:desc "Automated execution of control logic for building operations"
    DTDFVocab:provides HVACControlAction, LightingControlAction
]

instance BIMModelCreationService : DTDFVocab:Service [
    base:desc "Service for creating and enriching BIM models"
    DTDFVocab:provides BIMModelInsight
]

instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time temperature monitoring for facility managers"
]

instance OccupancyMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time occupancy monitoring for facility managers"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Predictive insights for energy optimization"
]

instance HealthEffectManagementInsight : DTDFVocab:Insight [
    base:desc "Predictive insights for health effect management"
]

instance EnergySavingsRecommendation : DTDFVocab:Insight [
    base:desc "Recommendations for energy savings based on operational adjustments"
]

instance LightLevelAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Recommendations for visual comfort adjustments"
]

instance BuildingVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization of building systems for facility managers"
]

instance HVACControlAction : DTDFVocab:Action [
    base:desc "Automated control signals to adjust HVAC systems"
    DTDFVocab:IsAutomatic true
]

instance LightingControlAction : DTDFVocab:Action [
    base:desc "Automated control signals to adjust lighting systems"
    DTDFVocab:IsAutomatic true
]

instance MaintenanceScheduleRecommendation : DTDFVocab:Insight [
    base:desc "Recommendations for maintenance schedules based on predictive analytics"
]

instance OperationalAdjustmentRecommendation : DTDFVocab:Insight [
    base:desc "Recommendations for operational adjustments for energy efficiency"
]

instance BIMModelInsight : DTDFVocab:Insight [
    base:desc "Insight for BIM model creation and enrichment"
]

instance EnergySimulationInsight : DTDFVocab:Insight [
    base:desc "Insight for energy consumption simulation"
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuators that receive control signals to adjust lighting systems"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuators that receive control signals to adjust HVAC systems"
]

instance BCSController : DTDFVocab:ActingComponent [
    base:desc "Building Control Systems components that receive control signals for infrastructure elements"
]

instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with Building Control System (BCS) metadata"
    DTDFVocab:inputTo Revit, ModelDrivenEngineeringTool
]

instance BuildingLivingLab : DTDFVocab:SystemUnderStudy [
    base:desc "Building infrastructure within AECO domain, Living Lab case study"
    base:contains AmbientTemperatureSensor, HumiditySensor, CO2Sensor, OccupancySensor, LightLevelSensor, EnergyMeter, HVACPerformanceSensor, LightingActuator, HVACActuator, BCSController
]

instance DigitalTwin : DTDFVocab:DigitalTwin [
    base:contains BuildingBIMModel, TemperatureData, HumidityData, CO2Data, OccupancyData, LightLevelData, EnergyConsumptionData, HVACPerformanceData, TemperatureDataTransmitted, HumidityDataTransmitted, CO2DataTransmitted, OccupancyDataTransmitted, LightLevelDataTransmitted, EnergyConsumptionDataTransmitted, HVACPerformanceDataTransmitted, EclipseHono, Ditto, UnrealEngine5, Revit, ModelDrivenEngineeringTool, RealTimeMonitoringService, SimulationService, PredictiveAnalyticsService, EnergyOptimizationService, VisualComfortOptimizationService, Interactive3DVisualizationService, AutomatedControlLogicExecutionService, BIMModelCreationService, TemperatureMonitoringInsight, OccupancyMonitoringInsight, EnergyOptimizationInsight, HealthEffectManagementInsight, EnergySavingsRecommendation, LightLevelAdjustmentInsight, BuildingVisualizationInsight, MaintenanceScheduleRecommendation, OperationalAdjustmentRecommendation, BIMModelInsight, EnergySimulationInsight, HVACControlAction, LightingControlAction
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals and commands generated by the DT, such as HVAC adjustments or lighting controls, transmitted via Eclipse Hono and Ditto to Building Control Systems (BCS) actuators for execution in the physical building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with continuous data exchange enabling immediate response to physical changes."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service-oriented architecture where components like BIM models, Hono/Ditto middleware, and Unreal Engine visualization are orchestrated to enable bidirectional data flow, with standardized extension points for integrating custom services across the building's life cycle."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers all life cycle stages from design through construction to operations and refurbishment, with the DT enabling optimization during the operational phase while integrating BIM data from earlier stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validated using the Overall Digital Twin Entanglement (ODTE) metric to assess synchronization accuracy, semantic coherence, and interoperability between physical and virtual components."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT-based communication via Eclipse Hono for device connectivity and Ditto for digital twin management, enabling secure, scalable data exchange between physical sensors/actuators and the DT."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems via standardized extension points and interoperable protocols (e.g., MQTT), though specific external systems are not detailed in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to BIM standards (e.g., IFC) for semantic modeling, with standardized extension points for service integration, though specific external standards beyond BIM are not detailed."
]