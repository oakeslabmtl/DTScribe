// Sensing Components
instance LightIntensitySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded light intensity sensor modeled in BIM providing real‑time telemetry via MQTT topics managed by Eclipse Hono."
    DTDFVocab:producedData LightIntensityDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded temperature sensor modeled in BIM providing real‑time telemetry via MQTT topics managed by Eclipse Hono."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded humidity sensor modeled in BIM providing real‑time telemetry via MQTT topics managed by Eclipse Hono."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded occupancy detector modeled in BIM providing real‑time telemetry via MQTT topics managed by Eclipse Hono."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// Data Transmitted
instance LightIntensityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightIntensitySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// Data
instance LightIntensityData : DTDFVocab:Data [
    base:desc "Light intensity readings published from LightIntensitySensor to DT via MQTT."
    DTDFVocab:fromData LightIntensityDataTransmitted
    DTDFVocab:inputTo HonoBrokerEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature readings published from TemperatureSensor to DT via MQTT."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo HonoBrokerEnabler
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity readings published from HumiditySensor to DT via MQTT."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo HonoBrokerEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy detector readings published from OccupancySensor to DT via MQTT."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo HonoBrokerEnabler
]

// Runtime Data Repository
instance SensorDataRepository : DTDFVocab:Data [
    base:desc "Runtime repository storing aggregated sensor data streams and historical logs."
    DTDFVocab:inputTo DockerDeploymentEnabler
]

// Enablers
instance HonoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT broker that receives sensor data and forwards to Ditto entities."
    DTDFVocab:enables RealTimeMonitoringService, SimulationEngineService, PredictiveMaintenanceService
]

instance DittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto broker that stores Ditto entities and enables simulation and optimisation services."
    DTDFVocab:enables SimulationEngineService, OptimisationAlgorithmService, ImmersiveVisualizationService
]

instance DockerDeploymentEnabler : DTDFVocab:Enabler [
    base:desc "Docker-based deployment environment running Ditto and associated analytic services."
    DTDFVocab:enables EnergyConsumptionAnalyticsService, OptimisationAlgorithmService, PredictiveMaintenanceService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 instance providing immersive visualization of the building model."
    DTDFVocab:enables ImmersiveVisualizationService
]

// Models
instance BuildingIFCEnrichedModel : DTDFVocab:Model [
    base:desc "BIM IFC model enriched with control and sensor metadata, Ditto entity definitions, and MQTT topic layouts."
    DTDFVocab:inputTo HonoBrokerEnabler, DittoBrokerEnabler
]

instance UnrealEngineSceneAsset : DTDFVocab:Model [
    base:desc "Unreal Engine 5 scene asset for immersive visualization of the building."
    DTDFVocab:inputTo UnrealEngine5Enabler
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards providing facility managers with KPIs."
    DTDFVocab:provides EnergyUsageInsight, OccupancyHeatMapInsight
]

instance SimulationEngineService : DTDFVocab:Service [
    base:desc "Simulation engine for conducting virtual building operations."
    DTDFVocab:provides ControlStrategyInsight
]

instance OptimisationAlgorithmService : DTDFVocab:Service [
    base:desc "Reinforcement learning optimisation algorithm for lighting control."
    DTDFVocab:provides ControlStrategyInsight, AdjustLightingAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance alerts based on sensor data streams."
    DTDFVocab:provides MaintenanceAlertInsight
]

instance EnergyConsumptionAnalyticsService : DTDFVocab:Service [
    base:desc "Energy consumption analytics service aggregating historical and current data."
    DTDFVocab:provides EnergyUsageInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization in Unreal Engine 5 for building operations."
    DTDFVocab:provides OccupancyHeatMapInsight, ControlStrategyInsight
]

// Insights
instance EnergyUsageInsight : DTDFVocab:Insight [
    base:desc "Aggregated dashboard displaying real‑time energy consumption KPIs."
]

instance OccupancyHeatMapInsight : DTDFVocab:Insight [
    base:desc "Heat map of occupancy levels across the building visualised in dashboards."
]

instance ControlStrategyInsight : DTDFVocab:Insight [
    base:desc "Actionable control strategy generated by reinforcement learning models."
]

instance MaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance alert informing engineers of potential failures."
]

// Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automated lighting dimming command dispatched to lighting dimmers via Eclipse Hono."
    DTDFVocab:IsAutomatic true
]

instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "HVAC adjustment command sent to dampers to regulate temperature via Hono."
    DTDFVocab:IsAutomatic true
]

instance AdjustBlindsAction : DTDFVocab:Action [
    base:desc "Motorised blinds adjustment command transmitted to actuators via Hono."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., dimming levels, HVAC set‑points) are published by Ditto to MQTT topics subscribed by physical controllers; these messages are then executed on the building’s physical components."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization with low‑latency (sub‑second) data exchange, alongside periodic batch simulations (daily or hourly) for optimisation; overall system designed for real‑time operational support."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A coordinated system of BIM (semantic backbone), Eclipse Hono (data ingestion), Eclipse Ditto (entity management and pub/sub), and Unreal Engine 5 (visualisation), forming a modular architecture that supports extension by DT engineers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Encompasses all building life‑cycle phases: design (as‑designed BIM), manufacturing (as‑manufactured verification), construction (as‑constructed BIM alignments), and operation (real‑time monitored)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Verification of BIM semantic consistency via model validation tools; runtime alignment measured by the Overall Digital Twin Entanglement (ODTE) metric; continuous synchronization checks to detect semantic drift."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical devices communicate over MQTT (TLS) or HTTP to Hono; Hono distributes messages to Ditto over MQTT/REST; Ditto brokers expose WebSocket and REST interfaces to the virtual client; network topology includes edge gateways and cloud broker."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Containerised deployment of Eclipse Hono and Ditto on Kubernetes (or Docker Swarm), hosted on a cloud platform (e.g., AWS, GCP) or on‑premises edge infrastructure; Unreal Engine 5 runs on a dedicated workstation or VR rig."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Employs standardized integration frameworks aligned with AECO practices; BIM serves as the semantic backbone, adhering to industry‑wide building information modeling standards."
]