]

instance CustomServiceIntegration : DTDFVocab:Service [
    base:desc "Service enabling integration of custom services and plugins into the digital twin framework."
    DTDFVocab:provides AIInsight, ModelDrivenPromptAction
]

instance CollaborativeDevelopmentService : DTDFVocab:Service [
    base:desc "Service supporting collaborative development workflows for digital twin applications."
    DTDFVocab:provides VisualDataInsight, CustomReportGenerationAction
]

instance CustomBehaviorConfiguration : DTDFVocab:Service [
