    DTDFVocab:provides SystemFailurePredictionInsight, PredictiveMaintenanceAlertAction
]

instance ScenarioSimulationService : DTDFVocab:Service [
    base:desc "Service enabling scenario-based simulations for 'what-if' analysis and predictive modeling."
