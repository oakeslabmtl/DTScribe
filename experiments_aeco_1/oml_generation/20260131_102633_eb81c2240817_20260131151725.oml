    DTDFVocab:IsAutomatic true
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insights into current and potential energy efficiency improvements based on real-time consumption data and predictive models."
]

instance OperationalImprovementRecommendationAction : DTDFVocab:Action [
    base:desc "Recommendations for operational improvements to enhance energy efficiency and occupant comfort."
    DTDFVocab:IsAutomatic false
]

instance SystemFailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive insights identifying potential system failures before they occur, based on anomaly detection algorithms."
]

instance PredictiveMaintenanceAlertAction : DTDFVocab:Action [
    base:desc "Automated alerts for scheduled maintenance activities based on predictive failure analysis."
    DTDFVocab:IsAutomatic true
]

instance SystemStateControlInsight : DTDFVocab:Insight [
    base:desc "Real-time insights into current system states (HVAC, lighting) for automated control decisions."
]

instance AutomatedActuationAction : DTDFVocab:Action [
    base:desc "Automated actuation of building systems (e.g., adjusting HVAC setpoints) based on digital twin insights."
    DTDFVocab:IsAutomatic true
]

instance VisualDataInsight : DTDFVocab:Insight [
    base:desc "Visual representation of digital twin data through 3D models and interactive dashboards for intuitive exploration."
]

instance CustomReportGenerationAction : DTDFVocab:Action [
    base:desc "Generation of custom reports and KPI tracking based on digital twin data and visualization requirements."
    DTDFVocab:IsAutomatic false
]

instance ResearchBenchmarkInsight : DTDFVocab:Insight [
    base:desc "Benchmarking data for validating new monitoring and control strategies in research environments."
]

instance TechnologyValidationAction : DTDFVocab:Action [
    base:desc "Validation of digital twin technologies through controlled experiments and living lab deployments."
    DTDFVocab:IsAutomatic false
]

instance DeploymentValidationInsight : DTDFVocab:Insight [
    base:desc "Validation insights confirming successful deployment of digital twin artifacts from enriched BIM models."
]

instance ArtifactGenerationAction : DTDFVocab:Action [
    base:desc "Automated generation of deployable digital twin artifacts from model-driven engineering processes."
    DTDFVocab:IsAutomatic true
]

instance AIInsight : DTDFVocab:Insight [
    base:desc "Advanced insights generated through AI/ML models integrated with digital twin data for predictive and optimization purposes."
]

instance ModelDrivenPromptAction : DTDFVocab:Action [
