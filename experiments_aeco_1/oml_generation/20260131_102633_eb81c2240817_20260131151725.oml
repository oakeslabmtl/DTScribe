// C3: Physical sensing components
instance AcademicBuildingHVACTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "IoT sensor for real-time temperature monitoring in HVAC systems of academic buildings, supporting LEED Platinum certification requirements."
]

instance AcademicBuildingHVACHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "IoT sensor for real-time humidity monitoring in HVAC systems of academic buildings, integrated with energy management systems."
]

instance AcademicBuildingAirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "IoT sensor for monitoring CO2 levels, particulate matter, and other air quality parameters in academic buildings."
]

instance AcademicBuildingOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Real-time occupancy tracking sensor for optimizing space utilization and HVAC operation in academic buildings."
]

instance AcademicBuildingLightingOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor integrated with lighting systems for automated control based on natural light and occupancy patterns."
]

instance LibraryAirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for monitoring CO2, VOCs, and particulate matter levels in university library environments."
]

instance LibraryTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor for tracking environmental comfort parameters in library spaces."
]

instance LibraryHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor for maintaining optimal environmental conditions in library environments."
]

instance LibraryOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Real-time occupancy tracking sensor for space utilization optimization in library environments."
]

instance IoTGatewayAcademicBuilding : DTDFVocab:SensingComponent [
    base:desc "IoT gateway for aggregating and transmitting sensor data from academic building systems to the digital twin."
]

instance IoTGatewayLibrary : DTDFVocab:SensingComponent [
    base:desc "IoT gateway for aggregating and transmitting sensor data from library systems to the digital twin."
]

// C4: Physical-to-virtual interaction
instance HVACEnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AcademicBuildingHVACTemperatureSensor, AcademicBuildingHVACHumiditySensor, AcademicBuildingAirQualitySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AcademicBuildingOccupancySensor, LibraryOccupancySensor
]

instance LightingControlDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AcademicBuildingLightingOccupancySensor
]

instance LibraryEnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LibraryAirQualitySensor, LibraryTemperatureSensor, LibraryHumiditySensor
]

instance IoTGatewayDataTransmittedAcademic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IoTGatewayAcademicBuilding
]

instance IoTGatewayDataTransmittedLibrary : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IoTGatewayLibrary
]

// C10: Models/Data
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "Building Information Model enriched with Building Control System components (sensors, actuators, controllers) for digital twin deployment."
    DTDFVocab:inputTo EclipseBasyxPlatform, ModelDrivenEngineeringFramework
]

instance RealTimeEnvironmentalData : DTDFVocab:Data [
    base:desc "Real-time data stream containing temperature, humidity, air quality, and occupancy metrics from building systems."
    DTDFVocab:fromData HVACEnvironmentalDataTransmitted, LibraryEnvironmentalDataTransmitted, OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseBasyxPlatform, itwinJsVisualizationEngine
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "Historical and real-time energy consumption data collected from building management systems and IoT sensors."
    DTDFVocab:fromData IoTGatewayDataTransmittedAcademic, IoTGatewayDataTransmittedLibrary
    DTDFVocab:inputTo ModelDrivenEngineeringFramework, SimulationEngines
]

instance OccupancyPatternData : DTDFVocab:Data [
    base:desc "Processed occupancy data used for space utilization analysis and predictive modeling."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo ModelDrivenEngineeringFramework, PredictiveAnalyticsService
]

instance LightingControlData : DTDFVocab:Data [
    base:desc "Data stream for automated lighting control based on occupancy and natural light conditions."
    DTDFVocab:fromData LightingControlDataTransmitted
    DTDFVocab:inputTo EclipseBasyxPlatform, AutomatedControlService
]

// C11: Enablers
instance EclipseBasyxPlatform : DTDFVocab:Enabler [
    base:desc "Open-source Industry 4.0 platform providing data integration, processing, and interoperability for digital twins."
    DTDFVocab:enables RealTimeMonitoringService, EnergyOptimizationService, PredictiveMaintenanceService, AutomatedControlService
]

instance ModelDrivenEngineeringFramework : DTDFVocab:Enabler [
    base:desc "Framework enabling model-driven deployment of digital twins with automated artifact generation from enriched BIM models."
    DTDFVocab:enables DigitalTwinDeploymentService, ModelTransformationService, CustomServiceIntegration
]

instance itwinJsVisualizationEngine : DTDFVocab:Enabler [
    base:desc "JavaScript library for 3D visualization and collaborative workflows in digital twin applications."
    DTDFVocab:enables InteractiveVisualizationService, CollaborativeDevelopmentService
]

instance SimulationEngines : DTDFVocab:Enabler [
    base:desc "Software engines for executing predictive models and simulations within the digital twin framework."
    DTDFVocab:enables PredictiveAnalyticsService, ScenarioSimulationService
]

instance ModelDrivenPromptEngineeringFramework : DTDFVocab:Enabler [
    base:desc "Framework combining model-driven engineering with prompt engineering for AI/ML integration in digital twins."
    DTDFVocab:enables AIIntegratedAnalyticsService, CustomBehaviorConfiguration
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real-time monitoring of indoor environmental parameters (temperature, humidity, air quality, occupancy) with dashboard visualization and threshold alerts."
    DTDFVocab:provides EnvironmentalConditionInsight, ThresholdBreachAlertAction
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing HVAC, lighting, and energy systems based on real-time data and predictive models to reduce consumption while maintaining comfort."
    DTDFVocab:provides EnergyEfficiencyInsight, OperationalImprovementRecommendationAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Service providing predictive analytics for forecasting system failures and indoor condition trends with anomaly detection capabilities."
    DTDFVocab:provides SystemFailurePredictionInsight, PredictiveMaintenanceAlertAction
]

instance AutomatedControlService : DTDFVocab:Service [
    base:desc "Service enabling automated control of building systems (HVAC, lighting) based on digital twin insights for closed-loop operations."
    DTDFVocab:provides SystemStateControlInsight, AutomatedActuationAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Service providing 3D digital twin representations and interactive dashboards for visualizing system states and performance metrics."
    DTDFVocab:provides VisualDataInsight, CustomReportGenerationAction
]

instance ResearchValidationService : DTDFVocab:Service [
    base:desc "Service enabling development and validation of digital twin technologies in controlled environments (living labs) for research purposes."
    DTDFVocab:provides ResearchBenchmarkInsight, TechnologyValidationAction
]

instance DigitalTwinDeploymentService : DTDFVocab:Service [
    base:desc "Service managing the automated transformation of enriched BIM models into deployable digital twin artifacts."
    DTDFVocab:provides DeploymentValidationInsight, ArtifactGenerationAction
]

instance AIIntegratedAnalyticsService : DTDFVocab:Service [
    base:desc "Service integrating AI/ML models with digital twin data for advanced predictive and optimization capabilities."
    DTDFVocab:provides AIInsight, ModelDrivenPromptAction
]

// C17: Insights/Actions
instance EnvironmentalConditionInsight : DTDFVocab:Insight [
    base:desc "Real-time insights into indoor environmental conditions (temperature, humidity, air quality) for operational decision-making."
]

instance ThresholdBreachAlertAction : DTDFVocab:Action [
