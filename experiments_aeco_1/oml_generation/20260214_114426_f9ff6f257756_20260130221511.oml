// =============================
// C2: Acting Components
// =============================

instance DimmableLampActuator : DTDFVocab:ActingComponent [
    base:desc "Dimmable lighting fixture modelled in BIM that can receive command signals for intensity control."
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC control valve modelled in BIM that can be opened or closed by the twin."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Building fan modelled in BIM for airflow regulation via twin commands."
]

instance BuildingControlDeviceActuator : DTDFVocab:ActingComponent [
    base:desc "Generic building control device (e.g., blinds, shades) extracted from BIM and addressable by the twin."
]

// =============================
// C3: Physical Sensing Components
// =============================

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded illumination sensor modelled in BIM, streams light level measurements."
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Embedded occupancy detector modelled in BIM, reports presence of occupants."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded temperature sensor modelled in BIM, provides ambient temperature readings."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded humidity sensor modelled in BIM, provides relative humidity readings."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance PostOccupancyEnvSensor : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy environmental sensor (e.g., CO₂, VOC) modelled in BIM for after‑use analysis."
    DTDFVocab:producedData PostOccupancyEnvDataTransmitted
]

// =============================
// C4: Physical‑to‑Virtual Interaction (Data Transmitted)
// =============================

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance PostOccupancyEnvDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PostOccupancyEnvSensor
]

// =============================
// C10: Data (runtime sensor data)
// =============================

instance IlluminationData : DTDFVocab:Data [
    base:desc "Real‑time illumination measurements streamed via Eclipse Hono and stored in the twin."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy detection events ingested through Eclipse Hono."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Continuous temperature readings routed via Eclipse Hono."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Continuous humidity readings routed via Eclipse Hono."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance PostOccupancyEnvData : DTDFVocab:Data [
    base:desc "Post‑occupancy environmental data (CO₂, VOC) ingested using Eclipse Ditto."
    DTDFVocab:fromData PostOccupancyEnvDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler
]

// =============================
// C10: Models/Data
// =============================

instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Static BIM geometry model extracted from the design files, representing building shape."
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance BIMSemanticModel : DTDFVocab:Model [
    base:desc "Static BIM semantic model containing space, asset, and system classifications."
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance SensorDataStreamModel : DTDFVocab:Model [
    base:desc "Model of runtime sensor data streams (time‑series) used for analytics and RL training."
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Model of building control logic (set‑points, schedules) generated from BIM metadata."
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance RLLightingPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning policy model for adaptive lighting optimisation."
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance UnrealVisualizationModel : DTDFVocab:Model [
    base:desc "Visual representation model exported to Unreal Engine 5 for 3D interactive visualization."
    DTDFVocab:inputTo UnrealEngine5Enabler
]

// =============================
// C11: Enablers
// =============================

instance BIMAuthoringToolEnabler : DTDFVocab:Enabler [
    base:desc "BIM authoring tools (e.g., Revit, ArchiCAD) used to create the source geometry and semantics."
    DTDFVocab:enables RealTimeMonitoringDashboardService, InteractiveVisualizationService
]

instance MDEPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering transformation pipelines that enrich BIM with device metadata and generate twin artefacts."
    DTDFVocab:enables RealTimeMonitoringDashboardService, InteractiveVisualizationService, BuildingPerformanceSimulationService, EnergyUsageOptimizationService, RLBasedLightingControlService, FacilityManagerTaskPlanningService
]

instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware handling MQTT/CoAP real‑time sensor streams."
    DTDFVocab:enables RealTimeMonitoringDashboardService, EnergyUsageOptimizationService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin platform for state ingestion, normalization and storage."
    DTDFVocab:enables RealTimeMonitoringDashboardService, InteractiveVisualizationService, RLBasedLightingControlService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime providing high‑fidelity 3D visualisation of the twin."
    DTDFVocab:enables InteractiveVisualizationService
]

instance ExtensionPointEnabler : DTDFVocab:Enabler [
    base:desc "Standardised extension points for integrating additional services (e.g., analytics, AI)."
    DTDFVocab:enables FacilityManagerTaskPlanningService
]

// =============================
// C6: Services
// =============================

instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards aggregating live sensor data for facility managers."
    DTDFVocab:provides EnergySavingRecommendationInsight, VisualComfortAssessmentInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "3D interactive visualization of the building in Unreal Engine 5."
    DTDFVocab:provides VisualComfortAssessmentInsight
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation service for evaluating building performance under different operational scenarios."
    DTDFVocab:provides EnergySavingRecommendationInsight
]

instance EnergyUsageOptimizationService : DTDFVocab:Service [
    base:desc "Service that analyses energy consumption and suggests optimisations."
    DTDFVocab:provides EnergySavingRecommendationInsight
]

instance RLBasedLightingControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based lighting control service that automatically adjusts illumination."
    DTDFVocab:provides AutomatedLightingAdjustmentAction
]

instance FacilityManagerTaskPlanningService : DTDFVocab:Service [
    base:desc "Task planning service assisting facility managers with maintenance and operational tasks."
    DTDFVocab:provides EnergySavingRecommendationInsight
]

// =============================
// C17: Insights / Actions
// =============================

instance EnergySavingRecommendationInsight : DTDFVocab:Insight [
    base:desc "Actionable recommendation to reduce energy consumption based on analytics and RL policies."
]

instance VisualComfortAssessmentInsight : DTDFVocab:Insight [
    base:desc "Assessment of visual comfort levels derived from illumination and occupancy data."
]

instance AutomatedLightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of dimmable lamps to maintain target illuminance."
    DTDFVocab:IsAutomatic true
]

// =============================
// Environment & Components
// =============================

instance LivingLabBuildingComponent : DTDFVocab:Component [
    base:desc "Digital representation of the academic Living Lab building extracted from BIM."
]

instance LivingLabEnvironment : DTDFVocab:Environment [
    base:contains LivingLabBuildingComponent, DimmableLampActuator, HVACValveActuator, FanActuator, BuildingControlDeviceActuator,
                 IlluminationSensor, OccupancyDetector, TemperatureSensor, HumiditySensor, PostOccupancyEnvSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command propagation from the twin to physical devices through the same Hono/Ditto middleware, allowing the twin to send control set‑points (e.g., lighting dimming levels, HVAC valve positions) back to actuators in near real‑time."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real‑time synchronization with update rates on the order of seconds to sub‑second intervals, enabled by the low‑latency Hono/Ditto data pipeline."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture where the BIM‑derived core twin interacts with middleware (Hono/Ditto) and visualization services; custom DT services can be plugged in via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Supports design (as‑built BIM), construction (integration of devices), commissioning, and operational phases; the twin can be updated during post‑occupancy to reflect as‑operated conditions."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric is applied to quantify how closely the twin reflects its physical counterpart; semantic drift and validation are addressed through continuous synchronization and model updates."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time connectivity is provided by Eclipse Hono (supporting MQTT/CoAP) for ingesting sensor data and by Eclipse Ditto (HTTP/WebSocket) for state management and command dissemination."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adheres to BIM standards for building information, uses open IoT protocols (MQTT, HTTP/WebSocket) via Eclipse Hono/Ditto, and defines standardized extension points to ensure interoperable service integration."
]