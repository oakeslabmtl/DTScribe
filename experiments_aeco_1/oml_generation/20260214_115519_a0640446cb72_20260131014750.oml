// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in BIM as a dimmable luminaire or switch, receiving command signals from the twin."
]

instance DimmerSwitch : DTDFVocab:ActingComponent [
    base:desc "Dimmer switch modeled in BIM, used to adjust illumination levels based on twin recommendations."
]

// C3: Physical sensing components
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor modeled in BIM to capture post‑occupancy lighting levels."
    DTDFVocab:producedData IlluminationSensorDataStream
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector modeled in BIM to capture presence of users after occupancy."
    DTDFVocab:producedData OccupancyDetectorDataStream
]

// C4: Physical‑to‑virtual interaction
instance IlluminationSensorDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance OccupancyDetectorDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

// Data instances
instance IlluminationMeasurement : DTDFVocab:Data [
    base:desc "Timestamped illumination level values streamed via Eclipse Hono."
    DTDFVocab:fromData IlluminationSensorDataStream
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance OccupancyMeasurement : DTDFVocab:Data [
    base:desc "Timestamped occupancy detection events streamed via Eclipse Hono."
    DTDFVocab:fromData OccupancyDetectorDataStream
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// Model instances
instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "Static BIM geometry and semantic model enriched with device metadata."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance SensorMetadataModel : DTDFVocab:Model [
    base:desc "Model describing sensor capabilities, units, and calibration data."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance UnrealEngine5VisualizationModel : DTDFVocab:Model [
    base:desc "Simulation model exported to Unreal Engine 5 for interactive 3‑D visualization."
    DTDFVocab:inputTo UnrealEngine5Enabler
]

instance PredictiveAnalyticsModel : DTDFVocab:Model [
    base:desc "Predictive analysis model used to generate forecasts for energy consumption."
    DTDFVocab:inputTo PredictiveAnalyticsEngine
]

instance EnergyOptimizationModel : DTDFVocab:Model [
    base:desc "Optimization model that computes energy‑saving control setpoints."
    DTDFVocab:inputTo OptimizationEngine
]

// Enabler instances
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono broker that ingests sensor telemetry streams."
    DTDFVocab:enables RealTimeMonitoringDashboard
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin state store that hosts digital twin representations."
    DTDFVocab:enables RealTimeMonitoringDashboard, Interactive3DVisualization
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime that renders the twin geometry for interactive visualization."
    DTDFVocab:enables Interactive3DVisualization
]

instance PredictiveAnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Analytics engine that consumes data and predictive models to produce forecasts."
    DTDFVocab:enables PredictiveAnalyticsService
]

instance OptimizationEngine : DTDFVocab:Enabler [
    base:desc "Optimization engine that evaluates control actions and recommends energy‑efficient setpoints."
    DTDFVocab:enables EnergyOptimizationService
]

// Service instances
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard displaying live sensor values and twin state."
    DTDFVocab:provides RealTimeOperationalInsight
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "3‑D interactive visualization in Unreal Engine 5 enabling spatial exploration of the building twin."
    DTDFVocab:provides RealTimeOperationalInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service delivering forecasts and anomaly detection."
    DTDFVocab:provides PredictiveAnalysisInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization service delivering energy consumption recommendations."
    DTDFVocab:provides OptimizationRecommendationInsight
]

// Insight instances
instance RealTimeOperationalInsight : DTDFVocab:Insight [
    base:desc "Operational insight derived from live telemetry, informing facility managers about current conditions."
]

instance PredictiveAnalysisInsight : DTDFVocab:Insight [
    base:desc "Predictive analysis result forecasting future energy usage and occupancy patterns."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation generated by the optimization model to adjust lighting and HVAC for efficiency."
]

// Action instance
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automatic lighting control action issued to LightingActuator based on optimization recommendation."
    DTDFVocab:IsAutomatic true
]

// Environment instance
instance LivingLabBuilding : DTDFVocab:Environment [
    base:contains IlluminationSensor, OccupancyDetector, LightingActuator, DimmerSwitch
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting dimming, HVAC set‑points) transmitted back through Eclipse Ditto to Eclipse Hono and delivered to the corresponding actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data exchange and twin updates occur in real time as sensor measurements arrive, supporting near‑instantaneous synchronization between physical and virtual assets."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where the enriched BIM model feeds a configurator that creates device metadata, which is consumed by Hono/Ditto middleware for bidirectional communication, while Unreal Engine provides the visualization layer; custom services can be added via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers design (BIM creation), construction (device commissioning), and operation/maintenance phases, supporting post‑occupancy adaptation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Entanglement measured with the Overall Digital Twin Entanglement (ODTE) metric to assess how closely the twin mirrors the physical building."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono acts as the IoT gateway handling device communication, while Eclipse Ditto manages the digital twin state; together they provide a bidirectional, protocol‑agnostic connection between physical devices and the twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Built upon BIM standards and uses standardized extension points; integration follows model‑driven engineering conventions and the ODTE metric for evaluation."
]