// C3: Physical sensing components
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor exported from Revit to IFC, carries UUID and IFC type, streams illumination measurements via Eclipse Hono with 1‑second heartbeat."
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor exported from Revit to IFC, carries UUID and IFC type, streams temperature measurements via Eclipse Hono with 1‑second heartbeat."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: DataTransmitted
instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C5: Data (measurement)
instance IlluminationMeasurementData : DTDFVocab:Data [
    base:desc "Illumination measurement (lux) persisted in Eclipse Ditto, received from IlluminationDataTransmitted."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance TemperatureMeasurementData : DTDFVocab:Data [
    base:desc "Temperature measurement (°C) persisted in Eclipse Ditto, received from TemperatureDataTransmitted."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono gateway ingests real‑time sensor streams, configured with tenant ID, device ID and endpoint addresses extracted from enriched BIM model."
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin platform stores current state, enforces policy‑based validation and provides bidirectional API for UE5."
    DTDFVocab:enables ClosedLoopControlService, ImmersiveVisualizationService
]

instance UE5VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 visualization layer consumes Ditto’s WebSocket updates and renders the geometric BIM model."
    DTDFVocab:enables ImmersiveVisualizationService
]

instance AnalyticsPluginEnabler : DTDFVocab:Enabler [
    base:desc "Extension point for custom analytics and optimization plugins."
    DTDFVocab:enables CustomAnalyticsService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of building sensors through live data integration with Eclipse Hono and Ditto."
    DTDFVocab:provides MonitoringInsight
]

instance ClosedLoopControlService : DTDFVocab:Service [
    base:desc "Executes closed‑loop control commands for actuators (e.g., lights) based on sensor inputs, routing through Ditto and Hono."
    DTDFVocab:provides ControlAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Delivers immersive interactive 3D visualization for facility managers via UE5, reflecting behavioral states."
    DTDFVocab:provides VisualizationInsight
]

instance CustomAnalyticsService : DTDFVocab:Service [
    base:desc "Runs extensible analytics plugins for optimization and advanced insights."
    DTDFVocab:provides AnalyticsInsight
]

instance DeveloperPlatformService : DTDFVocab:Service [
    base:desc "Platform for DT Engineers to create additional domain‑specific services."
    DTDFVocab:provides DeveloperPlatformInsight
]

// C17: Insights/Actions
instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Enables continuous real‑time observation of illumination and temperature sensor streams."
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Sends on/off, brightness and color‑temperature commands to LightActuator via UnrealTwinController, DittoController, and Hono."
    DTDFVocab:IsAutomatic true
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides immersive UI that visualizes geometric BIM model and current twin state."
]

instance AnalyticsInsight : DTDFVocab:Insight [
    base:desc "Delivers custom analytics results such as energy optimization and occupancy patterns."
]

instance DeveloperPlatformInsight : DTDFVocab:Insight [
    base:desc "Offers APIs and extension points for DT Engineers to develop new domain‑specific services."
]

// C2: Acting Components
instance LightActuator : DTDFVocab:ActingComponent [
    base:desc "Physical luminaire represented as IFC light fixture with UUID, accepts on/off, brightness (0‑100 %) and color‑temperature (Kelvin) commands."
]

// C10: Models/Data
instance BIMIfcModel : DTDFVocab:Model [
    base:desc "Geometric BIM model exported as IFC, enriched with custom Revit families that embed device metadata."
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance TwinComponentExtractionModel : DTDFVocab:Model [
    base:desc "Semantic extraction step (F2) transforms enriched BIM entities into TwinComponent objects such as LightTwinComponent."
    DTDFVocab:inputTo EclipseDitto
]

instance DeviceMetadata : DTDFVocab:Data [
    base:desc "Metadata including Instance General UUID and IFC type for each device, sourced from BIMIfcModel."
    DTDFVocab:inputTo EclipseDitto
]

instance BehavioralLogicData : DTDFVocab:Data [
    base:desc "Control logic authored by building control engineers, attached to device instances within BIM."
    DTDFVocab:inputTo EclipseDitto
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate in the UE5 interface or other DT services and are sent to Eclipse Ditto over the established WebSocket channel. Ditto forwards the command to Eclipse Hono, which routes it to the targeted physical device identified by its tenant/device ID. After the device executes the command, a confirmation message is returned to Ditto; only after this acknowledgment does the DT update its state, ensuring command execution confirmation. Commands include actuator state changes (e.g., switch on/off) and are formatted according to Ditto’s message schema (JSON)."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin maintains continuous, real‑time synchronization using a 1‑second heartbeat mechanism between the physical building and its digital counterpart. Timeliness is measured with an ODTE timeliness score of 0.997, indicating sub‑second latency. Deployment pipeline timings are 5.53 s for model checking, 8.7 s for model parsing, and 0.3 s for initialization, demonstrating rapid update cycles."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a model‑driven, service‑oriented architecture centred on a DT Framework acting as a central hub. Device models are created in BIM, enriched, then automatically transformed via MDE into deployable DT artifacts. Real‑time data flow is realized through Eclipse Hono for device connectivity and Eclipse Ditto for digital twin state management. The modular architecture provides standardized extension points for custom services, enabling runtime configuration and scalability across the building lifecycle."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a five‑stage lifecycle. (1) Device Modeling – Building Control Engineers create custom Revit families for sensors, actuators and controllers, assigning required metadata (Instance General UUID, IFC‑type such as IFCLIGHTFIXTURETYPE). (2) Model Checking – an IFC‑specific model checker validates that each device contains the mandatory metadata before deployment. (3) Semantic Model Extraction – the enriched BIM model is automatically transformed into structured, domain‑specific representations (F2). (4) One‑Click Deployment – a fully automated pipeline generates, configures and launches the Digital Twin artifacts directly from the BIM/IFC input (F3). (5) Runtime Operation – the deployed twin maintains live bidirectional data flow via Eclipse Hono and Ditto (F4), provides immersive UE5 3D visualisation (F5) and supports Runtime Configuration Management for parameter tuning without redeployment (F7). Governance is enforced through defined actor roles (Building Control Engineer, Facility Manager, DT Engineer) that own each stage."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through a dedicated IFC model checker that validates required metadata (e.g., presence of Instance General UUID) before deployment (Model Checking takes 5.53 s). Eclipse Ditto enforces policy‑based validation of sensor value ranges and units and performs pre‑execution checks on actuator commands, preventing unsafe or inconsistent states. Reliability is provided by Hono’s at‑least‑once message delivery and Ditto’s persistent event storage, yielding an ODTE reliability score of 1.0. Timeliness is measured via a 1‑second heartbeat, resulting in an ODTE timeliness score of 0.997, and availability is 1.0, giving an overall ODTE of 0.997. Deployment time totals 14.53 s (including parsing and initialization), demonstrating efficient model‑to‑runtime transformation. Uncertainty quantification beyond these metrics is not detailed in the documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The framework interconnects three main technical components: (1) Eclipse Hono acting as the ingestion endpoint for IoT sensor data, (2) Eclipse Ditto serving as the digital‑twin state repository and real‑time messaging hub, and (3) the UE5 visualization client. Communication protocols include HTTP POST for initial device payload delivery, MQTT/AMQP (implied by Hono) for device‑to‑Hono ingestion, and WebSocket for bidirectional messaging between Ditto and UE5. The network topology follows a cloud‑centric model where Hono and Ditto are provisioned as services (potentially cloud‑hosted), while UE5 runs on a workstation or edge device. Security and reliability mechanisms are not detailed in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through the use of Eclipse Hono and Eclipse Ditto, which support industry‑standard protocols such as MQTT, AMQP, HTTP and WebSockets. The framework is designed for interoperability across heterogeneous AECO tools, leveraging BIM as the semantic backbone and providing standardized extension points for plugging in additional enterprise services, analytics, or other Digital Twins."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution complies with established AECO standards: it uses Autodesk Revit for BIM authoring and exports models in IFC (Industry Foundation Classes), the open exchange format for BIM data. Interoperability across heterogeneous BIM tools, IoT protocols and visualization systems is explicitly required (NF1). Real‑time data exchange relies on Eclipse Hono and Ditto, which implement standard IoT messaging protocols (e.g., MQTT, AMQP) and provide at‑least‑once delivery guarantees. The framework’s modular service integration follows the standardised extension‑point model defined in the functional requirements (F6) and aligns with the semantic integration goals of BIM‑based digital twins."
]