]

instance StrainDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StrainGauge
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMonitor
]

instance IoTSensorNetworkDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor, HumiditySensor, CO2Sensor, LightingSensor, VibrationSensor, StrainGauge
]

