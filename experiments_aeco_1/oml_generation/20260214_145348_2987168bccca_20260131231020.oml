    DTDFVocab:inputTo LightingControlService, OccupancyForecastingService
]

instance StructuralHealthData : DTDFVocab:Data [
    base:desc "Vibration and strain data for real-time structural health monitoring and predictive maintenance analysis"
    DTDFVocab:fromData VibrationDataTransmitted, StrainDataTransmitted
    DTDFVocab:inputTo StructuralAnalysisModel, PredictiveMaintenanceService
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "Real-time energy consumption metrics tracking HVAC, lighting, and other building systems for LEED compliance validation"
    DTDFVocab:fromData EnergyDataTransmitted
    DTDFVocab:inputTo EnergyOptimizationService, CarbonFootprintService
]

instance IoTSensorData : DTDFVocab:Data [
    base:desc "Aggregated IoT sensor data from wireless sensor network providing comprehensive environmental monitoring for building operations"
