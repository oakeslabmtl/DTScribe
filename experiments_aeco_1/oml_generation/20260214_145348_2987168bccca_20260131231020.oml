    DTDFVocab:inputTo EnvironmentalSimulationModel, VentilationRecommendationAction
]

instance LightingData : DTDFVocab:Data [
    base:desc "Ambient and daylight lighting measurements supporting adaptive lighting control algorithms for energy efficiency"
