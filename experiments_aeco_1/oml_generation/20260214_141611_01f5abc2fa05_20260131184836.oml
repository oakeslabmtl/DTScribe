// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Real-time temperature sensor providing indoor environmental data for monitoring and simulation services"
    DTDFVocab:producedData IndoorTemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Real-time humidity sensor providing indoor environmental data for monitoring and simulation services"
    DTDFVocab:producedData IndoorHumidityDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Real-time CO2 concentration sensor providing indoor air quality data for monitoring and optimization services"
    DTDFVocab:producedData IndoorCO2DataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy detection sensor providing real-time occupancy data for behavioral simulations and energy optimization"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance HVACStatusSensor : DTDFVocab:SensingComponent [
    base:desc "HVAC system status sensor providing operational data for control validation and predictive maintenance"
    DTDFVocab:producedData HVACStatusDataTransmitted
]

instance LightingStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting system status sensor providing operational data for energy optimization and control logic validation"
    DTDFVocab:producedData LightingStatusDataTransmitted
]

instance StructuralIntegritySensor : DTDFVocab:SensingComponent [
    base:desc "Structural integrity monitoring sensor providing data for predictive maintenance and safety validation"
    DTDFVocab:producedData StructuralIntegrityDataTransmitted
]

instance AirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "Comprehensive air quality sensor providing PM2.5, VOC, and other environmental metrics for indoor environmental monitoring"
    DTDFVocab:producedData AirQualityDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance IndoorTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance IndoorHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance IndoorCO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance HVACStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACStatusSensor
]

instance LightingStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingStatusSensor
]

instance StructuralIntegrityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralIntegritySensor
]

instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualitySensor
]

// C10: Models/Data
instance BIMBuildingModel : DTDFVocab:Model [
    base:desc "Semantically enriched BIM model serving as foundational digital representation of LEED Platinum academic building with geometric, spatial, and functional metadata"
    DTDFVocab:inputTo EclipseDittoEnabler, UnrealEngineEnabler
]

instance ThermalDynamicsModel : DTDFVocab:Model [
    base:desc "Physics-based thermal dynamics model for predicting indoor temperature behavior under varying conditions"
    DTDFVocab:inputTo UnrealEngineEnabler, PythonSimulationEnabler
]

instance AirflowSimulationModel : DTDFVocab:Model [
    base:desc "Physics-based airflow simulation model for predicting indoor air movement and ventilation efficiency"
    DTDFVocab:inputTo UnrealEngineEnabler, PythonSimulationEnabler
]

instance OccupantBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral simulation model predicting occupant patterns and their impact on energy consumption"
    DTDFVocab:inputTo UnrealEngineEnabler, PythonSimulationEnabler
]

instance IndoorEnvironmentData : DTDFVocab:Data [
    base:desc "Aggregated real-time indoor environmental data including temperature, humidity, CO2, and occupancy"
    DTDFVocab:fromData IndoorTemperatureDataTransmitted, IndoorHumidityDataTransmitted, IndoorCO2DataTransmitted, OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler, InfluxDBEnabler
]

instance HVACControlData : DTDFVocab:Data [
    base:desc "Operational data for HVAC systems including status, energy consumption, and control signals"
    DTDFVocab:fromData HVACStatusDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler, OptimizationEngineEnabler
]

instance LightingControlData : DTDFVocab:Data [
    base:desc "Operational data for lighting systems including status, energy consumption, and control signals"
    DTDFVocab:fromData LightingStatusDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler, OptimizationEngineEnabler
]

instance StructuralHealthData : DTDFVocab:Data [
    base:desc "Structural integrity and safety monitoring data for predictive maintenance"
    DTDFVocab:fromData StructuralIntegrityDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler, PredictiveMaintenanceEnabler
]

instance AirQualityData : DTDFVocab:Data [
    base:desc "Comprehensive indoor air quality metrics for environmental monitoring and health safety"
    DTDFVocab:fromData AirQualityDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler, VisualizationDashboardEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Lightweight MQTT broker for secure, scalable IoT data ingestion from physical sensors to digital twin framework"
    DTDFVocab:enables RealTimeDataIngestionService, SensorDataSynchronizationService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Digital twin registry managing asset metadata, state synchronization, and event-driven updates between physical and virtual models"
    DTDFVocab:enables DigitalTwinSynchronizationService, AssetMetadataManagementService
]

instance UnrealEngineEnabler : DTDFVocab:Enabler [
    base:desc "Real-time 3D visualization platform providing immersive monitoring, physics simulations, and interactive scenario testing"
    DTDFVocab:enables ImmersiveMonitoringService, PhysicsSimulationService, ScenarioTestingService
]

instance PythonSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Custom Python scripts for physics-based modeling (thermal, airflow) and optimization algorithms"
    DTDFVocab:enables ThermalSimulationService, AirflowSimulationService
]

instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database for structured storage and querying of sensor data and operational metrics"
    DTDFVocab:enables HistoricalTrendAnalysisService, RealTimeDataStorageService
]

instance OptimizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Adaptive control algorithms and machine learning-driven recommendations for dynamic system optimization"
    DTDFVocab:enables AdaptiveControlService, EnergyOptimizationService, ComfortLevelOptimizationService
]

instance VisualizationDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard-based visualization tools for real-time monitoring and alerting mechanisms"
    DTDFVocab:enables RealTimeMonitoringDashboardService, AlertingMechanismService
]

instance PredictiveMaintenanceEnabler : DTDFVocab:Enabler [
    base:desc "Analytics platform for predictive maintenance and equipment health monitoring"
    DTDFVocab:enables PredictiveMaintenanceService, EquipmentHealthMonitoringService
]

// C6: Services
instance RealTimeDataIngestionService : DTDFVocab:Service [
    base:desc "Service for continuous ingestion of sensor data from physical infrastructure to digital twin framework"
    DTDFVocab:provides RealTimeDataAvailabilityInsight
]

instance SensorDataSynchronizationService : DTDFVocab:Service [
    base:desc "Service ensuring bidirectional synchronization between physical sensors and digital twin models"
    DTDFVocab:provides DataSynchronizationAccuracyInsight
]

instance DigitalTwinSynchronizationService : DTDFVocab:Service [
    base:desc "Service managing state synchronization and event-driven updates between physical and virtual representations"
    DTDFVocab:provides DigitalTwinConsistencyInsight
]

instance AssetMetadataManagementService : DTDFVocab:Service [
    base:desc "Service for managing metadata and configurations of physical assets in the digital twin registry"
    DTDFVocab:provides AssetConfigurationInsight
]

instance ImmersiveMonitoringService : DTDFVocab:Service [
    base:desc "Service providing 3D immersive monitoring of indoor environmental conditions via Unreal Engine"
    DTDFVocab:provides ImmersiveEnvironmentalMonitoringInsight
]

instance PhysicsSimulationService : DTDFVocab:Service [
    base:desc "Service enabling physics-based simulations of thermal dynamics and airflow within indoor environments"
    DTDFVocab:provides PhysicsSimulationResultsInsight
]

instance ScenarioTestingService : DTDFVocab:Service [
    base:desc "Service allowing interactive scenario testing and what-if analysis for energy optimization strategies"
    DTDFVocab:provides ScenarioTestingResultsInsight
]

instance ThermalSimulationService : DTDFVocab:Service [
    base:desc "Service providing thermal dynamics simulations to predict indoor temperature behavior"
    DTDFVocab:provides ThermalSimulationResultsInsight
]

instance AirflowSimulationService : DTDFVocab:Service [
    base:desc "Service providing airflow simulations to predict ventilation efficiency and air quality distribution"
    DTDFVocab:provides AirflowSimulationResultsInsight
]

instance AdaptiveControlService : DTDFVocab:Service [
    base:desc "Service implementing adaptive control algorithms for dynamic adjustment of HVAC and lighting systems"
    DTDFVocab:provides AdaptiveControlRecommendationsInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Service providing machine learning-driven recommendations for energy-efficient strategies"
    DTDFVocab:provides EnergyOptimizationRecommendationsInsight
]

instance ComfortLevelOptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing indoor environmental conditions for occupant comfort based on real-time data"
    DTDFVocab:provides ComfortLevelOptimizationRecommendationsInsight
]

instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Service providing dashboard-based visualization of real-time indoor environmental parameters"
    DTDFVocab:provides RealTimeEnvironmentalMonitoringInsight
]

instance AlertingMechanismService : DTDFVocab:Service [
    base:desc "Service implementing threshold-based alerting mechanisms for environmental parameter breaches"
    DTDFVocab:provides EnvironmentalAlertInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Service providing predictive maintenance recommendations based on structural health data"
    DTDFVocab:provides PredictiveMaintenanceRecommendationsInsight
]

instance EquipmentHealthMonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring the health status of HVAC and lighting systems for operational reliability"
    DTDFVocab:provides EquipmentHealthStatusInsight
]

instance HistoricalTrendAnalysisService : DTDFVocab:Service [
    base:desc "Service analyzing historical trends in environmental data for pattern recognition and forecasting"
    DTDFVocab:provides HistoricalTrendAnalysisResultsInsight
]

instance RealTimeDataStorageService : DTDFVocab:Service [
    base:desc "Service managing real-time storage of sensor data and operational metrics in time-series database"
