// C2: Acting Components
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator modeled in the BIM model that controls lighting zones in the Living Lab building."
]

// C3: Physical sensing components
instance BuildingOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in the BIM model providing live occupancy detection for the Living Lab building."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightingLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor defined in the BIM model delivering real‑time illumination levels."
    DTDFVocab:producedData LightingLevelDataTransmitted
]

instance EnvironmentalConditionSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor defined in the BIM model measuring temperature, humidity and CO₂."
    DTDFVocab:producedData EnvironmentalConditionDataTransmitted
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingOccupancySensor
]

instance LightingLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingLevelSensor
]

instance EnvironmentalConditionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalConditionSensor
]

// C5: Data
instance OccupancyLiveData : DTDFVocab:Data [
    base:desc "Live occupancy telemetry streamed from BuildingOccupancySensor."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoIngestionEnabler, EclipseDittoTwinEnabler
]

instance LightingLevelLiveData : DTDFVocab:Data [
    base:desc "Live illumination level data streamed from LightingLevelSensor."
    DTDFVocab:fromData LightingLevelDataTransmitted
    DTDFVocab:inputTo EclipseHonoIngestionEnabler, EclipseDittoTwinEnabler
]

instance EnvironmentalConditionLiveData : DTDFVocab:Data [
    base:desc "Live temperature, humidity and CO₂ data streamed from EnvironmentalConditionSensor."
    DTDFVocab:fromData EnvironmentalConditionDataTransmitted
    DTDFVocab:inputTo EclipseHonoIngestionEnabler, EclipseDittoTwinEnabler
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with device metadata, control logic, and runtime semantics for the Living Lab building."
    DTDFVocab:inputTo BIMModelingToolEnabler, ModelDrivenEngineeringEnabler
]

instance RuntimeArtifactsModel : DTDFVocab:Model [
    base:desc "Automatically generated runtime artifacts (e.g., Thing Descriptions) derived from the enriched BIM model."
    DTDFVocab:inputTo EclipseDittoTwinEnabler
]

instance SensorDataStreamModel : DTDFVocab:Model [
    base:desc "Model representing continuous sensor data streams emitted by building sensors."
    DTDFVocab:inputTo EclipseHonoIngestionEnabler
]

instance ControlStateDataModel : DTDFVocab:Model [
    base:desc "Model capturing control state data of building actuators for twin synchronization."
    DTDFVocab:inputTo EclipseDittoTwinEnabler
]

// C11: Enablers (tooling & platform)
instance BIMModelingToolEnabler : DTDFVocab:Enabler [
    base:desc "BIM authoring toolchain used to enrich the architectural model with IoT metadata."
    DTDFVocab:enables SimulationService
]

instance ModelDrivenEngineeringEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering methodology that drives automatic generation of twin artifacts."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance EclipseHonoIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono component that ingests real‑time telemetry from sensors via MQTT."
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoTwinEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin service managing state and providing twin APIs."
    DTDFVocab:enables SimulationService, EnergyOptimizationService
]

instance UnrealEngine5VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renderer delivering interactive 3D visualization of the twin."
    DTDFVocab:enables Interactive3DVisualizationService
]

instance PredictiveAnalyticsEngineEnabler : DTDFVocab:Enabler [
    base:desc "Analytics engine executing predictive models on historic and live data."
    DTDFVocab:enables PredictiveAnalyticsService
]

instance EnergyOptimizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Optimization service recommending energy‑saving actions based on twin state."
    DTDFVocab:enables EnergyOptimizationService
]

instance UserControlServiceEnabler : DTDFVocab:Enabler [
    base:desc "User‑driven control interface enabling manual overrides of building actuators."
    DTDFVocab:enables UserControlService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service delivering real‑time monitoring of building sensor streams."
    DTDFVocab:provides RealTimeOperationalInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Service offering interactive 3D visualization of the building twin via Unreal Engine 5."
    DTDFVocab:provides RealTimeOperationalInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service providing simulation capabilities of building behavior based on twin models."
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service delivering predictive analytics and forecasts for occupancy and energy use."
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Service generating optimization recommendations to reduce energy consumption while maintaining comfort."
    DTDFVocab:provides EnergyOptimizationInsight
]

instance UserControlService : DTDFVocab:Service [
    base:desc "Service allowing facility managers to issue manual control commands to actuators."
    DTDFVocab:provides AdjustLightingAction
]

// C17: Insights
instance RealTimeOperationalInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight derived from live sensor data indicating current building performance."
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive insight forecasting future occupancy patterns and energy demand."
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommendation insight suggesting optimal set‑points for lighting and HVAC to improve energy efficiency."
]

// C18: Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Action to adjust lighting levels via the LightingControlActuator based on user command."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points) are sent back to physical actuators through the same Hono/Ditto bidirectional communication channel."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time synchronization between physical assets and the digital twin."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture with a central DT framework hub that mediates bidirectional data exchange and allows plug‑in services via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin supports the full building lifecycle: design (BIM creation), construction (device commissioning) and operation (ongoing monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to quantify how accurately the twin reflects its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time data exchange is implemented with Eclipse Hono and Eclipse Ditto, providing bidirectional communication between sensors/actuators and the twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM is used as the semantic backbone following industry modeling standards; the framework provides standardized extension points and model‑driven engineering guidelines for interoperability."
]