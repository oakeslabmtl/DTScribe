// C3: Physical Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Provides real-time occupancy data for adaptive control policies in building infrastructures. Part of TwinLight and BOREALIS projects."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Measures indoor temperature for environmental condition monitoring and energy optimization. Integrated with Eclipse Hono/Ditto for real-time data exchange."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Monitors indoor air quality (CO2 levels) for occupant health and ventilation control. Data synchronized via Eclipse Ditto framework."
    DTDFVocab:producedData CO2DataTransmitted
]

instance LuminositySensor : DTDFVocab:SensingComponent [
    base:desc "Tracks daylight levels for daylight harvesting and visual comfort optimization. Sensor data used by BOREALIS reinforcement learning policies."
    DTDFVocab:producedData LuminosityDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Measures real-time energy consumption across building systems. Data streamed via Eclipse Hono for predictive analytics."
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

// C4: Physical-to-Virtual Interaction (DataTransmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance LuminosityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LuminositySensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

// C10: Models/Data
instance BIMModel : DTDFVocab:Model [
    base:desc "Semantically enriched Building Information Model serving as the semantic backbone for the Digital Twin. Contains device metadata, control logic, and middleware configurations (Eclipse Hono/Ditto endpoints)."
    DTDFVocab:inputTo ModelDrivenEngineering, EclipseDitto
]

instance RuntimeDataStream : DTDFVocab:Data [
    base:desc "Real-time operational data from IoT sensors (temperature, occupancy, energy consumption) and historical data for trend analysis. Stored in structured format (JSON/RDF) for interoperability."
    DTDFVocab:fromData OccupancyDataTransmitted, TemperatureDataTransmitted, CO2DataTransmitted, LuminosityDataTransmitted, EnergyConsumptionDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance ControlModel : DTDFVocab:Model [
    base:desc "Embedded control logic including reinforcement learning policies (BOREALIS) and rule-based logic (TwinLight) for adaptive building operations. Generated via model-to-model transformations from BIM."
    DTDFVocab:inputTo ModelDrivenEngineering
]

instance VisualizationModel : DTDFVocab:Model [
    base:desc "3D interactive representation in Unreal Engine 5 for facility managers. Enables immersive monitoring and control adjustments."
    DTDFVocab:inputTo UnrealEngine5
]

instance ExtensionModel : DTDFVocab:Model [
    base:desc "Custom services or plugins integrated via standardized extension points (e.g., new analytics modules). Supports modular architecture for DT evolution."
    DTDFVocab:inputTo EclipseDitto
]

// C11: Enablers
instance ModelDrivenEngineering : DTDFVocab:Enabler [
    base:desc "Automates extraction of domain semantics from BIM models and generates runtime artifacts (middleware configurations, control logic) via model-to-model/text transformations."
    DTDFVocab:enables BIMModelEnrichmentService, ControlLogicGenerationService
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Lightweight messaging protocol for real-time IoT data exchange between physical assets and the Digital Twin. Handles bidirectional communication channels."
    DTDFVocab:enables RealTimeDataExchangeService, SensorDataNormalizationService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Digital twin framework providing device management, bidirectional communication, and standardized data models. Enables metadata extraction and synchronization."
    DTDFVocab:enables DeviceManagementService, BidirectionalSynchronizationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Provides rich, interactive 3D visualization for facility managers and stakeholders. Supports immersive monitoring and control interfaces."
    DTDFVocab:enables ImmersiveVisualizationService
]

instance ReinforcementLearningBOREALIS : DTDFVocab:Enabler [
    base:desc "Enables adaptive control policies for energy optimization and visual comfort using reinforcement learning. Dynamically adjusts building operations based on sensor feedback."
    DTDFVocab:enables AdaptiveControlService, EnergyOptimizationService
]

// C6: Services
instance BIMModelEnrichmentService : DTDFVocab:Service [
    base:desc "Extends BIM models with device metadata (sensor/actuator IDs, control logic) and middleware configurations (Hono/Ditto endpoints). Part of model-driven deployment workflow."
    DTDFVocab:provides BIMModelValidationInsight, DeviceMetadataExtractionAction
]

instance ControlLogicGenerationService : DTDFVocab:Service [
    base:desc "Generates automated control strategies (e.g., daylight harvesting, occupancy-based lighting) from BIM-enriched models. Supports TwinLight and BOREALIS integration."
    DTDFVocab:provides ControlPolicyOptimizationInsight, AutomatedCommissioningAction
]

instance RealTimeDataExchangeService : DTDFVocab:Service [
    base:desc "Transmits real-time sensor data (temperature, occupancy, energy) via Eclipse Hono protocol. Ensures low-latency synchronization between physical and virtual twins."
    DTDFVocab:provides DataStreamConsistencyInsight, RealTimeSynchronizationAction
]

instance SensorDataNormalizationService : DTDFVocab:Service [
    base:desc "Normalizes and validates incoming sensor data streams for consistency. Prepares data for predictive analytics and control policies."
    DTDFVocab:provides DataQualityInsight, DataValidationAction
]

instance DeviceManagementService : DTDFVocab:Service [
    base:desc "Manages device lifecycles (registration, configuration, decommissioning) using Eclipse Ditto framework. Maintains bidirectional communication channels."
    DTDFVocab:provides DeviceHealthInsight, DeviceConfigurationAction
]

instance BidirectionalSynchronizationService : DTDFVocab:Service [
    base:desc "Synchronizes virtual and physical asset states in real-time. Enables live monitoring and closed-loop control adjustments."
    DTDFVocab:provides SynchronizationFidelityInsight, StateAdjustmentAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Provides 3D interactive visualization of building systems in Unreal Engine 5. Supports facility managers in monitoring and control adjustments."
    DTDFVocab:provides VisualizationClarityInsight, InteractiveControlAction
]

instance AdaptiveControlService : DTDFVocab:Service [
    base:desc "Implements reinforcement learning-based control policies (BOREALIS) for dynamic optimization of energy consumption and visual comfort."
    DTDFVocab:provides ControlAdaptabilityInsight, PolicyAdjustmentAction
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes building energy performance using real-time sensor data and predictive analytics. Generates energy efficiency reports and recommendations."
    DTDFVocab:provides EnergyEfficiencyInsight, OptimizationRecommendationAction
]

// C17: Insights/Actions
instance BIMModelValidationInsight : DTDFVocab:Insight [
    base:desc "Validates BIM model completeness and consistency for Digital Twin deployment. Identifies missing device metadata or control logic."
]

instance DeviceMetadataExtractionAction : DTDFVocab:Action [
    base:desc "Automatically extracts device metadata (IDs, endpoints) from BIM models for runtime configuration."
    DTDFVocab:IsAutomatic true
]

instance ControlPolicyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Evaluates the effectiveness of generated control policies (e.g., daylight harvesting) based on simulation results and sensor feedback."
]

instance AutomatedCommissioningAction : DTDFVocab:Action [
    base:desc "Automates the commissioning of lighting systems and other building controls using predefined logic from BIM models."
    DTDFVocab:IsAutomatic true
]

instance DataStreamConsistencyInsight : DTDFVocab:Insight [
    base:desc "Monitors the consistency and latency of real-time data streams from IoT sensors to the Digital Twin."
]

instance RealTimeSynchronizationAction : DTDFVocab:Action [
    base:desc "Ensures real-time synchronization between physical sensor data and virtual twin representations."
    DTDFVocab:IsAutomatic true
]

instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Assesses the quality and reliability of incoming sensor data streams before processing."
]

instance DataValidationAction : DTDFVocab:Action [
    base:desc "Validates and normalizes sensor data to ensure compatibility with Digital Twin services."
    DTDFVocab:IsAutomatic true
]

instance DeviceHealthInsight : DTDFVocab:Insight [
    base:desc "Tracks the operational health and status of connected devices (sensors, actuators) in the building infrastructure."
]

instance DeviceConfigurationAction : DTDFVocab:Action [
    base:desc "Configures and reconfigures devices (e.g., sensors, controllers) via Eclipse Ditto framework."
    DTDFVocab:IsAutomatic true
]

instance SynchronizationFidelityInsight : DTDFVocab:Insight [
    base:desc "Evaluates the fidelity of bidirectional synchronization between physical and virtual twins using ODTE metric."
]

instance StateAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjusts physical system states (e.g., lighting, HVAC) based on virtual twin recommendations."
    DTDFVocab:IsAutomatic true
]

instance VisualizationClarityInsight : DTDFVocab:Insight [
    base:desc "Assesses the clarity and usability of 3D visualizations in Unreal Engine 5 for facility management tasks."
]

instance InteractiveControlAction : DTDFVocab:Action [
    base:desc "Allows facility managers to interactively adjust building controls through the 3D visualization interface."
    DTDFVocab:IsAutomatic false
]

instance ControlAdaptabilityInsight : DTDFVocab:Insight [
    base:desc "Measures the adaptability of reinforcement learning-based control policies to changing environmental conditions."
]

instance PolicyAdjustmentAction : DTDFVocab:Action [
    base:desc "Dynamically adjusts control policies (e.g., BOREALIS) based on real-time performance feedback."
    DTDFVocab:IsAutomatic true
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Provides real-time and predictive insights into building energy performance and optimization opportunities."
]

instance OptimizationRecommendationAction : DTDFVocab:Action [
    base:desc "Generates actionable recommendations for improving energy efficiency and occupant comfort."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The interactions from the virtual world to the physical world involve **control signals** generated by the DT and transmitted back to the physical asset via the same middleware (Eclipse Hono/Ditto). These signals include **actuation commands** (e.g., dimming lights, adjusting HVAC setpoints) derived from **optimization algorithms** (e.g., reinforcement learning in BOREALIS) or **user-defined control logic** (e.g., occupancy-based lighting in TwinLight). The DT framework supports **runtime configuration management**, allowing dynamic adjustments without full redeployment. The **Unreal Engine 5** visualization layer provides an interactive interface for facility managers to manually override or fine-tune control parameters."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The **twinning time scale** is characterized by **real-time synchronization** between the physical and virtual twins, as enabled by **Eclipse Hono and Ditto** for **live data exchange**. The framework supports **continuous bidirectional communication**, ensuring that the DT reflects the current state of the physical asset. However, the documents do not specify **sub-second latency**, **minutes/hours for periodic synchronization**, or other granular time scales. The focus is on **real-time** and **runtime** operations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated as a **service-oriented architecture** with the following components:
  - **Core DT Framework**: Central hub for bidirectional data exchange, model management, and service integration.
  - **Middleware Layer**: Eclipse Hono/Ditto for **real-time connectivity** and **device abstraction**.
  - **Visualization Layer**: Unreal Engine 5 for **immersive monitoring** and **user interaction**.
  - **Extension Points**: Standardized interfaces for **custom services** (e.g., analytics, IoT integrations) developed by DT engineers.
  - **BIM Integration Layer**: Extracts and validates device metadata from BIM models to generate deployable artifacts.
  The constellation supports **modular scalability**, allowing the DT to evolve with new services or building modifications. The **Living Lab case study** demonstrates a **proof-of-concept deployment** of this constellation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the following lifecycle phases of the physical asset:
  1. **Design Phase**: Leverages BIM models to define static geometries, spatial relationships, and initial device configurations.
  2. **Construction Phase**: Supports clash detection and automated commissioning of Building Control Systems (BCS).
  3. **Operation Phase**: Enables real-time monitoring, predictive maintenance, and adaptive control (e.g., BOREALIS’s reinforcement learning).
  4. **Refurbishment/Adaptation Phase**: Facilitates **dynamic reconfiguration** of the DT to accommodate changes (e.g., retrofitting, tenant modifications) without full redeployment.
  The DT represents the physical asset **as operated**, with continuous synchronization to reflect real-world conditions (e.g., sensor drift, wear-and-tear)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
  - **Model-Driven Validation**: Automated checks for **semantic consistency** and **metadata completeness** in BIM models.
  - **Real-Time Synchronization**: Eclipse Hono/Ditto enforce **low-latency data exchange** to minimize drift between physical and virtual assets.
  - **Overall Digital Twin Entanglement (ODTE) Metric**: Quantifies the **degree of alignment** between the DT and its physical counterpart, accounting for **uncertainty** (e.g., sensor noise, model approximations).
  - **Reinforcement Learning (BOREALIS)**: Iteratively refines control policies using **post-occupancy sensor data**, reducing performance gaps between design and operation.
  - **Uncertainty Handling**: The framework acknowledges **sensor inaccuracies** and **model simplifications** but mitigates their impact via **dynamic recalibration** and **user feedback loops**."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection between the physical twin (PT) and Digital Twin (DT) is established using **Eclipse Hono** and **Eclipse Ditto** as middleware platforms for **real-time data exchange**. These tools provide:
  - **Bidirectional communication channels** between sensors/actuators in the PT and the DT.
  - **Lightweight messaging protocols** (implied by Hono/Ditto’s design) to support high-frequency data transmission.
  - **Standardized interfaces** for integrating heterogeneous data sources (e.g., BIM models, IoT devices) into the DT ecosystem.
  The document does not specify **exact network protocols** (e.g., MQTT, HTTP) or detailed architecture diagrams, but the use of **Hono/Ditto** implies adherence to **open standards** for interoperability. The framework ensures that the connection is **scalable and modular**, allowing for the integration of additional devices or services without disrupting existing workflows."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT framework adheres to **AECO-specific standards**, particularly **Building Information Modeling (BIM)**, to ensure compatibility with existing systems and workflows. The model-driven approach leverages BIM as the **semantic backbone** for integrating static and dynamic building data, enabling seamless interoperability across disciplines (e.g., architects, engineers, facility managers). The framework also supports **standardized extension points** for modular service integration, aligning with broader **model-driven engineering (MDE)** principles. While the document does not explicitly mention **specific standardization bodies or protocols** (e.g., ISO, OMG), the emphasis on BIM and MDE implies adherence to **industry-recognized standards** for digital twins in the construction sector."
]