// C3: Physical sensing components
instance LightSensorLobby : DTDFVocab:SensingComponent [
    base:desc "Light sensor in the lobby reporting on/off state, brightness level, and color temperature (in kelvin) as indicated by the LightFeatureParser."
    DTDFVocab:producedData LightDataTransmittedLobby
]

instance LightSensorConferenceRoom : DTDFVocab:SensingComponent [
    base:desc "Light sensor in the conference room reporting on/off state, brightness level, and color temperature (in kelvin) as indicated by the LightFeatureParser."
    DTDFVocab:producedData LightDataTransmittedConferenceRoom
]

// C4: Physical-to-virtual interaction
instance LightDataTransmittedLobby : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensorLobby
]

instance LightDataTransmittedConferenceRoom : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensorConferenceRoom
]

// C10: Models/Data – Events from sensors
instance LightOnOffStateDataLobby : DTDFVocab:Data [
    base:desc "Validated on/off state data stored in Ditto."
    DTDFVocab:fromData LightDataTransmittedLobby
    DTDFVocab:inputTo EclipseDittoStore
]

instance LightBrightnessDataLobby : DTDFVocab:Data [
    base:desc "Validated brightness level data stored in Ditto."
    DTDFVocab:fromData LightDataTransmittedLobby
    DTDFVocab:inputTo EclipseDittoStore
]

instance LightColorTemperatureDataLobby : DTDFVocab:Data [
    base:desc "Validated color temperature data in kelvin stored in Ditto."
    DTDFVocab:fromData LightDataTransmittedLobby
    DTDFVocab:inputTo EclipseDittoStore
]

instance LightOnOffStateDataConference : DTDFVocab:Data [
    base:desc "Validated on/off state data stored in Ditto."
    DTDFVocab:fromData LightDataTransmittedConferenceRoom
    DTDFVocab:inputTo EclipseDittoStore
]

instance LightBrightnessDataConference : DTDFVocab:Data [
    base:desc "Validated brightness level data stored in Ditto."
    DTDFVocab:fromData LightDataTransmittedConferenceRoom
    DTDFVocab:inputTo EclipseDittoStore
]

instance LightColorTemperatureDataConference : DTDFVocab:Data [
    base:desc "Validated color temperature data in kelvin stored in Ditto."
    DTDFVocab:fromData LightDataTransmittedConferenceRoom
    DTDFVocab:inputTo EclipseDittoStore
]

// C11: Enablers
instance ModelDrivenDeploymentFramework : DTDFVocab:Enabler [
    base:desc "Model‑driven deployment framework extending BIM with device modelling, extracting structured representations, and automatically generating deployable digital twin artifacts."
    DTDFVocab:enables BIMtoDTArtifactTransformationService
]

instance EclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono message broker facilitating continuous real‑time data exchange from physical building to Ditto."
    DTDFVocab:enables DittoMessageIntegrationService
]

instance EclipseDittoStore : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto data store applying policy‑defined validation of telemetry and persisting events for digital twin services."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveMaintenanceService, EnergyOptimizationService, OccupantComfortService, DirectBCSControlService, ImmersiveVisualizationService
]

instance CustomAnalyticsExtensionPoint : DTDFVocab:Enabler [
    base:desc "Modular extension point enabling integration of custom analytics services into the digital twin ecosystem."
    DTDFVocab:enables CustomAnalyticsService
]

// C6: Services
instance BIMtoDTArtifactTransformationService : DTDFVocab:Service [
    base:desc "Service performing MDE extraction of enriched BIM models into structured runtime models and twin artifacts."
    DTDFVocab:provides ArtifactGenerationInsight
]

instance DittoMessageIntegrationService : DTDFVocab:Service [
    base:desc "Service ensuring message validity and routing between Eclipse Hono and Ditto."
    DTDFVocab:provides MessageValidationInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real‑time monitoring of building states via continuous telemetry."
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Service delivering predictive analytics for preventive maintenance of building systems."
    DTDFVocab:provides PredictiveMaintenanceInsight, PreventiveMaintenanceAction
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing energy use based on telemetry and control logic."
    DTDFVocab:provides EnergyOptimizationInsight, EnergyOptimizationAction
]

instance OccupantComfortService : DTDFVocab:Service [
    base:desc "Service maintaining occupant comfort through real‑time adjustments."
    DTDFVocab:provides ComfortInsight, ComfortAdjustmentAction
]

instance DirectBCSControlService : DTDFVocab:Service [
    base:desc "Service enabling direct control of building control system components through embedded logic."
    DTDFVocab:provides DirectControlInsight, DirectControlAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Service providing immersive interactive visualization via Unreal Engine 5 for facility managers."
    DTDFVocab:provides VisualizationInsight
]

instance CustomAnalyticsService : DTDFVocab:Service [
    base:desc "Service executing custom analytics logic on streamed data before updating digital twin state."
    DTDFVocab:provides CustomAnalyticsInsight
]

// C17: Insights/Actions
instance ArtifactGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful generation of deployable twin artifacts from BIM models."
]

instance MessageValidationInsight : DTDFVocab:Insight [
    base:desc "Insight confirming validation of telemetry against policy‑defined ranges and units."
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing live monitoring status of building assets."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Insight identifying upcoming maintenance needs."
]

instance PreventiveMaintenanceAction : DTDFVocab:Action [
    base:desc "Automatic action to schedule maintenance tasks."
    DTDFVocab:IsAutomatic true
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight detailing recommended energy‑saving adjustments."
]

instance EnergyOptimizationAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust HVAC setpoints."
    DTDFVocab:IsAutomatic true
]

instance ComfortInsight : DTDFVocab:Insight [
    base:desc "Insight describing current occupant comfort metrics."
]

instance ComfortAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust lighting or HVAC for comfort."
    DTDFVocab:IsAutomatic true
]

instance DirectControlInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful remote control commands."
]

instance DirectControlAction : DTDFVocab:Action [
    base:desc "Automatic action to execute actuator commands via Ditto."
    DTDFVocab:IsAutomatic true
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight describing current visual state in Unreal Engine 5."
]

instance CustomAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Insight generated by custom analytics service."
]

// C2: Acting Components
instance LightActuatorLobby : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture in lobby controlled remotely through Ditto command interface, with policy‑based pre‑execution checks on brightness and color temperature."
]

instance HVACActuatorHallway : DTDFVocab:ActingComponent [
    base:desc "HVAC unit in hallway remote‑controlled via Ditto commands, with policy‑based execution constraints."
]

// C3 (Component representation)
instance LightTwinComponentLobby : DTDFVocab:Component [
    base:desc "Light twin component representing lobby lighting fixture in digital twin."
]

instance HVACTwinComponentHallway : DTDFVocab:Component [
    base:desc "HVAC twin component representing hallway HVAC unit in digital twin."
]

// C11 (Environment)
instance BuildingDigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains LightActuatorLobby, HVACActuatorHallway, LightTwinComponentLobby, HVACTwinComponentHallway
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands issued from the virtual twin are routed via the same bidirectional data channel to physical building devices. The framework provides mechanisms to validate and dispatch these commands through its extension points, and feedback on execution is returned through the channel. Detailed message formats or authentication mechanisms are not specified within the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin synchronises with the physical building in real‑time, enabling continuous data exchange; while specific synchronization frequencies and latency targets are not quantified in the documents, the architecture is designed for continuous, low‑latency updates to support real‑time monitoring, control and predictive analytics."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a centralized hub‑spoke pattern where the DT Framework acts as the orchestrator, providing bidirectional data exchange, runtime configuration management, and modular integration of custom analytics services. The hub manages resource provisioning, coordination of device models, and unified access for stakeholders."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Early stage: Device modeling within BIM enriched with sensor, actuator, and controller definitions by Building Control Engineers, forming the conceptual representation. Transition: Model‑Driven Engineering (MDE) principles automatically transform this enriched BIM into structured representations and deployable Digital Twin artifacts with minimal manual intervention. Deployment stage: The generated artefacts instantiate the Digital Twin, establishing continuous real‑time data exchange that synchronizes the physical building with its digital counterpart. Operation stage: Facility Managers monitor system states and interact with the twin through immersive, interactive visualization interfaces, controlling building operations. Extension stage: DT Engineers extend functionality by integrating custom services and analytics through a modular architecture with standardized extension points, ensuring backward compatibility and controlled evolution. Governance: The framework’s modularity, standardized extension points, and runtime configuration support lifecycle governance, enabling systematic transition management and evolving system capabilities while maintaining alignment with stakeholder use cases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained through MDE extraction of detailed BIM geometry and behavioral logic, while validation occurs at multiple levels. Eclipse Ditto enforces policy‑based value ranges and units for all sensor telemetry and pre‑execution checks for actuator commands, ensuring data correctness and operational safety. Fault tolerance is provided by Eclipse Hono’s at‑least‑once message delivery semantics and Ditto’s persistent event store, offering resilience against network outages or service disruptions. These mechanisms collectively assure continuous synchronization, integrity, and safety between the physical infrastructure and its Digital Twin representation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin architecture relies on a modular, centrally‑hosted hub that facilitates bidirectional data exchange across heterogeneous systems. Standardized extension points support integration with various message brokers and APIs, while runtime configuration management enables dynamic connectivity adjustments without full redeployment. No explicit network topology, protocol, bandwidth, or latency specifications are provided in the documentation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The framework can be deployed as a modular central hub, supporting on‑premise, edge, or cloud hosting via its standardized extension points. Computational and storage requirements are tailored to the size of the physical asset and the number of integrated services, with scalability achieved through service‑level extension and dynamic configuration. Availability and reliability are ensured by the ability to re‑configure without redeployment, but specific hosting platforms or resource specifications are not detailed in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system is designed for interoperability across heterogeneous systems, with standardized extension points that allow integration of external services and analytics. It supports bidirectional data exchange via unspecified yet standard protocols, and enables interaction with enterprise systems as well as other Digital Twins through the modular architecture."
]