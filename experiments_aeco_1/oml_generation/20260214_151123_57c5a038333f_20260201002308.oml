// C18: Environments/Components
instance AcademicBuildingEnvironment : DTDFVocab:Environment [
    base:contains ResearchBuildingStructuralSystem,
            ResearchBuildingHVACSystem,
            ResearchBuildingLightingSystem,
            ResearchBuildingEnergyMonitoringSystem,
            IndoorEnvironmentMonitoringSystem
]

instance UniversityLibraryEnvironment : DTDFVocab:Environment [
    base:contains LibraryHVACSystem,
            LibraryLightingSystem,
            LibraryOccupancySystem,
            LibraryEnvironmentalMonitoringSystem
]

instance InfrastructureEnvironment : DTDFVocab:Environment [
    base:contains StructuralAssets,
            IoTSensorNetwork,
            SimulationModels,
            GeospatialDataLayer
]

instance ResearchBuildingStructuralSystem : DTDFVocab:Component [
    base:desc "Structural components including floors, walls, and roof in LEED Platinum research building"
    base:isContainedIn AcademicBuildingEnvironment
]

