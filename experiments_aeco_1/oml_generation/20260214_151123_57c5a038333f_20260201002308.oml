// C2: Acting Components
instance SensorConfigurationManager : DTDFVocab:ActingComponent [
    base:desc "System component responsible for managing sensor configurations and calibration parameters"
]

instance BuildingControlEngineer : DTDFVocab:ActingComponent [
    base:desc "Human or automated system component representing building control engineers who define and adjust control logic"
]

// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "High-density sensor for real-time indoor temperature monitoring in LEED Platinum academic building"
    DTDFVocab:producedData IndoorTemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor measuring humidity levels for indoor air quality optimization in university library"
    DTDFVocab:producedData IndoorHumidityDataTransmitted
]

instance CarbonDioxideSensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor for monitoring indoor air quality and occupancy patterns in research building"
    DTDFVocab:producedData IndoorCarbonDioxideDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Presence detection sensor for adaptive HVAC and lighting control based on occupancy patterns"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnergyMonitoringSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for tracking real-time energy consumption of HVAC and lighting systems"
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

instance StructuralMonitoringSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for capturing structural integrity data in infrastructure systems"
    DTDFVocab:producedData StructuralIntegrityDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance IndoorTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance IndoorHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance IndoorCarbonDioxideDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CarbonDioxideSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMonitoringSensor
]

instance StructuralIntegrityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralMonitoringSensor
]

instance SensorConfigurationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SensorConfigurationManager
]

instance ControlLogicData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingControlEngineer
]

// C10: Models/Data
instance BuildingInformationModel : DTDFVocab:Model [
    base:desc "Enriched BIM model serving as foundational computational framework for digital twin, containing geometric, spatial, and functional characteristics of building components"
    DTDFVocab:inputTo EclipseBasyxPlatform, ItwinJsLibrary
]

instance OperationalPerformanceModel : DTDFVocab:Model [
    base:desc "Runtime model capturing real-time performance simulations and control logic derived from enriched BIM"
    DTDFVocab:inputTo SimulationEngine, ControlLogicEnabler
]

instance ThermalEnvironmentModel : DTDFVocab:Model [
    base:desc "Multi-physics simulation model for thermal behavior and energy consumption in building systems"
    DTDFVocab:inputTo SimulationEngine, EnergyAnalyticsEnabler
]

instance StructuralPerformanceModel : DTDFVocab:Model [
    base:desc "Model for structural integrity analysis and lifecycle management of infrastructure components"
    DTDFVocab:inputTo SimulationEngine, MaintenancePredictionService
]

instance IndoorAirQualityModel : DTDFVocab:Model [
    base:desc "Model for indoor environmental quality simulation including CO₂, humidity, and thermal comfort metrics"
    DTDFVocab:inputTo SimulationEngine, ComfortOptimizationService
]

instance IndoorTemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature data streamed from sensors to enable environmental monitoring and optimization"
    DTDFVocab:fromData IndoorTemperatureDataTransmitted
    DTDFVocab:inputTo RealTimeAnalyticsEnabler, VisualizationService
]

instance IndoorHumidityData : DTDFVocab:Data [
    base:desc "Real-time humidity data used for indoor air quality assessment and HVAC control"
    DTDFVocab:fromData IndoorHumidityDataTransmitted
    DTDFVocab:inputTo RealTimeAnalyticsEnabler, ComfortOptimizationService
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Dynamic occupancy patterns data enabling adaptive control of building systems"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo AdaptiveControlService, EnergyOptimizationService
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "High-frequency energy consumption metrics for HVAC and lighting systems enabling demand-side management"
    DTDFVocab:fromData EnergyConsumptionDataTransmitted
    DTDFVocab:inputTo EnergyAnalyticsEnabler, DemandManagementService
]

instance StructuralData : DTDFVocab:Data [
    base:desc "Structural integrity data for predictive maintenance and lifecycle management of infrastructure"
    DTDFVocab:fromData StructuralIntegrityDataTransmitted
    DTDFVocab:inputTo MaintenancePredictionService, StructuralAnalysisService
]

// C11: Enablers
instance EclipseBasyxPlatform : DTDFVocab:Enabler [
    base:desc "Open-source platform providing standardized data models (AAS), interoperability framework, and model-driven engineering support for Industry 4.0 digital twins"
    DTDFVocab:enables DeviceModelingService, ConfigurationManagementService
]

instance ItwinJsLibrary : DTDFVocab:Enabler [
    base:desc "Library enabling 3D/4D visualization, real-time data binding, and geospatial integration for large-scale infrastructure digital twins"
    DTDFVocab:enables VisualizationService, ScenarioSimulationService, CollaborativeDevelopmentService
]

instance RealTimeAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Platform enabling continuous synchronization and live analytics between physical and digital twins through event-triggered data ingestion"
    DTDFVocab:enables MonitoringService, ControlLogicInsightService, OperationalAnalyticsService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Multi-physics simulation engine supporting thermal, fluid dynamics, and structural analysis with real-time feedback capabilities"
    DTDFVocab:enables ThermalSimulationService, StructuralAnalysisService, ScenarioTestingService
]

instance ControlLogicEnabler : DTDFVocab:Enabler [
    base:desc "Framework supporting closed-loop control systems and automated adjustments to building management systems"
    DTDFVocab:enables HVACControlService, LightingControlService, AdaptiveControlService
]

instance EnergyAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database and analytics platform for energy consumption tracking and predictive modeling"
    DTDFVocab:enables EnergyOptimizationService, DemandManagementService, ConsumptionForecastingService
]

instance AssetAdministrationShellDatabase : DTDFVocab:Enabler [
    base:desc "Standardized repository for structured storage of asset models, metadata, and operational data supporting Industry 4.0 interoperability"
    DTDFVocab:enables DeviceModelingService, AssetLifecycleService, ConfigurationManagementService
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "IIoT platform enabling standardized data ingestion from IoT devices and sensors with event-driven architecture"
    DTDFVocab:enables DataIngestionService, SensorConfigurationService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Digital twin synchronization platform enabling bidirectional data exchange between physical assets and virtual models"
    DTDFVocab:enables TwinSynchronizationService, RuntimeConfigurationService
]

