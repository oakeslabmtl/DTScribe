// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor integrated into the lighting infrastructure"
    DTDFVocab:producedData BuildingSensorDataStreamViaDitto
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor integrated into the lighting infrastructure"
    DTDFVocab:producedData BuildingSensorDataStreamViaDitto
]

// C4: Physical‑to‑virtual interaction
instance BuildingSensorDataStreamViaDitto : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor, IlluminanceSensor
]

// C10: Models/Data
instance LiveSensorData : DTDFVocab:Data [
    base:desc "Live sensor data stream from occupancy and illuminance sensors via Eclipse Hono and Eclipse Ditto"
    DTDFVocab:fromData BuildingSensorDataStreamViaDitto
    DTDFVocab:inputTo EclipseHonoDittoEnabler
]

// C11: Enablers
instance EclipseHonoDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono and Eclipse Ditto data exchange middleware handling near real‑time sensor data ingestion and storage"
    DTDFVocab:enables LightingHVACOptimizationService, FacilityTaskPlanningService, EnergyPredictiveAnalyticsService
]

instance UnrealEngineEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine for immersive visualization and scenario simulation"
    DTDFVocab:enables ImmersiveVisualizationService
]

// C6: Services
instance LightingHVACOptimizationService : DTDFVocab:Service [
    base:desc "Runtime optimisation of lighting and HVAC schedules through reinforcement‑learning policies (BOREALIS)"
    DTDFVocab:provides AdjustLightingAction, AdjustHVACScheduleAction
]

instance FacilityTaskPlanningService : DTDFVocab:Service [
    base:desc "Task planning for facility management"
    DTDFVocab:provides TaskPlanningInsight
]

instance EnergyPredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy consumption"
    DTDFVocab:provides EnergyConsumptionPredictionInsight, RecommendEnergySavingAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization in Unreal Engine for scenario simulation and decision support"
    DTDFVocab:provides ScenarioSimulationInsight
]

// C17: Insights/Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Adjust lighting levels via dimming actuator"
    DTDFVocab:IsAutomatic true
]

instance AdjustHVACScheduleAction : DTDFVocab:Action [
    base:desc "Adjust HVAC operation schedule"
    DTDFVocab:IsAutomatic true
]

instance TaskPlanningInsight : DTDFVocab:Insight [
    base:desc "Insight for facility task planning generated by scenario simulation and analysis"
]

instance EnergyConsumptionPredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive energy consumption insight derived from temporal sensor and model data"
]

instance RecommendEnergySavingAction : DTDFVocab:Action [
    base:desc "Recommendation to reduce energy consumption"
    DTDFVocab:IsAutomatic false
]

instance ScenarioSimulationInsight : DTDFVocab:Insight [
    base:desc "Scenario simulation insight in Unreal Engine"
]

// C2: Acting Components
instance LightingFixtureDimmingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture equipped with dimming actuator modeled in BIM, controllable via the Digital Twin"
]

instance LightingFixtureOnOffActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture on/off actuator modeled in BIM"
]

// C18: Component hierarchy
instance LivingLabBuildingTwin : DTDFVocab:Component [
    base:desc "Living Lab academic building (LEED Platinum) acting as the building twin encompassing multiple device twins"
]

instance LightingFixtureTwin : DTDFVocab:Component [
    base:desc "Device twin representing an individual lighting fixture within the building twin"
]

// C19: Environment
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains LivingLabBuildingTwin, LightingFixtureTwin
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT – e.g., lighting level adjustments – are sent back to the physical actuators through Hono/Ditto, enabling bidirectional interaction."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data and control exchanges occur in real‑time, with end‑to‑end latency typically below a few seconds, supporting near‑instantaneous adjustments in the building’s lighting system."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central DT framework component orchestrating device registry, telemetry ingestion, control command dispatch, service plug‑in management, and visualization, with modular extension points for DT engineers to add custom analytics or control modules."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle spans design (ideal IFC BIM model), construction (enriched BIM with device metadata), and operation (live telemetry, real‑time control); the framework supports all three stages by generating runtime artifacts from the BIM model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation steps are performed to ensure semantic consistency; entanglement between the DT and PT is quantified using the ODTE metric, providing feedback on fidelity and guiding corrective actions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono serves as the MQTT-based message broker (as inferred by its IoT orientation) and Eclipse Ditto manages twin metadata and state synchronization, forming the core communication layer between physical assets and the virtual twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM provides the domain‑specific semantic standard, while Eclipse Ditto adheres to OMA Twin Registry specifications, ensuring interoperability across components."
]