// Actuating components
instance LightingFixtureDimmer : DTDFVocab:ActingComponent [
    base:desc "Actuator module responsible for dimming lights in response to control signals"
]

instance LightingFixtureSwitcher : DTDFVocab:ActingComponent [
    base:desc "Actuator module responsible for switching lights on or off based on commands"
]

// Sensing components
instance AmbientLightMeter : DTDFVocab:SensingComponent [
    base:desc "Embedded ambient light meters within lighting infrastructure providing real‑time light level measurements to the digital twin"
    DTDFVocab:producedData AmbientLightDataTransmitted
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Embedded occupancy detectors capturing presence data to inform lighting control"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensors measuring environmental temperature for building operation analysis"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensors monitoring indoor air quality for HVAC and lighting integration"
    DTDFVocab:producedData CO2DataTransmitted
]

// Data transmitted from sensors
instance AmbientLightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientLightMeter
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

// Processed data
instance AmbientLightData : DTDFVocab:Data [
    base:desc "Ambient light data processed for real‑time monitoring dashboards"
    DTDFVocab:fromData AmbientLightDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy data used for predictive analytics and occupation‑based lighting optimization"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature data incorporated into energy consumption modeling"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance CO2Data : DTDFVocab:Data [
    base:desc "CO₂ data utilized for indoor air quality analytics"
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// Enriched BIM model
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM models enriched with device metadata and control logic extracted through model‑driven semantic extraction"
    DTDFVocab:inputTo ModelDrivenBIMExtractionTool, ValidationTool, ModelDrivenTransformationPipeline, EclipseHono, EclipseDitto
]

// Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono platform facilitating real‑time telemetry exchange between physical sensors and the digital twin"
    DTDFVocab:enables RealTimeMonitoringDashboardService, PredictiveAnalyticsService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for managing device twins and enabling bidirectional command exchange"
    DTDFVocab:enables SimulationAnalysisService, Immersive3DVisualizationService
]

instance UnrealEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine providing immersive 3D visualization of the building based on enriched BIM"
    DTDFVocab:enables Immersive3DVisualizationService
]

instance ModelDrivenBIMExtractionTool : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering tooling for BIM semantic extraction and model transformation"
]

instance ValidationTool : DTDFVocab:Enabler [
    base:desc "Validation tooling ensuring integrity of enriched BIM and model data before runtime artifact generation"
]

instance ModelDrivenTransformationPipeline : DTDFVocab:Enabler [
    base:desc "Transformation pipeline that extracts enriched BIM data, validates the model, generates runtime artifacts, and deploys via Hono/Ditto"
    DTDFVocab:enables PredictiveAnalyticsService, ReinforcementLearningPolicyUpdateService, SimulationAnalysisService
]

// Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards delivering live status of lighting fixtures and environmental conditions"
    DTDFVocab:provides OptimizedLightingScheduleInsight, ActionableRecommendationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service enabling occupancy‑based lighting optimisation through forecasting models"
    DTDFVocab:provides PredictiveOccupancyForecastInsight, EnergyConsumptionModelInsight
]

instance ReinforcementLearningPolicyUpdateService : DTDFVocab:Service [
    base:desc "Reinforcement learning policy update service that iteratively refines lighting control strategies"
    DTDFVocab:provides LightDimAction, LightSwitchAction
]

instance Immersive3DVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D visualization service enabling interactive exploration of the building in Unreal Engine"
    DTDFVocab:provides VisualizationInsight
]

instance SimulationAnalysisService : DTDFVocab:Service [
    base:desc "Simulation and analysis service performing scenario evaluation based on enriched BIM data"
    DTDFVocab:provides EnergyConsumptionModelInsight
]

// Insights
instance OptimizedLightingScheduleInsight : DTDFVocab:Insight [
    base:desc "Insight providing optimized lighting schedules derived from occupancy predictions"
]

instance PredictiveOccupancyForecastInsight : DTDFVocab:Insight [
    base:desc "Insight presenting predictive occupancy forecasts for proactive control"
]

instance EnergyConsumptionModelInsight : DTDFVocab:Insight [
    base:desc "Insight illustrating modeled energy consumption correlated with lighting and HVAC operation"
]

instance ActionableRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation insight offering actionable adjustments to facility managers"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing visual representation of building states in 3D"
]

// Actions
instance LightDimAction : DTDFVocab:Action [
    base:desc "Automatic dimming command to adjust brightness levels of lighting fixtures"
    DTDFVocab:IsAutomatic true
]

instance LightSwitchAction : DTDFVocab:Action [
    base:desc "Automatic switching command to turn lighting fixtures on or off based on commands"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., dimming instructions) are published to the physical devices via Ditto over the Hono middleware, enabling bidirectional actuation"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization; data and control messages are exchanged with no explicit latency bound but operate in real‑time"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central Digital Twin hub orchestrating device twins via Hono/Ditto, embedding modular services (visualisation, analytics) and maintaining a unified real‑time representation of the building"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin covers design (ideal BIM), manufacturing (manufactured devices with annotated metadata), and operation (live operational data and control), managed through continuous model‑to‑runtime transformation"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Evaluation of the DT–physical correspondence using the Overall Digital Twin Entanglement (ODTE) metric, ensuring high semantic alignment"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time data exchange handled by the Eclipse Hono middleware and Ditto twin store, with devices publishing/subscribing to DT messages"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Distributed deployment of Eclipse Hono broker, Ditto runtime, and Unreal Engine renderer on an edge/cloud cluster; services orchestrated by containerized micro‑services managed via Kubernetes or equivalent orchestrator."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with BIM as the primary data source and standardized DT interfaces, enabling potential inter‑system communication via the Hono messaging layer"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with AECO‑specific BIM standards (IFC); use of OAuth/OpenID Connect for authentication with Hono/Ditto; adherence to ISO/IEC standards for secure IoT communication."
]