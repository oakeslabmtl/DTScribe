]

instance SustainabilityMetricsService : DTDFVocab:Service [
    base:desc "Model-based sustainability tracking service for LEED compliance and carbon footprint assessment"
    DTDFVocab:provides SustainabilityMetrics
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Predictive analytics service for anomaly detection in sensor data (maintenance needs, equipment failures)"
    DTDFVocab:provides MaintenanceAlerts
]

instance FutureStateForecastingService : DTDFVocab:Service [
    base:desc "Predictive service forecasting space utilization, energy demand, and occupant behavior"
    DTDFVocab:provides OccupantBehaviorForecasts
]

instance AutomatedControlService : DTDFVocab:Service [
    base:desc "Automated adjustment service for physical systems (HVAC, lighting) based on digital twin predictions"
    DTDFVocab:provides HVACLightingAdjustments
]

instance DemandResponseService : DTDFVocab:Service [
    base:desc "Grid-friendly operations service integrating demand-response strategies"
    DTDFVocab:provides GridOptimizationActions
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Real-time and historical data visualization service using itwin.js and Eclipse Basyx"
    DTDFVocab:provides VisualizationDashboards
]

// C17: Insights/Actions
instance IndoorEnvironmentInsights : DTDFVocab:Insight [
    base:desc "Real-time data visualization of indoor environmental parameters (temperature, humidity, CO₂, air quality)"
]

instance SpaceUtilizationInsights : DTDFVocab:Insight [
    base:desc "Occupancy and activity tracking insights for space utilization optimization"
]

instance EnergyOptimizationActions : DTDFVocab:Action [
    base:desc "Automated HVAC/lighting adjustments based on AI-driven demand forecasting"
    DTDFVocab:IsAutomatic true
]

instance SustainabilityMetrics : DTDFVocab:Insight [
    base:desc "LEED compliance and carbon footprint tracking metrics for smart buildings"
]

instance MaintenanceAlerts : DTDFVocab:Insight [
    base:desc "Anomaly detection alerts for maintenance needs and equipment failures"
]

instance OccupantBehaviorForecasts : DTDFVocab:Insight [
    base:desc "Future-state predictions for space utilization, energy demand, and occupant behavior patterns"
]

instance HVACLightingAdjustments : DTDFVocab:Action [
    base:desc "Preemptive adjustments to HVAC and lighting systems based on digital twin predictions"
    DTDFVocab:IsAutomatic true
]

instance GridOptimizationActions : DTDFVocab:Action [
    base:desc "Demand-response integration actions for grid-friendly operations"
    DTDFVocab:IsAutomatic true
]

