    base:desc "Smart lighting system controller for academic buildings, adjusting illumination levels based on occupancy and energy optimization algorithms"
]

instance EnergyDemandResponseActuator : DTDFVocab:ActuatingComponent [
    base:desc "Demand-response actuator for grid-friendly operations in smart buildings, modulating energy consumption based on digital twin forecasts"
]

// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Indoor environmental monitoring sensor deployed in academic buildings for temperature measurement (e.g., Dallas Semiconductor DS18B20)"
    DTDFVocab:producedData TemperatureData
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Indoor environmental monitoring sensor for humidity measurement (e.g., SCD30 CO₂/humidity sensor)"
    DTDFVocab:producedData HumidityData
]

instance AirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ and air quality monitoring sensor in university libraries for occupant comfort assessment"
    DTDFVocab:producedData AirQualityData
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Space utilization sensor tracking occupancy patterns in research facilities"
    DTDFVocab:producedData OccupancyData
]

instance LightIntensitySensor : DTDFVocab:SensingComponent [
    base:desc "Lighting condition sensor measuring ambient illumination levels"
    DTDFVocab:producedData LightIntensityData
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Energy usage monitoring sensor for HVAC and lighting systems in academic buildings"
    DTDFVocab:producedData EnergyConsumptionData
]

instance HVACSystemStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Status sensor for HVAC system components in research facilities"
    DTDFVocab:producedData HVACSystemStatusData
]

// C4: Data Transmission Components
instance TemperatureData : DTDFVocab:Data [
    DTDFVocab:fromData TemperatureSensor
]

instance HumidityData : DTDFVocab:Data [
    DTDFVocab:fromData HumiditySensor
]

instance AirQualityData : DTDFVocab:Data [
    DTDFVocab:fromData AirQualitySensor
]

instance OccupancyData : DTDFVocab:Data [
    DTDFVocab:fromData OccupancySensor
]

instance LightIntensityData : DTDFVocab:Data [
    DTDFVocab:fromData LightIntensitySensor
]

instance EnergyConsumptionData : DTDFVocab:Data [
    DTDFVocab:fromData EnergyConsumptionSensor
]

instance HVACSystemStatusData : DTDFVocab:Data [
    DTDFVocab:fromData HVACSystemStatusSensor
]

// C10: Models
instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "3D BIM-based computational framework for LEED Platinum research facility representing geometric, spatial, and functional attributes"
    DTDFVocab:inputTo BIMEnrichmentFramework
]

instance IndoorEnvironmentSimulationModel : DTDFVocab:Model [
    base:desc "Physics-based thermal and airflow simulation model for predicting indoor conditions in academic buildings"
    DTDFVocab:inputTo SimulationEngine
]

instance EnergyOptimizationModel : DTDFVocab:Model [
    base:desc "Model-driven framework for energy consumption reduction through AI-driven demand forecasting and automated HVAC/lighting adjustments"
    DTDFVocab:inputTo AIIntegrationFramework
]

instance SustainabilityMetricsModel : DTDFVocab:Model [
    base:desc "Model-based simulation for tracking LEED compliance and carbon footprint in smart buildings"
    DTDFVocab:inputTo TimeSeriesDatabase
]

// C11: Enablers
instance BIMEnrichmentFramework : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering framework for transforming BIM models into digital twin artifacts with semantic consistency"
    DTDFVocab:enables BuildingBIMModel, IndoorEnvironmentSimulationModel
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Physics-based simulation engine for thermal modeling and airflow dynamics in indoor environments"
    DTDFVocab:enables IndoorEnvironmentSimulationModel
]

instance AIIntegrationFramework : DTDFVocab:Enabler [
    base:desc "Machine learning framework for predictive analytics including occupancy prediction and energy forecasting"
    DTDFVocab:enables EnergyOptimizationModel
]

instance RealTimeDataExchangePlatform : DTDFVocab:Enabler [
    base:desc "Eclipse Basyx platform for real-time data exchange between physical assets and digital twins"
    DTDFVocab:enables TemperatureData, HumidityData, AirQualityData, OccupancyData, LightIntensityData, EnergyConsumptionData, HVACSystemStatusData
]

instance IoTSynchronizationMiddleware : DTDFVocab:Enabler [
    base:desc "Middleware for IoT device synchronization using Eclipse Hono and Ditto protocols"
    DTDFVocab:enables TemperatureData, HumidityData, AirQualityData, OccupancyData, LightIntensityData, EnergyConsumptionData, HVACSystemStatusData
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "InfluxDB/TimescaleDB time-series database for historical data retention and trend analysis"
    DTDFVocab:inputTo SustainabilityMetricsModel
]

instance ModelVersionControlSystem : DTDFVocab:Enabler [
    base:desc "Git/SVN version control system for managing model updates and revisions in MDE workflows"
    DTDFVocab:inputTo BuildingBIMModel, IndoorEnvironmentSimulationModel
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring service for real-time indoor environmental parameters (temperature, humidity, CO₂, air quality)"
    DTDFVocab:provides IndoorEnvironmentInsights
]

