// ====================
// C8: Insights
// ====================

instance EnergyConsumptionTrendInsight : DTDFVocab:Insight [
    base:desc "Insight showing energy‑consumption trends over time derived from live data."
]

instance ComfortViolationInsight : DTDFVocab:Insight [
    base:desc "Insight detecting comfort violations (temperature/air‑quality out of range)."
]

instance SpatialVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing a spatial, 3‑D view of sensor locations and building geometry."
]

instance PredictiveEnergyInsight : DTDFVocab:Insight [
    base:desc "Insight forecasting future energy usage based on simulation results."
]

instance EnergyOptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight offering optimisation recommendations to reduce energy consumption."
]

// ====================
// C9: Actions
// ====================

instance AdjustControlStrategyAction : DTDFVocab:Action [
    base:desc "Action to adjust lighting dimmers, HVAC valves or shades based on optimisation output.",
    DTDFVocab:IsAutomatic true
]

instance PlanRefurbishmentAction : DTDFVocab:Action [
    base:desc "Action suggesting refurbishment measures (e.g., retrofit lighting) for long‑term efficiency.",
    DTDFVocab:IsAutomatic false
]

// ====================
// C6: Services
// ====================

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards aggregating live sensor feeds.",
    DTDFVocab:provides EnergyConsumptionTrendInsight, ComfortViolationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3‑D interactive visualisation of the building in Unreal Engine 5.",
    DTDFVocab:provides SpatialVisualizationInsight
]

instance SimulationAnalyticsService : DTDFVocab:Service [
    base:desc "Simulation and predictive analytics for future energy performance.",
    DTDFVocab:provides PredictiveEnergyInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Automated optimisation of energy consumption based on model predictions.",
    DTDFVocab:provides EnergyOptimizationRecommendationInsight, AdjustControlStrategyAction
]

instance ControlCommandService : DTDFVocab:Service [
    base:desc "Service translating digital twin decisions into actuator commands.",
    DTDFVocab:provides AdjustControlStrategyAction
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Decision‑support for facility managers, delivering refurbishment planning actions.",
    DTDFVocab:provides PlanRefurbishmentAction
]

// ====================
// C7: Enablers
// ====================

instance HonoIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono platform ingesting telemetry from BIM‑derived sensors via MQTT.",
    DTDFVocab:enables RealTimeMonitoringService
]

instance DittoStateEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto managing twin state, persisting model updates and actuator commands.",
    DTDFVocab:enables ControlCommandService
]

instance UnrealEngine5VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime rendering the digital twin geometry for immersive 3‑D interaction.",
    DTDFVocab:enables VisualizationService
]

instance OptimizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑based optimisation engine executing energy‑consumption simulations and recommending actions.",
    DTDFVocab:enables EnergyOptimizationService
]

// ====================
// C2: Acting Components
// ====================

instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator modelled in BIM and addressable via generated runtime interfaces."
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve actuator modelled in BIM and controllable through the digital twin runtime."
]

instance WindowShadeActuator : DTDFVocab:ActingComponent [
    base:desc "Motorised window shade actuator extracted from BIM for adaptive daylight control."
]

// ====================
// C3: Physical Sensing Components
// ====================

instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded lighting sensor extracted from the BIM for the TwinLight project.",
    DTDFVocab:producedData LightingDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded occupancy sensor extracted from the BIM used in BOREALIS for space utilisation monitoring.",
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded temperature sensor extracted from the BIM to capture indoor thermal conditions.",
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Embedded CO₂ (environmental) sensor extracted from the BIM for indoor air‑quality assessment.",
    DTDFVocab:producedData CO2DataTransmitted
]

// ====================
// C4: Physical‑to‑Virtual Interaction (DataTransmitted)
// ====================

instance LightingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

// ====================
// C5: Data (Live Sensor Streams)
// ====================

instance LightingData : DTDFVocab:Data [
    base:desc "Live lighting level measurements streamed in real‑time from the building.",
    DTDFVocab:fromData LightingDataTransmitted,
    DTDFVocab:inputTo HonoIngestionEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy counts streamed in real‑time from the building zones.",
    DTDFVocab:fromData OccupancyDataTransmitted,
    DTDFVocab:inputTo HonoIngestionEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature readings streamed in real‑time from indoor air sensors.",
    DTDFVocab:fromData TemperatureDataTransmitted,
    DTDFVocab:inputTo HonoIngestionEnabler
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Live CO₂ concentration values streamed in real‑time for air‑quality monitoring.",
    DTDFVocab:fromData CO2DataTransmitted,
    DTDFVocab:inputTo HonoIngestionEnabler
]

// ====================
// C10: Models/Data
// ====================

instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Semantic BIM geometry and topology model enriched with device and control metadata.",
    DTDFVocab:inputTo DittoStateEnabler, UnrealEngine5VisualizationEnabler
]

instance RuntimeControlModel : DTDFVocab:Model [
    base:desc "Runtime model representing building control logic and actuator mappings.",
    DTDFVocab:inputTo DittoStateEnabler
]

instance LiveSensorDataStream : DTDFVocab:Data [
    base:desc "Aggregated live sensor data stream (lighting, occupancy, temperature, CO₂).",
    DTDFVocab:fromData LightingDataTransmitted, OccupancyDataTransmitted, TemperatureDataTransmitted, CO2DataTransmitted,
    DTDFVocab:inputTo HonoIngestionEnabler
]

instance VisualizationAssetModel : DTDFVocab:Model [
    base:desc "3‑D visualisation assets (meshes, materials) generated for Unreal Engine rendering.",
    DTDFVocab:inputTo UnrealEngine5VisualizationEnabler
]

// ====================
// C11: Environment (Physical Building)
// ====================

instance LivingLabBuilding : DTDFVocab:Environment [
    base:contains LightingSensor, OccupancySensor, TemperatureSensor, CO2Sensor,
                LightingDimmerActuator, HVACValveActuator, WindowShadeActuator,
                BIMGeometryModel, RuntimeControlModel
]

// ====================
// C12: Component (General)
// ====================

instance TwinLifecycleManager : DTDFVocab:Component [
    base:desc "Model‑driven pipeline orchestrating BIM enrichment, validation, artefact generation and runtime deployment."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command flow from the twin to physical devices through the same Hono/Ditto middleware, allowing the twin to issue control set‑points (e.g., lighting levels, HVAC commands) to actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real-time synchronization; sensor data are streamed continuously and control commands are propagated with low latency, supporting online monitoring and control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An integrated stack where an enriched BIM model feeds a configurator that generates Hono/Ditto runtime artefacts; these artefacts mediate bidirectional data flow between physical devices and the virtual twin, while Unreal Engine provides the user‑facing visualisation; additional custom services can be plugged via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the full building lifecycle: design (static BIM), construction (model enrichment), and operation (runtime‑enabled twin used for monitoring, optimisation and refurbishment)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to quantify how closely the digital twin reflects its physical counterpart; semantic drift is mitigated by continuous synchronization and model validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time connectivity realised through Eclipse Hono (messaging middleware) and Eclipse Ditto (digital twin platform), which together provide the protocols for telemetry ingestion and twin state updates."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Built on BIM standards for geometry and semantics; uses standardized extension points and aligns with industry practices for digital twins; evaluation employs the ODTE metric, a recognized standard for entanglement assessment."
]