// C2: Acting Components
instance OccupancyLightingController : DTDFVocab:ActingComponent [
    base:desc "Lighting control system embedded in BIM for occupancy-based adjustments, integrated with Unreal Engine visualizations for real-time monitoring"
]

instance HVACSystemController : DTDFVocab:Actuator [
    base:desc "HVAC control system actuator with embedded control logic for temperature/humidity regulation, synchronized with runtime metadata from BIM"
]

instance ShadingDeviceActuator : DTDFVocab:ActingComponent [
    base:desc "Shading device actuator for dynamic daylight control, configured via BIM-based control rules"
]

instance EnergyManagementActuator : DTDFVocab:ActingComponent [
    base:desc "Energy optimization actuator implementing reinforcement learning-based control (BOREALIS project) for adaptive HVAC/lighting"
]

// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy temperature sensor deployed in building infrastructure, providing real-time environmental data for operational optimization"
    DTDFVocab:producedData TemperatureDataStream
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Environmental humidity sensor monitoring indoor air quality metrics, integrated with BIM for spatial relationship tracking"
    DTDFVocab:producedData HumidityDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Motion detection sensor for occupancy tracking, configured via BIM model-to-model transformations for runtime interface generation"
    DTDFVocab:producedData OccupancyDataStream
]

instance LightIntensitySensor : DTDFVocab:SensingComponent [
    base:desc "Daylight sensor measuring natural light levels, embedded in building control logic within BIM environment"
    DTDFVocab:producedData LightIntensityDataStream
]

instance EnergyConsumptionMeter : DTDFVocab:SensingComponent [
    base:desc "Real-time energy consumption meter for HVAC/lighting systems, synchronized with BIM's spatial hierarchies"
    DTDFVocab:producedData EnergyConsumptionDataStream
]

// C4: Data Transmission Streams
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightIntensityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightIntensitySensor
]

instance EnergyConsumptionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionMeter
]

// C10: Models/Data - BIM-based Structural Models
instance BuildingStructureModel : DTDFVocab:Model [
    base:desc "Static 3D geometry and spatial relationships from building design phase, maintained in BIM environment for structural integrity verification"
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Runtime metadata extracted from BIM for embedded control logic (lighting/BCS rules), transformed via model-to-model transformations"
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance OperationalDataModel : DTDFVocab:Model [
    base:desc "Real-time operational data repository integrating sensor readings and actuator commands for performance benchmarking"
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

// C10: Additional Data Types
instance SensorConfigurationMetadata : DTDFVocab:Data [
    base:desc "Device configurations (sensor IDs, endpoint addresses) extracted from BIM for runtime interface generation"
]

instance ControlRuleMetadata : DTDFVocab:Data [
    base:desc "Embedded control logic (lighting/BCS rules) extracted from BIM for adaptive building management"
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Aggregated real-time operational data (sensor readings, actuator commands) for predictive maintenance and optimization"
    DTDFVocab:fromData TemperatureDataStream, HumidityDataStream, OccupancyDataStream, LightIntensityDataStream, EnergyConsumptionDataStream
    DTDFVocab:inputTo UnrealEngineVisualization
]

// C11: Enablers
instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Automated transformation pipeline converting BIM models to runtime artifacts via model-to-model/model-to-text transformations"
]

instance EclipseHonoMiddleware : DTDFVocab:Enabler [
    base:desc "Real-time bidirectional data exchange platform (Eclipse Hono/Ditto) for physical-virtual synchronization"
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Interactive 3D visualization environment for immersive DT monitoring with synchronized physical building data"
]

// Supporting Components
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains OccupancyLightingController, HVACSystemController, ShadingDeviceActuator, EnergyManagementActuator,
             TemperatureSensor, HumiditySensor, OccupancySensor, LightIntensitySensor, EnergyConsumptionMeter
]

instance DigitalTwinHub : DTDFVocab:Component [
    base:desc "Centralized service-oriented architecture acting as DT integration hub for all components and services"
]

// C17: Insights/Actions - Operational Optimization
instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Real-time analytics comparing actual energy consumption against design-phase simulations for optimization recommendations"
]

instance ComfortOptimizationInsight : DTDFVocab:Insight [
    base:desc "Occupant comfort metrics derived from temperature/humidity/lighting data for adaptive control adjustments"
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Equipment failure forecasting based on sensor data trends and historical patterns for proactive interventions"
]

instance PerformanceBenchmarkAction : DTDFVocab:Action [
    base:desc "Automated benchmarking comparison between physical building performance and BIM simulations for corrective actions"
    DTDFVocab:IsAutomatic true
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization via Unreal Engine for real-time monitoring of building conditions (occupancy, energy usage, environmental parameters)"
    DTDFVocab:enables UnrealEngineVisualization
]

instance SimulationAndAnalysisService : DTDFVocab:Service [
    base:desc "End-to-end automation pipeline for BIM-to-DT transformations enabling predictive analytics and performance optimization"
    DTDFVocab:provides EnergyEfficiencyInsight, ComfortOptimizationInsight
]

instance AdaptiveControlService : DTDFVocab:Service [
    base:desc "Reinforcement learning-based optimization of lighting and HVAC systems using post-occupancy sensor feedback"
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance CustomServiceExtension : DTDFVocab:Service [
    base:desc "Modular extension points for integrating third-party analytics, IoT gateways, or domain-specific services"
    DTDFVocab:provides PerformanceBenchmarkAction
]

instance AutomatedCommissioningService : DTDFVocab:Service [
    base:desc "Automated deployment pipeline reducing manual effort for device modeling and runtime interface generation"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals and commands generated by the DT are transmitted back to the physical building via the same middleware (Eclipse Hono/Ditto) to execute actions on actuators (e.g., adjusting HVAC systems, lighting, or shading). This enables closed-loop control, where the DT processes operational data to optimize building performance (e.g., energy efficiency, occupant comfort) in real-time. The framework supports modular service integration, allowing DT engineers to define custom control logic and extend functionality dynamically."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates with continuous real-time synchronization, ensuring live data exchange between physical and virtual systems. While no specific granularity (e.g., 1-second intervals) is mentioned, the framework supports high-frequency updates for critical operational data, enabling responsive control and monitoring."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is a **service-oriented, modular ecosystem** composed of:
  1. A **centralized DT core**: Orchestrates bidirectional data flow between physical assets and the virtual model, using middleware (Eclipse Hono/Ditto) for real-time synchronization.
  2. **Domain-specific services**:
     - **Lighting control** (e.g., TwinLight project): Embedded BIM-based control logic for adaptive lighting.
     - **Energy optimization** (e.g., BOREALIS project): Reinforcement learning models integrated with BIM for dynamic control policies.
     - **Visualization layer**: Unreal Engine provides immersive 3D interfaces for monitoring and simulation.
  3. **External integrations**: Horizontal integration with other DTs or AECO systems via standardized APIs (e.g., BIM standards like IFC). The framework’s extension points enable seamless addition of new services or analytics."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans all lifecycle stages of the physical building:
  1. **Design phase**: Enriched BIM models include device configurations, control logic, and sensor placements.
  2. **Construction phase**: BIM models are validated and transformed into runtime artifacts for automated deployment.
  3. **Operation phase**: Real-time synchronization occurs via middleware (Eclipse Hono/Ditto), with services like adaptive lighting (BOREALIS) and predictive analytics evolving over time.
  4. **Refurbishment phase**: DTs can be updated or extended to accommodate new requirements (e.g., retrofitting sensors, integrating IoT devices). The framework ensures compatibility with existing BIM standards and AECO workflows."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT’s fidelity and validity are ensured through:
  1. **Semantic Alignment**: BIM models are enriched with runtime semantics (e.g., sensor configurations, control logic) to bridge the gap between static design and dynamic operation.
  2. **Real-Time Synchronization**: Middleware (Eclipse Hono/Ditto) ensures bidirectional data flow with minimal latency, reducing semantic drift between the physical and virtual worlds.
  3. **Validation Metrics**: The **Overall Digital Twin Entanglement (ODTE) metric** evaluates the DT’s interoperability and architectural soundness, quantifying its alignment with the physical building.
  4. **Uncertainty Handling**: The framework supports modular updates and service extensions, allowing DTs to adapt to evolving operational requirements without losing fidelity.
  5. **Verification/Validation**: Automated model-to-model transformations and runtime interface generation reduce manual errors, ensuring data integrity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Technical connections rely on **real-time data exchange protocols** (e.g., Eclipse Hono/Ditto) for bidirectional communication between physical and virtual systems. While specific protocols (e.g., MQTT, WebSockets) are not detailed, the framework emphasizes seamless integration with IoT and BMS systems for operational monitoring."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed as a **scalable, modular system** leveraging cloud/edge infrastructure (not specified in documents). The framework emphasizes **low-overhead updates** via runtime configuration management, enabling dynamic adjustments without redeployment. The deployment is designed for **long-term compatibility** with existing AECO systems (e.g., BIM, BMS) and adheres to standardized extension points for future extensibility."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration supports interoperability with external systems, including:
  1. **Building Management Systems (BMS) and IoT platforms**: For seamless data exchange with operational infrastructure.
  2. **Interoperability frameworks**: Generalized integration with heterogeneous systems to enable cross-domain collaboration."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework adheres to AECO-specific standards like **Building Information Modeling (BIM)** and leverages general-purpose middleware (Eclipse Hono/Ditto) for interoperability. No explicit mention of proprietary standards (e.g., IFC, COBie) or protocols (e.g., MQTT) is provided."
]