]

instance OccupancyManagementService : DTDFVocab:Service [
    base:desc "Occupancy prediction to optimize space utilization in academic environments"
    DTDFVocab:provides SpaceUtilizationInsight
]

instance ClosedLoopControlService : DTDFVocab:Service [
