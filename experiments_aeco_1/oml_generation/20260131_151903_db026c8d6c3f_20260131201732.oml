]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Cloud-based remote management of building operations for facility managers"
    DTDFVocab:provides RemoteControlAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive dashboards displaying real-time and historical data for stakeholders (researchers, facility managers)"
