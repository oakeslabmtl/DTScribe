]

instance 3DMappingService : DTDFVocab:Service [
    base:desc "3D spatial mapping of sensor placements and system interactions in living labs"
    DTDFVocab:provides SpatialMappingInsight
]

instance ModelDrivenWorkflowService : DTDFVocab:Service [
    base:desc "Automation of model-driven engineering workflows for digital twin development"
    DTDFVocab:provides WorkflowAutomationAction
]

instance CrossDisciplinaryCollaborationService : DTDFVocab:Service [
    base:desc "Collaborative governance platform enabling cross-disciplinary collaboration between engineers, architects, and researchers"
    DTDFVocab:provides CollaborationInsight
]

