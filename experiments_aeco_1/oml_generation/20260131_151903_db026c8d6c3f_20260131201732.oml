    base:desc "Automated controller for dynamic HVAC system adjustments in LEED Platinum-certified academic buildings for energy efficiency optimization"
]

instance LightingActuator : DTDFVocab:Actuator [
    base:desc "Actuator for occupancy-based lighting control in university living labs, adjusting brightness according to real-time occupancy predictions"
]

instance StructuralMonitorActuator : DTDFVocab:Actuator [
    base:desc "Actuator for real-time structural health monitoring adjustments in research-oriented buildings"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "High-precision temperature sensors deployed throughout university library living labs for indoor environmental condition monitoring"
    DTDFVocab:producedData TemperatureData
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity monitoring sensors integrated into HVAC systems to maintain optimal indoor air quality in research environments"
    DTDFVocab:producedData HumidityData
]

instance AirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ and VOC sensors deployed in multiple zones of academic buildings for real-time air quality assessment"
    DTDFVocab:producedData AirQualityData
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Motion and presence sensors distributed across university library spaces for occupancy tracking and adaptive control"
    DTDFVocab:producedData OccupancyData
]

instance StructuralStrainSensor : DTDFVocab:SensingComponent [
    base:desc "Strain gauges embedded in structural elements for continuous structural health monitoring in LEED-certified buildings"
    DTDFVocab:producedData StructuralData
]

instance HVACPerformanceSensor : DTDFVocab:SensingComponent [
    base:desc "Performance sensors monitoring HVAC system efficiency and energy consumption in real-time"
    DTDFVocab:producedData HVACMetricsData
]

instance LightingPerformanceSensor : DTDFVocab:SensingComponent [
    base:desc "Energy efficiency sensors for lighting systems in research labs to validate adaptive control strategies"
    DTDFVocab:producedData LightingMetricsData
]

// C4: Physical-to-virtual interaction
instance TemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance AirQualityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualitySensor
]

instance OccupancyData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance StructuralData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralStrainSensor
]

instance HVACMetricsData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACPerformanceSensor
]

instance LightingMetricsData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingPerformanceSensor
]

// C10: Models/Data
instance BuildingPerformanceModel : DTDFVocab:Model [
    base:desc "BIM-based computational framework representing LEED Platinum building components for performance simulation and optimization"
    DTDFVocab:inputTo BIMIntegrationTool
]

instance EnvironmentalSimulationModel : DTDFVocab:Model [
    base:desc "Thermal and air quality simulation model integrated with real-time sensor data for predictive analytics"
    DTDFVocab:inputTo SimulationEngine
]

instance EnergyOptimizationModel : DTDFVocab:Model [
    base:desc "Model-driven optimization framework for HVAC/lighting control strategies in academic research environments"
    DTDFVocab:inputTo ModelDrivenEngineeringTool
]

instance PredictiveMaintenanceModel : DTDFVocab:Model [
    base:desc "AI/ML model for predictive maintenance of structural and HVAC components in LEED-certified buildings"
    DTDFVocab:inputTo MachineLearningFramework
]

instance OccupancyAnalysisModel : DTDFVocab:Model [
    base:desc "Space utilization model predicting occupancy patterns in university libraries and research labs"
    DTDFVocab:inputTo AnalyticsPlatform
]

instance RealTimeDataRepository : DTDFVocab:Data [
    base:desc "Time-series database storing real-time environmental metrics (temperature, humidity, CO₂) from distributed sensors"
    DTDFVocab:fromData TemperatureData, HumidityData, AirQualityData, OccupancyData
    DTDFVocab:inputTo TimeSeriesDatabase
]

instance StructuralHealthDatabase : DTDFVocab:Data [
    base:desc "Graph database representing relationships between physical assets and structural health indicators"
    DTDFVocab:fromData StructuralData
    DTDFVocab:inputTo GraphDatabase
]

// C11: Enablers
instance BIMIntegrationTool : DTDFVocab:Enabler [
    base:desc "itwin.js platform enabling BIM (Building Information Modeling) integration and real-time visualization of physical assets in digital twins"
    DTDFVocab:enables BuildingPerformanceModel, EnvironmentalSimulationModel
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Real-time data synchronization platform (Eclipse Hono) for live synchronization between physical sensors and digital twin models"
    DTDFVocab:enables TemperatureData, HumidityData, AirQualityData, OccupancyData, StructuralData
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Runtime configuration management system for bidirectional data exchange between physical assets and digital twins"
    DTDFVocab:enables HVACMetricsData, LightingMetricsData
]

instance ModelDrivenEngineeringTool : DTDFVocab:Enabler [
    base:desc "Impromptu framework for model-driven engineering workflows enabling rapid prototyping of digital twin logic"
    DTDFVocab:enables EnergyOptimizationModel
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Custom simulation tools for HVAC/lighting system modeling integrated with physical sensors for closed-loop validation"
    DTDFVocab:enables EnvironmentalSimulationModel
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Distributed sensor data repository storing real-time environmental metrics for historical analysis"
    DTDFVocab:enables RealTimeDataRepository
]

instance GraphDatabase : DTDFVocab:Enabler [
    base:desc "Graph database platform representing relationships between physical assets and digital twin components"
    DTDFVocab:enables StructuralHealthDatabase
]

instance MachineLearningFramework : DTDFVocab:Enabler [
    base:desc "AI/ML platform for predictive maintenance and anomaly detection using sensor data from living labs"
    DTDFVocab:enables PredictiveMaintenanceModel
]

instance AnalyticsPlatform : DTDFVocab:Enabler [
    base:desc "Data analytics platform for occupancy prediction and space utilization modeling in academic environments"
    DTDFVocab:enables OccupancyAnalysisModel
]

instance EclipseBasyx : DTDFVocab:Enabler [
    base:desc "Open-source platform for real-time communication between physical and digital twins via IIoT protocols (MQTT, WebSockets)"
    DTDFVocab:enables HVACController, LightingActuator
]

instance SemanticOntology : DTDFVocab:Enabler [
    base:desc "Semantic Web technologies enabling interoperability across digital twin platforms through standardized ontologies"
    DTDFVocab:enables BuildingPerformanceModel, EnvironmentalSimulationModel
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time indoor environmental condition tracking (temperature, CO₂ levels, air quality) via sensor networks in university libraries"
    DTDFVocab:provides IndoorEnvironmentInsight, HVACPerformanceInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
