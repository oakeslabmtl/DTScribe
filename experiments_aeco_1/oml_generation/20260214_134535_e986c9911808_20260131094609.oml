// Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the living lab building, linked to BIM metadata"
    DTDFVocab:producedData TemperatureDataTx
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector integrated into the building walls, providing presence data"
    DTDFVocab:producedData OccupancyDataTx
]

instance LightIntensitySensor : DTDFVocab:SensingComponent [
    base:desc "Light intensity sensor measuring global illumination within the building"
    DTDFVocab:producedData LightIntensityDataTx
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO\u2082 sensor monitoring indoor air quality"
    DTDFVocab:producedData CO2DataTx
]

instance MotionSensor : DTDFVocab:SensingComponent [
    base:desc "Motion sensor detecting movement for security and occupancy analytics"
    DTDFVocab:producedData MotionDataTx
]

// Data Transmitted Instances
instance TemperatureDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance LightIntensityDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightIntensitySensor
]

instance CO2DataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance MotionDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionSensor
]

// Data Instances
instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature readings transmitted via MQTT"
    DTDFVocab:fromData TemperatureDataTx
    DTDFVocab:inputTo DittoTwinEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy status data streamed from occupancy detectors"
    DTDFVocab:fromData OccupancyDataTx
    DTDFVocab:inputTo DittoTwinEnabler
]

instance LightIntensityData : DTDFVocab:Data [
    base:desc "Real‑time light intensity measurements in the building"
    DTDFVocab:fromData LightIntensityDataTx
    DTDFVocab:inputTo DittoTwinEnabler
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Indoor CO\u2082 concentration readings"
    DTDFVocab:fromData CO2DataTx
    DTDFVocab:inputTo DittoTwinEnabler
]

instance MotionData : DTDFVocab:Data [
    base:desc "Motion detection events from the building"
    DTDFVocab:fromData MotionDataTx
    DTDFVocab:inputTo DittoTwinEnabler
]

// Acting Components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer unit controlled via DT for adaptive lighting"
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve for zone temperature regulation"
]

instance ZoneDamperActuator : DTDFVocab:ActingComponent [
    base:desc "Zone damper regulating airflow in multi‑zone HVAC"
]

// Twin and Environment Components
instance BuildingDTOrchestratorTwin : DTDFVocab:Component [
    base:desc "Central digital twin orchestrator managing all building twins"
]

instance BuildingZoneTwin : DTDFVocab:Component [
    base:desc "Twin representing the building's zone-level devices and sensors"
]

instance AssetGroupTwin : DTDFVocab:Component [
    base:desc "Twin for a group of related building assets"
]

// Environment
instance LivingLabBuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, OccupancyDetector, LightIntensitySensor, CO2Sensor, MotionSensor, LightingDimmerActuator, HVACValveActuator, ZoneDamperActuator, BuildingDTOrchestratorTwin, BuildingZoneTwin, AssetGroupTwin
]

// Enablers
instance HonoMQTTEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono secure MQTT communication for telemetry ingestion"
    DTDFVocab:enables EnergyOptimizationService, PredictiveMaintenanceService
]

instance DittoTwinEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin registration and REST API service"
    DTDFVocab:enables EnergyOptimizationService, PredictiveMaintenanceService, RealTimeDashboardService, MonitoringService, ControlService, ImmersiveVisualizationService
]

instance UnrealEngineEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3D visualization of the building DT"
    DTDFVocab:enables ImmersiveVisualizationService
]

instance BIMRevitEnabler : DTDFVocab:Enabler [
    base:desc "Revit-based BIM model for extraction of building geometry and device metadata"
    DTDFVocab:enables EnergyOptimizationService
]

instance MDEToolchainEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering toolchain for BIM‑to‑runtime artifact transformations"
    DTDFVocab:enables RealTimeDashboardService
]

// Services
instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy optimization using reinforcement learning, processes sensor data to recommend actions"
    DTDFVocab:provides EnergySavingRecommendation
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance analytics based on sensor data streams"
    DTDFVocab:provides FaultAlert, MaintenanceSchedule
]

instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Real‑time building performance dashboards aggregated from sensor data"
    DTDFVocab:provides MonitoringInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization of building twin in Unreal Engine 5"
    DTDFVocab:provides EnterVirtualSceneAction, UpdateLightingLevelAction
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitoring service supervising sensor health and operational status"
    DTDFVocab:provides MonitoringInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Control service to adjust building actuators based on optimization decisions"
    DTDFVocab:provides AdjustControlPolicyAction, HVACValveAdjustmentAction
]

// Insights
instance EnergySavingRecommendation : DTDFVocab:Insight [
    base:desc "Recommendation to adjust HVAC or lighting settings to save energy, generated by energy optimization service"
]

instance FaultAlert : DTDFVocab:Insight [
    base:desc "Alert indicating detected fault in building systems, generated by predictive maintenance service"
]

instance MaintenanceSchedule : DTDFVocab:Insight [
    base:desc "Suggested maintenance schedule for building equipment, generated by predictive maintenance service"
]

instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight on sensor health and building performance status, generated by monitoring service"
]

// Actions
instance AdjustControlPolicyAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of control policies for HVAC and lighting based on optimization recommendations"
    DTDFVocab:IsAutomatic true
]

instance HVACValveAdjustmentAction : DTDFVocab:Action [
    base:desc "Action to adjust HVAC valve positions for zone climate control"
    DTDFVocab:IsAutomatic true
]

instance UpdateLightingLevelAction : DTDFVocab:Action [
    base:desc "Action to dim or brighten lights in specified zones through lighting dimmer actuators"
    DTDFVocab:IsAutomatic false
]

instance EnterVirtualSceneAction : DTDFVocab:Action [
    base:desc "Transition into immersive virtual representation of the building in Unreal Engine"
    DTDFVocab:IsAutomatic false
]

// Models
instance IFCModel : DTDFVocab:Model [
    base:desc "IFC model of the living lab building extracted from BIM"
    DTDFVocab:inputTo BIMRevitEnabler
]

instance DittoTwinDescriptionModel : DTDFVocab:Model [
    base:desc "Ditto twin description generated from BIM metadata"
    DTDFVocab:inputTo MDEToolchainEnabler
]

instance HonoDeviceConfigModel : DTDFVocab:Model [
    base:desc "Hono device configuration files produced via model‑to‑model transformation"
    DTDFVocab:inputTo MDEToolchainEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic models for actuator behavior derived from BIM annotations"
    DTDFVocab:inputTo MDEToolchainEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originating from the DT, such as setpoint adjustments or lighting schedules, are serialized through Ditto twin updates, transmitted over MQTT to Hono, and delivered to the physical actuators to modify building operations."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near‑real‑time synchronization with data exchange intervals of a few seconds, supporting real‑time monitoring, control, and adaptive optimization within the DT lifecycle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An integrated constellation comprising the BIM‑derived runtime models, the Hono middleware, the Ditto twin registry, the DT services layer, and the visualization layer, all coordinated by the central DT orchestrator."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans all lifecycle stages: design (as ideal), manufacturing (construction), and operation (building life cycle), providing a unified digital representation from BIM through operational runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured through the Overall Digital Twin Entanglement (ODTE) metric, semantic validation of BIM metadata, and runtime consistency checks; validity is maintained via continuous verification against physical measurements and controlled convergence."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT employs MQTT over TLS for device telemetry, HTTP/REST APIs for twin queries, and Hono’s Kafka backend for scalable message routing; Ditto provides a durable event store."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT infrastructure is deployed as containerized micro‑services (Docker) orchestrated by Kubernetes, running on cloud or on‑premise data centers, with Hono broker, Ditto server, and visualization service instances."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems such as building information management platforms, facility management software, energy analytics services, and other DTs through standard APIs and shared data models."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data produced by the building’s sensors remains owned by the physical asset owner; the DT provider manages access under secure protocols, ensuring privacy through encrypted transport and role‑based authorization."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The engineering follows BIM IFC standards for structural and spatial data, MQTT for runtime communication, and Ditto’s twin JSON schema, aligning with industry best practices in AECO digital twins."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security is addressed via TLS‑encrypted MQTT, OAuth2/JWT authentication, role‑based access control, and segregation of control networks; safety considerations include fail‑safe mechanisms to prevent unsafe actuator commands and monitoring of critical system health."
]