// C2: Acting Components
instance LightFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Smart lighting fixture capable of receiving dimming commands from the twin"
]

instance HVACDamperActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC damper that can be opened or closed based on twin control signals"
]

// C3: Physical sensing components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor measuring illumination levels in rooms"
    DTDFVocab:producedData LightSensorDataTransmitted
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector sensing presence of occupants in spaces"
    DTDFVocab:producedData OccupancyDetectorDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor capturing ambient temperature"
    DTDFVocab:producedData TemperatureSensorDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor measuring relative humidity"
    DTDFVocab:producedData HumiditySensorDataTransmitted
]

// C4: Physical-to-virtual interaction
instance LightSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance OccupancyDetectorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance TemperatureSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumiditySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

// C10: Data streams
instance LightLevelData : DTDFVocab:Data [
    base:desc "Illuminance data stream from light sensors"
    DTDFVocab:fromData LightSensorDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy status data stream from detectors"
    DTDFVocab:fromData OccupancyDetectorDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Ambient temperature data stream from sensors"
    DTDFVocab:fromData TemperatureSensorDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Relative humidity data stream from sensors"
    DTDFVocab:fromData HumiditySensorDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

// C10: Models/Data
instance BIMStaticModel : DTDFVocab:Model [
    base:desc "BIM model providing static geometry, spatial relationships, and semantic backbone"
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance RuntimeTwinModel : DTDFVocab:Model [
    base:desc "Automatically generated runtime artefacts derived from BIM for digital twin operation"
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model for building automation (lighting, HVAC) linked to twin"
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides MQTT/AMQP ingestion of sensor measurements"
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital twin state and synchronizes virtual and physical assets"
    DTDFVocab:enables RealTimeMonitoringService,
                Interactive3DVisualizationService,
                SimulationService,
                PredictiveAnalyticsService,
                EnergyOptimizationService,
                AdaptiveControlService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders 3D interactive visualizations of the twin"
    DTDFVocab:enables Interactive3DVisualizationService
]

instance PredictiveAnalyticsEngineEnabler : DTDFVocab:Enabler [
    base:desc "Predictive analytics engine processes historical and real‑time data for insight generation"
    DTDFVocab:enables PredictiveAnalyticsService
]

instance EnergyOptimizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Optimization engine computes optimal lighting and energy consumption settings"
    DTDFVocab:enables EnergyOptimizationService
]

instance ReinforcementLearningEngineEnabler : DTDFVocab:Enabler [
    base:desc "Reinforcement‑learning module updates control policies from post‑occupancy data"
    DTDFVocab:enables AdaptiveControlService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of sensor streams and twin state"
    DTDFVocab:provides LightingAdjustmentInsight, EnergySavingsInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "3D interactive visualization of building geometry and status via UE5"
    DTDFVocab:provides LightingAdjustmentInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building operational behavior using runtime models"
    DTDFVocab:provides MaintenanceScheduleInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics on occupancy, temperature, and energy data"
    DTDFVocab:provides LightingAdjustmentInsight, EnergySavingsInsight, RLPolicyUpdateInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of lighting and energy consumption based on predictions"
    DTDFVocab:provides EnergySavingsInsight, AdjustLightingAction, AdjustHVACAction
]

instance AdaptiveControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based adaptive control of building systems"
    DTDFVocab:provides UpdateRLPolicyAction
]

// C17: Insights
instance LightingAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Insight recommending lighting level adjustments based on occupancy forecasts"
]

instance EnergySavingsInsight : DTDFVocab:Insight [
    base:desc "Insight highlighting opportunities for energy savings in HVAC and lighting"
]

instance MaintenanceScheduleInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting preventive maintenance timing derived from sensor trends"
]

instance RLPolicyUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight derived from post‑occupancy data to update reinforcement‑learning control policies"
]

// C17: Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Command to dim or brighten lighting fixtures according to optimization output"
    DTDFVocab:IsAutomatic true
]

instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Command to modulate HVAC dampers for temperature setpoints"
    DTDFVocab:IsAutomatic true
]

instance UpdateRLPolicyAction : DTDFVocab:Action [
    base:desc "Action to upload new reinforcement‑learning policy to building controllers"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points, HVAC adjustments) are sent back to the physical actuators through the same Hono/Ditto bidirectional communication channel."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real‑time updates (sub‑second to second latency) enabled by continuous data exchange through Hono/Ditto."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where enriched BIM models feed a configurator that produces device metadata, which is consumed by Hono/Ditto middleware; the twin visualizes data in Unreal Engine and exposes extension points for custom services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the design phase (BIM creation), construction, operation/maintenance, and refurbishment/adaptation stages of the building lifecycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Entanglement measured with the Overall Digital Twin Entanglement (ODTE) metric to assess how closely the twin mirrors the physical building; semantic drift mitigation discussed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "IP‑based network using Eclipse Hono (supports MQTT, AMQP) for device protocol translation and Eclipse Ditto for twin state management and REST/WebSocket APIs."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adopts BIM standards (e.g., IFC) for semantic consistency and utilizes standardized extension points within the model‑driven framework; Eclipse Ditto follows OMA LwM2M/NGSI‑LD‑like data models."
]