    DTDFVocab:producedData EnergyConsumptionData
]

instance StructuralStressSensor : DTDFVocab:SensingComponent [
    base:desc "Vibration and strain gauge sensor array monitoring structural integrity with 0.01mm resolution for early fault detection"
    DTDFVocab:producedData StructuralHealthData
]

instance HVACPerformanceSensor : DTDFVocab:SensingComponent [
    base:desc "Multi-parameter sensor measuring HVAC system efficiency metrics including airflow, pressure differentials, and CO2 levels"
    DTDFVocab:producedData HVACSystemData
]

