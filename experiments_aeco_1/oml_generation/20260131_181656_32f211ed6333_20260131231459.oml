instance ModelDrivenTransformationEngine : DTDFVocab:Enabler [
    base:desc "QVT-based model transformation engine converting enriched BIM models to deployable DT artifacts with 98% transformation accuracy"
    DTDFVocab:enables BIMToDTTransformationService, ControlLogicGenerationService
]

instance EventStreamProcessor : DTDFVocab:Enabler [
    base:desc "Apache Flink-based stream processor handling 10,000 events/second with sub-millisecond latency for real-time analytics"
