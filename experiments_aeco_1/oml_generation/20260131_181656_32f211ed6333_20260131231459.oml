    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyPatternData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyConsumptionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMonitoringSensor
]

instance StructuralHealthData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralStressSensor
]

instance HVACSystemData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACPerformanceSensor
]

// C10: Models/Data
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing BCS components with semantic annotations for sensor-actuator relationships, generated via QVT transformations from IFC files"
    DTDFVocab:inputTo ModelDrivenTransformationEngine
]

instance OperationalStateModel : DTDFVocab:Model [
    base:desc "Real-time operational state model representing current building conditions with 1-second update granularity, derived from sensor data streams"
    DTDFVocab:inputTo EventStreamProcessor
]

instance PredictiveMaintenanceModel : DTDFVocab:Model [
    base:desc "LSTM-based time-series model for equipment failure prediction with 92% accuracy, trained on historical sensor data and validated via cross-validation"
    DTDFVocab:inputTo TensorFlowServing
]

instance EnergyOptimizationModel : DTDFVocab:Model [
    base:desc "Multi-objective optimization model using NSGA-II algorithm for HVAC control, validated through simulation-to-reality comparisons"
    DTDFVocab:inputTo ApacheSpark
]

instance DigitalShadowModel : DTDFVocab:Model [
    base:desc "Shadow model maintaining parallel digital representation of physical building state for what-if analysis and counterfactual reasoning"
    DTDFVocab:inputTo AnyLogicSimulationEngine
]

instance SensorDataStream : DTDFVocab:Data [
    base:desc "Continuous stream of sensor data with timestamped readings from all building systems, processed through Kafka for real-time analytics"
    DTDFVocab:fromData EnvironmentalTemperatureData, RelativeHumidityData, OccupancyPatternData, EnergyConsumptionData, StructuralHealthData, HVACSystemData
    DTDFVocab:inputTo StreamProcessingEngine
]

instance HistoricalBuildingData : DTDFVocab:Data [
    base:desc "Time-series database containing 5-year historical building operational data used for baseline comparisons and trend analysis"
    DTDFVocab:fromData EnergyConsumptionData
    DTDFVocab:inputTo BatchProcessingEngine
]

instance ModelCheckpoints : DTDFVocab:Data [
    base:desc "Versioned model artifacts stored in HDF5 format with semantic versioning, containing canonical checkpoints for all ML models"
    DTDFVocab:fromData PredictiveMaintenanceModel, EnergyOptimizationModel
    DTDFVocab:inputTo ModelRegistryService
]

