instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded IoT sensor measuring building environmental temperature with ±0.1°C precision, synchronized via MQTT protocol at 1-second intervals"
    DTDFVocab:producedData EnvironmentalTemperatureData
]

