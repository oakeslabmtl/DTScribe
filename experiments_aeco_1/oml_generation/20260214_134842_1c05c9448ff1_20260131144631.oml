// Sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
  base:desc "Occupancy sensor embedded in BIM model, reports occupancy events"
  DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
  base:desc "Temperature sensor embedded in BIM model, provides ambient temperature"
  DTDFVocab:producedData TemperatureDataTransmitted
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
  base:desc "Illuminance sensor embedded in BIM model, measures light levels"
  DTDFVocab:producedData IlluminanceDataTransmitted
]

// Data transmitted from sensors
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
  DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
  DTDFVocab:producedFrom TemperatureSensor
]

instance IlluminanceDataTransmitted : DTDFVocab:DataTransmitted [
  DTDFVocab:producedFrom IlluminanceSensor
]

// Telemetry data stored in Ditto registry
instance OccupancyData : DTDFVocab:Data [
  base:desc "Telemetry data of occupancy events stored in Ditto twin registry"
  DTDFVocab:inputTo EclipseDitto
  DTDFVocab:fromData OccupancyDataTransmitted
]

instance TemperatureData : DTDFVocab:Data [
  base:desc "Telemetry data of temperature readings stored in Ditto twin registry"
  DTDFVocab:inputTo EclipseDitto
  DTDFVocab:fromData TemperatureDataTransmitted
]

instance IlluminanceData : DTDFVocab:Data [
  base:desc "Telemetry data of illuminance readings stored in Ditto twin registry"
  DTDFVocab:inputTo EclipseDitto
  DTDFVocab:fromData IlluminanceDataTransmitted
]

// Acting components
instance SmartLightingFixture : DTDFVocab:ActingComponent [
  base:desc "Smart lighting fixture mapped from BIM, drives building lighting system"
]

instance SmartLightingController : DTDFVocab:ActingComponent [
  base:desc "Controller for smart lighting fixtures, implements lighting schedules"
]

// Models and data
instance BIMModelEnriched : DTDFVocab:Model [
  base:desc "BIM model enriched with device metadata for twin creation"
  DTDFVocab:inputTo BOREALISPipeline
]

instance ControlLogicModel : DTDFVocab:Model [
  base:desc "Runtime control‑logic model generated from BIM for building automation"
  DTDFVocab:inputTo BOREALISPipeline
  DTDFVocab:inputTo EclipseDitto
]

instance TelemetryDataModel : DTDFVocab:Model [
  base:desc "Continuous sensor telemetry model stored in Ditto twin registries"
  DTDFVocab:inputTo EclipseDitto
]

// Enablers
instance EclipseHono : DTDFVocab:Enabler [
  base:desc "Eclipse Hono IoT messaging backbone for publishing sensor telemetry"
  DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDitto : DTDFVocab:Enabler [
  base:desc "Eclipse Ditto twin management for storing configuration and telemetry"
  DTDFVocab:enables SimulationService
  DTDFVocab:enables PredictiveAnalyticsService
  DTDFVocab:enables EnergyOptimisationService
  DTDFVocab:enables LightingQualityOptimisationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
  base:desc "Unreal Engine 5 for immersive visualisation of the digital twin"
  DTDFVocab:enables ImmersiveVisualisationService
]

instance BOREALISPipeline : DTDFVocab:Enabler [
  base:desc "Model‑driven engineering pipeline that converts BIM semantics into runtime artifacts"
  DTDFVocab:enables SimulationService
  DTDFVocab:enables PredictiveAnalyticsService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
  base:desc "Real‑time monitoring of building operation through telemetry"
  DTDFVocab:provides OccupantComfortInsight
]

instance SimulationService : DTDFVocab:Service [
  base:desc "Simulation of building energy flows and lighting performance"
  DTDFVocab:provides EnergyOptimisationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
  base:desc "Predictive analytics for maintenance and operational efficiency"
  DTDFVocab:provides PredictiveMaintenanceInsight
]

instance EnergyOptimisationService : DTDFVocab:Service [
  base:desc "Energy optimisation based on sensor telemetry and control logic"
  DTDFVocab:provides EnergyOptimisationInsight
]

instance LightingQualityOptimisationService : DTDFVocab:Service [
  base:desc "Lighting quality optimisation using real‑time illuminance data"
  DTDFVocab:provides LightingControlAction
]

instance ImmersiveVisualisationService : DTDFVocab:Service [
  base:desc "Immersive visualisation of the building twin via Unreal Engine 5"
  DTDFVocab:provides FacilityManagerDashboardInsight
]

// Insights
instance OccupantComfortInsight : DTDFVocab:Insight [
  base:desc "Data‑driven insight for occupant comfort derived from occupancy and temperature telemetry"
]

instance EnergyOptimisationInsight : DTDFVocab:Insight [
  base:desc "Insight on optimal energy usage patterns generated from simulation and telemetry data"
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
  base:desc "Predictive maintenance insight for building systems based on telemetry analytics"
]

instance FacilityManagerDashboardInsight : DTDFVocab:Insight [
  base:desc "Decision‑support dashboard insight for facility managers integrating metrics and visualisation"
]

// Actions
instance LightingControlAction : DTDFVocab:Action [
  base:desc "Automatic adjustment of lighting fixtures to maintain desired illuminance levels"
  DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., dimming levels, set‑points) are published to Ditto, routed through Hono to the building’s IoT network, and executed by the relevant actuators (such as smart lights)."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange, with updates propagated immediately as telemetry or control events occur; no explicit periodic cadence is defined in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralised platform comprising the BIM‑based digital foundation, the Hono/ Ditto middleware cluster, and the Unreal Engine visualiser, orchestrating all component twins and services"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the design‑to‑as‑built phase and the operational phase, enabling post‑occupancy monitoring and adaptive control; manufacturing of components is not covered."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to assess fidelity; MDE ensures semantic consistency and model‑to‑text transformations provide validation of runtime artifacts"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical devices communicate via Eclipse Hono to the IoT middleware, and Eclipse Ditto mediates all data flows to and from the DT; the twin subscribes to telemetry topics and publishes control commands through these services."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external information systems is enabled through the standardized Hono‑Ditto middleware, allowing data exchange beyond the twin to other platforms within the building ecosystem."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT follows BIM as the semantic backbone and uses Eclipse Hono and Ditto as standardized middleware, ensuring compliance with building and IoT integration standards."
]