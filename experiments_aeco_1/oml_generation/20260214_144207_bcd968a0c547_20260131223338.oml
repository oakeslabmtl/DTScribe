// C2: Acting Components
instance OccupancyActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for automated occupancy-based lighting control in building systems, configured via BIM-enriched models and integrated with Eclipse Hono/Ditto middleware for bidirectional control signals."
]

instance EnergyOptimizationActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator implementing adaptive energy optimization strategies (e.g., BOREALIS project) for lighting systems, adjusting based on reinforcement learning models and post-occupancy sensor data."
]

instance AdaptiveLightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator implementing adaptive lighting control policies that balance energy efficiency, visual comfort, and non-visual health effects through iterative updates from BIM models and sensor streams."
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Physical temperature sensor deployed within building infrastructure, capturing operational temperature data for real-time monitoring and DT synchronization via Eclipse Hono/Ditto."
    DTDFVocab:producedData TemperatureDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Physical occupancy sensor detecting presence/absence in building zones, transmitting occupancy data streams for real-time monitoring and adaptive control logic implementation."
    DTDFVocab:producedData OccupancyDataStream
]

instance EnergyUsageSensor : DTDFVocab:SensingComponent [
    base:desc "Physical energy consumption sensor measuring real-time power usage across building systems, enabling energy optimization services and predictive analytics."
    DTDFVocab:producedData EnergyDataStream
]

instance EnvironmentalParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Physical environmental parameter sensor capturing conditions like humidity, air quality, and lighting levels for immersive visualization and operational monitoring."
    DTDFVocab:producedData EnvironmentalDataStream
]

instance BIMMetadataExtractor : DTDFVocab:SensingComponent [
    base:desc "BIM-based component extracting device metadata (e.g., device IDs, data types) from enriched BIM models to configure runtime interfaces for seamless data flow with Eclipse Hono/Ditto."
    DTDFVocab:producedData BIMMetadataStream
]

// C4: Physical-to-virtual interaction
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyUsageSensor
]

instance EnvironmentalDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalParameterSensor
]

instance BIMMetadataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BIMMetadataExtractor
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Semantically enriched BIM model incorporating static building geometry, functional relationships, and dynamic Building Control System metadata (sensor/actuator configurations, control logic)."
]

instance RealTimeDataStreamCollection : DTDFVocab:Data [
    base:desc "Collection of real-time data streams from sensors (temperature, occupancy, energy usage) normalized via Eclipse Hono/Ditto middleware for DT synchronization."
    DTDFVocab:fromData TemperatureDataStream, OccupancyDataStream, EnergyDataStream, EnvironmentalDataStream
    DTDFVocab:inputTo EclipseHonoMiddleware, BOREALISAdaptiveControl
]

instance BIMRuntimeConfiguration : DTDFVocab:Data [
    base:desc "Runtime configuration artifacts derived from BIM metadata extraction, defining sensor/actuator mappings and middleware interfaces for automated deployment."
    DTDFVocab:fromData BIMMetadataStream
    DTDFVocab:inputTo EclipseHonoMiddleware, UnrealEngine5Visualization
]

// C11: Enablers
instance EclipseHonoMiddleware : DTDFVocab:Enabler [
    base:desc "Real-time data exchange middleware (Eclipse Hono) facilitating bidirectional communication between physical sensors/actuators and DT virtual model via structured event streams."
    DTDFVocab:enables TemperatureDataStream, OccupancyDataStream, EnergyDataStream, EnvironmentalDataStream
]

instance DittoMiddleware : DTDFVocab:Enabler [
    base:desc "Ditto middleware extension for enhanced DT data transmission capabilities, supporting custom event handling and protocol integration."
    DTDFVocab:enables RealTimeDataStreamCollection
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Immersive 3D visualization platform (Unreal Engine 5) providing interactive monitoring of building conditions through BIM-integrated spatial context."
]

instance BOREALISAdaptiveControl : DTDFVocab:Enabler [
    base:desc "Adaptive control framework (BOREALIS project) implementing reinforcement learning algorithms for energy-efficient operational strategies (e.g., lighting schedules)."
    DTDFVocab:enables EnergyOptimizationService, AdaptiveLightingService
]

instance ModelDrivenDeploymentPipeline : DTDFVocab:Enabler [
    base:desc "MDE-based pipeline automating BIM-to-runtime artifact transformation, reducing manual intervention through standardized extension points for modular upgrades."
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization service providing immersive monitoring of building conditions (occupancy, energy usage, environmental parameters) via Unreal Engine 5."
    DTDFVocab:provides SpatialOccupancyMonitoring, EnvironmentalConditionInsights
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Runtime simulation and optimization service generating energy-efficient operational strategies (e.g., adaptive lighting schedules) using BOREALIS algorithms."
    DTDFVocab:provides EnergyEfficiencyRecommendations, ControlPolicyOptimization
]

instance AdaptiveLightingService : DTDFVocab:Service [
    base:desc "Adaptive lighting control service implementing reinforcement learning-based policies balancing energy efficiency, visual comfort, and non-visual health effects."
    DTDFVocab:provides LightingScheduleOptimization, ComfortAdaptation
]

instance PredictiveAnomalyDetection : DTDFVocab:Service [
    base:desc "Custom predictive analytics service identifying deviations from expected behavior via anomaly detection, triggering automated corrective actions."
    DTDFVocab:provides DeviationDetection, AlertGeneration
]

instance CustomServiceDeployment : DTDFVocab:Service [
    base:desc "Modular service deployment framework enabling extension points for custom services (e.g., predictive maintenance, anomaly detection) without redeploying core framework."
    DTDFVocab:provides ServiceExtensibility, ModularScalability
]

// C17: Insights/Actions
instance SpatialOccupancyMonitoring : DTDFVocab:Insight [
    base:desc "Real-time visualization of building occupancy patterns through immersive 3D spatial context, enabling proactive decision-making by facility managers."
]

instance EnvironmentalConditionInsights : DTDFVocab:Insight [
    base:desc "Monitoring of environmental parameters (temperature, humidity, air quality) to support operational decision-making and comfort optimization."
]

instance EnergyEfficiencyRecommendations : DTDFVocab:Insight [
    base:desc "Optimized operational strategies (e.g., energy-efficient lighting schedules) generated by BOREALIS algorithms for reducing energy consumption."
]

instance ControlPolicyOptimization : DTDFVocab:Insight [
    base:desc "Iteratively refined control policies (e.g., adaptive lighting) based on post-occupancy sensor data to improve operational performance."
]

instance LightingScheduleOptimization : DTDFVocab:Insight [
    base:desc "Adaptive lighting schedules balancing energy efficiency, visual comfort, and non-visual health effects through reinforcement learning models."
]

instance ComfortAdaptation : DTDFVocab:Insight [
    base:desc "Dynamic adjustment of environmental conditions to optimize occupant comfort while maintaining energy efficiency."
]

instance DeviationDetection : DTDFVocab:Insight [
    base:desc "Anomaly detection identifying operational deviations from expected behavior, triggering automated alerts or corrective actions."
]

instance AlertGeneration : DTDFVocab:Action [
    base:desc "Automated generation of alerts for critical operational deviations detected by predictive analytics services."
    DTDFVocab:IsAutomatic true
]

instance ServiceExtensibility : DTDFVocab:Action [
    base:desc "Modular deployment capability allowing DT engineers to integrate custom services (e.g., predictive maintenance) via standardized extension points."
    DTDFVocab:IsAutomatic true
]

instance ModularScalability : DTDFVocab:Action [
    base:desc "Support for scalable deployment of DT components across heterogeneous building infrastructures while maintaining interoperability."
    DTDFVocab:IsAutomatic true
]

// Supporting Components
instance BuildingGeometryComponent : DTDFVocab:Component [
    base:desc "Static spatial representation of building structure from BIM model, serving as foundation for DT visualization and control logic."
]

instance SensorNetworkComponent : DTDFVocab:Component [
    base:desc "Physical infrastructure of sensors deployed throughout building zones for real-time data collection and DT synchronization."
]

instance ControlLogicComponent : DTDFVocab:Component [
    base:desc "BIM-enriched control logic representing device configurations, actuator mappings, and adaptive algorithms for DT runtime."
]

instance DataNormalizationComponent : DTDFVocab:Component [
    base:desc "Middleware processing unit normalizing sensor data streams into structured events for consistent DT ingestion via Eclipse Hono/Ditto."
]

instance VisualizationContextComponent : DTDFVocab:Component [
    base:desc "Spatial context layer integrating BIM geometry with real-time data for immersive visualization in Unreal Engine 5."
]

instance AdaptiveAlgorithmComponent : DTDFVocab:Component [
    base:desc "Reinforcement learning-based algorithms implementing BOREALIS adaptive control strategies for energy optimization and comfort adaptation."
]

instance MetadataExtractionComponent : DTDFVocab:Component [
    base:desc "BIM processing unit extracting device metadata (IDs, data types) for runtime interface configuration and automated deployment."
]

instance ExtensionPointComponent : DTDFVocab:Component [
    base:desc "Standardized interface points enabling modular custom service integration without redeploying core DT framework."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Virtual-to-physical interaction is facilitated by **control signals** generated by the DT and transmitted back to the physical building via the same middleware (Eclipse Hono/Ditto). The framework leverages **BIM-enriched control logic** defined by Building Control Engineers, which is automatically transformed into runtime artifacts. These artifacts enable the DT to issue commands (e.g., lighting adjustments, HVAC setpoints) to actuators in real-time, ensuring adaptive control of the physical infrastructure based on virtual model predictions or optimization algorithms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates with real-time synchronization, ensuring live data streams from physical sensors are processed and reflected in the virtual model. The twinning process leverages iterative updates (e.g., BOREALIS reinforcement learning) to refine control policies over time, maintaining high fidelity between the physical and virtual representations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is organized as a **service-oriented, modular architecture** with the following components:
  1. **Core DT Framework**: Acts as the central hub, integrating BIM models, middleware (Eclipse Hono/Ditto), and visualization (Unreal Engine 5). It provides standardized extension points for custom services.
  2. **BIM Enrichment Layer**: Building Control Engineers model devices and control logic directly in BIM, extracting metadata for runtime configuration.
  3. **Runtime Interface Layer**: Handles real-time data exchange between physical assets and the DT, ensuring synchronization via middleware protocols.
  4. **Service Integration Layer**: Supports the deployment of custom services (e.g., adaptive lighting, predictive maintenance) by DT Engineers, enabling scalability and adaptability.
  5. **Orchestration Layer**: Manages the orchestration of DT services, ensuring seamless interaction between visualization, simulation, and control components."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the following lifecycle stages of the physical building:
  1. **Design Phase**: BIM models are enriched with BCS device configurations and control logic by Building Control Engineers, enabling the initial DT setup.
  2. **Construction Phase**: The DT is validated against the physical infrastructure, ensuring alignment between virtual and physical representations during installation.
  3. **Operation Phase**: The DT operates in real-time, providing continuous monitoring, simulation, and optimization of building performance (e.g., energy efficiency, occupant comfort). The framework supports **runtime evolution** via iterative updates to control policies (e.g., adaptive lighting) based on post-occupancy data.
  4. **Refurbishment/Adaptation**: The DT is extended or reconfigured to accommodate changes in physical infrastructure or operational requirements, leveraging standardized extension points for modular updates."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The fidelity and validity of the DT are ensured through:
  1. **Overall Digital Twin Entanglement (ODTE) Metric**: Measures the interoperability and architectural coherence between the physical and virtual models, evaluating their alignment in real-time.
  2. **Model Validation**: Cross-verification between BIM models and physical infrastructure during deployment to detect discrepancies.
  3. **Runtime Synchronization**: Continuous bidirectional data exchange via Eclipse Hono/Ditto ensures the DT accurately reflects physical conditions, mitigating semantic drift (e.g., alignment issues over time).
  4. **Uncertainty Management**: While not explicitly quantified, the framework emphasizes iterative refinement of control policies (e.g., adaptive lighting) based on post-occupancy sensor data to improve operational validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT technical connection relies on middleware platforms (Eclipse Hono and Ditto) for real-time data exchange, facilitating bidirectional communication between physical assets and the virtual model. The system does not specify protocols like MQTT or WebSockets explicitly, but emphasizes standardized integration frameworks for scalability and interoperability."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed via a model-driven pipeline that generates runtime artifacts from BIM models. Deployment is supported by Unreal Engine for visualization and a modular architecture with standardized extension points. The framework emphasizes automation and low-overhead updates, but does not specify centralized server or cloud infrastructure explicitly."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT integrates with external systems through standardized extension points, ensuring interoperability with BIM-based workflows and other AECO platforms. While BIM is the primary semantic backbone, the framework supports modular integration without explicit mention of IFC or COBIE standards."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework adheres to BIM as the primary standard for semantic modeling, leveraging model-driven engineering (MDE) principles for consistency. Eclipse Hono and Ditto are used for middleware integration, but no explicit mention of IFC or COBIE standards is provided in the documents."
]