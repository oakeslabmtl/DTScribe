// C2: Acting Components (none available, skipped)

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined as a BCS object in the IFC model, possessing an Instance General UUID and IFC type IFCTEMPERATURESENSOR publishes temperature telemetry over MQTT to Eclipse Hono."
    DTDFVocab:producedData TemperatureTelemetryPublished
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor defined as a BCS object in the IFC model, possessing an Instance General UUID and IFC type IFCHUMIDITYSENSOR publishes humidity telemetry over MQTT to Eclipse Hono."
    DTDFVocab:producedData HumidityTelemetryPublished
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined as a BCS object in the IFC model, possessing an Instance General UUID and IFC type IFCOCCUPANCYSENSOR publishes occupancy telemetry over MQTT to Eclipse Hono."
    DTDFVocab:producedData OccupancyTelemetryPublished
]

instance EquipmentStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Equipment status sensor defined as a BCS object in the IFC model, possessing an Instance General UUID and IFC type IFCEQUIPMENTSTATUS publishes equipment state telemetry over MQTT to Eclipse Hono."
    DTDFVocab:producedData EquipmentStatusTelemetryPublished
]

// C4: Physical-to-virtual interaction (data transmitted)
instance TemperatureTelemetryPublished : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityTelemetryPublished : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyTelemetryPublished : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EquipmentStatusTelemetryPublished : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EquipmentStatusSensor
]

// C5: Model/Data (runtime artefact)
instance BIMTransformationModel : DTDFVocab:Model [
    base:desc "Model representing the transformation of the enriched IFC into a runtime artefact via model checking, model-to-model translation, and one-click deployment."
    DTDFVocab:inputTo OneClickDeploymentEngine
]

// C5: Data (telemetry values)
instance TemperatureData : DTDFVocab:Data [
    base:desc "Current temperature value in degrees Celsius, validated for unit and range by Ditto."
    DTDFVocab:inputTo EclipseDittoBackend
    DTDFVocab:fromData TemperatureTelemetryPublished
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Current relative humidity percentage, validated for unit and range by Ditto."
    DTDFVocab:inputTo EclipseDittoBackend
    DTDFVocab:fromData HumidityTelemetryPublished
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy status flag (true/false), validated for unit and range by Ditto."
    DTDFVocab:inputTo EclipseDittoBackend
    DTDFVocab:fromData OccupancyTelemetryPublished
]

instance EquipmentStatusData : DTDFVocab:Data [
    base:desc "Equipment operational status code, validated for unit and range by Ditto."
    DTDFVocab:inputTo EclipseDittoBackend
    DTDFVocab:fromData EquipmentStatusTelemetryPublished
]

// C6: Services
instance DeploymentService : DTDFVocab:Service [
    base:desc "Service that deploys the digital twin stack, generating configuration files and starting the runtime stack."
    DTDFVocab:provides DeploymentSuccessInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service that provides real-time monitoring of building conditions via Ditto."
    DTDFVocab:provides RealTimeTelemetryInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service that performs predictive analytics for maintenance and energy optimization."
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Service that allows control commands to actuate HVAC and lighting systems through the twin interface."
    DTDFVocab:provides IssueControlCommandAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that exposes immersive 3D visualization of the twin via Unreal Engine 5."
    DTDFVocab:provides ImmersiveVisualizationInsight
]

// C7: Insights/Actions
instance DeploymentSuccessInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful deployment of the digital twin stack."
]

instance RealTimeTelemetryInsight : DTDFVocab:Insight [
    base:desc "Insight providing real-time telemetry of building conditions."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting predictive maintenance actions based on sensor data."
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the availability of an immersive 3D visualization."
]

instance IssueControlCommandAction : DTDFVocab:Action [
    base:desc "Action that issues a control command to an HVAC or lighting system."
    DTDFVocab:IsAutomatic false
]

// C10: Enablers
instance OneClickDeploymentEngine : DTDFVocab:Enabler [
    base:desc "Automated one-click deployment engine that generates configuration files and fires the build script to start the digital twin stack."
    DTDFVocab:enables DeploymentService
]

instance EclipseDittoBackend : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto backend that persists sensor telemetry, enforces policy-based validation, and publishes updates to the UE5 visualization client."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, ControlService
]

instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono edge gateway that receives MQTT telemetry from physical sensors and routes it to Ditto."
]

instance UnrealEngine5Visualizer : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 render pipeline that consumes Ditto updates and exposes the twin as an immersive 3D scene."
    DTDFVocab:enables VisualizationService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the UE5 UI and are sent as Ditto Thing API messages over a WebSocket to the Ditto broker. The command payloads include actuator instructions such as ON/OFF or numeric setpoints (e.g., temperature thresholds). Ditto forwards the command to the linked physical device via the Hono MQTT broker; the device subscribes to its command topic and executes the instruction. The device publishes a confirmation back through Hono, updates the twin state in Ditto, and the UE5 client waits for this acknowledgment before updating its visual representation. Authentication is performed by the underlying Ditto deployment using TLS client certificates, though specific credentials are not detailed in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin achieves real‑time synchronization by leveraging Eclipse Hono for device provisioning and Eclipse Ditto for data brokering. A 1‑second heartbeat mechanism coordinates state updates between the physical building and its twin. The deployment pipeline from an enriched BIM model takes 14.53 s, comprising 5.53 s for model checking, 8.7 s for model parsing, and 0.3 s for initialization. The Overall Digital Twin Entanglement (ODTE) measured over a 12‑minute window reports a timeliness score of 0.997 (indicating sub‑second delay in data propagation), with perfect reliability (1.0) and availability (1.0)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin system is orchestrated through a modular, model‑driven architecture. An enriched BIM model served as the source; the framework extracts structured representations and automatically generates deployable twin artifacts via model‑to‑model and model‑to‑text transformations (MDE). The central hub connects multiple components: BIM‑based device models from the Building Control Engineer, runtime twin entities maintained in Eclipse Ditto, data ingestion and routing via Eclipse Hono, and a configurable runtime environment for DT Engineers’ custom services. Resource management is handled by the hub, which coordinates provisioning of cloud resources, database access, and messaging queues. System‑wide coordination is achieved through standardized extension points that allow plugging of analytics services, visualization modules (e.g., UE5 rendering), and external control interfaces, all while preserving consistency between the design and operation stages."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design‑time BIM enrichment – Building Control Engineers use Autodesk Revit to model devices as custom families and property sets that include a globally unique identifier and an IFC type (e.g., IFCLIGHTFIXTURETYPE). The BIM model is exported to IFC and checked with a domain‑specific IFC model checker that verifies required metadata. Semantic model extraction transforms the enriched IFC into a domain‑specific representation that serves as a deployment planner. One‑click deployment automatically converts that representation into executable DT artifacts, configuring Eclipse Hono for bidirectional data flow and Eclipse Ditto for twin management. Runtime operation consists of continuous, real‑time data exchange, interactive visualization through Unreal Engine 5, and dynamic configuration management that allows interface updates and parameter tuning without redeployment. The lifecycle governance is anchored in the framework’s non‑functional requirements: interoperability across heterogeneous BIM tools and IoT protocols (NF 1), scalability from single components to whole infrastructure (NF 2), maintainability through low‑overhead updates (NF 3), and accessibility for users of varying expertise (NF 4)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "To achieve model fidelity, the framework performs rigorous model checking: a rule‑based validator checks for mandatory metadata (e.g., Instance General UUID) before any deployment step.  Transformation times – 5.53 s for model checking, 8.7 s for parsing, 0.3 s for startup – provide bounded latency.  Runtime fidelity is quantified by the Overall Digital Twin Entanglement (ODTE) metric, measured over a 12‑minute window with a 1‑second heartbeat.  The ODTE decomposes into timeliness (0.997 s), reliability (1.0), and availability (1.0), yielding a total score of 0.997, indicating that state changes in the physical twin are reflected in the digital twin within a negligible delay and with no message loss.  Error detection is handled by the Ditto policy engine, which rejects or flags out‑of‑range telemetry and prospective actuation commands.  Fault tolerance relies on Eclipse Hono’s at‑least‑once delivery and Ditto’s persistent event store, ensuring that transient network failures do not compromise data integrity or synchronization.  Uncertainty sources – network jitter, model‑to‑device‑density mismatches – are mitigated by policy validation and by the real‑time closed‑loop design of the Twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The network relies on standard protocols: MQTT for device‑to‑gateway traffic, HTTP for Hono/Ditto configuration and initial data transmission, and WebSocket (over TLS) for bidirectional command and telemetry between Ditto and UE5. Hono receives device telemetry and routes it to Ditto, which maintains the twin state and syncs it to the UE5 client via WebSocket. Hono and Ditto can be deployed on cloud or edge nodes; the architecture is designed for low‑latency real‑time updates (sub‑200 ms) and includes fault‑tolerant configuration through runtime management, although explicit bandwidth figures are not provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment is model‑driven and automated: a configurator parses the BIM model to generate artifacts for Eclipse Hono and Eclipse Ditto and issues an HTTP POST to seed the initial twin state in UE5. Hono and Ditto are typically containerized (e.g., Docker) on cloud or edge nodes, while UE5 runs locally or on a dedicated vector server for visualization. The modular architecture permits additional services to be added via extension points, and runtime configuration management allows for adjustments without full redeployment, supporting high availability. Specific cloud providers, hardware specs, or storage details are not specified in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The system integrates external systems by exposing standard‑based APIs and messaging interfaces via Eclipse Hono and Ditto, allowing bidirectional data exchange with IoT devices, building automation controllers, and enterprise applications. BIM tools (e.g., Revit) provide the initial static model, which is enriched and fed into the model‑driven transformer that outputs configurations for Hono/Ditto consumption. The architecture relies on industry‑standard protocols and open interfaces to achieve interoperability across heterogeneous platforms."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance is anchored in the adoption of industry standards: the BIM models use the IFC exchange format with IFC types and globally unique identifiers to uniquely identify devices; semantic integration follows the configured property sets and type hierarchy. Real‑time connectivity is achieved through middleware that conforms to IoT protocols, exemplified by Eclipse Hono (for reliable message ingestion) and Eclipse Ditto (for digital twin semantics), both of which implement standard messaging patterns. Interoperability across heterogeneous BIM tools, IoT platforms, and visualisation engines is mandated by the framework’s NF 1 requirement, ensuring that data schemas, protocols, and service interfaces adhere to shared specifications. Scalable deployment from individual devices to whole infrastructure is governed by NF 2, maintainability by NF 3, and user accessibility by NF 4. The modular architecture supports standardized extension points that align with open‑source service descriptions, enabling integration with external tools while preserving adherence to the same interoperability framework."
]