// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "\"Temperature sensor embedded in the building’s BIM\""
    DTDFVocab:producedData TemperatureSensorDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "\"Humidity sensor embedded in the building’s BIM\""
    DTDFVocab:producedData HumiditySensorDataTransmitted
]

instance PhotometricSensor : DTDFVocab:SensingComponent [
    base:desc "\"Photometric sensor (light level) embedded in the building’s BIM\""
    DTDFVocab:producedData PhotometricSensorDataTransmitted
]

instance MotionDetector : DTDFVocab:SensingComponent [
    base:desc "\"Motion/occupancy detector embedded in the building’s BIM\""
    DTDFVocab:producedData MotionDetectorDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "\"Light level sensor embedded in the building’s BIM\""
    DTDFVocab:producedData LightLevelSensorDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumiditySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance PhotometricSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhotometricSensor
]

instance MotionDetectorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionDetector
]

instance LightLevelSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

// C10: Models/Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "\"Temperature data stream collected from the TemperatureSensor\""
    DTDFVocab:inputTo EclipseHonoMiddleware, DittoPlatform
    DTDFVocab:fromData TemperatureSensorDataTransmitted
]

instance HumidityData : DTDFVocab:Data [
    base:desc "\"Humidity data stream collected from the HumiditySensor\""
    DTDFVocab:inputTo EclipseHonoMiddleware, DittoPlatform
    DTDFVocab:fromData HumiditySensorDataTransmitted
]

instance PhotometricData : DTDFVocab:Data [
    base:desc "\"Photometric data stream collected from the PhotometricSensor\""
    DTDFVocab:inputTo EclipseHonoMiddleware, DittoPlatform
    DTDFVocab:fromData PhotometricSensorDataTransmitted
]

instance MotionData : DTDFVocab:Data [
    base:desc "\"Occupancy data stream collected from the MotionDetector\""
    DTDFVocab:inputTo EclipseHonoMiddleware, DittoPlatform
    DTDFVocab:fromData MotionDetectorDataTransmitted
]

instance LightLevelData : DTDFVocab:Data [
    base:desc "\"Light level data stream collected from the LightLevelSensor\""
    DTDFVocab:inputTo EclipseHonoMiddleware, DittoPlatform
    DTDFVocab:fromData LightLevelSensorDataTransmitted
]

instance BIMRepresentationModel : DTDFVocab:Model [
    base:desc "\"BIM representation of the academic building using IFC schema\""
    DTDFVocab:inputTo BIMAuthoringTool
]

instance RuntimeDeviceModel : DTDFVocab:Model [
    base:desc "\"Runtime device models generated via MDE transformations\""
    DTDFVocab:inputTo MDETransformationEngine
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "\"Control logic models for lighting, HVAC, and shading\""
    DTDFVocab:inputTo MDETransformationEngine
]

instance SensorDataStreamModel : DTDFVocab:Model [
    base:desc "\"Model representing the sensor data streams into the Twin\""
    DTDFVocab:inputTo EclipseHonoMiddleware
]

instance VisualizationAssetModel : DTDFVocab:Model [
    base:desc "\"3D visualization assets imported into Unreal Engine\""
    DTDFVocab:inputTo UnrealEngineVisualization
]

// C17: Insights/Actions
instance EnergyConsumptionOptimizationInsight : DTDFVocab:Insight [
    base:desc "\"Optimization results for building energy consumption\""
]

instance LightingScheduleOptimizationInsight : DTDFVocab:Insight [
    base:desc "\"Optimization results for lighting schedules\""
]

instance ControlPolicyUpdateInsight : DTDFVocab:Insight [
    base:desc "\"Updates to control policies based on runtime analytics\""
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "\"Results from simulation of design scenarios\""
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "\"Immersive 3D visualization rendered in Unreal Engine\""
]

instance MonitoringDashboardInsight : DTDFVocab:Insight [
    base:desc "\"Real‑time monitoring dashboard insights\""
]

instance LightingActuationAction : DTDFVocab:Action [
    base:desc "\"Action to adjust dimmable LED fixtures\""
    DTDFVocab:IsAutomatic true
]

instance HVACActuationAction : DTDFVocab:Action [
    base:desc "\"Action to adjust HVAC settings\""
    DTDFVocab:IsAutomatic true
]

instance ShadingActuationAction : DTDFVocab:Action [
    base:desc "\"Action to control shading actuators\""
    DTDFVocab:IsAutomatic true
]

// C11: Enablers
instance MDETransformationEngine : DTDFVocab:Enabler [
    base:desc "\"Model‑driven transformation engine for generating runtime artifacts\""
    DTDFVocab:enables RuntimeDeviceModel, ControlLogicModel
]

instance EclipseHonoMiddleware : DTDFVocab:Enabler [
    base:desc "\"Eclipse Hono middleware for real‑time sensor data streams\""
    DTDFVocab:enables SensorDataStreamModel
]

instance DittoPlatform : DTDFVocab:Enabler [
    base:desc "\"Eclipse Ditto digital twin platform for live synchronization\""
    DTDFVocab:enables RealTimeMonitoringDashboardService, PredictiveAnalyticsEnergyService,
                      RLLightingOptimisationService, DesignScenarioSimulationService,
                      UnrealVisualizationService
]

instance BIMAuthoringTool : DTDFVocab:Enabler [
    base:desc "\"BIM authoring tool (e.g., Autodesk Revit) enriched with device metadata\""
    DTDFVocab:enables BIMRepresentationModel
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "\"Unreal Engine 5 for immersive 3D visualization\""
    DTDFVocab:enables VisualizationAssetModel
]

// C6: Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "\"Real‑time monitoring dashboards displaying live sensor feeds\""
    DTDFVocab:provides MonitoringDashboardInsight
]

instance PredictiveAnalyticsEnergyService : DTDFVocab:Service [
    base:desc "\"Predictive analytics for building energy use\""
    DTDFVocab:provides EnergyConsumptionOptimizationInsight, ControlPolicyUpdateInsight
]

instance RLLightingOptimisationService : DTDFVocab:Service [
    base:desc "\"Reinforcement‑learning based lighting optimisation\""
    DTDFVocab:provides LightingScheduleOptimizationInsight, LightingActuationAction
]

instance DesignScenarioSimulationService : DTDFVocab:Service [
    base:desc "\"Simulation of design scenarios for building performance\""
    DTDFVocab:provides SimulationResultInsight
]

instance UnrealVisualizationService : DTDFVocab:Service [
    base:desc "\"Immersive 3D visualization rendered in Unreal Engine\""
    DTDFVocab:provides ImmersiveVisualizationInsight
]

// C1: Physical acting components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "\"Dimmable LED fixture actuator integrated into the BMS\""
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "\"HVAC actuator integrated into the BMS\""
]

instance ShadingActuator : DTDFVocab:ActingComponent [
    base:desc "\"Shading actuator integrated into the BMS\""
]

// C17: Components hierarchy
instance BuildingTwin : DTDFVocab:Component [
    base:desc "\"Hierarchical digital twin of the academic building, aggregating device-level twins\""
]

instance AcademicBuildingEnvironment : DTDFVocab:Environment [
    base:contains BuildingTwin, LightingActuator, HVACActuator, ShadingActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin’s optimization and decision services are transmitted back to the building automation system through Eclipse Hono/Ditto, closing the loop and actuating the corresponding physical devices."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real‑time data ingestion and control with event rates typically within seconds, supported by Eclipse Hono’s high‑throughput message broker, enabling real‑time or sub‑second synchronization between PT and DT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellation consists of a central application orchestrating device twins, middleware for message routing, and graphical engines; all components are connected through defined interfaces and extension points to enable modular service integration."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin covers the design, construction (fabrication), and operation phases of the building; however, runtime semantic extraction is performed on BIM models of the designed building and updated during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Alignment between the virtual and physical assets is quantified using the Overall Digital Twin Entanglement (ODTE) metric; runtime validation is performed by continuous streaming of sensor data and periodic conformance checks against the BIM model."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses the Eclipse Hono message broker supporting MQTT, HTTP, and AMQP protocols, with data serialized in JSON and vertices communicated via Ditto’s RESTful API."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The framework is designed to exchange information with external building automation systems, sensor networks, and potentially other Digital Twins via the standardized middleware interfaces provided by Eclipse Hono and Ditto."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The development follows BIM standards (IFC), ISO 19650 for information management, and uses open‑source middleware (Hono, Ditto) that adhere to MQTT/AMQP standards; model‑driven transformations are guided by domain‑specific metamodels."
]