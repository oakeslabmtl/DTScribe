]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D/4D modeling and documentation generation providing immersive, interactive visualizations of building models and automated project documentation."
    DTDFVocab:provides SpatialVisualizationInsight, DocumentationGenerationAction
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Lifecycle forecasting enabling predictive maintenance and operational planning through AI-driven analytics integrated with DT frameworks."
    DTDFVocab:provides PredictiveMaintenanceInsight, LifecycleForecastingAction
]

// C17: Insights/Actions
instance LiveSynchronizationInsight : DTDFVocab:Insight [
    base:desc "Real-time bidirectional data exchange between physical assets and digital twins ensuring sub-second latency for critical parameters."
]

instance OperationalControlAction : DTDFVocab:Action [
    base:desc "Remote observation and management of physical assets through digital twins with standardized extension points for actuation."
    DTDFVocab:IsAutomatic true
]

instance PerformanceSimulationInsight : DTDFVocab:Insight [
    base:desc "Structured performance analysis of building systems using semantically enriched BIM models to identify optimization opportunities."
]

instance ClashDetectionInsight : DTDFVocab:Insight [
    base:desc "Early detection of design conflicts and inefficiencies through collaborative modeling and automated clash analysis."
]

instance ModelDrivenAutomationAction : DTDFVocab:Action [
    base:desc "Automated deployment and operational control of digital twins reducing manual intervention through MDE transformations."
    DTDFVocab:IsAutomatic true
]

instance DomainSpecificEngineeringInsight : DTDFVocab:Insight [
    base:desc "Scalable service-oriented development tailored to AECO requirements with modular architecture supporting extensibility."
]

instance SpatialVisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive 3D/4D visualizations of building models enabling spatial and temporal data exploration for all AECO stakeholders."
]

instance DocumentationGenerationAction : DTDFVocab:Action [
    base:desc "Automated creation of project documentation including as-built models and compliance reports from BIM data."
    DTDFVocab:IsAutomatic true
]

