// C2: Acting Components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Directly integrated into BIM models to represent physical HVAC devices controlled via DT-generated behavioral models and automated deployment of control logic from BIM-based behavioral models."
]

instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Modelled within BIM environment to represent motorized lighting systems with configurable actuation ranges and safety constraints validated through MDE transformations."
]

instance MotorizedShadeActuator : DTDFVocab:ActingComponent [
    base:desc "Configured in BIM with semantic labeling for precise addressing via DT framework, supporting remote operation through standardized extension points."
]

// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Building Control System sensor parameterized in BIM models with ±0.5°C precision, dynamically calibrated via real-time data validation against DT analytical models."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "BCS sensor configured in BIM with spatial distribution mapped to building layouts, supporting real-time synchronization with DT framework."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Parameterized in BIM models with configurable sampling frequencies, providing occupancy data for operational control and space utilization analysis."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance StructuralStressSensor : DTDFVocab:SensingComponent [
    base:desc "High-precision sensor integrated with BIM for structural monitoring, transmitting real-time data with sub-second latency requirements."
    DTDFVocab:producedData StructuralDataTransmitted
]

instance EnergyConsumptionMeter : DTDFVocab:SensingComponent [
    base:desc "Energy meter configured in BIM with ±X% accuracy specification, supporting dynamic calibration through DT framework analytics."
    DTDFVocab:producedData EnergyDataTransmitted
]

instance HVACPerformanceSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring HVAC system performance metrics with real-time validation against BIM-defined asset schemas for semantic consistency."
    DTDFVocab:producedData HVACPerformanceDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance StructuralDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralStressSensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionMeter
]

instance HVACPerformanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACPerformanceSensor
]

// C10: Models/Data
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Semantically rich, object-based 3D model representing static building structures and spatial configurations derived from BIM, serving as foundational data source for DT."
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance BIMBehavioralModel : DTDFVocab:Model [
    base:desc "Dynamic control logic representation encapsulating BCS components (sensors, actuators, controllers) defined by Building Control Engineers within BIM environment."
    DTDFVocab:inputTo ModelDrivenAutomationFramework
]

instance BIMAnalyticalModel : DTDFVocab:Model [
    base:desc "Automated transformation of enriched BIM models into deployable DT artifacts (simulation models, control algorithms) using MDE techniques."
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature measurements with ±0.5°C precision, validated against BIM-defined schemas and used for environmental control and predictive maintenance."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity measurements with spatial distribution mapped to building layouts, supporting indoor air quality analysis and HVAC optimization."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy patterns with configurable sampling frequencies, enabling space utilization optimization and predictive maintenance scheduling."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance StructuralData : DTDFVocab:Data [
    base:desc "Structural stress measurements with sub-second latency requirements, used for safety monitoring and predictive failure analysis."
    DTDFVocab:fromData StructuralDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance EnergyData : DTDFVocab:Data [
    base:desc "Energy consumption metrics with ±X% accuracy, supporting lifecycle cost modeling and sustainability analysis."
    DTDFVocab:fromData EnergyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance HVACPerformanceData : DTDFVocab:Data [
    base:desc "Performance metrics for HVAC systems validated against BIM schemas, enabling energy optimization and operational efficiency improvements."
    DTDFVocab:fromData HVACPerformanceDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Real-time data integration platform enabling live synchronization between physical assets and digital twins by handling IoT data ingestion and management via MQTT protocol."
    DTDFVocab:enables RealTimeMonitoringService, ControlService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Unified platform for managing digital twin data models and ensuring consistency between physical and digital representations through standardized extension points."
    DTDFVocab:enables RealTimeMonitoringService, OptimizationService, VisualizationService
]

instance ModelDrivenAutomationFramework : DTDFVocab:Enabler [
    base:desc "Automates DT deployment in BIM-based projects using Design Science Research methodology, reducing manual intervention and ensuring reproducibility."
    DTDFVocab:enables ControlService, PredictionService
]

instance ModularArchitectureEnabler : DTDFVocab:Enabler [
    base:desc "Service-oriented development framework with defined extension points for AECO-specific applications, enabling scalable DT engineering."
    DTDFVocab:enables RealTimeMonitoringService, OptimizationService
]

instance BIMEnabler : DTDFVocab:Enabler [
    base:desc "Core modeling paradigm providing semantically rich, object-based 3D models for entire building lifecycle with geometric, spatial, and functional data integration."
    DTDFVocab:enables VisualizationService, ControlService
]

instance DesignScienceResearchEnabler : DTDFVocab:Enabler [
    base:desc "Research methodology guiding development of artifacts (frameworks, tools) to address design science problems in DT deployment within BIM-based projects."
    DTDFVocab:enables ModelDrivenAutomationFramework
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous data integration between physical assets and digital twins ensuring real-time updates for operational control and live synchronization."
    DTDFVocab:provides LiveSynchronizationInsight, OperationalControlAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Performance analysis and optimization of building systems using semantically rich models to identify energy efficiency opportunities and design conflicts."
    DTDFVocab:provides PerformanceSimulationInsight, ClashDetectionInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Model-driven automation framework automating deployment and operational control of digital twins with domain-specific engineering capabilities."
