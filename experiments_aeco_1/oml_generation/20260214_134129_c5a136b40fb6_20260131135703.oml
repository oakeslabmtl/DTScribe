// C2: Acting Components
instance LightingControlUnitActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator device representing the building's lighting control unit modeled within BIM."
]

instance HVACControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator device representing the building's HVAC controller modeled within BIM."
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor device modeled in BIM that captures occupancy data."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor device modeled in BIM that captures temperature data."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor device modeled in BIM that captures humidity data."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance PostOccupancyPerformanceSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor device modeled in BIM that captures post‑occupancy performance metrics."
    DTDFVocab:producedData PerformanceDataTransmitted
]

// C4: Physical-to-virtual interaction
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance PerformanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PostOccupancyPerformanceSensor
]

// Data instances
instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy sensor data forwarded to the Digital Twin."
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler, UnrealEngine5Enabler
    DTDFVocab:fromData OccupancyDataTransmitted
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature sensor data forwarded to the Digital Twin."
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler, UnrealEngine5Enabler
    DTDFVocab:fromData TemperatureDataTransmitted
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Real‑time humidity sensor data forwarded to the Digital Twin."
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler, UnrealEngine5Enabler
    DTDFVocab:fromData HumidityDataTransmitted
]

instance PerformanceData : DTDFVocab:Data [
    base:desc "Real‑time post‑occupancy performance metrics forwarded to the Digital Twin."
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler, UnrealEngine5Enabler
    DTDFVocab:fromData PerformanceDataTransmitted
]

// C10: Models/Data
instance BIMIFCModel : DTDFVocab:Model [
    base:desc "BIM IFC model serving as the structural and asset foundation for the living lab building."
    DTDFVocab:inputTo MDEToolingEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides the data exchange backbone, receiving telemetry from physical devices."
    DTDFVocab:enables RealTimeMonitoringDashboardService, PredictiveAnalyticsService, LightingControlOptimizationService, ExternalAPIService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital twin entities and facilitates bi‑directional communication."
    DTDFVocab:enables RealTimeMonitoringDashboardService, PredictiveAnalyticsService, LightingControlOptimizationService, ExternalAPIService, ScenarioSimulationService, AutomatedReportingService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 provides interactive visualization and scenario simulation capabilities."
    DTDFVocab:enables RealTimeMonitoringDashboardService, ScenarioSimulationService, AutomatedReportingService
]

instance MDEToolingEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering tooling automates the generation of runtime artifacts from the BIM model."
    DTDFVocab:enables RuntimeArtifactGenerationService
]

// C6: Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards powered by Unreal Engine 5 provide live visualisation of building metrics."
    DTDFVocab:provides EnergyEfficiencyInsight, AdjustSetpointAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics compute energy‑efficiency and comfort optimization insights from telemetry."
    DTDFVocab:provides ComfortOptimizationInsight
]

instance LightingControlOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based lighting control optimises adaptive lighting strategies."
    DTDFVocab:provides AdaptiveLightingInsight
]

instance ScenarioSimulationService : DTDFVocab:Service [
    base:desc "Scenario simulation allows virtual testing of control strategies within Unreal Engine 5."
    DTDFVocab:provides SimulateScenarioAction
]

instance AutomatedReportingService : DTDFVocab:Service [
    base:desc "Automated reporting generates analysis reports for facility managers."
    DTDFVocab:provides GenerateReportAction
]

instance ExternalAPIService : DTDFVocab:Service [
    base:desc "External API service accepts control directives and queries from third‑party applications."
    DTDFVocab:provides SubmitControlDirectiveAction
]

instance RuntimeArtifactGenerationService : DTDFVocab:Service [
    base:desc "Service that generates runtime artifacts from the BIM model via MDE tooling."
    DTDFVocab:provides GenerateRuntimeArtifactsAction
]

// C17: Insights/Actions
instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time energy efficiency analytics."
]

instance ComfortOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight offering predictive comfort optimisation based on current sensor data."
]

instance AdaptiveLightingInsight : DTDFVocab:Insight [
    base:desc "Insight presenting adaptive lighting strategies suggested by reinforcement learning."
]

instance AdjustSetpointAction : DTDFVocab:Action [
    base:desc "Facility manager action to adjust HVAC or lighting set‑points."
    DTDFVocab:IsAutomatic false
]

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Automated production of environment and performance reports."
    DTDFVocab:IsAutomatic true
]

instance SimulateScenarioAction : DTDFVocab:Action [
    base:desc "Action to trigger a virtual scenario simulation."
    DTDFVocab:IsAutomatic false
]

instance GenerateRuntimeArtifactsAction : DTDFVocab:Action [
    base:desc "Action to generate runtime artifacts from the BIM model."
    DTDFVocab:IsAutomatic true
]

instance SubmitControlDirectiveAction : DTDFVocab:Action [
    base:desc "Action to submit control directives to physical devices via the API."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated in the Twin are routed back to the physical building automation system through Ditto/Hono, enabling bidirectional communication and real‑time actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All interactions (data ingestion, command dispatch, simulation updates) are performed in real time, with the Twin continuously synchronised to the physical building as changes occur."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system comprises a centralized Ditto hub that hosts individual device twins, a Hono bootstrapper that configures device endpoints, and an Unreal Engine frontend that connects to the Ditto API to visualise the Twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin operates in the operational lifecycle stage of the building, providing continuous monitoring and optimization. It incorporates runtime configuration management that supports ad‑hoc updates from the design‑to‑manufacture stages encapsulated in the BIM model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is quantified using the Overall Digital Twin Entanglement (ODTE) metric, which compares the virtual representation against the physical measurements. Validation occurs through continuous telemetry comparison and model‑driven consistency checks defined in the MDE pipeline."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Twin communicates with physical devices through Eclipse Hono and Ditto; device metadata (tenant ID, device ID, endpoint addresses) is stored in the Tenants registry used by the Hono/Ditto configuration pipeline."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM (IFC) is used as the primary semantic standard for modeling building elements; Eclipse Ditto follows established IoT Device Twin specifications."
]