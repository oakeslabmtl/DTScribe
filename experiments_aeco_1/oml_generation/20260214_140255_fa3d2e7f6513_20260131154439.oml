// C3: Physical Sensing Components
instance StructuralStressSensor : DTDFVocab:SensingComponent [
    base:desc "Aggregates real-time structural stress data from critical infrastructure components to enable anomaly detection and threshold-based alerts."
    DTDFVocab:producedData StructuralStressDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors energy consumption spikes across building systems to support predictive analytics and optimization services."
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

instance EnvironmentalConditionSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real-time environmental data (temperature, humidity, air quality) for live dashboard visualization and operational optimization."
    DTDFVocab:producedData EnvironmentalConditionDataTransmitted
]

instance EquipmentPerformanceSensor : DTDFVocab:SensingComponent [
    base:desc "Tracks equipment performance metrics (e.g., HVAC, lighting systems) to enable predictive maintenance and lifecycle cost optimization."
    DTDFVocab:producedData EquipmentPerformanceDataTransmitted
]

instance OccupancyPatternSensor : DTDFVocab:SensingComponent [
    base:desc "Captures occupancy behavior data for adaptive refurbishment planning and energy efficiency trend analysis."
    DTDFVocab:producedData OccupancyPatternDataTransmitted
]

instance CarbonFootprintSensor : DTDFVocab:SensingComponent [
    base:desc "Measures real-time carbon emissions data for sustainability reporting and regulatory compliance tracking."
    DTDFVocab:producedData CarbonFootprintDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance StructuralStressDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralStressSensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance EnvironmentalConditionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalConditionSensor
]

instance EquipmentPerformanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EquipmentPerformanceSensor
]

instance OccupancyPatternDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyPatternSensor
]

instance CarbonFootprintDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CarbonFootprintSensor
]

instance HistoricalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor, EquipmentPerformanceSensor, OccupancyPatternSensor
]

// C10: Models/Data
instance BimEnrichedModel : DTDFVocab:Model [
    base:desc "Standardized IFC or COBie format model representing static building assets with semantic enrichment for Digital Twin integration."
    DTDFVocab:inputTo DataFusionPlatform, PhysicsBasedSimulationEngine
]

instance HistoricalDataRepository : DTDFVocab:Data [
    base:desc "Aggregated historical operational data used for predictive analytics and trend analysis across building lifecycle."
    DTDFVocab:fromData HistoricalDataTransmitted
    DTDFVocab:inputTo PredictiveAnalyticsService, LifecycleCostOptimizationService
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "High-frequency sensor telemetry and environmental metrics synchronized between physical and digital domains."
    DTDFVocab:fromData StructuralStressDataTransmitted, EnergyConsumptionDataTransmitted, EnvironmentalConditionDataTransmitted, EquipmentPerformanceDataTransmitted, OccupancyPatternDataTransmitted, CarbonFootprintDataTransmitted
    DTDFVocab:inputTo EdgeComputingNode, TimeSeriesDatabase
]

instance SensorTelemetryData : DTDFVocab:Data [
    base:desc "Structured sensor data extracted from BIM-enriched models for real-time monitoring and control."
    DTDFVocab:fromData StructuralStressDataTransmitted, EnergyConsumptionDataTransmitted, EnvironmentalConditionDataTransmitted, EquipmentPerformanceDataTransmitted, OccupancyPatternDataTransmitted, CarbonFootprintDataTransmitted
    DTDFVocab:inputTo EdgeComputingNode
]

// C11: Enablers
instance DataFusionPlatform : DTDFVocab:Enabler [
    base:desc "Apache Kafka-based platform for integrating heterogeneous data sources (legacy systems, IoT telemetry) into unified data streams."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance PhysicsBasedSimulationEngine : DTDFVocab:Enabler [
    base:desc "ANSYS/OpenFOAM-based simulation engine for structural, thermal, and fluid dynamics analysis in virtual environments."
    DTDFVocab:enables DesignValidationService, DisasterResilienceTestingService
]

instance EdgeComputingNode : DTDFVocab:Enabler [
    base:desc "AWS IoT Greengrass/Azure IoT Edge deployment for low-latency processing of sensor data at the network edge."
    DTDFVocab:enables OperationalOptimizationService, RealTimeAlertService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "InfluxDB/TimescaleDB storage for high-frequency operational data with time-series query capabilities."
    DTDFVocab:enables PredictiveMaintenanceService, EnergyEfficiencyTrendAnalysisService
]

instance AiMlPredictiveEngine : DTDFVocab:Enabler [
    base:desc "TensorFlow/PyTorch-based engine for supervised/unsupervised learning in anomaly detection and predictive maintenance."
    DTDFVocab:enables PredictiveMaintenanceService, WhatIfScenarioAnalysisService
]

instance ReinforcementLearningController : DTDFVocab:Enabler [
    base:desc "RL-based controller for dynamic optimization of building systems (e.g., HVAC, lighting) using model-predictive control."
    DTDFVocab:enables OperationalOptimizationService
]

instance ThreeDimensionalVisualizationEngine : DTDFVocab:Enabler [
    base:desc "Autodesk Revit/Bentley MicroStation integration for interactive 3D/4D visualizations with real-time data overlays."
    DTDFVocab:enables DesignValidationService, FacilityManagementDashboardService
]

instance WebBasedDashboardFramework : DTDFVocab:Enabler [
    base:desc "Tableau/Power BI integration for KPI visualization and stakeholder reporting across AECO lifecycle."
    DTDFVocab:enables RegulatoryComplianceTrackingService, CarbonFootprintReportingService
]

instance OpcUaCommunicationGateway : DTDFVocab:Enabler [
    base:desc "OPC UA/MQTT-based middleware for machine-to-machine communication between IoT devices and Digital Twin framework."
    DTDFVocab:enables RealTimeDataSynchronizationService, DeviceControlService
]

instance SemanticKnowledgeGraph : DTDFVocab:Enabler [
    base:desc "OWL/RDF ontology-based knowledge graph for semantic integration of fragmented models and data."
    DTDFVocab:enables DataConsistencyValidationService, CrossDomainQueryService
]

instance HybridCloudInfrastructure : DTDFVocab:Enabler [
    base:desc "AWS Outposts/Azure Stack deployment balancing on-premise data sovereignty with scalable cloud processing."
    DTDFVocab:enables DigitalThreadService, ImmutableAuditLoggingService
]

instance ContainerizedServiceOrchestrator : DTDFVocab:Enabler [
    base:desc "Docker/Kubernetes-based orchestrator for modular Digital Twin service deployment and lifecycle management."
    DTDFVocab:enables ServiceExtensionService, RuntimeConfigurationService
]

