// Sensing Components
instance LightingIntensitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring ambient light intensity to support photometric-based lighting control in the office building."
    DTDFVocab:producedData LightingIntensityDataTransmitted
]

instance HVACTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the HVAC system to monitor indoor climate conditions."
    DTDFVocab:producedData HVACTemperatureDataTransmitted
]

// Data Transmission
instance LightingIntensityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingIntensitySensor
]

instance HVACTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACTemperatureSensor
]

// Data
instance LightingIntensityData : DTDFVocab:Data [
    base:desc "Ambient light intensity values captured by the LightingIntensitySensor, used for adaptive lighting decisions."
    DTDFVocab:fromData LightingIntensityDataTransmitted
    DTDFVocab:inputTo DittoDataStoreEnabler
]

instance HVACTemperatureData : DTDFVocab:Data [
    base:desc "Indoor temperature readings from the HVAC system, used for thermal management and predictive analytics."
    DTDFVocab:fromData HVACTemperatureDataTransmitted
    DTDFVocab:inputTo DittoDataStoreEnabler
]

// Models
instance GeometricTwinModel : DTDFVocab:Model [
    base:desc "Geometric representation of the office building derived from the enriched BIM model."
    DTDFVocab:inputTo DittoDataStoreEnabler
]

instance BehaviouralTwinModel : DTDFVocab:Model [
    base:desc "Behavioural model encoding control logic via custom twin components such as the LightTwinComponent."
    DTDFVocab:inputTo DittoDataStoreEnabler
]

instance AnalyticalTwinModel : DTDFVocab:Model [
    base:desc "Analytical model capturing photometric data for lighting control and predictive analytics."
    DTDFVocab:inputTo DittoDataStoreEnabler
]

// Enablers
instance DittoDataStoreEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto component that persistently stores and synchronises twin state with the physical building infrastructure."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, OptimizationService, DirectControlService, ImmersiveVisualizationService
]

// Acting Component
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Actuator component representing a lighting fixture capable of controlling power (on/off), brightness, and colour temperature (in Kelvin) via the LightTwinComponent."
    DTDFVocab:provides SetLightingPowerAction, ControlLightBrightnessAction
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing live monitoring of building subsystems such as HVAC and lighting."
    DTDFVocab:provides LightingStatusInsight, HVACTemperatureInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service delivering predictive analytics for energy consumption and fault detection."
    DTDFVocab:provides EnergyConsumptionPredictionInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that calculates optimization routines balancing comfort and cost."
    DTDFVocab:provides HVACOptimizationInsight, LightingOptimizationInsight
]

instance DirectControlService : DTDFVocab:Service [
    base:desc "Service enabling remote control over HVAC and lighting actuators via Ditto."
    DTDFVocab:provides SetLightingPowerAction, OptimizeHVACAction, ControlLightBrightnessAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Service offering visual dashboards for facility managers through Unreal Engine 5."
    DTDFVocab:provides VisualizationDashboardInsight
]

// Insights
instance LightingStatusInsight : DTDFVocab:Insight [
    base:desc "Insight summarising current lighting system status (power state, brightness levels, colour temperature)."
]

instance HVACTemperatureInsight : DTDFVocab:Insight [
    base:desc "Insight summarising current HVAC temperature readings and setpoints."
]

instance EnergyConsumptionPredictionInsight : DTDFVocab:Insight [
    base:desc "Insight presenting forecasted energy demand for the building’s lighting and HVAC systems."
]

instance HVACOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight outlining recommended HVAC setpoints based on optimization of comfort and energy cost."
]

instance LightingOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing recommended lighting adjustments for optimal energy use and occupant comfort."
]

instance VisualizationDashboardInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time 3D visualizations of building state for facility managers."
]

// Actions
instance SetLightingPowerAction : DTDFVocab:Action [
    base:desc "Action to toggle the power state of a lighting fixture via a Ditto command."
    DTDFVocab:IsAutomatic false
]

instance ControlLightBrightnessAction : DTDFVocab:Action [
    base:desc "Action to adjust the brightness level of a lighting fixture."
    DTDFVocab:IsAutomatic false
]

instance OptimizeHVACAction : DTDFVocab:Action [
    base:desc "Automatic action to apply optimized HVAC setpoints derived from the OptimizationService."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design and BIM enrichment: building control engineers model devices, sensors, actuators, and controllers directly within BIM, creating an object‑based 3D model enriched with functional attributes (BCS components). Transformation step: an MDE engine extracts structured representations from the enriched BIM and automatically generates deployable DT artifacts, minimizing manual intervention. Deployment stage: an automated deployment process (R2) produces reproducible DT setups, provisioning service instances and configuration files. Runtime operation: real‑time data exchange via Eclipse Hono (IoT messaging) and Eclipse Ditto (asset registry) keeps the DT synchronized with physical assets. Evolution and governance: a modular architecture (R4) defines extension points that allow adding custom services and analysis plugins, enabling a service‑oriented evolution. The entire process is governed by semantic integration, real‑time connectivity, and extensibility requirements."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin’s fidelity is ensured through multiple layers of validation.  Eclipse Ditto’s policy engine continuously checks sensor values against declared units and range constraints, rejecting invalid data to maintain consistency.  Pre‑execution validation for actuator commands guarantees that commands do not conflict with physical constraints.  Fault tolerance is provided by Eclipse Hono’s at‑least‑once delivery guarantee and Ditto’s persistent event storage, ensuring resilience against network failures.  Synchronisation quality is quantified by the Overall Digital Twin Entanglement (ODTE) metric, calculated as the product of timeliness (0.997 over a 12‑minute window, measured with a 1‑second heartbeat), reliability (1.0, no lost messages), and availability (1.0, full uptime), yielding an overall score of 0.997.  These metrics, combined with policy‑based validation and pre‑execution checks, serve as the primary quality assurance processes for models and data, ensuring a high‑fidelity relationship between the digital and physical systems."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Configured around a message‑oriented middleware stack that combines Eclipse Hono as the connectivity broker and Eclipse Ditto as the device twin abstraction layer. The architecture enables real‑time, bi‑directional communication between edge devices (building controls) and the central server, supporting scalability through modular extension points. Specific details about protocol versions, bandwidth, latency, redundancy, and security mechanisms are not specified in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The framework is designed for model‑driven deployment that allows automated installation and configuration across a range of hosting environments, from on‑premise servers to cloud or edge platforms. It incorporates runtime configuration management for dynamic adjustment, and a modular architecture encourages deployment of custom services. Exact computational, storage, and scalability requirements, as well as deployment models and availability guarantees, are not detailed in the documents."
]