// C3: Physical sensing components
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor configured in the BIM model for real‑time streaming of light levels."
    DTDFVocab:producedData IlluminationDataStream
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector configured in the BIM model for real‑time streaming of occupancy status."
    DTDFVocab:producedData OccupancyDataStream
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance IlluminationDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

// C10: Models/Data (derived Data from streams)
instance IlluminationData : DTDFVocab:Data [
    base:desc "Processed illumination readings derived from the live sensor stream."
    DTDFVocab:fromData IlluminationDataStream
    DTDFVocab:inputTo EclipseDittoThingStore
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Processed occupancy status derived from the live detector stream."
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo EclipseDittoThingStore
]

// C11: Enablers (tooling and enablers)
instance EclipseHonoConnector : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides MQTT/HTTP connectivity for streaming sensor data."
    DTDFVocab:enables EclipseDittoThingStore
]

instance EclipseDittoThingStore : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto stores digital twins (things) and synchronises model updates."
    DTDFVocab:enables RealTimeMonitoringDashboard,
                     UnrealEngine5VisualizationService,
                     PredictiveAnalyticsSimulation,
                     EnergyOptimizationService,
                     ReinforcementLearningLightingControl,
                     FacilityManagerTaskPlanning
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders the 3‑D interactive visualization of the building twin."
    DTDFVocab:enables UnrealEngine5VisualizationService
]

// C6: Services (dt_services)
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Provides facility managers with real‑time status dashboards."
    DTDFVocab:provides RealTimeStatusInsight
]

instance UnrealEngine5VisualizationService : DTDFVocab:Service [
    base:desc "Delivers immersive 3‑D interactive visualization of the digital twin."
    DTDFVocab:provides RealTimeStatusInsight
]

instance PredictiveAnalyticsSimulation : DTDFVocab:Service [
    base:desc "Runs simulation and predictive analytics on building performance."
    DTDFVocab:provides PredictivePerformanceAnalyticsInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Computes energy‑optimization recommendations for lighting and HVAC."
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance ReinforcementLearningLightingControl : DTDFVocab:Service [
    base:desc "Applies reinforcement‑learning policies to adjust illumination levels."
    DTDFVocab:provides ReinforcementLearningPolicyUpdateAction
]

instance FacilityManagerTaskPlanning : DTDFVocab:Service [
    base:desc "Supports task planning for facility managers based on twin insights."
    DTDFVocab:provides OptimizationRecommendationInsight
]

// C17: Insights
instance RealTimeStatusInsight : DTDFVocab:Insight [
    base:desc "Real‑time status of lighting and occupancy generated from live sensor data."
]

instance PredictivePerformanceAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive performance analytics forecasting future energy usage."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendations for reducing energy consumption."
]

// C17: Action
instance ReinforcementLearningPolicyUpdateAction : DTDFVocab:Action [
    base:desc "Updates reinforcement‑learning policy for lighting control based on analytics."
    DTDFVocab:IsAutomatic true
]

// C2: Acting components (physical_acting_components)
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator capable of adjusting illumination levels as defined in BIM semantics."
]

instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Controller that commands LightingActuator via digital twin commands."
]

// C10: Models/Data (dt_models_and_data)
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing geometry, topology, semantic attributes, and device metadata."
    DTDFVocab:inputTo EclipseDittoThingStore
]

instance RuntimeConfigurationArtifacts : DTDFVocab:Model [
    base:desc "Generated configuration files and code produced by the model‑driven engineering pipeline."
    DTDFVocab:inputTo EclipseHonoConnector
]

// C12: System under study
instance LivingLabBuilding : DTDFVocab:Environment [
    base:desc "The physical building infrastructure (Living Lab) modelled in BIM."
    base:contains IlluminationSensor, OccupancyDetector, LightingActuator, LightingController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin are sent back through Eclipse Ditto to Eclipse Hono, which delivers the commands to the building’s actuators (e.g., lighting devices) to enact adjustments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data exchange and model updates occur in real time, providing continuous synchronization between the physical building and its digital counterpart."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Modular, service‑oriented architecture linking BIM‑derived models, a Hono/Ditto configurator, a runtime broker (Ditto), and a visualization front‑end (Unreal Engine) with extension points for additional analytics services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The solution supports the full building life‑cycle, encompassing design (via BIM), construction, and operational phases, including refurbishment and adaptation during use."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric is used to quantify how closely the twin mirrors the physical counterpart; semantic drift is addressed by continuous synchronization."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical link between physical and virtual components is realized through Eclipse Hono for ingesting sensor streams and Eclipse Ditto for managing twin state and bi‑directional command exchange."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach leverages BIM as an industry‑standard modeling language and utilizes open‑source DT frameworks (Eclipse Ditto, Eclipse Hono) that adhere to common IoT and digital‑twin standards."
]