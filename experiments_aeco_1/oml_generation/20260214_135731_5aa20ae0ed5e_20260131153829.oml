// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Provides real-time temperature measurements integrated into Building Control Systems (BCS) and modeled within BIM environment. Supports environmental monitoring with spatial distribution defined by BIM geometric and semantic attributes."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Provides real-time humidity measurements integrated into Building Control Systems (BCS) and modeled within BIM environment. Supports environmental monitoring with spatial distribution defined by BIM geometric and semantic attributes."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance AirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "Provides real-time air quality measurements (CO2, VOCs, particulate matter) integrated into Building Control Systems (BCS) and modeled within BIM environment. Supports environmental monitoring with spatial distribution defined by BIM geometric and semantic attributes."
    DTDFVocab:producedData AirQualityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Provides real-time occupancy detection integrated into Building Control Systems (BCS) and modeled within BIM environment. Supports operational monitoring with spatial distribution defined by BIM geometric and semantic attributes."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnergyConsumptionMonitor : DTDFVocab:SensingComponent [
    base:desc "Provides real-time energy consumption measurements for HVAC and lighting systems integrated into Building Control Systems (BCS) and modeled within BIM environment."
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

instance StructuralSensor : DTDFVocab:SensingComponent [
    base:desc "Provides structural monitoring data (vibration, stress) integrated into Building Control Systems (BCS) and modeled within BIM environment."
    DTDFVocab:producedData StructuralDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Real-time temperature data extracted from IoT sensors with automated validation and normalization before integration into Digital Twin."
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Real-time humidity data extracted from IoT sensors with automated validation and normalization before integration into Digital Twin."
    DTDFVocab:producedFrom HumiditySensor
]

instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Real-time air quality data extracted from IoT sensors with automated validation and normalization before integration into Digital Twin."
    DTDFVocab:producedFrom AirQualitySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Real-time occupancy data extracted from IoT sensors with automated validation and normalization before integration into Digital Twin."
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Real-time energy consumption data extracted from Building Control Systems with automated validation and normalization before integration into Digital Twin."
    DTDFVocab:producedFrom EnergyConsumptionMonitor
]

instance StructuralDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Real-time structural data extracted from IoT sensors with automated validation and normalization before integration into Digital Twin."
    DTDFVocab:producedFrom StructuralSensor
]

// C10: Models/Data
instance BimGeometricModel : DTDFVocab:Model [
    base:desc "Static geometric representation of building components from Building Information Modeling (BIM) environment serving as foundational semantic layer."
    DTDFVocab:inputTo EclipseBasyxEnabler, ModelDrivenEngineeringEnabler
]

instance BimSemanticModel : DTDFVocab:Model [
    base:desc "Semantic enrichment of BIM models with Building Control Systems (BCS) components metadata including sensors, actuators, and controllers."
    DTDFVocab:inputTo EclipseBasyxEnabler, ModelDrivenEngineeringEnabler
]

instance BcsControlLogicModel : DTDFVocab:Model [
    base:desc "Dynamic behavioral model representing control logic and device configurations for Building Control Systems (BCS)."
    DTDFVocab:inputTo EclipseBasyxEnabler, ModelDrivenEngineeringEnabler
]

instance RealTimeEnvironmentalData : DTDFVocab:Data [
    base:desc "Aggregated real-time environmental data including temperature, humidity, air quality, and occupancy from IoT sensor networks."
    DTDFVocab:fromData TemperatureDataTransmitted, HumidityDataTransmitted, AirQualityDataTransmitted, OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseBasyxEnabler, IndoorConditionMonitoringEnabler
]

instance EnergyPerformanceData : DTDFVocab:Data [
    base:desc "Real-time and historical energy consumption data for HVAC and lighting systems with automated validation."
    DTDFVocab:fromData EnergyConsumptionDataTransmitted
    DTDFVocab:inputTo EclipseBasyxEnabler, IndoorConditionMonitoringEnabler
]

instance StructuralHealthData : DTDFVocab:Data [
    base:desc "Structural monitoring data including vibration and stress measurements with automated validation."
    DTDFVocab:fromData StructuralDataTransmitted
    DTDFVocab:inputTo EclipseBasyxEnabler
]

// C11: Enablers
instance EclipseBasyxEnabler : DTDFVocab:Enabler [
    base:desc "Open-source platform for Industry 4.0 digital twins providing modular architecture for development, supporting interoperability between systems and real-time data exchange."
    DTDFVocab:enables LEEDPlatinumBuildingMonitoringService, UniversityLibraryMonitoringService, EnergyOptimizationService, PredictiveMaintenanceService
]

instance ItwinJsEnabler : DTDFVocab:Enabler [
    base:desc "Library for developing infrastructure digital twin applications supporting 3D visualization, spatial data integration, and collaborative development."
    DTDFVocab:enables LEEDPlatinumBuildingVisualizationService, UniversityLibraryVisualizationService
]

instance ModelDrivenEngineeringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for digital twin development automating model transformations and code generation with domain-specific modeling support."
    DTDFVocab:enables LEEDPlatinumBuildingDeploymentService, UniversityLibraryDeploymentService
]

instance IndoorConditionMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Digital twin framework for indoor environmental monitoring enabling real-time tracking of conditions and automated control of HVAC systems."
    DTDFVocab:enables LEEDPlatinumBuildingOptimizationService, UniversityLibraryOptimizationService
]

instance LivingLabDigitalTwinEnabler : DTDFVocab:Enabler [
    base:desc "Research-oriented digital twin development framework supporting real-time monitoring, adaptive control, and data-driven decision making."
    DTDFVocab:enables LEEDPlatinumBuildingResearchService, UniversityLibraryResearchService
]

