]

instance UniversityLibraryControlService : DTDFVocab:Service [
    base:desc "Automated adjustments to HVAC and lighting systems for University Library."
    DTDFVocab:provides HVACControlAdjustment, LightingAutomationAction
]

instance UniversityLibraryVisualizationService : DTDFVocab:Service [
    base:desc "Data-driven insights for facility management in University Library."
    DTDFVocab:provides EnergyConsumptionDashboard, BuildingStateVisualization
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Cross-building energy optimization service leveraging machine learning for predictive analytics."
