]

instance LEEDPlatinumBuildingPredictionService : DTDFVocab:Service [
    base:desc "Forecasting of energy demand and indoor comfort trends for LEED Platinum Academic Building."
    DTDFVocab:provides EnergyDemandForecast, ComfortTrendInsight
]

instance LEEDPlatinumBuildingControlService : DTDFVocab:Service [
    base:desc "Adaptive control of HVAC and lighting systems for LEED Platinum Academic Building."
