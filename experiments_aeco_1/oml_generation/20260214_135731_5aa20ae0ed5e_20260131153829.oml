]

instance UniversityLibraryMonitoringService : DTDFVocab:Service [
    base:desc "Real-time indoor condition monitoring (temperature, humidity, lighting, occupancy) for University Library."
    DTDFVocab:provides IndoorConditionInsight, OccupancyPatternInsight
]

instance UniversityLibraryOptimizationService : DTDFVocab:Service [
