// C3: Physical sensing components
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Building illumination sensor embedded in the BIM model that measures light levels and streams data via Eclipse Hono"
    DTDFVocab:producedData IlluminationTelemetry
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector sensor modeled in BIM that detects presence of occupants and streams events via Eclipse Hono"
    DTDFVocab:producedData OccupancyTelemetry
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in the BIM model that measures indoor temperature and streams readings via Eclipse Hono"
    DTDFVocab:producedData TemperatureTelemetry
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor defined in the BIM model that measures indoor humidity and streams readings via Eclipse Hono"
    DTDFVocab:producedData HumidityTelemetry
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance IlluminationTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance OccupancyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance TemperatureTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

// C10: Data
instance IlluminationData : DTDFVocab:Data [
    base:desc "Live illumination telemetry used for real-time lighting optimization and monitoring"
    DTDFVocab:fromData IlluminationTelemetry
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy events used for space utilization analysis and adaptive control"
    DTDFVocab:fromData OccupancyTelemetry
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature readings used for HVAC control and predictive maintenance"
    DTDFVocab:fromData TemperatureTelemetry
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Live humidity readings used for indoor air quality monitoring and HVAC control"
    DTDFVocab:fromData HumidityTelemetry
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// C2: Acting Components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator defined in the BIM model that receives commands to adjust light levels"
]

instance HVACValveControllerActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve controller actuator defined in the BIM model that receives commands to modulate airflow"
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono ingests MQTT/AMQP sensor telemetry from the physical building and forwards it to the digital twin"
    DTDFVocab:enables RealTimeMonitoringDashboardService, EnergyOptimizationService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital twin state, processes incoming telemetry and provides contextual data for analytics"
    DTDFVocab:enables PredictiveAnalyticsService, SimulationCapabilityService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders the 3D interactive visualization of the building twin"
    DTDFVocab:enables UnrealEngineVisualizationService
]

instance BIMAuthoringToolEnabler : DTDFVocab:Enabler [
    base:desc "BIM authoring tools (e.g., Revit, ArchiCAD) provide the base geometric and semantic model enriched with sensor metadata"
]

instance ModelTransformationPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Model-driven transformation pipeline extracts metadata, validates models and generates runtime artifacts"
]

instance ODTEMetricEnabler : DTDFVocab:Enabler [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric computes the fidelity of physical‑virtual synchronization"
    DTDFVocab:enables EnergyOptimizationService, PredictiveAnalyticsService
]

// C6: Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards display live sensor data and system health"
    DTDFVocab:provides OptimizationRecommendationInsight, PredictiveMaintenanceAlertInsight
]

instance UnrealEngineVisualizationService : DTDFVocab:Service [
    base:desc "3D interactive visualization in Unreal Engine 5 enables scenario analysis and immersive exploration"
    DTDFVocab:provides InteractiveScenarioAnalysisInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics compute maintenance alerts and energy consumption forecasts from historic and live data"
    DTDFVocab:provides PredictiveMaintenanceAlertInsight, EnergyConsumptionForecastInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization engine advises energy‑saving actions and can trigger automatic actuator commands"
    DTDFVocab:provides OptimizationRecommendationInsight, AdjustLightingLevelAction, ModulateHVACValveAction
]

instance SimulationCapabilityService : DTDFVocab:Service [
    base:desc "Simulation capability runs what‑if scenarios based on control logic and BIM models"
    DTDFVocab:provides InteractiveScenarioAnalysisInsight
]

// C17: Insights
instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation for energy‑efficient lighting and HVAC set‑points derived from real‑time data"
]

instance PredictiveMaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating potential sensor or actuator failures predicted by anomaly detection on telemetry"
]

instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of building energy consumption for the next 24‑48 hours using predictive models"
]

instance InteractiveScenarioAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight from interactive scenario analysis visualized in the 3D twin to support decision making"
]

// C17: Actions
instance AdjustLightingLevelAction : DTDFVocab:Action [
    base:desc "Automatically adjust lighting dimmer set‑points based on occupancy and illumination levels"
    DTDFVocab:IsAutomatic true
]

instance ModulateHVACValveAction : DTDFVocab:Action [
    base:desc "Automatically modulate HVAC valve positions to maintain temperature and humidity comfort ranges"
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance BaseBIMGeometricSemanticModel : DTDFVocab:Model [
    base:desc "Base BIM geometric and semantic model describing building geometry, spaces and assets"
    DTDFVocab:inputTo BIMAuthoringToolEnabler
]

instance RuntimeMetadataEnrichedModel : DTDFVocab:Model [
    base:desc "BIM model enriched with runtime metadata for sensors and actuators"
    DTDFVocab:inputTo ModelTransformationPipelineEnabler
]

instance RuntimeArtifactsModel : DTDFVocab:Model [
    base:desc "Generated runtime artifacts (deployment descriptors, configuration files) produced by the transformation pipeline"
    DTDFVocab:inputTo EclipseDittoEnabler, EclipseHonoEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model defining rules for automatic actuator commands and optimization strategies"
]

instance UnrealEngineVisualizationModel : DTDFVocab:Model [
    base:desc "Unreal Engine 5 visualization model derived from BIM geometry and runtime state for immersive twin display"
    DTDFVocab:inputTo UnrealEngine5Enabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command messages generated by the DT (control set-points, lighting scenes, HVAC adjustments) transmitted through Eclipse Ditto/Hono to actuators in the building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near-real-time synchronization (continuous data flow with sub-second to second latency) as defined by the real-time data exchange layer."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service-oriented architecture where the BIM-derived core twin is connected to middleware (Hono/Ditto) and visualisation (Unreal Engine), with extension points for custom services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the design stage (ideal BIM model), construction/manufacturing stage (as-built BIM data) and operational stage (runtime sensor data and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Evaluation of twin fidelity using the Overall Digital Twin Entanglement (ODTE) metric to quantify alignment between the virtual twin and its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication over Eclipse Hono/Ditto, which typically employs MQTT/AMQP protocols for real-time telemetry and command exchange."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Standardization of BIM semantics through a modeling methodology that harmonizes heterogeneous BIM data across disciplines."
]