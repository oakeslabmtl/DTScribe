// C2: Acting Components
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control device modeled in the BIM model and exposed through generated runtime interfaces."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator modeled in the BIM model and exposed through generated runtime interfaces."
]

// C3: Physical sensing components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor integrated into the building and described in the enriched BIM model for automatic extraction."
    DTDFVocab:producedData LightSensorStream
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor integrated into the building and described in the enriched BIM model for automatic extraction."
    DTDFVocab:producedData TemperatureSensorStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor integrated into the building and described in the enriched BIM model for automatic extraction."
    DTDFVocab:producedData OccupancySensorStream
]

// C4: Physical-to-virtual interaction
instance LightSensorStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance TemperatureSensorStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancySensorStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Models/Data
instance LightData : DTDFVocab:Data [
    base:desc "Processed light level data derived from LightSensorStream."
    DTDFVocab:fromData LightSensorStream
    DTDFVocab:inputTo EclipseDitto
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Processed temperature data derived from TemperatureSensorStream."
    DTDFVocab:fromData TemperatureSensorStream
    DTDFVocab:inputTo EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Processed occupancy data derived from OccupancySensorStream."
    DTDFVocab:fromData OccupancySensorStream
    DTDFVocab:inputTo EclipseDitto
]

instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Base BIM model enriched with device and middleware metadata."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance RuntimeInterfaceModel : DTDFVocab:Model [
    base:desc "Generated runtime interfaces exposing modeled devices to middleware."
    DTDFVocab:inputTo EclipseDitto
]

instance ODTEModel : DTDFVocab:Model [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric model for evaluation."
    DTDFVocab:inputTo PredictiveAnalyticsService
]

// C11: Enablers
instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model-driven engineering pipeline that enriches BIM, validates models, and generates deployable artifacts."
    DTDFVocab:enables RealTimeMonitoringDashboard
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono handles continuous real‑time streaming of sensor data from the physical building to the digital twin."
    DTDFVocab:enables RealTimeMonitoringDashboard
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto provides digital twin runtime, storing state and exposing interfaces for services."
    DTDFVocab:enables BuildingPerformanceSimulation,
               EnergyComfortOptimization,
               PredictiveAnalyticsService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders the 3D interactive visualization of the digital twin."
    DTDFVocab:enables Interactive3DVisualization
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards aggregating live sensor streams."
    DTDFVocab:provides RealTimeInsight
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "3D interactive visualization of the building model in Unreal Engine 5."
    DTDFVocab:provides EnergyUseInsight,
               ComfortSettingInsight
]

instance BuildingPerformanceSimulation : DTDFVocab:Service [
    base:desc "Simulation of building performance using the enriched BIM model."
    DTDFVocab:provides EnergyUseInsight
]

instance EnergyComfortOptimization : DTDFVocab:Service [
    base:desc "Optimization of energy consumption and occupant comfort."
    DTDFVocab:provides AdjustLightingAction,
               AdjustHVACAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics generating forecasts and recommendations."
    DTDFVocab:provides PredictiveAnalyticsInsight
]

// C17: Insights/Actions
instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Provides real‑time insights on sensor readings for facility‑manager decisions."
]

instance EnergyUseInsight : DTDFVocab:Insight [
    base:desc "Insight on current energy usage derived from sensor data and simulation results."
]

instance ComfortSettingInsight : DTDFVocab:Insight [
    base:desc "Insight on occupant comfort levels derived from temperature and occupancy data."
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics insight supporting decisions on future energy use and maintenance actions."
]

instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automatically adjusts lighting levels based on real‑time occupancy and light sensor data."
    DTDFVocab:IsAutomatic true
]

instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Automatically adjusts HVAC set points based on temperature and occupancy data."
    DTDFVocab:IsAutomatic true
]

// Environment containing components
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains LightSensor,
               TemperatureSensor,
               OccupancySensor,
               LightingControlActuator,
               HVACActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional control commands dispatched from the Digital Twin to building actuators through the Ditto platform back to devices via Hono."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (continuous) synchronization supported by Eclipse Hono/Ditto; specific update rates are not detailed in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture centered on a DT framework hub that integrates the enriched BIM model, Hono/Ditto middleware, visualization layer and custom service plug‑ins."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the design stage (BIM creation), deployment stage (automatic generation of runtime artifacts), and operational stage (as‑operated monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to assess the degree of entanglement, interoperability and architectural soundness of the twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Device connectivity handled by Eclipse Hono (typical IoT protocols such as MQTT) and digital‑twin state management by Eclipse Ditto, enabling bidirectional communication."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Built on BIM standards widely adopted in AECO (e.g., IFC) and follows model‑driven engineering principles; specific external standards are not enumerated."
]