// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Building Control System temperature sensor integrated into BIM environment for real-time environmental monitoring"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance MotionDetector : DTDFVocab:SensingComponent [
    base:desc "Motion detection sensor for occupancy-based automation within BIM-aligned building infrastructure"
    DTDFVocab:producedData MotionDataTransmitted
]

instance EnvironmentalMonitor : DTDFVocab:SensingComponent [
    base:desc "Comprehensive environmental sensor measuring air quality, humidity, and CO2 levels for facility management"
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

instance EnergyUsageSensor : DTDFVocab:SensingComponent [
    base:desc "Energy consumption monitoring sensor tracking real-time electrical usage across building systems"
    DTDFVocab:producedData EnergyUsageDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "High-precision occupancy sensor for space utilization analytics and HVAC optimization"
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
    base:desc "Real-time temperature readings transmitted via OPC UA protocol with sub-second latency"
]

instance MotionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionDetector
    base:desc "Occupancy detection data synchronized through MQTT protocol for immediate facility response"
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalMonitor
    base:desc "Environmental metrics (air quality, humidity, CO2) transmitted via standardized IoT gateway"
]

instance EnergyUsageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyUsageSensor
    base:desc "High-frequency energy consumption data streamed for predictive analytics integration"
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
    base:desc "Occupancy patterns data synchronized for space utilization optimization"
]

// C10: Models/Data
instance BimGeometricModel : DTDFVocab:Model [
    base:desc "Static geometric representation derived from BIM models serving as foundational spatial framework"
    DTDFVocab:inputTo ModelDrivenEngineeringFramework
]

instance BcsBehavioralModel : DTDFVocab:Model [
    base:desc "Dynamic control logic model integrating sensors, actuators, and controllers from BIM environment"
    DTDFVocab:inputTo ModelDrivenEngineeringFramework
]

instance AnalyticalRuntimeModel : DTDFVocab:Model [
    base:desc "Structured analytical model generated via MDE principles for DT artifact deployment"
    DTDFVocab:inputTo ModelDrivenEngineeringFramework
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Continuously synchronized operational data from physical building systems"
    DTDFVocab:fromData TemperatureDataTransmitted, MotionDataTransmitted, EnvironmentalDataTransmitted, EnergyUsageDataTransmitted, OccupancyDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchangeProtocol
]

instance BimEnrichedMetadata : DTDFVocab:Data [
    base:desc "Semantic metadata extracted from BIM models enriched with BCS component annotations"
    DTDFVocab:inputTo ModelDrivenEngineeringFramework
]

// C11: Enablers
instance ModelDrivenEngineeringFramework : DTDFVocab:Enabler [
    base:desc "Core framework implementing MDE principles to transform BIM models into deployable DT artifacts"
    DTDFVocab:enables DeviceModelingService, DeploymentArtifactGenerationService
]

instance RealTimeDataExchangeProtocol : DTDFVocab:Enabler [
    base:desc "Standardized protocol stack (OPC UA, MQTT) ensuring continuous synchronization between physical and digital systems"
    DTDFVocab:enables RealTimeMonitoringService, ControlOptimizationService
]

instance ImmersiveVisualizationEngine : DTDFVocab:Enabler [
    base:desc "WebGL-based 3D rendering engine providing interactive visualization of live sensor data overlaid on BIM models"
    DTDFVocab:enables FacilityMonitoringService
]

instance PredictiveAnalyticsModule : DTDFVocab:Enabler [
    base:desc "Custom plugin architecture enabling integration of predictive analytics for energy optimization and fault detection"
    DTDFVocab:enables PredictiveMaintenanceService, EnergyOptimizationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Physics-based simulation engine supporting what-if scenario testing for control logic validation"
    DTDFVocab:enables ControlLogicValidationService, ScenarioTestingService
]

instance CustomServiceDevelopmentToolkit : DTDFVocab:Enabler [
    base:desc "Toolkit providing standardized APIs and microservice architecture for DT engineers to build domain-specific plugins"
    DTDFVocab:enables CustomAnalyticsIntegrationService
]

// C6: Services
instance DeviceModelingService : DTDFVocab:Service [
    base:desc "Service enabling Building Control Engineers to define and configure BCS components within BIM environment"
    DTDFVocab:provides DeviceConfigurationInsight, AutomatedMetadataExtractionAction
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Bidirectional real-time synchronization service maintaining sub-second latency for critical operational parameters"
    DTDFVocab:provides SystemStateInsight, ImmersiveMonitoringAction
]

instance ControlOptimizationService : DTDFVocab:Service [
    base:desc "Closed-loop control service implementing automated adjustments based on predictive analytics and predefined thresholds"
    DTDFVocab:provides OptimizationRecommendationInsight, AutomatedActuationAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Custom analytics plugin analyzing historical and real-time data for fault prediction and preventive maintenance"
    DTDFVocab:provides FaultPredictionInsight, MaintenanceRecommendationAction
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy consumption analytics service providing optimization recommendations based on occupancy and environmental patterns"
    DTDFVocab:provides EnergyEfficiencyInsight, ConsumptionReductionAction
]

instance DeploymentArtifactGenerationService : DTDFVocab:Service [
    base:desc "Automated service generating deployable DT artifacts (microservices, API endpoints) from enriched BIM models"
    DTDFVocab:provides DeploymentArtifactInsight, AutomatedDeploymentAction
]

instance FacilityMonitoringService : DTDFVocab:Service [
    base:desc "Interactive visualization service enabling Facility Managers to monitor system states through 3D BIM overlays"
    DTDFVocab:provides SpatialAwareMonitoringInsight, RemoteControlAction
]

instance CustomAnalyticsIntegrationService : DTDFVocab:Service [
    base:desc "Service enabling runtime integration of third-party analytics services and AI/ML models"
    DTDFVocab:provides CustomAnalyticsInsight, RuntimeExtensionAction
]

instance ControlLogicValidationService : DTDFVocab:Service [
    base:desc "Service validating control logic through simulation and scenario testing"
    DTDFVocab:provides ControlValidationInsight, LogicVerificationAction
]

instance ScenarioTestingService : DTDFVocab:Service [
    base:desc "Service enabling what-if scenario testing for control logic validation"
    DTDFVocab:provides ScenarioAnalysisInsight, TestExecutionAction
]

instance SpatialAwareControlService : DTDFVocab:Service [
    base:desc "Service providing spatial-aware control capabilities for building systems"
    DTDFVocab:provides SpatialControlInsight, ControlExecutionAction
]

instance PluginExtensionService : DTDFVocab:Service [
    base:desc "Service enabling extension of DT capabilities through plugin integration"
    DTDFVocab:provides ExtensionInsight, PluginManagementAction
]

