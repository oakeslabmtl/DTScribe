// Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded within rooms detects presence of occupants and reports state."
    DTDFVocab:producedData OccupancyMqttTopic
]
instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor embedded within rooms measures daylight intensity to inform lighting control."
    DTDFVocab:producedData IlluminanceMqttTopic
]
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded within rooms monitors indoor temperature for HVAC regulation."
    DTDFVocab:producedData TemperatureMqttTopic
]
instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor embedded within rooms measures indoor air quality to trigger ventilation."
    DTDFVocab:producedData CO2MqttTopic
]
instance MotionDetector : DTDFVocab:SensingComponent [
    base:desc "Motion detector embedded within rooms senses motion, enabling occupancy analytics."
    DTDFVocab:producedData MotionMqttTopic
]

// Physical-to-virtual interaction: MQTT topics
instance OccupancyMqttTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance IlluminanceMqttTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]
instance TemperatureMqttTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance CO2MqttTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]
instance MotionMqttTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionDetector
]

// Data streams
instance OccupancyTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry JSON stream for occupancy sensor published via Eclipse Hono."
    DTDFVocab:fromData OccupancyMqttTopic
    DTDFVocab:inputTo EclipseHonoBroker
]
instance IlluminanceTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry JSON stream for illuminance sensor published via Eclipse Hono."
    DTDFVocab:fromData IlluminanceMqttTopic
    DTDFVocab:inputTo EclipseHonoBroker
]
instance TemperatureTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry JSON stream for temperature sensor published via Eclipse Hono."
    DTDFVocab:fromData TemperatureMqttTopic
    DTDFVocab:inputTo EclipseHonoBroker
]
instance CO2TelemetryData : DTDFVocab:Data [
    base:desc "Telemetry JSON stream for CO₂ sensor published via Eclipse Hono."
    DTDFVocab:fromData CO2MqttTopic
    DTDFVocab:inputTo EclipseHonoBroker
]
instance MotionTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry JSON stream for motion detector published via Eclipse Hono."
    DTDFVocab:fromData MotionMqttTopic
    DTDFVocab:inputTo EclipseHonoBroker
]

// Enablers
instance EclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono message broker publishing telemetry data over MQTT topics."
    DTDFVocab:enables HonoDataIngestionService
]
instance EclipseDittoRegistry : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin registry exposing twin data as GeoJSON and SF JSON events."
    DTDFVocab:enables MonitoringDashboardService, EnergyAnalyticsService, LightingOptimizationService, AnomalyDetectionService, AnalyticsAPIService
]
instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering pipeline transforming IFC models to runtime twin templates."
    DTDFVocab:enables ModelTransformationService
]
instance UnrealEngine5Renderer : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 rendering engine visualizing live building data."
    DTDFVocab:enables VisualizationService
]
instance KubernetesCluster : DTDFVocab:Enabler [
    base:desc "Kubernetes cluster orchestrating containerized deployment of Digital Twin services."
]

// Models/Data
instance SemanticBIMModel : DTDFVocab:Model [
    base:desc "Semantic BIM model enriched with control metadata (IfcControl, IfcSensor)."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]
instance DittoTwinTemplateModel : DTDFVocab:Model [
    base:desc "Ditto twin template model representing controllable devices."
    DTDFVocab:inputTo EclipseDittoRegistry
]

// Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Live monitoring dashboards rendered in Unreal Engine 5."
    DTDFVocab:provides EnergyUsageInsight, OccupancyHeatMapInsight
]
instance EnergyAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive energy‑use analytics providing forecast insights."
    DTDFVocab:provides PredictiveMaintenanceInsight
]
instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning‑driven lighting optimization controlling dimming."
    DTDFVocab:provides LightingScheduleOptimizationInsight, AdjustLightingAction
]
instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Automated anomaly detection identifying abnormal events in building telemetry."
    DTDFVocab:provides AnomalyDetectionInsight
]
instance AnalyticsAPIService : DTDFVocab:Service [
    base:desc "REST/GraphQL API for third‑party analytics services."
]
instance HonoDataIngestionService : DTDFVocab:Service [
    base:desc "Data ingestion service of Eclipse Hono broker that receives telemetry."
]
instance ModelTransformationService : DTDFVocab:Service [
    base:desc "Service that transforms semantic BIM models into runtime twin templates."
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that renders building data visualizations in Unreal Engine 5."
]

// Insights/Actions
instance EnergyUsageInsight : DTDFVocab:Insight [
    base:desc "Real‑time energy usage dashboards for facility managers."
]
instance OccupancyHeatMapInsight : DTDFVocab:Insight [
    base:desc "Occupancy heat maps visualized on building schematics."
]
instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance alerts for HVAC and lighting systems."
]
instance LightingScheduleOptimizationInsight : DTDFVocab:Insight [
    base:desc "Automated lighting schedule optimization recommendations."
]
instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection insights highlighting irregular patterns."
]
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Adjust lighting levels automatically based on occupancy and daylight."
    DTDFVocab:IsAutomatic true
]

// Acting components
instance DimmingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimming actuator interfaced via the building BCS."
]
instance HVACDamperActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC damper actuator for airflow modulation."
]
instance WindowShadeActuator : DTDFVocab:ActingComponent [
    base:desc "Controllable window shade actuator for glare control."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., lighting dimming levels, HVAC set‑points) are serialized as MQTT messages via Hono and pushed to the building’s BCS, which then actuates the corresponding physical devices"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sub‑second latency (≈ 200 ms) for sensor telemetry and command propagation; synchronization of data streams occurs in near‑real time, with batch updates delivered every few seconds for analytics"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Co‑located microservice ecosystem: an Hono broker, Ditto twin manager, a controller microservice implementing reinforcement learning, a data analytics microservice, and a visualization front‑end in Unreal Engine, all orchestrated under a central Building Twin manager"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (BIM model generation), Construction (model‑to‑device mapping and deployment), Operation (live monitoring and control), and Decommissioning (schema removal), covering the full life‑cycle of the asset"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Alignment verified via the Overall Digital Twin Entanglement (ODTE) metric, with nightly consistency checks; model drift mitigated by re‑parsing IFC models and synchronizing state snapshots"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT over TLS for sensor and actuator messages, Ditto REST/JSON over HTTPS for twin state updates, and WebSocket connections from the Unreal Engine client for real‑time rendering; all routed via Eclipse Hono broker"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Containerized microservices deployed on a Kubernetes cluster, physical building embedded IoT gateways (e.g., ARM Cortex‑M platforms) for edge data ingestion, and cloud‑hosted visualization server exposing the Unreal Engine instance via WebRTC"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "REST/HTTP and MQTT interfaces to external Building Management System (BMS), weather API connectors, and interoperability with other DTs via the Ditto event bus"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of IFC (industry‑standard 4.0) for BIM, MQTT protocol per OASIS MQTT, ISO 19650 for BIM information delivery, and adherence to Eclipse Hono’s secure authentication mechanisms; ODTE metric provides standardised entanglement assessment"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Secure transmission via MQTT over TLS, Hono authentication for device identities, access controls in Ditto, audit logging; safety considerations require prior verification of control logic before deployment, with fail‑safe overrides, but detailed safety policies are not specified in the document"
]