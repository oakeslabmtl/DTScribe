// C3: Physical sensing components
instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor integrated into the building and described in the enriched BIM model for automatic extraction."
    DTDFVocab:producedData LightLevelDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor integrated into the building and described in the enriched BIM model for automatic extraction."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor integrated into the building and described in the enriched BIM model for automatic extraction."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Data
instance LightLevelData : DTDFVocab:Data [
    base:desc "Real‑time light level measurements streamed from the physical building."
    DTDFVocab:fromData LightLevelDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature measurements streamed from the physical building."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy status streamed from the physical building."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C10: Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Base BIM model enriched with device and middleware metadata, generated runtime interfaces, and ODTE metric."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance RuntimeInterfaceModel : DTDFVocab:Model [
    base:desc "Generated runtime interfaces derived from the enriched BIM model for device interaction."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance ODTEMetricModel : DTDFVocab:Model [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric model for evaluation of twin fidelity."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

// C11: Enablers
instance BIMSemanticBackbone : DTDFVocab:Enabler [
    base:desc "BIM used as the semantic backbone for the digital twin."
    DTDFVocab:enables RealTimeMonitoringDashboard, Interactive3DVisualization
]

instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline that transforms enriched BIM models into deployable artifacts."
    DTDFVocab:enables RealTimeMonitoringDashboard, Interactive3DVisualization, BuildingPerformanceSimulation, EnergyComfortOptimizationService, PredictiveAnalyticsService
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides continuous real‑time streaming of sensor data from the physical building to the digital twin."
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalyticsService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages the digital twin state and forwards data to services."
    DTDFVocab:enables Interactive3DVisualization, BuildingPerformanceSimulation, EnergyComfortOptimizationService, PredictiveAnalyticsService
]

instance UnrealEngine5Renderer : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders the 3D interactive visualization of the building twin."
    DTDFVocab:enables Interactive3DVisualization
]

instance ExtensionPointFramework : DTDFVocab:Enabler [
    base:desc "Standardized extension points for modular services enable runtime configuration management."
    DTDFVocab:enables EnergyComfortOptimizationService, PredictiveAnalyticsService
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards presenting sensor data and energy consumption."
    DTDFVocab:provides RealTimeEnergyInsight, ComfortConditionInsight
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "3D interactive visualization of the building twin in Unreal Engine 5."
    DTDFVocab:provides SpatialVisualizationInsight
]

instance BuildingPerformanceSimulation : DTDFVocab:Service [
    base:desc "Simulation of building performance for energy and comfort optimization."
    DTDFVocab:provides SimulationResultInsight
]

instance EnergyComfortOptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that computes optimal HVAC and lighting settings."
    DTDFVocab:provides AdjustHVACAction, AdjustLightingAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics that forecast maintenance needs and energy trends."
    DTDFVocab:provides MaintenancePredictionInsight, ScheduleMaintenanceAction
]

// C17: Insights
instance RealTimeEnergyInsight : DTDFVocab:Insight [
    base:desc "Provides real‑time insight into building energy use for facility‑manager decisions."
]

instance ComfortConditionInsight : DTDFVocab:Insight [
    base:desc "Provides insight into occupant comfort settings based on temperature and occupancy data."
]

instance SpatialVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides spatial insight through 3D interactive visualization of the twin."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Provides insight from simulation results about energy efficiency and comfort."
]

instance MaintenancePredictionInsight : DTDFVocab:Insight [
    base:desc "Provides predictive insight for proactive maintenance actions."
]

// C17: Actions
instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Automatically adjusts HVAC setpoints to optimize energy use and comfort."
    DTDFVocab:IsAutomatic true
]

instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automatically controls lighting devices to meet occupancy and daylight conditions."
    DTDFVocab:IsAutomatic true
]

instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Schedules maintenance tasks based on predictive analytics recommendations."
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control device modeled in BIM and exposed through generated runtime interfaces."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator modeled in BIM and exposed through generated runtime interfaces."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional control commands dispatched from the Digital Twin to building actuators through the Ditto platform back to devices via Hono."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (continuous) synchronization supported by Eclipse Hono/Ditto; specific update rates are not detailed in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture centered on a DT framework hub that integrates the enriched BIM model, Hono/Ditto middleware, visualization layer and custom service plug‑ins."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the design stage (BIM creation), deployment stage (automatic generation of runtime artifacts), and operational stage (as‑operated monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to assess the degree of entanglement, interoperability and architectural soundness of the twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Device connectivity handled by Eclipse Hono (typical IoT protocols such as MQTT) and digital‑twin state management by Eclipse Ditto, enabling bidirectional communication."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Built on BIM standards widely adopted in AECO (e.g., IFC) and follows model‑driven engineering principles; specific external standards are not enumerated."
]