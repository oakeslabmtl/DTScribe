// C3: Physical sensing components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor modeled in enriched BIM/IFC with photometric metadata (e.g., Revit photometric values for lights)."
    DTDFVocab:producedData LightSensorDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "General environmental temperature sensor modeled in enriched BIM/IFC with metadata."
    DTDFVocab:producedData TempSensorDataTransmitted
]

// C4: Data transmitted from sensors
instance LightSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance TempSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C10: Data artifacts derived from transmitted data
instance LightSensorReadingData : DTDFVocab:Data [
    base:desc "Validated light sensor reading stored in Eclipse Ditto after policy‑based range and unit checks."
    DTDFVocab:fromData LightSensorDataTransmitted
    DTDFVocab:inputTo HonoIngestionEnabler, DittoStateStoreEnabler, UnrealEngineVisualizationEnabler
]

instance TempSensorReadingData : DTDFVocab:Data [
    base:desc "Validated temperature sensor reading stored in Eclipse Ditto after policy checks."
    DTDFVocab:fromData TempSensorDataTransmitted
    DTDFVocab:inputTo HonoIngestionEnabler, DittoStateStoreEnabler, UnrealEngineVisualizationEnabler
]

// C10: Model artifact
instance EnrichedBIMIfcModel : DTDFVocab:Model [
    base:desc "Enriched BIM/IFC model containing geometric building information and device metadata (e.g., lights, sensors, actuators)."
    DTDFVocab:inputTo HonoIngestionEnabler, DittoStateStoreEnabler, UnrealEngineVisualizationEnabler
]

// C11: Enablers (pipeline components)
instance HonoIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono connectivity layer ingesting real‑time sensor updates and forwarding them to Ditto."
    DTDFVocab:enables RealTimeDataSyncService
]

instance DittoStateStoreEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto state store persisting twin state, validating data via policy engine, and exposing event store."
    DTDFVocab:enables RealTimeDataSyncService, BuildingVisualizationService, ActuatorControlService
]

instance UnrealEngineVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 visualization layer consuming twin state to render 3D geometry and dynamic behavior via TwinComponent objects."
    DTDFVocab:enables BuildingVisualizationService
]

// C6: Services offered by the DT
instance RealTimeDataSyncService : DTDFVocab:Service [
    base:desc "Provides continuous real‑time synchronization of sensor/actuator data between physical assets and the digital twin."
    DTDFVocab:provides SystemStateInsight
]

instance BuildingVisualizationService : DTDFVocab:Service [
    base:desc "Renders immersive 3‑D building visualization and reflects live state changes from the twin."
    DTDFVocab:provides SystemStateInsight
]

instance ActuatorControlService : DTDFVocab:Service [
    base:desc "Executes actuator commands received from UE5 twin, forwarding them via DittoController and DittoConnection to physical devices."
    DTDFVocab:provides OperatePhysicalActuatorAction
]

// C17: Insights
instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time view of building system states (sensor readings, actuator statuses) made available to facility managers."
]

// C17: Actions
instance OperatePhysicalActuatorAction : DTDFVocab:Action [
    base:desc "Manual operation of physical actuators (e.g., turn on/off, set brightness) initiated by facility manager through UE5 interface."
    DTDFVocab:IsAutomatic false
]

// C2: Acting components (actuators)
instance LightActuator : DTDFVocab:ActingComponent [
    base:desc "Digital representation of a physical lighting actuator managed by a DittoDevice instance."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Digital representation of a physical HVAC actuator managed by a DittoDevice instance."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control actions originate from the deployed Digital Twin (e.g., Facility Managers interacting with the DT) and are propagated back to the physical building systems via the same bidirectional data exchange infrastructure underpinning Eclipse Hono and Ditto. Commands are issued in real time to actuators or control modules, enabling the DT to influence physical operations."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange that continuously synchronizes the physical building with its digital twin; synchronization is performed continuously as data become available, with no explicit frequency or latency values stated, supporting near‑zero latency for monitoring and control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system adopts a modular hub‑and‑spoke constellation where a central DT Framework offers standardized extension points, integrates custom services and analytics, and manages bidirectional data flow between enriched BIM models and runtime data, with runtime configuration management enabling adjustments without full redeployment."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The proposed model‑driven deployment framework covers the full DT life‑cycle, beginning with device modeling directly in the BIM environment (defining sensors, actuators, controllers), followed by model‑driven engineering (MDE) that extracts a structured representation and automatically generates deployable DT artifacts, then deployment of those artifacts to the runtime environment where real‑time data exchange keeps the physical building and its twin continuously synchronized, and finally runtime operation with interactive visualization for monitoring/control and modular extension points that allow the twin to evolve by adding custom services or analytics."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by policy‑based validation in Eclipse Ditto, which checks value ranges, units, and prevents unsafe actuator commands through pre‑execution checks. The framework uses Eclipse Hono’s at‑least‑once delivery and Ditto’s persistent event storage to detect and recover from lost or out‑of‑order messages, providing fault tolerance and data integrity. Validation components run during model conversion to guarantee that BIM‑derived device metadata conforms to expected schemas before deployment. These mechanisms constitute the primary quality‑assurance processes for both models and runtime data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The framework adopts a modular, service‑oriented architecture with defined extension points, built on Eclipse Hono for device connectivity and Eclipse Ditto for digital twin communication. This architecture supports interoperability across heterogeneous systems, scalability from individual components to whole infrastructure, and runtime configuration management without full redeployment."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed via non‑functional requirements that emphasise compatibility with heterogeneous systems; the modular architecture with standardized extension points allows integration of external services and enterprise systems, enabling bidirectional data exchange, though specific protocols or standards are not detailed in the documents."
]