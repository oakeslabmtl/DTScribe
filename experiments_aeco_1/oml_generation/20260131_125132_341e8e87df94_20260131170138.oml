// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Semantically modeled sensor component within BIM for real-time temperature monitoring in building automation systems"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Semantically modeled sensor component within BIM for real-time humidity monitoring in building automation systems"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Semantically modeled sensor component within BIM for real-time occupancy detection in building automation systems"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Semantically modeled sensor component within BIM for real-time energy consumption monitoring in building automation systems"
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

instance HVACController : DTDFVocab:ActingComponent [
    base:desc "Semantically modeled controller component within BIM for HVAC system control logic and configuration"
    DTDFVocab:producedData HVACControlDataTransmitted
]

instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Semantically modeled controller component within BIM for lighting system control logic and configuration"
    DTDFVocab:producedData LightingControlDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance HVACControlDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACController
]

instance LightingControlDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingController
]

// C10: Models/Data
instance BimEnrichedModel : DTDFVocab:Model [
    base:desc "Semantically enriched BIM model containing BCS components with domain-specific annotations for DT deployment"
    DTDFVocab:inputTo MdeTransformationEnabler, BimIntegrationEnabler
]

instance RealTimeBuildingStateModel : DTDFVocab:Model [
    base:desc "Dynamic model representing real-time synchronized state of building systems derived from physical sensors"
    DTDFVocab:inputTo RealTimeSynchronizationEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Model containing predefined and adaptive control logic for building automation systems"
    DTDFVocab:inputTo ControlOperationService, CustomServiceExtension
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Structured temperature data extracted from BIM-enriched models and synchronized in real-time"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo RealTimeSynchronizationEnabler, PredictiveAnalyticsEnabler
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Structured humidity data extracted from BIM-enriched models and synchronized in real-time"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo RealTimeSynchronizationEnabler, PredictiveAnalyticsEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Structured occupancy data extracted from BIM-enriched models and synchronized in real-time"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo RealTimeSynchronizationEnabler, EnergyOptimizationService
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "Structured energy consumption data extracted from BIM-enriched models and synchronized in real-time"
    DTDFVocab:fromData EnergyConsumptionDataTransmitted
    DTDFVocab:inputTo RealTimeSynchronizationEnabler, PredictiveAnalyticsEnabler
]

instance HVACControlData : DTDFVocab:Data [
    base:desc "Structured HVAC control data extracted from BIM-enriched models and synchronized in real-time"
    DTDFVocab:fromData HVACControlDataTransmitted
    DTDFVocab:inputTo ControlOperationService, CustomServiceExtension
]

instance LightingControlData : DTDFVocab:Data [
    base:desc "Structured lighting control data extracted from BIM-enriched models and synchronized in real-time"
    DTDFVocab:fromData LightingControlDataTransmitted
    DTDFVocab:inputTo ControlOperationService, CustomServiceExtension
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Lightweight M2M service for secure, protocol-adaptable data ingestion from IoT devices into the DT framework"
    DTDFVocab:enables RealTimeSynchronizationService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Digital twin framework for representing and managing IoT devices as digital twins with stateful, event-driven interactions"
    DTDFVocab:enables RealTimeMonitoringService, CustomServiceExtension
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "High-fidelity 3D/4D visualization platform for immersive, interactive monitoring and control interfaces"
    DTDFVocab:enables InteractiveVisualizationService
]

instance MdeTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Custom MDE tools for extracting structured representations from enriched BIM models and automatically generating deployable DT artifacts"
    DTDFVocab:enables AutomatedDeploymentService
]

instance BimIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "BIM-compatible modeling tools enabling Building Control Engineers to define sensors, actuators, and controllers within BIM environment"
    DTDFVocab:enables DeviceModelingService
]

instance RealTimeSynchronizationEnabler : DTDFVocab:Enabler [
    base:desc "Automated synchronization protocols ensuring continuous bidirectional data flow between physical building and digital twin"
    DTDFVocab:enables RealTimeMonitoringService
]

instance PredictiveAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for integrating predictive analytics services like reinforcement learning for energy optimization"
    DTDFVocab:enables EnergyOptimizationService, FaultDetectionService
]

// C6: Services
instance DeviceModelingService : DTDFVocab:Service [
    base:desc "Enables semantic modeling of BCS components (sensors, actuators, controllers) within BIM environment creating unified semantic foundation"
    DTDFVocab:provides DeviceConfigurationInsight, ControlLogicDefinitionAction
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Facilitates continuous bidirectional data exchange between physical building and digital twin with immersive visualization interfaces"
    DTDFVocab:provides RealTimeStateInsight, OperationalMonitoringAction
]

instance ControlOperationService : DTDFVocab:Service [
    base:desc "Allows direct interaction with physical infrastructure via digital twin enabling operation, adjustment, or override of building systems"
    DTDFVocab:provides ControlExecutionInsight, SystemAdjustmentAction
]

instance CustomServiceExtension : DTDFVocab:Service [
    base:desc "Provides modular architecture with standardized extension points for integrating custom services, plugins, or analytics modules"
    DTDFVocab:provides CustomServiceIntegrationInsight, RuntimeEvolutionAction
]

instance AutomatedDeploymentService : DTDFVocab:Service [
    base:desc "Leverages MDE principles to extract structured representations from enriched BIM models and automatically generate deployable DT artifacts"
    DTDFVocab:provides DeploymentAutomationInsight, ArtifactGenerationAction
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Implements predictive analytics for energy consumption optimization using reinforcement learning approaches"
    DTDFVocab:provides EnergyEfficiencyInsight, OptimizationAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Provides anomaly detection capabilities through custom service integration for predictive maintenance"
    DTDFVocab:provides FaultIdentificationInsight, MaintenanceRecommendationAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Creates immersive, interactive interfaces for monitoring and control using high-fidelity 3D/4D visualization"
    DTDFVocab:provides VisualMonitoringInsight, InteractiveControlAction
]

// C17: Insights/Actions
instance DeviceConfigurationInsight : DTDFVocab:Insight [
    base:desc "Semantic configuration data for BCS components enabling alignment between physical and digital representations"
]

instance ControlLogicDefinitionAction : DTDFVocab:Action [
    base:desc "Definition of control logic and device configurations directly in BIM environment"
    DTDFVocab:IsAutomatic false
]

instance RealTimeStateInsight : DTDFVocab:Insight [
    base:desc "Continuously synchronized system states including sensor readings and actuator statuses"
]

instance OperationalMonitoringAction : DTDFVocab:Action [
    base:desc "Facility managers observing and responding to dynamic building conditions through DT interface"
    DTDFVocab:IsAutomatic false
]

instance ControlExecutionInsight : DTDFVocab:Insight [
    base:desc "Execution status of control logic applied to building systems in real-time"
]

instance SystemAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjustment or override of building systems (e.g., HVAC setpoints, lighting schedules) through DT interface"
    DTDFVocab:IsAutomatic false
]

instance CustomServiceIntegrationInsight : DTDFVocab:Insight [
    base:desc "Integration status and capabilities of custom services within the modular DT architecture"
]

instance RuntimeEvolutionAction : DTDFVocab:Action [
    base:desc "Development and deployment of domain-specific services (e.g., predictive maintenance, anomaly detection)"
    DTDFVocab:IsAutomatic false
]

instance DeploymentAutomationInsight : DTDFVocab:Insight [
    base:desc "Automated transformation status from static BIM models to dynamic DT components"
]

instance ArtifactGenerationAction : DTDFVocab:Action [
    base:desc "Automatic generation of deployable DT artifacts with minimal manual intervention"
    DTDFVocab:IsAutomatic true
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics results for energy consumption optimization using reinforcement learning"
]

instance OptimizationAction : DTDFVocab:Action [
    base:desc "Application of optimized control strategies based on predictive analytics"
    DTDFVocab:IsAutomatic true
]

instance FaultIdentificationInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection results identifying potential faults in building systems"
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Recommendations for predictive maintenance actions based on fault detection"
    DTDFVocab:IsAutomatic false
]

instance VisualMonitoringInsight : DTDFVocab:Insight [
    base:desc "Immersive visualization of building operations with real-time data integration"
]

instance InteractiveControlAction : DTDFVocab:Action [
    base:desc "Interactive control of building systems through immersive visualization interfaces"
    DTDFVocab:IsAutomatic false
]

// C1: Environment
instance BuildingAutomationSystemEnvironment : DTDFVocab:Environment [
    base:desc "Smart building infrastructure containing Building Control Systems (BCS) with sensors, actuators, and controllers"
    base:contains TemperatureSensor, HumiditySensor, OccupancySensor,
                  EnergyConsumptionSensor, HVACController, LightingController
]

instance DigitalTwinFrameworkEnvironment : DTDFVocab:Environment [
    base:desc "Modular Digital Twin framework for building automation with standardized extension points"
    base:contains BimEnrichedModel, RealTimeBuildingStateModel, ControlLogicModel,
                  EclipseHonoEnabler, EclipseDittoEnabler, UnrealEngine5Enabler,
                  MdeTransformationEnabler, BimIntegrationEnabler, RealTimeSynchronizationEnabler,
                  PredictiveAnalyticsEnabler
]

// Added missing service instances
instance RealTimeSynchronizationService : DTDFVocab:Service [
    base:desc "Service enabling real-time synchronization between physical building and digital twin"
    DTDFVocab:provides RealTimeStateInsight
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin (DT) system enables **control flows** from the virtual representation back to the physical building infrastructure, facilitating **real-time monitoring and operational adjustments** by Facility Managers. While the document does not specify exact command types (e.g., HVAC setpoints, lighting controls), it confirms that the DT framework **operates the physical infrastructure** via bidirectional data exchange. The system supports **runtime configuration management**, allowing dynamic adjustments without full redeployment, which implies a feedback loop for validating and executing control signals. The document highlights the role of **DT Engineers** in extending the framework’s capabilities through service integration, suggesting that control commands are validated and authenticated within the modular architecture. However, specific mechanisms like **message formats (JSON/XML), validation protocols, or conflict resolution strategies** are not detailed. The framework’s **central hub** role ensures holistic building lifecycle management, but the exact technical implementation of feedback systems or command execution confirmation remains unspecified."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system in the provided context emphasizes **real-time synchronization** between the physical and digital representations of infrastructure assets (e.g., buildings) to enable **real-time insights, predictive analytics, and data-driven decision-making**. While explicit synchronization frequencies or latency requirements are not specified, the architecture relies on **live data exchange** to maintain an up-to-date virtual model, ensuring temporal alignment for simulation, analysis, and optimization across the asset lifecycle. The system’s temporal granularity is implicitly tied to operational needs, such as monitoring and adaptive management during design, construction, and refurbishment phases. No quantitative thresholds (e.g., millisecond-level latency) are detailed, but the emphasis on **real-time** implies low-latency data pipelines for critical applications like predictive maintenance or dynamic optimization."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is structured as a **cyber-physical information construct** that integrates **static models** (e.g., building designs, structural data) with **runtime data** (e.g., sensor feeds, operational metrics) to create a unified virtual representation. The architecture leverages **model-driven approaches** and modular components, including **Eclipse Hono** (likely for IoT data ingestion) and **Ditto** (for state management), to enable **real-time data exchange**. The system is designed to support **scalable deployment** across heterogeneous infrastructure environments, though specific orchestration patterns (e.g., microservices, event-driven) or resource management strategies are not detailed. The document does not specify centralized vs. decentralized architectures or coordination mechanisms between twin instances, focusing instead on the **integration of static and dynamic data** for simulation, analysis, and optimization."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin (DT) lifecycle in the proposed model-driven deployment framework spans **five core phases**, aligned with the limitations of BIM and the dynamic requirements of DTs:
   1. **Device Modeling & BIM Enrichment**: Building Control Engineers define **sensors, actuators, and controllers** within the BIM environment, addressing BIM’s static limitations by introducing **semantic annotations** for Building Control System (BCS) components. This phase establishes a **unified semantic foundation** for subsequent transformations.
   2. **Model Transformation & Artifact Generation**: Leveraging **Model-Driven Engineering (MDE) principles**, the framework extracts **structured representations** from enriched BIM models and **automatically generates deployable DT artifacts** (e.g., runtime configurations, service interfaces) with **minimal manual intervention**. This phase bridges the gap between static BIM and dynamic DT requirements.
   3. **DT Deployment & Synchronization**: The framework ensures **real-time data exchange** between the physical building and its digital twin, enabling **continuous synchronization** of system states. This phase supports **immersive visualization** for monitoring and control, with **interactive interfaces** tailored for Facility Managers.
   4. **Custom Service Integration & Extension**: DT Engineers develop and integrate **custom services and plugins** via **standardized extension points** in the modular architecture. This phase allows the DT to **evolve dynamically** with operational needs, incorporating analytics, predictive maintenance, or domain-specific logic.
   5. **Runtime Operation & Governance**: The framework supports **lifecycle governance** through **modular architecture**, ensuring interoperability between phases. Facility Managers interact with the twin for **monitoring, control, and operational adjustments**, while the system maintains **versioned artifacts** and **traceability** between physical and digital states. Governance is implicit in the **use-case-driven design** (e.g., TwinLight, BOREALIS projects), ensuring alignment with stakeholder roles (Building Control Engineers, Facility Managers, DT Engineers)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin framework addresses **fidelity requirements** by enabling **Building Control Engineers** to define **sensors, actuators, and controllers** directly within the BIM environment, ensuring semantic consistency and reducing discrepancies between physical and digital representations. **Validation and verification** are implicitly supported through the **automated generation of deployable DT artifacts** from enriched BIM models, minimizing manual errors. **Uncertainty sources** are mitigated via **real-time data exchange**, which synchronizes physical states with the digital twin, though explicit quantification methods (e.g., statistical error modeling) are not detailed. **Error detection and correction** rely on the framework’s **modular architecture**, allowing custom services to integrate analytics for anomaly detection. **Quality assurance** is embedded in the **MDE-driven transformation pipeline**, where structured representations ensure traceability and consistency across the DT lifecycle. The system’s reliance on **BIM’s static representations** introduces potential fidelity gaps, which the framework seeks to bridge through dynamic extensions (e.g., custom services) and **interactive visualization** for operational oversight."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin (DT) framework relies on a **centralized hub architecture** to facilitate bidirectional data exchange between physical and virtual systems, ensuring **interoperability** across heterogeneous components. The document explicitly mentions the use of **Eclipse Hono** and **Ditto** as part of the technical stack, though specific communication protocols (e.g., MQTT, OPC UA) or network topologies are not detailed. The system prioritizes **scalability** from individual components to entire infrastructure systems, implying a distributed or hybrid network architecture to handle varying data loads. **Reliability and redundancy mechanisms** are inferred from the non-functional requirements (NF_X), which emphasize maintainability and low-overhead updates, but no specific failover or redundancy protocols are described. **Security protocols** for network communication are not explicitly stated, though the emphasis on interoperability suggests adherence to standardized security frameworks. The document does not provide details on **bandwidth/latency requirements** or **network topology**, focusing instead on the overarching goal of seamless integration between BIM tools and operational DTs."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin (DT) framework is designed with a **modular architecture** and **standardized extension points**, enabling deployment flexibility across **cloud, edge, or on-premise** environments (though specific platforms like AWS/Azure are not mentioned). The system prioritizes **scalability** to accommodate individual components or entire infrastructure systems, aligning with the non-functional requirements (NF_X) for maintainability and low-overhead updates. **Computational and storage requirements** are implied to support real-time data exchange and interactive visualization, but no specific hardware/software dependencies (e.g., Docker, Kubernetes) are detailed. The framework supports **runtime configuration management**, allowing dynamic adjustments without full redeployment, which suggests a **scalable deployment model** adaptable to evolving operational needs. **Availability and reliability** are addressed through the modular design and interoperability focus, though no explicit redundancy or high-availability mechanisms (e.g., database sharding) are described. The document emphasizes a **requirements-driven approach** tailored to AECO domain challenges, but lacks granular deployment infrastructure specifics."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system addresses **fragmented models and data** in the AECO domain by providing **standardized extension points** to enable modular, service-oriented platform integration. While the document does not explicitly name external systems (e.g., ERP, BIM tools), it highlights the need for **interoperability standards** to bridge heterogeneous data sources. The integration relies on **real-time data exchange protocols** (e.g., via Eclipse Hono and Ditto), though no specific standards (e.g., OPC UA, MQTT) or enterprise system dependencies are mentioned. The system’s modular design suggests **loose coupling** with external tools, but concrete integration patterns (e.g., API gateways, middleware) or dependencies on other Digital Twins are not documented. The absence of standardized integration frameworks is noted as a challenge, implying a reliance on **custom or domain-specific solutions** for horizontal scalability."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework adheres to **standardization principles** primarily through the use of **BIM as a standardized solution** for initial device modeling and semantic representation, addressing the **absence of standardized integration frameworks** in existing DT deployments. **BIM semantics** are standardized to ensure interoperability with **AECO-specific systems and standards** (e.g., Building Information Modeling for Architecture, Engineering, Construction, and Operations). The **modular architecture** incorporates **standardized extension points**, enabling compliant integration of third-party services and plugins while maintaining modularity. While the text does not specify **certification requirements** or **formal compliance frameworks** (e.g., ISO/IEC, OMG standards), the emphasis on **BIM standardization** and **modular interoperability** aligns with broader industry efforts to harmonize DT deployment across domains. The framework’s design explicitly targets **semantic standardization** to mitigate BIM’s limitations, ensuring seamless transitions between modeling, transformation, and runtime phases."
]