import "DTDFVocab"

// C3: Physical sensing components
instance BuildingSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor measuring building parameters, streamed via Eclipse Hono for real‑time synchronization with the digital twin.",
    DTDFVocab:producedData SensorMeasurementsStream
]

instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "TwinComponent that controls a lighting fixture with on/off, brightness (0‑100 %) and color‑temperature (2700‑6500 K) parameters, issuing commands through the UnrealTwinController → DittoController → DittoDevice stack.",
    DTDFVocab:producedData ActuatorCommandStream
]

// C4: Physical‑to‑virtual data transmission
instance SensorMeasurementsStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingSensor
]

instance ActuatorCommandStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightTwinComponent
]

// C10: Data
instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Live sensor measurements (e.g., temperature, occupancy, illuminance) received via MQTT/AMQP through Eclipse Hono.",
    DTDFVocab:fromData SensorMeasurementsStream,
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance LightCommandData : DTDFVocab:Data [
    base:desc "Command payload containing on/off, brightness, and color‑temperature values sent to the physical lighting device.",
    DTDFVocab:fromData ActuatorCommandStream,
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono IoT ingestion gateway handling at‑least‑once MQTT/AMQP delivery of sensor streams into the digital‑twin platform.",
    DTDFVocab:enables RealTimeDataSynchronization
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto runtime providing digital‑twin state management, policy‑based validation and command execution for actuators.",
    DTDFVocab:enables FacilityControlService
]

instance MDEToolchainEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline that transforms enriched BIM into deployable digital‑twin artifacts (TwinComponents, middleware configurations).",
    DTDFVocab:enables ModelGenerationService
]

instance UnrealEngineVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine runtime that hosts TwinComponents and provides the interactive 3‑D visualization layer.",
    DTDFVocab:enables Interactive3DVisualization
]

// C6: Services
instance RealTimeDataSynchronization : DTDFVocab:Service [
    base:desc "Keeps the virtual model continuously synchronized with physical assets by processing incoming sensor data.",
    DTDFVocab:provides StateMonitoringInsight
]

instance FacilityControlService : DTDFVocab:Service [
    base:desc "Enables Facility Managers to issue control actions (e.g., light on/off, brightness changes) via the twin.",
    DTDFVocab:provides LightControlAction
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "Interactive 3‑D visualization layer in Unreal Engine for immersive monitoring and control of the building twin.",
    DTDFVocab:provides VisualizationAction
]

instance ModelGenerationService : DTDFVocab:Service [
    base:desc "Generates UE5 TwinComponents and middleware configurations from BIM models.",
    DTDFVocab:provides ModelGenerationInsight
]

// C17: Insights / Actions
instance StateMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight into current building system states derived from live sensor streams."
]

instance LightControlAction : DTDFVocab:Action [
    base:desc "Action to change lighting fixture state (on/off, brightness, color temperature) through the twin.",
    DTDFVocab:IsAutomatic false
]

instance VisualizationAction : DTDFVocab:Action [
    base:desc "Action enabling user interaction with the 3‑D twin (e.g., selecting components, adjusting view).",
    DTDFVocab:IsAutomatic false
]

instance ModelGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight about successful generation and versioning of digital‑twin artifacts from BIM."
]

// C10: Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched Building Information Model containing geometric IFC entities and semantic device metadata (sensors, actuators, controllers).",
    DTDFVocab:inputTo MDEToolchainEnabler
]

instance GeometricIFCModel : DTDFVocab:Model [
    base:desc "3‑D IFC geometry extracted from the BIM and rendered in Unreal Engine.",
    DTDFVocab:inputTo UnrealEngineVisualizationEnabler
]

instance BehavioralTwinComponentModel : DTDFVocab:Model [
    base:desc "Behavioral model encoded in UE5 TwinComponents that react to device values and issue commands.",
    DTDFVocab:inputTo UnrealEngineVisualizationEnabler
]

instance PolicyValidationModel : DTDFVocab:Model [
    base:desc "Policy‑based validation rules in Eclipse Ditto that enforce safety constraints on actuator commands.",
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange capabilities that ensure continuous synchronization between the physical building and its digital counterpart, described as ongoing real‑time updates without a specified frequency or latency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular hub‑and‑spoke constellation: a central DT Framework orchestrates bidirectional data exchange between enriched BIM models and operational digital twins, enables runtime configuration management, and offers standardized extension points for adding custom analytics and services, supporting scalable component coordination."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports the complete Digital Twin lifecycle: (1) device modeling in the BIM environment where sensors, actuators, and controllers are defined; (2) model‑driven engineering (MDE) extraction of structured representations from the enriched BIM model; (3) automatic generation of deployable DT artifacts; (4) deployment of these artifacts to the runtime environment; and (5) continuous operation with real‑time data exchange and interactive visualization. Transitions between phases are managed by the model‑driven pipeline, and lifecycle governance is expressed through the functional requirements (F_X) that prescribe modeling, transformation, deployment and runtime management."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by enriching the BIM model with precise device metadata (photometric values for lights) and by applying Eclipse Ditto policy‑based validation that checks sensor data against defined ranges and units. The framework validates the enriched BIM during the conversion phase (validation component) and enforces runtime checks on incoming sensor updates and outgoing actuator commands. Uncertainty is limited by the deterministic mapping of Revit photometric parameters to UE5 lighting, and by the at‑least‑once delivery guarantee of Eclipse Hono which avoids lost updates. Errors are detected by Ditto’s persistent event store and corrected through policy re‑evaluation; fault tolerance is provided by Hono’s message reliability and Ditto’s storage, ensuring synchronization between physical assets and the twin."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed through non‑functional requirements emphasizing cross‑system compatibility; the framework relies on standardized extension points and bidirectional data exchange to integrate external services and enterprise systems, though no specific communication protocols or standards are named in the documents."
]