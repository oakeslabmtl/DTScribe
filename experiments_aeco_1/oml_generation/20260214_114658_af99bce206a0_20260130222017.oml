// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in the BIM, exposed through runtime interfaces for controlling building illumination."
]

instance HVACController : DTDFVocab:ActingComponent [
    base:desc "HVAC controller modeled in the BIM, manages heating, ventilation and air‑conditioning set‑points."
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in the BIM, provides indoor temperature measurements."
    DTDFVocab:producedData TemperatureDataTransmission
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in the BIM, detects presence of occupants in zones."
    DTDFVocab:producedData OccupancyDataTransmission
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor modeled in the BIM, measures ambient light levels."
    DTDFVocab:producedData IlluminationDataTransmission
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance TemperatureDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

// C10: Data (live streams)
instance TemperatureLiveData : DTDFVocab:Data [
    base:desc "Live temperature stream originating from TemperatureSensor."
    DTDFVocab:fromData TemperatureDataTransmission
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance OccupancyLiveData : DTDFVocab:Data [
    base:desc "Live occupancy stream originating from OccupancySensor."
    DTDFVocab:fromData OccupancyDataTransmission
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance IlluminationLiveData : DTDFVocab:Data [
    base:desc "Live illumination stream originating from IlluminationSensor."
    DTDFVocab:fromData IlluminationDataTransmission
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C10: Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM artefacts enriched with device and middleware metadata, transformed into runtime artefacts."
    DTDFVocab:inputTo ModelDrivenTransformationEnabler
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides MQTT/HTTP connectivity for ingesting sensor measurements from the physical building."
    DTDFVocab:enables RealTimeMonitoringDashboardService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages the digital twin state, persisting data streams and exposing twin APIs."
    DTDFVocab:enables RealTimeMonitoringDashboardService
    DTDFVocab:enables PredictiveAnalyticsService
    DTDFVocab:enables EnergyOptimizationService
    DTDFVocab:enables BuildingPerformanceSimulationService
]

instance ModelDrivenTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline that validates and transforms enriched BIM into runtime artefacts."
    DTDFVocab:enables Interactive3DVisualizationService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders immersive 3‑D visualisations of the building twin."
    DTDFVocab:enables Interactive3DVisualizationService
]

// C6: Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring dashboards for live sensor data and twin state."
    DTDFVocab:provides EnergyConsumptionTrendInsight
    DTDFVocab:provides AlertNotificationAction
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Delivers an interactive 3‑D visualization of the building twin within Unreal Engine 5."
    DTDFVocab:provides ComfortLevelAlertInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Runs predictive analytics on historical and live data to forecast comfort and energy usage."
    DTDFVocab:provides ComfortLevelAlertInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimises energy consumption by generating set‑point recommendations and applying automatic adjustments."
    DTDFVocab:provides OptimizedControlSetpointInsight
    DTDFVocab:provides AutomatedControlAdjustmentAction
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulates building performance under various scenarios to support decision making."
    DTDFVocab:provides EnergyConsumptionTrendInsight
]

// C17: Insights
instance EnergyConsumptionTrendInsight : DTDFVocab:Insight [
    base:desc "Insight into energy consumption trends derived from aggregated sensor data."
]

instance ComfortLevelAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating that occupant comfort levels (temperature, illumination) are outside predefined thresholds."
]

instance OptimizedControlSetpointInsight : DTDFVocab:Insight [
    base:desc "Recommendation for optimized control set‑points to reduce energy usage while maintaining comfort."
]

// C17: Actions
instance AutomatedControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatically adjusts actuator set‑points (e.g., HVAC, lighting) based on optimization insights."
    DTDFVocab:IsAutomatic true
]

instance AlertNotificationAction : DTDFVocab:Action [
    base:desc "Sends a notification to facility managers when comfort alerts are triggered."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., lighting dimming, HVAC set‑points) are sent back through Eclipse Ditto to Eclipse Hono, which delivers the commands to the respective actuators in the physical building, enabling bidirectional synchronization."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework is designed for near‑real‑time synchronization, with sensor data and control commands exchanged continuously through the Hono/Ditto middleware."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation consists of the enriched BIM model, an automatic configurator that generates Hono/Ditto device descriptors, the Hono broker, the Ditto twin server, and the Unreal Engine visualization client, all orchestrated by the model‑driven deployment framework."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the building lifecycle phases: design (ideal BIM model), construction/installation (as‑built BIM enriched with device metadata), and operation (runtime‑aware BIM used for monitoring and optimization)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is assessed using the Overall Digital Twin Entanglement (ODTE) metric, which quantifies how closely the digital twin reflects its physical counterpart; the framework aims to maintain semantic coherence between BIM and runtime data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT is realized through Eclipse Hono (supporting standard IoT protocols such as MQTT/HTTPS) feeding data into Eclipse Ditto, which exposes a RESTful API for twin interaction."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach follows BIM standards for building data and introduces standardized extension points for service integration, enforcing consistent semantics across the model‑driven pipeline."
]