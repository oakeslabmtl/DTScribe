// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "IoT sensor embedded in physical asset measuring indoor temperature with calibration parameters defined in BIM model"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "IoT sensor detecting occupancy levels with metadata including sensor ID and data format defined in BIM device modeling"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "IoT sensor measuring light levels for visual comfort optimization, integrated with BIM model for metadata management"
    DTDFVocab:producedData LightLevelDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Building Control System sensor monitoring energy consumption with real-time data acquisition capabilities"
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

instance BcsTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Building Control System sensor measuring temperature for HVAC optimization, synchronized with virtual twin via Eclipse Hono"
    DTDFVocab:producedData BcsTemperatureDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance BcsTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BcsTemperatureSensor
]

// C10: Models/Data
instance BimStaticModel : DTDFVocab:Model [
    base:desc "Semantically rich 3D BIM model representing building geometry, topology, and component relationships with device metadata"
    DTDFVocab:inputTo BimToRuntimeTransformationEnabler
]

instance DeviceRuntimeModel : DTDFVocab:Model [
    base:desc "Digital representation of devices generated from BIM via model transformations, managed by Eclipse Ditto"
    DTDFVocab:inputTo DittoEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "BIM-centric control configuration framework automating device-specific control logic deployment"
    DTDFVocab:inputTo TwinLightControlFrameworkEnabler
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Streamed sensor readings, device states, and event logs from IoT sensors and BCS via Eclipse Hono"
    DTDFVocab:fromData TemperatureDataTransmitted, OccupancyDataTransmitted, LightLevelDataTransmitted, EnergyConsumptionDataTransmitted, BcsTemperatureDataTransmitted
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]

instance SimulationAnalyticsModel : DTDFVocab:Model [
    base:desc "Reinforcement learning models for predictive analytics and performance optimization (e.g., BOREALIS project)"
    DTDFVocab:inputTo ReinforcementLearningEnabler
]

instance VisualizationModel : DTDFVocab:Model [
    base:desc "3D visualization model rendered in Unreal Engine 5 for interactive monitoring and user interaction"
    DTDFVocab:inputTo UnrealEngine5Enabler
]

// C11: Enablers
instance HonoEnabler : DTDFVocab:Enabler [
    base:desc "Lightweight open-source IoT middleware facilitating secure, protocol-agnostic data ingestion from sensors"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance DittoEnabler : DTDFVocab:Enabler [
    base:desc "Digital twin framework managing digital twin instances and runtime interfaces for bidirectional communication"
    DTDFVocab:enables AutomatedCommissioningService, RealTimeSynchronizationService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Provides rich, interactive 3D visualization for real-time monitoring and simulation of building operations"
    DTDFVocab:enables RealTimeMonitoringService, WhatIfAnalysisService
]

instance BimToRuntimeTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Model-driven engineering tool performing model-to-model and model-to-text transformations from BIM"
]

instance TwinLightControlFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "BIM-centric control configuration framework automating deployment of device-specific control logic"
    DTDFVocab:enables AutomatedCommissioningService, BidirectionalCommunicationService
]

instance ReinforcementLearningEnabler : DTDFVocab:Enabler [
    base:desc "Reinforcement learning framework for adaptive control optimization of building systems (e.g., BOREALIS)"
    DTDFVocab:enables PredictiveAnalyticsService, WhatIfAnalysisService
]

instance ModelDrivenEngineeringEnabler : DTDFVocab:Enabler [
    base:desc "Model transformations generating runtime artifacts from BIM for DT deployment automation"
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Leverages Unreal Engine 5 for immersive 3D visualization of building operations enabling spatially aware interaction"
    DTDFVocab:provides RealTimeVisualizationInsight, OperationalPerformanceInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Uses reinforcement learning to optimize energy consumption, visual comfort, and non-visual health effects"
    DTDFVocab:provides EnergyOptimizationInsight, VisualComfortInsight, HealthEffectsInsight
]

instance AutomatedCommissioningService : DTDFVocab:Service [
    base:desc "Deploys device-specific control logic and bidirectional communication between DT and physical systems"
    DTDFVocab:provides ControlConfigurationInsight, SystemIntegrationInsight
]

instance WhatIfAnalysisService : DTDFVocab:Service [
    base:desc "Supports operational change simulation (e.g., refurbishment planning) before physical implementation"
    DTDFVocab:provides ImpactAnalysisInsight, DesignOptimizationInsight
]

instance CustomServiceIntegrationService : DTDFVocab:Service [
    base:desc "Modular framework enabling DT Engineers to develop and deploy custom services (e.g., AI-driven fault detection)"
    DTDFVocab:provides CustomServiceInsight, ExtensibilityInsight
]

instance RealTimeSynchronizationService : DTDFVocab:Service [
    base:desc "Maintains continuous bidirectional data exchange between physical and virtual twins via Eclipse Hono and Ditto"
    DTDFVocab:provides DataConsistencyInsight, SynchronizationInsight
]

instance BidirectionalCommunicationService : DTDFVocab:Service [
    base:desc "Enables real-time control adjustments and operational feedback loops between DT and physical systems"
    DTDFVocab:provides ControlAdjustmentInsight, FeedbackLoopInsight
]

// C17: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Facility managers interact with DT in spatially aware manner through Unreal Engine 5 visualization"
]

instance OperationalPerformanceInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring dashboards showing system states and operational performance metrics"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics optimizing energy consumption based on real-time sensor data and RL policies"
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Optimization of visual comfort parameters through adaptive lighting and sensor feedback"
]

instance HealthEffectsInsight : DTDFVocab:Insight [
    base:desc "Analysis of non-visual health effects through building system optimization"
]

instance ControlConfigurationInsight : DTDFVocab:Insight [
    base:desc "Automated deployment of device-specific control logic configurations"
]

instance SystemIntegrationInsight : DTDFVocab:Insight [
    base:desc "Bidirectional communication between DT and physical building control systems"
]

instance ImpactAnalysisInsight : DTDFVocab:Insight [
    base:desc "Simulation results showing impact of operational changes before physical implementation"
]

instance DesignOptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for building design modifications based on what-if analysis"
]

instance CustomServiceInsight : DTDFVocab:Insight [
    base:desc "Integration of third-party custom services like AI-driven fault detection"
]

instance ExtensibilityInsight : DTDFVocab:Insight [
    base:desc "Modular architecture enabling development of new DT services through standardized extension points"
]

instance DataConsistencyInsight : DTDFVocab:Insight [
    base:desc "Ensured consistency between physical and virtual twin states through real-time synchronization"
]

instance SynchronizationInsight : DTDFVocab:Insight [
    base:desc "Continuous bidirectional data exchange maintaining digital thread of physical asset state"
]

instance ControlAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Real-time adjustments to building control systems based on DT recommendations"
]

instance FeedbackLoopInsight : DTDFVocab:Insight [
    base:desc "Operational feedback loops between physical systems and virtual twin for continuous optimization"
]

// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Building Control System actuator for adaptive lighting systems using reinforcement learning for dynamic adjustments"
]

instance HvacActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC control system actuator executing commands generated by DT for energy optimization"
]

instance AdaptiveShadingActuator : DTDFVocab:ActingComponent [
    base:desc "IoT-enabled adaptive shading mechanism responding to real-time sensor data and DT control logic"
]

instance SmartController : DTDFVocab:ActingComponent [
    base:desc "Centralized controller executing DT-generated commands for building systems with bidirectional communication"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The interactions from the virtual world to the physical world involve **control commands and adjustments** generated by the DT and transmitted back to the **Building Control Systems (BCS) and IoT actuators**. These commands include **setpoints for lighting, HVAC, and shading systems**, as well as **dynamic reconfiguration of control logic** (e.g., reinforcement learning-based adjustments in the **BOREALIS project**). The **Eclipse Hono** and **Ditto** platforms facilitate **bidirectional communication** by exposing **standardized APIs** for device control. The **Unreal Engine 5** visualization layer provides an **interactive interface** for **Facility Managers** to manually override or fine-tune control parameters. For instance, the DT may adjust lighting levels in response to occupancy data or energy efficiency goals, with these adjustments executed by the physical actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates on a **real-time synchronization scale**, ensuring continuous alignment between the physical and virtual representations. The framework supports **low-latency data exchange** through **Eclipse Hono and Ditto**, enabling **sub-second to millisecond latency** for critical operations such as sensor data ingestion and control signal execution. While the exact latency metrics are not specified, the emphasis on **real-time monitoring** and **live synchronization** implies high-frequency updates. The **Overall Digital Twin Entanglement (ODTE) metric** is used to evaluate the fidelity of this synchronization, ensuring the DT remains closely coupled with its physical counterpart throughout its operational life cycle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated as a **modular, service-oriented architecture** centered around the **BIM-based semantic backbone**. Key components include:
  1. **BIM Model**: The **source of truth** for building geometry, topology, and device metadata.
  2. **Hono/Ditto Configurator**: Extracts **device metadata** from BIM and generates **runtime interfaces** for **Eclipse Hono** and **Ditto**.
  3. **Eclipse Hono**: Handles **real-time data ingestion** from **IoT sensors and BCS**.
  4. **Eclipse Ditto**: Manages **digital twin instances** and **bidirectional communication** with physical devices.
  5. **Unreal Engine 5**: Provides **immersive visualization** for **Facility Managers**.
  6. **Custom Services Layer**: Hosts **domain-specific services** (e.g., **reinforcement learning for lighting optimization** in **BOREALIS**) integrated via **standardized extension points**.
  The constellation supports **scalable deployment** by allowing **independent scaling** of components (e.g., **Hono for data ingestion**, **Ditto for twin management**, and **Unreal Engine for visualization**). The **Overall Digital Twin Entanglement (ODTE) metric** is used to evaluate the **interoperability** and **architectural soundness** of the constellation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT operates across **all life cycle stages** of the building, from **design and construction** to **operation, refurbishment, and adaptation**. During the **design phase**, the DT leverages **BIM models** to simulate building performance and detect clashes. In the **construction phase**, it supports **automated commissioning** of **Building Control Systems (BCS)** by extracting device metadata from BIM. During **operation**, the DT enables **real-time monitoring, predictive maintenance, and adaptive control** (e.g., **BOREALIS’s reinforcement learning** for lighting optimization). For **refurbishment**, the DT provides **what-if analysis** to evaluate the impact of modifications before physical implementation. The framework ensures **long-term compatibility** with **AECO standards** (e.g., BIM) and supports **evolutionary upgrades** through **runtime configuration management** and **modular service integration**."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are assessed using the **Overall Digital Twin Entanglement (ODTE) metric**, which quantifies the alignment between the digital twin and its physical counterpart. The framework incorporates:
  - **Model Validation**: Ensures semantic consistency and correctness of BIM-enriched models before deployment.
  - **Real-Time Synchronization**: Leverages **Eclipse Hono/Ditto** to maintain **live data alignment** between physical and virtual assets.
  - **Uncertainty Management**: While not explicitly detailed, the emphasis on **real-time monitoring** and **predictive analytics** implies mechanisms to mitigate **semantic drift** (divergence between digital and physical states) over time.
  The ODTE metric provides a **quantitative measure** of the DT’s fidelity, guiding iterative improvements to ensure the twin remains a **high-fidelity representation** of the physical asset throughout its life cycle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT employs **Eclipse Hono** for **real-time data ingestion** from physical sensors and **Eclipse Ditto** for **device state management** and bidirectional communication. The framework supports **metadata-driven connectivity**, where device configurations (e.g., tenant IDs, endpoints) are extracted from the **BIM model** and used to establish connections. While the exact network protocols are not specified, the emphasis on 'real-time data exchange' implies the use of **lightweight, high-throughput protocols** (e.g., MQTT-like mechanisms) for efficient synchronization. The architecture is designed for **scalable, modular integration** of heterogeneous IoT/BCS devices."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed using a **scalable, service-oriented architecture** that leverages **middleware (Hono/Ditto)** and **visualization tools (Unreal Engine)**. The framework supports:
  - **Automated deployment pipelines** for generating runtime artifacts from BIM models.
  - **Modular service integration** via **standardized extension points**, enabling **scalable and future-proof deployments**.
  - **Centralized or decentralized hosting** depending on the complexity of the infrastructure and operational requirements.
  While the document does not specify **cloud/edge deployment strategies**, **Docker containers**, or **Kubernetes orchestration**, the emphasis on **scalability** and **modularity** implies a **containerized or microservices-based deployment model** to accommodate heterogeneous AECO environments."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT framework supports **horizontal integration** with external information systems through:
  - **Standardized data exchange protocols** enabled by **Eclipse Hono/Ditto**, ensuring interoperability with **heterogeneous systems** (e.g., ERP, CMMS, IoT platforms).
  - **BIM as a semantic backbone**, facilitating integration with **AECO-specific standards** (e.g., IFC, COBie) for cross-domain collaboration.
  - **Modular architecture** with **extension points** for connecting to **federated DT ecosystems** or other digital infrastructure systems.
  While specific standards (e.g., **OPC UA, IFC**) are not explicitly listed, the framework is designed to **bridge siloed data sources** and enable **seamless information exchange** across the AECO value chain."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT framework adheres to **BIM as the primary standardization backbone** for semantic consistency and interoperability in the AECO domain. It also incorporates:
  - **Standardized extension points** for modular service integration, ensuring compatibility with **domain-specific workflows**.
  - **Automated model-driven transformations** that align with **industry best practices** for DT deployment.
  While specific standards (e.g., **IFC, COBie, ISO 27001**) are not explicitly mentioned, the framework is designed to **leverage existing AECO standards** and **promote interoperability** across heterogeneous systems. The emphasis on **BIM-centric deployment** ensures alignment with **regulatory mandates** and **policy initiatives** driving digital transformation in the construction industry."
]