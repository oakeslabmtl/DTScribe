import DTDFVocab from "http://example.org/DTDFVocab#"

/// C3: Physical sensing components
instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Light-level sensor embedded in the BIM model, used in TwinLight and BOREALIS projects to provide runtime illumination data.",
    DTDFVocab:producedData LightLevelDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the BIM model, used in TwinLight and BOREALIS projects to provide runtime occupancy data.",
    DTDFVocab:producedData OccupancyDataTransmitted
]

/// C4: Physical-to-virtual interaction (DataTransmitted)
instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

/// C10: Models/Data
instance LightLevelData : DTDFVocab:Data [
    base:desc "Live light-level data stream received from LightLevelSensor.",
    DTDFVocab:fromData LightLevelDataTransmitted,
    DTDFVocab:inputTo EclipseHonoEnabler, BIMSemanticBackboneEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy data stream received from OccupancySensor.",
    DTDFVocab:fromData OccupancyDataTransmitted,
    DTDFVocab:inputTo EclipseHonoEnabler, BIMSemanticBackboneEnabler
]

instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Static BIM model enriched with control semantics for the Living Lab building.",
    DTDFVocab:inputTo ModelDrivenEngineeringEnabler, BIMSemanticBackboneEnabler
]

instance DittoRuntimeModel : DTDFVocab:Model [
    base:desc "Runtime representation of the twin stored in Eclipse Ditto.",
    DTDFVocab:inputTo EclipseDittoEnabler, ModelDrivenEngineeringEnabler
]

instance RuntimeArtifactsModel : DTDFVocab:Model [
    base:desc "Generated runtime artifacts produced by model-to-text transformations.",
    DTDFVocab:inputTo ModelDrivenEngineeringEnabler
]

/// C2: Acting components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Dimmable lighting control device modeled in BIM, capable of receiving brightness commands from the digital twin."
]

instance LightingSwitchActuator : DTDFVocab:ActingComponent [
    base:desc "On/off lighting switch modeled in BIM, capable of receiving toggle commands from the digital twin."
]

/// C11: Enablers (tooling and enablers)
instance BIMSemanticBackboneEnabler : DTDFVocab:Enabler [
    base:desc "BIM serves as the semantic backbone providing structural and semantic context.",
    DTDFVocab:enables RealTimeMonitoringService, VisualizationService
]

instance ModelDrivenEngineeringEnabler : DTDFVocab:Enabler [
    base:desc "Model-driven engineering pipeline that validates, transforms, and deploys twins.",
    DTDFVocab:enables RealTimeMonitoringService, SimulationService, PredictiveAnalyticsService, OptimizationService
]

instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides MQTT/AMQP connectivity for bidirectional data exchange.",
    DTDFVocab:enables RealTimeMonitoringService, SimulationService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages twin state, persisting runtime models and handling commands.",
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, OptimizationService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 delivers immersive 3‑D visualization of the building twin.",
    DTDFVocab:enables VisualizationService
]

instance ODTEMetricEnabler : DTDFVocab:Enabler [
    base:desc "ODTE metric evaluates twin fidelity and operational effectiveness.",
    DTDFVocab:enables OptimizationService
]

/// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides near‑real‑time monitoring of sensor streams and twin state.",
    DTDFVocab:provides DecisionSupportInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs simulation scenarios of building operation using the runtime model.",
    DTDFVocab:provides DecisionSupportInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Executes predictive analytics to forecast occupancy and lighting needs.",
    DTDFVocab:provides PredictiveAnalyticsInsight, LightingControlAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimizes building operation to reduce operational costs.",
    DTDFVocab:provides OptimizationInsight, LightingControlAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Delivers immersive 3‑D visualization via Unreal Engine 5.",
    DTDFVocab:provides DecisionSupportInsight
]

/// C17: Insights
instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics insight that forecasts future building usage patterns."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization insight that identifies energy‑saving opportunities."
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Decision‑making insight supporting facility managers to reduce operational costs."
]

/// C17: Actions
instance LightingControlAction : DTDFVocab:Action [
    base:desc "Automatic lighting control command issued to dimmers or switches based on twin recommendations.",
    DTDFVocab:IsAutomatic true
]

/// Environment (system under study)
instance LivingLabBuildingEnvironment : DTDFVocab:Environment [
    base:contains LightLevelSensor, OccupancySensor, LightingDimmerActuator, LightingSwitchActuator,
               EnrichedBIMModel, DittoRuntimeModel, RuntimeArtifactsModel
]

/// Component representing multiplicities (one twin per device)
instance TwinStoreComponent : DTDFVocab:Component [
    base:desc "Central Eclipse Ditto store holding one twin instance per discovered device (sensor or actuator) as defined by multiplicities."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin are sent back through Eclipse Hono/Ditto to the physical actuators, enabling runtime control of building systems."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous near‑real‑time synchronization of sensor streams and control actions; no discrete batch intervals are specified."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular service‑oriented architecture consisting of a BIM‑derived model extraction layer, a Hono/Ditto configurator, a runtime twin store, and a visualization front‑end, linked through standardized extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the full building lifecycle: design (BIM creation), construction (device commissioning), and operation (runtime monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric is used to quantify how well the Digital Twin reflects its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Connectivity is realized through Eclipse Hono, which mediates device communication (via its protocol adapters) to Eclipse Ditto, enabling bidirectional data flow."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Relies on BIM as an industry‑standard modeling format and open‑source frameworks (Eclipse Hono, Ditto) that adhere to interoperable data exchange standards."
]