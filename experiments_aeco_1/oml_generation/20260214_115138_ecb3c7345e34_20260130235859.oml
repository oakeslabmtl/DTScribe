// C2: Acting Components
instance ValveActuator : DTDFVocab:ActingComponent [
    base:desc "BIM-modeled valve actuator with on/off and proportional control, addressing derived from BIM metadata"
]

instance DamperActuator : DTDFVocab:ActingComponent [
    base:desc "BIM-modeled damper actuator with set‑point adjustment, safety interlocks encoded in the BIM model"
]

instance MotorizedBlindActuator : DTDFVocab:ActingComponent [
    base:desc "BIM-modeled motorized blind actuator, on/off capability, addressable via BIM‑derived identifiers"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled within BIM, streams high‑frequency measurements via the real‑time data exchange layer"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor modeled within BIM, provides continuous humidity readings to the Digital Twin"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor (e.g., PIR) embedded in BIM, delivers post‑occupancy status updates in real time"
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Models/Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Stream of temperature values received from TemperatureSensor"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DataIngestionHono
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Stream of humidity values received from HumiditySensor"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo DataIngestionHono
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy status stream generated by OccupancySensor"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo DataIngestionHono
]

instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Geometric representation of rooms, walls and building elements extracted from BIM"
    DTDFVocab:inputTo VisualizationEngine
]

instance BehavioralControlModel : DTDFVocab:Model [
    base:desc "Runtime behavioral model generated from control logic defined by building control engineers"
    DTDFVocab:inputTo TwinBrokerDitto
]

instance ThermalSimulationModel : DTDFVocab:Model [
    base:desc "Thermal performance simulation model derived from BIM geometry and control behavior"
    DTDFVocab:inputTo SimulationEngine
]

// C11: Enablers
instance DataIngestionHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono service that ingests IoT sensor streams and forwards them to the Twin"
    DTDFVocab:enables RealTimeMonitoringService, FaultDetectionAnalyticsService
]

instance TwinBrokerDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto information broker managing twin state, command routing and telemetry persistence"
    DTDFVocab:enables ControlActionExecutionService, ScenarioAnalysisService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine based high‑fidelity 3D visualisation platform delivering interactive twin views"
    DTDFVocab:enables InteractiveVisualizationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation module that consumes thermal models and produces performance forecasts"
    DTDFVocab:enables BuildingPerformanceSimulationService, EnergyOptimizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of building sensor streams for facility managers"
    DTDFVocab:provides OccupancyPatternInsight
]

instance FaultDetectionAnalyticsService : DTDFVocab:Service [
    base:desc "Runs predictive analytics on sensor telemetry to detect faults and energy waste"
    DTDFVocab:provides FaultDetectionInsight
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Executes building performance simulations based on BIM geometry and control models"
    DTDFVocab:provides EnergySavingInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimises operational set‑points across HVAC and lighting for energy savings"
    DTDFVocab:provides EnergySavingInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Delivers rich interactive 3D visualisation of the digital twin for designers and occupants"
    // No explicit insight, visualisation itself is the output
]

instance ControlActionExecutionService : DTDFVocab:Service [
    base:desc "Translates DT commands into BCS control signals for remote actuation of valves, dampers, etc."
    DTDFVocab:provides AdjustHVACSetpointAction
]

instance ScenarioAnalysisService : DTDFVocab:Service [
    base:desc "Enables what‑if scenario analysis and presents outcome insights"
    DTDFVocab:provides ScenarioOutcomeInsight
]

// C17: Insights/Actions
instance OccupancyPatternInsight : DTDFVocab:Insight [
    base:desc "Insight derived from occupancy sensor streams indicating space utilisation patterns"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight identifying likely equipment faults and abnormal energy consumption"
]

instance EnergySavingInsight : DTDFVocab:Insight [
    base:desc "Insight recommending set‑point adjustments and operational strategies for reduced energy use"
]

instance ScenarioOutcomeInsight : DTDFVocab:Insight [
    base:desc "Insight summarising results of simulated operational scenarios"
]

instance AdjustHVACSetpointAction : DTDFVocab:Action [
    base:desc "Action to adjust HVAC thermostat set‑point based on optimization recommendations"
    DTDFVocab:IsAutomatic false
]

instance OpenDamperAction : DTDFVocab:Action [
    base:desc "Action to open a damper actuator to increase airflow"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT supports bidirectional data exchange, allowing control signals generated in the digital environment to be sent back to physical building systems. Facility managers interact with the deployed DT to perform real‑time monitoring and issue control actions, which are propagated to the building control infrastructure. The document does not provide details on command types, message formats, validation, authentication, feedback loops, conflict resolution, or execution confirmation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The document states that DTs provide real‑time insights by integrating runtime data with static models, implying continuous updating of the digital representation, but it does not specify synchronization frequencies, latency requirements, or temporal granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a model‑driven, layered architecture where a central DT Framework acts as a hub orchestrating all components. The lower layer hosts the BIM representation of the asset; the middleware layer integrates Eclipse Hono for device connectivity and Eclipse Ditto for digital‑twin state management; the upper layer uses Unreal Engine for immersive visualization. The framework coordinates resource allocation, component integration, and service composition, providing system‑wide orchestration through the central hub."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a continuous life‑cycle that starts with device modeling inside the BIM environment (definition of sensors, actuators, and controllers), proceeds to extraction of a structured representation through model‑driven engineering (MDE) transformations, automatically generates deployable Digital Twin artifacts, and culminates in runtime operation where real‑time data exchange keeps the physical building and its twin synchronized. Transition between phases is managed by the MDE pipeline that maps enriched BIM models to executable DT components, and the overall lifecycle is guided by the functional requirements (F_X) that prescribe each stage, although explicit governance mechanisms are not detailed in the document."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assured through a validation step that compares the digital twin’s behavior against the physical building using the Overall Digital Twin Entanglement (ODTE) metric, which quantifies how closely the DT reflects its counterpart. Validation includes checking geometric alignment, synchronizing sensor streams, and verifying actuator response against expected control logic. Uncertainty sources such as sensor noise and model abstraction are acknowledged, and the ODTE score is used to guide quality‑assurance activities, including error detection, model refinement, and re‑deployment of updated DT artifacts."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The document mentions integration of static models with runtime data within the DT, but it does not detail any data exchange protocols, interoperability standards, or connections to external systems."
]