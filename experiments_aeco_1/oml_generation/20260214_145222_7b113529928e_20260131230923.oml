// C2: Acting Components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Directly integrated into BIM models to represent physical HVAC devices, controlled via DT-generated artifacts derived from MDE transformations. Enables real-time adjustments through automated deployment of control logic from BIM-based behavioral models."
]

instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "BIM-embedded actuator representing motorized lighting systems, configured within BIM environment with constraints defined by BIM specifications. Supports remote operation via standardized DT framework extension points."
]

instance MotorizedShadeActuator : DTDFVocab:ActingComponent [
    base:desc "Physical shading devices modeled in BIM with dynamic actuation capabilities enabled through DT-generated control algorithms. Addressed via semantic labeling in BIM models for precise digital-physical mapping."
]

// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Building Control System sensor parameterized in BIM models with ±0.5°C precision, spatially mapped within BIM geometry. Supports dynamic calibration via real-time data validation against DT analytical models."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "BCS sensor for humidity measurement with BIM-defined accuracy specifications, integrated within BIM environment for spatial correlation. Supports event-triggered data transmission for threshold breaches."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Customizable sensor for occupancy detection with configurable sampling frequencies, mapped to BIM elements for spatial alignment. Supports cross-correlation validation via multiple sensor sources."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Energy meter sensor with ±X% accuracy defined in BIM models, integrated via DT framework's modular architecture. Supports periodic polling for non-critical data analysis."
    DTDFVocab:producedData EnergyDataTransmitted
]

instance StructuralStressSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency sensor for structural monitoring with sub-second latency requirements, parameterized in BIM for continuous real-time synchronization. Supports anomaly detection via statistical thresholds."
    DTDFVocab:producedData StructuralDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance StructuralDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralStressSensor
]

instance DeviceStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor, HumiditySensor, OccupancySensor
]

// C10: Models/Data
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Foundational 3D model representing static building structures and spatial configurations derived from BIM, serving as the base layer for hierarchical DT relationships."
    DTDFVocab:inputTo BIMToolingEnabler
]

instance BCSBehavioralModel : DTDFVocab:Model [
    base:desc "Dynamic control logic representation encapsulating sensors, actuators, and controllers within BIM environment, defined by Building Control Engineers."
    DTDFVocab:inputTo MDETransformationEnabler
]

instance AnalyticalSimulationModel : DTDFVocab:Model [
    base:desc "Automated transformation of enriched BIM models into deployable DT artifacts (e.g., simulation models, control algorithms) using MDE techniques."
    DTDFVocab:inputTo PerformanceSimulationService
]

instance PhysicalAssetData : DTDFVocab:Data [
    base:desc "Centralized dataset aggregating real-time sensor data streams from physical infrastructure, synchronized with BIM models through automated ETL pipelines."
    DTDFVocab:fromData TemperatureDataTransmitted, HumidityDataTransmitted, OccupancyDataTransmitted, EnergyDataTransmitted, StructuralDataTransmitted, DeviceStatusDataTransmitted
    DTDFVocab:inputTo DataSynchronizationEnabler
]

instance BIMAlignedData : DTDFVocab:Data [
    base:desc "Structured data mapping raw sensor inputs to BIM-aligned digital twins, ensuring spatial and semantic consistency through graph-based data fusion."
    DTDFVocab:fromData DeviceStatusDataTransmitted
    DTDFVocab:inputTo ClashDetectionService
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Real-time data integration platform enabling live synchronization between physical assets and digital twins via IoT data ingestion and management."
    DTDFVocab:enables RealTimeMonitoringService, OperationalControlService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Unified digital twin synchronization platform managing data models and ensuring consistency between physical and digital representations."
    DTDFVocab:enables DataSynchronizationService
]

instance MDETransformationEnabler : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering framework automating transformations of BIM models into deployable DT artifacts, ensuring semantic consistency across lifecycle stages."
    DTDFVocab:enables ControlLogicService, AnalyticalModelingService
]

instance BIMToolingEnabler : DTDFVocab:Enabler [
    base:desc "BIM-based development framework supporting device-specific DT deployment via standardized BIM tools, enabling modular architecture extensions."
    DTDFVocab:enables DeviceSpecificDTService
]

instance DataSynchronizationEnabler : DTDFVocab:Enabler [
    base:desc "Centralized data management system facilitating bidirectional exchange between physical infrastructure and DT through real-time synchronization capabilities."
    DTDFVocab:enables DataIntegrationService
]

instance ControlLogicEnabler : DTDFVocab:Enabler [
    base:desc "Modular architecture enabling automated deployment of control logic from BIM-based behavioral models to physical actuators."
    DTDFVocab:enables AutomationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous data integration service enabling live synchronization and operational control of physical assets via their digital counterparts."
    DTDFVocab:provides LiveSynchronizationInsight, OperationalControlAction
]

instance OperationalControlService : DTDFVocab:Service [
    base:desc "Real-time observation and management service for physical assets through their digital representations, supporting remote actuation."
    DTDFVocab:provides RemoteActuationAction, FaultDetectionInsight
]

instance PerformanceSimulationService : DTDFVocab:Service [
    base:desc "Performance analysis service supporting optimization of building systems (energy, structural) using semantically rich BIM-aligned models."
    DTDFVocab:provides EnergyOptimizationInsight, StructuralAnalysisInsight
]

instance ClashDetectionService : DTDFVocab:Service [
    base:desc "Design conflict identification service enabling early detection of inefficiencies via collaborative BIM modeling."
    DTDFVocab:provides DesignConflictInsight
]

instance AutomationService : DTDFVocab:Service [
    base:desc "Model-driven automation service reducing manual intervention through reproducible DT deployments and operational control."
    DTDFVocab:provides ProcessAutomationAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D/4D modeling service providing interactive visualizations of building models and operational data."
    DTDFVocab:provides SpatialVisualizationInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Lifecycle forecasting service enabling predictive maintenance through real-time monitoring and AI-driven analytics."
    DTDFVocab:provides MaintenanceForecastingInsight
]

// C17: Insights/Actions
instance LiveSynchronizationInsight : DTDFVocab:Insight [
    base:desc "Real-time bidirectional data exchange ensuring consistent synchronization between physical assets and their digital twins."
]

instance OperationalControlAction : DTDFVocab:Action [
    base:desc "Remote actuation capabilities enabling facility managers to operate physical infrastructure through the DT interface."
    DTDFVocab:IsAutomatic false
]

instance RemoteActuationAction : DTDFVocab:Action [
    base:desc "Standardized extension point-based remote control of physical actuators via DT framework APIs."
    DTDFVocab:IsAutomatic true
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection insights generated through statistical thresholds and machine learning models for data quality assurance."
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Performance analysis results identifying energy consumption patterns and optimization opportunities in building systems."
]

instance StructuralAnalysisInsight : DTDFVocab:Insight [
    base:desc "Structural health monitoring insights derived from real-time stress data analysis and predictive modeling."
]

instance DesignConflictInsight : DTDFVocab:Insight [
    base:desc "Early detection of design conflicts and inefficiencies through collaborative BIM modeling and clash detection algorithms."
]

instance ProcessAutomationAction : DTDFVocab:Action [
    base:desc "Automated deployment of control logic from BIM-based models to physical systems, reducing manual configuration."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceForecastingInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance recommendations based on real-time sensor data and AI-driven analytics for equipment health forecasting."
]

instance SpatialVisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive 3D/4D visualizations enabling stakeholders to interact with building models and operational data in real-time."
]

instance DocumentationGenerationAction : DTDFVocab:Action [
    base:desc "Automated generation of project documentation including as-built models and compliance reports from BIM-aligned data."
    DTDFVocab:IsAutomatic true
]

// Additional Services and Enablers
