// C2: Acting Components
instance OccupancyControlActuator : DTDFVocab:ActingComponent [
    base:desc "Building Control System actuator for occupancy-based HVAC and lighting control embedded in physical building infrastructure, integrated with reinforcement learning strategies for user-centered control"
]

instance LightingActuator : DTDFVocab:Actuator [
    base:desc "Modular lighting control unit with adaptive dimming capabilities, integrated with BIM for tenant-specific occupancy rules and BOREALIS reinforcement learning optimization"
]

instance HVACControlActuator : DTDFVocab:Actuator [
    base:desc "HVAC control unit with dynamic setpoint adjustment capabilities, configured via BIM for zone-specific occupancy and environmental conditions"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy temperature sensors deployed within building infrastructure for real-time environmental monitoring, feeding data via Eclipse Hono to the digital twin"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ level sensors measuring indoor air quality for occupancy detection and ventilation optimization, synchronized with BIM tenant metadata"
    DTDFVocab:producedData CO2DataTransmitted
]

instance LightIntensitySensor : DTDFVocab:SensingComponent [
    base:desc "Ambient light intensity sensors detecting natural and artificial lighting conditions for adaptive control strategies"
    DTDFVocab:producedData LightIntensityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy detection sensors (e.g., motion sensors) providing real-time presence data for dynamic building control logic"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance SmartThermostat : DTDFVocab:SensingComponent [
    base:desc "Smart thermostat with occupancy-aware temperature regulation, interfacing with BIM for tenant-specific control configurations"
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Data transmission
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor, SmartThermostat
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance LightIntensityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightIntensitySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance ControlCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingActuator, HVACControlActuator
]

// C10: Models/Data
instance BIMStaticModel : DTDFVocab:Model [
    base:desc "3D spatial and functional BIM model of the LEED Platinum academic building containing geometry, topology, and relationships for the digital twin backbone"
]

instance RuntimeMetadataModel : DTDFVocab:Model [
    base:desc "Automatically generated runtime metadata model enriched with sensor/actuator configurations and control logic from BIM via model-driven transformations"
]

instance SensorMetadataData : DTDFVocab:Data [
    DTDFVocab:fromData TemperatureDataTransmitted, CO2DataTransmitted, LightIntensityDataTransmitted, OccupancyDataTransmitted
    DTDFVocab:inputTo AnalyticsEnabler
]

instance ControlLogicData : DTDFVocab:Data [
    DTDFVocab:fromData ControlCommandDataTransmitted
    DTDFVocab:inputTo ReinforcementLearningEnabler
]

instance OperationalDataPool : DTDFVocab:Data [
    DTDFVocab:fromData TemperatureDataTransmitted, CO2DataTransmitted, LightIntensityDataTransmitted, OccupancyDataTransmitted
]

// C11: Enablers
instance BIMMetadataEnabler : DTDFVocab:Enabler [
    base:desc "Model-driven engineering platform automating BIM-to-runtime metadata transformations for sensor/actuator configuration via MDE transformations"
    DTDFVocab:enables RuntimeInterfaceGeneratorService
]

instance EclipseHonoMiddleware : DTDFVocab:Enabler [
    base:desc "Real-time middleware platform (Eclipse Hono) enabling bidirectional communication between physical sensors/actuators and digital twin via standardized protocols"
    DTDFVocab:enables DataExchangeService
]

instance DittoPlatform : DTDFVocab:Enabler [
    base:desc "Standardized digital twin deployment platform (Ditto) supporting service orchestration and interoperability across heterogeneous systems"
    DTDFVocab:enables ServiceOrchestrationService
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Immersive 3D visualization environment (Unreal Engine 5) for interactive building state monitoring and control"
    DTDFVocab:enables VisualizationService
]

instance ReinforcementLearningEnabler : DTDFVocab:Enabler [
    base:desc "BOREALIS reinforcement learning framework integrating post-occupancy sensor data for adaptive control strategies (e.g., energy optimization)"
    DTDFVocab:enables AdaptiveControlService
]

instance AnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Data analytics platform processing real-time operational data for predictive insights and optimization recommendations"
    DTDFVocab:enables PredictiveAnalyticsService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Immersive 3D visualization of building operational state via Unreal Engine 5 for live diagnostics and control by Facility Managers"
    DTDFVocab:provides LiveVisualizationInsight, InteractiveDiagnosticsAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Adaptive control strategy service using reinforcement learning to optimize energy consumption, visual comfort, and non-visual health effects"
    DTDFVocab:provides EnergyOptimizationInsight, ComfortOptimizationAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "End-to-end automation of digital twin pipeline (excluding initial BIM modeling) for building performance simulation across life cycle stages"
    DTDFVocab:provides PerformanceSimulationInsight
]

instance CustomServiceIntegration : DTDFVocab:Service [
    base:desc "Modular extension point for domain-specific services (e.g., IoT integration, analytics plugins) via standardized API interfaces"
    DTDFVocab:provides DomainSpecificServiceAction
]

instance DataExchangeService : DTDFVocab:Service [
    base:desc "Real-time bidirectional data exchange between physical sensors and digital twin via Eclipse Hono/Ditto middleware"
    DTDFVocab:provides OperationalDataInsight
]

instance RuntimeInterfaceGeneratorService : DTDFVocab:Service [
    base:desc "Automated metadata extraction from BIM to configure runtime interfaces for sensor/actuator communication"
    DTDFVocab:provides ConfigurationInsight
]

instance AdaptiveControlService : DTDFVocab:Service [
    base:desc "Service implementing reinforcement learning-based adaptive control strategies for energy optimization and comfort management"
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service providing immersive 3D visualization capabilities for building state monitoring and control"
]

// C17: Insights/Actions
instance LiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time 3D visualization of building operational state (temperature, occupancy, lighting) for immediate diagnostics and control decisions"
]

instance InteractiveDiagnosticsAction : DTDFVocab:Action [
    base:desc "Facility Manager interaction with Unreal Engine visualization to adjust building parameters in real-time"
    DTDFVocab:IsAutomatic false
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Predictive analysis of energy consumption patterns and optimization recommendations via reinforcement learning algorithms"
]

instance ComfortOptimizationAction : DTDFVocab:Action [
    base:desc "Automated adjustment of HVAC/lighting parameters to maintain optimal comfort levels based on occupancy and environmental data"
    DTDFVocab:IsAutomatic true
]

instance PerformanceSimulationInsight : DTDFVocab:Insight [
    base:desc "Simulated building performance metrics across life cycle stages (design, operation, refurbishment) derived from digital twin data"
]

instance ConfigurationInsight : DTDFVocab:Insight [
    base:desc "Automated generation of runtime configurations from BIM metadata for sensor/actuator integration"
]

instance OperationalDataInsight : DTDFVocab:Insight [
    base:desc "Real-time operational metrics (temperature, CO₂, occupancy) feeding into predictive analytics and control strategies"
]

instance DomainSpecificServiceAction : DTDFVocab:Action [
    base:desc "Modular extension of digital twin functionality via domain-specific plugins (e.g., IoT integrations, custom analytics)"
    DTDFVocab:IsAutomatic true
]

// C12: Environment
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains BIMStaticModel, RuntimeMetadataModel
]

instance OperationalEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, CO2Sensor, LightIntensitySensor, OccupancySensor,
        LightingActuator, HVACControlActuator, EclipseHonoMiddleware, DittoPlatform,
        BIMMetadataEnabler, ReinforcementLearningEnabler, AnalyticsEnabler, UnrealEngineVisualization
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals and optimization commands generated by the digital twin are transmitted back to the physical building infrastructure via the same middleware (Eclipse Hono/Ditto) to execute real-time adjustments. This includes automated control logic for lighting systems, HVAC adjustments, and other building automation tasks. The framework ensures seamless integration with BCS components by embedding domain-specific control semantics directly into BIM models (e.g., TwinLight project), enabling automated commissioning and bidirectional communication."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates on a **real-time synchronization scale**, ensuring **sub-second latency** for critical data exchanges between physical assets and the DT. Real-time data integration via **Eclipse Hono/Ditto middleware** enables continuous bidirectional communication, supporting **live monitoring, predictive analytics, and adaptive control** without latency-induced delays."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated as a **service-oriented platform** with a layered architecture that couples BIM with middleware (Eclipse Hono/Ditto) for real-time data synchronization. It enables modular integration of custom services and sub-twins, facilitating a decentralized yet interoperable deployment model where each component communicates via standardized interfaces."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin spans all life cycle stages of the building: 1. **Design phase**: Enriched BIM models incorporate static and dynamic BCS components (e.g., sensors/actuators) for pre-deployment simulation and clash detection. 2. **Construction phase**: Automated extraction of device metadata from BIM enables real-time commissioning and integration of physical sensors/actuators. 3. **Operation phase**: Continuous synchronization with real-time operational data (e.g., post-occupancy sensor feedback) for adaptive control and performance optimization (e.g., BOREALIS’s iterative reinforcement learning). 4. **Refurbishment phase**: The modular architecture supports dynamic updates and integration of new services without redeployment."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured through **model-driven transformations** that automate the alignment of BIM models with runtime data. The **ODTE metric** quantifies the DT’s entanglement with the physical system, addressing semantic drift by validating consistency between static BIM and dynamic operational data. Model-driven engineering (MDE) enhances maintainability and reduces cognitive overhead, though uncertainty management is not explicitly addressed in the provided context."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT employs a **layered system architecture** that integrates BIM with middleware (Eclipse Hono/Ditto) for bidirectional communication. The technical connection relies on **real-time protocols** (e.g., for sensor-to-DT data exchange) and a modular design that supports extensibility via standardized interfaces. Network protocols are abstracted through middleware, ensuring scalability and interoperability across heterogeneous systems."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is hosted on a **scalable, service-oriented platform** with the following deployment characteristics: 1. **Middleware integration**: Eclipse Hono and Ditto provide real-time data exchange and service orchestration. 2. **Visualization**: Unreal Engine 5 enables interactive 3D visualization of the building’s operational state. 3. **Modular deployment**: Standardized extension points allow DT Engineers to integrate custom services (e.g., IoT plugins, analytics tools) without redeploying the core DT. 4. **Runtime configuration**: Dynamic adjustments are supported via middleware and modular architecture, enabling adaptability to evolving operational requirements."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The digital twin integrates horizontally with: 1. **External DTs**: Via standardized extension points to enable interoperability with other digital twin ecosystems (e.g., IoT platforms, analytics tools). 2. **Building Information Modeling (BIM) systems**: Seamless integration with BIM tools (e.g., Revit) for enriched modeling and real-time synchronization. 3. **IoT and sensor networks**: Middleware (Eclipse Hono/Ditto) facilitates bidirectional communication with physical sensors/actuators deployed across the building infrastructure. 4. **Analytics and control systems**: Custom services can integrate with third-party analytics tools or reinforcement learning frameworks (e.g., BOREALIS) for advanced optimization."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adheres to **Building Information Modeling (BIM)** standards as the semantic backbone and leverages **Model-Driven Engineering (MDE)** principles for abstraction and automation. Standardized extension points facilitate interoperability with middleware (Eclipse Hono/Ditto) and other AECO tools, though specific protocols (e.g., IFC, COBie) are not explicitly mentioned."
]