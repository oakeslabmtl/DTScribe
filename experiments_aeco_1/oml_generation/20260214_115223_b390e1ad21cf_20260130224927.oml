// C3: Physical sensing components
instance BuildingTemperatureSensor : DTDFVocab:Component [
    base:desc "Temperature sensor defined as a BIM model element, with metadata for type and location, streamed continuously to the digital twin."
]

instance OccupancySensor : DTDFVocab:Component [
    base:desc "Occupancy sensor defined as a BIM model element, with metadata for type and location, streamed continuously to the digital twin."
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance RealTimeDataExchangeLayer : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingTemperatureSensor, OccupancySensor
]

// C2: Acting components
instance HVACActuator : DTDFVocab:Component [
    base:desc "HVAC actuator modeled in BIM, addressable by the digital twin to issue heating, ventilation and cooling commands."
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Component [
    base:desc "Provides continuous monitoring of sensor streams and exposes current building performance.",
    DTDFVocab:provides BuildingPerformanceInsight, AdjustHVACAction
]

instance VisualizationService : DTDFVocab:Component [
    base:desc "Delivers interactive 3D visualisation of the digital twin for facility managers and designers.",
    DTDFVocab:provides SpatialVisualizationInsight
]

instance FaultDetectionService : DTDFVocab:Component [
    base:desc "Applies predictive analytics to sensor data for early fault detection.",
    DTDFVocab:provides FaultDetectionInsight, TriggerFaultAlertAction
]

instance PhysicsSimulationService : DTDFVocab:Component [
    base:desc "Runs physics‑based simulation of building performance using BIM geometry and control logic.",
    DTDFVocab:provides SimulationInsight
]

instance EnergyOptimizationService : DTDFVocab:Component [
    base:desc "Optimises energy consumption and occupant comfort across the building lifecycle.",
    DTDFVocab:provides EnergySavingInsight, AdjustHVACAction
]

// C11: Enablers
instance BIMModelRepository : DTDFVocab:Enabler [
    base:desc "BIM repository providing geometric and semantic models for the twin.",
    DTDFVocab:enables VisualizationService
]

instance EclipseHonoIngestion : DTDFVocab:Enabler [
    base:desc "Eclipse Hono component that securely ingests IoT sensor streams and forwards them to the twin runtime.",
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoStateManagement : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto instance managing twin state, bidirectional data exchange and orchestrating services.",
    DTDFVocab:enables RealTimeMonitoringService, FaultDetectionService, PhysicsSimulationService, EnergyOptimizationService
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine rendering engine delivering high‑fidelity, interactive 3D visualisation of the building.",
    DTDFVocab:enables VisualizationService
]

// C5: Data entities
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature measurements originating from the BuildingTemperatureSensor.",
    DTDFVocab:fromData RealTimeDataExchangeLayer,
    DTDFVocab:inputTo EclipseHonoIngestion
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy counts originating from the OccupancySensor.",
    DTDFVocab:fromData RealTimeDataExchangeLayer,
    DTDFVocab:inputTo EclipseHonoIngestion
]

// C10: Models
instance GeometricBIMModel : DTDFVocab:Model [
    base:desc "Geometric representation of the building extracted from the BIM environment.",
    DTDFVocab:inputTo EclipseDittoStateManagement
]

instance BehavioralControlModel : DTDFVocab:Model [
    base:desc "Control logic encoded by Building Control Engineers inside the BIM model.",
    DTDFVocab:inputTo EclipseDittoStateManagement
]

// C14: Environment (Living Lab)
instance LivingLabBuilding : DTDFVocab:Environment [
    base:contains BuildingTemperatureSensor,
                 OccupancySensor,
                 HVACActuator,
                 RealTimeMonitoringService,
                 VisualizationService,
                 FaultDetectionService,
                 PhysicsSimulationService,
                 EnergyOptimizationService,
                 GeometricBIMModel,
                 BehavioralControlModel
]

// C17: Insights
instance BuildingPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight into current thermal comfort, energy use and system status derived from live sensor data."
]

instance SpatialVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight into spatial relationships and asset locations via the 3D interactive view."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating probable equipment faults detected by anomaly analysis of sensor streams."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from physics‑based simulation about projected thermal loads and system behaviour."
]

instance EnergySavingInsight : DTDFVocab:Insight [
    base:desc "Insight recommending energy‑saving set‑points and operational adjustments."
]

// C17: Actions
instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Facility manager‑initiated or automated adjustment of HVAC set‑points through the twin.",
    DTDFVocab:IsAutomatic false
]

instance TriggerFaultAlertAction : DTDFVocab:Action [
    base:desc "Automatic generation of fault alerts and recommended corrective actions.",
    DTDFVocab:IsAutomatic true
]

// C15: Generic Components
instance BIMComponent : DTDFVocab:Component [
    base:desc "Static asset representation managed in the BIM repository."
]

instance IoTIngestionComponent : DTDFVocab:Component [
    base:desc "Component handling secure ingestion of IoT data via Eclipse Hono."
]

instance TwinStateComponent : DTDFVocab:Component [
    base:desc "Component managing twin state and bidirectional synchronization via Eclipse Ditto."
]

instance VisualizationComponent : DTDFVocab:Component [
    base:desc "Component rendering the digital twin using Unreal Engine."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication is supported by the DT Framework, which relays control commands from Facility Managers (or other DT users) to physical building devices. Commands are generated from the digital twin model in Ditto and transmitted through the same Eclipse Hono gateway to the field devices, enabling real‑time monitoring and control. The document does not provide details on command formats, validation, authentication, feedback loops, or execution confirmation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The document states that the Digital Twin provides real‑time insights by continuously integrating runtime data with static models to support predictive analytics across the building lifecycle, but it does not specify synchronization frequencies, latency requirements, or temporal granularity."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a full DT lifecycle composed of (1) device modeling within BIM where sensors, actuators, and controllers are added; (2) model enrichment and transformation using model‑driven engineering (MDE) to extract a structured representation; (3) automatic generation of deployable DT artifacts; (4) deployment and runtime operation where real‑time data exchange keeps the twin synchronized; and (5) ongoing evolution through modular extension points. Transition between stages is managed by the MDE pipeline that converts enriched BIM models into executable twin components, and lifecycle governance is implied by the requirement to support the complete life‑cycle of DT deployment and operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by embedding device definitions and control logic directly into the BIM model, creating a single source of truth. Continuous real‑time synchronization between physical and digital twins functions as an implicit validation mechanism: discrepancies trigger updates. The framework relies on the unified semantic foundation and MDE‑generated artifacts to ensure consistency, but explicit validation, verification, uncertainty quantification, or quality‑assurance procedures are not described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is built on BIM (Building Information Modeling) as the core industry standard for representing buildings and for encoding device information. BIM serves as the semantic basis from which structured DT models are derived. The framework defines standardized extension points (i.e., a modular API contract) to ensure that custom services and analytics can interoperate with the core twin platform. No additional industry standards, certification schemes, or formal compliance frameworks (e.g., IFC, ISO 19650) are mentioned in the document."
]