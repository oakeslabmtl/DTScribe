// C2: Acting Components
instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Automated lighting system actuator configured via DT control logic to adjust lighting levels based on occupancy and reinforcement learning policies for visual comfort optimization."
    base:isContainedIn BuildingInfrastructureEnvironment
]

instance HVACSystem : DTDFVocab:ActingComponent [
    base:desc "Building HVAC system actuator that receives temperature setpoint adjustments from the DT for energy optimization while maintaining occupant comfort."
    base:isContainedIn BuildingInfrastructureEnvironment
]

instance WindowActuator : DTDFVocab:ActingComponent [
    base:desc "Automated window system actuator controlled by the DT to optimize natural lighting and ventilation based on occupancy patterns and environmental conditions."
    base:isContainedIn BuildingInfrastructureEnvironment
]

// C3: Physical Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded occupancy sensor in building infrastructure that detects presence via PIR technology and transmits real-time occupancy data to the DT via MQTT."
    DTDFVocab:producedData OccupancyDataTransmitted
    base:isContainedIn BuildingInfrastructureEnvironment
]

instance TemperatureHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded environmental sensor measuring temperature and humidity levels, transmitting real-time data to the DT for HVAC optimization and comfort monitoring."
    DTDFVocab:producedData EnvironmentalDataTransmitted
    base:isContainedIn BuildingInfrastructureEnvironment
]

instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded light sensor measuring ambient light levels to enable adaptive lighting control policies through the DT."
    DTDFVocab:producedData LightDataTransmitted
    base:isContainedIn BuildingInfrastructureEnvironment
]

instance EnergyMonitor : DTDFVocab:SensingComponent [
    base:desc "Building energy consumption monitor that tracks real-time energy usage across systems and transmits aggregated data to the DT for optimization analysis."
    DTDFVocab:producedData EnergyDataTransmitted
    base:isContainedIn BuildingInfrastructureEnvironment
]

// C4: Physical-to-Virtual Data Transmission
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
    DTDFVocab:fromData OccupancyData
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureHumiditySensor
    DTDFVocab:fromData EnvironmentalData
]

instance LightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
    DTDFVocab:fromData LightData
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMonitor
    DTDFVocab:fromData EnergyData
]

// C10: Models/Data
instance BIMModel : DTDFVocab:Model [
    base:desc "Semantic-rich 3D Building Information Model containing geometric, topological, and device metadata including sensor placements, actuator configurations, and control logic annotations."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
    DTDFVocab:inputTo UnrealEngine5
    base:contains RuntimeDataModel
    base:isContainedIn DigitalTwinEnvironment
]

instance RuntimeDataModel : DTDFVocab:Model [
    base:desc "Model-driven generated data schema defining standardized formats for sensor readings, control commands, and system states used by Eclipse Hono/Ditto middleware."
    DTDFVocab:inputTo EclipseHono
    DTDFVocab:inputTo Ditto
    base:isContainedIn DigitalTwinEnvironment
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Domain-specific policy model containing embedded control logic for lighting schedules, HVAC setpoints, and reinforcement learning policies from BOREALIS project."
    DTDFVocab:inputTo ReinforcementLearningService
    DTDFVocab:inputTo Ditto
    base:isContainedIn DigitalTwinEnvironment
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time and historical occupancy patterns extracted from sensor data used for dynamic space management and resource allocation."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo SpaceUtilizationService
    DTDFVocab:inputTo ODTEValidationService
    base:isContainedIn DigitalTwinEnvironment
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Aggregated temperature, humidity, and light data used for energy optimization and occupant comfort analysis."
    DTDFVocab:fromData EnvironmentalDataTransmitted
    DTDFVocab:inputTo EnergyOptimizationService
    DTDFVocab:inputTo ComfortAnalysisService
    base:isContainedIn DigitalTwinEnvironment
]

instance EnergyData : DTDFVocab:Data [
    base:desc "Real-time and historical energy consumption metrics used for cost-effective operation and compliance monitoring."
    DTDFVocab:fromData EnergyDataTransmitted
    DTDFVocab:inputTo EnergyOptimizationService
    DTDFVocab:inputTo ComplianceMonitoringService
    base:isContainedIn DigitalTwinEnvironment
]

// C11: Enablers
instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model-driven transformation pipeline that automates extraction of domain semantics from BIM models and generates runtime artifacts including middleware configurations and visualization scripts."
    DTDFVocab:enables VisualizationEngine
    base:isContainedIn DigitalTwinEnvironment
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Open-source IoT middleware providing real-time data exchange, device management, and MQTT-based connectivity between physical sensors and the DT."
    DTDFVocab:enables RealTimeMonitoringService
    DTDFVocab:enables PredictiveAnalyticsService
    base:isContainedIn DigitalTwinEnvironment
]

instance Ditto : DTDFVocab:Enabler [
    base:desc "Event-driven data processing platform enabling scalable bidirectional communication between the DT and physical systems for low-latency synchronization."
    DTDFVocab:enables ReinforcementLearningService
    DTDFVocab:enables ControlServiceIntegration
    base:isContainedIn DigitalTwinEnvironment
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "High-fidelity 3D visualization engine providing interactive interfaces for real-time monitoring and control of building operations with sensor data overlays."
    DTDFVocab:enables RealTimeVisualizationService
    DTDFVocab:enables InteractiveControlService
    base:isContainedIn DigitalTwinEnvironment
]

instance ReinforcementLearningService : DTDFVocab:Enabler [
    base:desc "BOREALIS-based reinforcement learning framework implementing adaptive control policies for optimizing energy consumption and occupant comfort."
    DTDFVocab:enables LightingOptimizationService
    DTDFVocab:enables HVACOptimizationService
    base:isContainedIn DigitalTwinEnvironment
]

instance ODTEValidationService : DTDFVocab:Enabler [
    base:desc "Metric validation framework quantifying the alignment between virtual and physical representations to assess DT fidelity and responsiveness."
    DTDFVocab:enables ContinuousValidationService
    DTDFVocab:enables IterativeOptimizationService
    base:isContainedIn DigitalTwinEnvironment
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing interactive 3D visualization of building operations through Unreal Engine 5, enabling real-time monitoring of sensor data and system states."
    DTDFVocab:provides BuildingOperationsInsight
    DTDFVocab:provides SystemStateAction
    base:isContainedIn DigitalTwinEnvironment
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Service implementing real-time adjustments to lighting, HVAC, and shading systems for cost-effective operation while maintaining occupant comfort."
    DTDFVocab:provides EnergyEfficiencyInsight
    DTDFVocab:provides HVACAdjustmentAction
    base:isContainedIn DigitalTwinEnvironment
]

instance OccupantComfortService : DTDFVocab:Service [
    base:desc "Service implementing adaptive control policies using reinforcement learning to balance visual comfort and non-visual health effects based on sensor feedback."
    DTDFVocab:provides VisualComfortInsight
    DTDFVocab:provides LightingAdjustmentAction
    base:isContainedIn DigitalTwinEnvironment
]

instance SpaceUtilizationService : DTDFVocab:Service [
    base:desc "Service providing occupancy-based analytics for dynamic space management and resource allocation optimization."
    DTDFVocab:provides SpaceUtilizationInsight
    DTDFVocab:provides ResourceAllocationAction
    base:isContainedIn DigitalTwinEnvironment
]

instance ComplianceMonitoringService : DTDFVocab:Service [
    base:desc "Service automatically tracking regulatory requirements through runtime data validation against energy codes and accessibility standards."
    DTDFVocab:provides ComplianceStatusInsight
    DTDFVocab:provides RegulatoryAction
    base:isContainedIn DigitalTwinEnvironment
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service enabling implicit equipment health monitoring through sensor data analytics for predictive maintenance."
    DTDFVocab:provides EquipmentHealthInsight
    DTDFVocab:provides MaintenanceRecommendationAction
    base:isContainedIn DigitalTwinEnvironment
]

// C17: Insights/Actions
instance BuildingOperationsInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of all building operational parameters including sensor readings and system states for stakeholder monitoring."
    base:isContainedIn DigitalTwinEnvironment
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Quantitative analysis of energy consumption patterns identifying opportunities for cost-effective operation through system adjustments."
    base:isContainedIn DigitalTwinEnvironment
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Analysis of visual comfort metrics including luminance levels and glare indices to assess occupant satisfaction."
    base:isContainedIn DigitalTwinEnvironment
]

instance SpaceUtilizationInsight : DTDFVocab:Insight [
    base:desc "Occupancy-based analytics revealing space utilization patterns for optimized resource allocation and dynamic management."
    base:isContainedIn DigitalTwinEnvironment
]

instance ComplianceStatusInsight : DTDFVocab:Insight [
    base:desc "Automated assessment of building operations against regulatory requirements including energy codes and accessibility standards."
    base:isContainedIn DigitalTwinEnvironment
]

instance EquipmentHealthInsight : DTDFVocab:Insight [
    base:desc "Predictive analysis of equipment condition based on sensor data patterns identifying potential failures before they occur."
    base:isContainedIn DigitalTwinEnvironment
]

instance SystemStateAction : DTDFVocab:Action [
    base:desc "Automated adjustment of building system states based on real-time monitoring requirements."
    DTDFVocab:IsAutomatic true
    base:isContainedIn DigitalTwinEnvironment
]

instance HVACAdjustmentAction : DTDFVocab:Action [
    base:desc "Real-time temperature and ventilation setpoint adjustments for energy optimization while maintaining comfort."
    DTDFVocab:IsAutomatic true
    base:isContainedIn DigitalTwinEnvironment
]

instance LightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Dynamic lighting level adjustments based on occupancy and reinforcement learning policies for visual comfort optimization."
    DTDFVocab:IsAutomatic true
    base:isContainedIn DigitalTwinEnvironment
]

instance ResourceAllocationAction : DTDFVocab:Action [
    base:desc "Automated reallocation of building resources based on occupancy patterns and utilization analytics."
    DTDFVocab:IsAutomatic true
    base:isContainedIn DigitalTwinEnvironment
]

instance RegulatoryAction : DTDFVocab:Action [
    base:desc "Automated corrective actions triggered when compliance monitoring detects violations of regulatory requirements."
    DTDFVocab:IsAutomatic true
    base:isContainedIn DigitalTwinEnvironment
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Predictive maintenance recommendations generated from equipment health analytics for proactive system maintenance."
    DTDFVocab:IsAutomatic false
    base:isContainedIn DigitalTwinEnvironment
]

// C12: Environment
instance BuildingInfrastructureEnvironment : DTDFVocab:Environment [
    base:desc "Physical building environment containing all operational systems including sensors, actuators, and controlled infrastructure."
    base:contains LightingController
    base:contains HVACSystem
    base:contains WindowActuator
    base:contains OccupancySensor
    base:contains TemperatureHumiditySensor
    base:contains LightSensor
    base:contains EnergyMonitor
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:desc "Virtual representation environment containing all digital components including models, services, and data processing elements."
    base:contains BIMModel
    base:contains RuntimeDataModel
    base:contains ControlLogicModel
    base:contains OccupancyData
    base:contains EnvironmentalData
    base:contains EnergyData
    base:contains EclipseHono
    base:contains Ditto
    base:contains UnrealEngine5
    base:contains ReinforcementLearningService
    base:contains ODTEValidationService
