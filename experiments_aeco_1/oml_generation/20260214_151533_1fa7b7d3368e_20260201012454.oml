    base:contains EnergyOptimizationService
    base:contains OccupantComfortService
    base:contains SpaceUtilizationService
    base:contains ComplianceMonitoringService
    base:contains PredictiveAnalyticsService
    base:contains BuildingOperationsInsight
    base:contains EnergyEfficiencyInsight
    base:contains VisualComfortInsight
    base:contains SpaceUtilizationInsight
    base:contains ComplianceStatusInsight
    base:contains EquipmentHealthInsight
    base:contains SystemStateAction
    base:contains HVACAdjustmentAction
    base:contains LightingAdjustmentAction
    base:contains ResourceAllocationAction
    base:contains RegulatoryAction
    base:contains MaintenanceRecommendationAction
]

