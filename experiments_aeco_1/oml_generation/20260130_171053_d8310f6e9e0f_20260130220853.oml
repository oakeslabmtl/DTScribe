// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded temperature sensor defined in the BIM model, streaming measurements to the twin."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded occupancy sensor defined in the BIM model, streaming measurements to the twin."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded illumination sensor defined in the BIM model, streaming measurements to the twin."
    DTDFVocab:producedData IlluminationDataTransmitted
]

// C4: DataTransmitted
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance AggregatedSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor, OccupancySensor, IlluminationSensor
]

// C5: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature measurement stream (°C) consumed by ingestion pipeline."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy count stream used for space‑usage analytics."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Illuminance (lux) measurement stream used for lighting optimization."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance AggregatedSensorData : DTDFVocab:Data [
    base:desc "Aggregated sensor dataset used for predictive analytics."
    DTDFVocab:fromData AggregatedSensorDataTransmitted
    DTDFVocab:inputTo PredictiveAnalyticsEngine
]

// C2: Acting components
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control device defined in enriched BIM, receives set‑point commands from the twin."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator defined in enriched BIM, receives control commands from the twin."
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono IoT ingestion service (MQTT/HTTP) that receives sensor data from the building."
    DTDFVocab:enables DataIngestionService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital‑twin platform that stores twin state and processes commands."
    DTDFVocab:enables TwinStateManagementService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime for interactive 3D visualisation of the building twin."
    DTDFVocab:enables VisualizationService
]

instance ReinforcementLearningEngine : DTDFVocab:Enabler [
    base:desc "Model‑driven reinforcement‑learning engine that generates optimized lighting control policies."
    DTDFVocab:enables LightingOptimizationService
]

instance PredictiveAnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Engine executing predictive analytics on aggregated sensor data."
    DTDFVocab:enables PredictiveAnalyticsService
]

// C6: Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Real‑time ingestion of sensor streams, updates twin state in Ditto."
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance TwinStateManagementService : DTDFVocab:Service [
    base:desc "Maintains the digital‑twin representation of building components and sensor values."
    DTDFVocab:provides TwinStateInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides interactive 3D visualisation of twin geometry and live sensor data."
    DTDFVocab:provides VisualizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Runs predictive models on sensor data to forecast energy use and occupant comfort."
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes lighting set‑points using reinforcement learning and issues recommendations."
    DTDFVocab:provides LightingOptimizationInsight
    DTDFVocab:provides LightingSetpointAction
]

// C17: Insights / Actions
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring dashboards showing temperature, occupancy, and illumination trends."
]

instance TwinStateInsight : DTDFVocab:Insight [
    base:desc "Current digital‑twin state model reflecting the physical building’s configuration."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D view in Unreal Engine 5 visualising live sensor values on building geometry."
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Forecasts of energy consumption and occupant comfort derived from historical sensor data."
]

instance LightingOptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for lighting set‑points to improve energy efficiency and occupant comfort."
]

instance LightingSetpointAction : DTDFVocab:Action [
    base:desc "Recommended lighting set‑point to be applied by the LightingControlActuator."
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance BIMModel : DTDFVocab:Model [
    base:desc "Base BIM model containing geometry, spatial relationships, and device metadata."
    DTDFVocab:inputTo EclipseDitto, UnrealEngine5
]

instance RuntimeControlModel : DTDFVocab:Model [
    base:desc "Control‑logic model used for reinforcement‑learning based lighting optimization."
    DTDFVocab:inputTo ReinforcementLearningEngine, EclipseDitto
]

instance SensorDataStreamModel : DTDFVocab:Model [
    base:desc "Schema describing temperature, occupancy, and illumination data streams."
    DTDFVocab:inputTo EclipseHono
]

instance TwinStateModel : DTDFVocab:Model [
    base:desc "Ditto twin‑state model representing current values of all building components."
    DTDFVocab:inputTo EclipseDitto
]

instance UnrealEngineAssetModel : DTDFVocab:Model [
    base:desc "Assets and shaders for Unreal Engine 5 visualisation of the building twin."
    DTDFVocab:inputTo UnrealEngine5
]

// C12: Environment (optional aggregation)
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, OccupancySensor, IlluminationSensor,
          LightingControlActuator, HVACActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin are sent from Eclipse Ditto through Eclipse Hono to the corresponding actuator endpoints, effecting changes in the physical building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization (sub‑second to second latency) enabled by the Eclipse Hono/Ditto data‑exchange layer."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular service‑oriented architecture where an enriched BIM model feeds a configurator that generates Hono/Ditto runtime artifacts; the twin core (Ditto) maintains state, Hono handles bi‑directional messaging, and visualization/analytics services plug in via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the design/as‑built phase (BIM), commissioning/deployment, and operational phase where runtime data are consumed and control actions are issued."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric is used to quantify how closely the twin reflects the physical counterpart, providing a quantitative fidelity assessment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono provides MQTT/HTTP (and optionally AMQP) gateways; Eclipse Ditto exposes HTTP/REST and WebSocket APIs for twin state access and command issuance."
]