// C2: Acting Components
instance LightingDimmer : DTDFVocab:ActingComponent [
    base:desc "BIM‑modeled dimmer that can receive control commands from the digital twin to adjust illumination levels."
]

instance LightingSwitch : DTDFVocab:ActingComponent [
    base:desc "BIM‑modeled switch that can be toggled by the digital twin to turn lighting zones on or off."
]

// C3: Physical sensing components
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded BIM‑modeled sensor that captures illumination levels in the Living Lab building."
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded BIM‑modeled sensor that detects occupancy presence in zones of the Living Lab building."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded BIM‑modeled sensor that measures additional environmental variables (temperature, humidity) in the Living Lab building."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C10: Data
instance IlluminationData : DTDFVocab:Data [
    base:desc "Illumination measurement values streamed from physical sensors to the digital twin."
    DTDFVocab:inputTo EclipseHono, EclipseDitto
    DTDFVocab:fromData IlluminationDataTransmitted
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy presence events streamed from physical sensors to the digital twin."
    DTDFVocab:inputTo EclipseHono, EclipseDitto
    DTDFVocab:fromData OccupancyDataTransmitted
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Environmental variable readings (temperature, humidity) streamed from physical sensors to the digital twin."
    DTDFVocab:inputTo EclipseHono, EclipseDitto
    DTDFVocab:fromData EnvironmentalDataTransmitted
]

instance TwinStateData : DTDFVocab:Data [
    base:desc "Current twin property values stored in Eclipse Ditto representing building state."
    DTDFVocab:inputTo EclipseDitto, ModelDrivenTransformationPipeline
]

// C10: Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Core BIM representation enriched with device metadata for sensors and actuators."
    DTDFVocab:inputTo EclipseHono, EclipseDitto, ModelDrivenTransformationPipeline, BIMAuthoringTool
]

instance HonoConfigurationModel : DTDFVocab:Model [
    base:desc "Generated Hono configuration model derived from the enriched BIM for ingesting sensor streams."
    DTDFVocab:inputTo EclipseHono
]

instance DittoPersistenceModel : DTDFVocab:Model [
    base:desc "Ditto model defining twin property schema and persistence rules."
    DTDFVocab:inputTo EclipseDitto
]

instance PredictiveAnalyticsModel : DTDFVocab:Model [
    base:desc "Model supporting predictive analytics algorithms for future energy and occupancy forecasting."
    DTDFVocab:inputTo ModelDrivenTransformationPipeline
]

instance EnergyOptimizationModel : DTDFVocab:Model [
    base:desc "Model describing optimization constraints and objectives for lighting energy reduction."
    DTDFVocab:inputTo ModelDrivenTransformationPipeline
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides secure MQTT/AMQP ingestion of sensor measurements from the building to the digital twin."
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalyticsService, EnergyOptimizationService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto stores twin properties and runtime data, enabling services to query and react to building state."
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalyticsService, EnergyOptimizationService, InteractiveVisualizationService, BuildingPerformanceSimulationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders 3D interactive visualizations of the BIM‑derived digital twin."
    DTDFVocab:enables InteractiveVisualizationService, BuildingPerformanceSimulationService
]

instance ModelDrivenTransformationPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline transforms enriched BIM models into deployable Hono/Ditto configurations."
    DTDFVocab:enables PredictiveAnalyticsService, EnergyOptimizationService, BuildingPerformanceSimulationService
]

instance BIMAuthoringTool : DTDFVocab:Enabler [
    base:desc "BIM authoring tools embed device semantics (sensor/actuator metadata) into the building information model."
    DTDFVocab:enables RealTimeMonitoringDashboard, InteractiveVisualizationService
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards display live sensor streams and twin state to facility managers."
    DTDFVocab:provides EnergyConsumptionTrendInsight, ComfortViolationInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "3D interactive visualization in Unreal Engine 5 enables immersive exploration of the building twin."
    DTDFVocab:provides EnergyConsumptionTrendInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics compute future energy usage and occupancy patterns for proactive management."
    DTDFVocab:provides OptimizedLightingSetpointInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy‑optimization algorithms generate optimal lighting set‑points and control strategies."
    DTDFVocab:provides OptimizedLightingSetpointInsight, AdjustLightingAction
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance evaluates comfort and energy scenarios under varying conditions."
    DTDFVocab:provides ComfortViolationInsight, EnergyConsumptionTrendInsight
]

// C17: Insights
instance EnergyConsumptionTrendInsight : DTDFVocab:Insight [
    base:desc "Insight into energy‑consumption trends derived from aggregated sensor data."
]

instance ComfortViolationInsight : DTDFVocab:Insight [
    base:desc "Insight highlighting comfort violations such as insufficient illumination or occupancy mismatches."
]

instance OptimizedLightingSetpointInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimized lighting set‑points to reduce energy while maintaining comfort."
]

// C17: Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust lighting dimmer or switch to the recommended set‑point."
    DTDFVocab:IsAutomatic true
]

// Environment containing components
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains IlluminationSensor, OccupancySensor, EnvironmentalSensor, LightingDimmer, LightingSwitch
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command flow from the twin to physical actuators through Eclipse Ditto and Eclipse Hono, allowing the twin to issue control signals back to the building control system."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (sub‑second) synchronization of sensor data and control commands between the physical asset and the twin."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central hub linking the enriched BIM model, Hono/Ditto middleware, and Unreal Engine visualization; modular extension points allow additional services to be plugged in."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Supports the design, construction, and operation phases; the twin persists from as‑designed BIM through as‑built to as‑operated representations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric is employed to quantify the fidelity of the twin to its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication is realized through Eclipse Hono and Eclipse Ditto, providing real‑time data exchange between physical assets and the twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Built on BIM/IFC standards and open IoT standards implemented by Eclipse Hono and Ditto."
]