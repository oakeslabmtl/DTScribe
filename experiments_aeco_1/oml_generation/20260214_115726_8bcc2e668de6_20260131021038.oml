// C2: Acting Components
instance DimmableLuminaire : DTDFVocab:ActingComponent [
    base:desc "Dimmable luminaire modeled as a BIM object with device ID, tenant and endpoint metadata"
]

instance LightingSwitch : DTDFVocab:ActingComponent [
    base:desc "Lighting switch modeled as a BIM object enabling on/off control"
]

instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Lighting controller managing groups of dimmable luminaires via the twin"
]

// C3: Physical sensing components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental light sensor whose metadata is stored in the BIM model and streams measurements via Eclipse Hono"
    DTDFVocab:producedData LightDataStream
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor whose metadata is stored in the BIM model and streams measurements via Eclipse Hono"
    DTDFVocab:producedData TemperatureDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy sensor whose metadata is stored in the BIM model and streams measurements via Eclipse Hono"
    DTDFVocab:producedData OccupancyDataStream
]

// C4: Physical-to-virtual interaction
instance LightDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Data
instance LightMeasurementData : DTDFVocab:Data [
    base:desc "Real‑time light level measurements from the building’s light sensors"
    DTDFVocab:fromData LightDataStream
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance TemperatureMeasurementData : DTDFVocab:Data [
    base:desc "Real‑time temperature measurements from the building’s temperature sensors"
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyMeasurementData : DTDFVocab:Data [
    base:desc "Real‑time occupancy measurements from post‑occupancy sensors"
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Static BIM model enriched with device metadata (device ID, tenant, endpoint) for lighting control and sensors"
    DTDFVocab:inputTo EclipseDitto
]

instance RuntimeTwinModel : DTDFVocab:Model [
    base:desc "Runtime twin model stored in Eclipse Ditto, representing current state of lighting devices and sensor data"
    DTDFVocab:inputTo EclipseDitto
]

instance BuildingSimulationModel : DTDFVocab:Model [
    base:desc "Real‑time simulation model of building performance used for predictive analytics and energy optimisation"
    DTDFVocab:inputTo PredictiveAnalyticsEngine, EnergyOptimizationEngine
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides bi‑directional IoT connectivity for sensor data ingestion and command dispatch"
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalyticsService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto hosts the digital twin runtime, maintaining state and handling control commands"
    DTDFVocab:enables RealTimeMonitoringDashboard, BuildingPerformanceSimulationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders the 3‑D interactive visualization of the building digital twin"
    DTDFVocab:enables Interactive3DVisualization
]

instance PredictiveAnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Engine executing predictive analytics on the simulation model to forecast lighting demand"
    DTDFVocab:enables PredictiveAnalyticsService
]

instance EnergyOptimizationEngine : DTDFVocab:Enabler [
    base:desc "Engine performing energy optimisation and evaluating control strategies"
    DTDFVocab:enables EnergyOptimizationService
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Dashboard delivering real‑time monitoring of energy consumption and lighting status"
    DTDFVocab:provides EnergyConsumptionInsight
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "3‑D interactive visualization in Unreal Engine 5 for facility managers"
    DTDFVocab:provides EnergyConsumptionInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service generating lighting demand forecasts"
    DTDFVocab:provides PredictedLightingDemandInsight, AdjustIlluminationSetpointAction
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy optimisation service evaluating impact of lighting control strategies"
    DTDFVocab:provides ControlStrategyImpactInsight
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation service providing real‑time building performance results"
    DTDFVocab:provides PredictedLightingDemandInsight
]

// C17: Insights
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight on current energy consumption patterns of the lighting system"
]

instance PredictedLightingDemandInsight : DTDFVocab:Insight [
    base:desc "Predicted lighting demand based on occupancy and ambient light levels"
]

instance ControlStrategyImpactInsight : DTDFVocab:Insight [
    base:desc "Evaluation of the impact of lighting control strategies on energy usage"
]

// C17: Actions
instance AdjustIlluminationSetpointAction : DTDFVocab:Action [
    base:desc "Action to adjust illumination set‑points in response to predicted demand"
    DTDFVocab:IsAutomatic true
]

// Environment
instance BuildingLivingLab : DTDFVocab:Environment [
    base:contains DimmableLuminaire, LightingSwitch, LightingController, LightSensor, TemperatureSensor, OccupancySensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT issues control commands (e.g., set lighting level, turn fixtures on/off) which are sent from the Ditto twin to Eclipse Hono and routed to the corresponding lighting actuators in the building, achieving bidirectional synchronization."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data exchange and command propagation occur continuously, supporting near‑real‑time synchronization between physical sensors/actuators and the digital twin; the system is designed to process incoming sensor streams and emit control actions with latency low enough for live operational monitoring."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where the enriched BIM model feeds a configurator that generates Hono/Ditto configurations; Ditto maintains the twin state, Hono handles messaging, and Unreal Engine provides the user interface; services can be added via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers design (BIM creation), construction (device commissioning) and operation (runtime monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric is used to quantify the fidelity between physical asset and its twin; model validation performed before deployment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical devices publish sensor data to Eclipse Hono, which forwards it to Eclipse Ditto where the twin state is updated. Control commands originate in Ditto and are sent back through Hono to the devices, establishing a bidirectional technical connection between PT and DT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework leverages BIM standards for building information, open IoT communication standards via Eclipse Hono, and standardized extension points for service integration."
]