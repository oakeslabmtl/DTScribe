// C1: Environment
instance BuildingInfrastructure : DTDFVocab:Environment [
    base:desc "A building infrastructure within a Living Lab environment, serving as the physical counterpart for real-time monitoring, simulation, and optimization of building operations."
    base:contains TemperatureSensor, HumiditySensor, LightSensor, OccupancySensor, LightingControlActuator, HVACSystemActuator
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor measuring temperature in the building"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor measuring humidity levels"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor measuring light intensity"
    DTDFVocab:producedData LightDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy detection sensor for room usage monitoring"
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance LightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Models/Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature readings transmitted via MQTT/AMQP protocols"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono, MDEFramework
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Real-time humidity measurements transmitted via MQTT/AMQP protocols"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseHono, MDEFramework
]

instance LightData : DTDFVocab:Data [
    base:desc "Real-time light intensity data transmitted via MQTT/AMQP protocols"
    DTDFVocab:fromData LightDataTransmitted
    DTDFVocab:inputTo EclipseHono, MDEFramework
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy counts transmitted via MQTT/AMQP protocols"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, MDEFramework
]

instance BCSRuntimeData : DTDFVocab:Data [
    base:desc "Integrated runtime data from Building Control System components including temperature, humidity, light, and occupancy readings"
    DTDFVocab:fromData TemperatureDataTransmitted, HumidityDataTransmitted, LightDataTransmitted, OccupancyDataTransmitted
    DTDFVocab:inputTo Revit, MDEFramework
]

instance BIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with Building Control System runtime data for geometric, spatial, and functional characteristics"
    DTDFVocab:inputTo Revit, MDEFramework
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "MQTT/AMQP protocol middleware for real-time sensor data transmission and bidirectional communication with BCS actuators"
    DTDFVocab:enables RealTimeMonitoring, PredictiveAnalytics, EnergyOptimization, VisualComfortAdjustment
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Digital Twin framework for managing device identities and states via bidirectional communication"
    DTDFVocab:enables RealTimeMonitoring, PredictiveAnalytics, EnergyOptimization, VisualComfortAdjustment
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "3D visualization engine for interactive digital twin representation using Unreal Engine 5"
    DTDFVocab:enables Interactive3DVisualization
]

instance Revit : DTDFVocab:Enabler [
    base:desc "BIM modeling tool for creating and enriching geometric and spatial building models"
    DTDFVocab:enables Simulation, EnergyOptimization, VisualComfortAdjustment
]

instance MDEFramework : DTDFVocab:Enabler [
    base:desc "Model-driven Engineering framework for automated BIM-to-runtime artifact transformation"
    DTDFVocab:enables Simulation, PredictiveAnalytics, EnergyOptimization
]

// C6: Services
instance RealTimeMonitoring : DTDFVocab:Service [
    base:desc "Continuous monitoring of building operations using real-time sensor data from environmental sensors"
    DTDFVocab:provides RealTimeDataInsight
]

instance Simulation : DTDFVocab:Service [
    base:desc "Simulation of building operations using BIM models and sensor data"
    DTDFVocab:provides SimulationResults
]

instance PredictiveAnalytics : DTDFVocab:Service [
    base:desc "Analysis of sensor data to generate energy usage forecasts and occupancy pattern predictions"
    DTDFVocab:provides EnergyUsageForecast, OccupancyPatterns
]

instance EnergyOptimization : DTDFVocab:Service [
    base:desc "Optimization of energy usage based on predictive analytics and real-time data"
    DTDFVocab:provides EnergyOptimizationRecommendation
]

instance VisualComfortAdjustment : DTDFVocab:Service [
    base:desc "Adjustment of lighting and HVAC for optimal visual comfort"
    DTDFVocab:provides VisualComfortInsight
]

instance NonVisualHealthEffectsManagement : DTDFVocab:Service [
    base:desc "Management of non-visual health effects through environmental adjustments"
    DTDFVocab:provides HealthEffectsInsight
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "Interactive 3D visualization of building operations using Unreal Engine 5"
    DTDFVocab:provides Interactive3DVisualizationInsight
]

// C17: Insights/Actions
instance RealTimeDataInsight : DTDFVocab:Insight [
    base:desc "Current operational status of building systems based on sensor data"
]

instance SimulationResults : DTDFVocab:Insight [
    base:desc "Simulated outcomes of building operations under various scenarios"
]

instance EnergyUsageForecast : DTDFVocab:Insight [
    base:desc "Predicted energy consumption for building operations over time"
]

instance OccupancyPatterns : DTDFVocab:Insight [
    base:desc "Predicted patterns of room occupancy for optimization purposes"
]

instance EnergyOptimizationRecommendation : DTDFVocab:Insight [
    base:desc "Recommendations for reducing energy consumption in building systems"
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Optimized lighting and temperature settings for visual comfort"
]

instance HealthEffectsInsight : DTDFVocab:Insight [
    base:desc "Environmental adjustments to mitigate non-visual health impacts"
]

instance Interactive3DVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time 3D model visualization of building systems and data"
]

// C2: Acting Components
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for controlling lighting systems managed via Eclipse Hono and Ditto"
]

instance HVACSystemActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for HVAC system control managed via bidirectional communication"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Optimized control commands (e.g., HVAC setpoints, lighting adjustments) generated by DT services and sent to physical actuators via Eclipse Ditto for real-time adjustments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with data updates processed continuously; however, exact time intervals (e.g., milliseconds) are not specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Integrated ecosystem comprising BIM models, Eclipse Hono/Ditto middleware for data exchange, Unreal Engine visualization, and modular service extensions, enabling holistic building life cycle management."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers all life cycle stages from design through construction to operation and refurbishment, with emphasis on operational phase for real-time monitoring and control."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation using the Overall Digital Twin Entanglement (ODTE) metric to assess interoperability and architectural soundness; verification and validation details beyond ODTE are not provided."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Technical connection via MQTT, AMQP, and HTTP protocols through Eclipse Hono and Ditto middleware for bidirectional data exchange between physical assets and digital twin."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems such as IoT platforms and Building Management Systems (BMS) via standardized APIs and middleware (e.g., Hono/Ditto) for cross-system data exchange."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to BIM standards (e.g., IFC), MQTT/AMQP protocols via Eclipse Hono, and Ditto's Thing Model specifications; specific industry standards like ISO or IEC are not explicitly cited."
]