// C0: Environment – Living Lab Building
instance LivingLabBuilding : DTDFVocab:Environment [
    base:desc "Living Lab building infrastructure modelled in BIM, representing the physical asset whose operations are mirrored in a Digital Twin.",
    base:contains IlluminationSensor, OccupancyDetector, LightingActuator, LightingController, EnrichedBIMModel, RuntimeArtifactsModel, LiveSensorDataStore
]

// C3: Physical sensing components
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy illumination sensor configured in BIM, streaming real‑time illumination levels.",
    DTDFVocab:producedData IlluminationDataStream
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy occupancy detector configured in BIM, streaming real‑time presence detection.",
    DTDFVocab:producedData OccupancyDataStream
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance IlluminationDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

// C10: Data objects
instance IlluminationData : DTDFVocab:Data [
    base:desc "Illumination level readings from the building, stored in Eclipse Ditto's thing store.",
    DTDFVocab:fromData IlluminationDataStream,
    DTDFVocab:inputTo HonoConnector, DittoThingStore
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy detection events from the building, stored in Eclipse Ditto's thing store.",
    DTDFVocab:fromData OccupancyDataStream,
    DTDFVocab:inputTo HonoConnector, DittoThingStore
]

// C2: Acting components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator capable of adjusting illumination levels as defined by BIM lighting control semantics."
]

instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Controller that receives lighting commands and drives the LightingActuator."
]

// C10: Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing geometry, topology, semantic attributes and device metadata.",
    DTDFVocab:inputTo HonoConnector, DittoThingStore, MDEPipeline
]

instance RuntimeArtifactsModel : DTDFVocab:Model [
    base:desc "Generated runtime artifacts such as configuration files and code produced by the model‑driven deployment pipeline.",
    DTDFVocab:inputTo HonoConnector, DittoThingStore
]

instance LiveSensorDataStore : DTDFVocab:Data [
    base:desc "Live sensor data streams persisted in Eclipse Ditto's thing store.",
    DTDFVocab:inputTo DittoThingStore
]

// C11: Enablers
instance HonoConnector : DTDFVocab:Enabler [
    base:desc "Eclipse Hono component handling device connectivity and forwarding sensor streams to Ditto.",
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalyticsSimulation, EnergyOptimizationService, RLLightingControlService, TaskPlanningService
]

instance DittoThingStore : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin platform storing thing states and enabling state synchronization.",
    DTDFVocab:enables RealTimeMonitoringDashboard, Interactive3DVisualization, PredictiveAnalyticsSimulation, EnergyOptimizationService, RLLightingControlService, TaskPlanningService
]

instance UE5VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 engine providing immersive 3‑D interactive visualization of the building twin.",
    DTDFVocab:enables Interactive3DVisualization
]

instance MDEPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline that enriches BIM, validates models and generates Hono/Ditto configurations.",
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalyticsSimulation, EnergyOptimizationService, RLLightingControlService
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard delivering live status of sensors and actuators to facility managers.",
    DTDFVocab:provides RealTimeStatusInsight, AdjustLightingAction
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "3‑D interactive visualization in Unreal Engine 5 for immersive exploration of the digital twin.",
    DTDFVocab:provides SpatialAwarenessInsight
]

instance PredictiveAnalyticsSimulation : DTDFVocab:Service [
    base:desc "Simulation and predictive analytics service generating performance forecasts and anomaly detection.",
    DTDFVocab:provides PredictivePerformanceInsight, OptimizationRecommendationInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy optimisation service recommending optimal lighting setpoints based on occupancy and illumination data.",
    DTDFVocab:provides OptimizationRecommendationInsight, AdjustLightingAction
]

instance RLLightingControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based lighting control service that updates control policies for dynamic illumination management.",
    DTDFVocab:provides RLPolicyUpdateInsight, AdjustLightingAction
]

instance TaskPlanningService : DTDFVocab:Service [
    base:desc "Task planning service assisting facility managers with maintenance and operational scheduling.",
    DTDFVocab:provides MaintenanceTaskInsight
]

// C17: Insights
instance RealTimeStatusInsight : DTDFVocab:Insight [
    base:desc "Real‑time status of sensors and actuators displayed on the monitoring dashboard."
]

instance PredictivePerformanceInsight : DTDFVocab:Insight [
    base:desc "Predictive performance analytics forecasting lighting energy consumption."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendations for lighting settings to reduce energy usage."
]

instance RLPolicyUpdateInsight : DTDFVocab:Insight [
    base:desc "Reinforcement‑learning policy updates for adaptive lighting control."
]

instance SpatialAwarenessInsight : DTDFVocab:Insight [
    base:desc "Spatial awareness of building components within the 3‑D visualization."
]

instance MaintenanceTaskInsight : DTDFVocab:Insight [
    base:desc "Task planning insights for maintenance scheduling of lighting infrastructure."
]

// C17: Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Command to adjust lighting illumination levels via the LightingActuator.",
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin are sent back through Eclipse Ditto to Eclipse Hono, which delivers the commands to the building’s actuators (e.g., lighting devices) to enact adjustments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data exchange and model updates occur in real time, providing continuous synchronization between the physical building and its digital counterpart."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Modular, service‑oriented architecture linking BIM‑derived models, a Hono/Ditto configurator, a runtime broker (Ditto), and a visualization front‑end (Unreal Engine) with extension points for additional analytics services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The solution supports the full building life‑cycle, encompassing design (via BIM), construction, and operational phases, including refurbishment and adaptation during use."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric is used to quantify how closely the twin mirrors the physical counterpart; semantic drift is addressed by continuous synchronization."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical link between physical and virtual components is realized through Eclipse Hono for ingesting sensor streams and Eclipse Ditto for managing twin state and bi‑directional command exchange."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach leverages BIM as an industry‑standard modeling language and utilizes open‑source DT frameworks (Eclipse Ditto, Eclipse Hono) that adhere to common IoT and digital‑twin standards."
]