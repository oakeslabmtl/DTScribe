// Environment and Core Building Component
instance AcademicBuildingEnvironment : DTDFVocab:Environment [
    base:desc "LEED Platinum certified research-oriented academic building serving as living lab for indoor environmental monitoring"
    base:contains BuildingComponent, LightTwinComponent
]

// Core building infrastructure component
instance BuildingComponent : DTDFVocab:Component [
    base:desc "Core building infrastructure integrating HVAC, lighting and BCS embedded systems within an enriched BIM model"
]

// ----------------------------------------
// Acting Component – Lighting Twin
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Digital twin representation of a physical lighting fixture defined in the BIM model, accepting commands such as on/off, brightness and color temperature which are routed via the DittoEnabler and Hono connectivity framework"
]

// ----------------------------------------
// Enablers
instance DittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin store and policy engine providing device twin management and command routing"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, EnergyOptimizationService, ControlInterfaceService
]

instance iTwinJSEnabler : DTDFVocab:Enabler [
    base:desc "iTwin.js library for web-based 3D BIM visualization and interaction, exposing the current twin state to immersive dashboards"
    DTDFVocab:enables Visualization3DService
]

instance HonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono connectivity framework that streams sensor telemetry and command traffic to and from building devices"
    DTDFVocab:enables RealTimeMonitoringService, ControlInterfaceService
]

instance PostgreSQLEnabler : DTDFVocab:Enabler [
    base:desc "PostgreSQL database for structured archival of building configuration data and policies"
]

instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time-series database for storing high‑volume telemetry generated by building sensors and IoT devices"
]

instance BasyxAssetRegistryEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse BASYX asset registry providing a unified asset catalogue and data-model services for BIM entities"
]

// ----------------------------------------
// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of building states via sensor data streams delivering real‑time telemetry for visualization and alerting"
    DTDFVocab:provides IndoorClimateInsight, EnergyConsumptionInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service that forecasts indoor environmental conditions and energy consumption patterns using historical telemetry"
    DTDFVocab:provides AnomalyDetectionInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization engine that recommends energy savings strategies and controls building systems for efficient operation"
    DTDFVocab:provides UpdateControlLogicAction
]

instance ControlInterfaceService : DTDFVocab:Service [
    base:desc "Facility Manager control interface that issues commands to actuators through the twin"
    DTDFVocab:provides SetLightingCommandAction, AdjustHVACCommandAction
]

instance Visualization3DService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization service that consumes twin state for immersive analysis via Unreal/UE5 engine"
    DTDFVocab:provides GeneralVisualizationInsight
]

// ----------------------------------------
// Actions
instance SetLightingCommandAction : DTDFVocab:Action [
    base:desc "Action that encapsulates a command for a lighting fixture, including on/off status, brightness level and color temperature"
    DTDFVocab:IsAutomatic false
]

instance AdjustHVACCommandAction : DTDFVocab:Action [
    base:desc "Action for HVAC control, modifying setpoints and fan speeds through the twin"
    DTDFVocab:IsAutomatic false
]

instance UpdateControlLogicAction : DTDFVocab:Action [
    base:desc "Automatic action that updates building control logic as part of energy optimization"
    DTDFVocab:IsAutomatic true
]

// ----------------------------------------
// Insights
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight reporting current and projected energy consumption derived from telemetry and predictive models"
]

instance IndoorClimateInsight : DTDFVocab:Insight [
    base:desc "Insight presenting indoor temperature, humidity, CO2 levels and air quality as observed by building sensors"
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight highlighting anomalous behavior or fault in building systems identified by predictive analytics"
]

instance GeneralVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight that aggregates 3D visualization data for immersive analysis"
]

// ----------------------------------------
// Models
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "BIM geometry enriched with IFC metadata representing building layout, volumes, and spatial relationships"
    DTDFVocab:inputTo DittoEnabler, BasyxAssetRegistryEnabler
]

instance BehaviouralTwinModel : DTDFVocab:Model [
    base:desc "Behavioural model derived from TwinComponent and FeatureParser definitions capturing device logic and state transitions"
    DTDFVocab:inputTo DittoEnabler
]

instance AnalyticalPolicyModel : DTDFVocab:Model [
    base:desc "Policy‑based validation rules implemented in Ditto for device behavior and security compliance"
    DTDFVocab:inputTo DittoEnabler
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework achieves continuous real‑time synchronization between the physical building and its digital counterpart, enabling events from sensors and control actions to be reflected in the DT with near‑zero latency. Although specific update frequencies or latency limits are not quantified in the documents, the design explicitly targets real‑time bidirectional data exchange and interactive visualization, implying sub‑second to real‑time update cycles for monitoring and control workflows."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated using a modular, service‑oriented architecture. Core components include the Digital Twin Framework hub that handles bidirectional data exchange, runtime configuration management for service adaptation, and an interactive visualization layer for stakeholders. Extension points expose APIs for integrating custom analytics, AI models, and sensor drivers, thereby enabling resource‑aware scaling from individual component services up to whole‑system orchestration."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Phase 1 – Device‑Modeling: Building‑Control‑Engineers enrich a BIM model with explicit sensor, actuator, and controller meta‑data, encoding control logic as BIM objects. Phase 2 – Semantic‑Enrichment & MDE Extraction: MDE techniques parse the enriched BIM and generate a structured, machine‑readable representation that captures system topology, control relationships, and real‑time data flow. Phase 3 – Artifact‑Generation & Deployment: The framework auto‑creates deployable Digital‑Twin artifacts (service endpoints, data schemas, communication adapters) from the extracted representation, minimizing manual configuration. Phase 4 – Runtime Synchronization: Continuous bidirectional data exchange (e.g., via OPC UA or MQTT patterns implied by real‑time data exchange claims) keeps the DT state synced with the physical building, while interactive visualization tools provide immersive monitoring. Phase 5 – Custom‑Service Integration & Evolution: Modular extension points allow DT‑Engineers to plug analytics, AI, or cost‑modeling services, enabling incremental evolution of the twin without re‑engineering the base model. Transition management is handled by the automated MDE pipeline, and lifecycle governance is supported by the framework’s standardized, role‑based configuration, as reflected in Table I."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Data integrity and model validity are guaranteed through Eclipse Ditto’s policy‑based validation framework, which enforces value ranges and unit consistency for all sensor telemetry. Ditto policy rules also perform pre‑execution checks on actuator commands to prevent conflicts or unsafe operations. Fault tolerance is achieved by Eclipse Hono’s at‑least‑once message delivery semantics and Ditto’s persistent event storage, ensuring resilience against network failures or service disruptions. The framework also employs runtime validation of TwinComponent state changes and utilizes Eclipse Ditto’s event catalog to detect and correct erroneous or outlier data. Additionally, the modular architecture allows the integration of custom analytics services that can apply further model verification, comparison with analytical predictions, and uncertainty quantification."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection layer relies on the Eclipse Hono messaging platform for secure, scalable transport of telemetry and command data, and on Eclipse Ditto for managing twin representations and event routing. The underlying network is orchestrated by the modular framework described in Document 1, which implements a central hub that mediates bidirectional communication between physical devices and the digital twin. Detailed protocols, topology, bandwidth, latency, or security specifications are not provided."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration relies on interoperability across heterogeneous systems, as highlighted in the non‑functional requirements. The framework exposes standardized communication endpoints facilitating bidirectional data exchange, though specific protocols (e.g., MQTT, OPC UA) are not named. Dependencies on external BIM tools, sensor networks, and enterprise systems are accommodated via the modular extension points, enabling integration of custom services and analytics within the DT ecosystem."
]