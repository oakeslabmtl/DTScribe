// C1: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing detailed device descriptors for sensors, actuators, and controllers."
    DTDFVocab:inputTo ValidationEnabler, ConversionEnabler
]

// C2: Acting Components
instance LightActuator : DTDFVocab:ActingComponent [
    base:desc "Physical actuator controlling individual lighting fixtures via DittoDevice and MQTT."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Physical actuator controlling HVAC units via DittoDevice and MQTT."
]

// C3: Physical sensing components
instance BuildingTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Aggregates real‑time telemetry from building sensors and actuators."
    DTDFVocab:producedData BuildingTelemetryTransmitted
]

// C4: Physical-to-virtual interaction
instance BuildingTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingTelemetrySensor
]

// C5: Data
instance BuildingTelemetryData : DTDFVocab:Data [
    base:desc "Aggregated telemetry data for real‑time monitoring and analytics."
    DTDFVocab:fromData BuildingTelemetryTransmitted
    DTDFVocab:inputTo DittoEventStoreEnabler
]

// C6: Enablers
instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enables validation of enriched BIM model against domain policies."
    DTDFVocab:enables ValidationService
]

instance ConversionEnabler : DTDFVocab:Enabler [
    base:desc "Enables transformation of structural data into runtime representations for middleware."
    DTDFVocab:enables ConversionService
]

instance DittoEventStoreEnabler : DTDFVocab:Enabler [
    base:desc "Ditto event store that ingests telemetry data for storage and policy validation."
    DTDFVocab:enables MonitoringService, ControlService
]

instance HonoMQTTEnabler : DTDFVocab:Enabler [
    base:desc "Hono MQTT broker for sending control commands to physical actuators."
    DTDFVocab:enables ControlService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 visualization module for immersive dashboards."
    DTDFVocab:enables VisualizationService
]

// C7: Services
instance ValidationService : DTDFVocab:Service [
    base:desc "Provides validation of enriched BIM against domain policies."
    DTDFVocab:provides ValidationResultInsight
]

instance ConversionService : DTDFVocab:Service [
    base:desc "Provides runtime representations of BIM structural data."
    DTDFVocab:provides ConversionInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitors real‑time telemetry to provide continuous insight into building operation."
    DTDFVocab:provides OperationalStatusInsight, PerformanceTrendInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Enables Facility Managers to issue control commands to building systems through immersive interfaces."
    DTDFVocab:provides ControlOverrideAction
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Integrated analytics predict future building performance and detect anomalies."
    DTDFVocab:provides ForecastInsight, AnomalyDetectionInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Recommends operational adjustments to improve efficiency based on predictions."
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Renders immersive dashboards via Unreal Engine 5 showcasing building state and trends."
    DTDFVocab:provides VisualizationInsight
]

// C8: Insights
instance ValidationResultInsight : DTDFVocab:Insight [
    base:desc "Insight indicating success or failure of BIM validation against domain policies."
]

instance ConversionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating completion of converting BIM structural data into runtime representations."
]

instance OperationalStatusInsight : DTDFVocab:Insight [
    base:desc "Insight indicating current operational status of building systems."
]

instance PerformanceTrendInsight : DTDFVocab:Insight [
    base:desc "Insight indicating trends in building performance over time."
]

instance ForecastInsight : DTDFVocab:Insight [
    base:desc "Insight predicting future building performance based on analytics."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting anomalies in building operation."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending operational adjustments to reduce costs and improve efficiency."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight enabling immersive visualization of building state and trends in Unreal Engine 5."
]

// C9: Actions
instance ControlOverrideAction : DTDFVocab:Action [
    base:desc "User‑initiated override of automatic building system controls."
    DTDFVocab:IsAutomatic false
]

// C10: Components (environment)
instance LightTwinComponent : DTDFVocab:Component [
    base:desc "Twin component representing building lighting system linked to physical light actuator."
]

instance HVACTwinComponent : DTDFVocab:Component [
    base:desc "Twin component representing building HVAC system linked to physical HVAC actuator."
]

instance UnrealTwinController : DTDFVocab:Component [
    base:desc "Unreal Engine 5 controller that maps twin component states to immersive visualization."
]

instance DittoController : DTDFVocab:Component [
    base:desc "Controller that manages communication with Ditto devices for telemetry and control."
]

// C11: Environment
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains LightTwinComponent, HVACTwinComponent, LightActuator, HVACActuator, UnrealTwinController, DittoController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "While the documented framework supports bidirectional data exchange, the specific control flow from the digital twin to physical building systems—encompassing command types, control message formats, validation and authentication procedures, feedback loops, conflict resolution strategies, or command execution confirmation mechanisms—are not described within the provided texts."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange enables continuous synchronization between the physical building and its digital counterpart; the architecture is designed for sub‑second latency, though explicit update frequencies are not provided in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT system is organized as a modular, service‑oriented framework with standardized extension points; runtime configuration management allows dynamic adjustment of services; bidirectional data flows between embedded sensors, BIM models, and control layers are orchestrated through the central hub, enabling holistic building life‑cycle management from design to operations."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a four‑stage lifecycle: (1) Device Modeling and Control Logic Definition within BIM, where sensors, actuators, and controllers are added to the BIM model; (2) Model‑Driven Extraction, where MDE principles transform the enriched BIM into structured representations stored in a semantic repository; (3) Deployment, where deployable DT artifacts (code, configuration, services) are automatically generated from the structured model with minimal manual effort; and (4) Runtime Operation, where real‑time data exchange keeps the physical building and its twin continuously synchronised, enabling monitoring, control and iterative evolution through modular extension points. Transition management relies on versioned MDE transformations and governance is supported by the modular architecture and standardized extension points."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by a multi‑stage validation pipeline: BIM enrichment undergoes schema validation, while runtime data is verified against Ditto’s policy engine that enforces acceptable value ranges and units. Real‑time data exchange is guaranteed by Eclipse Hono’s at‑least‑once message delivery, ensuring no information loss across network disruptions. Ditto’s persistent event storage provides fault tolerance and auditability of sensor streams. Pre‑execution checks on actuator commands detect and correct operation conflicts before the command is sent to the physical device, maintaining synchronization and operational safety. Overall, the framework adopts a service‑oriented architecture with modular extension points, allowing the continuous refinement of model‑data fidelity through iterative validation and verification steps."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The documentation references interoperability across heterogeneous systems and a modular architecture with standardized extension points, yet it does not provide details on the underlying communication protocols (e.g., MQTT, AMQP), network topology or architecture, bandwidth and latency requirements, reliability or redundancy mechanisms, or security protocols governing the data exchanges."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The documents mention runtime configuration management and modular architecture that enable adjustments without full redeployment, but they do not specify hosting platforms (cloud, edge, or on‑premise), computational or storage requirements, scalability mechanisms, supported deployment models, or availability and reliability guarantees for the digital twin system."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved via high‑level interoperability standards at the software architecture layer, employing standardized data exchange points for enriched BIM models and other domain services; specific protocols (e.g., OPC UA, MQTT) or enterprise integration patterns are not delineated in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework aligns with industry BIM standards for model representation and leverages model‑driven engineering (MDE) for transformation; it facilitates interoperability through real‑time data exchange protocols and bidirectional communication, referencing open‑source DT frameworks such as Eclipse Ditto and BaSyx for connectivity and standard compliance, while noting that AECO‑specific solutions like Bentley iTwin.js rely on proprietary ecosystems, underscoring the need for standardized data schemas and integration mechanisms."
]