// Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor transmitting real-time operational data"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor transmitting real-time operational data"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor transmitting real-time operational data"
    DTDFVocab:producedData LightDataTransmitted
]

// Data Transmitted
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

// Sensor Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature measurements"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy data"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance LightData : DTDFVocab:Data [
    base:desc "Real-time light level measurements"
    DTDFVocab:fromData LightDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// BIM Model
instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "BIM model containing geometric, spatial, and functional data for the building infrastructure"
    DTDFVocab:inputTo BIMAuthoringTool, ModelDrivenEngineering, EclipseDitto
]

// Physical Acting Components
instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Actuator for controlling lighting systems in the building"
]

instance HVACValve : DTDFVocab:ActingComponent [
    base:desc "Actuator for regulating HVAC system operations"
]

// Enablers
instance BIMAuthoringTool : DTDFVocab:Enabler [
    base:desc "BIM authoring tool for creating and managing building information models"
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for IoT connectivity and sensor data ingestion"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for digital twin management and state synchronization"
    DTDFVocab:enables RealTimeMonitoringService, SimulationService, PredictiveAnalyticsService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for interactive 3D visualization"
    DTDFVocab:enables Interactive3DVisualizationService
]

instance ModelDrivenEngineering : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering techniques for automated BIM transformation and runtime artifacts using Design Science Research (DSR) methodology; continuous evolution through service extensions and ODTE metric validation; modular service-oriented architecture with standardized extension points for interconnected twins"
    DTDFVocab:enables SimulationService, PredictiveAnalyticsService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous real-time monitoring of building systems using sensor data"
    DTDFVocab:provides RealTimeDataInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building systems for performance analysis"
    DTDFVocab:provides SimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy optimization, visual comfort, and non-visual health effects"
    DTDFVocab:provides EnergyUsageInsight, VisualComfortInsight, NonVisualHealthInsight, MaintenanceSchedulingInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization of building systems using Unreal Engine 5"
    DTDFVocab:provides VisualizationInsight
]

// Insights
instance RealTimeDataInsight : DTDFVocab:Insight [
    base:desc "Real-time operational data for immediate system monitoring"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulated performance outcomes for building systems"
]

instance EnergyUsageInsight : DTDFVocab:Insight [
    base:desc "Predicted energy consumption patterns for optimization"
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Analysis of visual comfort levels based on lighting and spatial data"
]

instance NonVisualHealthInsight : DTDFVocab:Insight [
    base:desc "Assessment of non-visual health effects from environmental factors"
]

instance MaintenanceSchedulingInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance schedule for building systems"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D visual representation of building infrastructure"
]

// Environment
instance BuildingEnvironment : DTDFVocab:Environment [
    base:desc "A building infrastructure represented as a Digital Twin for a Living Lab case study, enabling real-time monitoring, simulation, and life cycle optimization of physical assets."
    base:contains TemperatureSensor, OccupancySensor, LightSensor, LightingController, HVACValve
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands sent from the Digital Twin to BCS actuators (e.g., adjusting lighting levels or HVAC settings) via Eclipse Hono and Ditto."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization between physical assets and digital counterparts with sensor data updates and control command execution occurring within milliseconds to seconds."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized DT Framework orchestrating BIM data, Hono/Ditto data exchange, Unreal Engine visualization, and modular services for holistic building management."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the entire building life cycle from design through construction, operation, and refurbishment phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Evaluated using the Overall Digital Twin Entanglement (ODTE) metric to measure synchronization accuracy between physical and virtual counterparts."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono and Ditto middleware for real-time data exchange."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized interfaces enabling integration with external systems (e.g., energy management platforms) via Eclipse Hono and Ditto."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM standards for semantic modeling and standardized extension points for service integration."
]