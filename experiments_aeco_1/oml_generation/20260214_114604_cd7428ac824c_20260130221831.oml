// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modelled in BIM and deployed on site, streams temperature measurements to the Digital Twin via Eclipse Hono and Ditto."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modelled in BIM, streams occupancy measurements to the Digital Twin."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor modelled in BIM, streams daylight level measurements to the Digital Twin."
    DTDFVocab:producedData IlluminanceDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]

// C5: Data instances
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature measurement data streamed from the building."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoTwinManager
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy measurement data from occupancy sensors."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoTwinManager
]

instance IlluminanceData : DTDFVocab:Data [
    base:desc "Real‑time illuminance measurement data from illuminance sensors."
    DTDFVocab:fromData IlluminanceDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoTwinManager
]

// C2: Acting components
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control device modelled in BIM, can be commanded by the Digital Twin to adjust lighting schedules."
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve actuator modelled in BIM, enables the Twin to set HVAC set‑points."
]

instance BCSGenericActuator : DTDFVocab:ActingComponent [
    base:desc "Generic building control‑system actuator modelled in BIM for miscellaneous control actions."
]

// C10: Models/Data
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "BIM semantic model enriched with device metadata for sensors and actuators."
    DTDFVocab:inputTo ModelDrivenPipeline
]

instance RuntimeSensorDataModel : DTDFVocab:Model [
    base:desc "Model representing runtime sensor data streams for transformation into Twin data structures."
    DTDFVocab:inputTo ModelDrivenPipeline
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model defining how the Twin issues commands to actuators."
    DTDFVocab:inputTo ModelDrivenPipeline
]

instance Visual3DModel : DTDFVocab:Model [
    base:desc "3D visual model of the building rendered in Unreal Engine 5."
    DTDFVocab:inputTo UnrealEngine5Renderer, ModelDrivenPipeline
]

// C11: Enablers (tooling & enablers)
instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono IoT gateway for ingesting sensor measurement streams from the physical building."
    DTDFVocab:enables RealTimeMonitoringDashboard, PhysicsBasedSimulation
]

instance EclipseDittoTwinManager : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for digital‑twin state management, receives data from Hono and stores Twin state."
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalyticsEnergyOptimization, Immersive3DVisualization
]

instance UnrealEngine5Renderer : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 provides immersive 3D visualization of the building twin."
    DTDFVocab:enables Immersive3DVisualization
]

instance ModelDrivenPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering tooling that automatically transforms BIM and other models into runtime artifacts."
    DTDFVocab:enables RealTimeMonitoringDashboard, PhysicsBasedSimulation, PredictiveAnalyticsEnergyOptimization, Immersive3DVisualization
]

instance ServiceIntegrationExtensionPoint : DTDFVocab:Enabler [
    base:desc "Standardized extension points enabling integration of additional services into the twin ecosystem."
    DTDFVocab:enables RealTimeMonitoringDashboard, PhysicsBasedSimulation, PredictiveAnalyticsEnergyOptimization, Immersive3DVisualization
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Dashboard providing real‑time monitoring of sensor data and Twin state."
    DTDFVocab:provides VisualDecisionSupportInsight
]

instance PhysicsBasedSimulation : DTDFVocab:Service [
    base:desc "Physics‑based simulation service for evaluating building performance under different scenarios."
    DTDFVocab:provides PredictiveAlertInsight
]

instance PredictiveAnalyticsEnergyOptimization : DTDFVocab:Service [
    base:desc "Predictive analytics service delivering optimization recommendations for energy usage."
    DTDFVocab:provides LightingScheduleRecommendation, HVACSetpointRecommendation, PredictiveAlertInsight
]

instance Immersive3DVisualization : DTDFVocab:Service [
    base:desc "Immersive 3D visualization in Unreal Engine 5 for decision support."
    DTDFVocab:provides VisualDecisionSupportInsight
]

// C17: Insights
instance LightingScheduleRecommendation : DTDFVocab:Insight [
    base:desc "Recommendation for optimal lighting schedules based on occupancy and daylight data."
]

instance HVACSetpointRecommendation : DTDFVocab:Insight [
    base:desc "Recommendation for HVAC set‑points to minimize energy consumption while maintaining comfort."
]

instance PredictiveAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive alert indicating potential comfort violations or equipment failures."
]

instance VisualDecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Visual decision‑support dashboard integrated in Unreal Engine 5 for facility managers."
]

// C7: Environment (system under study)
instance AcademicBuildingLivingLab : DTDFVocab:Environment [
    base:contains TemperatureSensor, OccupancySensor, IlluminanceSensor, LightingControlActuator, HVACValveActuator, BCSGenericActuator
]

// C8: Twinning process & evolution
instance TwinCreationProcess : DTDFVocab:Component [
    base:desc "Process that starts with BIM model enrichment, validation, automatic extraction of device metadata, generation of Hono/Ditto configuration, deployment of runtime artifacts, and continuous runtime configuration management; evolution is supported through modular extensions and re‑generation of artifacts without full redeployment."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command flow from the Digital Twin to the building control actuators through the same Hono/Ditto middleware, allowing the Twin to issue lighting or HVAC set-point adjustments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time (continuous) synchronization; data are processed as they arrive, supporting near-instantaneous control loops."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service-oriented architecture where the enriched BIM model is the central semantic hub, Hono/Ditto provide the real-time communication layer, and optional services (e.g., analytics, control plugins) are plugged in via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers design (BIM authoring), construction (installation of sensors/actuators) and operation (post-occupancy monitoring and optimisation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed using the Overall Digital Twin Entanglement (ODTE) metric; the BIM model is validated before transformation to ensure semantic correctness and reduce drift between physical and digital states."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real-time data exchange is realized through Eclipse Hono (IoT gateway) linked to Eclipse Ditto for twin state synchronization; the middleware mediates bidirectional communication between physical devices and the Digital Twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Built upon BIM as an industry-standard data model; uses standardized extension points and adheres to open-source DT frameworks (Eclipse Hono/Ditto) that follow interoperable protocols."
]