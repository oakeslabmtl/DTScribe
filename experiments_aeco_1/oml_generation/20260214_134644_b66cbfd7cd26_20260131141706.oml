// Sensors
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in BIM, deployed on-site, transmitting temperature data via MQTT"
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor in building sensors network, returning humidity metrics"
    DTDFVocab:producedData HumidityDataTransmitted
]
instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Light level sensor measuring indoor illumination, integrated into BIM model"
    DTDFVocab:producedData LightLevelDataTransmitted
]
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector providing presence data for facility management"
    DTDFVocab:producedData OccupancyDataTransmitted
]

// Actuators
instance ProgrammableLightingActuator : DTDFVocab:ActingComponent [
    base:desc "Programmable lighting fixture defined within BIM and twin, receives lighting commands from twin"
]
instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve actuator defined within BIM and twin, receives HVAC control commands"
]

// Data Transmitted
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]
instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// Sensor Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Parsed temperature value from MQTT message, stored in DT"
    DTDFVocab:inputTo EclipseDittoEnabler
]
instance HumidityData : DTDFVocab:Data [
    base:desc "Parsed humidity value from MQTT message, stored in DT"
    DTDFVocab:inputTo EclipseDittoEnabler
]
instance LightLevelData : DTDFVocab:Data [
    base:desc "Parsed light level value from MQTT message, stored in DT"
    DTDFVocab:inputTo EclipseDittoEnabler
]
instance OccupancyData : DTDFVocab:Data [
    base:desc "Parsed occupancy status from MQTT message, stored in DT"
    DTDFVocab:inputTo EclipseDittoEnabler
]

// Models
instance BIMIFCModel : DTDFVocab:Model [
    base:desc "BIM IFC model representing the LivingLab building, enriched with device annotations"
    DTDFVocab:inputTo MDEToolingEnabler
]
instance RuntimeEntityRegistryModel : DTDFVocab:Model [
    base:desc "Runtime entity registry mapping physical devices to twin entities"
    DTDFVocab:inputTo MDEToolingEnabler
]
instance SensorMetadataModel : DTDFVocab:Model [
    base:desc "Metadata describing sensor capabilities and locations"
    DTDFVocab:inputTo MDEToolingEnabler
]
instance ActuatorMetadataModel : DTDFVocab:Model [
    base:desc "Metadata describing actuator types and control parameters"
    DTDFVocab:inputTo MDEToolingEnabler
]
instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model governing HVAC and lighting operations"
    DTDFVocab:inputTo MDEToolingEnabler
]
instance ConfigurationFileModel : DTDFVocab:Model [
    base:desc "Configuration files for device control and firmware"
    DTDFVocab:inputTo MDEToolingEnabler
]
instance DittoTwinModel : DTDFVocab:Model [
    base:desc "Ditto twin representation derived from BIM and runtime models"
    DTDFVocab:inputTo MDEToolingEnabler
]

// Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT broker handling continuous telemetry from building sensors"
    DTDFVocab:enables RealTimeMonitoringDashboardService
]
instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto platform receiving MQTT messages, maintaining twin registry"
    DTDFVocab:enables RealTimeMonitoringDashboardService, LightingHVACSimulationService, EnergyOptimizationService, MaintenanceTaskPlanningService, ImmersiveVisualizationService
]
instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive visualization of building environment"
    DTDFVocab:enables ImmersiveVisualizationService
]
instance MDEToolingEnabler : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering tooling for transforming BIM to runtime artifacts"
    DTDFVocab:enables LightingHVACSimulationService, EnergyOptimizationService, MaintenanceTaskPlanningService
]
instance BIMSoftwareEnabler : DTDFVocab:Enabler [
    base:desc "BIM authoring software used for model creation and annotation"
    DTDFVocab:enables LightingHVACSimulationService
]

// Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real-time monitoring dashboards displaying live sensor data and analytics"
    DTDFVocab:provides EnergyUseForecastInsight, OccupantComfortInsight
]
instance LightingHVACSimulationService : DTDFVocab:Service [
    base:desc "Simulation service for lighting and HVAC scenarios using thermal models"
    DTDFVocab:provides OccupantComfortInsight
]
instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement learning-based energy consumption optimization"
    DTDFVocab:provides PolicyOptimizationOutputAction
]
instance MaintenanceTaskPlanningService : DTDFVocab:Service [
    base:desc "Task planning service for building maintenance scheduling"
    DTDFVocab:provides MaintenanceSchedulingRecommendationAction
]
instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization rendered in Unreal Engine 5"
    DTDFVocab:provides ImmersiveVisualizationInsight
]

// Insights and Actions
instance EnergyUseForecastInsight : DTDFVocab:Insight [
    base:desc "Energy use forecast predictions generated by analytics"
]
instance OccupantComfortInsight : DTDFVocab:Insight [
    base:desc "Occupant comfort model insights derived from sensor data"
]
instance PolicyOptimizationOutputAction : DTDFVocab:Action [
    base:desc "Policy optimization outputs informing facility managers (manual review)"
    DTDFVocab:IsAutomatic false
]
instance MaintenanceSchedulingRecommendationAction : DTDFVocab:Action [
    base:desc "Automated maintenance scheduling recommendations"
    DTDFVocab:IsAutomatic true
]
instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D immersive visualization insight of building state"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control messages generated by the twin (e.g., lighting schedules, HVAC set‑points) sent from the virtual model through Ditto, received by Hono, and ultimately routed to the physical actuators to change building conditions."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time synchronization between the physical building and its digital twin, with data flowing and commands exchanged on a near‑instantaneous basis."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated system comprising the BIM extraction engine, Hono/Ditto communication layer, simulation module, visualization interface, and service‑extension points exposed via APIs for custom DT services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (ideal model), construction (manufactured model), commissioning, and operation phases, with the DT evolving from static BIM to runtime‑enabled twin throughout the asset lifecycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Verification of model alignment with the Physical System using the Overall Digital Twin Entanglement (ODTE) metric, periodic synchronization checks to mitigate semantic drift, and simulation validation against measured data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono serves as the message broker, handling incoming telemetry and outgoing commands; Eclipse Ditto acts as the twin server, routing messages between the physical devices and the twin application layer."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability with external IoT middleware, BIM exchanges from other stakeholders, and potential integration with other building twins via standard APIs (e.g., MQTT, REST)."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not explicitly addressed in the document; data ownership and privacy concerns are implied to reside with the building owner and management, but explicit policies are not described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM (IFC) provides the standardized spatial and semantic model; integration follows standardized protocols via Eclipse Hono and Ditto, supporting interoperable twin deployment."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "No detailed security or safety framework is provided; the use of Hono/Ditto suggests the application of TLS encryption and access control, but explicit safety guarantees for remote actuation are not described."
]