// ==================== C3: Physical sensing components ====================
// Temperature sensor defined in BIM
instance BuildingTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor component defined in the BIM model; publishes real‑time temperature readings via Eclipse Hono to Eclipse Ditto."
    DTDFVocab:producedData TemperatureDataProd
]

// Occupancy sensor defined in BIM
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor component defined in the BIM model; publishes presence detection data via Eclipse Hono to Eclipse Ditto."
    DTDFVocab:producedData OccupancyDataProd
]

// Light level sensor defined in BIM
instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Light level sensor component defined in the BIM model; publishes ambient illumination data via Eclipse Hono to Eclipse Ditto."
    DTDFVocab:producedData LightLevelDataProd
]

// ==================== C4: DataTransmitted (from sensors) ====================
instance TemperatureDataProd : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingTemperatureSensor
]

instance OccupancyDataProd : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightLevelDataProd : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

// ==================== C10: Data objects ====================
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature value (°C) with unit and range validation enforced by Ditto policies."
    DTDFVocab:fromData TemperatureDataProd
    DTDFVocab:inputTo RealTimeDataValidator
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy state (occupied / vacant) validated by Ditto policies."
    DTDFVocab:fromData OccupancyDataProd
    DTDFVocab:inputTo RealTimeDataValidator
]

instance LightLevelData : DTDFVocab:Data [
    base:desc "Real‑time ambient light level (lux) validated by Ditto policies."
    DTDFVocab:fromData LightLevelDataProd
    DTDFVocab:inputTo RealTimeDataValidator
]

// ==================== C11: Enablers ====================
// Middleware that persists events in Eclipse Ditto
instance DittoMiddleware : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto middleware handling MQTT/HTTP ingestion, policy‑based validation and persistent storage of sensor events."
    DTDFVocab:enables MonitoringService, ControlService
]

// Validator that checks units, ranges and converts data before further processing
instance RealTimeDataValidator : DTDFVocab:Enabler [
    base:desc "Real‑time data validator performing unit conversion, range checks and forwarding validated data to downstream services."
    DTDFVocab:enables RealTimeSyncService
]

// Visualization engine in Unreal Engine 5
instance UnrealVisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 visualization layer consuming validated data streams for interactive 3‑D building performance rendering."
    DTDFVocab:enables VisualizationService
]

// Model‑Driven Engineering (MDE) pipeline that extracts enriched BIM models and generates DT artifacts
instance MDEPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Automated MDE pipeline that transforms enriched BIM models into deployable digital‑twin artifacts and performs quality checks."
    DTDFVocab:enables CustomAnalyticsService
]

// ==================== C6: Services ====================
instance RealTimeSyncService : DTDFVocab:Service [
    base:desc "Service that continuously synchronizes sensor data from Ditto to the UE5 visualization layer."
    DTDFVocab:provides EnergyConsumptionInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors system states, detects anomalies and supplies predictive‑maintenance insights."
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Service that receives control commands from the UE5 layer and forwards them via Ditto to physical actuators."
    DTDFVocab:provides AdjustLightingAction, TurnOnHVACAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that renders real‑time building performance (temperature, occupancy, lighting) in Unreal Engine 5."
    DTDFVocab:provides LightingOptimizationInsight
]

instance CustomAnalyticsService : DTDFVocab:Service [
    base:desc "Extension point service where DT engineers can plug in custom analytics (e.g., predictive optimisation, energy forecasting)."
    DTDFVocab:provides SendControlCommandAction
]

// ==================== C17: Insights ====================
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight about current energy consumption derived from real‑time temperature and occupancy data."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting maintenance actions based on long‑term trends detected in sensor streams."
]

instance LightingOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending lighting set‑point adjustments to improve comfort while reducing energy use."
]

// ==================== C17: Actions ====================
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Action to adjust brightness or color temperature of lighting actuators."
    DTDFVocab:IsAutomatic false
]

instance TurnOnHVACAction : DTDFVocab:Action [
    base:desc "Action to activate HVAC system based on temperature thresholds."
    DTDFVocab:IsAutomatic false
]

instance SendControlCommandAction : DTDFVocab:Action [
    base:desc "Action representing a custom control command generated by a plug‑in analytics service."
    DTDFVocab:IsAutomatic true
]

// ==================== C2: Acting components ====================
instance LightingActuatorComponent : DTDFVocab:ActingComponent [
    base:desc "LightTwinComponent instance that controls building lighting devices; receives commands via UnrealTwinController - DittoController."
]

instance HVACActuatorComponent : DTDFVocab:ActingComponent [
    base:desc "Actuator component representing HVAC control units; receives set‑point commands through Ditto."
]

// ==================== C10: Models ====================
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Enriched BIM model providing 3‑D geometry for Unreal Engine rendering."
    DTDFVocab:inputTo UnrealVisualizationEngine, MDEPipelineEnabler
]

instance LightingBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model (LightTwinComponent + LightFeatureParser) describing on/off, brightness and color‑temperature semantics."
    DTDFVocab:inputTo RealTimeDataValidator, ControlService
]

instance HVACBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model defining HVAC set‑point handling and safety constraints."
    DTDFVocab:inputTo RealTimeDataValidator, ControlService
]

// ==================== C17: Environment (centralized twin) ====================
instance CentralizedDigitalTwinHub : DTDFVocab:Environment [
    base:contains BuildingTemperatureSensor, OccupancySensor, LightLevelSensor,
           LightingActuatorComponent, HVACActuatorComponent,
           RealTimeSyncService, MonitoringService, ControlService,
           VisualizationService, CustomAnalyticsService,
           BIMGeometricModel, LightingBehaviorModel, HVACBehaviorModel
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange capabilities that keep the physical building and its digital counterpart continuously synchronized; however, specific update frequencies, latency limits, or temporal granularity are not detailed in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, service‑oriented architecture with standardized extension points and runtime configuration management; the DT Framework serves as the central orchestration component, mediating bidirectional data exchange between BIM models, sensors, and custom analytics services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The proposed model‑driven DT deployment framework supports a full DT lifecycle composed of (1) device modeling where Building Control Engineers enrich BIM models with explicit sensor, actuator, and controller definitions; (2) model transformation using Model‑Driven Engineering (MDE) to extract a structured representation from the enriched BIM; (3) automatic generation of deployable DT artifacts (code, configuration, and service descriptors); (4) deployment and runtime operation during which real‑time data exchange synchronises the physical building and its digital counterpart; (5) interactive, immersive visualization for monitoring and control; and (6) post‑deployment evolution through the integration of custom services and analytics via standardized extension points. Governance is enforced by the modular architecture and its extension‑point contracts, which define how artifacts are versioned, validated and evolved across stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by enriching BIM models with device metadata and by using validation, conversion, and configuration components before deployment. Quality assurance includes Eclipse Ditto’s policy‑based validation (checking sensor value ranges, units, and actuator command safety), pre‑execution checks for commands, and fault tolerance via Hono’s at‑least‑once message delivery combined with Ditto’s persistent event storage. These mechanisms provide error detection, correction, and uncertainty mitigation throughout the twin’s lifecycle."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external and heterogeneous systems is achieved via interoperable interfaces and standardized extension points, supporting custom service integration and analytics; the documents do not specify concrete data exchange protocols or standards such as OPC UA or MQTT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Interoperability is achieved via a modular architecture with standardized extension points for plug‑in integration. The approach aligns with the connectivity and standard‑compliance strategies of open‑source DT frameworks such as Eclipse Ditto and BaSyx, which implement common IoT standards (e.g., NGSI‑LD, MQTT, OPC‑UA), although the documents do not list explicit industry standards (such as IFC, ISO 19650) or certification requirements."
]