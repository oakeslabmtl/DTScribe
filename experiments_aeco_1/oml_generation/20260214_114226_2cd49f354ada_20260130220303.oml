// C3: Physical sensing components
instance HVACTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Building automation temperature sensor embedded in the enriched BIM model for HVAC monitoring."
    DTDFVocab:producedData HVACTemperatureDataStream
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance HVACTemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACTemperatureSensor
]

// C10: Models/Data
instance HVACTemperatureRealTimeData : DTDFVocab:Data [
    base:desc "Real‑time temperature data stream from HVAC sensor used by the Digital Twin."
    DTDFVocab:fromData HVACTemperatureDataStream
    DTDFVocab:inputTo DTFrameworkHub
]

instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM artifact containing definitions of sensors, actuators, and controllers with a unified semantic layer."
    DTDFVocab:inputTo DTFrameworkHub
]

instance MDETransformationPipeline : DTDFVocab:Model [
    base:desc "Model‑Driven Engineering transformation pipeline that extracts structured representations from enriched BIM and generates deployable DT artifacts."
    DTDFVocab:inputTo DTFrameworkHub
]

// C11: Enablers
instance DTFrameworkHub : DTDFVocab:Enabler [
    base:desc "Central DT Framework hub that streams data from building sensors and manages model‑to‑runtime linkage."
    DTDFVocab:enables RealTimeTwinSyncService
]

// C6: Services
instance RealTimeTwinSyncService : DTDFVocab:Service [
    base:desc "Service that synchronizes physical sensor data with the Digital Twin in real time."
    DTDFVocab:provides AnomalyDetectionInsight, AdjustHVACSetpointAction
]

// C17: Insights/Actions
instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting operational anomalies in HVAC performance based on real‑time temperature data."
]

instance AdjustHVACSetpointAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust HVAC setpoint in response to detected anomalies."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Facility Managers interact with the deployed Digital Twin for real‑time monitoring and control, allowing the DT to issue commands that affect physical building systems. The DT therefore supports control flows from the virtual model back to physical actuators and devices. No details are given regarding command types, message formats, validation/authentication, feedback loops, conflict resolution, or execution confirmation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The model‑driven DT framework defines four lifecycle phases: (1) **Device Modeling** – building control engineers enrich BIM models with semantic definitions of sensors, actuators and controllers; (2) **Model Transformation & Artifact Generation** – Model‑Driven Engineering (MDE) extracts structured representations from the enriched BIM and automatically produces deployable DT artifacts (e.g., service descriptors, configuration files); (3) **Deployment & Runtime Operation** – the generated artifacts are instantiated, establishing real‑time data exchange that continuously synchronises the physical building system with its digital twin; (4) **Post‑Deployment Evolution** – a modular architecture with standardized extension points enables DT engineers to add custom services, analytics or plug‑ins, allowing the twin to evolve without redeploying the whole system. Transitions between phases are managed automatically by the MDE pipeline, and lifecycle governance is expressed through the role‑based responsibilities defined in Table I (Building Control Engineer, Facility Manager, DT Engineer)."
]