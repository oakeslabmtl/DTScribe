// C3: Physical sensing component
instance BuildingBIMSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor defined in the BIM model with semantic annotations real‑time measurements streamed to the Digital Twin"
    DTDFVocab:producedData BuildingSensorDataTransmitted
]

// C4: Physical-to-virtual interaction – data transmitted from sensor
instance BuildingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Bidirectional real‑time data exchange layer streaming sensor measurements from the building to the Digital Twin"
    DTDFVocab:producedFrom BuildingBIMSensor
]

// C10: Data generated from sensor stream
instance BuildingSensorData : DTDFVocab:Data [
    base:desc "Continuous sensor measurement data synchronized with the Digital Twin runtime platform"
    DTDFVocab:fromData BuildingSensorDataTransmitted
    DTDFVocab:inputTo TransformationEngineEnabler
]

// C11: Enabler - model‑driven engineering transformation engine
instance TransformationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering transformation engine that converts enriched BIM models into executable Digital Twin artifacts"
    DTDFVocab:enables AutomaticDTGenerationService
]

// C6: Service - automatic DT generation
instance AutomaticDTGenerationService : DTDFVocab:Service [
    base:desc "Service that automatically generates deployable Digital Twin components from enriched BIM models"
    DTDFVocab:provides ContinuousEvolutionInsight
]

// C17: Insight - continuous evolution
instance ContinuousEvolutionInsight : DTDFVocab:Insight [
    base:desc "Insight that the Digital Twin can evolve continuously via modular extensions and versioned model artifacts"
]

// C2: Acting component (actuator/controller)
instance BuildingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Controller object modeled in BIM representing actuators receives remote control commands for HVAC valves or lighting"
]

// C4: Physical-to-virtual interaction – data transmitted to actuator
instance ActuatorCommandDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Real‑time command stream from the Digital Twin to physical actuators via the data exchange layer"
]

// C10: Data generated for actuator commands
instance ActuatorCommandData : DTDFVocab:Data [
    base:desc "Actuation command data synchronized with physical devices"
    DTDFVocab:fromData ActuatorCommandDataTransmitted
    DTDFVocab:inputTo CommandExecutionEnabler
]

// C11: Enabler - command execution runtime component
instance CommandExecutionEnabler : DTDFVocab:Enabler [
    base:desc "Runtime component that dispatches actuation commands to physical devices"
    DTDFVocab:enables ActuatorCommandExecutionService
]

// C6: Service - command execution
instance ActuatorCommandExecutionService : DTDFVocab:Service [
    base:desc "Service that executes remote control actions on HVAC valves or lighting systems"
    DTDFVocab:provides ActuationAction
]

// C17: Action - actuation
instance ActuationAction : DTDFVocab:Action [
    base:desc "Action to adjust HVAC valve position or dim lighting based on control logic"
    DTDFVocab:IsAutomatic true
]

// C10: Model – enriched BIM device model
instance EnrichedDeviceModel : DTDFVocab:Model [
    base:desc "Enriched BIM model linking geometric building components with semantic sensor, actuator, and controller definitions"
    DTDFVocab:inputTo TransformationEngineEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Through the same bidirectional data exchange layer, the DT enables facility managers and DT engineers to issue control commands from the digital twin to physical devices. Commands (e.g., actuator activation, set‑point adjustments) are formatted according to the framework’s standardized service interfaces and transmitted over the established communication channels, with execution confirmation routed back to the DT."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange capabilities provide continuous synchronization between the physical building and its digital counterpart; the document does not specify exact synchronization frequencies, latency constraints, or temporal granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The proposed DT framework uses a modular, service‑oriented architecture centred on a central DT Framework hub that orchestrates bidirectional data exchange among enriched BIM models, device models, and external analytics services. Standardized extension points and runtime configuration management enable dynamic integration and coordination of components."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a five‑stage life‑cycle: (1) Device and control‑logic modeling inside the BIM environment where sensors, actuators and controllers are semantically annotated; (2) Model‑driven extraction where MDE transforms the enriched BIM model into structured intermediate representations; (3) Automatic generation of deployable DT artifacts (software components, configuration files) with minimal manual steps; (4) Runtime deployment providing real‑time data exchange and interactive 3‑D visualization for monitoring and control; (5) Evolution stage where DT engineers add or replace services through the framework’s standardized extension points. Transitions between stages are managed by the deployment engine and are governed by role‑based responsibilities (Building Control Engineer, Facility Manager, DT Engineer)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT framework adopts a modular, service‑oriented architecture with standardized extension points that expose interoperable communication protocols for heterogeneous systems. It supports runtime configuration over typical enterprise network topologies, ensuring scalability and maintainability. The architecture leverages the connectivity and standard compliance features of open‑source frameworks such as Eclipse Ditto and BaSyx, providing reliable, low‑latency bidirectional links between physical sensors and the digital twin."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The framework emphasizes interoperability across heterogeneous systems and permits integration of external services through standardized extension points, but no concrete data exchange protocols, standards, or integration patterns are detailed in the document."
]