// C3: Physical Sensing Components
instance EnvironmentalSensorNetwork : DTDFVocab:SensingComponent [
    base:desc "Real-time data collection infrastructure leveraging Eclipse Hono for device connectivity and Eclipse Ditto for state management, supporting continuous synchronization of operational data from physical building assets"
    DTDFVocab:producedData EnvironmentalDataTransmission
]

instance BuildingManagementSystemSensorInterface : DTDFVocab:SensingComponent [
    base:desc "Interface for integrating BMS data streams (e.g., BACnet, Modbus protocols) with the Digital Twin framework, enabling real-time monitoring of building systems"
    DTDFVocab:producedData BmsDataTransmission
]

instance IoTSensorArray : DTDFVocab:SensingComponent [
    base:desc "Collection of IoT devices deployed across the LEED Platinum academic building for environmental and structural parameter monitoring, supporting high-frequency data transmission"
    DTDFVocab:producedData IoTDataTransmission
]

// C4: Physical-to-Virtual Interaction
instance EnvironmentalDataTransmission : DTDFVocab:DataTransmitted [
    base:desc "Real-time transmission of environmental metrics (e.g., temperature, humidity, air quality) from IoT sensors to the Digital Twin via Eclipse Hono and Ditto protocols"
    DTDFVocab:producedFrom EnvironmentalSensorNetwork
]

instance BmsDataTransmission : DTDFVocab:DataTransmitted [
    base:desc "Continuous synchronization of building management system operational data (e.g., HVAC status, equipment health) using standardized protocols like BACnet and Modbus"
    DTDFVocab:producedFrom BuildingManagementSystemSensorInterface
]

instance IoTDataTransmission : DTDFVocab:DataTransmitted [
    base:desc "High-frequency data stream from distributed IoT sensors capturing dynamic building performance parameters for real-time Digital Twin synchronization"
    DTDFVocab:producedFrom IoTSensorArray
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Semantically enriched Building Information Model incorporating geometric, spatial, and functional characteristics of building components, serving as the foundational static representation for the Digital Twin"
    DTDFVocab:inputTo ModelDrivenEngineeringFramework
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Aggregated operational data from physical assets (sensors, BMS) processed through validation and normalization pipelines to ensure quality before integration into the Digital Twin"
    DTDFVocab:fromData EnvironmentalDataTransmission, BmsDataTransmission, IoTDataTransmission
    DTDFVocab:inputTo DataIntegrationEnabler
]

instance BuildingLifecycleData : DTDFVocab:Data [
    base:desc "Comprehensive dataset spanning design, construction, and operational phases, enabling longitudinal analysis of building performance across its lifecycle"
    DTDFVocab:fromData RealTimeOperationalData
    DTDFVocab:inputTo ModelDrivenEngineeringFramework
]

// C11: Enablers
instance EclipseHonoIoTGateway : DTDFVocab:Enabler [
    base:desc "Open-source IoT connectivity framework enabling real-time data ingestion from physical assets using standardized protocols, serving as the primary gateway for sensor data transmission"
    DTDFVocab:enables RealTimeDataIngestionService, DataPreprocessingService
]

instance EclipseDittoStateManager : DTDFVocab:Enabler [
    base:desc "Digital Twin state management solution providing live synchronization between physical assets and their virtual counterparts, ensuring operational data consistency"
    DTDFVocab:enables DigitalTwinSynchronizationService, EventTriggeredUpdateService
]

instance ModelDrivenEngineeringFramework : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering framework implementing MDE4DT principles to automate model transformations between static BIM representations and dynamic Digital Twin requirements"
    DTDFVocab:enables BIMToDTTransformationService, ModelValidationService
]

instance DataIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Modular architecture component bridging static BIM models with dynamic operational data, enabling seamless integration of heterogeneous data sources"
    DTDFVocab:enables DataQualityAssuranceService, HeterogeneousDataIntegrationService
]

instance EclipseBaSyxPlatform : DTDFVocab:Enabler [
    base:desc "Open-source Industry 4.0 platform providing modular architecture and interoperability for Digital Twin development, with implied OPC UA integration and asset administration shell support"
    DTDFVocab:enables DigitalTwinFrameworkService, ServiceExtensionManagementService
]

