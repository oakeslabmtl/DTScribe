    DTDFVocab:provides ServiceExtensionInsight
]

instance PhysicsBasedSimulationService : DTDFVocab:Service [
    base:desc "Execution environment for physics-based simulations modeling building behavior under varying conditions (occupancy, weather, system failures)"
