    DTDFVocab:provides ModelValidationInsight
]

instance DataQualityAssuranceService : DTDFVocab:Service [
    base:desc "Continuous monitoring and assurance of data quality across integrated heterogeneous data sources in the Digital Twin framework"
    DTDFVocab:provides DataQualityAssuranceInsight
]

instance HeterogeneousDataIntegrationService : DTDFVocab:Service [
