// C2: Acting Components
instance OccupancySensorActuator : DTDFVocab:ActingComponent [
    base:desc "Building automation system actuator for occupancy-based control policies, modeled in BIM with metadata for bidirectional communication via Eclipse Hono/Ditto middleware. Enables dynamic adjustment of lighting/HVAC based on real-time occupancy patterns."
]

instance TemperatureHumidityActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC control actuator receiving temperature/humidity setpoints from reinforcement learning policies (BOREALIS project). Integrated with BIM model for automated deployment and real-time adjustments via Ditto registry."
]

instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "TwinLight project lighting control actuator implementing occupancy-based dimming and circadian lighting strategies. Embedded in BIM model with control logic metadata for automated deployment via Hono/Ditto."
]

instance HVACControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Building control system actuator for HVAC systems, receiving optimized setpoints from predictive analytics services. Modeled in BIM with semantic metadata for real-time synchronization via Ditto."
]

instance MotorizedShadeActuator : DTDFVocab:ActingComponent [
    base:desc "Automated shading system actuator controlled via reinforcement learning policies (BOREALIS). Integrated with BIM for real-time adjustments based on luminosity and occupancy data."
]

instance SmartMeterActuator : DTDFVocab:ActingComponent [
    base:desc "IoT-enabled smart meter actuator for energy consumption monitoring and control. Provides bidirectional communication with DT via Eclipse Hono for real-time energy optimization."
]

// C3: Physical Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "IoT occupancy sensor deployed in physical asset, modeled in BIM with metadata including sensor ID, calibration parameters, and data format. Transmits real-time presence data for adaptive control policies."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "BAS temperature/humidity sensor with post-occupancy data capabilities. Modeled in BIM environment with calibration parameters for real-time environmental monitoring and iterative refinement of control policies via BOREALIS RL."
    DTDFVocab:producedData TemperatureHumidityDataTransmitted
]

instance LuminositySensor : DTDFVocab:SensingComponent [
    base:desc "Light intensity sensor for adaptive lighting control systems. Integrated with BIM model to provide real-time luminosity data for TwinLight project's occupancy-based dimming strategies."
    DTDFVocab:producedData LuminosityDataTransmitted
]

instance CO2Monitor : DTDFVocab:SensingComponent [
    base:desc "CO2 concentration sensor for indoor air quality monitoring. Deployed as part of BAS with metadata in BIM for real-time telemetry and ventilation control optimization."
    DTDFVocab:producedData CO2DataTransmitted
]

instance BASOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Building automation system occupancy sensor providing high-fidelity presence data. Modeled in BIM with device specifications for real-time synchronization with digital twin via Eclipse Hono."
    DTDFVocab:producedData BASOccupancyDataTransmitted
]

instance BASEnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "BAS environmental sensor suite (temperature, humidity, pressure) with post-occupancy data capabilities. Enriched in BIM model for iterative control policy refinement via reinforcement learning."
    DTDFVocab:producedData BASEnvironmentalDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor, BASOccupancySensor
    base:desc "Normalized occupancy telemetry data stream transmitted via Eclipse Hono (MQTT protocol) to Ditto digital twin registry for real-time processing and adaptive control."
]

instance TemperatureHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureHumiditySensor, BASEnvironmentalSensor
    base:desc "Environmental sensor data (temperature, humidity) normalized and transmitted via Eclipse Hono (AMQP protocol) to Ditto registry for building performance optimization."
]

instance LuminosityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LuminositySensor
    base:desc "Light intensity data stream transmitted via Eclipse Hono (HTTP protocol) for TwinLight project's adaptive lighting control systems."
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Monitor
    base:desc "CO2 concentration telemetry transmitted via Eclipse Hono (MQTT protocol) for indoor air quality monitoring and ventilation control optimization."
]

instance BASOccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BASOccupancySensor
    base:desc "High-fidelity BAS occupancy data stream transmitted via Eclipse Hono (AMQP protocol) for reinforcement learning-based control policy refinement."
]

instance BASEnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BASEnvironmentalSensor
    base:desc "Comprehensive BAS environmental data (temperature, humidity, pressure) transmitted via Eclipse Hono (MQTT protocol) for post-occupancy analysis and control optimization."
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Semantically enriched IFC model containing geometric, spatial, and functional data with embedded device metadata (sensor/actuator specifications, control policies). Serves as the authoritative source for digital twin deployment."
    DTDFVocab:inputTo BIMToRuntimeTransformer, DittoRegistryConfigurator
]

instance RuntimeDeviceModel : DTDFVocab:Model [
    base:desc "Metadata-extended BIM entities representing sensors, actuators, and controllers with device IDs, endpoint addresses, and control logic (e.g., TwinLight lighting policies, BOREALIS RL policies)."
    DTDFVocab:inputTo HonoProtocolAdapter
]

instance DigitalTwinRegistryModel : DTDFVocab:Model [
    base:desc "Ditto digital twin registry model storing live telemetry, historical data, and policy configurations. Enables semantic consistency between physical and virtual representations."
    DTDFVocab:inputTo DittoRegistry
]

instance VisualizationModel : DTDFVocab:Model [
    base:desc "Unreal Engine 5 assets (3D meshes, shaders) for interactive rendering of building operations with real-time data overlays (sensor heatmaps, control feedback)."
    DTDFVocab:inputTo UnrealEngineRenderer
]

instance OptimizationModel : DTDFVocab:Model [
    base:desc "Machine learning models (BOREALIS reinforcement learning agents) and rule-based engines (TwinLight control strategies) embedded in DT for autonomous decision-making."
]

instance MiddlewareArtifactModel : DTDFVocab:Model [
    base:desc "Eclipse Hono configurations for protocol adaptation (MQTT, AMQP, HTTP) and Ditto policies for access control and data validation."
    DTDFVocab:inputTo HonoProtocolAdapter
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Normalized occupancy data from multiple sensors, aggregated and validated for real-time monitoring and adaptive control policies."
    DTDFVocab:fromData OccupancyDataTransmitted, BASOccupancyDataTransmitted
    DTDFVocab:inputTo RealTimeMonitoringService
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Processed environmental data (temperature, humidity, CO2) with historical context for predictive analytics and control optimization."
    DTDFVocab:fromData TemperatureHumidityDataTransmitted, CO2DataTransmitted, BASEnvironmentalDataTransmitted
    DTDFVocab:inputTo PredictiveAnalyticsService
]

instance LuminosityData : DTDFVocab:Data [
    base:desc "Light intensity data processed for adaptive lighting control strategies and energy optimization."
    DTDFVocab:fromData LuminosityDataTransmitted
    DTDFVocab:inputTo LightingControlService
]

instance ControlPolicyData : DTDFVocab:Data [
    base:desc "Dynamic control policies generated via reinforcement learning (BOREALIS) and rule-based engines (TwinLight) for adaptive building systems."
    DTDFVocab:fromData OccupancyData, EnvironmentalData, LuminosityData
    DTDFVocab:inputTo AdaptiveControlService
]

instance HistoricalSensorLogs : DTDFVocab:Data [
    base:desc "Time-series sensor data logs used for post-occupancy analysis, failure prediction, and iterative refinement of control strategies."
    DTDFVocab:fromData OccupancyDataTransmitted, TemperatureHumidityDataTransmitted, CO2DataTransmitted
    DTDFVocab:inputTo PredictiveAnalyticsService
]

// C11: Enablers
instance BIMToRuntimeTransformer : DTDFVocab:Enabler [
    base:desc "Model transformation engine (EMF/Acceleo) that extracts runtime artifacts (Hono/Ditto configurations) from enriched BIM model for automated digital twin deployment."
    DTDFVocab:enables DeploymentAutomationService
]

instance HonoProtocolAdapter : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware providing protocol adaptation (MQTT, AMQP, HTTP) and bidirectional data exchange between heterogeneous IoT/BAS systems and digital twin."
    DTDFVocab:enables RealTimeMonitoringService
]

instance DittoRegistry : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin registry managing twin instances with CRUD operations, event sourcing, and state management for sensor telemetry and device states."
    DTDFVocab:enables DigitalTwinRegistryService
]

instance DittoRegistryConfigurator : DTDFVocab:Enabler [
    base:desc "Automated configurator that scans enriched BIM model for 'twinnable' devices and generates Ditto registry bindings for digital twin instances."
    DTDFVocab:enables DeploymentAutomationService
]

instance UnrealEngineRenderer : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 visualization engine enabling real-time 3D rendering with data-driven animations (sensor heatmaps, control feedback) for interactive monitoring."
    DTDFVocab:enables RealTimeMonitoringService
]

instance ModelValidationServiceEnabler : DTDFVocab:Enabler [
    base:desc "Validation framework ensuring BIM model compliance with semantic constraints (device connectivity, control logic consistency) before digital twin deployment."
    DTDFVocab:enables ModelValidationService
]

instance ODTEMetricCalculator : DTDFVocab:Enabler [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric calculator quantifying synchronization fidelity between physical and virtual representations."
]

instance CI/CDPipeline : DTDFVocab:Enabler [
    base:desc "Continuous integration/continuous deployment pipeline for automated testing and deployment of custom services (analytics plugins, third-party integrations)."
    DTDFVocab:enables ServiceExtensibilityService
]

instance AccessControlManager : DTDFVocab:Enabler [
    base:desc "Role-based access control system managing permissions for Building Control Engineers, Facility Managers, and DT Engineers with audit logging for compliance."
    DTDFVocab:enables FacilityManagementService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization service (Unreal Engine 5) displaying sensor telemetry overlays (temperature maps, occupancy heatmaps) and system alerts (equipment failures)."
    DTDFVocab:provides BuildingOperationInsight, EquipmentFailureAlert
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Data-driven optimization service using machine learning (reinforcement learning in BOREALIS) and rule-based engines for building performance prediction and control strategy refinement."
    DTDFVocab:provides EnergyConsumptionForecast, SystemFailurePrediction, OptimizationRecommendation
]

instance AdaptiveControlService : DTDFVocab:Service [
    base:desc "Dynamic adjustment service modifying BCS parameters (lighting levels, HVAC setpoints) based on real-time sensor data and occupancy patterns with user-defined constraints."
    DTDFVocab:provides LightingAdjustmentAction, HVACSetpointAdjustmentAction, ShadePositionAdjustmentAction
]

instance ScenarioTestingService : DTDFVocab:Service [
    base:desc "What-if analysis service evaluating design/operational scenarios (e.g., 'What if occupancy increases by 20%?') using ODTE-validated models for optimization decisions."
    DTDFVocab:provides ScenarioEvaluationInsight, ControlStrategyComparisonInsight
]

instance ServiceExtensibilityService : DTDFVocab:Service [
    base:desc "Modular architecture service providing standardized extension points for custom analytics plugins and third-party integrations (e.g., fire safety simulations, acoustic modeling)."
    DTDFVocab:provides CustomAnalyticsIntegrationAction, ThirdPartyIntegrationAction
]

instance FacilityManagementService : DTDFVocab:Service [
    base:desc "Role-based facility management service with dashboards for Building Control Engineers (device configuration), Facility Managers (operational oversight), and DT Engineers (service development)."
    DTDFVocab:provides DeviceConfigurationAction, OperationalOversightInsight, ServiceDevelopmentAction
]

instance DeploymentAutomationService : DTDFVocab:Service [
    base:desc "Automated deployment service generating Hono/Ditto configurations and Unreal Engine assets from enriched BIM model for rapid digital twin initialization."
    DTDFVocab:provides DeploymentAutomationAction, RuntimeConfigurationAction
]

instance ModelValidationService : DTDFVocab:Service [
    base:desc "Semantic validation service ensuring BIM model compliance with device connectivity and control logic consistency before digital twin deployment."
    DTDFVocab:provides ModelValidationInsight, ConstraintViolationAlert
]

instance QualityAssuranceService : DTDFVocab:Service [
    base:desc "Quality assurance service monitoring ODTE metric and performing automated testing for interoperability and fault tolerance validation."
    DTDFVocab:provides SynchronizationFidelityInsight, InteroperabilityTestResult
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy consumption optimization service providing automated suggestions for control policy adjustments and cost-benefit analysis for retrofitting decisions."
    DTDFVocab:provides EnergySavingRecommendation, CostBenefitAnalysisInsight
]

instance ComplianceReportingService : DTDFVocab:Service [
    base:desc "Automated compliance reporting service generating energy certification reports (LEED, BREEAM) and audit trails for regulatory compliance (GDPR, ISO 55000)."
    DTDFVocab:provides CertificationReport, ComplianceAuditTrail
]

instance DigitalTwinRegistryService : DTDFVocab:Service [
    base:desc "Centralized digital twin registry service managing twin instances, live telemetry, and historical data with event sourcing capabilities."
    DTDFVocab:provides TwinInstanceManagementAction, TelemetryDataAccessInsight
]

