// C3: Physical sensing components
instance TemperatureSensorLivingRoom : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor located in LivingRoom, providing readings of room temperature in °C."
    DTDFVocab:producedData TempDataTransmitted
]

instance OccupancySensorHallway : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor located in Hallway, detecting presence of occupants."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightIntensitySensorLivingRoom : DTDFVocab:SensingComponent [
    base:desc "Light intensity sensor in LivingRoom measuring illumination level (lux)."
    DTDFVocab:producedData LightIntDataTransmitted
]

instance LightTwinComponentLivingRoom : DTDFVocab:ActingComponent [
    base:desc "Digital twin of a lighting fixture in LivingRoom, controllable via UE5 light element."
]

// C4: Data transmitted
instance TempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorLivingRoom
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensorHallway
]

instance LightIntDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightIntensitySensorLivingRoom
]

instance LightCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightTwinComponentLivingRoom
]

// C5: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature reading JSON object with fields tenantId, deviceId, timestamp, payload."
    DTDFVocab:fromData TempDataTransmitted
    DTDFVocab:inputTo DittoTwinEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy detection JSON object with fields tenantId, deviceId, timestamp, payload."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo DittoTwinEnabler
]

instance LightIntensityData : DTDFVocab:Data [
    base:desc "Illumination level JSON object with fields tenantId, deviceId, timestamp, payload."
    DTDFVocab:fromData LightIntDataTransmitted
    DTDFVocab:inputTo DittoTwinEnabler
]

instance LightCommandData : DTDFVocab:Data [
    base:desc "Actuation command for LightTwinComponent, containing brightness and colourTemperature."
    DTDFVocab:fromData LightCommandDataTransmitted
    DTDFVocab:inputTo DittoControllerEnabler
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Semantic BIM model enriched with device metadata, used as source for MDE transformation."
    DTDFVocab:inputTo MDETransformerEnabler
]

// C11: Enablers
instance DittoTwinEnabler : DTDFVocab:Enabler [
    base:desc "Ditto twin service that stores telemetry and provides real‑time updates."
    DTDFVocab:enables MonitoringService, PredictiveAnalyticsService, ImmersiveVisualizationService
]

instance DittoControllerEnabler : DTDFVocab:Enabler [
    base:desc "Ditto controller that validates and delivers actuator commands to physical PLCs."
    DTDFVocab:enables ControlService
]

instance MDETransformerEnabler : DTDFVocab:Enabler [
    base:desc "MDE transformer that converts enriched BIM into runtime twin artifacts."
    DTDFVocab:enables CustomPluginService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring building performance through continuous ingestion of temperature, occupancy, and light intensity data."
    DTDFVocab:provides RealTimeBuildingPerformanceInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Service enabling real‑time control of HVAC, lighting via direct command interfaces."
    DTDFVocab:provides IssueControlCommandAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service applying predictive analytics to optimize energy usage and system scheduling."
    DTDFVocab:provides PredictiveEnergyInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Service powering immersive 3D and mixed‑reality dashboards for Facility Managers."
    DTDFVocab:provides VisualizationInsight
]

instance CustomPluginService : DTDFVocab:Service [
    base:desc "Extensible service platform for domain‑specific analytics and third‑party integration."
    DTDFVocab:provides CustomAnalyticsInsight
]

// C17: Insights/Actions
instance RealTimeBuildingPerformanceInsight : DTDFVocab:Insight [
    base:desc "Live view of building performance metrics assembled from sensor telemetry."
]

instance IssueControlCommandAction : DTDFVocab:Action [
    base:desc "Action to issue control commands to lighting fixtures, HVAC units, and other actuators."
    DTDFVocab:IsAutomatic false
]

instance PredictiveEnergyInsight : DTDFVocab:Insight [
    base:desc "Forecasts for energy consumption and optimization opportunities."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive 3D representation of building state with real‑time telemetry overlays."
]

instance CustomAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Results from custom analytics plugins developed by DT Engineers."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control flows are facilitated by the DT framework acting as a central hub; facility managers can issue commands via the DT interface to manage building controls in real‑time. The documents do not elaborate on specific command formats, communication protocols, authentication, or confirmation mechanisms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange capabilities ensure continuous synchronization between the physical building and its digital twin, emphasizing minimal latency for real‑time insights and monitoring."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular architecture pattern with a central DT Framework hub orchestrating component integration. Core elements include enriched BIM models, real‑time data ingestion modules, analytics services, and interactive visualization. Integration occurs through standardized extension points and bidirectional data exchange. Run‑time configuration management handles resource allocation and adaptability, while the hub coordinates system‑wide data flow, service evolution, and control actions."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports a complete digital twin lifecycle consisting of: (1) Device Modeling – Building Control Engineers populate enriched BIM models with explicit BCS component definitions (sensors, actuators, controllers) to overcome BIM’s static representation limitation; (2) Model‑to‑Artifact Transformation – Using Model‑Driven Engineering (MDE) principles the enriched BIM is parsed to a structured semantic representation and automatically compiled into deployable digital twin artifacts; (3) Deployment – The generated artifacts are deployed to the runtime environment with minimal manual configuration, giving the physical building a digital counterpart; (4) Runtime Operation – Continuous bi‑directional, real‑time data exchange synchronizes physical asset states with the twin, while interactive visualization dashboards allow Facility Managers to monitor and control operations; (5) Service Extension – Through the framework’s modular architecture with standardized extension points, custom DT services and analytics can be added, evolving the twin in line with operational demands. Lifecycle governance is achieved via the standardized extension point architecture, ensuring traceability from BIM definition to runtime services."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through automated validation during the conversion of enriched BIM data. Eclipse Ditto’s policy infrastructure checks that incoming sensor values fall within predefined ranges and that actuator commands respect safety limits, thereby providing runtime verification of data integrity. Fault tolerance is achieved via Eclipse Hono’s at‑least‑once delivery semantics and Ditto’s persistent event storage, which guarantees message durability across network disruptions. The combination of model‑driven validation, policy enforcement, and resilient messaging establishes a continuous quality‑assurance cycle for both models and the real‑time data that drive the Digital Twin."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is enabled via standard data exchange protocols and modular extension points that support interoperability across heterogeneous platforms. Specific protocols or dependency details are not provided, but the framework is designed to allow integration with enterprise systems, other Digital Twins, and custom services through these extensible interfaces."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The documentation does not specify adherence to particular industry standards, certification requirements or interoperability frameworks. The framework does, however, employ a modular architecture with standardized extension points to integrate third‑party services and analytics, but no explicit compliance with AECO‑specific or other standardised schemas (e.g., IFC, BIM/IFC) is mentioned."
]