// C2: Acting Components
instance LightingControlSystem : DTDFVocab:ActuatingComponent [
    base:desc "Adaptive lighting system with reinforcement learning-based optimization for energy efficiency in the LEED Platinum academic building's Living Lab"
]

instance HVACController : DTDFVocab:ActuatingComponent [
    base:desc "Building Control System component managing HVAC operations with automated commissioning capabilities"
]

instance ReinforcementLearningOptimizer : DTDFVocab:ActuatingComponent [
    base:desc "Adaptive control system implementing reinforcement learning for dynamic lighting optimization (BOREALIS project)"
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy sensor embedded in building infrastructure for monitoring occupancy patterns in the Living Lab"
    DTDFVocab:producedData OccupancyDataStream
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded sensor measuring indoor environmental temperature for energy efficiency monitoring in the LEED Platinum building"
    DTDFVocab:producedData TemperatureDataStream
]

instance LightingLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor tracking real-time lighting levels to support adaptive control systems in the Living Lab"
    DTDFVocab:producedData LightingLevelDataStream
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy sensor monitoring energy consumption metrics for operational cost optimization"
    DTDFVocab:producedData EnergyConsumptionDataStream
]

instance IndoorAirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring indoor environmental quality parameters (CO₂, humidity) for occupant comfort monitoring"
    DTDFVocab:producedData IndoorAirQualityDataStream
]

// C4: Physical-to-virtual interaction
instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance LightingLevelDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingLevelSensor
]

instance EnergyConsumptionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance IndoorAirQualityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndoorAirQualitySensor
]

// C10: Models/Data
instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "Semantic backbone BIM model containing geometry, topology, and component relationships for the LEED Platinum Living Lab building"
    DTDFVocab:inputTo BIMEnrichmentPipeline
]

instance DeviceConfigurationMetadata : DTDFVocab:Data [
    base:desc "Runtime metadata extracted from BIM for device configurations, sensor/actuator mappings, and control logic"
    DTDFVocab:fromData OccupancyDataStream, TemperatureDataStream, LightingLevelDataStream, EnergyConsumptionDataStream, IndoorAirQualityDataStream
]

instance SensorDataStreamAggregator : DTDFVocab:Data [
    base:desc "Aggregated sensor data streams combining real-time environmental measurements from multiple physical devices"
    DTDFVocab:fromData OccupancyDataStream, TemperatureDataStream, LightingLevelDataStream, EnergyConsumptionDataStream, IndoorAirQualityDataStream
]

instance ControlProtocolDefinitions : DTDFVocab:Component [
    base:desc "Generated runtime interfaces defining communication protocols between physical and virtual assets"
]

// C11: Enablers
instance EclipseHonoMiddleware : DTDFVocab:Enabler [
    base:desc "Real-time data exchange middleware (Eclipse Hono) enabling IoT connectivity between physical sensors and digital twin components"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, BidirectionalCommunicationService
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Immersive 3D visualization platform (Unreal Engine) for interactive monitoring and immersive building performance visualization"
    DTDFVocab:enables RealTimeMonitoringService, ImmersiveVisualizationService
]

instance ModelDrivenEngineeringFramework : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering principles automating BIM model enrichment to DT deployment pipeline"
    DTDFVocab:enables BIMEnrichmentPipeline, RuntimeConfigurationService
]

instance RevitBIMTool : DTDFVocab:Enabler [
    base:desc "BIM modeling tool (Revit) for device modeling and control logic definition in the AECO domain"
    DTDFVocab:enables BIMEnrichmentPipeline
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring and visualization platform using Unreal Engine for immersive 3D interaction with building performance metrics"
    DTDFVocab:provides BuildingPerformanceMetricsInsight, OccupancyPatternInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics and optimization platform for operational cost reduction, energy efficiency, and occupant comfort"
    DTDFVocab:provides EnergyOptimizationAction, ComfortAdaptationAction
]

instance BidirectionalCommunicationService : DTDFVocab:Service [
    base:desc "Automated bidirectional communication system between virtual and physical assets for real-time synchronization"
    DTDFVocab:provides DeviceStateSynchronizationAction, ControlCommandExecutionAction
]

instance AdaptiveControlService : DTDFVocab:Service [
    base:desc "Adaptive control system implementing reinforcement learning for dynamic optimization of building operations"
    DTDFVocab:provides ReinforcementLearningOptimizationAction, DynamicParameterAdjustmentAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization interface for interactive 3D building performance monitoring"
    DTDFVocab:provides SpatialPerformanceAnalysisAction
]

// C17: Insights/Actions
instance BuildingPerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of building performance metrics including energy consumption, occupant comfort, and environmental conditions"
]

instance OccupancyPatternInsight : DTDFVocab:Insight [
    base:desc "Analysis of occupancy patterns to inform adaptive building operations and resource allocation"
]

instance EnergyOptimizationAction : DTDFVocab:Action [
    base:desc "Automated energy optimization recommendations based on predictive analytics for cost reduction"
    DTDFVocab:IsAutomatic true
]

instance ComfortAdaptationAction : DTDFVocab:Action [
    base:desc "Dynamic adjustment of building systems to maintain optimal occupant comfort levels"
    DTDFVocab:IsAutomatic true
]

instance DeviceStateSynchronizationAction : DTDFVocab:Action [
    base:desc "Bidirectional synchronization of physical device states with virtual model for real-time consistency"
    DTDFVocab:IsAutomatic true
]

instance ControlCommandExecutionAction : DTDFVocab:Action [
    base:desc "Execution of control commands from virtual model to physical actuators for system adjustments"
    DTDFVocab:IsAutomatic true
]

instance ReinforcementLearningOptimizationAction : DTDFVocab:Action [
    base:desc "Application of reinforcement learning algorithms for adaptive building system optimization"
    DTDFVocab:IsAutomatic true
]

instance DynamicParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Real-time dynamic adjustment of building parameters based on current conditions and predictive models"
    DTDFVocab:IsAutomatic true
]

instance SpatialPerformanceAnalysisAction : DTDFVocab:Action [
    base:desc "3D spatial analysis of building performance metrics for immersive visualization and decision support"
    DTDFVocab:IsAutomatic false
]

// Supporting Components
instance BIMEnrichmentPipeline : DTDFVocab:Component [
    base:desc "Automated pipeline transforming BIM models into DT artifacts with runtime metadata enrichment"
]

instance RuntimeConfigurationService : DTDFVocab:Component [
    base:desc "Service managing device configurations, sensor mappings, and control logic at runtime"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals and commands generated by the DT to adjust physical building systems, such as lighting control logic, energy optimization policies, and adaptive adjustments based on reinforcement learning models. Enables closed-loop control for operational improvements."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with sub-second latency for critical operational data (e.g., sensor readings, control commands). The framework supports continuous, dynamic updates throughout the building lifecycle, including post-occupancy phases."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "['Centralized DT platform with BIM as the core semantic model.', 'Modular integration of middleware (Hono/Ditto) for real-time data synchronization.', 'Interoperable ecosystem with standardized extension points for third-party services and analytics.', 'Orchestration of physical sensors, actuators, and control logic within a unified digital representation.']"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "['Design phase: Enriched BIM models with device configurations and control logic.', 'Construction phase: Integration of IoT devices and middleware (Hono/Ditto) for real-time data exchange.', 'Operation phase: Continuous monitoring, optimization, and adaptation via DT services (e.g., reinforcement learning for dynamic control).']"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "['Overall Digital Twin Entanglement (ODTE) metric to measure alignment between physical and virtual representations.', 'Verification of BIM model accuracy and completeness during enrichment.', 'Validation through real-world Living Lab case study and iterative refinement of control logic.', 'Uncertainty management via real-time data synchronization and adaptive learning (e.g., reinforcement learning).']"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "['Middleware-based architecture (Eclipse Hono/Ditto) for real-time data exchange between physical sensors and DT.', 'Bidirectional communication protocols for live synchronization (e.g., MQTT, WebSocket).', 'Cloud/edge deployment for scalability and low-latency processing.']"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "['Cloud-based deployment for centralized management and scalability.', 'Edge computing for low-latency processing of real-time sensor data.', 'Unreal Engine for interactive visualization hosted on dedicated servers or cloud platforms.']"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "['Integration with BIM tools (e.g., Revit) for unified modeling and device configuration.', 'Interoperability with external IoT platforms and building management systems (BMS).', 'Standardized APIs for third-party service integration (e.g., analytics, AI models).']"
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "['Physical asset owner retains primary ownership of sensor data and building systems.', 'DT service providers manage derived insights and analytics (e.g., energy optimization recommendations).', 'Compliance with AECO-specific standards (e.g., BIM protocols) and data privacy regulations (e.g., GDPR).']"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "['BIM as the semantic backbone for consistent modeling across AECO stakeholders.', 'Standardized extension points for modular service integration (e.g., IoT protocols, analytics frameworks).', 'Eclipse Hono/Ditto for interoperable real-time data exchange.', 'ODTE metric for validating DT fidelity and interoperability.']"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "['Encrypted communication protocols (e.g., TLS) for secure data transmission.', 'Remote operation capabilities for facility managers and engineers, with safeguards against unauthorized access.', 'Automated anomaly detection and fault management to prevent accidents in physical systems.', 'Compliance with safety standards for building automation (e.g., ISO 27001 for cybersecurity).']"
]