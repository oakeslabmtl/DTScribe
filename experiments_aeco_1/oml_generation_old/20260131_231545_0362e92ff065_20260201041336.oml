// Enablers
instance DittoConnection : DTDFVocab:Enabler [
    base:desc "DittoConnection layer enabling communication between physical devices and digital twin"
    DTDFVocab:enables MonitoringService, ControlService
]

instance DittoDeviceModel : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto device model representing a physical lighting fixture"
    DTDFVocab:enables ControlService, MonitoringService
]

instance EclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono message broker used to publish JSON command and telemetry messages"
]

instance UnrealEngineRenderer : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renderer displaying TwinComponent objects"
]

// Acting Components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Physical lighting fixture represented as Ditto device, controlled via UnrealTwinController"
]

instance UnrealTwinController : DTDFVocab:ActingComponent [
    base:desc "Controller in Unreal Engine 5 that sends on/off, brightness, colourTemperature commands to LightTwinComponent via Ditto channel"
]

// Data Transmitted
instance ControlCommandJSONMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom UnrealTwinController
]

instance BuildingStateJSONMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DittoConnection
]

// Data
instance ControlCommandData : DTDFVocab:Data [
    base:desc "JSON message containing command values for light fixture (on/off, brightness %, colourTempKelvin)"
    DTDFVocab:fromData ControlCommandJSONMessage
    DTDFVocab:inputTo DittoConnection
]

instance BuildingStateData : DTDFVocab:Data [
    base:desc "Aggregated state of building components, including lighting status, HVAC metrics, and sensor telemetry"
    DTDFVocab:fromData BuildingStateJSONMessage
    DTDFVocab:inputTo MonitoringService
]

// Models
instance BuildingTwinModel : DTDFVocab:Model [
    base:desc "Geometric model of the building and lighting actuators rendered in Unreal Engine 5"
    DTDFVocab:inputTo UnrealEngineRenderer, DittoConnection
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors sensor data streams and updates building state"
    DTDFVocab:provides OperationalEfficiencyInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Service that receives control commands and forwards them to physical actuators via Ditto"
    DTDFVocab:provides CommandExecutionAction
]

instance AnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service optimizing building operations"
    DTDFVocab:provides OperationalEfficiencyInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that renders immersive dashboards in Unreal Engine 5 for Building Control Engineers"
    DTDFVocab:provides VisualizationInsight
]

// Insights & Actions
instance OperationalEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight into energy consumption efficiency derived from building state data"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight into visual analytics from immersive dashboards"
]

instance CommandExecutionAction : DTDFVocab:Action [
    base:desc "Action that executes lighting control commands on the physical fixture"
    DTDFVocab:IsAutomatic true
]

instance SafetyCheckAction : DTDFVocab:Action [
    base:desc "Safety check action verifying command values against predefined limits (e.g., brightness 0-100%)"
    DTDFVocab:IsAutomatic true
]

// Environment and Components
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains BuildingComponent, TwinComponent, DittoDeviceModel, DittoConnection, EclipseHonoBroker, UnrealEngineRenderer
]

instance BuildingComponent : DTDFVocab:Component [
    base:desc "Enriched BIM building component containing device specifications"
]

instance TwinComponent : DTDFVocab:Component [
    base:desc "Unreal Engine 5 TwinComponent rendering of building geometry and behavior"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital twin instances support real‑time monitoring and control of physical assets. Building Control Engineers use BIM tools to model devices and initiate deployment, while Facility Managers interact with the deployed digital twin for monitoring and issuing control commands. The specific command types, message formats, and authentication mechanisms are not detailed in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a centralized hub architecture, where the DT Framework serves as the core orchestrator. It is modular, composed of standardized extension points that allow integration of custom analytics and services. Runtime configuration management is employed to adapt the twin’s behavior without full redeployment, enabling high adaptability. Bidirectional data exchange between the physical building and its digital twin is facilitated through this central hub, ensuring that simulation, analysis, and optimization routines are coordinated across all components."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Initialization: Building Control Engineers enrich BIM models with device (sensor, actuator, controller) definitions and control logic, creating a unified semantic representation. Transformation: The model‑driven framework applies MDE principles to extract a structured, machine‑processable representation from the enriched BIM and automatically compiles deployable DT artifacts with minimal manual steps. Deployment and Runtime: The generated artifacts are provisioned into the DT platform, establishing continuous real‑time data exchange with the physical building for synchronization. Operation: Facility Managers monitor and control building operations via interactive, immersive visualizations provided by the DT. Governance: Lifecycle management is anchored in the framework’s modular architecture with standardized extension points, enabling configuration, versioning, and evolution of DT services over time."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and data validity are enforced through multiple layers of validation and robustness mechanisms. The MDE pipeline validates the enriched BIM against architectural and device schemas before generating the twin artefacts. Eclipse Ditto’s policy‑based validation guarantees that incoming sensor data and actuator commands conform to defined units and acceptable ranges, eliminating erroneous inputs. Fault tolerance is achieved by Eclipse Hono’s at‑least‑once message delivery semantics, ensuring that no sensor or command message is lost even during network disruptions, complemented by Ditto’s persistent event storage that retains a complete, ordered history of device states for replay and audit. Pre‑execution checks in Ditto prevent the execution of unsafe actuator commands, while the continuous synchronization between the physical building and the Unreal Engine 5 scene provides real‑time verification of twin behaviour against observable reality. These layered safeguards collectively support operational safety, data integrity, and reliable digital‑physical convergence."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin framework provides a bidirectional data exchange capability between the physical assets and the digital model, operating in real‑time. While the documents emphasize robust connectivity and standard compliance, specific network protocols, topology, bandwidth, latency, reliability, redundancy, or security mechanisms are not disclosed."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The framework achieves horizontal integration by exposing standardized extension points that enable the attachment of external services and analytics. It supports interoperability across heterogeneous systems, allowing integration with BIM tools for device modeling, as well as with facility management tools for real‑time monitoring and control. The modular architecture permits coupling with other Digital Twins or enterprise systems, facilitating data exchange through the shared DT Framework hub."
]