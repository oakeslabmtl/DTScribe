instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for environmental temperature data integrated into BIM models to provide real-time operational metrics."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for occupancy data integrated into BIM models to provide real-time operational metrics."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for light levels integrated into BIM models to provide real-time operational metrics."
    DTDFVocab:producedData LightLevelDataTransmitted
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Operational temperature sensor data from Building Control Systems (BCS)"
    DTDFVocab:inputTo EclipseHono, EclipseDitto
    DTDFVocab:fromData TemperatureDataTransmitted
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Operational occupancy sensor data from Building Control Systems (BCS)"
    DTDFVocab:inputTo EclipseHono, EclipseDitto
    DTDFVocab:fromData OccupancyDataTransmitted
]

instance LightLevelData : DTDFVocab:Data [
    base:desc "Operational light level sensor data from Building Control Systems (BCS)"
    DTDFVocab:inputTo EclipseHono, EclipseDitto
    DTDFVocab:fromData LightLevelDataTransmitted
]

instance GeometricData : DTDFVocab:Data [
    base:desc "Geometric characteristics of BIM model"
    DTDFVocab:inputTo BIMModelingTools, ModelDrivenEngineering
]

instance SpatialData : DTDFVocab:Data [
    base:desc "Spatial characteristics of BIM model"
    DTDFVocab:inputTo BIMModelingTools, ModelDrivenEngineering
]

instance FunctionalData : DTDFVocab:Data [
    base:desc "Functional characteristics of BIM model"
    DTDFVocab:inputTo BIMModelingTools, ModelDrivenEngineering
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for IoT data ingestion"
    DTDFVocab:enables RealTimeMonitoring, PredictiveAnalytics
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for digital twin management"
    DTDFVocab:enables RealTimeMonitoring, PredictiveAnalytics, EnergyOptimization, VisualComfortOptimization, NonVisualHealthEffectBalancing
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for visualization"
    DTDFVocab:enables InteractiveVisualization
]

instance BIMModelingTools : DTDFVocab:Enabler [
    base:desc "BIM modeling tools for geometric and spatial data processing"
    DTDFVocab:enables Simulation
]

instance ModelDrivenEngineering : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering for automated artifact generation"
    DTDFVocab:enables Simulation, PredictiveAnalytics
]

instance RealTimeMonitoring : DTDFVocab:Service [
    base:desc "Real-time monitoring of building operational metrics"
    DTDFVocab:provides FacilityManagementDecision
]

instance Simulation : DTDFVocab:Service [
    base:desc "Building simulation for operational optimization"
    DTDFVocab:provides SimulationResultsInsight
]

instance PredictiveAnalytics : DTDFVocab:Service [
    base:desc "Predictive analytics for building operations"
    DTDFVocab:provides EnergyConsumptionOptimizationInsight, NonVisualHealthEffectInsight
]

instance EnergyOptimization : DTDFVocab:Service [
    base:desc "Energy optimization using reinforcement learning for building operations"
    DTDFVocab:provides EnergyConsumptionOptimizationInsight, AdjustHVACActuator
]

instance VisualComfortOptimization : DTDFVocab:Service [
    base:desc "Visual comfort optimization for building environments"
    DTDFVocab:provides VisualComfortOptimizationInsight, AdjustLightingController
]

instance NonVisualHealthEffectBalancing : DTDFVocab:Service [
    base:desc "Non-visual health effect balancing through environmental optimization"
    DTDFVocab:provides NonVisualHealthEffectInsight
]

instance InteractiveVisualization : DTDFVocab:Service [
    base:desc "Interactive visualization using Unreal Engine 5"
    DTDFVocab:provides InteractiveVisualizationInsight
]

instance EnergyConsumptionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization insights for energy consumption through reinforcement learning"
]

instance VisualComfortOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization insights for visual comfort"
]

instance NonVisualHealthEffectInsight : DTDFVocab:Insight [
    base:desc "Optimization insights for non-visual health effects"
]

instance SimulationResultsInsight : DTDFVocab:Insight [
    base:desc "Simulation results for operational optimization"
]

instance InteractiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive visualization insights for building operations"
]

instance FacilityManagementDecision : DTDFVocab:Action [
    base:desc "Data-driven facility management decisions based on real-time monitoring"
    DTDFVocab:IsAutomatic true
]

instance AdjustLightingController : DTDFVocab:Action [
    base:desc "Automated control signal for lighting adjustment"
    DTDFVocab:IsAutomatic true
]

instance AdjustHVACActuator : DTDFVocab:Action [
    base:desc "Automated control signal for HVAC adjustment"
    DTDFVocab:IsAutomatic true
]

instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Actuator for lighting control within Building Control Systems (BCS)"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for HVAC control within Building Control Systems (BCS)"
]

instance LightingSubsystem : DTDFVocab:Component [
    base:desc "Modular lighting subsystem integrated into DT Framework"
]

instance HVACSubsystem : DTDFVocab:Component [
    base:desc "Modular HVAC subsystem integrated into DT Framework"
]

instance BIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with runtime metadata for BCS components"
    DTDFVocab:inputTo ModelDrivenEngineering, BIMModelingTools
]

instance LivingLabBuilding : DTDFVocab:Environment [
    base:desc "Living Lab building infrastructure as cyber-physical system for real-time monitoring, simulation, and life cycle-encompassing optimization of building operations"
    base:contains TemperatureSensor, OccupancySensor, LightLevelSensor, LightingController, HVACActuator, LightingSubsystem, HVACSubsystem, BIMModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals generated by the digital twin and sent to BCS actuators (e.g., lighting, HVAC) through Eclipse Hono and Ditto for real-time physical system adjustments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with continuous data exchange and immediate response to physical system changes, as evidenced by bidirectional communication protocols and ODTE metric evaluation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized DT Framework orchestrating BIM models, Eclipse Hono/Ditto for data exchange, Unreal Engine visualization, and modular services through standardized extension points, with roles for Building Control Engineers, Facility Managers, and DT Engineers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers all building life cycle stages from initial design through construction, operation, refurbishment, and adaptations, leveraging BIM as a semantic backbone throughout."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Measured using the Overall Digital Twin Entanglement (ODTE) metric for interoperability and architectural soundness; synchronization techniques address semantic drift to maintain model-physical alignment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional real-time communication via Eclipse Hono (IoT data ingestion) and Eclipse Ditto (digital twin state management) for secure data exchange between physical assets and virtual representations."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM (Building Information Modeling) standards as the primary AECO-specific standard, with the framework's modeling methodology designed to standardize BIM semantics for consistent runtime artifact generation."
]