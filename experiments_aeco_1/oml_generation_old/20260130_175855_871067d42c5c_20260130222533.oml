// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in BIM providing measurement capability for ambient temperature, streamed in real‑time to the Digital Twin."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM providing measurement capability for space occupancy, streamed in real‑time to the Digital Twin."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature measurement values used by models and analytics."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo RealTimeSyncLayer
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy presence data used for space‑utilization analytics."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo RealTimeSyncLayer
]

// C10: Models/Data (Enriched BIM and control models)
instance GeometricBIMModel : DTDFVocab:Model [
    base:desc "Geometric model derived from BIM geometry enriched with device definitions."
    DTDFVocab:inputTo MDETransformationEngine
]

instance BehavioralControlModel : DTDFVocab:Model [
    base:desc "Behavioral model encoding control logic for sensors, actuators, and controllers."
    DTDFVocab:inputTo MDETransformationEngine
]

// C11: Enablers
instance MDETransformationEngine : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering engine that transforms enriched BIM and behavioral models into executable Digital Twin artifacts."
    DTDFVocab:enables ImmersiveVisualizationService
]

instance RealTimeSyncLayer : DTDFVocab:Enabler [
    base:desc "Real‑time data‑exchange layer that streams sensor measurements and device states into the Digital Twin."
    DTDFVocab:enables CustomAnalyticsService
]

// C6: Services
instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization service that presents real‑time system states to Facility Managers."
    DTDFVocab:provides SystemStateInsight
]

instance CustomAnalyticsService : DTDFVocab:Service [
    base:desc "Analytics service integrating custom algorithms to generate operational insights for building management."
    DTDFVocab:provides EnergyPerformanceInsight, IssueControlCommandAction
]

// C17: Insights
instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time overview of building system states derived from sensor data."
]

instance EnergyPerformanceInsight : DTDFVocab:Insight [
    base:desc "Operational insight on energy performance generated by custom analytics."
]

// C17: Actions
instance IssueControlCommandAction : DTDFVocab:Action [
    base:desc "Action allowing Facility Manager to issue on/off or set‑point commands to actuators via the Digital Twin."
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator defined in BIM and exposed for remote operation through the Digital Twin."
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator defined in BIM and exposed for remote operation through the Digital Twin."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication is supported so that the Digital Twin can issue control commands back to the physical building. Facility managers interact with the DT’s visualisation interface to trigger actions; these commands are transmitted through the same standardized extension points to the building control system, where they are validated and enacted on the physical devices. The framework’s runtime configuration capability allows modification of command handling policies on‑the‑fly, ensuring that control flows remain consistent with the current deployment state."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin is kept synchronized with the physical asset in real time using Eclipse Hono for device connectivity and Eclipse Ditto for twin state management. The document does not provide explicit synchronization frequencies, latency requirements, or temporal granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system architecture combines Eclipse Hono for inbound data acquisition, Eclipse Ditto for digital twin lifecycle and state handling, and the Unreal Engine for immersive 3‑D visualization. These components are integrated in a model‑driven fashion to provide simulation, analysis, and optimization capabilities. No further orchestration mechanisms are described."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The proposed model‑driven DT deployment framework defines a full lifecycle that starts with device modeling inside the BIM environment (definition of sensors, actuators, and controllers), proceeds to model‑driven engineering (MDE) extraction of structured representations, automatic generation and deployment of DT artifacts, runtime operation with continuous real‑time data exchange for state synchronization, interactive visualization for monitoring and control, and a modular extension phase where custom services and analytics are integrated via standardized extension points. Governance is embodied in role‑based responsibilities (Building Control Engineer, Facility Manager, DT Engineer) that guide each phase."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through an explicit validation step that evaluates the alignment between the physical asset and its digital counterpart using the Overall Digital Twin Entanglement (ODTE) metric. The ODTE metric quantifies the degree of entanglement, serving as a verification criterion during deployment. Validation ensures that the automatically generated DT artifacts faithfully reflect the enriched BIM device definitions. Continuous runtime synchronization mitigates uncertainties arising from BIM's static nature, and the metric‑based assessment forms part of the quality‑assurance process for both models and live data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on a modular architecture with standardized extension points that enable interoperable communication between heterogeneous subsystems. The framework abstracts the underlying network protocols, allowing integration of diverse data sources and control endpoints while meeting non‑functional requirements for scalability (from single components to whole infrastructure) and maintainability (low‑overhead updates). Security and reliability are addressed through the framework’s runtime configuration management, which can adjust security policies and redundancy settings without redeployment."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration between the physical environment and the digital twin is performed via Eclipse Hono, which ingests data from sensors/actuators, and Eclipse Ditto, which exposes the twin state. The document does not specify particular communication protocols, external enterprise systems, or interoperability standards beyond these components."
]