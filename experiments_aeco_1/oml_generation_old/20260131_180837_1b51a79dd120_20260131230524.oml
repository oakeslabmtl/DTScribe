    DTDFVocab:inputFrom HumidityData
]

instance ControlLogicDeploymentService : DTDFVocab:Service [
    base:desc "Service enabling Building Control Engineers to define and deploy automated control algorithms directly within BIM models for rule-based or AI-driven actuator automation."
