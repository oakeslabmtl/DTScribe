    base:desc "Motorized HVAC damper actuator defined within BIM as part of Building Control System components, enabling automated control of airflow based on environmental parameters and control logic defined by Building Control Engineers."
    DTDFVocab:addressingMechanism BIMSemanticAnnotation
    DTDFVocab:controlCapabilities "Rule-based and AI-driven automation"
    DTDFVocab:remoteControlInterface DigitalTwinVisualizationInterface
]

instance MotorizedValveActuator : DTDFVocab:ActingComponent [
    base:desc "Building Control System component modeled in BIM representing motorized valves for fluid control systems, with dynamic behavioral overlays addressing BIM's static representation limitations."
