    DTDFVocab:preprocessingSteps "Modular architecture extension points"
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Environmental humidity data transmitted from sensors to Digital Twin for indoor air quality monitoring and control system adjustments."
    DTDFVocab:producedFrom HumiditySensor
    DTDFVocab:transmissionProtocols "Standardized interfaces for interoperability"
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Building energy consumption data transmitted from sensors to Digital Twin for predictive analytics and optimization services."
