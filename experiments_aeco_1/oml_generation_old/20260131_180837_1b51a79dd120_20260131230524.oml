    DTDFVocab:transmissionFrequency "Low-latency, high-frequency updates"
    DTDFVocab:dataQualityAssurance "Framework's runtime synchronization"
]

// C10: Models/Data
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "Building Information Model enriched with BCS component definitions (sensors, actuators, controllers) serving as the semantic foundation for Digital Twin deployment."
    DTDFVocab:inputTo BIMEnrichmentTool
    DTDFVocab:outputTo ModelToModelTransformation
    DTDFVocab:contains BCSComponentMetadata
]

instance BehavioralControlModel : DTDFVocab:Model [
    base:desc "Dynamic behavioral model encapsulating control logic for sensors, actuators, and controllers defined by Building Control Engineers within BIM environment."
    DTDFVocab:inputTo ControlLogicDefinitionTool
    DTDFVocab:inputTo RuntimeSynchronizationEngine
    DTDFVocab:outputTo DeployableControlArtifacts
]

instance AnalyticalSimulationModel : DTDFVocab:Model [
    base:desc "MDE-generated analytical model transforming enriched BIM representations into deployable Digital Twin artifacts including simulation models and control logic templates."
    DTDFVocab:inputTo ModelDrivenEngineeringFramework
    DTDFVocab:inputTo CustomServiceIntegrationPlatform
    DTDFVocab:outputTo PredictiveAnalyticsServices
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Processed temperature data derived from transmitted sensor readings, used for environmental monitoring and control system validation."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EnvironmentalMonitoringService
    DTDFVocab:inputTo ControlLogicValidationService
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Processed occupancy data from motion sensors enabling space utilization analytics and dynamic resource allocation services."
    DTDFVocab:fromData MotionDataTransmitted
    DTDFVocab:inputTo SpaceUtilizationAnalyticsService
    DTDFVocab:inputTo ResourceAllocationService
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "Processed energy consumption data used for predictive modeling, energy efficiency analytics, and optimization services."
    DTDFVocab:fromData EnergyDataTransmitted
    DTDFVocab:inputTo EnergyEfficiencyAnalyticsService
    DTDFVocab:inputTo PredictiveMaintenanceService
]

// C11: Enablers
instance ModelDrivenEngineeringFramework : DTDFVocab:Enabler [
    base:desc "Core framework implementing MDE principles for automated extraction of structured Digital Twin artifacts from enriched BIM models, reducing manual intervention."
    DTDFVocab:enables ModelToModelTransformation
    DTDFVocab:enables ModelToCodeTransformation
    DTDFVocab:enables ArtifactDeploymentService
]

instance BIMEnrichmentTool : DTDFVocab:Enabler [
    base:desc "Toolset for augmenting BIM models with BCS-specific metadata including sensor calibration and actuator response curves to bridge static representations with dynamic DT requirements."
    DTDFVocab:enables BIMEnrichedModel
    DTDFVocab:enables SemanticAnnotationService
    DTDFVocab:enables IoTIntegrationGateway
]

instance RuntimeSynchronizationEngine : DTDFVocab:Enabler [
    base:desc "Real-time bidirectional data exchange mechanism ensuring low-latency updates between physical BCS components and Digital Twin representations."
    DTDFVocab:enables ContinuousDataSynchronization
    DTDFVocab:enables StateConsistencyValidation
    DTDFVocab:enables EventTriggeredDataIngestion
]

instance CustomServiceIntegrationPlatform : DTDFVocab:Enabler [
    base:desc "Modular plugin framework enabling DT Engineers to integrate third-party services including IoT gateways, analytics engines, and predictive maintenance solutions."
