    DTDFVocab:inputFrom OccupancyData
    DTDFVocab:inputFrom PredictiveOccupancyModel
]

instance DigitalTwinVisualizationInterface : DTDFVocab:Service [
    base:desc "Immersive 3D/4D interface providing interactive BIM-derived visualizations for spatial and temporal analysis of building operations with AR/VR support."
