    DTDFVocab:enables PredictiveMaintenanceService
    DTDFVocab:enables ThirdPartyServiceOrchestration
]

instance InteractiveVisualizationEngine : DTDFVocab:Enabler [
    base:desc "3D/4D visualization toolset providing immersive interfaces for Facility Managers to monitor building operations with support for AR/VR overlays."
