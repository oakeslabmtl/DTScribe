    DTDFVocab:controlCapabilities "Automated responses to sensor inputs and external commands"
    DTDFVocab:safetyConstraints "Runtime synchronization mechanisms to prevent unsafe operations"
]

instance LightingControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control actuator defined within BIM framework, enabling remote operation via Digital Twin's interactive visualization interfaces for Facility Managers."
