    DTDFVocab:provides AutomatedActuation
    DTDFVocab:inputFrom BehavioralControlModel
    DTDFVocab:inputFrom BIMEnrichedModel
]

instance EnergyEfficiencyAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive modeling service analyzing energy consumption patterns using time-series data to optimize building energy performance."
    DTDFVocab:provides EnergyConsumptionInsight
    DTDFVocab:provides OptimizationRecommendation
    DTDFVocab:inputFrom EnergyConsumptionData
    DTDFVocab:inputFrom PredictiveModel
]

instance SpaceUtilizationAnalyticsService : DTDFVocab:Service [
