]

// C1: Environments
instance BuildingControlSystemEnvironment : DTDFVocab:Environment [
    base:desc "Physical and digital environment encompassing Building Control Systems integrated with Digital Twin framework for smart building management."
    base:contains HVACDamperActuator
    base:contains TemperatureSensor
    base:contains MotorizedValveActuator
    base:contains MotionSensor
]

instance DigitalTwinFrameworkEnvironment : DTDFVocab:Environment [
