    DTDFVocab:enables SpatialTemporalAnalysisService
    DTDFVocab:enables ImmersiveDashboardService
]

// C6: Services
instance EnvironmentalMonitoringService : DTDFVocab:Service [
    base:desc "Real-time state visualization service providing continuous synchronization of physical building states (temperature, humidity, occupancy) via immersive interfaces."
    DTDFVocab:provides EnvironmentalStateInsight
    DTDFVocab:provides AnomalyDetectionAlert
