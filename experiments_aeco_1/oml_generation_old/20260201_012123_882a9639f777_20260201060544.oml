// C2: Acting Components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Light control actuator modeled in the enriched BIM, operated through a JSON message validated by Eclipse Ditto policy engine."
]

instance HVACTwinComponent : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator modeled in the enriched BIM, operated through a JSON message validated by Eclipse Ditto policy engine."
]

// C3: Physical sensing components
instance IndoorAirTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in the enriched BIM, metadata includes measurement type, units and location."
    DTDFVocab:producedData AirTemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in the enriched BIM, delivers occupancy status to the DT."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical-to-virtual interaction
instance AirTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndoorAirTemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Models/Data
instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "Enriched IFC-based BIM model containing device configurations, control logic and metadata for the building."
    DTDFVocab:inputTo MDETransformationEngine, SimulationEngine
]

instance AirTemperatureData : DTDFVocab:Data [
    base:desc "Air temperature value streamed from the temperature sensor, validated by Ditto."
    DTDFVocab:inputTo DittoEventStore
    DTDFVocab:fromData AirTemperatureDataTransmitted
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy status streamed from the occupancy sensor, validated by Ditto."
    DTDFVocab:inputTo DittoEventStore
    DTDFVocab:fromData OccupancyDataTransmitted
]

// C11: Enablers
instance DittoDeviceRegistry : DTDFVocab:Enabler [
    base:desc "Persistent device registry in Eclipse Ditto that validates telemetry and command payloads."
    DTDFVocab:enables MonitoringService
]

instance DittoConnection : DTDFVocab:Enabler [
    base:desc "Connection between physical actuators and Ditto, marshaling JSON command messages via Ditto Controller."
    DTDFVocab:enables ControlService
]

instance DittoController : DTDFVocab:Enabler [
    base:desc "Mediator that marshals command messages to physical plants, performing pre‑execution checks."
    DTDFVocab:enables ControlService
]

instance HonoMessaging : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT broker providing 'at-most‑once' transport for sensor telemetry."
    DTDFVocab:enables MonitoringService
]

instance DittoEventStore : DTDFVocab:Enabler [
    base:desc "Ditto event store where live telemetry data is persisted after policy validation."
    DTDFVocab:enables MonitoringService
]

instance MDETransformationEngine : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline that transforms enriched BIM into deployable digital twin artifacts."
    DTDFVocab:enables MonitoringService, SimulationEngine
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine that generates artifact geometry and behavioral models from the BIM."
    DTDFVocab:enables PredictionService, OptimizationService
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 rendering layer that provides immersive visualization of the building model."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that provides real‑time visibility of building status and component health to facility managers."
    DTDFVocab:provides EnergyEfficiencyInsight, ToggleLightingAction
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Predictive analytics service for maintenance, energy consumption and occupant comfort, enabling proactive decisions."
    DTDFVocab:provides EnergyEfficiencyInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Service that executes control logic defined by building control engineers, automating HVAC and lighting."
    DTDFVocab:provides AdjustHVACAction, ToggleLightingAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Data‑driven optimization of energy use and operational costs driven by simulation and analytics."
    DTDFVocab:provides EnergyEfficiencyInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization service that renders the virtual twin and allows scenario exploration."
    DTDFVocab:provides EnergyEfficiencyInsight
]

// C17: Insights/Actions
instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight detailing opportunities to reduce energy consumption based on sensor telemetry and predictive models."
]

instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of HVAC setpoint to maintain comfort while optimizing energy use."
    DTDFVocab:IsAutomatic true
]

instance ToggleLightingAction : DTDFVocab:Action [
    base:desc "Automatic on/off control of lighting fixtures based on occupancy and ambient light levels."
    DTDFVocab:IsAutomatic true
]

// C10: Environment and Components
instance BuildingFacilityEnvironment : DTDFVocab:Environment [
    base:contains IndoorAirTemperatureSensor, OccupancySensor, LightTwinComponent, HVACTwinComponent
]

instance LightingComponent : DTDFVocab:Component [
    base:desc "Lighting system component managed through the LightTwinComponent actuator."
]

instance HVACComponent : DTDFVocab:Component [
    base:desc "HVAC system component managed through the HVACTwinComponent actuator."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "No description of control flows from digital to physical is provided in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized Digital Twin framework coordinating Building Control Engineers, Facility Managers, and DT Engineers. The system features a modular architecture with standardized extension points, enabling the addition of custom services and analytics. A central hub facilitates bidirectional data exchange between the physical building and its digital counterpart, supporting real‑time synchronization. Runtime configuration management allows adjustments without full redeployment, while the framework orchestrates services across the building lifecycle, ensuring cohesive integration of BIM models and operational data."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design and Definition Phase: Building control engineers model devices—sensors, actuators, controllers—directly within the BIM environment, embedding control logic via BIM annotations. Extraction and Transformation Phase: Using Model‑Driven Engineering (MDE) principles, the enriched BIM models are parsed to generate structured, semantically‑rich representations (e.g., IFC with custom extensions). Deployment Phase: The transformation layer automatically creates deployable DT artifacts (e.g., Docker containers, micro‑services) with minimal manual intervention, packaging device models and connectors. Runtime and Synchronization Phase: Real‑time data exchange protocols (e.g., MQTT or OPC UA) continuously synchronize state between physical building assets and their digital twins, while interactive visualization tools (e.g., WebGL dashboards) provide immersive monitoring interfaces. Extension and Governance Phase: The framework exposes standardized extension points that allow DT engineers to integrate custom services and analytics; versioned artifacts are managed through a modular architecture to support controlled evolution and lifecycle governance across design, deployment, operation, and decommissioning."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is enforced through a multi‑layer validation pipeline: (1) BIM validation checks semantic consistency of device metadata; (2) conversion logic verifies that every TwinComponent is assigned a unique Ditto identifier and that its property schema matches Ditto’s RTU schema; (3) Ditto’s policy engine guarantees numeric bounds, unit consistency and availability of required fields for all data packets. Fault tolerance is achieved using Hono’s at‑least‑once transport, Ditto’s persistent event store and an Observable pattern implemented via UE 5 delegates, which keeps the virtual state synchronized with the physical state. Any actuator command that violates policy is rejected before execution, thus preventing unsafe operations. Uncertainty sources are confined to sensor noise, which is mitigated by policy‑based filtering and data validation. The observable pattern ensures that any discrepancy in state is rapidly propagated to both UE 5 visualisers and any downstream analytics services, enabling continuous quality assurance of both the data and the model representations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT framework provides real‑time, bidirectional connectivity across heterogeneous systems, leveraging standardized extension points and open‑source platforms such as Eclipse Ditto and BaSyx for connectivity and standard compliance. While specific protocols and network topology details are not enumerated, the architecture supports scalability from individual components to entire infrastructure systems, ensuring interoperability and low‑overhead updates. Security and reliability are managed through standard compliance and runtime configuration."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through standard interoperability across heterogeneous platforms, leveraging well‑known protocols and standards (e.g., REST/HTTPS, WebSockets, OPC‑UA are common but not explicitly named in the documents).  The DT framework integrates with Building Information Modeling (BIM) tools to enrich static models with runtime data, bridging static representations with dynamic operations.  The modular architecture and extension points enable integration patterns such as API adapters, message brokers, or publish/subscribe to other enterprise systems or other Digital Twinning solutions.  No specific data exchange protocols or interoperability standards are enumerated beyond the reference to interoperability requirements."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adheres to industry standards that are integral to the AECO domain. 1. BIM/IFC: All structural and asset data originates from IFC‑compliant BIM models, ensuring a shared information model. 2. Connectivity standards: Device adapters are built on Eclipse Hono, which implements OASIS MQTT and NATS protocols, while Eclipse Ditto provides the REST/CoAP API for asset representation, thus ensuring interoperability with a broad range of IoT platforms. 3. Semantic standards: The enriched BIM model may use IFC Extension or BIMs (building information exchange) schemas; the intermediate model is based on a domain‑specific metamodel that associates IFC entities with DT artefacts. 4. Certification & compliance: No explicit certification (e.g., ISO 50001) is mentioned; however, the framework’s reliance on open‑source, standards‑compliant connectors (Ditto, Hono) positions it for alignment with ISO 37120 (smart city) and ISO 16739 (IFC). 5. Interoperability: The use of Ditto as an asset‑centric cloud broker and Hono as IoT gateway enables bidirectional integration with external systems, ensuring compliance with OASIS standards for cyber‑security and data exchange."
]