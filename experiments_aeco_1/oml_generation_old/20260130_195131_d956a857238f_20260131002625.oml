// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the Living Lab building, providing real‑time temperature readings to the digital twin"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor embedded in the Living Lab building, streaming real‑time humidity levels to the digital twin"
    DTDFVocab:producedData HumidityDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Stream of temperature measurements from the building sensors"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseDitto, TimeSeriesDatabase
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Stream of humidity measurements from the building sensors"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseDitto, TimeSeriesDatabase
]

// C11: Enablers (tooling and enablers)
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides real‑time data ingestion and exchange between field devices and the digital twin"
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital‑twin state synchronization and query/update operations"
    DTDFVocab:enables RealTimeMonitoringService, SimulationWhatIfService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time‑series database stores telemetry for analysis and historical queries"
    DTDFVocab:enables EnergyOptimizationService
]

instance BIMModel : DTDFVocab:Enabler [
    base:desc "BIM model provides static geometric representation of the building for visualization and simulation"
    DTDFVocab:enables Interactive3DVisualizationService, SimulationWhatIfService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders high‑fidelity 3‑D visualizations and enables immersive interaction"
    DTDFVocab:enables Interactive3DVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of system states by aggregating live sensor data"
    DTDFVocab:provides LiveSensorInsight, ControlCommandAction
]

instance SimulationWhatIfService : DTDFVocab:Service [
    base:desc "Enables what‑if simulations based on control logic and analytical models"
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes energy consumption across the building lifecycle using simulation results"
    DTDFVocab:provides EnergyEfficiencyInsight, EnergyOptimizationAction
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Delivers immersive 3‑D visualization of the building with overlaid real‑time operational data"
    DTDFVocab:provides ImmersiveVisualizationInsight
]

// C17: Insights
instance LiveSensorInsight : DTDFVocab:Insight [
    base:desc "Live view of temperature and humidity readings for facility managers"
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics indicating future temperature trends based on current data"
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insights on building energy performance and potential savings"
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3‑D visualization of the Living Lab with real‑time sensor overlays"
]

// C17: Actions
instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Allows facility managers to issue control commands to building actuators via the twin"
    DTDFVocab:IsAutomatic false
]

instance EnergyOptimizationAction : DTDFVocab:Action [
    base:desc "Automated recommendations to adjust HVAC setpoints for optimal energy use"
    DTDFVocab:IsAutomatic true
]

// C10: Models/Data (derived from BIM)
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Geometric BIM model extracted from design data, representing building structure"
    DTDFVocab:inputTo BIMModel
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral control logic model derived from BIM device definitions"
    DTDFVocab:inputTo EclipseDitto, SimulationWhatIfService
]

instance AnalyticalSimulationModel : DTDFVocab:Model [
    base:desc "Analytical model for simulation and performance analysis of the building"
    DTDFVocab:inputTo SimulationWhatIfService, EnergyOptimizationService
]

// C15: Environment (system under study)
instance LivingLabBuilding : DTDFVocab:Environment [
    base:contains TemperatureSensor, HumiditySensor, BIMGeometryModel, ControlLogicModel, AnalyticalSimulationModel, CentralTwinHub
]

// C1: Central hub (multiplicities)
instance CentralTwinHub : DTDFVocab:Component [
    base:desc "Central digital‑twin hub hosting a single primary twin instance and orchestrating data flow among services"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are issued from the digital twin to physical building devices via the same central hub, allowing Facility Managers to perform real‑time monitoring and control actions. The interaction is described as bidirectional, but the document does not detail command formats, validation/authentication methods, feedback loops, conflict‑resolution strategies, or execution confirmations."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange that continuously synchronizes the physical building with its digital counterpart, implying an ongoing, sub‑second update loop; however, explicit synchronization frequencies, latency targets, or temporal granularity levels are not detailed in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is orchestrated as a modular, service‑oriented platform where the DT Framework acts as a central hub coordinating bidirectional data exchange among BIM‑derived models, custom analytics services, and user interfaces. Runtime configuration management enables dynamic adaptation without redeployment, and standardized extension points support integration of additional services, reflecting a component‑based orchestration pattern."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a six‑step life‑cycle for a Digital Twin: (1) device modeling inside the BIM environment where Building Control Engineers define sensors, actuators and controllers; (2) semantic enrichment of the BIM model to create a unified representation; (3) model‑driven engineering (MDE) extraction that transforms the enriched BIM into structured DT representations; (4) automated generation of deployable DT artifacts with minimal manual effort; (5) runtime operation where real‑time data exchange synchronises the physical building and its twin and interactive visualisation supports monitoring and control; (6) evolution through modular extension points that allow DT Engineers to add custom services or plugins. Transition between phases is managed by automated transformation pipelines and role‑based governance (Building Control Engineer, Facility Manager, DT Engineer)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The solution adopts a modular architecture with standardized extension points and runtime configuration management to integrate custom services and analytics. Communication between components occurs over the framework’s central hub, but the document does not provide explicit information on the underlying network protocols, topology, bandwidth or latency requirements, reliability/redundancy mechanisms, or security protocols for network communication."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed through standardized extension points and support for heterogeneous systems, enabling bidirectional data exchange with external BIM tools, analytics services, and enterprise applications. Specific data exchange protocols or standards are not enumerated in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework leverages Building Information Modeling (BIM) as the core semantic standard, aligning with BIM’s status as the de‑facto standard in the construction industry (e.g., implicit use of IFC‑based exchange). It adopts a model‑driven engineering approach that enforces consistent artifact generation across the lifecycle. Moreover, the architecture defines standardized extension points to ensure that custom services and analytics can interoperate within the twin ecosystem, providing a systematic interoperability strategy even though specific external standards (e.g., ISO 19650) are not explicitly cited."
]