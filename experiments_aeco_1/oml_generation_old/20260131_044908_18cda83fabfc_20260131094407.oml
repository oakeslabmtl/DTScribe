instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Indoor temperature sensor measuring room temperature in the building"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Indoor humidity sensor providing relative humidity measurements"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Indoor CO₂ sensor measuring air quality for TwinLight and BOREALIS control policies"
    DTDFVocab:producedData CO2DataTransmitted
]

instance LightIntensitySensor : DTDFVocab:SensingComponent [
    base:desc "Light intensity sensor measuring illumination levels for lighting control"
    DTDFVocab:producedData LightIntensityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor providing post‑occupancy data for building management"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance LightIntensityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightIntensitySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Runtime temperature data stream from the building"
    DTDFVocab:inputTo HonoBroker, DittoGateway
    DTDFVocab:fromData TemperatureDataTransmitted
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Runtime humidity data stream from the building"
    DTDFVocab:inputTo HonoBroker, DittoGateway
    DTDFVocab:fromData HumidityDataTransmitted
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Runtime CO₂ data stream from the building"
    DTDFVocab:inputTo HonoBroker, DittoGateway
    DTDFVocab:fromData CO2DataTransmitted
]

instance LightIntensityData : DTDFVocab:Data [
    base:desc "Runtime light intensity data stream from the building"
    DTDFVocab:inputTo HonoBroker, DittoGateway
    DTDFVocab:fromData LightIntensityDataTransmitted
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Runtime occupancy data stream from the building"
    DTDFVocab:inputTo HonoBroker, DittoGateway
    DTDFVocab:fromData OccupancyDataTransmitted
]

instance HonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT broker facilitating real‑time sensor data ingestion and forwarding to Ditto"
    DTDFVocab:enables RealTimeMonitoringDashboardService, PredictiveAnalyticsService
]

instance DittoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin asset management service storing twin states"
    DTDFVocab:enables ReinforcementLearningLightingControlService, BuildingPerformanceSimulationService
]

instance EMFModelTransformer : DTDFVocab:Enabler [
    base:desc "EMF‑based model transformation tool converting enriched BIM with embedded semantics into runtime state models"
    DTDFVocab:enables BuildingPerformanceSimulationService, ReinforcementLearningLightingControlService
]

instance UnrealEngineVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine tool enabling immersive 3D visualization of the digital twin"
    DTDFVocab:enables UnrealEngineVisualizationService
]

instance AutodeskRevitAuthoring : DTDFVocab:Enabler [
    base:desc "Autodesk Revit building information modeling authoring tool providing enriched BIM models for TwinLight and BOREALIS"
    DTDFVocab:enables BIMModelValidationService
]

instance BIMModelValidationService : DTDFVocab:Service [
    base:desc "Service validating enriched BIM models for TwinLight and BOREALIS"
]

instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Service delivering real‑time dashboards for energy consumption and thermostat setpoint history"
    DTDFVocab:provides EnergyConsumptionSummaryInsight, ThermostatSetpointHistoryInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service performing predictive analytics on building operation data to generate maintenance alerts"
    DTDFVocab:provides PredictiveMaintenanceAlertsInsight
]

instance EnergyUseOptimizationService : DTDFVocab:Service [
    base:desc "Service generating energy optimization plans based on analytics"
    DTDFVocab:provides EnergyOptimizationPlanAction
]

instance ReinforcementLearningLightingControlService : DTDFVocab:Service [
    base:desc "Service creating lighting control policies via reinforcement learning"
    DTDFVocab:provides LightingScheduleRecommendationsInsight, SetLightingScheduleAction
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Service simulating building performance based on BIM models and runtime state models"
    DTDFVocab:provides PerformanceReportInsight
]

instance UnrealEngineVisualizationService : DTDFVocab:Service [
    base:desc "Service streaming immersive 3D visualization of the building via Unreal Engine"
    DTDFVocab:provides LaunchUnreal3DVisualizationAction
]

instance EnergyConsumptionSummaryInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing energy consumption over time for facility managers"
]

instance ThermostatSetpointHistoryInsight : DTDFVocab:Insight [
    base:desc "Insight displaying historical thermostat setpoint changes for analysis"
]

instance PredictiveMaintenanceAlertsInsight : DTDFVocab:Insight [
    base:desc "Insight providing alerts for predictive maintenance of HVAC and lighting actuators"
]

instance LightingScheduleRecommendationsInsight : DTDFVocab:Insight [
    base:desc "Insight recommending lighting schedules derived from reinforcement learning policy"
]

instance HVACSetpointRecommendationsInsight : DTDFVocab:Insight [
    base:desc "Insight recommending HVAC setpoints based on optimization models"
]

instance PerformanceReportInsight : DTDFVocab:Insight [
    base:desc "Insight reporting simulated building performance metrics such as energy use and occupant comfort"
]

instance EnergyOptimizationPlanAction : DTDFVocab:Action [
    base:desc "Action to apply optimized energy schedule to building systems"
    DTDFVocab:IsAutomatic false
]

instance SetLightingScheduleAction : DTDFVocab:Action [
    base:desc "Action to set lighting schedule according to reinforcement learning policy"
    DTDFVocab:IsAutomatic false
]

instance SetHVACSetpointAction : DTDFVocab:Action [
    base:desc "Action to set HVAC setpoints based on optimization recommendations"
    DTDFVocab:IsAutomatic false
]

instance LaunchUnreal3DVisualizationAction : DTDFVocab:Action [
    base:desc "Action to launch immersive 3D visualization of building state in Unreal Engine"
    DTDFVocab:IsAutomatic false
]

instance IFCBIMWithDeviceSemanticsModel : DTDFVocab:Model [
    base:desc "IFC BIM model embedded with device semantics for TwinLight and BOREALIS"
    DTDFVocab:inputTo AutodeskRevitAuthoring
]

instance RuntimeStateModel : DTDFVocab:Model [
    base:desc "Runtime state model for building actuators and sensors derived from enriched BIM"
    DTDFVocab:inputTo EMFModelTransformer
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model extracted via model-driven transformation from IFC model"
    DTDFVocab:inputTo EMFModelTransformer
]

instance RLPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement learning policy model for lighting control"
    DTDFVocab:inputTo EMFModelTransformer
]

instance LEDLightingActuator : DTDFVocab:ActingComponent [
    base:desc "LED luminaires integrated into the building automation system for dynamic lighting control"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator controlling temperature setpoints for occupant comfort"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (lighting setpoints, HVAC modes) generated by the Digital Twin and transmitted back to physical actuators through the Hono/Ditto bidirectional channel."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization, with sensor updates and control messages processed on a scale of milliseconds to seconds for near‑real‑time interaction."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (BIM model creation), Construction (manufacturing and installation data), and Operation (runtime monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "ODTE metric quantifies entanglement, semantic drift mitigation through regular synchronization, validation by comparing twin states with sensor readings, and uncertainty bounded by sensor error specifications."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono implements MQTT (device‑to‑cloud) and HTTP/REST APIs; Eclipse Ditto stores device twins and exposes WebSocket/REST interfaces; network architecture includes an MQTT broker, Ditto server, and visualization client connected over secure channels."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM IFC for building models; MQTT, HTTPS/REST, and JSON schema for IoT communication; adherence to open model‑driven engineering standards (EMF)."
]