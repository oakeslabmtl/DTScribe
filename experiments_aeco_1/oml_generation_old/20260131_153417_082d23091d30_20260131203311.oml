// C2: Acting Components
instance LightingActuatorSystem : DTDFVocab:ActingComponent [
    base:desc "Building Control System actuators for adaptive lighting systems in BOREALIS project"
]

instance HVACController : DTDFVocab:ActuatingComponent [
    base:desc "Building Control System controllers for HVAC adjustments based on environmental data"
]

// C3: Physical sensing components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors embedded in buildings for operational data collection including post-occupancy lighting sensor data"
    DTDFVocab:producedData LightingDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors embedded in buildings for operational data collection including post-occupancy environmental sensor data"
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors embedded in buildings for operational data collection including post-occupancy occupancy sensor data"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors embedded in buildings for operational data collection including post-occupancy temperature sensor data"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors embedded in buildings for operational data collection including post-occupancy humidity sensor data"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance AirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors embedded in buildings for operational data collection including post-occupancy air quality sensor data"
    DTDFVocab:producedData AirQualityDataTransmitted
]

// C4: Data Transmission
instance LightingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualitySensor
]

// C10: Models/Data
instance BIMModel : DTDFVocab:Model [
    base:desc "BIM (Building Information Modeling) models as the primary semantic backbone for static and dynamic building data"
]

instance RuntimeConfigurationModel : DTDFVocab:Model [
    base:desc "Runtime interfaces and metadata extracted from BIM for device configuration and control logic"
]

instance PostOccupancyData : DTDFVocab:Data [
    base:desc "Sensor data and operational metrics from physical building systems including post-occupancy data"
    DTDFVocab:fromData LightingDataTransmitted
    DTDFVocab:fromData EnvironmentalDataTransmitted
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:fromData AirQualityDataTransmitted
]

instance ControlConfigurationArtifact : DTDFVocab:Data [
    base:desc "Generated runtime artifacts including control configurations and service definitions via model-driven transformations"
]

instance BorealisRLPolicy : DTDFVocab:Data [
    base:desc "Reinforcement learning-based adaptive control policies derived from post-occupancy sensor data"
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for real-time data exchange and bidirectional communication between physical and virtual systems"
    DTDFVocab:inputTo RuntimeConfigurationModel
    DTDFVocab:inputTo PostOccupancyData
]

instance UnrealEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine for rich, interactive visualization and simulation of building operations"
]

instance ModelDrivenEngineering : DTDFVocab:Enabler [
    base:desc "Model-driven engineering principles for automating the transformation of BIM models into DT artifacts"
]

instance StandardizedExtensionPoints : DTDFVocab:Enabler [
    base:desc "Standardized extension points for modular service integration and scalability in DT architecture"
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring and visualization using Unreal Engine for immersive interfaces"
    DTDFVocab:enables RealTimeMonitoringService
    DTDFVocab:provides EnergyEfficiencyInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics and optimization for operational cost reduction and energy efficiency"
    DTDFVocab:enables PredictiveAnalyticsService
    DTDFVocab:provides EnergyEfficiencyInsight
    DTDFVocab:provides ControlOptimizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Interactive simulation and performance analysis of building operations"
    DTDFVocab:enables SimulationService
    DTDFVocab:provides PerformanceVisualizationInsight
]

instance RLAdaptiveControlService : DTDFVocab:Service [
    base:desc "Reinforcement learning-based adaptive control as in BOREALIS project"
    DTDFVocab:enables RLAdaptiveControlService
    DTDFVocab:provides PolicyIterationAction
    DTDFVocab:provides AdaptiveControlAction
]

instance AutomatedCommissioningService : DTDFVocab:Service [
    base:desc "Automated commissioning and bidirectional communication between virtual and physical assets"
    DTDFVocab:enables AutomatedCommissioningService
    DTDFVocab:provides CostReductionAction
]

// C17: Insights/Actions
instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring and predictive analytics for operational cost reduction and energy efficiency"
]

instance ControlOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized control strategies based on sensor data and analytics for adaptive lighting and HVAC adjustments"
]

instance PerformanceVisualizationInsight : DTDFVocab:Insight [
    base:desc "Enhanced decision-making for facility managers via interactive visualization of building operations"
]

instance PolicyIterationAction : DTDFVocab:Action [
    base:desc "Iterative improvement of control policies using reinforcement learning for dynamic adjustments"
    DTDFVocab:IsAutomatic true
]

instance CostReductionAction : DTDFVocab:Action [
    base:desc "Automated actions for operational cost reduction through optimized building operations"
    DTDFVocab:IsAutomatic true
]

instance AdaptiveControlAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting and HVAC systems based on real-time sensor data"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals and commands generated by the DT to adjust physical building systems, such as lighting, HVAC, and other operational parameters, via bidirectional communication protocols (e.g., through Ditto and Hono)."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with sub-second latency for critical operational data (e.g., sensor inputs, control commands)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "['Centralized DT platform with BIM as the core semantic model.', 'Integration of middleware (Hono/Ditto) for real-time data synchronization.', 'Modular extension points for adding custom services and analytics (e.g., reinforcement learning for adaptive control).', 'Orchestration of physical sensors, actuators, and control logic within a unified framework.']"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "['Design phase (as designed): BIM models serve as foundational representations.', 'Construction phase (as manufactured): Integration of BIM with real-time data for monitoring.', 'Operational phase (as operated): Continuous real-time synchronization, optimization, and control via DT services.']"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "['Overall Digital Twin Entanglement (ODTE) metric to measure alignment between physical and virtual representations.', 'Ensuring semantic coherence between BIM models and runtime data through model-driven transformations.', 'Handling semantic drift by continuous synchronization and validation of data (e.g., via middleware integration).', 'Verification and validation through case studies (e.g., Living Lab building) and iterative refinement.']"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "['Middleware-based real-time communication (Eclipse Hono and Ditto) for bidirectional data exchange.', 'Standardized protocols for sensor data ingestion and control signal transmission.', 'Network architecture supporting low-latency synchronization between physical and virtual systems.']"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "['Cloud-based or edge deployment for real-time processing and visualization (e.g., Unreal Engine for immersive interfaces).', 'Modular architecture enabling deployment on scalable infrastructure (e.g., distributed services via extension points).', 'Standardized extension points for integrating third-party tools and services.']"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "['Integration with BIM tools for unified semantic representation across design and operational phases.', 'Seamless interoperability with IoT platforms and building automation systems (e.g., via Hono/Ditto).', 'Standardized extension points for connecting with external systems (e.g., analytics platforms, third-party services).', 'Collaborative workflows between building control engineers, facility managers, and DT engineers.']"
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "['Data ownership is primarily with the PT owner (building infrastructure), as DT services are extensions for operational management.', 'Privacy considerations addressed through secure middleware (e.g., Hono/Ditto) and compliance with AECO standards.', 'No explicit mention of data anonymization or encryption protocols, but emphasis on secure real-time data exchange.']"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "['BIM as the primary standard for semantic representation and interoperability.', 'Integration with Eclipse Hono and Ditto for standardized real-time data exchange.', 'Standardized extension points for modular service integration.', 'Overall Digital Twin Entanglement (ODTE) metric for validation and interoperability assessment.']"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "['Real-time bidirectional communication via secure middleware (e.g., Hono/Ditto) to prevent unauthorized access.', 'Remote operation of DTs is possible but requires safeguards to avoid accidents (e.g., human-in-the-loop validation).', 'Focus on cybersecurity for data integrity and system reliability, especially for critical infrastructure control.', 'No explicit mention of human-in-the-loop validation protocols, but emphasis on operational safety.']"
]