// C1: System under study
instance BuildingInfrastructure : DTDFVocab:Component [
    base:desc "Physical building infrastructure modeled as a Digital Twin for AECO"
]

// C2: Acting Components
instance DimmableLightFixture : DTDFVocab:ActingComponent [
    base:desc "Dimable light fixture modeled in BIM and controlled by TwinLight and BOREALIS"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator modeled in BIM and addressed by TwinLight and BOREALIS"
]

// C3: Physical Sensing Components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor embedded in the building, configuration stored in BIM"
    DTDFVocab:producedData LightingSensorDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the building, configuration stored in BIM"
    DTDFVocab:producedData OccupancySensorDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor (temperature, humidity, CO2) embedded in the building, configuration stored in BIM"
    DTDFVocab:producedData EnvironmentalSensorDataTransmitted
]

// C4: Physical-to-Virtual Interaction – Data Transmitted
instance LightingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance OccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnvironmentalSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C5: Data (runtime)
instance LightingSensorData : DTDFVocab:Data [
    base:desc "Real‑time illumination levels streamed from LightingSensor"
    DTDFVocab:fromData LightingSensorDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancySensorData : DTDFVocab:Data [
    base:desc "Real‑time occupancy counts streamed from OccupancySensor"
    DTDFVocab:fromData OccupancySensorDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance EnvironmentalSensorData : DTDFVocab:Data [
    base:desc "Real‑time temperature, humidity and CO₂ readings streamed from EnvironmentalSensor"
    DTDFVocab:fromData EnvironmentalSensorDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C6: Enablers (tooling and enablers)
instance BIMModelingTool : DTDFVocab:Enabler [
    base:desc "BIM authoring tools used to create geometry and semantic models"
    DTDFVocab:enables Live3DVisualization
]

instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering transformation pipeline that generates Hono/Ditto configs and runtime artifacts"
    DTDFVocab:enables Live3DVisualization, VisualComfortReinforcementLearningControl
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono platform (MQTT/AMQP) for ingesting sensor streams from the physical building"
    DTDFVocab:enables RealTimeMonitoring, PredictiveAnalytics
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin service that stores device twin state and aggregates data"
    DTDFVocab:enables EnergyOptimization, BuildingPerformanceSimulation
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime that consumes data from Ditto for live 3‑D visualization"
    DTDFVocab:enables Live3DVisualization
]

// C7: Services (DT services)
instance Live3DVisualization : DTDFVocab:Service [
    base:desc "Live 3‑D visualization of the building in Unreal Engine 5"
    DTDFVocab:provides VisualComfortAssessmentInsight
]

instance RealTimeMonitoring : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard for sensor streams"
    DTDFVocab:provides EnergySavingRecommendationsInsight
]

instance PredictiveAnalytics : DTDFVocab:Service [
    base:desc "Predictive analytics providing optimized lighting set‑points"
    DTDFVocab:provides OptimizedLightingSetpointsInsight
]

instance EnergyOptimization : DTDFVocab:Service [
    base:desc "Energy‑consumption optimization based on sensor data and control policies"
    DTDFVocab:provides EnergyConsumptionOptimizationInsight
]

instance VisualComfortReinforcementLearningControl : DTDFVocab:Service [
    base:desc "Reinforcement‑learning control loop that reinforces visual comfort"
    DTDFVocab:provides AdjustLightingControlAction
]

instance BuildingPerformanceSimulation : DTDFVocab:Service [
    base:desc "Simulation of building performance using the digital twin"
    DTDFVocab:provides BuildingPerformanceSimulationInsight
]

// C8: Insights
instance VisualComfortAssessmentInsight : DTDFVocab:Insight [
    base:desc "Assessment of visual comfort levels for facility managers"
]

instance EnergySavingRecommendationsInsight : DTDFVocab:Insight [
    base:desc "Energy‑saving recommendations derived from real‑time monitoring"
]

instance OptimizedLightingSetpointsInsight : DTDFVocab:Insight [
    base:desc "Optimized lighting control set‑points generated by predictive analytics"
]

instance EnergyConsumptionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight on how to reduce overall building energy consumption"
]

instance BuildingPerformanceSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from simulation of building performance under varying conditions"
]

// C9: Actions
instance AdjustLightingControlAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of dimmable light fixtures to maintain visual comfort"
    DTDFVocab:IsAutomatic true
]

// C10: Models/Data
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Static BIM geometry model of the building"
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance SemanticBIMModel : DTDFVocab:Model [
    base:desc "Semantic BIM model storing component classifications and metadata"
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance SensorStreamModel : DTDFVocab:Model [
    base:desc "Dynamic model representing live sensor streams"
    DTDFVocab:inputTo EclipseHono
]

instance ControlPolicyModel : DTDFVocab:Model [
    base:desc "Model of control policies governing actuators"
    DTDFVocab:inputTo EclipseDitto
]

instance ReinforcementLearningModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning model used for visual‑comfort control"
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

// C11: Composite Twin (multiplicities)
instance BuildingLevelTwin : DTDFVocab:Component [
    base:desc "Composite building‑level twin aggregating device‑level twins (sensors, actuators, controllers)"
    base:contains LightingSensor, OccupancySensor, EnvironmentalSensor, DimmableLightFixture, HVACActuator
]

// C12: Environment (optional grouping)
instance TwinEnvironment : DTDFVocab:Environment [
    base:contains BuildingInfrastructure, BuildingLevelTwin, Live3DVisualization, RealTimeMonitoring, PredictiveAnalytics, EnergyOptimization, VisualComfortReinforcementLearningControl, BuildingPerformanceSimulation
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points, reinforcement‑learning policies) are sent back to the physical actuators through the same Hono/Ditto middleware, enabling bidirectional actuation"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous near‑real‑time synchronization; data exchange occurs at the rate required by sensor update frequencies (typically sub‑second to seconds)"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A service‑oriented architecture consisting of a BIM‑derived model repository, a Hono/Ditto configurator, bidirectional middleware, a visualization layer (Unreal Engine), and plug‑in extension points for custom services"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers design (BIM model creation), construction (device commissioning), and operation (runtime monitoring and control)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation step before deployment and quantitative evaluation of twin‑physical alignment using the Overall Digital Twin Entanglement (ODTE) metric"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "IoT messaging via Eclipse Hono (supports MQTT and AMQP) linked to Eclipse Ditto digital‑twin server; communication uses tenant and device IDs extracted from BIM metadata"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized extension points enable integration with external building‑management systems and analytics services, though specific systems are not enumerated"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Relies on BIM as the standard modelling language for the construction domain and uses standardized extension points; integration with Eclipse Ditto follows open‑source IoT standards"
]