// Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor twin mapped to BIM element via Ditto, transmitting data every 5 seconds"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor twin mapped to BIM element via Ditto, transmitting data every 5 seconds"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor twin mapped to BIM element via Ditto, transmitting data every 5 seconds"
    DTDFVocab:producedData CO2DataTransmitted
]

instance LuminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Luminance sensor twin mapped to BIM element via Ditto, transmitting data every 5 seconds"
    DTDFVocab:producedData LuminanceDataTransmitted
]

instance OccupancyMotionSensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy motion detector twin mapped to BIM element via Ditto, transmitting data every 5 seconds"
    DTDFVocab:producedData OccupancyDataTransmitted
]

// Physical- to Virtual Interaction - Data Transmitted
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance LuminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LuminanceSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyMotionSensor
]

// Runtime Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Time‑series temperature data stored in InfluxDB, received via MQTT/TLS"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Time‑series humidity data stored in InfluxDB, received via MQTT/TLS"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Time‑series CO₂ data stored in InfluxDB, received via MQTT/TLS"
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance LuminanceData : DTDFVocab:Data [
    base:desc "Time‑series luminance data stored in InfluxDB, received via MQTT/TLS"
    DTDFVocab:fromData LuminanceDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Time‑series occupancy data stored in InfluxDB, received via MQTT/TLS"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// Enablers / Tools
instance EMFTool : DTDFVocab:Enabler [
    base:desc "EMF-based metamodel for transforming enriched BIM into runtime configuration"
    DTDFVocab:enables RealTimeMonitoringDashboardService, LightingOptimizationService, HVACReinforcementLearningService, MaintenancePlanningService, ImmersiveVisualizationService
]

instance ATLTransformation : DTDFVocab:Enabler [
    base:desc "ATL transformation engine to extract domain semantics from BIM for setup of Docker‑based deployments"
    DTDFVocab:enables RealTimeMonitoringDashboardService, LightingOptimizationService, HVACReinforcementLearningService, MaintenancePlanningService, ImmersiveVisualizationService
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT‑over‑TLS bridge for bidirectional transport of sensor telemetry and actuator commands"
    DTDFVocab:enables RealTimeMonitoringDashboardService, LightingOptimizationService, HVACReinforcementLearningService, MaintenancePlanningService, ImmersiveVisualizationService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for device shadowing and real‑time data binding, exposing twin state to dashboards and RL policies"
    DTDFVocab:enables RealTimeMonitoringDashboardService, LightingOptimizationService, HVACReinforcementLearningService, MaintenancePlanningService, ImmersiveVisualizationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3D visualization of the building and indoor environment"
    DTDFVocab:enables ImmersiveVisualizationService
]

instance CodeGenerator : DTDFVocab:Enabler [
    base:desc "Automated code generator producing Ditto twin definitions and MQTT client stubs from metamodel instances"
    DTDFVocab:enables RealTimeMonitoringDashboardService, LightingOptimizationService, HVACReinforcementLearningService, MaintenancePlanningService
]

// Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Live dashboards displaying real‑time energy consumption and comfort indices"
    DTDFVocab:provides EnergyConsumptionInsight, ComfortIndexInsight
]

instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Predictive optimization of lighting schedules using time‑series data"
    DTDFVocab:provides SetLightingScheduleAction
]

instance HVACReinforcementLearningService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based HVAC control policy tuning"
    DTDFVocab:provides AdjustHVACSetpointAction
]

instance MaintenancePlanningService : DTDFVocab:Service [
    base:desc "Task planning service for predictive maintenance events"
    DTDFVocab:provides PlanMaintenanceEventAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time 3D visualization of building states powered by Unreal Engine 5"
    DTDFVocab:provides VisualizeInUnrealAction
]

// Insights
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight into current and forecast energy consumption derived from sensor data streams"
]

instance ComfortIndexInsight : DTDFVocab:Insight [
    base:desc "Insight on indoor comfort indices combining temperature, humidity, luminance, and occupancy data"
]

instance PredictiveAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive alerts for abnormal temperature or CO₂ spikes based on anomaly detection models"
]

// Actions
instance SetLightingScheduleAction : DTDFVocab:Action [
    base:desc "Automated adjustment of lighting dimmer setpoints according to optimized schedule"
    DTDFVocab:IsAutomatic true
]

instance AdjustHVACSetpointAction : DTDFVocab:Action [
    base:desc "Automated adjustment of HVAC temperature setpoints based on RL policy"
    DTDFVocab:IsAutomatic true
]

instance PlanMaintenanceEventAction : DTDFVocab:Action [
    base:desc "Automated scheduling of maintenance tasks based on predictive maintenance model"
    DTDFVocab:IsAutomatic true
]

instance CalibrateControlParametersAction : DTDFVocab:Action [
    base:desc "Calibration of supervisory control parameters based on observed discrepancies"
    DTDFVocab:IsAutomatic true
]

instance VisualizeInUnrealAction : DTDFVocab:Action [
    base:desc "Trigger 3D visualization rendering in Unreal Engine 5"
    DTDFVocab:IsAutomatic false
]

// Acting Components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator twin controlled via MQTT commands sent through Hono to building management system"
]

instance HVACDamperActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC damper actuator twin controlled via MQTT commands sent through Hono to building management system"
]

instance PlugLoadModuleActuator : DTDFVocab:ActingComponent [
    base:desc "Plug‑load module twin that can switch devices on/off via MQTT commands sent through Hono"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control decisions or optimization actions generated by the DT are published back through Ditto to Hono, carrying desired actuator states (e.g., light level setpoints) which propagate to the physical control devices with sub‑minute latency."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sub‑second real‑time data bus (latency < 1 s); optimisation cycles run every 5‑10 minutes, with visualisation refreshed continuously."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Central orchestrator: Ditto twin manager; connectivity hub: Hono gateway; data analytics engine; optional cloud analytics service; immersive front‑end: Unreal Engine; all coordinated via micro‑service architecture."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Lifecycle stages covered: (1) design (BIM authoring), (2) construction (device configuration extraction), (3) operation (real‑time monitoring and dynamic control); the DT is primarily instantiated for the operated phase."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Semantic fidelity monitored through the Overall Digital Twin Entanglement (ODTE) metric; simulation validation against field measurements; uncertainty quantified via error bounds on sensor data; discrepancy handling via automated reconciliation scripts."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT over TLS 1.3 for device‑to‑gateway communication; HTTP/REST for twin inventory queries; WebSocket for real‑time velocity streaming; Hono enables scalable, secure routing to Ditto."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Containerised microservices running on a Kubernetes cluster in a private cloud; Ditto and Hono deployed in Docker containers; Unreal Engine rendering node on a dedicated GPU server; time‑series database (e.g., InfluxDB) shared via secure API."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "RESTful APIs expose twin data to downstream systems (BMS, ERP, asset management) and enable import of external IoT data streams into the twin; extension points for third‑party analytics services."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM using IFC 4.x; MQTT V3.1.1/5 for data transport; Ditto following Its REST API spec; adherence to ISO/IEC 30141 (Digital Twin Definition) through the framework’s ontology."
]