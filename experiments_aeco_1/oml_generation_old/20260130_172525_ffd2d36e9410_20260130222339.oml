// C3: Physical sensing components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor modelled in BIM for measuring illumination levels in the Living Lab building."
    DTDFVocab:producedData LightingDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modelled in BIM for detecting presence of occupants in the Living Lab building."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modelled in BIM for measuring ambient temperature in the Living Lab building."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor modelled in BIM for capturing additional environmental parameters (e.g., humidity, CO₂)."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance LightingDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Realtime stream of illumination measurements from LightingSensor."
    DTDFVocab:producedFrom LightingSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Realtime stream of occupancy detections from OccupancySensor."
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Realtime stream of temperature measurements from TemperatureSensor."
    DTDFVocab:producedFrom TemperatureSensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Realtime stream of environmental parameters from EnvironmentalSensor."
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C5: Data objects
instance LightingData : DTDFVocab:Data [
    base:desc "Live illumination data derived from LightingSensor."
    DTDFVocab:fromData LightingDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy data derived from OccupancySensor."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature data derived from TemperatureSensor."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Live environmental data (humidity, CO₂, etc.) derived from EnvironmentalSensor."
    DTDFVocab:fromData EnvironmentalDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing static geometry, spatial relationships, and runtime semantics for the Living Lab building."
    DTDFVocab:inputTo EclipseDitto, ModelDrivenEngineeringPipeline
]

// C11: Enablers
instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital twin state and stores incoming sensor data."
    DTDFVocab:enables MonitoringDashboard, EnergyOptimizationService
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides IoT connectivity and streams sensor measurements to Eclipse Ditto."
    DTDFVocab:enables MonitoringDashboard
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders immersive 3‑D visualization of the building twin."
    DTDFVocab:enables UnrealVisualizationService
]

instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline automates model‑to‑model and model‑to‑text transformations for runtime artifacts."
    DTDFVocab:enables SimulationAnalyticsService, CustomExtensionService
]

instance Configurator : DTDFVocab:Enabler [
    base:desc "Automated configurator deploys device twins and updates control strategies (e.g., reinforcement‑learning based updates)."
    DTDFVocab:enables EnergyOptimizationService, ControlStrategyAdjustmentAction
]

// C6: Services
instance MonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards display live sensor data for facility managers."
    DTDFVocab:provides EnergyConsumptionInsight, VisualComfortInsight
]

instance UnrealVisualizationService : DTDFVocab:Service [
    base:desc "3‑D interactive visualization in Unreal Engine 5 allows immersive exploration of the building twin."
    DTDFVocab:provides VisualComfortInsight
]

instance SimulationAnalyticsService : DTDFVocab:Service [
    base:desc "Simulation and predictive analytics service runs energy models and forecasts building performance."
    DTDFVocab:provides PredictiveFacilityManagementInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy‑optimization algorithms compute optimal control setpoints for lighting and HVAC."
    DTDFVocab:provides EnergyConsumptionInsight, ControlStrategyAdjustmentAction
]

instance CustomExtensionService : DTDFVocab:Service [
    base:desc "Extensible custom services added through defined extension points."
    DTDFVocab:provides ControlStrategyAdjustmentAction
]

// C17: Insights
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight on energy consumption patterns enabling optimization decisions."
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Insight on visual comfort levels derived from illumination data."
]

instance PredictiveFacilityManagementInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics insight supporting facility management decisions."
]

// C18: Actions
instance ControlStrategyAdjustmentAction : DTDFVocab:Action [
    base:desc "Action to adjust lighting and HVAC control strategies based on optimization results."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modelled in BIM that receives commands to adjust illumination levels."
]

instance HVACControlValve : DTDFVocab:ActingComponent [
    base:desc "HVAC control valve modelled in BIM that receives commands to regulate airflow."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command transmission from the Digital Twin to building actuators through Ditto’s command API, routed via Eclipse Hono to the physical control devices."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization between physical and virtual representations (sub‑second update cycle supported by Hono/Ditto)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized DT framework hub that orchestrates bidirectional data flow (Hono ↔ Ditto), executes services, and presents the building twin through Unreal Engine; services are plugged in via standardized extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the full building lifecycle: design (BIM authoring), construction (model validation and deployment), and operation (runtime data integration and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation is performed before deployment; the Overall Digital Twin Entanglement (ODTE) metric is used to quantify the fidelity of the twin relative to its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Realtime data exchange is implemented through Eclipse Hono and Eclipse Ditto, using the standard IoT protocols supported by Hono (e.g., MQTT/HTTP) to connect physical devices with the twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework relies on BIM standards for geometric and semantic data, and defines standardized extension points for service integration, ensuring compliance with AECO interoperability guidelines."
]