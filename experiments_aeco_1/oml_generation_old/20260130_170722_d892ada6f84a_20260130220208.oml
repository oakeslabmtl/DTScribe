// C3: Physical sensing components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor defined in the enriched BIM model, providing on/off state, brightness level, and colour‑temperature."
    DTDFVocab:producedData LightSensorDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor integrated in the building, streamed via Eclipse Hono to Ditto for monitoring."
    DTDFVocab:producedData TemperatureSensorDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in office spaces, reporting presence data through the middleware."
    DTDFVocab:producedData OccupancySensorDataTransmitted
]

// C4: Data transmitted from sensors
instance LightSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance TemperatureSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Data objects created from transmitted data
instance LightSensorData : DTDFVocab:Data [
    base:desc "Light sensor readings (on/off, brightness, colour‑temperature) after validation."
    DTDFVocab:fromData LightSensorDataTransmitted
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

instance TemperatureSensorData : DTDFVocab:Data [
    base:desc "Temperature values delivered at‑least‑once via Eclipse Hono and stored in Ditto."
    DTDFVocab:fromData TemperatureSensorDataTransmitted
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

instance OccupancySensorData : DTDFVocab:Data [
    base:desc "Occupancy presence flags transmitted through the middleware for real‑time use."
    DTDFVocab:fromData OccupancySensorDataTransmitted
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware providing at‑least‑once message delivery from sensors to downstream components."
    DTDFVocab:enables DataIngestionService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin store that validates policies, retains state, and supports real‑time synchronization."
    DTDFVocab:enables RealTimeDataExchangeService, ClosedLoopControlService
]

instance ModelDrivenDeploymentFramework : DTDFVocab:Enabler [
    base:desc "Model‑driven deployment framework that enriches BIM models, generates DT artefacts, and hosts custom extensions (TwinLight, BOREALIS)."
    DTDFVocab:enables VisualizationService, PredictiveAnalyticsService
]

// C6: Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Ingests sensor streams from Eclipse Hono, performs format conversion and forwards to Ditto."
    DTDFVocab:provides FacilityMonitoringInsight
]

instance RealTimeDataExchangeService : DTDFVocab:Service [
    base:desc "Continuously synchronises physical sensor states with the digital twin via Ditto."
    DTDFVocab:provides FacilityMonitoringInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive, immersive UE5 visualisation of building performance for facility managers."
    DTDFVocab:provides FacilityMonitoringInsight
]

instance ClosedLoopControlService : DTDFVocab:Service [
    base:desc "Executes control logic, maps twin commands to physical actuators (lights) through Ditto and UE5 delegates."
    DTDFVocab:provides ControlCommandAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Runs optimisation, predictive maintenance and what‑if scenario analyses on twin data."
    DTDFVocab:provides OptimizationInsight, PredictiveMaintenanceInsight, WhatIfScenarioInsight
]

// C17: Insights
instance FacilityMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time view of temperature, occupancy and energy consumption supporting facility manager decisions."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for energy‑efficient operation derived from predictive analytics."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Forecasts of component degradation enabling proactive maintenance actions."
]

instance WhatIfScenarioInsight : DTDFVocab:Insight [
    base:desc "Simulation outcomes for alternative control strategies and design changes."
]

// C17: Actions
instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Operator‑initiated command to toggle lights, adjust brightness or colour‑temperature."
    DTDFVocab:IsAutomatic false
]

// C10: Models / Data (semantic artefacts)
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with device metadata (e.g., Revit photometric values) serving as the geometric source."
    DTDFVocab:inputTo ModelDrivenDeploymentFramework
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral control logic defined by building control engineers, expressed as executable rules."
    DTDFVocab:inputTo ModelDrivenDeploymentFramework
]

instance FeatureParserModel : DTDFVocab:Model [
    base:desc "Custom FeatureParser services (e.g., LightFeatureParser) that map device states to actions."
    DTDFVocab:inputTo ModelDrivenDeploymentFramework
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The framework adopts a modular architecture centred on a central DT Framework that acts as a hub for bidirectional data exchange between the physical building and its digital counterpart. Standardised extension points allow DT Engineers to plug in custom services and analytics, while runtime configuration management enables on‑the‑fly adjustments without redeployment. The architecture coordinates distinct roles—Building Control Engineers model devices via BIM tools, Facility Managers interact with the deployed twin for real-time monitoring and control, and DT Engineers extend functionality—ensuring systematic orchestration of the Digital Twin lifecycle."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports the full DT life‑cycle from initial device modeling within the BIM environment (definition of sensors, actuators, controllers), model‑driven extraction of structured representations using MDE principles, automatic generation of deployable DT artifacts, deployment and real‑time operation with continuous data synchronization, runtime monitoring and interactive visualization, and subsequent evolution through modular extension points that allow integration of custom services and analytics."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is achieved by importing accurate geometric data from BIM and photometric parameters from Revit for realistic UE5 rendering. Validation occurs at multiple stages: the DT framework’s validation component checks model consistency, Eclipse Ditto applies policy‑based validation of sensor data and actuator commands, and pre‑execution checks prevent unsafe operations. Fault tolerance is provided by Hono’s at‑least‑once delivery and Ditto’s persistent event storage, ensuring synchronization despite network failures. The documents do not detail quantitative uncertainty quantification or formal verification methods."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The solution emphasizes interoperability across heterogeneous systems through non‑functional requirements that address scalability and maintainability. Integration is achieved via standardized extension points and bidirectional data exchange mechanisms, allowing external services, analytics, and other enterprise systems to be incorporated without a full system redesign. While specific protocols are not enumerated, the architecture is designed to support generic data exchange standards and to facilitate seamless horizontal integration with other Digital Twins and enterprise applications."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The proposed solution is built on the BIM standard as the core AECO data model and references industry‑wide DT frameworks (Eclipse Ditto, BaSyx) that comply with established interoperability specifications. However, the documents do not list additional certifications, compliance frameworks, or detailed data‑schema standards beyond BIM and the mentioned open‑source framework standards."
]