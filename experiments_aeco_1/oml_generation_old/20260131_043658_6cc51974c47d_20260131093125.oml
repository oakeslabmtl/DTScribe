// C1: Environment
instance UniversityAcademicBuilding : DTDFVocab:Environment [
    base:desc "A university academic building used as a living lab, serving as the physical counterpart for the Digital Twin."
    base:contains BuildingLightSubsystem, BuildingVentilationSubsystem, BuildingSensorSubsystem
]

// C2: Components
instance BuildingLightSubsystem : DTDFVocab:Component [
    base:desc "Digital twin sub‑twin representing the building lighting system, including smart light fixtures and dimmers."
]
instance BuildingVentilationSubsystem : DTDFVocab:Component [
    base:desc "Digital twin sub‑twin representing the building ventilation units."
]
instance BuildingSensorSubsystem : DTDFVocab:Component [
    base:desc "Digital twin sub‑twin representing the building sensor network."
]

// C2: Acting Components
instance SmartLightFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for lighting control modeled as a smart light fixture, configured and deployed via the DT."
]
instance DimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for dimming light fixtures, modeled and controlled through the Digital Twin."
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor collecting presence data from the building."
    DTDFVocab:producedData OccupancySensorDataTransmitted
]
instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Light level sensor measuring illumination for lighting control."
    DTDFVocab:producedData LightLevelSensorDataTransmitted
]
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring ambient temperature."
    DTDFVocab:producedData TemperatureSensorDataTransmitted
]
instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Generic environmental sensor capturing various environmental parameters."
    DTDFVocab:producedData EnvironmentalSensorDataTransmitted
]

// C4: Data transmitted
instance OccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance LightLevelSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]
instance TemperatureSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance EnvironmentalSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C5: Data
instance OccupancyRuntimeData : DTDFVocab:Data [
    base:desc "Runtime data stream from the occupancy sensor."
    DTDFVocab:fromData OccupancySensorDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]
instance LightLevelRuntimeData : DTDFVocab:Data [
    base:desc "Runtime data stream from the light level sensor."
    DTDFVocab:fromData LightLevelSensorDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]
instance TemperatureRuntimeData : DTDFVocab:Data [
    base:desc "Runtime data stream from the temperature sensor."
    DTDFVocab:fromData TemperatureSensorDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]
instance EnvironmentalRuntimeData : DTDFVocab:Data [
    base:desc "Runtime data stream from the generic environmental sensor."
    DTDFVocab:fromData EnvironmentalSensorDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// C6: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware connecting IoT devices to the Digital Twin."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsOptimisationService, ReinforcementLearningControlPolicyService
]
instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto service registry and telemetry ingestion."
    DTDFVocab:enables RealTimeMonitoringService, FacilityManagementInterfaceService
]
instance ModelDrivenTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Model–driven transformation tools mapping BIM metadata to runtime artifacts."
    DTDFVocab:enables ModelTransformationService
]
instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 rendering support for real‑time visualization."
    DTDFVocab:enables UnrealEngineVisualizationService
]
instance HonoDittoConfiguratorEnabler : DTDFVocab:Enabler [
    base:desc "Custom configurator deploying artifacts via Hono/Ditto."
    DTDFVocab:enables DeploymentService
]

// C7: Model–driven transformation service (auxiliary)
instance ModelTransformationService : DTDFVocab:Service [
    base:desc "Service applying BIM to runtime artifact transformations."
    DTDFVocab:provides ModelTransformationInsight
]
instance DeploymentService : DTDFVocab:Service [
    base:desc "Service deploying constructed runtimes via Hono/Ditto configurator."
    DTDFVocab:provides DeploymentInsight
]

// C10: Models/Data
instance IFCModel : DTDFVocab:Model [
    base:desc "BIM geometry represented in IFC format."
    DTDFVocab:inputTo ModelDrivenTransformationEnabler
]
instance SemanticAnnotationsModel : DTDFVocab:Model [
    base:desc "Semantic annotations enriching device and control logic."
    DTDFVocab:inputTo ModelDrivenTransformationEnabler
]
instance RuntimeDataStreamsModel : DTDFVocab:Model [
    base:desc "Runtime data streams model from sensor telemetry."
    DTDFVocab:inputTo ModelDrivenTransformationEnabler
]
instance ControlCommandHistoryModel : DTDFVocab:Model [
    base:desc "Model storing historical control command execution."
    DTDFVocab:inputTo ModelDrivenTransformationEnabler
]
instance ControlCommandHistoryData : DTDFVocab:Data [
    base:desc "Data instance representing historical control command records."
    DTDFVocab:inputTo ModelDrivenTransformationEnabler
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring and visualization of building systems."
    DTDFVocab:provides VisualizeInUnrealAction
]
instance UnrealEngineVisualizationService : DTDFVocab:Service [
    base:desc "Renders building status using Unreal Engine 5."
    DTDFVocab:provides UnrealEngineVisualizationAction
]
instance PredictiveAnalyticsOptimisationService : DTDFVocab:Service [
    base:desc "Offers predictive analytics and optimization for lighting and HVAC."
    DTDFVocab:provides EnergySavingsProjectionInsight, OptimalLightingScheduleInsight, SendEnergySavingsReportAction, SendLightingScheduleAction
]
instance ReinforcementLearningControlPolicyService : DTDFVocab:Service [
    base:desc "Refines control policies through reinforcement‑learning based control."
    DTDFVocab:provides ControlPolicyUpdateSuggestionInsight, SendControlPolicyUpdateAction
]
instance FacilityManagementInterfaceService : DTDFVocab:Service [
    base:desc "Interactive user interface for facility management."
    DTDFVocab:provides FacilityManagementAction
]

// C17: Insights
instance EnergySavingsProjectionInsight : DTDFVocab:Insight [
    base:desc "Projected energy savings achieved through optimized control strategies."
]
instance OptimalLightingScheduleInsight : DTDFVocab:Insight [
    base:desc "Optimal lighting schedules derived from predictive analytics."
]
instance ControlPolicyUpdateSuggestionInsight : DTDFVocab:Insight [
    base:desc "Suggested updates to control policy based on post‑occupancy data."
]
instance ModelTransformationInsight : DTDFVocab:Insight [
    base:desc "Insights derived from model transformation processes."
]
instance DeploymentInsight : DTDFVocab:Insight [
    base:desc "Deployment status and logs of runtime artifacts."
]

// C17: Actions
instance SendEnergySavingsReportAction : DTDFVocab:Action [
    base:desc "Automatically sends energy savings report to facility managers."
    DTDFVocab:IsAutomatic true
]
instance SendLightingScheduleAction : DTDFVocab:Action [
    base:desc "Sends optimal lighting schedule to facility management dashboard."
    DTDFVocab:IsAutomatic true
]
instance SendControlPolicyUpdateAction : DTDFVocab:Action [
    base:desc "Automated dispatch of control policy updates to actuators."
    DTDFVocab:IsAutomatic true
]
instance VisualizeInUnrealAction : DTDFVocab:Action [
    base:desc "Visualizes real‑time building status within Unreal Engine 5."
    DTDFVocab:IsAutomatic true
]
instance UnrealEngineVisualizationAction : DTDFVocab:Action [
    base:desc "Triggers rendering of building model in Unreal Engine 5."
    DTDFVocab:IsAutomatic true
]
instance FacilityManagementAction : DTDFVocab:Action [
    base:desc "Facilitates interactive user interface operations for facility managers."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin (e.g., lighting setpoints, HVAC adjustments) are sent via Ditto messages through Hono back to the physical actuators, enabling bidirectional synchronization."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates in real‑time, continuously ingesting sensor streams and propagating control signals with minimal latency, enabling instantaneous synchronization between the physical and virtual worlds."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized orchestration layer comprising the BIM‑based device model, the Hono/Ditto micro‑services handling communication, the Unreal Engine rendering engine, and optional reinforcement‑learning modules that refine control policies."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (BIM modeling), Construction (deployment of devices and connectivity configuration), Commissioning (validation of connectivity and control logic), and Operation (ongoing monitoring, optimization, and iterative policy updates during occupancy)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is evaluated using the Overall Digital Twin Entanglement (ODTE) metric; semantic drift is mitigated through continuous synchronisation; validation covers data consistency checks between BIM annotations and live telemetry."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication relies on MQTT (via Hono) and CoAP protocols over TCP/IP, with Ditto providing the device registry and command/telemetry channels."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin stack is hosted in a cloud or on‑premises environment orchestrated by Kubernetes, with Ditto services deployed in containers and Unreal Engine running as a rendering service."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of BIM (IFC) for semantic modeling, MQTT/CoAP protocols for connectivity, and open‑source standards provided by Eclipse Hono and Ditto."
]