// Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded in BIM, measures room temperature (-20°C to 50°C) via dedicated sensor, transmits data at 1 Hz"
    DTDFVocab:producedData TemperatureSensorDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded in BIM, detects presence, transmits occupancy status at 1 Hz"
    DTDFVocab:producedData OccupancySensorDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded in BIM, measures relative humidity, transmits data at 1 Hz"
    DTDFVocab:producedData HumiditySensorDataTransmitted
]

instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded in BIM, monitors lighting levels, transmits data at 1 Hz"
    DTDFVocab:producedData LightingSensorDataTransmitted
]

// Data transmitted from sensing components
instance TemperatureSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance HumiditySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance LightingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

// Data derived from transmitted telemetry
instance TemperatureData : DTDFVocab:Data [
    base:desc "Measured temperature values from TemperatureSensor, stored in Celsius"
    DTDFVocab:inputTo MonitoringEnabler, TimeSeriesAnalyticsEnabler
    DTDFVocab:fromData TemperatureSensorDataTransmitted
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Presence detection values from OccupancySensor, stored as boolean at 1 Hz"
    DTDFVocab:inputTo MonitoringEnabler, TimeSeriesAnalyticsEnabler
    DTDFVocab:fromData OccupancySensorDataTransmitted
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Relative humidity values from HumiditySensor, stored in percent"
    DTDFVocab:inputTo MonitoringEnabler, TimeSeriesAnalyticsEnabler
    DTDFVocab:fromData HumiditySensorDataTransmitted
]

instance LightingData : DTDFVocab:Data [
    base:desc "Illuminance values from LightingSensor, stored in lux"
    DTDFVocab:inputTo MonitoringEnabler, TimeSeriesAnalyticsEnabler
    DTDFVocab:fromData LightingSensorDataTransmitted
]

// Acting components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Lighting actuation path; processes brightness and colour temperature commands via UnrealTwinController to DittoController, translating to LED fixtures"
]

instance HVACActuatorComponent : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator logic defined in BIM via HVACFeatureParser, validated by policy validator for safe ranges"
]

// Actuator command data
instance ActuationCommandTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightTwinComponent, HVACActuatorComponent
]

instance ActuatorCommandData : DTDFVocab:Data [
    base:desc "Actuator command data (brightness change, HVAC setpoint) transmitted via Hono MQTT"
    DTDFVocab:inputTo ActuationCommandEnabler
    DTDFVocab:fromData ActuationCommandTransmitted
]

// Enablers
instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Processes telemetry from sensors via Hono/Ditto, enforcing policy ranges and units for subsystem monitoring"
    DTDFVocab:enables MonitoringService
]

instance TimeSeriesAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Consumes sensor data to predict failures and optimize schedules using time-series analytics"
    DTDFVocab:enables PredictionService, OptimizationService
]

instance ActuationCommandEnabler : DTDFVocab:Enabler [
    base:desc "Validates and routes actuator commands through Hono MQTT to physical actuators"
    DTDFVocab:enables DirectControlService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Feeds aggregated data to dashboards for immersive visualization"
    DTDFVocab:enables VisualizationService
]

instance PluginIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Allows Digital Twin engineers to add custom analytic services via plugin architecture"
    DTDFVocab:enables PluginIntegrationService
]

instance MDETransformationEnabler : DTDFVocab:Enabler [
    base:desc "Transforms enriched BIM into deployable twin artefacts via model-driven engineering"
    DTDFVocab:enables ModelTransformationService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitors building subsystems (energy, temperature, occupancy) via real-time telemetry"
    DTDFVocab:provides SystemStatusInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Predicts future states and potential failures using time-series analytics"
    DTDFVocab:provides FailurePredictionInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimizes HVAC, lighting, and energy schedules to reduce operating costs"
    DTDFVocab:provides EnergyScheduleOptimizationAction
]

instance DirectControlService : DTDFVocab:Service [
    base:desc "Provides direct control of actuators through command interfaces"
    DTDFVocab:provides ActuatorControlAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization of building layout, status, and simulation results via dashboards"
    DTDFVocab:provides DashboardVisualizationInsight
]

instance PluginIntegrationService : DTDFVocab:Service [
    base:desc "Enables Digital Twin engineers to add custom analytic services as plugins"
    DTDFVocab:provides CustomAnalyticsPluginAction
]

instance ModelTransformationService : DTDFVocab:Service [
    base:desc "Performs model-driven transformation of enriched BIM to runtime twin artefacts"
    DTDFVocab:provides ModelTransformationInsight
]

// Insights and Actions
instance SystemStatusInsight : DTDFVocab:Insight [
    base:desc "Real‑time status of building subsystems including energy, temperature, and occupancy"
]

instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted risk of subsystem failures based on time-series analytics"
]

instance EnergyScheduleOptimizationAction : DTDFVocab:Action [
    base:desc "Optimized HVAC and lighting schedules to reduce operating costs"
    DTDFVocab:IsAutomatic true
]

instance ActuatorControlAction : DTDFVocab:Action [
    base:desc "Commands to actuators such as brightness change or HVAC setpoint"
    DTDFVocab:IsAutomatic false
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Dashboard displaying building layout, status, and simulation results"
]

instance CustomAnalyticsPluginAction : DTDFVocab:Action [
    base:desc "Action to register and activate custom analytic plugins"
    DTDFVocab:IsAutomatic false
]

instance ModelTransformationInsight : DTDFVocab:Insight [
    base:desc "Status of model transformation process from enriched BIM to runtime artefacts"
]

// Model derived from BIM
instance LivingLabBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model of the Living Lab building with embedded sensor and actuator definitions, used as input to MDE transformation"
    DTDFVocab:inputTo MDETransformationEnabler
]

// Environment
instance LivingLabBuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, OccupancySensor, HumiditySensor, LightingSensor, LightTwinComponent, HVACActuatorComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin (e.g., HVAC adjustments, lighting changes) are sent through the Hono/Ditto messaging stack to the building control systems, enabling bidirectional communication and confirmation of command execution."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization between the physical building and its digital twin is achieved through the framework’s real‑time data exchange capabilities. The system continuously pushes sensor measurements from the physical assets to the digital replica and pulls control commands back, ensuring a near‑zero‑lag loop. While explicit update frequencies or latency bounds are not specified in the documents, the architecture emphasizes continuous, low‑latency data flow to support live monitoring, predictive analytics, and rapid control decisions."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Model‑driven deployment orchestrates an end‑to‑end lifecycle: enriched BIM data is parsed via MDE to generate structured digital twins for each physical component; a central DT framework hub orchestrates bidirectional data exchange, runtime configuration, and service plug‑in integration; the architecture follows a hub‑and‑spoke pattern with the central hub coordinating device‑level sub‑twin instances, encapsulating device modeling, control logic, and monitoring; resource management and coordination are handled by this central component, while DT Engineers extend functionality through standardized extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows a model‑driven deployment workflow that begins with an enriched Building Information Model (BIM) where Building Control Engineers directly embed sensors, actuators and control logic into the 3‑D representation. Using Model‑Driven Engineering (MDE) principles, the enriched BIM is automatically extracted into a structured runtime artefact, and a reproducible deployment pipeline (R2) deploys the digital twin with minimal manual intervention. During operation, live telemetry from the physical building is streamed via Eclipse Hono to the twin service (Eclipse Ditto) for continuous synchronization, while facility managers interact with the twin through interactive visualization interfaces. Lifecycle governance is defined by the role hierarchy in Table I: Building Control Engineers manage model creation, DT Engineers extend functionality, and Facility Managers oversee runtime monitoring and control, ensuring that each phase—design, deployment, runtime, and evolution—is coordinated under a formally defined change‑management process."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model and data fidelity is enforced through several mechanisms. The deployment pipeline validates structural consistency during the Model‑Checking and Model‑Parsing stages. Runtime validity is verified by Ditto’s policy engine, ensuring value ranges and units, and by Hono’s at‑least‑once delivery guaranteeing no message loss. The Overall Digital Twin Entanglement (ODTE) metric quantifies entanglement via its components: timeliness (0.997, indicating minimal delay across the 1 s heartbeat), reliability (1.0, no lost updates), and availability (1.0, full uptime), yielding an ODTE score of 0.997 over a 12‑minute measurement window. These metrics, together with persistent event storage and policy validation, provide rigorous quality assurance for the twin’s synchronization with the physical system."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin middleware employs Eclipse Hono as a message broker to ingest data from sensors and control devices, and Eclipse Ditto to manage the digital twin representation. This stack delivers interoperability across heterogeneous systems and provides the required real‑time connectivity between physical and virtual layers."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The platform integrates with external BIM tools for device modeling and with enterprise or building‑management systems through standardized extension points and plugin interfaces. Interaction with other Digital Twins or external systems is mediated by the framework’s modular architecture, which allows developers to plug in adapters for data exchange, authentication, and orchestration. Although specific communication protocols are not named, the design supports interoperability across heterogeneous systems, enabling the DT to serve as a bridge between the static BIM representation and dynamic operational environments."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture adheres to open‑source, industry‑standard protocols: MQTT for low‑latency messaging through Eclipse Hono, JSON and REST APIs for twin manipulation via Eclipse Ditto, and the semantic integration promised by the MDE transformation rules. It explicitly addresses the documented lack of standardized data schemas by generating compliant Ditto twin definitions from enriched BIM models, thereby conforming to JSON‑LD‑style structures. The framework’s modular design (R4) permits the adoption of additional interoperability standards (e.g., OPC UA, BACnet) through plug‑in extension points, while still relying on the core Eclipse stack for connectivity and device management."
]