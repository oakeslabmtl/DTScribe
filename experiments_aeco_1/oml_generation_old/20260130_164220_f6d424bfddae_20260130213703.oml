// C3: Physical sensing components
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor modeled as BIM device with IFC classification, streams illumination level data via Eclipse Hono every 1 second with 0.997 timeliness."
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled as BIM device with IFC classification, streams temperature data via Eclipse Hono every 1 second with 0.997 timeliness."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Data transmitted from sensors
instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C5: Data objects
instance IlluminationData : DTDFVocab:Data [
    base:desc "Real‑time illumination level values received from physical sensor."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoStore
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature values received from physical sensor."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoStore
]

// C2: Acting components
instance LightActuator : DTDFVocab:ActingComponent [
    base:desc "Light fixture modeled as IFCLIGHTFIXTURETYPE with UUID, exposes on/off, brightness, colour‑temperature properties."
    DTDFVocab:producedData LightCommandDataTransmitted
]

// C4: Data transmitted from actuators (control commands)
instance LightCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightActuator
]

// C5: Command data object
instance LightCommandData : DTDFVocab:Data [
    base:desc "Control command data sent from UE5 to Ditto for light actuation."
    DTDFVocab:fromData LightCommandDataTransmitted
    DTDFVocab:inputTo EclipseDittoStore
]

// C11: Enablers
instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Protocol gateway (MQTT/AMQP) that ingests sensor telemetry with at‑least‑once delivery."
    DTDFVocab:enables RealTimeSynchronizationService
]

instance EclipseDittoStore : DTDFVocab:Enabler [
    base:desc "Ditto twin state store with policy‑based validation for unit consistency and safety."
    DTDFVocab:enables RealTimeSynchronizationService, ControlExecutionService
]

instance AutomatedDeploymentPipeline : DTDFVocab:Enabler [
    base:desc "One‑click model‑to‑artifact transformation pipeline that extracts semantic model and generates deployable DT artifacts."
    DTDFVocab:enables DeploymentAutomationService
]

instance ModularExtensionFramework : DTDFVocab:Enabler [
    base:desc "Modular architecture with defined extension points allowing DT Engineers to plug in new services or analytics."
    DTDFVocab:enables ExtensionManagementService
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 client that renders 3‑D building geometry and visualizes live sensor data."
    DTDFVocab:enables InteractiveVisualizationService, MonitoringService
]

// C6: Services
instance RealTimeSynchronizationService : DTDFVocab:Service [
    base:desc "Real‑time data exchange synchronizing physical building assets with their digital counterparts."
    DTDFVocab:provides BuildingStateInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3‑D visualization of building geometry and live sensor values in UE5."
    DTDFVocab:provides VisualizationInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of system states for Facility Managers."
    DTDFVocab:provides FacilityManagerAlertAction
]

instance ControlExecutionService : DTDFVocab:Service [
    base:desc "Execution of control logic for actuators with safety constraints validated by Ditto policies."
    DTDFVocab:provides ActuatorCommandAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization of building operations based on real‑time data and analytics."
    DTDFVocab:provides BuildingOperationOptimizationInsight
]

instance DeploymentAutomationService : DTDFVocab:Service [
    base:desc "Automated deployment of DT artifacts via one‑click mechanism ensuring reproducible setup."
    DTDFVocab:provides DeploymentStatusInsight
]

instance ExtensionManagementService : DTDFVocab:Service [
    base:desc "Management of modular extensions allowing plug‑in of new analytics or services."
    DTDFVocab:provides ExtensionHealthInsight
]

// C17: Insights
instance BuildingStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current operational state of building systems derived from synchronized twin data."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight enabling UE5 client to render up‑to‑date visual representation of the building."
]

instance BuildingOperationOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting operational adjustments to improve energy efficiency based on real‑time sensor data."
]

instance DeploymentStatusInsight : DTDFVocab:Insight [
    base:desc "Insight reporting status of automated DT artifact deployment."
]

instance ExtensionHealthInsight : DTDFVocab:Insight [
    base:desc "Insight indicating health and performance of modular extensions."
]

// C17: Actions
instance FacilityManagerAlertAction : DTDFVocab:Action [
    base:desc "Automatic alert sent to Facility Manager when sensor readings exceed predefined thresholds."
    DTDFVocab:IsAutomatic true
]

instance ActuatorCommandAction : DTDFVocab:Action [
    base:desc "Command issued to an actuator (e.g., turn on light, adjust brightness) after pre‑execution safety checks."
    DTDFVocab:IsAutomatic false
]

// C10: Models/Data
instance GeometricBIMModel : DTDFVocab:Model [
    base:desc "3‑D building geometry exported from Revit to IFC, providing spatial relationships for visualization."
    DTDFVocab:inputTo UnrealEngineVisualization
]

instance DeviceSemanticModel : DTDFVocab:Model [
    base:desc "Semantic model extracted from enriched BIM containing device identifiers, IFC types, and control logic."
    DTDFVocab:inputTo AutomatedDeploymentPipeline, ModularExtensionFramework
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are created by the Facility Manager in the DT UI, transmitted to Ditto over the same WebSocket channel, and then routed by Ditto through Eclipse Hono to the addressed physical device. Commands are encoded as structured JSON payloads describing the desired action (e.g., turn‑on, set‑point change). Ditto validates the command schema before forwarding; Hono handles authentication/authorisation (as defined by its security configuration). The device executes the command and returns an execution acknowledgment, which Ditto receives and propagates back to the DT, allowing the twin state to be updated only after confirmation. This round‑trip ensures command validation, feedback, and conflict‑free operation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The solution uses a regular 1‑second heartbeat mechanism to coordinate data exchange between the physical building and its digital twin, providing continuous real‑time synchronization. Measured Overall Digital Twin Entanglement (ODTE) timeliness of 0.997 indicates a sub‑second latency. Full twin deployment (model checking, parsing, initialization) completes in 14.53 seconds (5.53 s + 8.7 s + 0.3 s)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, service‑oriented pattern. Enriched BIM models are transformed via model‑driven engineering into deployable artifacts. Runtime components include Eclipse Hono for device connectivity, Eclipse Ditto as the digital‑twin runtime, and a configurable DT Framework that provides standardized extension points and runtime configuration management. The central hub orchestrates bidirectional data flow, supports plug‑in services, and enables scalable deployment across the building lifecycle."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a five‑stage lifecycle for a building Digital Twin: (1) Device modelling in BIM – Building Control Engineers create custom Revit families and property sets for sensors, actuators and controllers, assign a unique Instance General UUID and set the appropriate IFC type (e.g., IFCLIGHTFIXTURETYPE). (2) Model checking – an IFC‑based model checker validates that all required metadata is present before the model is uploaded. (3) Semantic model extraction (F2) – model‑to‑model transformations generate a structured, domain‑specific representation from the enriched BIM/IFC file. (4) Automated one‑click deployment (F3) – the extracted model drives a model‑to‑text transformation that produces, configures and launches the DT runtime artifacts with minimal manual effort. (5) Runtime operation – live bidirectional data exchange (F4) via Eclipse Hono and Ditto keeps the physical building and its digital counterpart synchronised; interactive 3D visualisation (F5) in UE5 enables immersive monitoring; modular service integration (F6) and runtime configuration management (F7) allow new analytics or control services to be added or re‑configured without redeploying the whole twin. Governance is split across three roles: Building Control Engineer (modeling and deployment), Facility Manager (monitoring and control) and DT Engineer (service extension)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Before deployment the enriched IFC model undergoes automated model checking (average 5.53 s) using a custom IFC model checker that verifies required metadata such as the Instance General UUID. After parsing (8.7 s) the framework validates twin‑device bindings and applies Eclipse Ditto policy‑based validation to enforce correct units and value ranges, providing error detection at the data‑ingress point. Runtime consistency is quantified by the Overall Digital Twin Entanglement (ODTE) metric, which combines timeliness (0.997), reliability (1.0) and availability (1.0) measured over a 12‑minute window with a 1‑second heartbeat. Fault tolerance is achieved through Eclipse Hono’s at‑least‑once delivery and Ditto’s persistent event storage, ensuring resilience to network disruptions and enabling corrective replay of missed updates."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical network consists of a hub‑spoke architecture: physical devices connect to Eclipse Hono (gateway) via MQTT/HTTP/CoAP; Hono forwards data and commands to Eclipse Ditto (digital‑twin server). Ditto communicates bidirectionally with the UE5 visualization client using a persistent WebSocket connection and with the deployment configurator via HTTP POST for initial state transfer. Real‑time operation implies low‑latency links, though exact bandwidth or latency numbers are not specified. Reliability is achieved through automatic configuration, acknowledgment loops, and Ditto’s state persistence. Security mechanisms are provided by Hono’s built‑in authentication/authorisation, but detailed protocols (e.g., TLS) are not described in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is realized through Eclipse Hono for ingesting device data and Eclipse Ditto for exposing the twin via standard REST/WS APIs. The framework consumes BIM data and offers standardized extension points, allowing external analytics services, enterprise IT systems, or other digital twins to connect. Non‑functional requirements stress scalability, interoperability across heterogeneous systems, and accessibility for users with varying technical expertise."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution complies with BIM industry practices and uses the Industry Foundation Classes (IFC) as the open exchange format for all model data, ensuring interoperability across heterogeneous BIM tools (NF1). Semantic integration is achieved by mapping Revit custom families to IFC types and by extracting domain‑specific models that conform to BIM's object‑based 3D representation standards. Real‑time connectivity leverages Eclipse Hono and Eclipse Ditto, which implement standard IoT messaging patterns (e.g., MQTT with reliable at‑least‑once delivery). The modular service layer follows a standardized interface specification with defined extension points to guarantee that added services remain interoperable with the core DT platform."
]