// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded temperature sensor incorporated into the BIM model, transmitting measurements to the DT via Eclipse Hono over MQTT."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded occupancy sensor incorporated into the BIM model, transmitting measurements to the DT via Eclipse Hono over MQTT."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded light level sensor incorporated into the BIM model, transmitting measurements to the DT via Eclipse Hono over MQTT."
    DTDFVocab:producedData LightLevelDataTransmitted
]

// C2: Acting components
instance LightingDriverActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting driver embodied in the building control system, modeled in BIM and exposed to the digital twin via Eclipse Ditto twin interfaces for command execution."
]

instance HVACDamperActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC damper embodied in the building control system, modeled in BIM and exposed to the digital twin via Eclipse Ditto twin interfaces for command execution."
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

// C10: Models/Data (sensor data)
instance TemperatureData : DTDFVocab:Data [
    base:desc "Sensor readings from the temperature sensor, recorded and stored by the DT."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Sensor readings from the occupancy sensor, recorded and stored by the DT."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance LightLevelData : DTDFVocab:Data [
    base:desc "Sensor readings from the light level sensor, recorded and stored by the DT."
    DTDFVocab:fromData LightLevelDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

// C10: Models/Data (model data)
instance BIMGeometricSemanticData : DTDFVocab:Data [
    base:desc "BIM geometric and semantic model data enriched with device metadata."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance RuntimeDittoTwinData : DTDFVocab:Data [
    base:desc "Runtime Ditto twin descriptions extracted from the enriched BIM model."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance ControlLogicData : DTDFVocab:Data [
    base:desc "Control logic models embedded in BIM, representing actuator behavior."
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C10: Models
instance BIMGeometricSemanticModel : DTDFVocab:Model [
    base:desc "BIM geometric/semantic model used as the foundation for the digital twin."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance RuntimeDittoTwinModel : DTDFVocab:Model [
    base:desc "Runtime Ditto twin descriptions used for state synchronization in the digital twin."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic models embedded in BIM, defining actuator behavior."
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware for secure MQTT-based data ingestion from physical sensors to the digital twin."
    DTDFVocab:enables MonitoringService, PredictiveAnalyticsService, OptimizationEngineService, SimulationService, VisualizationService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto platform for twin management, state synchronization, and command execution."
    DTDFVocab:enables MonitoringService, PredictiveAnalyticsService, OptimizationEngineService, SimulationService, VisualizationService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 integration for immersive visualization of the building and its control states."
    DTDFVocab:enables VisualizationService
]

instance MDETransformationEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering transformation pipeline that enriches BIM with metadata and generates runtime Ditto twin schemas."
    DTDFVocab:enables EclipseDittoEnabler
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard service that visualizes live sensor states."
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service for energy efficiency and occupant comfort."
    DTDFVocab:provides EnergyEfficiencyInsight, OccupantComfortInsight
]

instance OptimizationEngineService : DTDFVocab:Service [
    base:desc "Optimization engine that computes optimal lighting schedules and HVAC set‑points."
    DTDFVocab:provides LightingScheduleInsight, HVACSetpointInsight, ApplyLightingScheduleAction, ApplyHVACSetpointAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation and what‑if analysis service for evaluating alternative control strategies."
    DTDFVocab:provides WhatIfAnalysisInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization service that renders the building and its control states using Unreal Engine 5."
    DTDFVocab:provides VisualizeFacilityAction
]

// C17: Insights
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Live sensor state visualization, showing current temperature, occupancy, and light level."
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Predictive insight recommending energy‑saving strategies based on sensor data and control logic."
]

instance OccupantComfortInsight : DTDFVocab:Insight [
    base:desc "Predictive insight concerning occupant comfort levels, derived from temperature and occupancy data."
]

instance LightingScheduleInsight : DTDFVocab:Insight [
    base:desc "Optimal lighting schedule derived from occupancy patterns."
]

instance HVACSetpointInsight : DTDFVocab:Insight [
    base:desc "Optimal HVAC set‑points derived from temperature and occupancy patterns."
]

instance WhatIfAnalysisInsight : DTDFVocab:Insight [
    base:desc "Results of simulated alternative control scenarios."
]

// C17: Actions
instance ApplyLightingScheduleAction : DTDFVocab:Action [
    base:desc "Automated action to adjust lighting drivers to the optimal schedule."
    DTDFVocab:IsAutomatic true
]

instance ApplyHVACSetpointAction : DTDFVocab:Action [
    base:desc "Automated action to set HVAC damper positions to optimal set‑points."
    DTDFVocab:IsAutomatic true
]

instance VisualizeFacilityAction : DTDFVocab:Action [
    base:desc "Command to launch immersive visualization of the building in Unreal Engine 5."
    DTDFVocab:IsAutomatic true
]

// C10: Environment
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, OccupancySensor, LightLevelSensor, LightingDriverActuator, HVACDamperActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT—e.g., lighting schedules or HVAC set‑points—are sent as twin updates over MQTT to the physical devices via Ditto, which forwards them to the actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, event‑driven real‑time synchronization with sub‑second latency between PT and DT achieved via MQTT broker."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A master building twin aggregates data from multiple device twins; Hono/Ditto orchestrate communication; visualization front‑ends interact via WebSocket/REST; overall architecture relies on MQTT for data flow."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Lifecycle phases covered are Design (BIM creation), Construction (device modeling and commissioning), and Operation (runtime monitoring, analytics, and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity assessed using the Overall Digital Twin Entanglement (ODTE) metric; validation performed by comparing virtual states to physical sensor data; semantic drift mitigated by synchronization mechanisms; uncertainties quantified by sensor error bounds."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Network connection employs MQTT broker in Eclipse Hono; Ditto twin updates exchanged over WebSocket/REST; communications secured with TLS and OAuth2 authentication via Hono."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Ditto and Hono services are containerized microservices deployed on a Kubernetes cluster; Unreal Engine visualizer runs on a dedicated GPU server, interfacing via WebSocket with the Ditto instance."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external building management systems and other digital twins is achieved via Ditto’s event bus and standardized APIs, enabling inter‑system data exchange and joint analytics."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Ownership of data remains with the PT owner; access is controlled through OAuth2 scopes in Hono/Ditto, and personal data are anonymized following GDPR guidelines."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adheres to BIM standards (ISO 19650, IFC schema), IoT middleware standards (MQTT, OCF), Ditto compatibility, and the ODTE metric for entanglement assessment."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Secure MQTT/TLS channels, role‑based access control in Hono/Ditto, runtime safety checks to prevent unsafe command propagation, and authentication‑gated remote command execution to avoid human‑near hazards."
]