instance OfficeTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor deployed in the academic building's office space"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OfficeHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor deployed in the academic building's office space"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OfficeCO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO2 sensor deployed in the academic building's office space"
    DTDFVocab:producedData CO2DataTransmitted
]

instance OfficeIlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor deployed in the academic building's office space"
    DTDFVocab:producedData IlluminanceDataTransmitted
]

instance OfficeOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor deployed in the academic building's office space"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OfficeTemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OfficeHumiditySensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OfficeCO2Sensor
]

instance IlluminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OfficeIlluminanceSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OfficeOccupancySensor
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature readings from office space sensors"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Real-time humidity readings from office space sensors"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Real-time CO2 concentration readings from office space sensors"
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

instance IlluminanceData : DTDFVocab:Data [
    base:desc "Real-time illuminance readings from office space sensors"
    DTDFVocab:fromData IlluminanceDataTransmitted
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy status from office space sensors"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched Building Information Modeling data from Revit with device-specific metadata"
    DTDFVocab:inputTo MDEFramework, UnrealEngine5
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting system actuator controlled via commands from the digital twin"
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Policy-based validation of sensor values and actuator commands"
    DTDFVocab:enables DataSynchronizationService, InteractiveVisualizationService
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Message delivery for real-time data synchronization"
    DTDFVocab:enables DataSynchronizationService
]

instance MDEFramework : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering framework for automated artifact generation from BIM models"
    DTDFVocab:enables SimulationTestingService
]

instance EclipseBasyx : DTDFVocab:Enabler [
    base:desc "Open-source Industry 4.0 platform for digital twin integration"
    DTDFVocab:enables DataSynchronizationService
]

instance itwinjs : DTDFVocab:Enabler [
    base:desc "Library for infrastructure digital twin applications"
    DTDFVocab:enables SimulationTestingService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Visualization platform for immersive interactive interfaces"
    DTDFVocab:enables InteractiveVisualizationService, SimulationTestingService
]

instance TwinComponent : DTDFVocab:Enabler [
    base:desc "Enabler for implementing behavioral models in the digital twin"
    DTDFVocab:enables PredictiveAnalyticsService
]

instance LightFeatureParser : DTDFVocab:Enabler [
    base:desc "Extension for processing lighting parameters"
    DTDFVocab:enables PredictiveAnalyticsService
]

instance ODTE : DTDFVocab:Enabler [
    base:desc "Overall Digital Twin Entanglement metric components for analytical models"
    DTDFVocab:enables PredictiveAnalyticsService
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of indoor environmental parameters and building systems"
    DTDFVocab:provides OperationalInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for maintenance scheduling and energy consumption optimization"
    DTDFVocab:provides MaintenanceSchedulingInsight, EnergyConsumptionInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization interfaces for Facility Managers to control physical infrastructure"
    DTDFVocab:provides ControlLightingAction
]

instance DataSynchronizationService : DTDFVocab:Service [
    base:desc "Continuous data synchronization between physical and digital assets"
    DTDFVocab:provides OperationalInsight
]

instance SimulationTestingService : DTDFVocab:Service [
    base:desc "Simulation-based scenario testing for operational optimization"
    DTDFVocab:provides ScenarioSimulationInsight
]

instance AutomatedReportingService : DTDFVocab:Service [
    base:desc "Automated reporting for decision-making support"
    DTDFVocab:provides ReportInsight
]

instance OperationalInsight : DTDFVocab:Insight [
    base:desc "Continuous operational insights from real-time data synchronization"
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Energy consumption optimization insights from predictive analytics"
]

instance MaintenanceSchedulingInsight : DTDFVocab:Insight [
    base:desc "Maintenance scheduling insights from predictive analytics"
]

instance ScenarioSimulationInsight : DTDFVocab:Insight [
    base:desc "Scenario simulation results for operational testing"
]

instance ReportInsight : DTDFVocab:Insight [
    base:desc "Automated reports for decision-making support"
]

instance ControlLightingAction : DTDFVocab:Action [
    base:desc "Control lighting parameters (on/off state, brightness, color temperature in kelvin)"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals are transmitted from the digital twin to Building Control Systems (BCS) for operational adjustments, as described in Document 4. Specific command types, message formats, validation mechanisms, feedback systems, conflict resolution, and execution confirmation details are not provided in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time data exchange capabilities ensure continuous synchronization between physical buildings and their digital counterparts."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT Framework serves as a central hub coordinating Building Control Engineers, Facility Managers, and DT Engineers to facilitate bidirectional data exchange and holistic building life cycle management through a modular architecture with standardized extension points for service integration."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle encompasses design-time modeling in BIM (Building Control Engineers define sensors, actuators, and controllers), automated deployment via Model-Driven Engineering (MDE) to generate deployable artifacts with minimal manual intervention (R2), and runtime operations involving real-time data synchronization using Eclipse Hono and Ditto (R3), interactive visualization for monitoring/control by Facility Managers, and extensibility through custom services via modular architecture (R4). Stakeholder roles govern each phase: Building Control Engineers handle initial modeling, Facility Managers operate physical infrastructure via the DT, and DT Engineers extend functionality."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is validated using the Overall Digital Twin Entanglement (ODTE) metric, comprising timeliness (0.997), reliability (1.0), and availability (1.0), measured via a 1-second heartbeat mechanism over 12 minutes. Data integrity is ensured through Eclipse Ditto’s policy-based validation for sensor value ranges and units, and pre-execution checks for actuator commands. Fault tolerance mechanisms include Eclipse Hono’s at-least-once delivery and Ditto’s persistent event storage, maintaining synchronization and operational safety. Bidirectional communication is verified by confirming state updates in both directions between physical and digital twins."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono and Ditto facilitate communication between physical and digital components for real-time data exchange, but specific network protocols, topology, bandwidth requirements, latency specifications, redundancy mechanisms, and security protocols are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "A modular architecture with standardized extension points supports scalable, service-oriented deployment and runtime configuration management for digital twins, enabling adjustments without full redeployment. Specific hosting platforms, computational requirements, storage specifications, and deployment models are not detailed in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability across heterogeneous systems via standardized data schemas and bidirectional communication protocols, with BIM integration enabling unified semantic foundation and automated artifact generation through model-driven engineering principles."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework adheres to Building Information Modeling (BIM) standards as the AECO industry standard. Real-time data integration employs Eclipse Ditto and Hono, which comply with IoT communication protocols like MQTT. Modular architecture includes standardized extension points for interoperability, addressing fragmented deployments by ensuring semantic integration and consistent data schemas."
]