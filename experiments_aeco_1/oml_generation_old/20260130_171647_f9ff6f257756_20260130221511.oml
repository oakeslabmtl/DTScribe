// =============================
//  C3: Physical sensing components
// =============================

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor embedded in the BIM model for real‑time light level measurement."
    DTDFVocab:producedData IlluminationDataStream
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector embedded in the BIM model to sense presence of occupants."
    DTDFVocab:producedData OccupancyDataStream
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the BIM model for ambient temperature monitoring."
    DTDFVocab:producedData TemperatureDataStream
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor embedded in the BIM model for ambient humidity monitoring."
    DTDFVocab:producedData HumidityDataStream
]

instance PostOccupancyEnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy environmental sensor feeding runtime data (e.g., CO₂, VOC) into the twin."
    DTDFVocab:producedData PostOccupancyEnvDataStream
]

// =============================
//  C4: Physical‑to‑virtual interaction (DataTransmitted)
// =============================

instance IlluminationDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance PostOccupancyEnvDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PostOccupancyEnvironmentalSensor
]

// =============================
//  C10: Data (digital twin state)
// =============================

instance IlluminationData : DTDFVocab:Data [
    base:desc "Realtime illumination measurements streamed from the building."
    DTDFVocab:fromData IlluminationDataStream
    DTDFVocab:inputTo EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Realtime occupancy detection events streamed from the building."
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo EclipseDitto
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Realtime ambient temperature values streamed from the building."
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo EclipseDitto
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Realtime ambient humidity values streamed from the building."
    DTDFVocab:fromData HumidityDataStream
    DTDFVocab:inputTo EclipseDitto
]

instance PostOccupancyEnvData : DTDFVocab:Data [
    base:desc "Post‑occupancy environmental readings (e.g., CO₂, VOC) streamed from the building."
    DTDFVocab:fromData PostOccupancyEnvDataStream
    DTDFVocab:inputTo EclipseDitto
]

// =============================
//  C10: Models / Data (knowledge base)
// =============================

instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Static BIM geometry and semantic model extracted from the design model."
    DTDFVocab:inputTo ModelingEngine
]

instance SensorDataStreamModel : DTDFVocab:Model [
    base:desc "Runtime sensor data stream model defining schema for incoming measurement streams."
    DTDFVocab:inputTo ModelingEngine
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Model of building control logic (set‑points, schedules) generated from BIM."
    DTDFVocab:inputTo ModelingEngine
]

instance RLPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning policy model for lighting optimisation."
    DTDFVocab:inputTo ModelingEngine
]

instance UnrealVisualizationModel : DTDFVocab:Model [
    base:desc "3D visual representation model for Unreal Engine 5 interactive visualization."
    DTDFVocab:inputTo UnrealEngine5
]

// =============================
//  C11: Enablers (tools & middleware)
// =============================

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware handling MQTT/CoAP ingestion of sensor streams."
    DTDFVocab:enables RealTimeMonitoringDashboard
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin service storing normalized twin state."
    DTDFVocab:enables BuildingPerformanceSimulation
    DTDFVocab:enables EnergyUsageOptimization
    DTDFVocab:enables RLBasedLightingControl
]

instance ModelingEngine : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering transformation pipeline that enriches BIM with device metadata."
    DTDFVocab:enables FacilityManagerTaskPlanning
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime visualisation platform for 3D interactive dashboards."
    DTDFVocab:enables Interactive3DVisualization
]

// =============================
//  C6: Services
// =============================

instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards displaying live sensor data."
    DTDFVocab:provides OccupancyInsight
    DTDFVocab:provides IlluminationInsight
]

instance BuildingPerformanceSimulation : DTDFVocab:Service [
    base:desc "3D interactive simulation of building performance in Unreal Engine 5."
    DTDFVocab:provides EnergySavingRecommendation
]

instance EnergyUsageOptimization : DTDFVocab:Service [
    base:desc "Energy‑usage optimisation service analysing sensor data and control logic."
    DTDFVocab:provides EnergySavingRecommendation
]

instance RLBasedLightingControl : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based lighting control service automatically adjusting illumination."
    DTDFVocab:provides AutomatedLightingAdjustment
]

instance FacilityManagerTaskPlanning : DTDFVocab:Service [
    base:desc "Facility‑manager task planning tool that leverages insights for maintenance scheduling."
    DTDFVocab:provides MaintenanceTaskSuggestion
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "3D interactive visualization in Unreal Engine 5 for stakeholder exploration."
    DTDFVocab:provides VisualComfortAssessment
]

// =============================
//  C17: Insights & Actions
// =============================

instance OccupancyInsight : DTDFVocab:Insight [
    base:desc "Current occupancy status per zone derived from detector streams."
]

instance IlluminationInsight : DTDFVocab:Insight [
    base:desc "Current illumination levels per space compared against design targets."
]

instance EnergySavingRecommendation : DTDFVocab:Insight [
    base:desc "Actionable energy‑saving recommendations based on real‑time analytics."
]

instance VisualComfortAssessment : DTDFVocab:Insight [
    base:desc "Assessment of visual comfort (glare, uniformity) using sensor data and simulation."
]

instance AutomatedLightingAdjustment : DTDFVocab:Action [
    base:desc "Automatic adjustment of dimmable lighting fixtures based on RL policy."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceTaskSuggestion : DTDFVocab:Action [
    base:desc "Suggested maintenance tasks for HVAC valves, fans, and lighting fixtures."
    DTDFVocab:IsAutomatic false
]

// =============================
//  C2: Acting components (actuators)
// =============================

instance DimmableLightingFixture : DTDFVocab:ActingComponent [
    base:desc "Dimmable lighting fixture modelled in BIM capable of receiving control signals."
]

instance HVACControlValve : DTDFVocab:ActingComponent [
    base:desc "HVAC control valve modelled in BIM for flow regulation."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan actuator modelled in BIM for ventilation control."
]

// =============================
//  C1: System under study (Digital Twin)
// =============================

instance LivingLabDigitalTwin : DTDFVocab:DigitalTwin [
    base:desc "BIM‑based Digital Twin of an academic Living Lab building covering the full life‑cycle."
    base:contains IlluminationSensor, OccupancyDetector, TemperatureSensor, HumiditySensor,
                 PostOccupancyEnvironmentalSensor,
                 DimmableLightingFixture, HVACControlValve, FanActuator,
                 BIMGeometryModel, SensorDataStreamModel, ControlLogicModel,
                 RLPolicyModel, UnrealVisualizationModel,
                 EclipseHono, EclipseDitto, ModelingEngine, UnrealEngine5,
                 RealTimeMonitoringDashboard, BuildingPerformanceSimulation,
                 EnergyUsageOptimization, RLBasedLightingControl,
                 FacilityManagerTaskPlanning, Interactive3DVisualization,
                 OccupancyInsight, IlluminationInsight, EnergySavingRecommendation,
                 VisualComfortAssessment, AutomatedLightingAdjustment,
                 MaintenanceTaskSuggestion
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command propagation from the twin to physical devices through the same Hono/Ditto middleware, allowing the twin to send control set‑points (e.g., lighting dimming levels, HVAC valve positions) back to actuators in near real‑time."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real‑time synchronization with update rates on the order of seconds to sub‑second intervals, enabled by the low‑latency Hono/Ditto data pipeline."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture where the BIM‑derived core twin interacts with middleware (Hono/Ditto) and visualization services; custom DT services can be plugged in via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Supports design (as‑built BIM), construction (integration of devices), commissioning, and operational phases; the twin can be updated during post‑occupancy to reflect as‑operated conditions."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric is applied to quantify how closely the twin reflects its physical counterpart; semantic drift and validation are addressed through continuous synchronization and model updates."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time connectivity is provided by Eclipse Hono (supporting MQTT/CoAP) for ingesting sensor data and by Eclipse Ditto (HTTP/WebSocket) for state management and command dissemination."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adheres to BIM standards for building information, uses open IoT protocols (MQTT, HTTP/WebSocket) via Eclipse Hono/Ditto, and defines standardized extension points to ensure interoperable service integration."
]