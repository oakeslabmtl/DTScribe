// C3: Physical sensing components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor embedded in the building, modeled in BIM, measurements streamed via Eclipse Hono."
    DTDFVocab:producedData LightingSensorDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the building, modeled in BIM, measurements streamed via Eclipse Hono."
    DTDFVocab:producedData OccupancySensorDataTransmitted
]

instance EnergyMeter : DTDFVocab:SensingComponent [
    base:desc "Energy meter sensor embedded in the building, modeled in BIM, measurements streamed via Eclipse Hono."
    DTDFVocab:producedData EnergyMeterDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LightingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance OccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyMeterDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeter
]

// C10: Data objects
instance LightingSensorData : DTDFVocab:Data [
    base:desc "Streaming lighting level measurements from the physical building."
    DTDFVocab:fromData LightingSensorDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance OccupancySensorData : DTDFVocab:Data [
    base:desc "Streaming occupancy detection events from the physical building."
    DTDFVocab:fromData OccupancySensorDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance EnergyMeterData : DTDFVocab:Data [
    base:desc "Streaming energy consumption measurements from the physical building."
    DTDFVocab:fromData EnergyMeterDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

// C2: Acting components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator addressed via Hono/Ditto to receive control commands."
]

instance BuildingControlSystemActuator : DTDFVocab:ActingComponent [
    base:desc "General BCS actuator (e.g., HVAC valve) addressed via Hono/Ditto."
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono messaging middleware handling bidirectional MQTT/AMQP streams from sensors and actuators."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, OptimizationService, AdaptiveLightingService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin platform ingesting data from Hono and maintaining the virtual representation."
    DTDFVocab:enables SimulationService, ImmersiveVisualizationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 provides immersive 3‑D visualization of the building twin."
    DTDFVocab:enables ImmersiveVisualizationService
]

instance BOREALIS : DTDFVocab:Enabler [
    base:desc "BOREALIS reinforcement‑learning engine for adaptive lighting control."
    DTDFVocab:enables AdaptiveLightingService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of sensor streams and twin state."
    DTDFVocab:provides EnergyConsumptionInsight, LightingComfortInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics on historical and streaming data for forecasting energy usage."
    DTDFVocab:provides EnergyConsumptionInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization of building operation parameters based on model predictions."
    DTDFVocab:provides AdaptiveLightingControlAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building scenarios using BIM and control‑logic models."
    DTDFVocab:provides FacilityManagerInterventionAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3‑D visualization of the twin in Unreal Engine 5."
    DTDFVocab:provides LightingComfortInsight
]

instance AdaptiveLightingService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based adaptive lighting control (BOREALIS)."
    DTDFVocab:provides AdaptiveLightingControlAction
]

// C17: Insights
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight on building energy consumption derived from sensor data."
]

instance LightingComfortInsight : DTDFVocab:Insight [
    base:desc "Insight on lighting comfort levels based on lighting and occupancy sensor data."
]

// C17: Actions
instance AdaptiveLightingControlAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting actuators to maintain comfort while minimizing energy."
    DTDFVocab:IsAutomatic true
]

instance FacilityManagerInterventionAction : DTDFVocab:Action [
    base:desc "Suggested interventions for facility managers based on simulation outcomes."
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance BIMStaticModel : DTDFVocab:Model [
    base:desc "Static BIM model of the building enriched with device metadata."
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

instance DeviceMetadataModel : DTDFVocab:Model [
    base:desc "Extracted device metadata from BIM used to configure Hono and Ditto."
    DTDFVocab:inputTo EclipseDitto
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control‑logic models governing building operation."
    DTDFVocab:inputTo EclipseDitto, BOREALIS
]

instance RLPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning policies for adaptive lighting (BOREALIS)."
    DTDFVocab:inputTo BOREALIS
]

// Environment aggregating sub‑twins
instance BuildingTwinEnvironment : DTDFVocab:Environment [
    base:contains LightingSensor, OccupancySensor, EnergyMeter, LightingActuator, BuildingControlSystemActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command propagation from the twin to the physical building through Eclipse Ditto to Eclipse Hono, delivering control signals (e.g., lighting set‑points) to actuators defined in the BIM model."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (continuous) synchronization between physical sensors and the twin; no explicit sampling rate is given, but the framework is described as supporting live data exchange."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture where a central DT Framework mediates between enriched BIM, middleware (Hono/Ditto), and the 3‑D visual front‑end; roles (building control engineer, facility manager, DT engineer) interact with the constellation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the full building lifecycle: design (BIM model creation), construction (model validation and deployment), and operation (runtime monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to assess how closely the twin reflects its physical counterpart, providing a quantitative fidelity evaluation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time connectivity is realised through Eclipse Hono (IoT messaging) linked to Eclipse Ditto; the exact transport protocols are not specified in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployed as a modular platform integrating the DT Framework, Hono, Ditto and Unreal Engine; hosting details (cloud/on‑premise) are not described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized extension points allow integration of additional services and external systems, but specific external integrations are not detailed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework builds on BIM as a standardized architectural modelling standard and employs standardized extension points; however, specific standards (e.g., IFC, ISO 19650) are not mentioned."
]