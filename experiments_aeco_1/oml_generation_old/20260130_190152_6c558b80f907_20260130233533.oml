// C3: Physical sensing components
instance BuildingTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Physical temperature sensor installed in the building, measuring ambient temperature."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance BuildingHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Physical humidity sensor installed in the building, measuring relative humidity."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Physical energy consumption sensor measuring electricity usage of building systems."
    DTDFVocab:producedData EnergyDataTransmitted
]

// C4: Physical-to-virtual interaction – Data transmitted
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingTemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingHumiditySensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature readings synchronized to the digital twin."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoTwinState
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Live humidity readings synchronized to the digital twin."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoTwinState
]

instance EnergyData : DTDFVocab:Data [
    base:desc "Live energy consumption values synchronized to the digital twin."
    DTDFVocab:fromData EnergyDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoTwinState
]

// C11: Enablers
instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono acts as a gateway ingesting real‑time sensor data from the building and forwarding it to the twin."
    DTDFVocab:enables RealTimeDecisionSupportService
]

instance EclipseDittoTwinState : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto maintains the digital twin state, receiving updated BIM‑linked attributes."
    DTDFVocab:enables RealTimeDecisionSupportService
]

// C6: Services
instance RealTimeDecisionSupportService : DTDFVocab:Service [
    base:desc "Aggregates live sensor data, runs analytics plug‑ins and provides decision support via visualisation and actionable recommendations."
    DTDFVocab:provides EnergyUsageTrendInsight, FaultDetectionAlertInsight, ControlActionRecommendation
]

// C17: Insights
instance EnergyUsageTrendInsight : DTDFVocab:Insight [
    base:desc "Shows energy‑usage trends derived from live energy data and analytics plug‑ins."
]

instance FaultDetectionAlertInsight : DTDFVocab:Insight [
    base:desc "Generates fault detection alerts based on anomalies in temperature and humidity streams."
]

// C17: Action
instance ControlActionRecommendation : DTDFVocab:Action [
    base:desc "Recommended control actions (e.g., HVAC set‑point adjustments) presented to Facility Managers."
    DTDFVocab:IsAutomatic false
]

// C10: Models/Data
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Geometric BIM model enriched with semantic definitions of sensors, actuators and controllers."
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoTwinState
]

instance ControlBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model describing control strategies encoded directly in BIM."
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoTwinState
]

instance AnalyticsPlugInModel : DTDFVocab:Model [
    base:desc "Analytical model representing plug‑ins such as performance dashboards or optimisation algorithms."
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoTwinState
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Through the central DT Framework hub, Facility Managers can issue control commands from the digital twin back to the physical building control system. The framework supports bidirectional data exchange, allowing the DT to transmit operational directives (e.g., HVAC set‑points, lighting control) to the building infrastructure. Validation, authentication and feedback mechanisms are mentioned only in general terms as part of the framework’s runtime configuration management, without concrete technical specifications."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports a complete Digital Twin lifecycle that starts with device modeling inside the BIM environment, where Building Control Engineers define sensors, actuators and controllers. The enriched BIM model is then processed by Model‑Driven Engineering (MDE) transformations to extract a structured representation and automatically generate deployable DT artefacts. These artefacts are deployed to the runtime environment, establishing real‑time data exchange that continuously synchronises the physical building and its digital counterpart. During operation the twin offers interactive visualisation for monitoring and control. Evolution is handled by adding custom services or plugins (via the DT Engineer role) and re‑generating artefacts as needed, thus moving the twin from a static deployment to an extensible, operational state."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution builds on Building Information Modelling (BIM), the de‑facto industry standard for construction data exchange, and extends it with a unified semantic layer for control components. The framework’s architecture defines standardized extension points (e.g., plug‑in APIs) to ensure interoperability of custom services. While specific standards such as IFC or ISO 19650 are not named, the reliance on BIM and the use of standardized APIs imply compliance with established construction and software integration standards, facilitating exchange with other BIM‑based tools and third‑party analytics platforms."
]