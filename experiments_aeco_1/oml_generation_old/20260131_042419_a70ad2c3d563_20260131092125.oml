// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor integrated into BIM, telemetry collected by the building's BMS and forwarded to the DT"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy (presence) sensor integrated into BIM, telemetry collected by the building's BMS and forwarded to the DT"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor integrated into BIM, telemetry collected by the building's BMS and forwarded to the DT"
    DTDFVocab:producedData IlluminationDataTransmitted
]

// C4: Physical-to-Virtual Interaction (DataTransmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

// C10 & C6: Data, Models and Enablers
instance TemperatureSensorData : DTDFVocab:Data [
    base:desc "Live temperature sensor data persisted in Ditto and a time-series database"
    DTDFVocab:inputTo DittoEnabler
    DTDFVocab:fromData TemperatureDataTransmitted
]

instance OccupancySensorData : DTDFVocab:Data [
    base:desc "Live occupancy sensor data persisted in Ditto and a time-series database"
    DTDFVocab:inputTo DittoEnabler
    DTDFVocab:fromData OccupancyDataTransmitted
]

instance IlluminationSensorData : DTDFVocab:Data [
    base:desc "Live illumination sensor data persisted in Ditto and a time-series database"
    DTDFVocab:inputTo DittoEnabler
    DTDFVocab:fromData IlluminationDataTransmitted
]

instance IFCBIMModel : DTDFVocab:Model [
    base:desc "IFC-based BIM model enriched with device semantic annotations"
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]

instance RuntimeConfigurationModel : DTDFVocab:Model [
    base:desc "Model-derived runtime configuration generated by MDE transformations"
    DTDFVocab:inputTo MDEToolKitEnabler, DittoEnabler
]

// C11: Enablers
instance HonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for secure MQTT communication"
    DTDFVocab:enables EnergyEfficiencySimulationService, RealTimeMonitoringDashboardService, PredictiveAnalyticsService
]

instance DittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for device registry and entity management"
    DTDFVocab:enables EnergyEfficiencySimulationService, RealTimeMonitoringDashboardService, Interactive3DVisualizationService, PredictiveAnalyticsService, TaskPlanningService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3‑D visualization"
    DTDFVocab:enables Interactive3DVisualizationService
]

instance MDEToolKitEnabler : DTDFVocab:Enabler [
    base:desc "MDE tooling for model‑to‑model and model‑to‑text transformations"
    DTDFVocab:enables EnergyEfficiencySimulationService
]

instance RevitEnabler : DTDFVocab:Enabler [
    base:desc "Revit for BIM authoring and data extraction"
    DTDFVocab:enables EnergyEfficiencySimulationService
]

// C6: Digital Twin Services
instance EnergyEfficiencySimulationService : DTDFVocab:Service [
    base:desc "Simulation and optimization service for energy‑efficiency scenario analysis"
    DTDFVocab:provides EnergyConsumptionHotspotInsight
]

instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards for facility operators"
    DTDFVocab:provides OptimalLightingScheduleInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3‑D visualization via Unreal Engine 5"
    DTDFVocab:provides VisualizationInteractionInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics using reinforcement‑learning‑driven control policy generation"
    DTDFVocab:provides PredictiveMaintenanceAlertInsight, ControlPolicyAdjustmentInsight
]

instance TaskPlanningService : DTDFVocab:Service [
    base:desc "Task planning utilities for facility management"
    DTDFVocab:provides TaskPlanningInsight
]

// C17: Insights
instance EnergyConsumptionHotspotInsight : DTDFVocab:Insight [
    base:desc "Insight identifying energy consumption hotspots surfaced by the DT"
]

instance OptimalLightingScheduleInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal lighting schedules derived from sensor data"
]

instance VisualizationInteractionInsight : DTDFVocab:Insight [
    base:desc "Insight logging user interaction events within the immersive 3‑D visualization"
]

instance PredictiveMaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Insight alerting on predicted maintenance conditions for building equipment"
]

instance ControlPolicyAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Insight informing evidence‑based adjustments to control policies"
]

instance TaskPlanningInsight : DTDFVocab:Insight [
    base:desc "Insight into optimal task scheduling for facility maintenance operations"
]

// C3: Physical Acting Components
instance SmartLightingFixture : DTDFVocab:ActingComponent [
    base:desc "Smart lighting fixture modeled in BIM, supporting bidirectional communication via Hono and Ditto"
]

instance HVACDamperValve : DTDFVocab:ActingComponent [
    base:desc "HVAC damper valve modeled in BIM, controlling airflow and integrated into the DT"
]

instance HVACFanDrive : DTDFVocab:ActingComponent [
    base:desc "HVAC fan drive modeled in BIM, handling fan speed control through the DT"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., light dimming, HVAC set‑point adjustment) are published via Eclipse Hono and delivered to the building’s actuators via Ditto’s device service interfaces, enabling live actuation of the physical premises."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Bidirectional communication is performed in real time with sub‑second latency underpinning the synchronization cycle; simulation responses are rendered at millisecond to second granularity, while long‑term policy updates occur on a minute‑scale."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A service‑oriented constellation comprising the BIM‐based modeling engine, the Hono middleware layer, the Ditto runtime registry, a reinforcement learning controller (BOREALIS), and the Unreal visualizer, all orchestrated through a Docker‑based deployment stack."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the design (ideal BIM model), the construction/manufacture (as‑built IFC with device metadata), and the operation stage (runtime state, telemetry, and control), enabling continuous lifecycle adaptation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is assessed using the Overall Digital Twin Entanglement (ODTE) metric applied to the ITS‑BIM mapping; validation involves schema validation of IFC elements, consistency checks of device metadata, and statistical uncertainty quantification of sensor noise."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication is performed using MQTT over TCP/IP, secured with TLS, with Hono acting as a bridge to the Ditto entity data store; HTTP/REST endpoints are exposed for management and configuration."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External integration is achieved via Hono’s protocol adapters, allowing the DT to expose data to larger building management systems, facility management software, and potentially other DTs for cross‑building analytics."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adheres to IFC4 BIM standards for geometric and semantic data, MQTT and TLS for secure messaging, and Eclipse Ditto’s REST and WebSocket interfaces for device interaction; model transformation follows MDE best practices."
]