// C3: Physical sensing components  
instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient temperature sensor located in living lab rooms, providing temperature measurements."
    DTDFVocab:producedData AmbientTemperatureDataTransmitted
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Light level sensor measuring illuminance across occupied zones."
    DTDFVocab:producedData IlluminanceDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor monitoring air‑quality levels for comfort analysis."
    DTDFVocab:producedData CO2DataTransmitted
]

instance OccupancyPresenceSensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor detecting presence of occupants in rooms."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical‑to‑virtual interaction – Data transmitted  
instance AmbientTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

instance IlluminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyPresenceSensor
]

// C10: Models/Data – Data objects  
instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Stream of ambient temperature values received from the ambient temperature sensor."
    DTDFVocab:inputTo EclipseHonoDittoGateway
    DTDFVocab:fromData AmbientTemperatureDataTransmitted
]

instance IlluminanceData : DTDFVocab:Data [
    base:desc "Illuminance values collected from the light level sensor."
    DTDFVocab:inputTo EclipseHonoDittoGateway
    DTDFVocab:fromData IlluminanceDataTransmitted
]

instance CO2Data : DTDFVocab:Data [
    base:desc "CO₂ concentration data from the air‑quality sensor."
    DTDFVocab:inputTo EclipseHonoDittoGateway
    DTDFVocab:fromData CO2DataTransmitted
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy detection data from the presence sensor."
    DTDFVocab:inputTo EclipseHonoDittoGateway
    DTDFVocab:fromData OccupancyDataTransmitted
]

// C11: Enablers – Hono / Ditto gateway  
instance EclipseHonoDittoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono IoT gateway for routing MQTT messages and Eclipse Ditto registry for twin state management."
    DTDFVocab:enables RealTimeMonitoringService, LiveSimulationService, PredictiveAnalyticsService, LightingOptimizationRLService, ImmersiveVisualizationService
]

// C6: Services  
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building performance via live sensor data streams."
    DTDFVocab:provides EnergyConsumptionPredictionInsight, ComfortLevelPredictionInsight
]

instance LiveSimulationService : DTDFVocab:Service [
    base:desc "Live simulation of building performance, integrating BIM models with real‑time sensor data."
    DTDFVocab:provides EnergyConsumptionPredictionInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy consumption and occupant comfort using machine learning on sensor data."
    DTDFVocab:provides EnergyConsumptionPredictionInsight
]

instance LightingOptimizationRLService : DTDFVocab:Service [
    base:desc "Lighting optimization driven by reinforcement learning, adjusting schedules for energy efficiency and comfort."
    DTDFVocab:provides LightingScheduleAdjustmentAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization of building performance in Unreal Engine 5."
    DTDFVocab:provides ComfortLevelPredictionInsight
]

// C17: Insights / Actions  
instance EnergyConsumptionPredictionInsight : DTDFVocab:Insight [
    base:desc "Prediction of future energy consumption based on predictive analytics of real‑time temperature, occupancy, and lighting data."
]

instance ComfortLevelPredictionInsight : DTDFVocab:Insight [
    base:desc "Estimation of visual comfort levels using illuminance and occupancy data."
]

instance LightingScheduleAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated adjustment of lighting schedules via reinforcement learning."
    DTDFVocab:IsAutomatic true
]

// C13: Physical device twins (aggregated under orchestrator)  
instance AmbientTemperatureSensorTwin : DTDFVocab:Component [
    base:desc "Digital twin representation of the ambient temperature sensor, aggregated under building orchestrator."
]

instance IlluminanceSensorTwin : DTDFVocab:Component [
    base:desc "Digital twin representation of the illuminance sensor, aggregated under building orchestrator."
]

instance CO2SensorTwin : DTDFVocab:Component [
    base:desc "Digital twin representation of the CO₂ sensor, aggregated under building orchestrator."
]

instance OccupancyPresenceSensorTwin : DTDFVocab:Component [
    base:desc "Digital twin representation of the occupancy sensor, aggregated under building orchestrator."
]

// C15: Physical building component  
instance LivingLabBuilding : DTDFVocab:Component [
    base:desc "BIM‑modeled building encompassing architectural, structural, mechanical and electrical components."
]

// C14: Environment – orchestrator aggregating all twins  
instance LivingLabDigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains LivingLabBuilding, AmbientTemperatureSensorTwin, IlluminanceSensorTwin, CO2SensorTwin, OccupancyPresenceSensorTwin
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin are written to Ditto Things and routed by Hono over MQTT/TLS to the building’s controllers, enabling actuators to adjust lighting and other parameters."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time synchronization; sensor data and control messages are streamed instantly as event payloads, enabling live interaction between physical and virtual models."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture where individual device twins exchange information via Hono/Ditto under a central DT orchestrator, enabling extensibility and scalability."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (BIM creation), construction (model validation), commissioning (integration of IoT devices), and operation (runtime execution and iterative optimization). The DT spans the full life‑cycle of the building, from model to operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Evaluation with the Overall Digital Twin Entanglement (ODTE) metric to quantify the closeness of the digital twin to its physical counterpart; verification of sensor data integrity and semantic consistency is performed during model validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time communication implemented through the Eclipse Hono broker and Ditto twin registry, enabling bidirectional data exchange between the physical assets and the virtual twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of BIM as the semantically rich standard for building information, and adherence to standardized integration frameworks for DT deployment."
]