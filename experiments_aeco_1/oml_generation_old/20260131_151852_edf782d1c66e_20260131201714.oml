instance EclipseHonoPlatform : DTDFVocab:Enabler [
    base:desc "Open-source platform for IoT connectivity enabling live event-based data exchange between physical assets and DTs via standardized messaging protocols (MQTT, WebSockets)"
    DTDFVocab:enables RealTimeDataExchangeService, ProtocolStandardizationService
]

instance DittoEngine : DTDFVocab:Enabler [
    base:desc "Lightweight real-time synchronization engine for DTs supporting bidirectional data flows and state reconciliation between physical and digital twins"
    DTDFVocab:enables BidirectionalSynchronizationService, StateReconciliationService
]

instance AutomatedDeploymentPipeline : DTDFVocab:Enabler [
    base:desc "Leverages scripted workflows (CI/CD pipelines) to automate BIM-to-DT mapping, environment provisioning, and service deployment"
    DTDFVocab:enables DeploymentAutomationService, VersionControlledDeploymentService
]

instance ReproducibleSetups : DTDFVocab:Enabler [
    base:desc "Enables reproducible setups via artifact repositories (Git, Docker registries) and infrastructure-as-code (IaC) tools (Terraform)"
    DTDFVocab:enables InfrastructureReplicationService, CodeVersioningService
]

instance ServiceOrientedDesign : DTDFVocab:Enabler [
    base:desc "Uses REST/gRPC APIs for inter-service communication enabling scalable microservices in AECO DTs"
    DTDFVocab:enables ServiceCommunicationService, MicroservicesIntegrationService
]

instance DomainSpecificModels : DTDFVocab:Enabler [
    base:desc "Integrates with BIM standards (IFC, COBie) via ontology mapping tools (OWL, RDFS) for semantic interoperability"
    DTDFVocab:enables OntologyMappingService, SemanticInteroperabilityService
]

instance SimulationEngines : DTDFVocab:Enabler [
    base:desc "Supports physics-based simulations (EnergyPlus, ETABS) via plug-in modules for energy modeling and structural analysis"
    DTDFVocab:enables PhysicsSimulationService, AnalyticalModelingService
]

