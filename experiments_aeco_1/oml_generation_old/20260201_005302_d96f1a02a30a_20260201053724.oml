// Sensing Components
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor modeling brightness levels as defined in the enriched BIM."
    DTDFVocab:producedData IlluminationMeasurement
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor detecting presence/movement, embedded in BIM."
    DTDFVocab:producedData OccupancyMeasurement
]

// Data Transmitted
instance IlluminationMeasurement : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance OccupancyMeasurement : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// Data
instance IlluminationReadingData : DTDFVocab:Data [
    base:desc "Real‑time illumination data transmitted from the IlluminationSensor."
    DTDFVocab:fromData IlluminationMeasurement
    DTDFVocab:inputTo DittoConnectionEnabler
]

instance OccupancyReadingData : DTDFVocab:Data [
    base:desc "Real‑time occupancy data transmitted from the OccupancySensor."
    DTDFVocab:fromData OccupancyMeasurement
    DTDFVocab:inputTo DittoConnectionEnabler
]

// Enablers
instance DittoConnectionEnabler : DTDFVocab:Enabler [
    base:desc "DittoConnection mediates data between Eclipse Hono and Ditto."
    DTDFVocab:enables MonitoringService, ControlService, VisualizationService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Service for real‑time monitoring of sensor streams and anomaly detection."
    DTDFVocab:provides AnomalyDetectionInsight, EnergyEfficiencyInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Service providing automated control of dimming actuators via validated commands."
    DTDFVocab:provides DimLightAction, OccupancyControlAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service furnishing immersive dashboards that display live sensor and actuator states."
    DTDFVocab:provides VisualizationInsight
]

// Insights
instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight that flags abnormal illumination or occupancy patterns detected during monitoring."
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time recommendations for energy savings based on sensor data."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight that reflects the current building state in the interactive Unreal Engine visualizer."
]

// Actions
instance DimLightAction : DTDFVocab:Action [
    base:desc "Action to adjust dimming actuator settings in response to controller logic."
    DTDFVocab:IsAutomatic false
]

instance OccupancyControlAction : DTDFVocab:Action [
    base:desc "Action to activate occupancy‑based lighting control."
    DTDFVocab:IsAutomatic false
]

// Acting Components
instance DimmingActuator : DTDFVocab:ActingComponent [
    base:desc "Dimming actuator translating Ditto commands into voltage adjustments for lighting fixtures."
]

instance LocalControlUnit : DTDFVocab:ActingComponent [
    base:desc "Local control unit managing actuator behavior and enforcing policy constraints."
]

// Additional Components and Environment
instance TwinLightBuilding : DTDFVocab:Component [
    base:desc "BIM-enriched building model containing lighting fixtures, sensors, actuators, and controllers."
]

instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains TwinLightBuilding
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Facility managers use the system to issue control commands from digital twins to actual building equipment. Command types and message formats are not specified, and the documents lack details on validation, authentication, or feedback mechanisms. The framework is said to provide real‑time monitoring and control, but specific flow and conflict resolution details are absent."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system adopts a modular, service‑oriented architecture where a central Digital Twin Framework hub orchestrates bidirectional data exchange between enriched BIM models and the physical building’s sensor fleet, while exposing standardized extension points for custom analytics and service integration. Runtime configuration management allows the framework to adapt to evolving operational needs without full redeployment, providing dynamic orchestration and resource management across the Digital Twin lifecycle."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Phases: 1) Initial device modeling directly within BIM, defining sensors, actuators, and controller logic; 2) Transformation via Model‑Driven Engineering (MDE) principles to extract structured representations; 3) Automatic generation of deployable DT artifacts with minimal manual intervention; 4) Real‑time bidirectional data exchange ensuring continuous synchronization; 5) Interactive visualization and monitoring; 6) Extension of functionality through custom services via standardized extension points. Transitions are managed through automated artifact extraction and deployment pipelines, with governance enforced by verification against the enriched BIM baseline."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is preserved by validating enriched BIM models against a set of structural and semantic rules during the validation step of the conversion pipeline. Eclipse Ditto’s policy engine performs continuous verification of incoming sensor data and actuator commands, ensuring that all values respect predefined bounds and units. Fault tolerance is achieved through Eclipse Hono’s at‑least‑once message delivery guarantee and Ditto’s persistent event storage, providing resilience against network interruptions. Error detection is handled by policy violations that trigger alerts or message rejections, while error correction is achieved by either resetting the device state or reverting to the last stable state stored in Ditto. Quality assurance of the DT system is supported by the modular architecture, which enables adding custom analytics services to monitor fidelity metrics and enforce consistency between the physical assets and their digital twins.}"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The documents mention interoperability across heterogeneous systems and a modular architecture with standardized extension points. They do not provide concrete network protocols (e.g., MQTT, REST), topology, bandwidth, latency, reliability or security specifics for the Digital Twin network. Hence these details are not provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment infrastructure is broadly described: the DT Framework acts as a central hub facilitating bidirectional data exchange. The documents do not specify whether the deployment is on‑premise, edge or cloud, nor do they state computational, storage requirements, scalability or availability mechanisms. Therefore such details are not available."
]