// C3: Physical sensing components
instance LightSensorLivingLab : DTDFVocab:SensingComponent [
    base:desc "Light sensors embedded in the Living Lab academic building for continuous illumination measurement"
    DTDFVocab:producedData LightSensorStream
]

instance OccupancyDetectorLivingLab : DTDFVocab:SensingComponent [
    base:desc "Occupancy detectors installed in rooms of the Living Lab building to capture presence of occupants"
    DTDFVocab:producedData OccupancyDetectorStream
]

instance EnergyMeterLivingLab : DTDFVocab:SensingComponent [
    base:desc "Electrical energy meters measuring real-time power consumption of the Living Lab facilities"
    DTDFVocab:producedData EnergyMeterStream
]

instance EnvironmentalSensorLivingLab : DTDFVocab:SensingComponent [
    base:desc "Environmental sensors (temperature, humidity, CO₂) providing ambient condition data in the Living Lab"
    DTDFVocab:producedData EnvironmentalSensorStream
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance LightSensorStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensorLivingLab
]

instance OccupancyDetectorStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetectorLivingLab
]

instance EnergyMeterStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeterLivingLab
]

instance EnvironmentalSensorStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensorLivingLab
]

// C10: Data objects
instance LightMeasurementData : DTDFVocab:Data [
    base:desc "Timestamped illuminance values streamed from LightSensorLivingLab"
    DTDFVocab:fromData LightSensorStream
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Binary occupancy status updates from OccupancyDetectorLivingLab"
    DTDFVocab:fromData OccupancyDetectorStream
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "Real‑time power usage readings delivered by EnergyMeterLivingLab"
    DTDFVocab:fromData EnergyMeterStream
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Temperature, humidity and CO₂ measurements from EnvironmentalSensorLivingLab"
    DTDFVocab:fromData EnvironmentalSensorStream
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// C10: Model instances
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Enriched BIM geometry, topology and spatial relationships of the Living Lab building"
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance RuntimeSemanticsModel : DTDFVocab:Model [
    base:desc "Runtime semantics containing sensor configuration and control logic stored in Eclipse Ditto"
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance EnergyForecastModel : DTDFVocab:Model [
    base:desc "Predictive model for building energy consumption used by predictive analytics"
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance LightingOptimizationModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning model that generates adaptive lighting set‑points"
    DTDFVocab:inputTo MDEPipelineEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono service ingesting sensor streams over MQTT/HTTPS"
    DTDFVocab:enables DataIngestionService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital‑thing platform managing twin state and metadata"
    DTDFVocab:enables DigitalTwinManagementService
]

instance BIMAuthoringEnabler : DTDFVocab:Enabler [
    base:desc "BIM authoring tools (e.g., Revit, IFC) used for creating the base building model"
    DTDFVocab:enables BIMModelManagementService
]

instance MDEPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline that validates, transforms and deploys BIM and runtime models"
    DTDFVocab:enables ModelDeploymentService, PredictiveAnalyticsService, EnergyOptimizationControlService, SimulationAnalysisService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime providing immersive 3D visualization of the digital twin"
    DTDFVocab:enables Interactive3DVisualizationService
]

instance EnergyOptimizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Engine executing energy‑optimization and reinforcement‑learning algorithms for lighting control"
    DTDFVocab:enables EnergyOptimizationControlService
]

// C6: Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service that receives streamed sensor data from Eclipse Hono and forwards it to the twin"
    DTDFVocab:provides VisualDiagnosticInsight
]

instance DigitalTwinManagementService : DTDFVocab:Service [
    base:desc "Service that stores and updates twin state in Eclipse Ditto"
    DTDFVocab:provides VisualDiagnosticInsight
]

instance BIMModelManagementService : DTDFVocab:Service [
    base:desc "Service handling versioned BIM models and exposing them to downstream tools"
    DTDFVocab:provides VisualDiagnosticInsight
]

instance ModelDeploymentService : DTDFVocab:Service [
    base:desc "Service that deploys validated BIM and runtime semantics into the digital twin environment"
    DTDFVocab:provides VisualDiagnosticInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time 3D interactive visualization of the building twin in Unreal Engine 5"
    DTDFVocab:provides VisualDiagnosticInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics providing energy consumption forecasts and anomaly detection"
    DTDFVocab:provides EnergyConsumptionForecastInsight
]

instance EnergyOptimizationControlService : DTDFVocab:Service [
    base:desc "Energy‑optimization and adaptive lighting control using reinforcement learning"
    DTDFVocab:provides LightingOptimizationRecommendationInsight, AdaptiveLightingSetpointAction
]

instance SimulationAnalysisService : DTDFVocab:Service [
    base:desc "Simulation capabilities for design‑time analysis of building performance"
    DTDFVocab:provides SimulationRunAction
]

// C17: Insights
instance LightingOptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendations such as optimal lighting set‑points for energy savings"
]

instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasts of future building energy consumption based on current sensor data"
]

instance VisualDiagnosticInsight : DTDFVocab:Insight [
    base:desc "Visual diagnostics displayed in dashboards and 3D view to aid facility‑manager decisions"
]

// C17: Actions
instance AdaptiveLightingSetpointAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting control units to recommended set‑points"
    DTDFVocab:IsAutomatic true
]

instance SimulationRunAction : DTDFVocab:Action [
    base:desc "Trigger execution of a building performance simulation scenario"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance LightingControlUnit : DTDFVocab:ActingComponent [
    base:desc "Lighting control units modeled in BIM that receive set‑point commands from the digital twin"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator devices represented in the BIM model and controlled via the twin"
]

instance BCSControlDevice : DTDFVocab:ActingComponent [
    base:desc "General building control system components that act on commands issued by the DT"
]

// C17: Environment & Twins (Multiplicity)
instance BuildingTwinLivingLab : DTDFVocab:Component [
    base:desc "Digital twin representing the whole Living Lab academic building, aggregating device‑level twins"
    base:contains LightSensorTwin, OccupancyDetectorTwin, EnergyMeterTwin, EnvironmentalSensorTwin, LightingControlUnitTwin, HVACActuatorTwin
]

instance LightSensorTwin : DTDFVocab:Component [
    base:desc "Device‑level twin for a single LightSensorLivingLab instance"
]

instance OccupancyDetectorTwin : DTDFVocab:Component [
    base:desc "Device‑level twin for a single OccupancyDetectorLivingLab instance"
]

instance EnergyMeterTwin : DTDFVocab:Component [
    base:desc "Device‑level twin for a single EnergyMeterLivingLab instance"
]

instance EnvironmentalSensorTwin : DTDFVocab:Component [
    base:desc "Device‑level twin for a single EnvironmentalSensorLivingLab instance"
]

instance LightingControlUnitTwin : DTDFVocab:Component [
    base:desc "Device‑level twin for a LightingControlUnit acting component"
]

instance HVACActuatorTwin : DTDFVocab:Component [
    base:desc "Device‑level twin for an HVACActuator acting component"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command flow from the DT to physical devices through Eclipse Ditto, which forwards control commands (e.g., lighting set-points, HVAC adjustments) to the actuators via the Hono middleware."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real-time operation with continuous data exchange; the twin processes incoming sensor streams and issues control commands on a sub-second to second timescale."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An integrated stack where the enriched BIM model feeds a configurator that generates Hono/Ditto artifacts; Hono ingests sensor data, Ditto maintains the twin state, and Unreal Engine visualizes the state; custom services plug into defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the full building lifecycle: design (BIM model creation), construction (model enrichment with device metadata), commissioning, operation (real-time monitoring and control), and post-occupancy optimization."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is applied to quantify how closely the twin reflects the physical building, providing a systematic fidelity assessment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Uses Eclipse Hono’s MQTT (and optionally HTTPS) transport to collect sensor data, and Ditto’s REST/WS APIs for twin state access and command issuance; all components communicate over standard IP networks."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Leverages BIM as a standardized data backbone (e.g., IFC-compatible semantics) and adopts open, standards-based middleware (Eclipse Hono, Eclipse Ditto) with defined extension points to ensure interoperability."
]