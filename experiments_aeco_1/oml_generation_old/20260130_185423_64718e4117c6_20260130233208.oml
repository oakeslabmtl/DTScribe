// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled as a first‑class entity within the enriched BIM, measures zone temperature."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor modeled as a first‑class entity within the enriched BIM, measures zone relative humidity."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled as a first‑class entity within the enriched BIM, detects presence of occupants."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Energy consumption sensor modeled as a first‑class entity within the enriched BIM, records real‑time energy use."
    DTDFVocab:producedData EnergyDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

// C10: Data objects
instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature measurements streamed from TemperatureSensor."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoPlatform
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Live humidity measurements streamed from HumiditySensor."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoPlatform
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy status streamed from OccupancySensor."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoPlatform
]

instance EnergyData : DTDFVocab:Data [
    base:desc "Live energy consumption readings streamed from EnergyConsumptionSensor."
    DTDFVocab:fromData EnergyDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoPlatform
]

// C10: Model objects
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Static geometric building model captured in BIM and synchronized with the Digital Twin."
    DTDFVocab:inputTo EclipseDittoPlatform, UnrealEngine5Visualization
]

instance SemanticEnrichmentModel : DTDFVocab:Model [
    base:desc "Semantic layer enriching BIM with definitions of sensors, actuators and controllers."
    DTDFVocab:inputTo EclipseDittoPlatform
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Automatically generated control logic for actuators, derived from the enriched BIM model."
    DTDFVocab:inputTo EclipseDittoPlatform
]

// C2: Acting components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator entity representing HVAC equipment, linked to controller logic in the BIM environment."
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator entity representing lighting fixtures, linked to controller logic in the BIM environment."
]

// C11: Enablers
instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono IoT gateway for secure, scalable ingestion of MQTT/HTTP sensor data."
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoPlatform : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto core Digital Twin platform storing the unified semantic model and exposing remote service endpoints."
    DTDFVocab:enables RealTimeMonitoringService,
                     Interactive3DVisualizationService,
                     WhatIfSimulationService,
                     EnergyOptimizationService,
                     PredictiveMaintenanceService,
                     ActuatorControlService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 provides high‑fidelity, immersive 3D visualization of the building state."
    DTDFVocab:enables Interactive3DVisualizationService,
                     WhatIfSimulationService
]

instance CloudPersistenceService : DTDFVocab:Enabler [
    base:desc "Cloud‑based persistence layer for historical sensor data and model snapshots."
    DTDFVocab:enables EnergyOptimizationService,
                     PredictiveMaintenanceService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of all sensor streams, presenting current building conditions."
    DTDFVocab:provides OperationalInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization of the building state via Unreal Engine 5."
    DTDFVocab:provides VisualizationInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Simulation of ‘what‑if’ scenarios to evaluate design or operational changes."
    DTDFVocab:provides ScenarioInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Life‑cycle‑wide optimization of energy use and occupant comfort."
    DTDFVocab:provides EnergyOptimizationInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive analytics for maintenance based on continuous sensor data."
    DTDFVocab:provides MaintenancePredictionInsight
]

instance ActuatorControlService : DTDFVocab:Service [
    base:desc "Limited control loops exposing remote endpoints to command physical actuators."
    DTDFVocab:provides ControlCommandAction
]

// C17: Insights
instance OperationalInsight : DTDFVocab:Insight [
    base:desc "Insight into current temperature, humidity, occupancy and energy consumption."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from immersive 3D visualization of building performance."
]

instance ScenarioInsight : DTDFVocab:Insight [
    base:desc "Insight from simulated ‘what‑if’ scenarios informing design or operational decisions."
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommendation for optimal energy settings balancing comfort and efficiency."
]

instance MaintenancePredictionInsight : DTDFVocab:Insight [
    base:desc "Prediction of upcoming maintenance needs based on anomaly detection in sensor streams."
]

// C17: Actions
instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Action to command HVAC or lighting actuators through the Digital Twin."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange that continuously synchronizes the physical building with its digital replica. Updates are propagated as soon as sensor readings or control actions occur, implying a near‑zero latency loop suitable for device‑level monitoring and control. Temporal granularity is at the level of individual building devices (e.g., HVAC units, lighting fixtures). No explicit numerical frequency is specified."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, service‑oriented architecture with standardized extension points. Core components (BIM enrichment, data acquisition, visualization, runtime configuration) are plugged into the central DT Framework, which orchestrates their interaction. Resource management is handled at runtime through configuration changes without redeployment. System‑wide coordination is achieved via the hub that routes data between physical devices, BIM models, and custom analytics services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a full DT lifecycle that starts with device modeling directly in the BIM environment (defining sensors, actuators, controllers), proceeds to model‑driven engineering (MDE) that extracts a structured representation and automatically generates deployable DT artifacts, followed by runtime operation where continuous real‑time data exchange keeps the physical building and its digital counterpart synchronized, and interactive 3‑D visualization enables monitoring and control. The lifecycle is extensible through standardized extension points that allow integration of custom services, supporting ongoing evolution and governance of the twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The framework evaluates the correspondence between the DT and its physical counterpart using the Overall Digital Twin Entanglement (ODTE) metric, which quantifies how well the generated DT reflects the real building. Validation is performed by comparing runtime telemetry (sensor streams, actuator states) against the modeled expectations, enabling detection of deviations. Uncertainty sources such as modeling gaps in BIM are acknowledged, and the ODTE score serves as a quality‑assurance indicator guiding further refinement of models and data pipelines."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed through non‑functional requirements that demand compatibility with heterogeneous systems. The framework relies on standardized extension points and open interfaces to integrate external services, analytics, and enterprise systems. Specific data exchange protocols are not enumerated, but the design emphasizes modular integration and bidirectional communication with external components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution is built to be compatible with existing AECO‑specific standards such as BIM, ensuring that device models and control logic are anchored in industry‑accepted building information models. For interoperability and real‑time data exchange, the framework integrates Eclipse Hono and Eclipse Ditto, leveraging their IoT communication and digital twin protocols to connect physical devices with the twin. The architecture also follows a modular, standardized extension‑point model to facilitate compliance with broader interoperability frameworks."
]