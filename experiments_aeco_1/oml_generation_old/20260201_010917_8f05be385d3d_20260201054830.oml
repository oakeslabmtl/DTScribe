// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the building envelope, modelled within BIM to report indoor temperature"
    DTDFVocab:producedData TemperatureTelemetry
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor integrated into interior spaces, modelled within BIM to provide occupant presence data"
    DTDFVocab:producedData OccupancyTelemetry
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor placed in hallways, enriched in BIM to deliver indoor relative humidity data"
    DTDFVocab:producedData HumidityTelemetry
]

instance AirflowSensor : DTDFVocab:SensingComponent [
    base:desc "Airflow sensor located in HVAC ducts, modelled in BIM to measure airflow rates"
    DTDFVocab:producedData AirflowTelemetry
]

instance EquipmentStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Equipment status sensor attached to HVAC units, modelled in BIM to report operational states"
    DTDFVocab:producedData EquipmentStatusTelemetry
]

// C4: Physical-to-virtual interaction
instance TemperatureTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance HumidityTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance AirflowTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirflowSensor
]

instance EquipmentStatusTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EquipmentStatusSensor
]

// C10: Models/Data for telemetry
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature data ingested from TemperatureTelemetry via Eclipse Hono and stored in Ditto"
    DTDFVocab:fromData TemperatureTelemetry
    DTDFVocab:inputTo BIMDataMiddleware
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy data ingested from OccupancyTelemetry via Eclipse Hono and stored in Ditto"
    DTDFVocab:fromData OccupancyTelemetry
    DTDFVocab:inputTo BIMDataMiddleware
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity data ingested from HumidityTelemetry via Eclipse Hono and stored in Ditto"
    DTDFVocab:fromData HumidityTelemetry
    DTDFVocab:inputTo BIMDataMiddleware
]

instance AirflowData : DTDFVocab:Data [
    base:desc "Airflow data ingested from AirflowTelemetry via Eclipse Hono and stored in Ditto"
    DTDFVocab:fromData AirflowTelemetry
    DTDFVocab:inputTo BIMDataMiddleware
]

instance EquipmentStatusData : DTDFVocab:Data [
    base:desc "Equipment status data ingested from EquipmentStatusTelemetry via Eclipse Hono and stored in Ditto"
    DTDFVocab:fromData EquipmentStatusTelemetry
    DTDFVocab:inputTo BIMDataMiddleware
]

// C10: Models for simulation and optimization
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Enriched BIM geometry of the building envelope and interior spaces, used for visualisation and spatial analysis"
    DTDFVocab:inputTo SimulationEnabler, OptimizationEnabler, VisualizationEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic defined in BIM for actuators, interpreted by the ControlService"
    DTDFVocab:inputTo ControlEnabler
]

instance ThermalModel : DTDFVocab:Model [
    base:desc "Thermal simulation model derived from enriched BIM, used by SimulationService"
    DTDFVocab:inputTo SimulationEnabler
]

instance LightingModel : DTDFVocab:Model [
    base:desc "Lighting simulation model derived from enriched BIM, used by SimulationService"
    DTDFVocab:inputTo SimulationEnabler
]

instance AirflowModel : DTDFVocab:Model [
    base:desc "Airflow dynamics model derived from enriched BIM, used by SimulationService"
    DTDFVocab:inputTo SimulationEnabler
]

// C11: Enablers
instance BIMDataMiddleware : DTDFVocab:Enabler [
    base:desc "Middleware integrating Eclipse Hono and Eclipse Ditto for real-time telemetry ingestion and persistence"
    DTDFVocab:enables RealTimeMonitoringService, ControlService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine connector that executes thermal, lighting, and airflow models"
    DTDFVocab:enables SimulationService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimization pipeline that consumes simulation outputs and telemetry to recommend energy savings"
    DTDFVocab:enables OptimizationService
]

instance ControlEnabler : DTDFVocab:Enabler [
    base:desc "Actuator command dispatcher that validates safety policies before forwarding commands to physical actuators"
    DTDFVocab:enables ControlService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 viewer integration that overlays live telemetry onto the BIM 3D model"
    DTDFVocab:enables ImmersiveVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service that aggregates real-time telemetry to provide live dashboards for Facility Managers"
    DTDFVocab:provides TemperatureInsight, OccupancyInsight, HumidityInsight, AirflowInsight, EquipmentStatusInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Service that interprets control logic and issues actuator commands while enforcing safety constraints"
    DTDFVocab:provides AdjustHVACCommand, ToggleLightingCommand
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs thermal, lighting, and airflow simulations based on enriched BIM models"
    DTDFVocab:provides ThermalSimulationInsight, LightingSimulationInsight, AirflowSimulationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that analyses simulation results and telemetry to generate energy efficiency recommendations"
    DTDFVocab:provides EnergyEfficiencyInsight, PredictiveMaintenanceInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Service that provides real-time immersive visualization of building state in Unreal Engine 5"
    DTDFVocab:provides OpenVisualizationAction
]

// C17: Insights
instance TemperatureInsight : DTDFVocab:Insight [
    base:desc "Live temperature readings visualized for facility monitoring"
]

instance OccupancyInsight : DTDFVocab:Insight [
    base:desc "Real-time occupancy status across building zones"
]

instance HumidityInsight : DTDFVocab:Insight [
    base:desc "Current indoor humidity levels displayed for environmental control"
]

instance AirflowInsight : DTDFVocab:Insight [
    base:desc "Airflow rates reported from HVAC ducts"
]

instance EquipmentStatusInsight : DTDFVocab:Insight [
    base:desc "Operational status of HVAC equipment and other critical systems"
]

instance ThermalSimulationInsight : DTDFVocab:Insight [
    base:desc "Thermal model output showing temperature distribution across the building"
]

instance LightingSimulationInsight : DTDFVocab:Insight [
    base:desc "Lighting model output indicating illumination levels throughout interior spaces"
]

instance AirflowSimulationInsight : DTDFVocab:Insight [
    base:desc "Airflow dynamics predicted by the simulation model"
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Optimization algorithm recommendation for reducing energy consumption"
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predicted maintenance events for HVAC equipment derived from telemetry trends"
]

// C17: Actions
instance AdjustHVACCommand : DTDFVocab:Action [
    base:desc "Command to adjust HVAC setpoints based on control logic decisions"
    DTDFVocab:IsAutomatic true
]

instance ToggleLightingCommand : DTDFVocab:Action [
    base:desc "Command to turn lighting fixtures on or off according to occupancy detection"
    DTDFVocab:IsAutomatic false
]

instance OpenVisualizationAction : DTDFVocab:Action [
    base:desc "Interaction to open the immersive visualization in Unreal Engine 5 for detailed inspection"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication between the Digital Twin and physical assets is facilitated through the same event stream used for telemetry. Control commands—such as HVAC setpoint adjustments, lighting level changes, and equipment operation changes—are embedded in the twin’s service layer and translated into actuator instructions sent to the physical devices. Validation and authorization of these commands are performed by the middleware, and execution confirmation is returned as acknowledgment events, forming a closed‑loop feedback system that resolves conflicts and ensures command consistency."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time, continuous bidirectional data exchange between the physical building and its digital twin, providing real‑time synchronization; no specific frequency or latency values are specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT Constellation follows a modular, service‑oriented architecture with a central DT Framework hub that orchestrates bidirectional data exchange between enriched BIM models and runtime sensor streams. Standardized extension points allow insertion of custom analytics and control services, and runtime configuration management enables dynamic adaptation without full redeployment. System‑wide coordination is enforced through the hub’s configuration and event‑based messaging, providing a holistic approach to building life‑cycle management."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "1) Enrichment of the BIM model with device‑level metadata (sensors, actuators, controllers) by Building Control Engineers, establishing a unified semantic foundation. 2) Model‑Driven Engineering (MDE) transformations extract structured representations (e.g., IFC extensions or domain ontologies) from the enriched BIM, automatically mapping BIM constructs to runtime components. 3) Artifacts (executable services, APIs, database schemas) are generated and deployed from the transformed models with minimal manual configuration, enabling rapid iteration. 4) Runtime operation continuously synchronises sensor data and actuator commands via real‑time data exchange protocols, providing real‑time state alignment between the physical building and its Digital Twin. 5) Continuous evolution is supported by modular extension points, allowing new analytics or control logic to be plugged in without modifying core artifacts. Governance is realised through defined stakeholder roles—Building Control Engineer, Facility Manager, DT Engineer—each responsible for specific lifecycle stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by embedding the semantic constraints of the BIM model into Ditto’s policy framework, which enforces value ranges and units during runtime message validation. Verification of actuator command safety is performed by the policy engine before dispatch, preventing unsafe state transitions. Data validity is maintained via Hono’s reliable message broker guaranteeing at‑least‑once delivery and Ditto’s persistent event store, providing recoverable event streams. Fault tolerance is achieved by persistent storage in Ditto, so that events are not lost during service interruptions. No formal static verification of control logic is described; the system relies on runtime validation and memory of past events to ensure consistent behavior."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved via standardized extension points that support interoperability across heterogeneous enterprise systems; specific protocols or messaging patterns are not specified in the provided documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The platform is designed to interoperate with established open‑source DT frameworks such as Eclipse Ditto and BaSyx, providing bidirectional communication with sensor networks through standardized protocols. It aligns with AECO‑specific interoperability requirements by building on BIM as a semantic foundation, and the modular architecture facilitates compliance with evolving industry standards and data schemas."
]