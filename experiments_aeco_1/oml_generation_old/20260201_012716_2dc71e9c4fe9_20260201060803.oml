// Acting Component
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Actuation component that interprets BIM-defined lighting fixtures as LightTwinComponents, injecting UE5 light objects into the scene and wiring commands through the UnrealTwinController."
]

// Sensor Component
instance PhotometricSensor : DTDFVocab:SensingComponent [
    base:desc "Photometric sensor embedded in a lighting fixture that measures illumination, colour‑temperature, and on/off status."
    DTDFVocab:producedData PhotometricSensorDataTrans
]

// Data Transmitted by the Sensor
instance PhotometricSensorDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhotometricSensor
]

// Data Elements Derived from the Transmitted Sensor Data
instance IlluminationData : DTDFVocab:Data [
    base:desc "Illumination measurement (lux) produced by the photometric sensor."
    DTDFVocab:inputTo DittoConnection
    DTDFVocab:fromData PhotometricSensorDataTrans
]
instance ColorTemperatureData : DTDFVocab:Data [
    base:desc "Color temperature (K) produced by the photometric sensor."
    DTDFVocab:inputTo DittoConnection
    DTDFVocab:fromData PhotometricSensorDataTrans
]
instance OnOffStatusData : DTDFVocab:Data [
    base:desc "On/off status (true/false) produced by the photometric sensor."
    DTDFVocab:inputTo DittoConnection
    DTDFVocab:fromData PhotometricSensorDataTrans
]

// Enabler: Eclipse Ditto integration layer
instance DittoConnection : DTDFVocab:Enabler [
    base:desc "DittoConnection that receives updated state from Eclipse Hono events, validates units and ranges, and persists the data as DittoDevices."
    DTDFVocab:enables RealTimeMonitoringService,
                 PredictiveAnalyticsService,
                 OptimizationService,
                 DirectControlService,
                 InteractiveVisualizationService
]

// Service: Real‑time monitoring
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring service that streams all BCS component data through Eclipse Ditto to a dashboard."
    DTDFVocab:provides RealTimeStatusInsight
]
instance RealTimeStatusInsight : DTDFVocab:Insight [
    base:desc "Insight providing the current status of all monitored devices."
]

// Service: Predictive analytics
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service that forecasts equipment wear, energy consumption, and fault likelihood."
    DTDFVocab:provides EnergyConsumptionInsight,
                 FaultLikelihoodInsight
]
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight predicting future energy consumption of lighting and HVAC units."
]
instance FaultLikelihoodInsight : DTDFVocab:Insight [
    base:desc "Insight estimating the likelihood of fault conditions in building control systems."
]

// Service: Optimization
instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that recommends control set‑point adjustments to reduce energy use while maintaining occupant comfort."
    DTDFVocab:provides EnergyOptimizationAction
]
instance EnergyOptimizationAction : DTDFVocab:Action [
    base:desc "Action to automatically adjust lighting and HVAC set‑points based on optimization recommendations."
    DTDFVocab:IsAutomatic true
]

// Service: Direct control
instance DirectControlService : DTDFVocab:Service [
    base:desc "Direct control service that allows facility managers to command actuators and HVAC units based on user‑defined logic."
    DTDFVocab:provides DirectControlAction
]
instance DirectControlAction : DTDFVocab:Action [
    base:desc "Manual or automated action to change the state of lighting fixtures and HVAC units."
    DTDFVocab:IsAutomatic false
]

// Service: Interactive visualization
instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization service that renders the building model and real‑time data in an immersive UE5 scene."
    DTDFVocab:provides VisualizationAction
]
instance VisualizationAction : DTDFVocab:Action [
    base:desc "Action enabling users to inspect building conditions and manipulate operations within the UE5 dashboard."
    DTDFVocab:IsAutomatic false
]

// Model: BIM-ENRICHED representation
instance BIMModel : DTDFVocab:Model [
    base:desc "BIM artefact enriched with sensor, actuator, and controller annotations, used as the source for MDE-driven twin generation."
    DTDFVocab:inputTo MDEPipelineEnabler
]

// Enabler: Model‑Driven Engineering Pipeline
instance MDEPipelineEnabler : DTDFVocab:Enabler [
    base:desc "MDE pipeline that transforms the enriched BIM model into a platform‑agnostic representation and generates deployable twin artefacts."
    DTDFVocab:enables ModelGenerationService
]
instance ModelGenerationService : DTDFVocab:Service [
    base:desc "Service that performs model generation, code synthesis, and artifact packaging for deployment onto the runtime stack."
    DTDFVocab:provides ModelCompilationInsight
]
instance ModelCompilationInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful compilation and deployment of the twin artefacts."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin framework supports continuous real‑time data exchange, ensuring the digital representation stays synchronised with its physical counterpart in real time. The system provides bidirectional communication that enables up‑to‑date monitoring and control without explicit fixed sampling intervals in the document, indicating a design aimed at real‑time interaction with minimal latency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellations are orchestrated through a modular, service‑oriented architecture centered on a DT Framework that serves as a central hub. The framework offers standardized extension points enabling the integration of custom services and analytics, while runtime configuration management allows adaptations without full redeployment. Component integration follows a service‑oriented pattern: Building Control Engineers use BIM tools to model devices and trigger deployment, DT Engineers extend the framework by plugging in specialized analytics or control services, and Facility Managers interact with the deployed DT for real‑time monitoring and control. Resource management is supported by a scalable broker within the framework, allowing scaling from component‑level to entire infrastructure systems. Maintainability is achieved via low‑overhead updates, and interoperability across heterogeneous systems is ensured through common data models and runtime agreements. Overall orchestration guarantees bidirectional continuous data exchange between the physical building and its digital twin, facilitating a holistic approach to building life‑cycle management."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle in this framework follows a model‑driven path that begins with BIM enrichment where Building Control Engineers annotate physical assets with explicit sensor, actuator, and controller semantics directly inside the BIM workspace. These enriched models are then subjected to model‑based engineering (MDE) transformations that map the BIM representation to a deployable semantic data model and automatically generate the corresponding DT artifacts (e.g., device configuration, connectivity adapters, and service descriptors). The conversion phase produces deployable artifacts that are staged for deployment to the runtime platform. Deployment, governed by the DT Engineer, respectively instantiates the digital twins and configures the real‑time data connectors so that every change in the physical building (via IoT gateways) is mirrored in the digital space. Throughout the operational phase, Facility Managers continuously monitor and interact with the twin through immersive visualization (Unreal Engine) and real‑time dashboards, while custom analytics plugins can be added at runtime via the framework’s standardized extension points. Lifecycle governance is explicit: Building Control Engineers own the modeling phase, DT Engineers oversee artifact generation and deployment, and Facility Managers drive operational interaction, ensuring traceability and a single source of truth."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by validating the enriched BIM model against a custom schema before pipeline execution, guaranteeing that all required semantic annotations are present. Runtime fidelity is preserved through Ditto’s policy‑based validation, which enforces value ranges, units, and pre‑execution safety checks on actuator commands. Fault tolerance is achieved with Eclipse Hono’s at‑least‑once message delivery guaranteeing message receipt during network interruptions, and Ditto’s persistent event store that preserves state even during service disruptions. Quality assurance is performed via continuous monitoring of event logs, automated integrity checks, and reconciliation between physical timestamps and virtual twin states, ensuring consistent and trustworthy model behaviour."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional data exchange facilitated by the DT framework, supporting interoperability across heterogeneous systems."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with external environments via a modular framework that exposes standardized extension points for service integration and supports bidirectional data exchange. While specific protocols are not detailed, the design emphasizes interoperability across heterogeneous systems, allowing the framework to serve as a bridge for external services, analytics, and enterprise systems within the AECO domain."
]