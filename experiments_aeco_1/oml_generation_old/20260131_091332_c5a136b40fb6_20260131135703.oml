// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM, captures post-occupancy occupancy data"
    DTDFVocab:producedData HonoTelemetryOccupancy
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental temperature sensor modeled in BIM, captures indoor temperature readings"
    DTDFVocab:producedData HonoTelemetryTemperature
]

instance EnergyMeterSensor : DTDFVocab:SensingComponent [
    base:desc "Performance sensor modeled in BIM, measures building energy consumption"
    DTDFVocab:producedData HonoTelemetryEnergy
]

// C4: Physical-to-virtual interaction
instance HonoTelemetryOccupancy : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance HonoTelemetryTemperature : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HonoTelemetryEnergy : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeterSensor
]

// C10: Models/Data
instance BIMIFCModel : DTDFVocab:Model [
    base:desc "BIM IFC model of the Living Lab building"
    DTDFVocab:inputTo MDERunner
]

instance DeviceTwinModel : DTDFVocab:Model [
    base:desc "Autogenerated device twin model created from BIM data via MDE"
    DTDFVocab:inputTo HonoMediator, DittoMediator
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic for lighting and HVAC derived from BIM modeling"
    DTDFVocab:inputTo DittoMediator, HonoMediator
]

instance DataModel : DTDFVocab:Model [
    base:desc "Runtime data model for sensor readings and derived KPIs"
    DTDFVocab:inputTo HonoMediator, DittoMediator
]

// C10: Data instances
instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy data transmitted to the Digital Twin"
    DTDFVocab:inputTo HonoMediator
    DTDFVocab:fromData HonoTelemetryOccupancy
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature data transmitted to the Digital Twin"
    DTDFVocab:inputTo HonoMediator
    DTDFVocab:fromData HonoTelemetryTemperature
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "Energy consumption data transmitted to the Digital Twin"
    DTDFVocab:inputTo HonoMediator
    DTDFVocab:fromData HonoTelemetryEnergy
]

// C11: Enablers
instance HonoMediator : DTDFVocab:Enabler [
    base:desc "Eclipse Hono service handling telemetry transport from physical sensors"
    DTDFVocab:enables TelemetryDataProcessingService
]

instance DittoMediator : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto service managing device twin state and command routing"
    DTDFVocab:enables StateManagementService, CommandRoutingService
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 visualization engine powering real-time dashboards"
    DTDFVocab:enables RenderingService
]

instance MDERunner : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering transformer generating runtime artifacts from BIM"
    DTDFVocab:enables ArtifactGenerationService
]

// C6: Services
instance TelemetryDataProcessingService : DTDFVocab:Service [
    base:desc "Service processing telemetry data streams from Hono"
    DTDFVocab:provides DataIngestionInsight
]

instance StateManagementService : DTDFVocab:Service [
    base:desc "Service maintaining device twin state via Eclipse Ditto"
    DTDFVocab:provides StateConsistencyInsight
]

instance CommandRoutingService : DTDFVocab:Service [
    base:desc "Service routing control commands from the twin to physical actuation layers"
    DTDFVocab:provides CommandExecutionInsight
]

instance RenderingService : DTDFVocab:Service [
    base:desc "Service rendering building models and real-time telemetry in Unreal Engine 5"
    DTDFVocab:provides VisualizationInsight
]

instance ArtifactGenerationService : DTDFVocab:Service [
    base:desc "Service transforming BIM metadata into runtime artifacts such as device twins"
    DTDFVocab:provides ArtifactCreationInsight
]

instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real-time monitoring dashboard powered by Unreal Engine 5"
    DTDFVocab:provides OccupancyInsight, TemperatureInsight, EnergyConsumptionInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics and optimization models, e.g., reinforcement-learning-based lighting control"
    DTDFVocab:provides ComfortOptimizationInsight, EnergyEfficiencyInsight, AdaptiveLightingAction
]

instance ScenarioSimulationService : DTDFVocab:Service [
    base:desc "Service enabling scenario simulation for building performance"
    DTDFVocab:provides SimulationOutcomeInsight
]

instance AutomatedReportingService : DTDFVocab:Service [
    base:desc "Service automating generation of performance reports"
    DTDFVocab:provides ReportGenerationInsight
]

instance ExternalAPIService : DTDFVocab:Service [
    base:desc "API exposing twin state and allowing external services to query or submit control directives"
    DTDFVocab:provides ExternalInteractionInsight
]

// C17: Insights/Actions
instance OccupancyInsight : DTDFVocab:Insight [
    base:desc "Real-time occupancy analytics derived from OccupancyData"
]

instance TemperatureInsight : DTDFVocab:Insight [
    base:desc "Real-time temperature analytics derived from TemperatureData"
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Real-time energy consumption analytics derived from EnergyConsumptionData"
]

instance DataIngestionInsight : DTDFVocab:Insight [
    base:desc "Insight into data ingestion throughput and latency"
]

instance StateConsistencyInsight : DTDFVocab:Insight [
    base:desc "Insight on device twin state consistency"
]

instance CommandExecutionInsight : DTDFVocab:Insight [
    base:desc "Insight on command execution status and actuator responsiveness"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight on visualization fidelity within Unreal Engine 5"
]

instance ArtifactCreationInsight : DTDFVocab:Insight [
    base:desc "Insight into the success of MDE-generated runtime artifacts"
]

instance ComfortOptimizationInsight : DTDFVocab:Insight [
    base:desc "Predictive insight guiding comfort optimization strategies"
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Predictive insight identifying opportunities for energy savings"
]

instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Outcome analytics of scenario simulations"
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight on automated reporting accuracy and timeliness"
]

instance ExternalInteractionInsight : DTDFVocab:Insight [
    base:desc "Insight into external API interactions and data sharing"
]

instance AdaptiveLightingAction : DTDFVocab:Action [
    base:desc "Automatic reinforcement-learning-based lighting control action"
    DTDFVocab:IsAutomatic true
]

instance ManualSetpointAdjustmentAction : DTDFVocab:Action [
    base:desc "Manual adjustment of lighting or HVAC setpoints by facility managers"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control unit defined within BIM, receives control commands from Ditto"
    DTDFVocab:producedData HonoTelemetryLightingControl
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC controller defined within BIM, receives control commands from Ditto"
    DTDFVocab:producedData HonoTelemetryHVACControl
]

// C4: DataTransmitted for actuators
instance HonoTelemetryLightingControl : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingActuator
]

instance HonoTelemetryHVACControl : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACActuator
]

// Data from actuators (if any)
instance LightingControlData : DTDFVocab:Data [
    base:desc "Data reflecting lighting actuator state changes"
    DTDFVocab:inputTo DittoMediator
    DTDFVocab:fromData HonoTelemetryLightingControl
]

instance HVACControlData : DTDFVocab:Data [
    base:desc "Data reflecting HVAC actuator state changes"
    DTDFVocab:inputTo DittoMediator
    DTDFVocab:fromData HonoTelemetryHVACControl
]

// C17: Insight from actuation
instance LightingControlInsight : DTDFVocab:Insight [
    base:desc "Insight into lighting actuator performance and energy impact"
]

instance HVACControlInsight : DTDFVocab:Insight [
    base:desc "Insight into HVAC actuator performance and comfort impact"
]

// C6: Service for acting components
instance ActuationMonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring actuator state changes and providing control insights"
    DTDFVocab:provides LightingControlInsight, HVACControlInsight
]

// C11: Enabler linking actuators to service
instance DittoForActuation : DTDFVocab:Enabler [
    base:desc "Ditto instance configured for actuator command routing"
    DTDFVocab:enables ActuationMonitoringService
]

// C3: Add a container for components
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, TemperatureSensor, EnergyMeterSensor, LightingActuator, HVACActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated in the Twin are routed back to the physical building automation system through Ditto/Hono, enabling bidirectional communication and real‑time actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All interactions (data ingestion, command dispatch, simulation updates) are performed in real time, with the Twin continuously synchronised to the physical building as changes occur."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system comprises a centralized Ditto hub that hosts individual device twins, a Hono bootstrapper that configures device endpoints, and an Unreal Engine frontend that connects to the Ditto API to visualise the Twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin operates in the operational lifecycle stage of the building, providing continuous monitoring and optimization. It incorporates runtime configuration management that supports ad‑hoc updates from the design‑to‑manufacture stages encapsulated in the BIM model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is quantified using the Overall Digital Twin Entanglement (ODTE) metric, which compares the virtual representation against the physical measurements. Validation occurs through continuous telemetry comparison and model‑driven consistency checks defined in the MDE pipeline."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Twin communicates with physical devices through Eclipse Hono and Ditto; device metadata (tenant ID, device ID, endpoint addresses) is stored in the Tenants registry used by the Hono/Ditto configuration pipeline."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM (IFC) is used as the primary semantic standard for modeling building elements; Eclipse Ditto follows established IoT Device Twin specifications."
]