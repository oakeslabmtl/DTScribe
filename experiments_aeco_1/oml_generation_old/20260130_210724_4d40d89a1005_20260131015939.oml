// C3: Physical sensing components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Light level sensor embedded in the BIM model and deployed in the Living Lab building, providing lighting measurements for the BOREALIS reinforcement‑learning loop."
    DTDFVocab:producedData LightingDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental condition sensor (temperature, humidity, CO2) embedded in the BIM model and deployed in the Living Lab building, feeding data for real‑time monitoring and optimization."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LightingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C10: Data
instance LightingMeasurementData : DTDFVocab:Data [
    base:desc "Live light level measurements streamed from the physical building to the digital twin."
    DTDFVocab:fromData LightingDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoTwinStore
]

instance EnvironmentalMeasurementData : DTDFVocab:Data [
    base:desc "Live environmental condition measurements (temperature, humidity, CO2) streamed from the physical building to the digital twin."
    DTDFVocab:fromData EnvironmentalDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoTwinStore
]

// C10: Models/Data (Model instances)
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Static BIM model enriched with runtime semantics such as device metadata and control logic, representing the Living Lab building across design, construction and operation."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline, EclipseDittoTwinStore
]

instance BOREALISReinforcementLearningModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning model (BOREALIS) that generates adaptive lighting control policies based on live sensor data and energy objectives."
    DTDFVocab:inputTo EclipseDittoTwinStore, AdaptiveLightingControlService
]

// C11: Enablers
instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono IoT protocol gateway that ingests real‑time sensor measurements from the building and forwards them to the digital twin store."
    DTDFVocab:enables RealTimeMonitoringDashboardService, PredictiveAnalyticsService
]

instance EclipseDittoTwinStore : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin platform that stores live sensor data, control state and runtime artifacts."
    DTDFVocab:enables Immersive3DVisualizationService, EnergyConsumptionOptimizationService, AdaptiveLightingControlService
]

instance UnrealEngine5VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime that renders a 3‑D immersive visualization of the digital twin for facility managers."
    DTDFVocab:enables Immersive3DVisualizationService
]

instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline that validates the enriched BIM model, generates runtime code and configures Hono/Ditto."
    DTDFVocab:enables RealTimeMonitoringDashboardService, EnergyConsumptionOptimizationService
]

// C6: Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards delivering up‑to‑date building status visualizations."
    DTDFVocab:provides RealTimeBuildingStatusInsight
]

instance Immersive3DVisualizationService : DTDFVocab:Service [
    base:desc "3‑D immersive visualization of the building using Unreal Engine 5."
    DTDFVocab:provides Immersive3DViewInsight
]

instance EnergyConsumptionOptimizationService : DTDFVocab:Service [
    base:desc "Energy‑consumption optimization service that analyses data and proposes recommendations."
    DTDFVocab:provides EnergyConsumptionRecommendationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service that forecasts future building performance and anomalies."
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance AdaptiveLightingControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based adaptive lighting control service that automatically adjusts lighting settings."
    DTDFVocab:provides AdaptiveLightingControlAction
]

// C17: Insights
instance RealTimeBuildingStatusInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing current building operational status derived from live sensor streams."
]

instance Immersive3DViewInsight : DTDFVocab:Insight [
    base:desc "Insight providing an immersive 3‑D view of the building state for facility managers."
]

instance EnergyConsumptionRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight offering optimization recommendations to reduce energy consumption while maintaining comfort."
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Insight forecasting future energy demand, equipment failures, and occupancy trends."
]

// C17: Actions
instance AdaptiveLightingControlAction : DTDFVocab:Action [
    base:desc "Automatic lighting control command generated by the BOREALIS reinforcement‑learning loop and applied to building actuators."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator modeled in the BIM that receives lighting control commands from the digital twin and adjusts fixture illumination."
]

instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Controller device that mediates between the digital twin service and the lighting actuators."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional control commands generated by the twin are transmitted back to the physical actuators through the same Hono/Ditto middleware, allowing the twin to influence lighting (and other) building systems in real time."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (continuous) synchronization between physical sensor streams and the twin; control actions are applied with minimal latency through the middleware."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated architecture where the enriched BIM model feeds a configurator that produces device metadata, which is consumed by Hono/Ditto for bidirectional communication; services and visualization components plug into this core via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Supports the full building life‑cycle: design (as‑built BIM), construction, operation (live sensor data), and post‑occupancy adaptation, enabling continuous updates from design to refurbishment phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric is applied to quantify how closely the twin reflects its physical counterpart; model validation is performed before deployment to ensure semantic correctness."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Technical connectivity is realized through Eclipse Hono (gateway for device telemetry) and Eclipse Ditto (digital twin store and API gateway), which together provide the communication backbone between physical sensors/actuators and the digital twin."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Runtime artifacts and services are deployed on a service‑oriented platform that hosts Hono, Ditto and the Unreal Engine visualization; the framework provides automated deployment of these components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Relies on BIM as a standardized building information model; uses open‑source standards provided by Eclipse Hono/Ditto and defines standardized extension points for service integration."
]