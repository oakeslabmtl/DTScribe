import vocab DTDFVocab from "http://example.org/DTDFVocab"

// C2: Acting Components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator modelled in BIM, addressable via generated runtime interfaces."
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve actuator modelled in BIM, addressable via generated runtime interfaces."
]

// C3: Physical sensing components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor embedded in the building, extracted from BIM for TwinLight project.",
    DTDFVocab:producedData LightingTelemetry
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the building, extracted from BIM for BOREALIS project.",
    DTDFVocab:producedData OccupancyTelemetry
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the building, extracted from BIM.",
    DTDFVocab:producedData TemperatureTelemetry
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor embedded in the building, extracted from BIM.",
    DTDFVocab:producedData HumidityTelemetry
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LightingTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance OccupancyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

// C10: Data
instance LightingData : DTDFVocab:Data [
    base:desc "Live lighting telemetry data stream.",
    DTDFVocab:fromData LightingTelemetry,
    DTDFVocab:inputTo EclipseHono
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy telemetry data stream.",
    DTDFVocab:fromData OccupancyTelemetry,
    DTDFVocab:inputTo EclipseHono
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature telemetry data stream.",
    DTDFVocab:fromData TemperatureTelemetry,
    DTDFVocab:inputTo EclipseHono
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Live humidity telemetry data stream.",
    DTDFVocab:fromData HumidityTelemetry,
    DTDFVocab:inputTo EclipseHono
]

// C10: Models
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Semantic BIM geometry and topology model enriched with device metadata.",
    DTDFVocab:inputTo BIMAuthoringTool, EclipseDitto
]

instance DeviceMetadataModel : DTDFVocab:Model [
    base:desc "Model containing device and control metadata extracted from BIM.",
    DTDFVocab:inputTo ModelDrivenDeploymentFramework, EclipseDitto
]

instance BuildingControlRuntimeModel : DTDFVocab:Model [
    base:desc "Runtime model for building control systems generated by the model‑driven pipeline.",
    DTDFVocab:inputTo EclipseDitto
]

instance UnrealVisualizationModel : DTDFVocab:Model [
    base:desc "3‑D visualisation model rendered in Unreal Engine 5 for immersive interaction.",
    DTDFVocab:inputTo UnrealEngine5
]

// C11: Enablers
instance ModelDrivenDeploymentFramework : DTDFVocab:Enabler [
    base:desc "Model‑driven deployment framework that generates and deploys runtime artefacts automatically.",
    DTDFVocab:enables RealTimeMonitoringDashboard, EnergyConsumptionOptimization
]

instance BIMAuthoringTool : DTDFVocab:Enabler [
    base:desc "BIM authoring tool used to enrich geometry and topology models with device metadata.",
    DTDFVocab:enables UnrealInteractiveVisualization
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono platform for real‑time telemetry ingestion from building sensors.",
    DTDFVocab:enables RealTimeMonitoringDashboard, EnergyConsumptionOptimization
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for digital twin state management and runtime model handling.",
    DTDFVocab:enables FacilityManagerDecisionSupport, PredictiveAnalyticsSimulation
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 providing immersive 3‑D visualisation of the digital twin.",
    DTDFVocab:enables UnrealInteractiveVisualization
]

instance ModularExtensionPoint : DTDFVocab:Enabler [
    base:desc "Standardized extension points enabling modular services to be plugged into the twin platform.",
    DTDFVocab:enables RealTimeMonitoringDashboard, UnrealInteractiveVisualization, PredictiveAnalyticsSimulation, EnergyConsumptionOptimization, FacilityManagerDecisionSupport
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard displaying live building sensor data.",
    DTDFVocab:provides EnergyConsumptionTrendInsight, ComfortViolationInsight
]

instance UnrealInteractiveVisualization : DTDFVocab:Service [
    base:desc "3‑D interactive visualisation of the building twin in Unreal Engine 5."
]

instance PredictiveAnalyticsSimulation : DTDFVocab:Service [
    base:desc "Simulation and predictive analytics service for forecasting building performance.",
    DTDFVocab:provides ComfortViolationInsight, OptimizationRecommendationInsight
]

instance EnergyConsumptionOptimization : DTDFVocab:Service [
    base:desc "Optimization service that generates recommendations to reduce energy usage.",
    DTDFVocab:provides OptimizationRecommendationInsight, AdjustControlStrategyAction
]

instance FacilityManagerDecisionSupport : DTDFVocab:Service [
    base:desc "Decision‑support service for facility managers to plan refurbishment actions.",
    DTDFVocab:provides PlanRefurbishmentAction
]

// C17: Insights
instance EnergyConsumptionTrendInsight : DTDFVocab:Insight [
    base:desc "Insight showing energy‑consumption trends derived from live telemetry."
]

instance ComfortViolationInsight : DTDFVocab:Insight [
    base:desc "Insight detecting comfort violations (e.g., temperature or humidity out of acceptable range)."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight delivering optimisation recommendations for energy savings and comfort improvement."
]

// C17: Actions
instance AdjustControlStrategyAction : DTDFVocab:Action [
    base:desc "Action to adjust building control strategies based on optimisation recommendations.",
    DTDFVocab:IsAutomatic false
]

instance PlanRefurbishmentAction : DTDFVocab:Action [
    base:desc "Action to plan refurbishment activities guided by twin‑derived insights.",
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command flow from the twin to physical devices through the same Hono/Ditto middleware, allowing the twin to issue control set‑points (e.g., lighting levels, HVAC commands) to actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real-time synchronization; sensor data are streamed continuously and control commands are propagated with low latency, supporting online monitoring and control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An integrated stack where an enriched BIM model feeds a configurator that generates Hono/Ditto runtime artefacts; these artefacts mediate bidirectional data flow between physical devices and the virtual twin, while Unreal Engine provides the user‑facing visualisation; additional custom services can be plugged via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the full building lifecycle: design (static BIM), construction (model enrichment), and operation (runtime‑enabled twin used for monitoring, optimisation and refurbishment)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to quantify how closely the digital twin reflects its physical counterpart; semantic drift is mitigated by continuous synchronization and model validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time connectivity realised through Eclipse Hono (messaging middleware) and Eclipse Ditto (digital twin platform), which together provide the protocols for telemetry ingestion and twin state updates."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Built on BIM standards for geometry and semantics; uses standardized extension points and aligns with industry practices for digital twins; evaluation employs the ODTE metric, a recognized standard for entanglement assessment."
]