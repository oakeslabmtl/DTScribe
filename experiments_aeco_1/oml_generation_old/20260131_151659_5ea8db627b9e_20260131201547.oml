// C2: Acting Components
instance BuildingControlEngineer : DTDFVocab:ActingComponent [
    base:desc "Role responsible for defining sensor-actuator feedback loops and control logic within BIM environments for DT construction"
]

instance FacilityManager : DTDFVocab:ActingComponent [
    base:desc "Role responsible for real-time monitoring, visualization, and operational oversight of the digital twin through immersive interfaces"
]

instance DTEngineer : DTDFVocab:ActingComponent [
    base:desc "Role responsible for extending DT capabilities through custom services/plugins and analytics integration"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing operational metrics like temperature within building systems for real-time synchronization"
    DTDFVocab:producedData TemperatureData
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring humidity levels in building environments for operational monitoring"
    DTDFVocab:producedData HumidityData
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor tracking occupancy patterns within building zones for predictive analytics"
    DTDFVocab:producedData OccupancyData
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring energy usage metrics across building systems for efficiency optimization"
    DTDFVocab:producedData EnergyConsumptionData
]

instance ControlSignalActuator : DTDFVocab:SensingComponent [
    base:desc "Actuator receiving control signals from DT for real-time building system adjustments"
]

// C4: Physical-to-virtual interaction
instance TemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyConsumptionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance ControlSignalData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ControlSignalActuator
]

// C10: Models/Data
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "3D spatial and structural BIM model representing building components for precise alignment with physical assets"
    DTDFVocab:inputTo BIMTools
]

instance BIMBehavioralModel : DTDFVocab:Model [
    base:desc "Control logic defined by Building Control Engineers capturing dynamic interactions between sensors and actuators"
    DTDFVocab:inputTo BIMTools
]

instance BIMAnalyticalModel : DTDFVocab:Model [
    base:desc "Automatically generated analytical models from MDE transformations ensuring DT artifact consistency"
    DTDFVocab:inputTo BIMBasedSimulationEngines
]

instance OperationalMetricsData : DTDFVocab:Data [
    base:desc "Aggregated operational data combining temperature, humidity, occupancy, and energy consumption metrics"
    DTDFVocab:fromData TemperatureData, HumidityData, OccupancyData, EnergyConsumptionData
    DTDFVocab:inputTo SemanticDatabases
]

instance ControlStatusData : DTDFVocab:Data [
    base:desc "Status updates and control signals exchanged between physical building systems and DT"
    DTDFVocab:fromData ControlSignalData
    DTDFVocab:inputTo RealTimeSynchronizationService
]

instance BIMEnrichedData : DTDFVocab:Data [
    base:desc "Structured representations extracted from enriched BIM models for DT deployment"
    DTDFVocab:inputTo ModelDrivenAutomationFramework
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Open-source framework enabling real-time device connectivity and low-latency data synchronization for DT"
    DTDFVocab:enables RealTimeConnectivityService
]

instance DittoProtocol : DTDFVocab:Enabler [
    base:desc "Lightweight IoT messaging protocol facilitating live DT synchronization with minimal latency"
    DTDFVocab:enables LiveSynchronizationService
]

instance ModelDrivenAutomationFramework : DTDFVocab:Enabler [
    base:desc "Framework enabling semantic integration, real-time connectivity, and extensibility via DSR methodologies"
    DTDFVocab:enables AutomationService, ExtensibilityService
]

instance BIMTools : DTDFVocab:Enabler [
    base:desc "Industry-standard platforms (Revit, ArchiCAD) for creating semantically rich BIM models"
    DTDFVocab:enables BIMModelCreationService
]

instance BIMBasedSimulationEngines : DTDFVocab:Enabler [
    base:desc "Engines like EnergyPlus and Dynamo for performance analysis and predictive modeling"
    DTDFVocab:enables PerformanceSimulationService
]

instance SemanticDatabases : DTDFVocab:Enabler [
    base:desc "GraphDB and Neo4j databases storing and querying relationships between BIM objects and physical asset data"
    DTDFVocab:enables DataRelationshipService
]

instance ModularArchitecture : DTDFVocab:Enabler [
    base:desc "Defined extension points for scalable, service-oriented DT development"
    DTDFVocab:enables ScalableServiceDeployment
]

instance DesignScienceResearch : DTDFVocab:Enabler [
    base:desc "Methodology for artifact development through requirements elicitation, prototyping, and experimentation"
    DTDFVocab:enables ResearchDrivenDevelopment
]

instance AutomatedDeploymentTools : DTDFVocab:Enabler [
    base:desc "Tools reducing manual intervention in DT setup (e.g., C2 framework)"
    DTDFVocab:enables AutomatedDeploymentService
]

