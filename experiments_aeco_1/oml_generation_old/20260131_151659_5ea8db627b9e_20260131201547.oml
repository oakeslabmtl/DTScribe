]

instance RealTimeSynchronizationService : DTDFVocab:Service [
    base:desc "Core service for real-time synchronization between physical assets and digital twins"
    DTDFVocab:provides PerformanceTrackingInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Core service for real-time synchronization between physical assets and digital twins"
    DTDFVocab:provides PerformanceTrackingInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service supporting predictive maintenance and resource allocation optimization"
