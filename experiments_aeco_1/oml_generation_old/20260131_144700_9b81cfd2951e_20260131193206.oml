// C3: Physical Sensing Components
instance EnvironmentalConditionSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real-time environmental data including temperature, humidity, and air quality metrics from building infrastructure. Integrated with BIM framework and BOREALIS project for post-occupancy sensor data refinement."
    DTDFVocab:producedData EnvironmentalConditionDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Monitors real-time occupancy metrics (e.g., presence detection, movement patterns) within building spaces. Metadata includes tenant ID and device endpoint addresses for middleware integration."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Tracks real-time energy consumption across building systems (e.g., HVAC, lighting). Data used for reinforcement learning-based optimization in BOREALIS project."
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance EnvironmentalConditionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalConditionSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

// C10: Models/Data
instance BimEnrichedModel : DTDFVocab:Model [
    base:desc "Semantically enriched BIM model containing geometric, spatial, and functional data of building components (e.g., walls, HVAC systems). Extended with runtime metadata for sensor/actuator configurations."
    DTDFVocab:inputTo BimModelingTool, EclipseDitto
]

instance RealTimeBuildingStateData : DTDFVocab:Data [
    base:desc "Structured JSON-based runtime data representing real-time states of building systems (e.g., sensor readings, actuator commands, control logic) stored in Eclipse Ditto instances."
    DTDFVocab:fromData EnvironmentalConditionDataTransmitted, OccupancyDataTransmitted, EnergyConsumptionDataTransmitted
    DTDFVocab:inputTo EclipseDitto, ReinforcementLearningEngine
]

instance DeviceMetadataConfiguration : DTDFVocab:Data [
    base:desc "Metadata configurations for sensors/actuators including device IDs, tenant IDs, and endpoint addresses. Used for Eclipse Hono device registration and Ditto instance creation."
    DTDFVocab:fromData OccupancyDataTransmitted, EnergyConsumptionDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "TwinLight's BIM-centric control framework embedding domain-specific control semantics (e.g., adaptive lighting strategies, HVAC schedules) directly into BIM models."
    DTDFVocab:inputTo BimModelingTool, EclipseDitto
]

instance ReinforcementLearningModel : DTDFVocab:Model [
    base:desc "BOREALIS project's reinforcement learning model using historical sensor data to optimize energy consumption, visual comfort, and circadian lighting strategies."
    DTDFVocab:inputTo ReinforcementLearningEngine
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Middleware for device management and real-time data ingestion from sensors to digital twin. Handles authentication, device registration, and data routing."
    DTDFVocab:enables RealTimeMonitoringService, AutomatedCommissioningService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Digital twin runtime platform storing real-time states of building components in structured JSON format. Supports bidirectional communication and dynamic configuration."
    DTDFVocab:enables PredictiveAnalyticsService, SimulationAndOptimizationService, CustomServiceIntegration
]

instance BimModelingTool : DTDFVocab:Enabler [
    base:desc "Toolset for creating and enriching BIM models with runtime metadata (e.g., Revit, ArchiCAD). Supports model-driven deployment pipeline."
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Interactive 3D visualization engine for immersive monitoring of building performance metrics (e.g., energy consumption, occupancy heatmaps)."
    DTDFVocab:enables RealTimeMonitoringService, StakeholderDashboardService
]

instance ReinforcementLearningEngine : DTDFVocab:Enabler [
    base:desc "Machine learning framework executing BOREALIS project's reinforcement learning algorithms for adaptive control policy optimization."
    DTDFVocab:enables PredictiveAnalyticsService, ControlPolicyUpdateService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Interactive visualization of building performance metrics (e.g., energy consumption, occupancy, environmental conditions) via Unreal Engine 5 immersive 3D interface."
    DTDFVocab:provides BuildingPerformanceInsight, OperationalOptimizationAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Reinforcement learning-based optimization of energy consumption, visual comfort, and circadian lighting using post-occupancy sensor data from BOREALIS project."
    DTDFVocab:provides EnergyOptimizationInsight, VisualComfortInsight, NonVisualHealthInsight
]

instance AutomatedCommissioningService : DTDFVocab:Service [
    base:desc "TwinLight's BIM-centric framework automating setup and calibration of Building Control System devices, reducing manual effort during commissioning."
    DTDFVocab:provides DeviceConfigurationInsight, CommissioningEfficiencyAction
]

instance SimulationAndOptimizationService : DTDFVocab:Service [
    base:desc "Supports what-if scenario analysis (e.g., energy-saving strategies) and life cycle cost optimization leveraging BIM's semantic richness."
    DTDFVocab:provides ScenarioAnalysisInsight, LifeCycleCostOptimizationAction
]

instance CustomServiceIntegration : DTDFVocab:Service [
    base:desc "Modular architecture with standardized extension points allowing DT Engineers to develop and deploy domain-specific plugins (e.g., predictive maintenance, anomaly detection)."
    DTDFVocab:provides CustomPluginInsight, DomainSpecificAction
]

instance ControlPolicyUpdateService : DTDFVocab:Service [
    base:desc "Automated suggestions for adjusting control logic (e.g., modifying lighting schedules based on occupancy trends)."
    DTDFVocab:provides ControlPolicyUpdateInsight
]

instance StakeholderDashboardService : DTDFVocab:Service [
    base:desc "Facility managers receive actionable insights via Unreal Engine 5 visualizations enabling data-driven decision-making."
    DTDFVocab:provides RegulatoryComplianceInsight, PerformanceAnalyticsInsight
]

// C17: Insights/Actions
instance BuildingPerformanceInsight : DTDFVocab:Insight [
    base:desc "Real-time recommendations for energy-saving strategies, occupant comfort adjustments, and predictive maintenance based on current building performance metrics."
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized energy consumption strategies derived from reinforcement learning analysis of sensor data and occupancy patterns."
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Adaptive lighting strategies ensuring visual comfort and circadian rhythm alignment based on occupancy and environmental conditions."
]

instance NonVisualHealthInsight : DTDFVocab:Insight [
    base:desc "Non-visual health effects optimization (e.g., air quality, temperature) through data-driven control policy adjustments."
]

instance DeviceConfigurationInsight : DTDFVocab:Insight [
    base:desc "Automated configuration suggestions for Building Control System devices ensuring optimal performance and calibration."
]

instance OperationalOptimizationAction : DTDFVocab:Action [
    base:desc "Automated actions for real-time adjustments to building systems (e.g., HVAC, lighting) based on performance insights."
    DTDFVocab:IsAutomatic true
]

instance CommissioningEfficiencyAction : DTDFVocab:Action [
    base:desc "Automated setup and calibration of BCS devices during commissioning phase."
    DTDFVocab:IsAutomatic true
]

instance ScenarioAnalysisInsight : DTDFVocab:Insight [
    base:desc "What-if scenario analysis results for testing energy-saving strategies and their potential impact on building performance."
]

instance LifeCycleCostOptimizationAction : DTDFVocab:Action [
    base:desc "Automated optimization of life cycle costs through data-driven decision-making and scenario testing."
    DTDFVocab:IsAutomatic true
]

instance CustomPluginInsight : DTDFVocab:Insight [
    base:desc "Domain-specific insights generated by custom plugins (e.g., predictive maintenance alerts, anomaly detection results)."
]

instance DomainSpecificAction : DTDFVocab:Action [
    base:desc "Custom actions executed by domain-specific plugins (e.g., triggering maintenance workflows, adjusting control policies)."
    DTDFVocab:IsAutomatic true
]

instance ControlPolicyUpdateInsight : DTDFVocab:Insight [
    base:desc "Data-driven recommendations for refining control policies to improve energy efficiency and occupant comfort."
]

instance RegulatoryComplianceInsight : DTDFVocab:Insight [
    base:desc "Automated reporting for energy efficiency standards (e.g., LEED certification) leveraging BIM's semantic data."
]

instance PerformanceAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Historical trend analysis (e.g., energy consumption patterns, occupancy heatmaps) informing design decisions and retrofitting strategies."
]

// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Building Control System actuator for lighting fixtures enabling adaptive dimming, color tuning, and occupancy-based activation. Configured via TwinLight's BIM-centric control framework."
]

instance HvacActuator : DTDFVocab:ActingComponent [
    base:desc "Building Control System actuator for HVAC systems enabling real-time adjustments based on environmental conditions and occupancy data."
]

instance WindowBlindActuator : DTDFVocab:ActingComponent [
    base:desc "Automated window blinds actuator for dynamic shading control integrated with reinforcement learning-based adaptive strategies."
]

// C1: Modular Architecture Components
instance CentralizedDigitalTwinCore : DTDFVocab:Component [
    base:desc "Centralized configuration of the Digital Twin system managing core services and middleware integration (Eclipse Hono/Ditto)."
]

instance DecentralizedComponentTwin : DTDFVocab:Component [
    base:desc "Modular component twin representing individual building subsystems (e.g., lighting, HVAC) with localized control logic."
]

instance SharedMiddlewareLayer : DTDFVocab:Component [
    base:desc "Interoperability layer using Eclipse Hono and Ditto for bidirectional communication between physical and virtual systems."
]

// C12: Processes
instance ModelEnrichmentProcess : DTDFVocab:Process [
    base:desc "Process where Building Control Engineers extend BIM models with runtime metadata using domain-specific modeling languages."
]

instance AutomatedDeploymentProcess : DTDFVocab:Process [
    base:desc "Automated model-to-model and model-to-text transformations generating runtime artifacts for Eclipse Hono and Ditto."
]

// C2: Environment
instance BuildingInfrastructureEnvironment : DTDFVocab:Environment [
    base:desc "Physical environment representing building infrastructures (e.g., academic buildings, commercial facilities) under study."
    base:contains CentralizedDigitalTwinCore, DecentralizedComponentTwin, SharedMiddlewareLayer,
                EnvironmentalConditionSensor, OccupancySensor, EnergyConsumptionSensor,
                LightingActuator, HvacActuator, WindowBlindActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The virtual-to-physical interaction involves the transmission of **control signals and commands** from the DT back to the Building Control System (BCS) to adjust physical components (e.g., lighting systems, HVAC). This is achieved through **runtime configuration management**, allowing the DT to dynamically update control policies without requiring full redeployment. In the **BOREALIS** project, the DT iteratively refines control policies using reinforcement learning, feeding optimized commands back to the physical system. The framework ensures seamless integration of these control signals via middleware (Eclipse Hono and Ditto), enabling real-time operational adjustments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates on a **real-time time-scale**, ensuring continuous synchronization between the physical building and its digital twin. The framework supports **low-latency data exchange** via Eclipse Hono and Ditto, enabling immediate updates and responses to changes in the physical system. While specific latency metrics (e.g., millisecond-level) are not explicitly detailed, the emphasis on real-time monitoring and bidirectional communication implies sub-second synchronization for critical operational adjustments."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **DT constellation** is orchestrated as a **service-oriented architecture (SOA)** with the following components:
  1. **BIM Core**: The **semantic backbone** providing **static and runtime data** (e.g., building geometry, sensor/actuator metadata).
  2. **Middleware Layer**: **Eclipse Hono/Ditto** handle **real-time data ingestion, processing, and command execution**, acting as the **bidirectional bridge** between the physical and virtual worlds.
  3. **Visualization Layer**: **Unreal Engine 5** renders the **interactive 3D DT**, enabling **facility managers** to monitor and control the building.
  4. **Service Layer**: **Custom DT services** (e.g., RL optimization, predictive maintenance) are deployed as **microservices**, integrated via **standardized extension points**.
  5. **Deployment Pipeline**: **Model-driven transformations** automate the **generation of runtime artifacts** (e.g., Ditto configurations, Hono endpoints) from the **enriched BIM model**.
  The constellation supports **scalable deployment** across **multiple buildings** and **heterogeneous IoT ecosystems**."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the **entire building life cycle**, from **initial design** (using BIM as the static model backbone) through **construction**, **operation**, and **refurbishment/adaptation**. During the **design phase**, BIM models are enriched with runtime semantics (e.g., sensor and actuator configurations) to enable DT deployment. In the **operation phase**, the DT integrates real-time data from sensors and BCS to support monitoring, optimization, and control. The framework also accommodates **refurbishment and adaptations**, ensuring the DT remains aligned with evolving physical systems."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are assessed using the **Overall Digital Twin Entanglement (ODTE) metric**, which quantifies the alignment between the DT and its physical counterpart. The framework addresses **semantic drift** (as referenced in related work) by ensuring continuous synchronization and automated updates. Validation mechanisms include **model validation** (e.g., checking BIM metadata consistency) and **runtime monitoring** to detect discrepancies between the virtual and physical systems. The ODTE metric provides a measurable indicator of the DT's accuracy and reliability."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework adheres to **standardized integration mechanisms** and **standard compliance** for interoperability, though specific standards (e.g., IFC, bSDD) are not explicitly listed. The use of **Eclipse Hono and Ditto** ensures alignment with open-source middleware standards, while the model-driven pipeline leverages **BIM as a semantic backbone** for consistency across AECO workflows. The architecture supports **modular service integration**, enabling adherence to evolving industry standards."
]