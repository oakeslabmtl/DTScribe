    base:desc "Automated alert for sensor failures or control logic deviations"
    DTDFVocab:IsAutomatic true
]

instance LightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated lighting adjustments based on occupancy and environmental conditions"
    DTDFVocab:IsAutomatic true
]

instance HVACSetpointAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated HVAC setpoint adjustments for energy-efficient comfort"
    DTDFVocab:IsAutomatic true
