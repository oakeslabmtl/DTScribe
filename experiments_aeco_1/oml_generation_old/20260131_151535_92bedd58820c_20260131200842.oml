// C3: Physical Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "IoT sensor detecting occupancy status in building zones, integrated with BIM metadata for Hono/Ditto endpoint configuration"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "IoT sensor measuring environmental metrics (temperature, humidity, light levels) with BIM-enriched metadata for standardized data ingestion"
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

instance LightingSystemSensor : DTDFVocab:SensingComponent [
    base:desc "Building Automation System sensor monitoring lighting system status, integrated with TwinLight project for real-time control synchronization"
    DTDFVocab:producedData LightingSystemDataTransmitted
]

instance BASEnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Building Automation System sensor for HVAC and shading control metrics, configured via BIM-extracted device metadata"
    DTDFVocab:producedData BASEnvironmentalDataTransmitted
]

instance PostOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy sensor network used in BOREALIS project for iterative reinforcement learning policy refinement"
    DTDFVocab:producedData PostOccupancyDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
    base:desc "Real-time occupancy data transmitted via Eclipse Hono to Ditto device twins for live synchronization"
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
    base:desc "Environmental metrics (temperature, humidity, light) ingested through Eclipse Hono middleware for DT management"
]

instance LightingSystemDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSystemSensor
    base:desc "Lighting system status data exchanged bidirectionally via Eclipse Ditto for TwinLight adaptive control"
]

instance BASEnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BASEnvironmentalSensor
    base:desc "HVAC and shading control metrics transmitted via Eclipse Hono for real-time building control synchronization"
]

instance PostOccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PostOccupancySensor
    base:desc "Post-occupancy sensor data used in BOREALIS reinforcement learning pipeline for policy optimization"
]

// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Building Control System actuator for lighting systems, integrated with TwinLight project for bidirectional control"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC control actuator receiving real-time adjustments from DT via Eclipse Ditto middleware"
]

instance ShadingMechanismActuator : DTDFVocab:ActingComponent [
    base:desc "Shading mechanism actuator controlled through DT's adaptive comfort optimization strategies"
]

instance ReinforcementLearningController : DTDFVocab:ActingComponent [
    base:desc "BOREALIS reinforcement learning-based controller for adaptive lighting and environmental optimization"
]

// C10: Models/Data
instance BIMModel : DTDFVocab:Model [
    base:desc "Building Information Model enriched with runtime semantics including sensor configurations, control logic, and Hono/Ditto metadata"
    DTDFVocab:inputTo BIMToRuntimeTransformer, BIMMetadataExtractor
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Aggregated real-time data from IoT sensors and BCS, managed by Eclipse Ditto for bidirectional synchronization"
    DTDFVocab:fromData OccupancyDataTransmitted, EnvironmentalDataTransmitted, LightingSystemDataTransmitted, BASEnvironmentalDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance ControlModel : DTDFVocab:Model [
    base:desc "Reinforcement learning policies for adaptive lighting and comfort optimization (BOREALIS project implementation)"
    DTDFVocab:inputTo BOREALISReinforcementLearning
]

instance VisualizationModel : DTDFVocab:Model [
    base:desc "3D visualization model rendered in Unreal Engine 5 for interactive monitoring and simulation"
    DTDFVocab:inputTo UnrealEngine5
]

instance MetadataRepository : DTDFVocab:Data [
    base:desc "Central repository storing device IDs, tenant information, and endpoint addresses for seamless integration"
    DTDFVocab:inputTo DeviceConfigurationService
]

// C11: Enablers
instance BIMToRuntimeTransformer : DTDFVocab:Enabler [
    base:desc "Model-driven engineering tool automating BIM model transformation into runtime artifacts (model-to-model and model-to-text)"
    DTDFVocab:enables BIMIntegrationService
]

instance BIMMetadataExtractor : DTDFVocab:Enabler [
    base:desc "Automated extraction of sensor metadata from BIM models to configure Hono/Ditto endpoints"
    DTDFVocab:enables SensorConfigurationService
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Middleware for real-time IoT data ingestion and bidirectional communication between physical and virtual systems"
    DTDFVocab:enables IoTDataIngestionService, PhysicalVirtualSyncService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Digital twin management platform for device twin lifecycle management and standardized data exchange"
    DTDFVocab:enables DigitalTwinManagementService, ControlSignalService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Rich visualization environment for interactive 3D monitoring and simulation of building operations"
    DTDFVocab:enables VisualizationService, ImmersiveMonitoringService
]

instance BOREALISReinforcementLearning : DTDFVocab:Enabler [
    base:desc "Reinforcement learning framework enabling adaptive control strategies for energy and comfort optimization"
    DTDFVocab:enables AdaptiveControlService, EnergyOptimizationService
]

instance StandardizedExtensionPoints : DTDFVocab:Enabler [
    base:desc "Modular integration framework allowing custom services and plugins to extend DT functionality"
    DTDFVocab:enables CustomServiceIntegrationService
]

// C6: Services
instance BIMIntegrationService : DTDFVocab:Service [
    base:desc "Service automating the deployment of BIM-enriched models into runtime DT artifacts with minimal manual intervention"
    DTDFVocab:provides BIMDeploymentInsight
]

instance SensorConfigurationService : DTDFVocab:Service [
    base:desc "Service automating sensor metadata extraction from BIM to configure Hono/Ditto endpoints"
    DTDFVocab:provides SensorConfigurationInsight
]

instance IoTDataIngestionService : DTDFVocab:Service [
    base:desc "Service handling real-time sensor data ingestion through Eclipse Hono middleware"
    DTDFVocab:provides DataIngestionInsight
]

instance DigitalTwinManagementService : DTDFVocab:Service [
    base:desc "Service managing device twin lifecycle and bidirectional communication via Eclipse Ditto"
    DTDFVocab:provides TwinLifecycleInsight
]

instance PhysicalVirtualSyncService : DTDFVocab:Service [
    base:desc "Service ensuring continuous synchronization between physical building and virtual DT"
    DTDFVocab:provides SyncStatusInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service providing real-time 3D visualization of building operations in Unreal Engine 5"
    DTDFVocab:provides VisualizationInsight
]

instance ImmersiveMonitoringService : DTDFVocab:Service [
    base:desc "Service enabling interactive 3D monitoring for facility managers"
    DTDFVocab:provides MonitoringInsight
]

instance AdaptiveControlService : DTDFVocab:Service [
    base:desc "Service implementing BOREALIS reinforcement learning for adaptive lighting and comfort control"
    DTDFVocab:provides AdaptiveControlInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing energy consumption through RL-based control strategies"
    DTDFVocab:provides EnergyOptimizationInsight
]

instance CustomServiceIntegrationService : DTDFVocab:Service [
    base:desc "Service enabling modular integration of custom domain-specific plugins"
    DTDFVocab:provides IntegrationInsight
]

instance ControlSignalService : DTDFVocab:Service [
    base:desc "Service managing bidirectional control signals between DT and physical BCS actuators"
    DTDFVocab:provides ControlSignalInsight
]

instance DeviceConfigurationService : DTDFVocab:Service [
    base:desc "Service managing device metadata and endpoint configurations from BIM-extracted data"
    DTDFVocab:provides DeviceConfigurationInsight
]

// C17: Insights/Actions
instance BIMDeploymentInsight : DTDFVocab:Insight [
    base:desc "Validation status and deployment readiness of BIM-enriched DT artifacts"
]

instance SensorConfigurationInsight : DTDFVocab:Insight [
