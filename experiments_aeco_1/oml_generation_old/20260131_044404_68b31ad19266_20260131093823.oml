// ---- C3: Physical Sensing Components ----
instance PhotometricSensor : DTDFVocab:SensingComponent [
    base:desc "Photometric sensor (Device ID PH1) in LivingLab, routed via Eclipse Hono with tenant info."
    DTDFVocab:producedData PhotometricDataTransmitted
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy/Presence detector (Device ID OD1) in LivingLab, routed via Eclipse Hono with tenant info."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor (Device ID TS1) in LivingLab, routed via Eclipse Hono with tenant info."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor (Device ID HS1) in LivingLab, routed via Eclipse Hono with tenant info."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance MotionSensor : DTDFVocab:SensingComponent [
    base:desc "Motion sensor (Device ID MS1) in LivingLab, routed via Eclipse Hono with tenant info."
    DTDFVocab:producedData MotionDataTransmitted
]

instance PowerMeter : DTDFVocab:SensingComponent [
    base:desc "Power meter (Device ID PM1) in LivingLab, routed via Eclipse Hono with tenant info."
    DTDFVocab:producedData PowerMeterDataTransmitted
]

// ---- C4: Physical‑to‑Virtual Interaction ----
instance PhotometricDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhotometricSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance MotionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionSensor
]

instance PowerMeterDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerMeter
]

// ---- C4 continued: Data Instances ----
instance PhotometricSensorData : DTDFVocab:Data [
    base:desc "Photometric sensor telemetry stream in JSON format."
    DTDFVocab:fromData PhotometricDataTransmitted
    DTDFVocab:inputTo ReinforcementLearningFrameworkEnabler
]

instance OccupancySensorData : DTDFVocab:Data [
    base:desc "Occupancy detector telemetry stream in JSON format."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance TemperatureSensorData : DTDFVocab:Data [
    base:desc "Temperature sensor telemetry stream in time‑series JSON."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo InfluxDBEnabler
]

instance HumiditySensorData : DTDFVocab:Data [
    base:desc "Humidity sensor telemetry stream in time‑series JSON."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo InfluxDBEnabler
]

instance MotionSensorData : DTDFVocab:Data [
    base:desc "Motion sensor telemetry stream in JSON."
    DTDFVocab:fromData MotionDataTransmitted
    DTDFVocab:inputTo InfluxDBEnabler
]

instance PowerMeterSensorData : DTDFVocab:Data [
    base:desc "Power meter telemetry stream in JSON."
    DTDFVocab:fromData PowerMeterDataTransmitted
    DTDFVocab:inputTo InfluxDBEnabler
]

// ---- Deployable Services (added for reference resolution) ----
instance TelemetryRoutingService : DTDFVocab:Service [
    base:desc "Service responsible for routing telemetry via Eclipse Hono."
]

instance TwinRegistryService : DTDFVocab:Service [
    base:desc "Service for twin registration in Eclipse Ditto."
]

instance TwinCreationService : DTDFVocab:Service [
    base:desc "Service to create twins from BIM annotations."
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Service for deploying microservices on Docker/Kubernetes."
]

// ---- C11: Enablers ----
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware for MQTT/HTTP routing of device telemetry."
    DTDFVocab:enables TelemetryRoutingService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin registry and realtime data bus."
    DTDFVocab:enables TwinRegistryService, HVACSchedulingService
]

instance ModelDrivenPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline converting augmented IFC to Ditto twin descriptors."
    DTDFVocab:enables TwinCreationService
]

instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database for storing raw sensor data."
    DTDFVocab:enables PredictiveAnalyticsMicroservice
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime for immersive 3D visualization."
    DTDFVocab:enables UnrealImmersiveVisualizationService
]

instance DockerKubernetesEnabler : DTDFVocab:Enabler [
    base:desc "Docker/Kubernetes container orchestration for microservice deployment."
    DTDFVocab:enables DeploymentService
]

instance ReinforcementLearningFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "OpenAI Gym/TensorFlow reinforcement learning framework integrated with BOREALIS."
    DTDFVocab:enables LeaseBasedLightingOptimizationService
]

instance BOREALISServiceEnabler : DTDFVocab:Enabler [
    base:desc "BOREALIS policy engine for continuous learning and runtime configuration."
    DTDFVocab:enables RuntimeConfigurationService
]

// ---- C6: Services ----
instance LeaseBasedLightingOptimizationService : DTDFVocab:Service [
    base:desc "Lease‑based lighting optimization service that predicts energy savings using reinforcement learning."
    DTDFVocab:provides EnergyConsumptionForecastInsight, LightingSetpointRecommendationInsight
]

instance HVACSchedulingService : DTDFVocab:Service [
    base:desc "HVAC load‑balancing scheduling service."
    DTDFVocab:provides HVACLoadScheduleInsight, AdjustHVACScheduleAction
]

instance UnrealImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "3‑D immersive visualization service built on Unreal Engine 5."
    DTDFVocab:provides VisualSceneInsight
]

instance PredictiveAnalyticsMicroservice : DTDFVocab:Service [
    base:desc "Predictive analytics microservice in Python/Node.js that ingests sensor time‑series and outputs anomaly alerts."
    DTDFVocab:provides AnomalyAlertInsight, MaintenanceBacklogSuggestionInsight
]

instance RuntimeConfigurationService : DTDFVocab:Service [
    base:desc "Runtime configuration service that updates device metadata dynamically via BOREALIS."
    DTDFVocab:provides UpdateDeviceMetadataAction
]

// ---- C17: Insights ----
instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Insight providing comparative energy consumption forecasts and recommended lighting setpoints."
]

instance LightingSetpointRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal lighting setpoints based on reinforcement learning prediction."
]

instance HVACLoadScheduleInsight : DTDFVocab:Insight [
    base:desc "Insight detailing HVAC load schedules for load balancing across building zones."
]

instance AnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Alert insight indicating potential equipment failures detected by sensor time‑series analysis."
]

instance MaintenanceBacklogSuggestionInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting maintenance backlog priorities derived from anomaly alerts."
]

instance VisualSceneInsight : DTDFVocab:Insight [
    base:desc "Insight exposing the current 3‑D immersive visual state of the building in Unreal Engine 5."
]

// ---- C17: Actions ----
instance AdjustLightingSetpointAction : DTDFVocab:Action [
    base:desc "Action to automatically adjust lighting setpoints in real time."
    DTDFVocab:IsAutomatic true
]

instance AdjustHVACScheduleAction : DTDFVocab:Action [
    base:desc "Action to automatically adjust HVAC schedules based on load predictions."
    DTDFVocab:IsAutomatic true
]

instance UpdateDeviceMetadataAction : DTDFVocab:Action [
    base:desc "Action to update device metadata dynamically through BOREALIS."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control logic, formulated in either deterministic rule sets or reinforcement‑learning policies, emits actuator commands (e.g., setpoint adjustments, on/off signals) which are serialized as JSON, routed through the Ditto twin registry, and delivered to the building’s BCS via Hono’s outbound MQTT topics, effecting real‑time device state changes."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous live synchronization with sub‑second latency, leveraging Hono’s low‑latency MQTT transport; service APIs are invoked via REST/HTTP with JSON payloads at configurable polling intervals (default 1 s) and can be stretched to higher rates (down to 10 ms for sensor bursts) when required."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin constellation consists of the BIM‑derived central building twin, the Ditto ecosystem hosting twin entities, Hono gateways acting as device proxies, Unreal Engine visualization front‑end, and specialized micro‑services (light optimizer, HVAC scheduler, analytics) all orchestrated through a lightweight message broker and orchestrated via Kubernetes deployments."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the full asset lifecycle— (a) design‑time, where the IFC/BIM model represents the ideal building geometry and asset catalog; (b) construction‑time, wherein the as‑built BIM model is augmented with fabrication data and device coordinates; and (c) operation‑time, where live telemetry populates the twin, allowing simulation and optimization of the operating configuration."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validity is enforced through BIM schema conformance checks, runtime data type validation in Ditto, and ODTE metric calculations to quantify twin entanglement; semantic drift is mitigated by periodic synchronization checkpoints that compare BIM attributes against live device metadata; error handling is performed by Hono’s persistence queues and Ditto’s delta monitoring."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The physical–virtual communication stack comprises: (a) device firmware publishing to MQTT topics via Eclipse Hono; (b) Hono’s gateway extracting payloads and routing to Ditto twin registry over HTTP; (c) Ditto managing twin state in a distributed database (e.g., Cassandra) and exposing a REST/CoAP API; (d) Unreal Engine consuming reference coordinates via WebSocket for real‑time visualization; all secured using TLS 1.3 and mutual authentication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire architecture is deployed in a containerised micro‑service ecosystem orchestrated by Kubernetes; Hono, Ditto, InfluxDB, and the reinforcement‑learning service run in Docker containers on a private cloud; the Unreal Engine front‑end is hosted on a Windows/UE5 dedicated instance with a GPU; scalability is achieved via horizontal pod autoscaling."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework adheres to open interoperability standards: IFC for building data, MQTT for message transport, HTTP/REST for APIs, and JSON for payloads; in addition, unidirectional control logic follows the one‑time pad standards for device identity protocols."
]