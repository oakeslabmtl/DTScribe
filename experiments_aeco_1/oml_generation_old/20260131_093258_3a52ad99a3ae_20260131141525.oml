// Sensing component
instance PostOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy sensor capturing environmental metrics within the Living Lab academic building"
    DTDFVocab:producedData PostOccupancyTelemetry
]

// Data transmitted by the sensor
instance PostOccupancyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PostOccupancySensor
]

// Telemetry data received by the twin
instance PostOccupancyTelemetryData : DTDFVocab:Data [
    base:desc "Continuous stream of post-occupancy sensor telemetry collected via Eclipse Hono"
    DTDFVocab:inputTo EclipseHono, EclipseDitto
    DTDFVocab:fromData PostOccupancyTelemetry
]

// IC-based BIM model enriched with runtime semantics
instance IFCBasedBIMModel : DTDFVocab:Model [
    base:desc "IFC-based BIM model enriched with runtime semantics for the Living Lab building"
    DTDFVocab:inputTo BIMAuthoringTools, ModelDrivenEngineeringTools, EclipseDitto
]

// JSON representation of the virtual twin
instance VirtualTwinJSONData : DTDFVocab:Data [
    base:desc "JSON representations of the virtual twin managed by Eclipse Ditto"
    DTDFVocab:inputTo EclipseDitto, UnrealEngine5
    DTDFVocab:fromData PostOccupancyTelemetry
]

// Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides IoT messaging for sensor telemetry"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, AdaptiveLightingControlService, AutomatedCommissioningService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages device twin representations and communications"
    DTDFVocab:enables RealTimeMonitoringService, PerformanceSimulationService, InteractiveVisualizationService, AdaptiveLightingControlService, AutomatedCommissioningService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 offers real-time 3D visualization of the building"
    DTDFVocab:enables InteractiveVisualizationService
]

instance BIMAuthoringTools : DTDFVocab:Enabler [
    base:desc "BIM authoring tools create and enrich IFC models with control semantics"
    DTDFVocab:enables PerformanceSimulationService
]

instance ModelDrivenEngineeringTools : DTDFVocab:Enabler [
    base:desc "Model-driven engineering tools auto-generate runtime artifacts from the BIM model"
    DTDFVocab:enables PerformanceSimulationService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of environmental metrics through sensor telemetry"
    DTDFVocab:provides AnomalyDetectionInsight
]

instance PerformanceSimulationService : DTDFVocab:Service [
    base:desc "Performance simulation via enriched BIM model"
    DTDFVocab:provides PerformanceSimulationInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization in Unreal Engine 5"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy optimization using sensor telemetry"
    DTDFVocab:provides EnergyConsumptionForecastInsight
]

instance AdaptiveLightingControlService : DTDFVocab:Service [
    base:desc "Adaptive lighting control based on reinforcement-learning"
    DTDFVocab:provides AdaptiveLightingControlAction
]

instance AutomatedCommissioningService : DTDFVocab:Service [
    base:desc "Automated commissioning workflows integrated with twin"
    DTDFVocab:provides CommissioningWorkflowInsight
]

// Insights
instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection in environmental metrics"
]

instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of future energy consumption"
]

instance PerformanceSimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results for building performance"
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of building state"
]

instance CommissioningWorkflowInsight : DTDFVocab:Insight [
    base:desc "Insights from automated commissioning processes"
]

// Action
instance AdaptiveLightingControlAction : DTDFVocab:Action [
    base:desc "Reinforcement-learning based adaptive lighting control action"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., light intensity adjustments) are transmitted back to the Building Control System (BCS) through Ditto messages, enabling bidirectional actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Synchronisation operates in real time with data throughput in the millisecond to sub‑second range, as dictated by Eclipse Hono’s event‑driven messaging and Ditto’s twin update mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A cohesive orchestration comprising a central Ditto hub, Hono middleware, device twins representing physical assets, simulation modules for BIM-based performance, and a visualization subsystem built on Unreal Engine, all connected via standardized APIs."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (BIM creation), Construction (device installation and metadata enrichment), Operation (runtime monitoring and control), and Adaptation (continuous evolution through reinforcement learning)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Assessment of twin fidelity via the ODTE metric, monitoring of semantic drift, and synchronization integrity checks between physical and virtual states."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to BIM IFC standards for model representation, use of open protocols (MQTT, JSON, HTTP) through Hono/Ditto, and alignment with AECO industry best practices for data integration."
]