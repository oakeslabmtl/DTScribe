// C2: Acting Components
instance DimmableLEDFixture : DTDFVocab:ActingComponent [
    base:desc "Dimmable LED lamp fixture actuated via Eclipse Hono/Ditto messaging for adaptive lighting control"
]

instance SwitchControl : DTDFVocab:ActingComponent [
    base:desc "Physical switch controlling lighting fixture power, integrated into BIM and activated through Ditto"
]

// C3: Physical sensing components
instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient light level sensor modeled in BIM and transmitting data via Eclipse Hono/Ditto for real‑time processing"
    DTDFVocab:producedData LightLevelDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM to detect presence and transmit data through Hono/Ditto middleware"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient temperature sensor modeled in BIM, sending data via Hono/Ditto for real‑time monitoring"
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Physical-to-virtual interaction
instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C10: Models/Data
instance LightLevelData : DTDFVocab:Data [
    base:desc "Live light level data stream from LightLevelSensor via Hono/Ditto"
    DTDFVocab:fromData LightLevelDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy data stream from OccupancySensor via Hono/Ditto"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature data stream from TemperatureSensor via Hono/Ditto"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance BIMSemanticModel : DTDFVocab:Model [
    base:desc "Semantic BIM model augmented with control element metadata for the Living Lab academic building"
    DTDFVocab:inputTo TransformationPipelineEnabler
]

instance RuntimeDeviceConfigurationModel : DTDFVocab:Model [
    base:desc "Runtime device configuration model for actuated lighting fixtures and control elements"
    DTDFVocab:inputTo TransformationPipelineEnabler
]

instance ControlLogicScriptModel : DTDFVocab:Model [
    base:desc "Control logic scripts governing adaptive lighting behavior"
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance EnergyConsumptionSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of building energy consumption for evaluating adaptive lighting strategies"
    DTDFVocab:inputTo TransformationPipelineEnabler
]

instance ReinforcementLearningPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement learning policy model used for lighting control optimization"
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C11: Enablers
instance EclipseModelingFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Modeling Framework for model‑driven engineering of the digital twin"
]

instance TransformationPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Transformation pipelines converting enriched BIM models into runtime artifacts via Hono/Ditto"
]

instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware for ingesting real‑time sensor data streams"
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for routing data and managing digital twin instances"
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive visualization of the digital twin"
]

// C6: Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Live monitoring dashboard displaying real‑time building performance"
    DTDFVocab:provides LivePerformanceDashboardInsight
]

instance EnergySimulationService : DTDFVocab:Service [
    base:desc "Simulates building energy consumption under varying lighting scenarios"
    DTDFVocab:provides EnergyConsumptionProjectionInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Provides predictive analytics for lighting control based on sensor data"
    DTDFVocab:provides LightingControlPredictiveInsight
]

instance RLPolicyOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement learning policy optimization for lighting control"
    DTDFVocab:provides PolicyOptimizationInsight, SetActuatorSetpointsAction
]

instance UnrealVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization of the building state using Unreal Engine 5"
    DTDFVocab:provides ImmersiveVisualizationInsight
]

// C17: Insights/Actions
instance LivePerformanceDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time performance data displayed on the monitoring dashboard"
]

instance EnergyConsumptionProjectionInsight : DTDFVocab:Insight [
    base:desc "Projected energy savings from adaptive lighting strategies"
]

instance LightingControlPredictiveInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics results for future lighting control scenarios"
]

instance PolicyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insights derived from reinforcement learning policy optimization"
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive visualization rendering of building state in Unreal Engine 5"
]

instance SetActuatorSetpointsAction : DTDFVocab:Action [
    base:desc "Recommended actuator set‑points for lighting fixtures based on optimization insights"
    DTDFVocab:IsAutomatic false
]

// C1: Environment
instance LivingLabEnvironment : DTDFVocab:Environment [
    base:contains DimmableLEDFixture, SwitchControl, LightLevelSensor, OccupancySensor, TemperatureSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., light level adjustments) are transmitted back to physical lighting devices via Hono/Ditto, enabling closed‑loop operation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time, continuous synchronization with latency typically in the order of seconds, enabling near‑instantaneous updates between the DT and the physical building."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated stack comprising the BIM‑derived semantic layer, the Hono/Ditto middleware for bi‑directional data exchange, runtime control logic engines, simulation modules, and the Unreal Engine visualization layer, all tied together through defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin supports the full life‑cycle of the building—from designed (BIM model), through construction (manufactured data integration), to operation (live sensor data and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Verification of BIM semantics through model validation, runtime synchronization assessed with the Overall Digital Twin Entanglement (ODTE) metric, and continuous synchronization to mitigate semantic drift."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono serving as the message broker and Eclipse Ditto as the device twin registry, facilitating bidirectional messaging of sensor data and control commands between the DT and the physical building."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Building Information Modeling (BIM) standards as the semantic backbone; adherence to Model‑Driven Engineering practices; no explicit industry‑wide standard for twin interfaces noted."
]