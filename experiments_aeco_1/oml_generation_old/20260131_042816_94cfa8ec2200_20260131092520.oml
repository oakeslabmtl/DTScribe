// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy temperature sensor embedded in BIM, providing real‑time temperature data"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy humidity sensor embedded in BIM, providing real‑time humidity data"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy CO2 sensor embedded in BIM, providing real‑time CO2 concentration data"
    DTDFVocab:producedData CO2DataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy light‑level sensor embedded in BIM, providing real‑time illumination data"
    DTDFVocab:producedData LightLevelDataTransmitted
]

// C4: Data transmitted from sensors
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

// C5: Data instances flowing into enablers
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature data ingested via MQTT/AMQP through Eclipse Hono middleware"
    DTDFVocab:inputTo HonoMiddlewareEnabler
    DTDFVocab:fromData TemperatureDataTransmitted
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity data ingested via MQTT/AMQP through Eclipse Hono middleware"
    DTDFVocab:inputTo HonoMiddlewareEnabler
    DTDFVocab:fromData HumidityDataTransmitted
]

instance CO2Data : DTDFVocab:Data [
    base:desc "CO2 data ingested via MQTT/AMQP through Eclipse Hono middleware"
    DTDFVocab:inputTo HonoMiddlewareEnabler
    DTDFVocab:fromData CO2DataTransmitted
]

instance LightLevelData : DTDFVocab:Data [
    base:desc "Light‑level data ingested via MQTT/AMQP through Eclipse Hono middleware"
    DTDFVocab:inputTo HonoMiddlewareEnabler
    DTDFVocab:fromData LightLevelDataTransmitted
]

// C1: Enablers
instance HonoMiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware enabling real‑time data ingestion via MQTT/AMQP from physical twin to digital twin"
    DTDFVocab:enables RealTimeDataIngestionService
]

instance DittoConfiguratorEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto configurator enabling state synchronization and dashboard configuration"
    DTDFVocab:enables MonitoringDashboardService
]

instance MDETransformationEnabler : DTDFVocab:Enabler [
    base:desc "MDE tooling enabling transformation of BIM IFC models into executables via model‑to‑text"
    DTDFVocab:enables ModelCompilationService
]

instance TwinLightControlEnabler : DTDFVocab:Enabler [
    base:desc "TwinLight control configuration enabler for actuating lighting and HVAC devices"
    DTDFVocab:enables LightingControlService
]

instance UnrealEngine5VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 visualization enabler rendering immersive 3‑D digital twin"
    DTDFVocab:enables ImmersiveVisualizationService
]

// C6: Services
instance RealTimeDataIngestionService : DTDFVocab:Service [
    base:desc "Service that processes sensor data ingested by Eclipse Hono"
    DTDFVocab:provides DataIngestionHealthInsight
]

instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Service that collects and displays real‑time system status via dashboards"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance EnergySimulationService : DTDFVocab:Service [
    base:desc "Service performing energy consumption simulation using BIM IFC model and sensor data"
    DTDFVocab:provides EnergySimulationResultInsight
]

instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Service applying reinforcement‑learning algorithms to optimize lighting control"
    DTDFVocab:provides LightingOptimizationResultInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Service rendering the digital twin in immersive 3‑D via Unreal Engine 5"
    DTDFVocab:provides ImmersiveModelInsight
]

instance ModelCompilationService : DTDFVocab:Service [
    base:desc "Service compiling BIM IFC and control logic models into executable artifacts"
    DTDFVocab:provides CompiledArtifactsInsight
]

instance LightingControlService : DTDFVocab:Service [
    base:desc "Service executing lighting dimmer adjustments based on TwinLight control configurations"
    DTDFVocab:provides AdjustLightingAction
]

// C7: Insights and Actions
instance DataIngestionHealthInsight : DTDFVocab:Insight [
    base:desc "Insight reporting health and latency of sensor data ingestion"
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time status of building systems via dashboards"
]

instance EnergySimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight containing results of building energy consumption simulation"
]

instance LightingOptimizationResultInsight : DTDFVocab:Insight [
    base:desc "Insight containing optimal lighting control recommendations from reinforcement‑learning algorithm"
]

instance ImmersiveModelInsight : DTDFVocab:Insight [
    base:desc "Insight showcasing immersive 3‑D visualization of the building"
]

instance CompiledArtifactsInsight : DTDFVocab:Insight [
    base:desc "Insight reporting success and details of compiled executable artifacts from MDE transformation"
]

instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Action to adjust lighting dimmer levels via TwinLight control configuration"
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance LightingDimmer : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator integrated in BIM, controlled through TwinLight"
]

instance HVACControlValve : DTDFVocab:ActingComponent [
    base:desc "HVAC control valve actuator integrated in BIM, controlled through TwinLight"
]

// C10: Models
instance BIMIFCSchemaModel : DTDFVocab:Model [
    base:desc "BIM IFC schema model representing the building structure"
    DTDFVocab:inputTo MDETransformationEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Converted control logic model derived from BIM with embedded device semantics"
    DTDFVocab:inputTo MDETransformationEnabler
]

instance RuntimeDataModel : DTDFVocab:Model [
    base:desc "Runtime data model of sensor streams and actuator states compiled into executable artifacts"
    DTDFVocab:inputTo MDETransformationEnabler
]

// C17: Environment
instance LivingLabBuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, HumiditySensor, CO2Sensor, LightLevelSensor, LightingDimmer, HVACControlValve, BIMIFCSchemaModel, ControlLogicModel, RuntimeDataModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals emitted by the digital twin through Ditto’s device management layer, translated into actuator commands (e.g., lighting brightness, HVAC setpoint) and transmitted over the same MQTT/AMQP channels to the physical building devices."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central orchestration hub that ingests BIM‑derived device metadata, publishes sensor data to Ditto, drives simulation services, and exposes visualization endpoints via Unreal Engine, forming a modular, service‑oriented DT ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers all life‑cycle stages of the building—design (ideal BIM), construction (as‑built model), and operation (as‑operated data), enabling continuous lifecycle optimization."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Quantitative assessment using the Overall Digital Twin Entanglement (ODTE) metric to evaluate the synchronicity between the digital model and the physical assets, and ongoing verification of sensor data against the embedded control logic."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Network architecture relies on Eclipse Hono as MQTT/AMQP broker for sensor streams and Ditto’s RESTful/WebSocket API for device state updates, enabling low‑latency, bi‑directional communication between PT and DT."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Extensible integration layer allows connection to external building management systems and enterprise resource planning platforms via standard APIs, facilitating cross‑system data exchange beyond the DT itself."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to IFC-based BIM standards, standard MQTT/AMQP protocols, Eclipse open‑source stacks, and the use of the ODTE metric for entanglement assessment."
]