// Sensing Components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor embedded in enriched BIM model, capturing real‑time illumination levels."
    DTDFVocab:producedData LightTelemetry
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in enriched BIM model, capturing real‑time ambient temperature."
    DTDFVocab:producedData TemperatureTelemetry
]

// Data Transmitted
instance LightTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance TemperatureTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// Data
instance LightData : DTDFVocab:Data [
    base:desc "Aggregated real‑time light level data received via MQTT through Eclipse Hono and stored in Eclipse Ditto."
    DTDFVocab:fromData LightTelemetry
    DTDFVocab:inputTo DBSynchEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Aggregated real‑time temperature data received via MQTT through Eclipse Hono and stored in Eclipse Ditto."
    DTDFVocab:fromData TemperatureTelemetry
    DTDFVocab:inputTo DBSynchEnabler
]

// Enabler
instance DBSynchEnabler : DTDFVocab:Enabler [
    base:desc "Real‑time data exchange and synchronization enabler using Eclipse Hono for MQTT messaging and Eclipse Ditto for device state management."
    DTDFVocab:enables MonitoringService, ControlService, PredictionService, OptimizationService, VisualizationService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that captures sensor data to continuously monitor building operation."
    DTDFVocab:provides OperationalStatusInsight, PerformanceTrendInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Service allowing Facility Managers to interactively control building systems through immersive interfaces."
    DTDFVocab:provides ControlLightingAction, ControlHVACAction, OverrideControlAction
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Service that uses synchronized data to forecast performance and detect anomalies."
    DTDFVocab:provides AnomalyDetectionInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that leverages predictive insights to recommend operational adjustments to reduce costs and improve efficiency."
    DTDFVocab:provides CostEfficiencyOptimizationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that provides interactive, immersive dashboards displaying building state, trends, and control actions."
    DTDFVocab:provides DashboardInsight
]

// Insights
instance OperationalStatusInsight : DTDFVocab:Insight [
    base:desc "Insight showing current operational status of building systems derived from live telemetry."
]

instance PerformanceTrendInsight : DTDFVocab:Insight [
    base:desc "Insight depicting performance trends over time extracted from historical data streams."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating anomalous events detected via predictive analytics."
]

instance CostEfficiencyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending cost‑saving operational adjustments based on optimization analysis."
]

instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Insight representing the immersive dashboard visualizing building state and controls."
]

// Actions
instance ControlLightingAction : DTDFVocab:Action [
    base:desc "Action to override lighting control logic and set desired illumination levels."
    DTDFVocab:IsAutomatic false
]

instance ControlHVACAction : DTDFVocab:Action [
    base:desc "Action to override HVAC control logic and set desired temperature setpoints."
    DTDFVocab:IsAutomatic false
]

instance OverrideControlAction : DTDFVocab:Action [
    base:desc "Action enabling Facility Managers to manually override automated control loops."
    DTDFVocab:IsAutomatic false
]

// Acting Components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Digital twin component mapped to the physical light actuator, interfacing via Ditto for command transmission."
]

instance HVACTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Digital twin component mapped to the physical HVAC actuator, interfacing via Ditto for command transmission."
]

// Environment
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains LightTwinComponent, HVACTwinComponent
]

// Component
instance PhysicalBuilding : DTDFVocab:Component [
    base:desc "Commercial building modeled in BIM, instrumented with sensors, actuators, and controllers."
]

// Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM representation containing device descriptors for sensors, actuators, and controllers."
    DTDFVocab:inputTo DBSynchEnabler
]

instance DeviceConfigModel : DTDFVocab:Model [
    base:desc "Configuration model deriving from the enriched BIM and targeting middleware (Ditto) and event storage."
    DTDFVocab:inputTo DBSynchEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "While the documented framework supports bidirectional data exchange, the specific control flow from the digital twin to physical building systems—encompassing command types, control message formats, validation and authentication procedures, feedback loops, conflict resolution strategies, or command execution confirmation mechanisms—are not described within the provided texts."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange enables continuous synchronization between the physical building and its digital counterpart; the architecture is designed for sub‑second latency, though explicit update frequencies are not provided in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT system is organized as a modular, service‑oriented framework with standardized extension points; runtime configuration management allows dynamic adjustment of services; bidirectional data flows between embedded sensors, BIM models, and control layers are orchestrated through the central hub, enabling holistic building life‑cycle management from design to operations."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a four‑stage lifecycle: (1) Device Modeling and Control Logic Definition within BIM, where sensors, actuators, and controllers are added to the BIM model; (2) Model‑Driven Extraction, where MDE principles transform the enriched BIM into structured representations stored in a semantic repository; (3) Deployment, where deployable DT artifacts (code, configuration, services) are automatically generated from the structured model with minimal manual effort; and (4) Runtime Operation, where real‑time data exchange keeps the physical building and its twin continuously synchronised, enabling monitoring, control and iterative evolution through modular extension points. Transition management relies on versioned MDE transformations and governance is supported by the modular architecture and standardized extension points."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by a multi‑stage validation pipeline: BIM enrichment undergoes schema validation, while runtime data is verified against Ditto’s policy engine that enforces acceptable value ranges and units. Real‑time data exchange is guaranteed by Eclipse Hono’s at‑least‑once message delivery, ensuring no information loss across network disruptions. Ditto’s persistent event storage provides fault tolerance and auditability of sensor streams. Pre‑execution checks on actuator commands detect and correct operation conflicts before the command is sent to the physical device, maintaining synchronization and operational safety. Overall, the framework adopts a service‑oriented architecture with modular extension points, allowing the continuous refinement of model‑data fidelity through iterative validation and verification steps."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The documentation references interoperability across heterogeneous systems and a modular architecture with standardized extension points, yet it does not provide details on the underlying communication protocols (e.g., MQTT, AMQP), network topology or architecture, bandwidth and latency requirements, reliability or redundancy mechanisms, or security protocols governing the data exchanges."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The documents mention runtime configuration management and modular architecture that enable adjustments without full redeployment, but they do not specify hosting platforms (cloud, edge, or on‑premise), computational or storage requirements, scalability mechanisms, supported deployment models, or availability and reliability guarantees for the digital twin system."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved via high‑level interoperability standards at the software architecture layer, employing standardized data exchange points for enriched BIM models and other domain services; specific protocols (e.g., OPC UA, MQTT) or enterprise integration patterns are not delineated in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework aligns with industry BIM standards for model representation and leverages model‑driven engineering (MDE) for transformation; it facilitates interoperability through real‑time data exchange protocols and bidirectional communication, referencing open‑source DT frameworks such as Eclipse Ditto and BaSyx for connectivity and standard compliance, while noting that AECO‑specific solutions like Bentley iTwin.js rely on proprietary ecosystems, underscoring the need for standardized data schemas and integration mechanisms."
]