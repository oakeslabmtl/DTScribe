// C3: Physical sensing components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for lighting measurements modeled in BIM, streaming data via Eclipse Hono"
    DTDFVocab:producedData LightingSensorDataTransmission
]

instance LightingSensorDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance LightingSensorData : DTDFVocab:Data [
    base:desc "Live lighting measurement data streamed from the building"
    DTDFVocab:fromData LightingSensorDataTransmission
    DTDFVocab:inputTo EclipseHonoBroker, EclipseDittoPlatform
]

instance EnvironmentalConditionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for environmental conditions (temperature, humidity, CO₂) modeled in BIM, data streamed via Eclipse Hono"
    DTDFVocab:producedData EnvironmentalConditionSensorDataTransmission
]

instance EnvironmentalConditionSensorDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalConditionSensor
]

instance EnvironmentalConditionData : DTDFVocab:Data [
    base:desc "Live environmental condition measurements"
    DTDFVocab:fromData EnvironmentalConditionSensorDataTransmission
    DTDFVocab:inputTo EclipseHonoBroker, EclipseDittoPlatform
]

instance BuildingControlSystemSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for building‑control‑system measurements (e.g., occupancy, valve positions) modeled in BIM"
    DTDFVocab:producedData BuildingControlSystemSensorDataTransmission
]

instance BuildingControlSystemSensorDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingControlSystemSensor
]

instance BuildingControlSystemData : DTDFVocab:Data [
    base:desc "Data from building control system devices"
    DTDFVocab:fromData BuildingControlSystemSensorDataTransmission
    DTDFVocab:inputTo EclipseHonoBroker, EclipseDittoPlatform
]

// C2: Acting components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuating component for building lighting, modeled in BIM and exposed via twin APIs"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator controlling heating, ventilation, and cooling, modeled in BIM"
]

instance ControlDevice : DTDFVocab:ActingComponent [
    base:desc "General control device for building automation, modeled in BIM"
]

// C11: Enablers
instance EclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono messaging broker handling bidirectional streaming of sensor measurements"
    DTDFVocab:enables RealTimeMonitoringService, EnergyOptimizationService, PredictiveAnalyticsService, SimulationService, VisualizationService, CustomExtensionService
]

instance EclipseDittoPlatform : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin platform synchronizing incoming data and exposing twin APIs"
    DTDFVocab:enables RealTimeMonitoringService, EnergyOptimizationService, PredictiveAnalyticsService, SimulationService, VisualizationService, CustomExtensionService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real-time monitoring dashboards and status overviews"
    DTDFVocab:provides StatusDashboardInsight, EnergyConsumptionTrendInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes energy consumption based on live sensor data and predictive models"
    DTDFVocab:provides OptimizationRecommendationInsight, AdjustHVACAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Runs predictive analytics to forecast building performance and generate alerts"
    DTDFVocab:provides PredictiveAlertInsight, TriggerPredictiveAlertAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Executes simulation models for scenario analysis"
    DTDFVocab:provides SimulationResultInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Renders 3‑D visualization of the twin in Unreal Engine 5"
    DTDFVocab:provides VisualizationInsight
]

instance CustomExtensionService : DTDFVocab:Service [
    base:desc "Allows integration of custom services via standardized extension points"
    DTDFVocab:provides CustomExtensionInsight
]

// C17: Insights
instance StatusDashboardInsight : DTDFVocab:Insight [
    base:desc "Real-time status dashboard for facility managers"
]

instance EnergyConsumptionTrendInsight : DTDFVocab:Insight [
    base:desc "Trend analysis of building energy consumption"
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for reducing energy usage"
]

instance PredictiveAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive alerts for potential faults or inefficiencies"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Provides results from simulation runs for decision support"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3‑D visualization of building state in Unreal Engine 5"
]

instance CustomExtensionInsight : DTDFVocab:Insight [
    base:desc "Insight generated by custom extension services"
]

// C17: Actions
instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Automatically adjusts HVAC setpoints based on optimization recommendations"
    DTDFVocab:IsAutomatic true
]

instance TriggerPredictiveAlertAction : DTDFVocab:Action [
    base:desc "Triggers alert notifications to facility managers when predictive conditions are met"
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance BIMInformationModel : DTDFVocab:Model [
    base:desc "Core BIM information model enriched with device definitions and control logic"
    DTDFVocab:inputTo EclipseDittoPlatform
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Runtime semantics representing control logic derived from BIM"
    DTDFVocab:inputTo EclipseDittoPlatform
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulation model used for analysis and scenario testing"
    DTDFVocab:inputTo EclipseDittoPlatform, SimulationService
]

// C4: Physical-to-virtual interaction (represented via DataTransmitted already defined above)

// C0: Environment
instance BuildingDigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains LightingSensor, EnvironmentalConditionSensor, BuildingControlSystemSensor,
          LightingActuator, HVACActuator, ControlDevice,
          BIMInformationModel, ControlLogicModel, SimulationModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points, HVAC adjustments) are sent back to the physical devices through the same Hono/Ditto channel, enabling actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (sub‑second) synchronization between physical sensors and the twin as enabled by the Hono/Ditto data pipeline."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where the DT framework acts as a central hub connecting BIM‑derived device twins, the Hono/Ditto communication layer, and the Unreal Engine visualisation, with roles for building‑control engineers, facility managers and DT engineers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin supports the full building lifecycle: design (ideal BIM model), construction/manufacturing, and operational phases (post‑occupancy), allowing updates from each stage."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The overall digital‑twin entanglement (ODTE) metric is used to quantify how well the twin reflects its physical counterpart; the approach also addresses semantic drift through synchronization mechanisms."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication is realized through Eclipse Hono (messaging) and Eclipse Ditto (digital‑twin state management), providing a real‑time link between physical devices and the virtual model."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Generated runtime artifacts are deployed on a server‑based platform that hosts Eclipse Hono, Eclipse Ditto and the Unreal Engine visualization component as part of the DT framework."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution leverages BIM standards for building data, uses standardized extension points for modularity, and adopts open‑source frameworks (Eclipse Hono, Ditto) that follow industry interoperability specifications."
]