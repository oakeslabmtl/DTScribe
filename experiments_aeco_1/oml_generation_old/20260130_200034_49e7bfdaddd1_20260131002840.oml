// C1: Digital Twin Core
instance BuildingTwin : DTDFVocab:DigitalTwin [
    base:desc "Generic building digital twin representing the full lifecycle from design through operation and refurbishment in the AECO domain"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled as a semantic object in BIM, measuring ambient temperature within the building"
    DTDFVocab:producedData TemperatureDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM, providing real‑time count of occupants in spaces"
    DTDFVocab:producedData OccupancyDataStream
]

// C4: Physical‑to‑virtual data transmission
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Data instances
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature readings streamed from physical TemperatureSensor"
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo EclipseDittoEnabler, EclipseHonoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy counts streamed from physical OccupancySensor"
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo EclipseDittoEnabler, EclipseHonoEnabler
]

// C10: Models/Data
instance BuildingGeometryModel : DTDFVocab:Model [
    base:desc "Geometric BIM model of building layout and asset locations extracted from enriched BIM"
    DTDFVocab:inputTo UnrealEngineEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic scripts generated from BIM‑embedded device definitions for runtime execution"
    DTDFVocab:inputTo EclipseDittoEnabler, EclipseHonoEnabler
]

instance OccupancyForecastModel : DTDFVocab:Model [
    base:desc "Analytical model forecasting occupancy to support predictive analytics"
    DTDFVocab:inputTo MDETransformationEnabler, EclipseDittoEnabler
]

// C11: Enablers
instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto platform managing twin state and synchronizing data via MQTT"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, DecisionSupportDashboardService
]

instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT broker providing the real‑time data‑exchange channel between physical devices and the twin"
    DTDFVocab:enables RealTimeMonitoringService
]

instance UnrealEngineEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine rendering engine delivering high‑fidelity interactive 3‑D visualizations"
    DTDFVocab:enables InteractiveVisualizationService
]

instance MDETransformationEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering engine that transforms enriched BIM artefacts into deployable twin artifacts"
    DTDFVocab:enables LifecycleOptimizationService, CustomPluginService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides continuous real‑time monitoring of sensor data synchronized from the physical building control system"
    DTDFVocab:provides SensorStatusInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Delivers immersive 3‑D simulation allowing facility managers to visualise building state and issue commands"
    DTDFVocab:provides VisualizationInsight
]

instance LifecycleOptimizationService : DTDFVocab:Service [
    base:desc "Optimises building operations across lifecycle stages using analytical and control models"
    DTDFVocab:provides OperationOptimizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Executes fault detection and performance‑forecasting analytics on streamed sensor data"
    DTDFVocab:provides FaultDetectionInsight, PerformanceForecastInsight
]

instance DecisionSupportDashboardService : DTDFVocab:Service [
    base:desc "Presents decision‑support dashboards with actionable insights for facility managers"
    DTDFVocab:provides DecisionSupportInsight
]

instance CustomPluginService : DTDFVocab:Service [
    base:desc "Extensible plug‑in architecture enabling custom analytics or control actions"
    DTDFVocab:provides CustomAction
]

// C17: Insights
instance SensorStatusInsight : DTDFVocab:Insight [
    base:desc "Current status and trend of all monitored sensor readings"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Rendered 3‑D view of the building reflecting real‑time sensor and actuator states"
]

instance OperationOptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for energy‑efficient operation derived from lifecycle models"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detected anomalies and probable faults in building systems"
]

instance PerformanceForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of building performance metrics such as energy consumption and occupancy"
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Actionable recommendations for facility managers based on integrated analytics"
]

// C17: Actions
instance CustomAction : DTDFVocab:Action [
    base:desc "User‑defined custom action executed via plug‑in service"
    DTDFVocab:IsAutomatic false
]

// C2: Acting components (actuators/controllers)
instance HeatingActuator : DTDFVocab:ActingComponent [
    base:desc "Heating actuator modeled in BIM, capable of receiving remote commands to adjust temperature setpoints"
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in BIM, allowing remote on/off and dimming control"
]

instance HVACController : DTDFVocab:ActingComponent [
    base:desc "HVAC controller defined in BIM, exposing commandable actions for system-wide climate regulation"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional data exchange allows the digital twin to send control commands back to the physical building for monitoring and actuation, enabling Facility Managers to perform real‑time control. The document mentions this capability but does not provide details on command types, message formats, validation or authentication mechanisms, feedback loops, conflict‑resolution strategies, or confirmation of command execution."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT is designed to operate on a real‑time scale: physical sensor streams are ingested continuously and fed to the digital replica with low latency, enabling live synchronization and immediate analytical feedback. The architecture requires that data be synchronized as soon as it becomes available, supporting real‑time insights and predictive analytics; no explicit synchronization interval is prescribed."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a model‑driven orchestration pattern centred on a central integration hub. Static BIM models are combined with runtime IoT data through bidirectional data exchange facilitated by Eclipse Hono (for protocol translation and connectivity) and Eclipse Ditto (for digital twin state management). The hub orchestrates services that expose standardized REST/WS APIs, enabling the Unreal Engine visualisation component to render the virtual environment. Resource management, component integration and system‑wide coordination are handled within this modular hub, which links the data acquisition, state management and visualisation layers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a model‑driven lifecycle that starts with device modeling in the BIM environment by the Building Control Engineer (definition of sensors, actuators, controllers). Enriched BIM models are then processed by model‑driven engineering (MDE) tooling to extract a structured semantic representation. The MDE step automatically generates deployable Digital Twin artifacts (ontology instances, service descriptors) which are instantiated in the runtime environment. During operation the Twin is kept in continuous synchronization with the physical building via real‑time data exchange. The Twin provides interactive visualization for monitoring and control. Extensions can be added through standardized plug‑in points, enabling evolution of the Twin throughout its operational phase. Governance is realized through role‑based responsibilities (Building Control Engineer, Facility Manager, DT Engineer) and the modular architecture that isolates lifecycle stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by binding the enriched BIM semantic model to live sensor/actuator streams through the MDE‑driven transformation pipeline; any deviation between the physical state and its digital representation is detected by the continuous real‑time synchronization layer. Validation is performed implicitly when the generated DT artifacts are deployed: the framework checks that each BIM‑defined device has a corresponding runtime endpoint and that control logic can be instantiated without manual intervention. Uncertainty sources such as stale sensor readings are mitigated by the ongoing synchronization, while semantic consistency between the BIM model and the twin is the primary quality‑assurance criterion described in the document."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system is built on a modular architecture with standardized extension points that support interoperability across heterogeneous systems and scalability from component to infrastructure level. Runtime configuration management further enhances adaptability. However, the document does not detail the underlying communication protocols, network topology, bandwidth or latency requirements, reliability or redundancy mechanisms, nor the security protocols used for network communication."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is built on Building Information Modeling (BIM), which the document cites as the emerging industry standard for construction data exchange. The framework leverages BIM as the foundational representation, enriches it with control‑logic semantics, and uses standardized extension points to ensure interoperability of custom services. No additional external standards (e.g., OPC UA, ISO 19650) are mentioned in the provided text."
]