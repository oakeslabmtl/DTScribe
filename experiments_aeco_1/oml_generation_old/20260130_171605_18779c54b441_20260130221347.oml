// C3: Physical sensing components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor modelled in BIM that measures ambient light levels and feeds live data to the twin."
    DTDFVocab:producedData LightingSensorDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor modelled in BIM that captures temperature, humidity and other indoor climate parameters."
    DTDFVocab:producedData EnvironmentalSensorDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy sensor modelled in BIM that detects space usage and feeds occupancy counts to the twin."
    DTDFVocab:producedData OccupancySensorDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LightingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance EnvironmentalSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance OccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Models/Data
instance StaticBIMModel : DTDFVocab:Model [
    base:desc "Static BIM model providing geometry, topology and functional attributes of the building."
    DTDFVocab:inputTo MDETransformationEngineEnabler
]

instance RuntimeSemanticsModel : DTDFVocab:Model [
    base:desc "Runtime semantics enriched onto the BIM model for sensors, actuators and control logic."
    DTDFVocab:inputTo MDETransformationEngineEnabler, BOREALISEnabler
]

instance LightingSensorData : DTDFVocab:Data [
    base:desc "Live time‑series stream of illuminance measurements from LightingSensor."
    DTDFVocab:fromData LightingSensorDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance EnvironmentalSensorData : DTDFVocab:Data [
    base:desc "Live time‑series stream of temperature, humidity and air‑quality readings from EnvironmentalSensor."
    DTDFVocab:fromData EnvironmentalSensorDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance OccupancySensorData : DTDFVocab:Data [
    base:desc "Live time‑series stream of occupancy counts from OccupancySensor."
    DTDFVocab:fromData OccupancySensorDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides IoT connectivity for continuous real‑time ingestion of sensor measurements."
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages the digital‑twin state and processes updates from incoming data."
    DTDFVocab:enables PredictiveAnalyticsService, DecisionSupportService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders the interactive 3‑D visualization of the building twin."
    DTDFVocab:enables Interactive3DVisualizationService
]

instance BOREALISEnabler : DTDFVocab:Enabler [
    base:desc "BOREALIS implements reinforcement‑learning based energy‑optimization for the building twin."
    DTDFVocab:enables EnergyOptimizationService, SimulationService
]

instance MDETransformationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering transformation pipeline enriches BIM with device metadata and generates deployment artifacts."
    DTDFVocab:enables SimulationService, DecisionSupportService
]

// C6: Services
instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Provides an interactive 3‑D visualization of the building twin via Unreal Engine 5."
    DTDFVocab:provides VisualComfortInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Monitors live sensor streams in real time for facility‑manager dashboards."
    DTDFVocab:provides PredictiveAlertInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs simulation scenarios of building performance using the enriched BIM model."
    DTDFVocab:provides AdjustLightingAction, AdjustHVACAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Applies predictive analytics on sensor data to generate alerts and forecasts."
    DTDFVocab:provides PredictiveAlertInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes energy consumption using reinforcement‑learning recommendations."
    DTDFVocab:provides EnergySavingsInsight, AdjustLightingAction, AdjustHVACAction
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Offers stakeholder‑focused decision support through dashboards and scenario analysis."
    DTDFVocab:provides VisualComfortInsight, EnergySavingsInsight
]

// C17: Insights/Actions
instance EnergySavingsInsight : DTDFVocab:Insight [
    base:desc "Insight on potential energy savings derived from optimization analytics."
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Insight on visual comfort levels based on lighting sensor data and simulation results."
]

instance PredictiveAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive alert indicating likely future violations of comfort or energy limits."
]

instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automated adjustment of lighting actuator setpoints to improve energy efficiency and visual comfort."
    DTDFVocab:IsAutomatic true
]

instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Automated control of HVAC controllers to maintain thermal comfort while minimizing energy use."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator addressed by the twin to dim or brighten fixtures."
]

instance HVACController : DTDFVocab:ActingComponent [
    base:desc "HVAC controller addressed by the twin for temperature regulation."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command transmission from the twin to physical devices through Eclipse Ditto and Hono, enabling the twin to issue control set‑points to actuators and update configuration at runtime."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time synchronization; sensor data and control commands are exchanged continuously with latency in the order of seconds (sub‑second to second range) as enabled by Hono/Ditto."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular service‑oriented architecture where the BIM‑derived model drives configurators that generate Hono/Ditto runtime artifacts; these services interoperate to provide bidirectional data flow, visualization and extensible custom plugins."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the complete building lifecycle: design (BIM authoring), construction (model validation), commissioning, and ongoing operation and refurbishment."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric is used to quantify the fidelity of the twin to its physical counterpart; the framework addresses semantic drift by synchronizing runtime semantics with the BIM model."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Realtime IoT connectivity via Eclipse Hono (protocol‑agnostic, e.g., MQTT/HTTP) coupled with Eclipse Ditto for twin state management and bidirectional messaging."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Built on BIM standards for building information, uses model‑driven engineering principles and adheres to standard extension points for service integration; evaluation follows the ODTE metric."
]