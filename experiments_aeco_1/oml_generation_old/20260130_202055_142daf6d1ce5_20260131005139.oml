// C3: Physical sensing components
instance IndoorEnvironmentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor embedded as a BIM entity that captures indoor environmental conditions (temperature, humidity, CO₂) and streams readings continuously to the Digital Twin."
    DTDFVocab:producedData IndoorEnvDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor represented in BIM that records post‑occupancy presence data and streams it in real‑time to keep the twin synchronized with actual usage."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Data transmitted from sensors
instance IndoorEnvDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndoorEnvironmentSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C5: Data objects derived from transmissions
instance IndoorEnvData : DTDFVocab:Data [
    base:desc "Live indoor environmental measurements (temperature, humidity, CO₂) derived from the sensor stream."
    DTDFVocab:fromData IndoorEnvDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchangeChannel, MDETransformationEngine
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy counts extracted from the occupancy sensor stream."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchangeChannel, MDETransformationEngine
]

// C10: Models generated from enriched BIM
instance EnrichedBIMGeometricModel : DTDFVocab:Model [
    base:desc "Geometric backbone extracted from enriched BIM, providing the 3D building structure for the twin."
    DTDFVocab:inputTo MDETransformationEngine
]

instance DeviceBehavioralModel : DTDFVocab:Model [
    base:desc "Control‑logic scripts attached to BIM‑defined devices (sensors and actuators) describing their behavioural semantics."
    DTDFVocab:inputTo MDETransformationEngine
]

instance DownstreamAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical models generated downstream for energy analytics, forecasting, and optimisation."
    DTDFVocab:inputTo MDETransformationEngine
]

// C11: Enablers
instance RealTimeDataExchangeChannel : DTDFVocab:Enabler [
    base:desc "Bidirectional real‑time data‑exchange channel that continuously synchronises physical sensor/actuator streams with their digital twins."
    DTDFVocab:enables RealTimeMonitoringService, ClosedLoopControlService
]

instance MDETransformationEngine : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline that transforms enriched BIM models into deployable digital‑twin artefacts."
    DTDFVocab:enables EnergySimulationService, LightingOptimizationService, PredictiveAnalyticsService
]

instance ServiceIntegrationExtension : DTDFVocab:Enabler [
    base:desc "Standardised extension point allowing custom services (e.g., visualisation, analytics) to be plugged into the runtime without redeployment."
    DTDFVocab:enables ImmersiveVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of lighting and environmental parameters, exposing live KPI dashboards to Facility Managers."
    DTDFVocab:provides KPIInsight
]

instance EnergySimulationService : DTDFVocab:Service [
    base:desc "High‑fidelity simulation of building energy usage and illumination scenarios based on the geometric and behavioural models."
    DTDFVocab:provides EnergyForecastInsight
]

instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Optimisation of lighting schedules and set‑points to minimise energy consumption while meeting comfort requirements."
    DTDFVocab:provides LightingRecommendationAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics forecasting equipment degradation and occupancy‑driven lighting demand, and detecting anomalies."
    DTDFVocab:provides EnergyForecastInsight, AnomalyDetectionInsight
]

instance ClosedLoopControlService : DTDFVocab:Service [
    base:desc "Closed‑loop control that automatically actuates dimmers and switches based on simulation outcomes and real‑time data."
    DTDFVocab:provides ClosedLoopActuationAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc " immersive 3D visualisation of the building state, integrating live sensor data and simulation results."
    // No explicit insight/action; visualization is the output
]

// C17: Insights
instance KPIInsight : DTDFVocab:Insight [
    base:desc "Key Performance Indicator insight enabling Facility Managers to monitor energy usage, lighting levels, and environmental comfort in real time."
]

instance EnergyForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast insight providing predicted energy consumption and lighting demand for upcoming periods."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection insight flagging abnormal sensor readings or unexpected energy spikes for operator review."
]

// C17: Actions
instance LightingRecommendationAction : DTDFVocab:Action [
    base:desc "Recommendation to adjust lighting set‑points or schedules based on optimisation results."
    DTDFVocab:IsAutomatic false
]

instance ClosedLoopActuationAction : DTDFVocab:Action [
    base:desc "Automatic command sent to lighting actuators to dim or switch lights in response to real‑time conditions."
    DTDFVocab:IsAutomatic true
]

// C2: Acting components (actuators)
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "BIM‑modeled actuator (dimmer/switch) that can be remotely commanded via the real‑time data‑exchange channel to control building lighting."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication is supported by the DT Framework, which acts as a central hub. Facility Managers and DT Engineers can issue control signals from the Digital Twin to physical devices for real‑time monitoring and control. The document mentions runtime interfaces and control signals but provides no detail on command types, message formats, validation, authentication, feedback loops, conflict resolution, or execution confirmation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange that keeps the physical building and its digital counterpart continuously synchronized. Synchronization is performed continuously (i.e., as soon as sensor updates are available) and supports near‑zero latency required for live monitoring and control. The temporal granularity is tied to the frequency of incoming building‑automation data streams, and runtime configuration management allows these frequencies to be adjusted without redeploying the twin."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, service‑oriented architecture with standardized extension points that enable integration of custom services and analytics. Runtime configuration management permits on‑the‑fly adaptation of services. The DT Engine orchestrates bidirectional data exchange between enriched BIM models and the operational twin, orchestrating the flow of data through defined roles (Building Control Engineer, Facility Manager, DT Engineer) and acting as the central coordination component."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a four‑stage lifecycle for a building Digital Twin: (1) Device Modeling – Building Control Engineers enrich BIM models with explicit sensor, actuator and controller definitions, creating a unified semantic base; (2) Model‑Driven Transformation – Model‑Driven Engineering (MDE) tools extract structured representations from the enriched BIM and automatically generate deployable DT artefacts; (3) Deployment & Activation – The generated artefacts are instantiated in the runtime environment, establishing real‑time data exchange links that keep the physical devices synchronised with their digital counterparts; (4) Operational Use & Evolution – Facility Managers interact with the Twin via immersive visualisation for monitoring and control, while the modular architecture’s standardized extension points allow DT Engineers to integrate custom services and analytics, supporting ongoing evolution of the Twin. Transition between stages is managed automatically by the MDE pipeline, and governance is implicit in the role‑based responsibilities (Control Engineer, Facility Manager, DT Engineer) defined in the model‑driven deployment framework."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT Framework is described as having a modular architecture with standardized extension points and a central hub that mediates bidirectional data exchange between physical assets and the digital twin. Non‑functional requirements such as interoperability and scalability are highlighted, yet the document does not disclose specific network protocols, topology, bandwidth or latency targets, redundancy mechanisms, or security protocols for the underlying communication infrastructure."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed by non‑functional requirements targeting heterogeneous systems. The framework exposes standardized interfaces for bidirectional data exchange, allowing BIM tools, building‑automation devices and external analytics services to connect via a plug‑in pattern using the defined extension points. Specific data exchange protocols are not enumerated, but the architecture is designed for integration with external systems through these standardized interfaces."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is built on the Building Information Modeling (BIM) standard as the core semantic foundation. All device definitions, control logic and generated artefacts conform to BIM‑based schemas, ensuring compatibility with existing BIM tools. The framework’s modular architecture defines standardized extension points that follow a common interface contract, enabling interoperability of custom services and analytics across different implementations."
]