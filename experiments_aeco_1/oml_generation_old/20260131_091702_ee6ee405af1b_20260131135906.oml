// C3: Physical Sensing Components
instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector instantiated in the BIM model that captures presence information."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightIntensitySensor : DTDFVocab:SensingComponent [
    base:desc "Light intensity sensor instantiated in the BIM model that measures ambient light levels."
    DTDFVocab:producedData LightIntensityDataTransmitted
]

instance IndoorEnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Indoor environmental sensor instantiated in the BIM model that records temperature, humidity, and CO2 concentration."
    DTDFVocab:producedData IndoorEnvironmentalDataTransmitted
]

// C4: Physical-to-Virtual Interaction (Data Transmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance LightIntensityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightIntensitySensor
]

instance IndoorEnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndoorEnvironmentalSensor
]

// C4: Data Instances
instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy data transmitted from the OccupancyDetector."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway
]

instance LightIntensityData : DTDFVocab:Data [
    base:desc "Light intensity data transmitted from the LightIntensitySensor."
    DTDFVocab:fromData LightIntensityDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway
]

instance IndoorEnvironmentalData : DTDFVocab:Data [
    base:desc "Indoor environmental data (temperature, humidity, CO₂) transmitted from the IndoorEnvironmentalSensor."
    DTDFVocab:fromData IndoorEnvironmentalDataTransmitted
    DTDFVocab:inputTo EclipseHonoGateway
]

// C2: Acting Components
instance DimmerController : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer controller embedded in the BIM model that can receive commands from the Digital Twin."
]

instance SwitchController : DTDFVocab:ActingComponent [
    base:desc "Lighting switch controller embedded in the BIM model that can receive commands from the Digital Twin."
]

instance HVACValveController : DTDFVocab:ActingComponent [
    base:desc "HVAC valve controller embedded in the BIM model that can receive commands from the Digital Twin."
]

// C11: Enablers
instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT gateway that receives sensor events and forwards them to the Digital Twin."
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoDeviceTwinService : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto device twin service that maintains the virtual twin state."
    DTDFVocab:enables ActuationService, PredictiveAnalyticsService, EnergyOptimizationService, VisualComfortOptimizationService
]

instance UnrealEngine5VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 rendering engine used for immersive 3D visualization of the building."
    DTDFVocab:enables ImmersiveVisualizationService
]

instance MDEToolModelTransformation : DTDFVocab:Enabler [
    base:desc "MDE tool that performs model-to-model and model-to-text transformations to produce runtime artifacts."
    DTDFVocab:enables ModelGenerationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service that gathers real-time data from sensor streams and updates the digital twin."
    DTDFVocab:provides RealTimeDashboardInsight, FacilityManagerDecisionSupport
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service that performs predictive analytics for energy use and building comfort."
    DTDFVocab:provides EnergyUsePrediction
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Service that optimizes lighting and HVAC schedules for energy efficiency."
    DTDFVocab:provides LightingScheduleOptimization, HVACScheduleOptimization
]

instance VisualComfortOptimizationService : DTDFVocab:Service [
    base:desc "Service that optimizes visual comfort based on lighting and occupant data."
    DTDFVocab:provides VisualComfortInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Service that renders the digital twin data in immersive 3D via Unreal Engine 5."
    DTDFVocab:provides VisualComfortInsight
]

instance ActuationService : DTDFVocab:Service [
    base:desc "Service that sends control commands to lighting and HVAC actuators."
    DTDFVocab:provides DimLightingAction, HVACControlAction
]

instance ModelGenerationService : DTDFVocab:Service [
    base:desc "Service that orchestrates model-to-model and model-to-text transformations for runtime artifact creation."
]

// C17: Insights
instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Dashboard insights for real-time monitoring of occupancy, lighting, and environmental conditions."
]

instance EnergyUsePrediction : DTDFVocab:Insight [
    base:desc "Predictive analytics for building energy consumption."
]

instance LightingScheduleOptimization : DTDFVocab:Insight [
    base:desc "Optimized lighting schedules based on occupancy and lighting forecasts."
]

instance HVACScheduleOptimization : DTDFVocab:Insight [
    base:desc "Optimized HVAC schedules for thermal comfort and energy efficiency."
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Insights for visual comfort derived from lighting and environmental data."
]

instance FacilityManagerDecisionSupport : DTDFVocab:Insight [
    base:desc "Decision support for facility managers based on real-time monitoring and predictions."
]

// C17: Actions
instance DimLightingAction : DTDFVocab:Action [
    base:desc "Action to adjust lighting levels via dimmer controllers."
    DTDFVocab:IsAutomatic true
]

instance HVACControlAction : DTDFVocab:Action [
    base:desc "Action to control HVAC actuators for temperature regulation."
    DTDFVocab:IsAutomatic true
]

// C10: Models/Data (BIM and runtime artifacts)
instance BIMModelIFC : DTDFVocab:Model [
    base:desc "The BIM model of the Living Lab building represented in IFC format."
    DTDFVocab:inputTo MDEToolModelTransformation
]

instance DittoConfigModel : DTDFVocab:Model [
    base:desc "Ditto configuration model generated during the model-to-model transformation."
    DTDFVocab:inputTo MDEToolModelTransformation
]

instance HonoTenantModel : DTDFVocab:Model [
    base:desc "Eclipse Hono tenant configuration model generated during the transformation."
    DTDFVocab:inputTo MDEToolModelTransformation
]

instance DeviceControlLogicModel : DTDFVocab:Model [
    base:desc "Runtime representations of device control logic derived from the BIM model."
    DTDFVocab:inputTo MDEToolModelTransformation
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands issued by the DT are transmitted via Ditto/Hono endpoints to the building’s control system, driving actuators such as lighting and HVAC."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange; updates are typically made within milliseconds to seconds, but the document only specifies real‑time operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A service‑oriented architecture integrating BIM semantics, Ditto twin registry, Hono messaging, and visualization services, all orchestrated through a central deployment pipeline with plug‑in extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (BIM creation), Manufacture (physical device installation), and Operation (continuous monitoring and control), with the DT evolving across all lifecycle stages via automated MDE transformations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Use of the ODTE metric to quantify coupling fidelity between the physical building and the DT, along with synchronization checks to mitigate semantic drift."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional messaging via Eclipse Hono/Ditto: sensor events are published over Hono, consumed by Ditto twins; control commands are sent from DT to Ditto and then routed to the physical control system."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized integration via Hono and Ditto exposes MQTT and HTTP APIs, allowing the DT to exchange data with external enterprise systems such as CMMS or BMS platforms."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to BIM standards (IFC), model‑driven engineering practices, and standardized integration frameworks (Hono, Ditto) ensures interoperability across tools and stakeholders."
]