// C3: Physical sensing components
instance BuildingTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in BIM for real‑time monitoring of building thermal conditions."
    DTDFVocab:producedData TemperatureMeasurement
]

instance BuildingOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM for detecting presence in building zones."
    DTDFVocab:producedData OccupancyMeasurement
]

// C2: Acting components
instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Digital representation of a lighting fixture modeled in BIM, visualized in UE5. Commands flow via UnrealTwinController, DittoController, and Eclipse Hono with policy validation."
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance TemperatureMeasurement : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingTemperatureSensor
]

instance OccupancyMeasurement : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingOccupancySensor
]

// C5: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature readings streamed via Eclipse Hono."
    DTDFVocab:fromData TemperatureMeasurement
    DTDFVocab:inputTo HonoAdapter
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy status streamed via Eclipse Hono to Ditto."
    DTDFVocab:fromData OccupancyMeasurement
    DTDFVocab:inputTo DittoStateManager
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM enriched with device definitions (sensors, actuators, controllers) used as the primary computational model."
    DTDFVocab:inputTo MDEPipline
]

// C11: Enablers
instance HonoAdapter : DTDFVocab:Enabler [
    base:desc "Eclipse Hono protocol adapter ingesting sensor streams and forwarding to Eclipse Ditto."
    DTDFVocab:enables TemperatureMonitoringService, OccupancyBasedLightingControlService
]

instance DittoStateManager : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin state manager applying policy validation and persisting events."
    DTDFVocab:enables OccupancyBasedLightingControlService, Interactive3DVisualizationService
]

instance UE5VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 based visualization engine hosting TwinComponents and rendering interactive 3‑D views."
    DTDFVocab:enables Interactive3DVisualizationService, AnalyticsOptimizationService
]

instance MDEPipline : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline that extracts JSON/OWL from the enriched BIM and generates deployable DT artefacts."
    DTDFVocab:enables TemperatureMonitoringService, ControlLogicExecutionService, Interactive3DVisualizationService, AnalyticsOptimizationService
]

// C6: Services
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature sensor states for facility managers."
    DTDFVocab:provides TemperatureAnomalyInsight
]

instance OccupancyBasedLightingControlService : DTDFVocab:Service [
    base:desc "Control logic that adjusts lighting based on occupancy data for building control engineers."
    DTDFVocab:provides AdjustLightingAction
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3‑D visualization of building assets for facility manager oversight."
    DTDFVocab:provides FacilityVisualizationInsight
]

instance AnalyticsOptimizationService : DTDFVocab:Service [
    base:desc "Extensible analytics and optimisation plugins for energy efficiency and performance."
    DTDFVocab:provides EnergyOptimizationInsight
]

instance ControlLogicExecutionService : DTDFVocab:Service [
    base:desc "Executes control logic for building equipment based on sensor inputs."
    DTDFVocab:provides ControlCommandAction
]

// C17: Insights/Actions
instance TemperatureAnomalyInsight : DTDFVocab:Insight [
    base:desc "Detects temperature deviations beyond thresholds, enabling preventive maintenance."
]

instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Command to adjust lighting fixture brightness based on occupancy."
    DTDFVocab:IsAutomatic true
]

instance FacilityVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides a live 3‑D representation of building systems for oversight."
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Provides recommendations for energy optimisation across the building lifecycle."
]

instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Generic command sent to actuators after policy validation."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT enables facility managers to perform real‑time monitoring and issue control commands back to the physical building. The central DT Framework acts as a hub for bidirectional exchange, allowing digital‑to‑physical control messages to be sent from the virtual model to devices. No details on command types, message formats, validation, authentication, feedback loops, conflict resolution, or execution confirmation are provided in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real-time data exchange that keeps the digital replica continuously synchronized with the physical building. Synchronisation is described as continuous, with no explicit cycle time, implying near‑real‑time updates; latency requirements are not quantified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is organised as a modular framework centred on a central DT Framework component that acts as a hub for bidirectional data exchange. Standardized extension points allow DT Engineers to plug in custom services and analytics, while runtime configuration management enables on‑the‑fly adjustments without full redeployment, indicating a service‑oriented, centrally coordinated architecture."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The proposed model‑driven DT deployment framework covers the full DT life‑cycle: (1) device modeling where sensors, actuators and controllers are defined directly inside the BIM model; (2) model enrichment and transformation using Model‑Driven Engineering (MDE) to extract a structured representation; (3) automatic generation of deployable DT artifacts (software components, configuration files) that are provisioned to a runtime environment; (4) runtime operation in which real‑time data exchange keeps the physical building and its digital twin continuously synchronized; and (5) evolution/maintenance enabled by a modular architecture with standardized extension points that allow insertion of new services or analytics. Governance is expressed through role‑based responsibilities (Building Control Engineer, Facility Manager, DT Engineer) for each phase."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by policy‑based validation in Eclipse Ditto, which checks sensor value ranges, units and type consistency at ingestion time. Pre‑execution validation of actuator commands provides functional correctness. Fault tolerance is achieved through Eclipse Hono’s at‑least‑once message delivery and Ditto’s persistent event storage, ensuring synchronization despite network failures. Validation and verification are performed automatically during the model‑to‑artifact generation step and during runtime by the middleware’s validation layer."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The solution adopts a modular architecture with standardized extension points to achieve interoperability across heterogeneous systems, implying a network capable of connecting multiple components. However, the documents do not enumerate specific communication protocols, network topology, bandwidth or latency requirements, reliability/redundancy mechanisms, or security protocols for the underlying network communication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT Framework is described as a central hub that can be extended via service integration and runtime configuration management, suggesting it can be deployed on various infrastructures (cloud, edge, or on‑premise). The documents do not disclose concrete hosting platforms, computational and storage sizing, scalability approaches, supported deployment models, or explicit availability and reliability guarantees."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Non‑functional requirements explicitly address interoperability across heterogeneous systems and scalability to whole‑site infrastructures. The modular architecture uses standardized extension points to integrate external services and enterprise systems, though specific data exchange protocols or standards are not listed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework builds on BIM as the canonical data source and declares a set of standardized extension points for plug‑in services, but the documents do not enumerate specific industry standards, certification schemes, or interoperability protocols. Consequently only a generic reference to “standardized extension points” is provided."
]