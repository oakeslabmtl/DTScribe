// C3: Physical sensing components
instance BIMDefinedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors are defined in the BIM model and streamed to the DT via Eclipse Hono; their data are stored in Eclipse Ditto with 1‑second heartbeat synchronization."
    DTDFVocab:producedData SensorDataTransmitted
]

// C2: Acting components
instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixtures modeled as BIM devices with binary on/off, dimming level, and colour‑temperature capabilities; commands are routed via UnrealTwinController → DittoController → DittoDevice."
]

// C4: Physical-to-virtual interaction
instance SensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BIMDefinedSensor
]

// C5: Data
instance SensorData : DTDFVocab:Data [
    base:desc "Real‑time sensor measurements (e.g., occupancy, temperature, lighting state) transmitted every second."
    DTDFVocab:fromData SensorDataTransmitted
    DTDFVocab:inputTo EclipseDittoTwinStore
]

// C10: Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Geometric foundation of the building extracted from Revit enriched BIM, embedding device definitions."
    DTDFVocab:inputTo EclipseDittoTwinStore
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model of building control logic generated from BIM device definitions via Model‑Driven Engineering."
    DTDFVocab:inputTo EclipseDittoTwinStore
]

instance PredictiveEnergyModel : DTDFVocab:Model [
    base:desc "Predictive analytics model for energy consumption and indoor‑condition forecasting."
    DTDFVocab:inputTo EclipseDittoTwinStore
]

// C11: Enablers
instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono ingestion gateway that forwards device telemetry to Eclipse Ditto using MQTT‑like protocols."
    DTDFVocab:enables RealTimeMonitoringService, ControlLogicExecutionService
]

instance EclipseDittoTwinStore : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin store providing policy‑based validation, persistent event storage and addressable DittoDevice objects."
    DTDFVocab:enables RealTimeMonitoringService, ControlLogicExecutionService, EnergyPredictiveAnalyticsService, OperationalOptimizationService, Interactive3DVisualizationService, CustomExtensionService
]

instance UE5VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 visual component mapping and FeatureParser translating device states into visual parameters."
    DTDFVocab:enables Interactive3DVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of sensor streams and device states."
    DTDFVocab:provides LiveSensorInsight
]

instance ControlLogicExecutionService : DTDFVocab:Service [
    base:desc "Execution of control logic defined by building control engineers."
    DTDFVocab:provides ControlCommandAction
]

instance EnergyPredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics and simulation for energy consumption and indoor‑condition forecasting."
    DTDFVocab:provides EnergyForecastInsight
]

instance OperationalOptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that computes cost‑effective operational set‑points."
    DTDFVocab:provides CostEffectiveSetpointInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3‑D visualization of the BIM‑derived model for facility managers."
    DTDFVocab:provides Render3DVisualizationAction
]

instance CustomExtensionService : DTDFVocab:Service [
    base:desc "Extensible custom services and analytics via standardized plug‑in extension points."
    DTDFVocab:provides CustomAnalyticsInsight
]

// C17: Insights / Actions
instance LiveSensorInsight : DTDFVocab:Insight [
    base:desc "Live view of building conditions derived from continuous sensor streams."
]

instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Command dispatched to actuators (e.g., lighting fixtures) through Ditto policies."
    DTDFVocab:IsAutomatic false
]

instance EnergyForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of future energy consumption and indoor environmental conditions."
]

instance CostEffectiveSetpointInsight : DTDFVocab:Insight [
    base:desc "Recommendation of cost‑effective operational set‑points for HVAC and lighting."
]

instance Render3DVisualizationAction : DTDFVocab:Action [
    base:desc "Render interactive 3‑D visualization of the digital twin in UE5."
    DTDFVocab:IsAutomatic true
]

instance CustomAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Custom analytics results (e.g., occupancy patterns, fault detection) generated by plug‑in services."
]

instance LightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjust lighting actuator state (on/off, dimming, colour temperature) as instructed by control logic."
    DTDFVocab:IsAutomatic true
]

// Optional environment aggregation
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains BIMDefinedSensor, LightingFixtureActuator, EnrichedBIMModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional data exchange is enabled by the DT framework, allowing the digital twin to issue control commands back to the building control systems. Control logic defined by Building Control Engineers is executed in the twin and the resulting commands (e.g., actuator set‑points, HVAC overrides) are transmitted to the physical devices through the same communication path used for sensor data, ensuring immediate feedback. The framework validates and authenticates each command before dispatch, and the physical system acknowledges execution, closing the loop."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides continuous, real-time data exchange between the physical building and its digital counterpart, aiming for synchronous updates without specified frequency, latency or granularity; the exact synchronization interval is not detailed in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a model-driven, service-oriented constellation where enriched BIM models are transformed into deployable DT artifacts; a modular architecture with standardized extension points enables integration of custom services, runtime configuration management, and bidirectional data exchange, orchestrated by the central DT Framework."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a DT life‑cycle that starts with design‑time device modelling where building control engineers enrich BIM models with semantic definitions of sensors, actuators and controllers. A model‑driven engineering (MDE) step then extracts a structured representation from the enriched BIM and automatically generates deployable DT artefacts. An automated deployment process (R2) instantiates the twin with minimal manual intervention, establishing runtime operation. In the operation stage continuous real‑time data exchange (R3) synchronises the physical asset and its digital counterpart, while interactive visualisation supports monitoring and control. Transition between stages is orchestrated by the model‑driven automation engine and governance is enforced through the defined actor roles (building control engineer, facility manager, DT engineer)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assured by a two‑stage verification pipeline: model checking (5.53 s) and model parsing (8.7 s) prior to DT initialization. Eclipse Ditto applies policy‑based validation to detect out‑of‑range values and performs pre‑execution checks on actuator commands. Fault tolerance is provided by Eclipse Hono’s at‑least‑once message delivery and Ditto’s persistent event storage, enabling recovery from network failures. Synchronisation quality is quantified by the Overall Digital Twin Entanglement (ODTE) metric, comprising timeliness (0.997), reliability (1.0) and availability (1.0), measured over a 12‑minute window with a 1‑second heartbeat."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical network consists of a modular, service‑oriented architecture built on Eclipse Hono and Eclipse Ditto. Hono provides a scalable gateway that aggregates heterogeneous sensor streams and forwards them over standard IoT protocols to the Ditto digital‑twin engine, which stores and exposes the twin state via REST and WebSocket interfaces. The topology supports horizontal scaling of both gateway and twin components, and the use of standardized protocols ensures interoperability across heterogeneous systems as required by the NF_X non‑functional requirements."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through BIM model enrichment and standardized extension points that allow custom services and analytics to be plugged in; however, specific data exchange protocols, interoperability standards or external enterprise system dependencies are not detailed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach builds on BIM as the primary modelling standard in the AECO sector and reuses open‑source frameworks noted for standard compliance. Connectivity relies on Eclipse Hono and Eclipse Ditto, which are referenced as providing robust, standards‑based communication in DT implementations. While specific industry certification requirements are not enumerated, the modular architecture and standardized extension points are intended to ensure interoperability with existing AECO standards and other DT platforms."
]