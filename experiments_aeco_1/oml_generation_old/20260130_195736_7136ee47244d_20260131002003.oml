// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "BIM-defined temperature sensor attached to HVAC zone, sampling at device‑specified rate"
    DTDFVocab:producedData TemperatureDataStream
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "BIM-defined CO₂ sensor placed in conference rooms, providing continuous real‑time concentration readings"
    DTDFVocab:producedData CO2DataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "BIM-defined occupancy sensor capturing presence counts for space utilization analysis"
    DTDFVocab:producedData OccupancyDataStream
]

// C4: Data transmitted from sensors
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance CO2DataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C11: Data objects
instance TemperatureData : DTDFVocab:Data [
    base:desc "Raw temperature measurement values streamed in real time"
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo RealTimeDataExchange
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Raw CO₂ concentration values streamed in real time"
    DTDFVocab:fromData CO2DataStream
    DTDFVocab:inputTo RealTimeDataExchange
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Raw occupancy count values streamed in real time"
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo RealTimeDataExchange
]

// C11: Enablers
instance RealTimeDataExchange : DTDFVocab:Enabler [
    base:desc "Eclipse Hono based MQTT/AMQP ingestion that synchronizes sensor streams with digital‑twin instances in Eclipse Ditto"
    DTDFVocab:enables SimulationService, PredictiveAnalyticsService, OptimizationService, VisualizationService
]

instance AnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Modular analytics platform that filters, converts units and applies predictive models to incoming data streams"
    DTDFVocab:enables PredictiveAnalyticsService, OptimizationService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Real‑time simulation of thermal and energy performance using BIM geometry and behavioral models"
    DTDFVocab:provides SimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics that generate forecasts of equipment failure and energy consumption"
    DTDFVocab:provides PredictiveFailureInsight, EnergyConsumptionForecastInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization engine that recommends control set‑points to reduce energy use while maintaining occupant comfort"
    DTDFVocab:provides OptimizationRecommendationAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive Unreal Engine dashboard presenting live sensor and actuator states to facility managers"
    DTDFVocab:provides VisualizationInsight
]

// C17: Insights and Actions
instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Live simulation results showing temperature distribution and airflow patterns"
]

instance PredictiveFailureInsight : DTDFVocab:Insight [
    base:desc "Forecast of potential HVAC component failures with associated confidence levels"
]

instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Projected energy consumption for the next 24 h based on current occupancy and weather"
]

instance OptimizationRecommendationAction : DTDFVocab:Action [
    base:desc "Recommended HVAC set‑point adjustments to achieve energy savings"
    DTDFVocab:IsAutomatic false
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive 3D visualization of current building state and sensor data"
]

// C2: Acting components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "BIM‑modeled HVAC actuator and controller capable of receiving digital‑twin commands to adjust airflow and temperature"
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "BIM‑modeled lighting actuator controlled via digital twin for adaptive illumination"
]

// C10: Models/Data
instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "Static geometric BIM model containing building elements and locations of sensors and actuators"
    DTDFVocab:inputTo RealTimeDataExchange, SimulationService
]

instance ThermalBehaviorModel : DTDFVocab:Model [
    base:desc "Model‑driven thermal behavior representation derived from BIM geometry for simulation and prediction"
    DTDFVocab:inputTo SimulationService, PredictiveAnalyticsService
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Semantic extension defining control logic for BIM actuators, used by the digital twin to generate commands"
    DTDFVocab:inputTo OptimizationService, VisualizationService
]

// C17: Environment
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, CO2Sensor, OccupancySensor, HVACActuator, LightingActuator
]

// System under study component
instance BuildingAsset : DTDFVocab:Component [
    base:desc "Generic civil infrastructure building asset spanning design to operation, represented in the AECO domain"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication enables the digital twin to issue control commands back to physical building systems. Facility managers use the DT interface to adjust building operations; commands are transmitted through the same modular framework via the standardized extension points to the underlying devices. The description does not provide details about specific command types, message formats, validation or authentication mechanisms, feedback loops, conflict‑resolution strategies, or execution confirmations."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports the full DT lifecycle from initial device modeling in the BIM environment, through model‑driven engineering (MDE) extraction of structured representations, automatic generation of deployable DT artifacts, deployment, and runtime operation with real‑time data exchange and interactive visualization. At the modeling stage sensors, actuators and controllers are defined within BIM; the transformation stage creates an enriched semantic model; the generation stage produces code‑level DT artifacts; the deployment stage instantiates the twin; the operation stage maintains synchronization and enables monitoring. Transition between stages is managed automatically by the MDE‑based transformation pipeline, requiring minimal manual intervention."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by aligning the enriched BIM models (geometric and behavioral) with live data from the physical building through continuous synchronization. Validation occurs as the framework automatically reconciles runtime sensor and actuator data with the corresponding model elements, detecting mismatches that indicate fidelity loss. Quality assurance is achieved by the automated generation of DT artifacts from the verified BIM models and by maintaining up‑to‑date semantic links, thereby supporting ongoing verification of model accuracy during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The solution adopts a modular architecture with defined extension points that supports interoperability across heterogeneous building‑system components. Runtime configuration management facilitates dynamic adaptation of connections without full redeployment. While the document highlights scalability from individual components to whole infrastructure and mentions reliability through low‑overhead updates, it does not detail the underlying network protocols, topology, bandwidth or latency requirements, redundancy mechanisms, or security protocols employed for network communication."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution is built around BIM, the de‑facto industry standard for AECO data, and requires that all device definitions and control logic be expressed as BIM extensions. It introduces standardized extension points in the twin’s architecture to ensure interoperability of custom services and analytics. While specific standards (e.g., IFC, ISO 19650) are not cited, the framework explicitly targets compatibility with existing AECO‑specific standards and adopts a model‑driven, standards‑aware approach to integration."
]