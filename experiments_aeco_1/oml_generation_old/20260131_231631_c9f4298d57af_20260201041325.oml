// C3: Physical sensing components // Return code: 1 | Stderr:
instance LightFixtureBrightnessSensor : DTDFVocab:SensingComponent [
    base:desc "Brightness sensor monitoring LED lighting fixtures for real‑time brightness data"
    DTDFVocab:producedData BrightnessDataTransmitted
]

instance LightFixtureColorTempSensor : DTDFVocab:SensingComponent [
    base:desc "Color temperature sensor for lighting fixtures, providing real‑time Kelvin values"
    DTDFVocab:producedData ColorTempDataTransmitted
]

instance BuildingTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor located throughout the building, capturing ambient temperature for HVAC monitoring"
    DTDFVocab:producedData TempDataTransmitted
]

// C4: Physical-to-virtual interaction
instance BrightnessDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightFixtureBrightnessSensor
]

instance ColorTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightFixtureColorTempSensor
]

instance TempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingTemperatureSensor
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model embedding geometric data and detailed device metadata for building control system components"
    DTDFVocab:inputTo ModelDrivenEngineeringFramework, EclipseHonoService
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model capturing control logic defined by Building Control Engineers within the BIM environment"
    DTDFVocab:inputTo EclipseDittoService
]

instance PredictiveAnalyticsModel : DTDFVocab:Model [
    base:desc "Predictive analytics model for forecasting equipment failures and environmental conditions based on sensor streams"
    DTDFVocab:inputTo ModularityArchitectureComponent
]

instance OptimizationModel : DTDFVocab:Model [
    base:desc "Optimization model to recommend energy‑saving schedules and operational improvements derived from aggregated data"
    DTDFVocab:inputTo ModularityArchitectureComponent
]

instance BrightnessMeasurementData : DTDFVocab:Data [
    base:desc "Measured brightness value streamed from BrightnessDataTransmitted"
    DTDFVocab:fromData BrightnessDataTransmitted
    DTDFVocab:inputTo EclipseHonoService
]

instance ColorTemperatureMeasurementData : DTDFVocab:Data [
    base:desc "Measured color‑temperature value streamed from ColorTempDataTransmitted"
    DTDFVocab:fromData ColorTempDataTransmitted
    DTDFVocab:inputTo EclipseHonoService
]

instance BuildingTemperatureMeasurementData : DTDFVocab:Data [
    base:desc "Measured ambient temperature value streamed from TempDataTransmitted"
    DTDFVocab:fromData TempDataTransmitted
    DTDFVocab:inputTo EclipseHonoService
]

// C11: Enablers
instance EclipseHonoService : DTDFVocab:Enabler [
    base:desc "Real‑time data exchange middleware (Eclipse Hono) routing sensor data to the Digital Twin"
    DTDFVocab:enables MonitoringService, PredictionService
]

instance EclipseDittoService : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto platform handling device representation, policy‑based validation, and state persistence"
    DTDFVocab:enables ControlService
]

instance ModularityArchitectureComponent : DTDFVocab:Enabler [
    base:desc "Modular architecture supporting plug‑in of custom services, analytics and simulation engines"
    DTDFVocab:enables OptimizationService, PredictionService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Immersive visualization platform (Unreal Engine 5) for interactive monitoring and control of the digital twin"
    DTDFVocab:enables VisualizationService
]

instance ModelDrivenEngineeringFramework : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering framework that converts enriched BIM models into deployable Digital Twin artifacts"
    DTDFVocab:enables MonitoringService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous real‑time acquisition of device state data through IoT‑enabled sensors and real‑time data exchange layers"
    DTDFVocab:provides EnvironmentalMonitoringInsight, LogDataConsumptionAction
]

instance ControlService : DTDFVocab:Service [
    base:desc "Execution of control logic defined by Building Control Engineers to actuate lighting fixtures and building devices"
    DTDFVocab:provides ControlExecutionInsight, ExecuteControlCommandAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Algorithmic analysis of aggregated data to recommend energy‑saving schedules and operational improvements"
    DTDFVocab:provides EnergyOptimizationInsight, ScheduleAdjustmentAction
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Predictive analytics that forecast equipment failures and environmental conditions"
    DTDFVocab:provides FailurePredictionInsight, PreemptiveMaintenanceAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive, interactive interfaces displaying the building’s physical and digital states"
    DTDFVocab:provides VisualizationInsight, AdjustCameraAction
]

// C17: Insights
instance EnvironmentalMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight into current environmental conditions derived from building temperature sensor data"
]

instance ControlExecutionInsight : DTDFVocab:Insight [
    base:desc "Insight confirming execution of control commands sent to building devices"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting optimization schedules based on aggregated HVAC, lighting, and energy consumption data"
]

instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Insight predicting impending equipment failures using predictive analytics models"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time visualization status of the digital twin environment"
]

// C17: Actions
instance ExecuteControlCommandAction : DTDFVocab:Action [
    base:desc "Action to execute control commands (e.g., set brightness, adjust color temperature) on lighting fixtures"
    DTDFVocab:IsAutomatic false
]

instance ScheduleAdjustmentAction : DTDFVocab:Action [
    base:desc "Action to schedule adjustments to HVAC or lighting based on optimization recommendations"
    DTDFVocab:IsAutomatic false
]

instance PreemptiveMaintenanceAction : DTDFVocab:Action [
    base:desc "Action to initiate preemptive maintenance tasks before predicted equipment failure"
    DTDFVocab:IsAutomatic false
]

instance AdjustCameraAction : DTDFVocab:Action [
    base:desc "Action to adjust camera or viewpoint in the immersive visualization"
    DTDFVocab:IsAutomatic false
]

instance LogDataConsumptionAction : DTDFVocab:Action [
    base:desc "Action to log data consumption events for monitoring and auditing purposes"
    DTDFVocab:IsAutomatic true
]

// C3: Acting Components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture representation supporting on/off control, brightness adjustment, and color‑temperature modulation via Ditto interfaces"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control messages originating from the Digital Twin are transmitted back to physical building devices through the same bidirectional communication channel. The DT Framework maps virtual command intents (e.g., HVAC setpoint changes, lighting level adjustments, fault interventions) to device‑specific command formats via adapters provided in the modular architecture. Validation and authentication are performed by the framework’s runtime policy engine, ensuring only authorized commands are forwarded. Physical devices acknowledge execution, and the DT records the confirmation in the digital model, enabling conflict resolution based on priority rules defined in the deployment configuration."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated by a modular framework positioned as a central hub that facilitates bidirectional data exchange between physical buildings and their digital counterparts. The architecture follows a component-based pattern with standardized extension points that allow for the integration of custom services and analytics. Runtime configuration management is employed to enable dynamic adaptation without full redeployments, and the framework supports both centralized control of operational data and scalable deployment across the building life cycle. The framework coordinates roles such as Building Control Engineers, Facility Managers, and DT Engineers, allowing device modelling, real‑time monitoring, and extension of capabilities through service integration."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Enrichment – Building Control Engineers model devices, actuators and control logic directly within BIM, producing enriched BIM models that capture building component‑system (BCS) elements. Extraction – Using model‑driven engineering (MDE) principles, the framework automatically extracts structured, semantic representations from the enriched BIM (e.g., GIS‑compatible data structures). Deployment – The extracted models are compiled into deployable Digital Twin artifacts (containers, microservices) with minimal manual intervention; DT Engineers deploy these artifacts to a runtime environment. Operation – Real‑time data‑exchange protocols (e.g., MQTT or OPC UA) continuously sync sensor/actuator streams between the physical building and the DT, enabling Facility Managers to monitor status and issue control commands via interactive visualization dashboards. Extension – Custom services, analytics and plugins are added through standardized extension points, leveraging a modular architecture that isolates new functionality while preserving core runtime integrity. Maintenance – Lifecycle governance relies on automated transformation pipelines and versioned BIM artifacts; manual intervention is limited to configuration changes, and incremental updates to BIM models trigger regeneration of the Corresponding DT artifacts, ensuring consistency across lifecycle stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through multiple layers of validation: enriched BIM models are syntactically verified against IFC schema extensions and semantically checked by custom validators that confirm completeness of device metadata. Runtime data integrity is maintained by Eclipse Ditto’s policy‑based value and unit validation, which flags or rejects out‑of‑range sensor readings before propagation to the Digital Twin. Fault tolerance uses Eclipse Hono’s at‑least‑once delivery semantics combined with Ditto’s persistent event storage, allowing the Twin to recover messages after network failures. Verification of control logic is performed by comparing executed device states with the expected outcomes derived from the embedded behavioral models, while any discrepancy triggers an automated alert. Uncertainty quantification is managed by enumerating measurement precision and sensor accuracy within the Ditto policies, e.g., specifying ±0.5 % for luminance sensors. Overall quality assurance follows a CI/CD pipeline where MDE transformation scripts are unit‑tested, and the resulting artifacts undergo integration tests against a simulated building environment before deployment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Underlying network connectivity relies on the framework’s modular connectors which support industry‑standard IoT protocols as defined by the underlying open‑source DT platforms Eclipse Ditto and BaSyx. The architecture enables real‑time, low‑latency data exchange between physical sensors and the Digital Twin, with secure communication via TLS/SSL. Network topology is client‑server‑style with optional edge gateways for local aggregation; redundancy mechanisms include multiple connector instances to preserve reliability. Specific bandwidth, latency and topology details remain unspecified in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "In the described architecture, horizontal integration is addressed through interoperability across heterogeneous systems. The framework utilizes standardized extension points and bidirectional data exchange mechanisms to interface with external BIM tools, monitoring and control systems, and enterprise applications. While explicit protocols are not specified in the documents, the design supports integration patterns that enable the Digital Twin to connect with other Digital Twins and enterprise systems, thereby facilitating data sharing and coordinated decision‑making."
]