// C3: Physical sensing components
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded illumination sensor modeled in BIM and streamed to the digital twin."
    DTDFVocab:producedData IlluminationTelemetryDataTransmitted
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Embedded occupancy detector modeled in BIM and streamed to the digital twin."
    DTDFVocab:producedData OccupancyTelemetryDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded temperature sensor modeled in BIM and streamed to the digital twin."
    DTDFVocab:producedData TemperatureTelemetryDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded humidity sensor modeled in BIM and streamed to the digital twin."
    DTDFVocab:producedData HumidityTelemetryDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance IlluminationTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance OccupancyTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance TemperatureTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

// C5: Data
instance IlluminationData : DTDFVocab:Data [
    base:desc "Streaming illumination telemetry data from building sensors."
    DTDFVocab:fromData IlluminationTelemetryDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Streaming occupancy detection data from building sensors."
    DTDFVocab:fromData OccupancyTelemetryDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Streaming temperature telemetry data from building sensors."
    DTDFVocab:fromData TemperatureTelemetryDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Streaming humidity telemetry data from building sensors."
    DTDFVocab:fromData HumidityTelemetryDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// C2: Acting components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator defined in BIM that receives commands from the digital twin."
]

instance HVACValveControllerActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve controller actuator defined in BIM that receives commands from the digital twin."
]

instance GenericBuildingActuator : DTDFVocab:ActingComponent [
    base:desc "Other building control actuators defined in BIM that receive commands from the digital twin."
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware ingesting sensor telemetry via MQTT and forwarding to Eclipse Ditto."
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalyticsService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin platform storing device state and handling commands."
    DTDFVocab:enables UnrealEngine5Visualization, EnergyConsumptionOptimizationService, SimulationCapabilityService
]

instance ModelDrivenTransformationPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Automated model‑driven pipeline that transforms enriched BIM into runtime artifacts and deployment configurations."
]

// C10: Models/Data
instance BIMGeometricSemanticModel : DTDFVocab:Model [
    base:desc "Base BIM geometric and semantic model enriched with runtime metadata for sensors and actuators."
    DTDFVocab:inputTo ModelDrivenTransformationPipelineEnabler
]

instance RuntimeMetadataModel : DTDFVocab:Model [
    base:desc "Model containing runtime metadata for sensors and actuators generated from enriched BIM."
    DTDFVocab:inputTo ModelDrivenTransformationPipelineEnabler
]

instance RuntimeArtifactsModel : DTDFVocab:Model [
    base:desc "Model representing generated runtime artifacts for deployment."
    DTDFVocab:inputTo ModelDrivenTransformationPipelineEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model defining automation rules for actuators."
    DTDFVocab:inputTo ModelDrivenTransformationPipelineEnabler
]

instance UnrealEngineVisualizationModel : DTDFVocab:Model [
    base:desc "3D interactive visualization model for Unreal Engine 5."
    DTDFVocab:inputTo ModelDrivenTransformationPipelineEnabler
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards presenting live sensor data."
    DTDFVocab:provides EnergyConsumptionForecastInsight
]

instance UnrealEngine5Visualization : DTDFVocab:Service [
    base:desc "3D interactive visualization in Unreal Engine 5."
    DTDFVocab:provides InteractiveScenarioAnalysisInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service generating maintenance alerts."
    DTDFVocab:provides PredictiveMaintenanceAlertInsight
]

instance EnergyConsumptionOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of energy consumption using analytics."
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance SimulationCapabilityService : DTDFVocab:Service [
    base:desc "Simulation capabilities for scenario testing."
    DTDFVocab:provides PredictiveMaintenanceAlertInsight
]

// C17: Insights
instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendations for building systems."
]

instance PredictiveMaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance alerts based on sensor trends."
]

instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasts of future energy consumption."
]

instance InteractiveScenarioAnalysisInsight : DTDFVocab:Insight [
    base:desc "Interactive scenario analysis presented in the 3D twin."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command messages generated by the DT (control set-points, lighting scenes, HVAC adjustments) transmitted through Eclipse Ditto/Hono to actuators in the building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near-real-time synchronization (continuous data flow with sub-second to second latency) as defined by the real-time data exchange layer."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service-oriented architecture where the BIM-derived core twin is connected to middleware (Hono/Ditto) and visualisation (Unreal Engine), with extension points for custom services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the design stage (ideal BIM model), construction/manufacturing stage (as-built BIM data) and operational stage (runtime sensor data and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Evaluation of twin fidelity using the Overall Digital Twin Entanglement (ODTE) metric to quantify alignment between the virtual twin and its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication over Eclipse Hono/Ditto, which typically employs MQTT/AMQP protocols for real-time telemetry and command exchange."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Standardization of BIM semantics through a modeling methodology that harmonizes heterogeneous BIM data across disciplines."
]