import DTDFVocab as DTDFVocab
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor collecting real-time temperature data from building infrastructure",
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor collecting real-time humidity data from building infrastructure",
    DTDFVocab:producedData HumidityDataTransmitted
]
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor detecting occupancy in building spaces",
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor measuring light levels for visual comfort monitoring",
    DTDFVocab:producedData LightDataTransmitted
]
instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor measuring carbon dioxide levels for indoor air quality",
    DTDFVocab:producedData CO2DataTransmitted
]
instance EnergyMeter : DTDFVocab:SensingComponent [
    base:desc "Physical meter measuring energy consumption for building systems",
    DTDFVocab:producedData EnergyDataTransmitted
]
instance HVACFlowSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor monitoring HVAC system flow rates and performance",
    DTDFVocab:producedData HVACFlowDataTransmitted
]
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance LightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]
instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]
instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeter
]
instance HVACFlowDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACFlowSensor
]
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature measurements transmitted via MQTT",
    DTDFVocab:fromData TemperatureDataTransmitted,
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]
instance HumidityData : DTDFVocab:Data [
    base:desc "Real-time humidity measurements transmitted via MQTT",
    DTDFVocab:fromData HumidityDataTransmitted,
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]
instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy data transmitted via MQTT",
    DTDFVocab:fromData OccupancyDataTransmitted,
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]
instance LightData : DTDFVocab:Data [
    base:desc "Real-time light level data transmitted via MQTT",
    DTDFVocab:fromData LightDataTransmitted,
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]
instance CO2Data : DTDFVocab:Data [
    base:desc "Real-time carbon dioxide concentration data transmitted via MQTT",
    DTDFVocab:fromData CO2DataTransmitted,
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]
instance EnergyData : DTDFVocab:Data [
    base:desc "Real-time energy consumption data transmitted via MQTT",
    DTDFVocab:fromData EnergyDataTransmitted,
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]
instance HVACFlowData : DTDFVocab:Data [
    base:desc "Real-time HVAC flow rate data transmitted via MQTT",
    DTDFVocab:fromData HVACFlowDataTransmitted,
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]
instance HonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono protocol for MQTT-based real-time data exchange between physical sensors and digital twin",
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, ControlLogicExecutionService
]
instance DittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for device management and MQTT-based data synchronization",
    DTDFVocab:enables RealTimeMonitoringService, ControlLogicExecutionService
]
instance UnrealEngineEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for interactive 3D visualization of building models",
    DTDFVocab:enables InteractiveVisualizationService
]
instance RevitEnabler : DTDFVocab:Enabler [
    base:desc "Autodesk Revit for BIM model creation and authoring",
    DTDFVocab:enables BIMModelCreationService
]
instance ModelDrivenEngineeringEnabler : DTDFVocab:Enabler [
    base:desc "Model-driven engineering tools for automated transformation of BIM to runtime artifacts",
    DTDFVocab:enables SimulationService, ControlLogicExecutionService
]
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Geometric representation of building structure from BIM model",
    DTDFVocab:inputTo ModelDrivenEngineeringEnabler
]
instance BIMSpatialModel : DTDFVocab:Model [
    base:desc "Spatial relationships and layout data from BIM model",
    DTDFVocab:inputTo ModelDrivenEngineeringEnabler
]
instance BIMFunctionalModel : DTDFVocab:Model [
    base:desc "Functional and operational data from BIM model",
    DTDFVocab:inputTo ModelDrivenEngineeringEnabler
]
instance SensorConfigModel : DTDFVocab:Model [
    base:desc "Sensor configuration details embedded in BIM metadata",
    DTDFVocab:inputTo ModelDrivenEngineeringEnabler
]
instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic definitions for building systems",
    DTDFVocab:inputTo ModelDrivenEngineeringEnabler
]
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring insights for building operational data"
]
instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insights derived from building performance simulations"
]
instance BIMModelInsight : DTDFVocab:Insight [
    base:desc "Insights related to BIM model creation and enrichment"
]
instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics for optimizing energy consumption based on sensor data and model simulations"
]
instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Insights for adjusting lighting and shading to maintain visual comfort"
]
instance HealthEffectInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics for managing health effects related to indoor environmental conditions"
]
instance MaintenanceRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for maintenance schedules based on system performance data"
]
instance OperationalAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Suggestions for operational adjustments to improve building efficiency"
]
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D visualization of building infrastructure for facility management"
]
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automated control signal to adjust lighting levels based on occupancy and light sensor data",
    DTDFVocab:IsAutomatic true
]
instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Automated control signal to adjust HVAC settings for optimal energy use",
    DTDFVocab:IsAutomatic true
]
instance AdjustShadingAction : DTDFVocab:Action [
    base:desc "Automated control signal to adjust window shades for visual comfort",
    DTDFVocab:IsAutomatic true
]
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of building operational data for immediate insights",
    DTDFVocab:provides RealTimeMonitoringInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance under various scenarios",
    DTDFVocab:provides SimulationInsight
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy optimization, visual comfort adjustments, and health effect management",
    DTDFVocab:provides EnergyOptimizationInsight, VisualComfortInsight, HealthEffectInsight, MaintenanceRecommendationInsight, OperationalAdjustmentInsight
]
instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization of building infrastructure using Unreal Engine 5",
    DTDFVocab:provides VisualizationInsight
]
instance ControlLogicExecutionService : DTDFVocab:Service [
    base:desc "Automated control logic execution for building operations",
    DTDFVocab:provides AdjustLightingAction, AdjustHVACAction, AdjustShadingAction
]
instance BIMModelCreationService : DTDFVocab:Service [
    base:desc "Service for creating and enriching BIM models using Revit",
    DTDFVocab:provides BIMModelInsight
]
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling lighting systems in the building infrastructure"
]
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling HVAC systems for temperature and airflow regulation"
]
instance ShadingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling window shades for visual comfort adjustment"
]
instance BuildingEnvironment : DTDFVocab:Environment [
    base:desc "Living Lab building infrastructure serving as the physical counterpart for unified virtual representation",
    base:contains TemperatureSensor, HumiditySensor, OccupancySensor, LightSensor, CO2Sensor, EnergyMeter, HVACFlowSensor, LightingActuator, HVACActuator, ShadingActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals and commands generated by the DT, such as HVAC adjustments or lighting controls, transmitted via Eclipse Hono and Ditto to Building Control Systems (BCS) actuators for execution in the physical building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with continuous data exchange enabling immediate response to physical changes."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service-oriented architecture where components like BIM models, Hono/Ditto middleware, and Unreal Engine visualization are orchestrated to enable bidirectional data flow, with standardized extension points for integrating custom services across the building's life cycle."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers all life cycle stages from design through construction to operations and refurbishment, with the DT enabling optimization during the operational phase while integrating BIM data from earlier stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validated using the Overall Digital Twin Entanglement (ODTE) metric to assess synchronization accuracy, semantic coherence, and interoperability between physical and virtual components."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT-based communication via Eclipse Hono for device connectivity and Ditto for digital twin management, enabling secure, scalable data exchange between physical sensors/actuators and the DT."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems via standardized extension points and interoperable protocols (e.g., MQTT), though specific external systems are not detailed in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to BIM standards (e.g., IFC) for semantic modeling, with standardized extension points for service integration, though specific external standards beyond BIM are not detailed."
]