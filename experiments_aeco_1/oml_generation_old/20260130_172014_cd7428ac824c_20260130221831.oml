// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modelled in BIM and deployed on site, streaming measurements to the Digital Twin"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modelled in BIM and deployed on site, streaming measurements to the Digital Twin"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor modelled in BIM and deployed on site, streaming measurements to the Digital Twin"
    DTDFVocab:producedData IlluminanceDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "General environmental sensor modelled in BIM and deployed on site, streaming measurements to the Digital Twin"
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// C4: Physical-to-virtual interaction – Data transmitted
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Stream of temperature measurements from the building"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo HonoIngestionEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Stream of occupancy counts from the building"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo HonoIngestionEnabler
]

instance IlluminanceData : DTDFVocab:Data [
    base:desc "Stream of illuminance (light level) measurements from the building"
    DTDFVocab:fromData IlluminanceDataTransmitted
    DTDFVocab:inputTo HonoIngestionEnabler
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Stream of additional environmental measurements (e.g., CO2, humidity) from the building"
    DTDFVocab:fromData EnvironmentalDataTransmitted
    DTDFVocab:inputTo HonoIngestionEnabler
]

// C2: Acting components
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control devices modelled in BIM and commandable by the Digital Twin"
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve actuators modelled in BIM and commandable by the Digital Twin"
]

instance BCSActuator : DTDFVocab:ActingComponent [
    base:desc "Other building control system actuators modelled in BIM and commandable by the Digital Twin"
]

// C11: Enablers
instance HonoIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono gateway for IoT data ingestion from physical sensors"
    DTDFVocab:enables MonitoringDashboardService, PredictiveAnalyticsService, PhysicsSimulationService
]

instance DittoStateEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for Digital Twin state management and persistence"
    DTDFVocab:enables PhysicsSimulationService, PredictiveAnalyticsService, VisualizationService
]

instance UnrealEngineVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime for immersive 3D visualization of the Twin"
    DTDFVocab:enables VisualizationService
]

instance ModelDrivenEngineeringEnabler : DTDFVocab:Enabler [
    base:desc "Model-driven engineering tooling for automatic model‑to‑text transformations and artifact generation"
    DTDFVocab:enables MonitoringDashboardService, PhysicsSimulationService, PredictiveAnalyticsService, VisualizationService
]

// C10: Models/Data
instance BIMSemanticModel : DTDFVocab:Model [
    base:desc "BIM semantic model enriched with device metadata"
    DTDFVocab:inputTo DittoStateEnabler
]

instance DeviceMetadataModel : DTDFVocab:Model [
    base:desc "Metadata model describing sensors and actuators extracted from BIM"
    DTDFVocab:inputTo DittoStateEnabler
]

instance RuntimeSensorDataModel : DTDFVocab:Model [
    base:desc "Model of runtime sensor data streams"
    DTDFVocab:inputTo HonoIngestionEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model governing actuator commands"
    DTDFVocab:inputTo DittoStateEnabler
]

instance Visual3DModel : DTDFVocab:Model [
    base:desc "3D visual model rendered in Unreal Engine 5"
    DTDFVocab:inputTo UnrealEngineVisualizationEnabler
]

// C6: Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards aggregating live sensor data"
    DTDFVocab:provides VisualDecisionSupportInsight, LightingControlAction, HVACValveAction
]

instance PhysicsSimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation of building energy performance"
    DTDFVocab:provides LightingScheduleOptimizationInsight, HVACSetpointOptimizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy optimisation and anomaly detection"
    DTDFVocab:provides PredictiveAlertInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D visualization of the building Twin in Unreal Engine 5"
    DTDFVocab:provides VisualDecisionSupportInsight
]

// C17: Insights
instance LightingScheduleOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendation for lighting schedules to reduce energy consumption"
]

instance HVACSetpointOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendation for HVAC set‑points to improve comfort and efficiency"
]

instance PredictiveAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive alert about potential energy waste or equipment failure"
]

instance VisualDecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Visual decision support dashboard for facility managers"
]

// C17: Actions
instance LightingControlAction : DTDFVocab:Action [
    base:desc "Command to adjust lighting based on schedule optimization"
    DTDFVocab:IsAutomatic false
]

instance HVACValveAction : DTDFVocab:Action [
    base:desc "Command to set HVAC valve positions based on set‑point optimization"
    DTDFVocab:IsAutomatic false
]

// C15: Environment
instance AcademicBuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, OccupancySensor, IlluminanceSensor, EnvironmentalSensor,
                LightingControlActuator, HVACValveActuator, BCSActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command flow from the Digital Twin to the building control actuators through the same Hono/Ditto middleware, allowing the Twin to issue lighting or HVAC set-point adjustments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time (continuous) synchronization; data are processed as they arrive, supporting near-instantaneous control loops."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service-oriented architecture where the enriched BIM model is the central semantic hub, Hono/Ditto provide the real-time communication layer, and optional services (e.g., analytics, control plugins) are plugged in via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers design (BIM authoring), construction (installation of sensors/actuators) and operation (post-occupancy monitoring and optimisation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed using the Overall Digital Twin Entanglement (ODTE) metric; the BIM model is validated before transformation to ensure semantic correctness and reduce drift between physical and digital states."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real-time data exchange is realized through Eclipse Hono (IoT gateway) linked to Eclipse Ditto for twin state synchronization; the middleware mediates bidirectional communication between physical devices and the Digital Twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Built upon BIM as an industry-standard data model; uses standardized extension points and adheres to open-source DT frameworks (Eclipse Hono/Ditto) that follow interoperable protocols."
]