// C3: Physical sensing components
instance HVACTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "HVAC temperature sensor defined as a BIM element with metadata type and location, streamed to the twin"
    DTDFVocab:producedData HVACTempDataTransmitted
]

instance LightingIlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting illuminance sensor modeled in BIM with type and location metadata for real‑time streaming"
    DTDFVocab:producedData LightingIllumDataTransmitted
]

instance OccupancyPresenceSensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy presence sensor captured in the BIM model, providing occupancy state to the twin"
    DTDFVocab:producedData OccupancyPresenceDataTransmitted
]

instance EnvelopeHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Building envelope humidity sensor represented as a BIM component, delivering moisture data"
    DTDFVocab:producedData EnvelopeHumidityDataTransmitted
]

// C4: DataTransmitted
instance HVACTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACTemperatureSensor
]

instance LightingIllumDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingIlluminanceSensor
]

instance OccupancyPresenceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyPresenceSensor
]

instance EnvelopeHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvelopeHumiditySensor
]

// C5: Data (processed or raw)
instance HVACTempData : DTDFVocab:Data [
    base:desc "Temperature readings from the HVAC system used for monitoring and simulation"
    DTDFVocab:fromData HVACTempDataTransmitted
    DTDFVocab:inputTo EclipseHonoIngestion, EclipseDittoTwinState, UnrealEngineVisualization
]

instance LightingIllumData : DTDFVocab:Data [
    base:desc "Illuminance levels from lighting sensors for daylighting analysis"
    DTDFVocab:fromData LightingIllumDataTransmitted
    DTDFVocab:inputTo EclipseHonoIngestion, EclipseDittoTwinState, UnrealEngineVisualization
]

instance OccupancyPresenceData : DTDFVocab:Data [
    base:desc "Binary occupancy status used for space‑utilization insights"
    DTDFVocab:fromData OccupancyPresenceDataTransmitted
    DTDFVocab:inputTo EclipseHonoIngestion, EclipseDittoTwinState, UnrealEngineVisualization
]

instance EnvelopeHumidityData : DTDFVocab:Data [
    base:desc "Humidity measurements from envelope sensors influencing moisture‑risk assessments"
    DTDFVocab:fromData EnvelopeHumidityDataTransmitted
    DTDFVocab:inputTo EclipseHonoIngestion, EclipseDittoTwinState, UnrealEngineVisualization
]

// C11: Enablers
instance EclipseHonoIngestion : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides secure, scalable IoT data ingestion for streaming sensor measurements"
    DTDFVocab:enables RealTimeMonitoringService, FaultDetectionService
]

instance EclipseDittoTwinState : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital‑twin state, bidirectional data exchange, and command handling"
    DTDFVocab:enables RealTimeMonitoringService, EnergyOptimizationService, ControlActionService,
                PhysicsSimulationService, FaultDetectionService
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine renders high‑fidelity, interactive 3D visualizations of the building model"
    DTDFVocab:enables Interactive3DVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides continuous real‑time monitoring of streamed sensor data"
    DTDFVocab:provides MonitoringInsight
]

instance PhysicsSimulationService : DTDFVocab:Service [
    base:desc "Executes physics‑based building performance simulation using control logic and BIM geometry"
    DTDFVocab:provides PerformanceInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes energy consumption and occupant comfort across the building lifecycle"
    DTDFVocab:provides EnergyOptimizationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Runs predictive analytics on sensor streams to detect faults in HVAC, lighting, and envelope systems"
    DTDFVocab:provides FaultDetectionInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Delivers rich, interactive 3D visualizations for stakeholders via Unreal Engine"
    DTDFVocab:provides VisualizationAction
]

instance ControlActionService : DTDFVocab:Service [
    base:desc "Exposes actuation commands to facility managers for remote control of building systems"
    DTDFVocab:provides ControlAction
]

// C17: Insights/Actions
instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Shows current sensor states, enabling facility managers to assess building performance"
]

instance PerformanceInsight : DTDFVocab:Insight [
    base:desc "Indicates thermal comfort and load predictions derived from physics‑based simulation"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommends actions to reduce energy usage while maintaining occupant comfort"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Alerts when anomalous sensor patterns suggest equipment faults"
]

instance VisualizationAction : DTDFVocab:Action [
    base:desc "Interactive 3D navigation action allowing users to explore the digital twin visually"
    DTDFVocab:IsAutomatic false
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Command action to change actuator state (e.g., adjust HVAC set‑point) from the twin"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance HVACTemperatureActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator defined in BIM with an identifier addressable by the twin for set‑point adjustments"
]

instance LightingDimmingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator modeled as a BIM element, controllable via twin commands"
]

instance ShadingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Exterior shading actuator represented in BIM, enabling remote blind operation through the twin"
]

// C10: Models/Data
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Geometric representation extracted from the BIM model for visualization and simulation"
    DTDFVocab:inputTo EclipseDittoTwinState, UnrealEngineVisualization
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model containing control logic authored by building control engineers within BIM"
    DTDFVocab:inputTo EclipseDittoTwinState, PhysicsSimulationService
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based analytical model used by the simulation service to evaluate building performance"
    DTDFVocab:inputTo PhysicsSimulationService
]

// Environment containing all components
instance LivingLabEnvironment : DTDFVocab:Environment [
    base:contains HVACTemperatureSensor, LightingIlluminanceSensor, OccupancyPresenceSensor, EnvelopeHumiditySensor,
                 HVACTemperatureActuator, LightingDimmingActuator, ShadingControlActuator,
                 BIMGeometricModel, ControlLogicModel, PhysicsSimulationModel
]

// Generic component definition
instance BuildingComponent : DTDFVocab:Component [
    base:desc "Abstract representation of a building component participating in the digital twin"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication is supported by the DT Framework, which relays control commands from Facility Managers (or other DT users) to physical building devices. Commands are generated from the digital twin model in Ditto and transmitted through the same Eclipse Hono gateway to the field devices, enabling real‑time monitoring and control. The document does not provide details on command formats, validation, authentication, feedback loops, or execution confirmation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The document states that the Digital Twin provides real‑time insights by continuously integrating runtime data with static models to support predictive analytics across the building lifecycle, but it does not specify synchronization frequencies, latency requirements, or temporal granularity."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a full DT lifecycle composed of (1) device modeling within BIM where sensors, actuators, and controllers are added; (2) model enrichment and transformation using model‑driven engineering (MDE) to extract a structured representation; (3) automatic generation of deployable DT artifacts; (4) deployment and runtime operation where real‑time data exchange keeps the twin synchronized; and (5) ongoing evolution through modular extension points. Transition between stages is managed by the MDE pipeline that converts enriched BIM models into executable twin components, and lifecycle governance is implied by the requirement to support the complete life‑cycle of DT deployment and operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by embedding device definitions and control logic directly into the BIM model, creating a single source of truth. Continuous real‑time synchronization between physical and digital twins functions as an implicit validation mechanism: discrepancies trigger updates. The framework relies on the unified semantic foundation and MDE‑generated artifacts to ensure consistency, but explicit validation, verification, uncertainty quantification, or quality‑assurance procedures are not described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is built on BIM (Building Information Modeling) as the core industry standard for representing buildings and for encoding device information. BIM serves as the semantic basis from which structured DT models are derived. The framework defines standardized extension points (i.e., a modular API contract) to ensure that custom services and analytics can interoperate with the core twin platform. No additional industry standards, certification schemes, or formal compliance frameworks (e.g., IFC, ISO 19650) are mentioned in the document."
]