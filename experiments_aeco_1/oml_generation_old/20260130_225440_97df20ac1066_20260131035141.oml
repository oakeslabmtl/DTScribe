instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors capturing temperature data for post-occupancy monitoring"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors capturing light levels for post-occupancy monitoring"
    DTDFVocab:producedData LightLevelDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors capturing occupancy data for post-occupancy monitoring"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature data transmitted from physical sensors"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance LightLevelData : DTDFVocab:Data [
    base:desc "Real-time light level data transmitted from physical sensors"
    DTDFVocab:fromData LightLevelDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy data transmitted from physical sensors"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for IoT connectivity"
    DTDFVocab:enables RealTimeMonitoringService, EnergyOptimizationService, PredictiveAnalyticsService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for digital twin management"
    DTDFVocab:enables RealTimeMonitoringService, SimulationService, InteractiveVisualizationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for interactive visualization"
    DTDFVocab:enables InteractiveVisualizationService
]

instance BIMAuthoringTools : DTDFVocab:Enabler [
    base:desc "BIM authoring tools for model creation"
    DTDFVocab:enables RealTimeMonitoringService, SimulationService
]

instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "BIM model containing geometric, spatial, and functional data of building components"
    DTDFVocab:inputTo BIMAuthoringTools, EclipseDitto
]

instance SensorMetadata : DTDFVocab:Data [
    base:desc "Metadata for sensors including device specifications and configuration"
    DTDFVocab:inputTo EclipseDitto
]

instance ActuatorMetadata : DTDFVocab:Data [
    base:desc "Metadata for actuators including device specifications and configuration"
    DTDFVocab:inputTo EclipseDitto
]

instance MiddlewareConfigurations : DTDFVocab:Data [
    base:desc "Middleware configurations for Eclipse Hono and Ditto"
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for HVAC system control configured via BIM models"
]

instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Controller for lighting systems configured via BIM models"
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of building operations using sensor data"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Building simulation for scenario analysis and forecasting"
    DTDFVocab:provides SimulationResultsInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy optimization using reinforcement learning for efficient resource allocation"
    DTDFVocab:provides EnergyConsumptionOptimizationInsight, AdjustHVACAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for visual comfort and non-visual health effects"
    DTDFVocab:provides VisualComfortAdjustmentInsight, NonVisualHealthEffectInsight, AdjustLightingAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization of building operations using Unreal Engine 5"
    DTDFVocab:provides Interactive3DVisualization
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time data stream for continuous monitoring of building operations"
]

instance SimulationResultsInsight : DTDFVocab:Insight [
    base:desc "Predictive simulation results for building performance analysis"
]

instance EnergyConsumptionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Predictive insights for energy consumption optimization based on sensor data analysis"
]

instance VisualComfortAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Predictive insights for adjusting lighting to maintain visual comfort"
]

instance NonVisualHealthEffectInsight : DTDFVocab:Insight [
    base:desc "Predictive insights for managing non-visual health effects through environmental adjustments"
]

instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of HVAC system to optimize energy usage"
    DTDFVocab:IsAutomatic true
]

instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting systems for visual comfort and health"
    DTDFVocab:IsAutomatic true
]

instance Interactive3DVisualization : DTDFVocab:Action [
    base:desc "Real-time 3D visualization of building data for interactive analysis"
    DTDFVocab:IsAutomatic false
]

instance ModularArchitecture : DTDFVocab:Component [
    base:desc "Modular service-oriented architecture with standardized extension points for decentralized integration"
]

instance LivingLabBuildingEnvironment : DTDFVocab:Environment [
    base:desc "Living Lab case study for building operations monitoring and optimization throughout its life cycle"
    base:contains TemperatureSensor, LightLevelSensor, OccupancySensor, HVACActuator, LightingController, BuildingBIMModel, EclipseHono, EclipseDitto, UnrealEngine5, BIMAuthoringTools, RealTimeMonitoringService, SimulationService, EnergyOptimizationService, PredictiveAnalyticsService, InteractiveVisualizationService, RealTimeMonitoringInsight, SimulationResultsInsight, EnergyConsumptionOptimizationInsight, VisualComfortAdjustmentInsight, NonVisualHealthEffectInsight, AdjustHVACAction, AdjustLightingAction, Interactive3DVisualization, ModularArchitecture
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals from the DT to physical actuators via Building Control Systems (BCS) for adjusting building operations."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with continuous data exchange for immediate response to physical changes in the building environment."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized framework where BIM serves as the semantic backbone, integrated with Eclipse Hono and Ditto for real-time data exchange and Unreal Engine for visualization, enabling bidirectional communication between physical and virtual assets."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers all building life cycle phases from initial design, construction, operation, to refurbishment and adaptation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Evaluated using the Overall Digital Twin Entanglement (ODTE) metric to quantify the alignment between the digital twin and its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono and Ditto facilitating real-time data exchange for bidirectional communication between physical and virtual assets."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized extension points enabling integration with external systems and services for cross-platform interoperability."
]