// Sensors
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor integrated into the building control system, providing ambient temperature readings for the Digital Twin."
    DTDFVocab:producedData TempTemperatureDataTransmitted
]

instance LightingLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting level sensor measuring illumination intensity for lighting comfort monitoring."
    DTDFVocab:producedData LightingLevelDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor detecting presence to inform building automation and energy optimization."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// Data transmitted over Hono/Ditto
instance TempTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance LightingLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingLevelSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// Live sensor data
instance TempTemperatureData : DTDFVocab:Data [
    base:desc "Temperature measurement data transmitted from TemperatureSensor via Eclipse Hono to Eclipse Ditto."
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
    DTDFVocab:fromData TempTemperatureDataTransmitted
]

instance LightingLevelData : DTDFVocab:Data [
    base:desc "Illumination level data from LightingLevelSensor, used for real‑time monitoring and optimization."
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
    DTDFVocab:fromData LightingLevelDataTransmitted
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy state data from OccupancySensor, informing predictive maintenance and scheduling."
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
    DTDFVocab:fromData OccupancyDataTransmitted
]

// Acting components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator embedded in the building, controllable via BIM-configured control system."
]

instance LightingSwitchActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting switch actuator controlling on/off status of lights, integrated into the control infrastructure."
]

// Models
instance BIMIFCModel : DTDFVocab:Model [
    base:desc "BIM IFC model containing geometric and functional information of the Living Lab academic building."
    DTDFVocab:inputTo MDETransformEnabler
]

instance DeviceTwinModel : DTDFVocab:Model [
    base:desc "Eclipse Ditto device twin model representing each building element within the Digital Twin."
    DTDFVocab:inputTo DittoEnabler
]

instance SimulationDataModel : DTDFVocab:Model [
    base:desc "Supplementary simulation data generated by the twin’s analytical modules for optimisation."
    DTDFVocab:inputTo PerformanceSimulationService
]

// Enablers
instance HonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono multi‑tenant MQTT broker mediating real‑time data transport from sensors to Ditto."
    DTDFVocab:enables MonitoringDashboardService, PerformanceSimulationService, LightingScheduleOptimizationService, MaintenanceTaskPlanningService, ReinforcementLearningOptimizationService
]

instance DittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto device twin platform enabling registration, data storage, and actuation of building devices."
    DTDFVocab:enables MonitoringDashboardService, PerformanceSimulationService, LightingScheduleOptimizationService, MaintenanceTaskPlanningService, ReinforcementLearningOptimizationService
]

instance MDETransformEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation tools extracting semantics from BIM for runtime configuration."
    DTDFVocab:enables ModelDrivenPipelineService
]

instance ScriptingEnabler : DTDFVocab:Enabler [
    base:desc "Scripting environment orchestrating automated configuration within Ditto."
    DTDFVocab:enables RuntimeConfigurationService
]

instance UnrealEngine5VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 acting as the rendering engine for immersive visualization of the building model."
    DTDFVocab:enables ImmersiveVisualizationService
]

// Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard built with Ditto, visualizing live temperature, lighting, and occupancy data."
    DTDFVocab:provides EnergyConsumptionInsight, LightingComfortInsight
]

instance PerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation module evaluating building performance scenarios using BIM and live sensor data."
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance LightingScheduleOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement learning based lighting schedule optimization, generating recommendations to improve comfort and energy efficiency."
    DTDFVocab:provides OptimizationRecommendationInsight, AdjustLightingAction
]

instance MaintenanceTaskPlanningService : DTDFVocab:Service [
    base:desc "Task planning service recommending predictive maintenance based on sensor trends."
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization of the building model and twin state using Unreal Engine 5."
    DTDFVocab:provides VisualizationInsight
]

instance ModelDrivenPipelineService : DTDFVocab:Service [
    base:desc "Model-driven pipeline extracting semantics from BIM, generating runtime configuration, and deploying via Hono/Ditto configurator."
    DTDFVocab:provides PipelineInsight
]

instance RuntimeConfigurationService : DTDFVocab:Service [
    base:desc "Runtime configuration service applying automated scripts to configure Ditto device twins."
]

instance ReinforcementLearningOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement learning module that updates control policies for lighting and other building systems."
    DTDFVocab:provides UpdateControlPolicyAction
]

// Insights
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight on real‑time energy consumption derived from live temperature and lighting data."
]

instance LightingComfortInsight : DTDFVocab:Insight [
    base:desc "Insight on lighting comfort levels based on illumination and occupancy data."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation for optimizing lighting schedules to reduce energy usage while maintaining comfort."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance schedule based on trend analysis of environmental sensors."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight displaying the current state of the building in an immersive Unreal Engine 5 environment."
]

instance PipelineInsight : DTDFVocab:Insight [
    base:desc "Insight on the status and outcomes of the model‑driven pipeline deployment."
]

// Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting schedules to improve comfort while reducing energy consumption."
    DTDFVocab:IsAutomatic true
]

instance UpdateControlPolicyAction : DTDFVocab:Action [
    base:desc "Updating control policies in Ditto based on reinforcement learning outcomes."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin are sent back to the building’s control system through Ditto, which forwards them via Eclipse Hono to the respective actuators in the physical building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization; data and command exchanges occur immediately upon availability without a fixed interval."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centrally managed DT constellation where each physical asset is represented by a Ditto twin, all interconnected via Hono, and rendered through Unreal Engine; the constellation is modular and expandable with additional service plug‑ins."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (ideal BIM), Construction (manufactured with BIM‑based device profiles), and Operation (live PT–DT synchronization), with the framework supporting each phase through model extraction and runtime deployment."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The entanglement of the Digital Twin with its physical counterpart is quantified using the Overall Digital Twin Entanglement (ODTE) metric."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the physical building and the twin is enabled by Eclipse Hono’s broker, which transports messages (e.g., sensor data and control commands) to and from Ditto device twins."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin is deployed in a modular, service‑oriented environment that can be scaled across cloud or edge nodes; the architecture supports repeated, reproducible deployments via automated MDE pipelines."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability with external building automation and management platforms through Eclipse Hono/Ditto; standardized integration points allow additional data sources and services to be incorporated."
]