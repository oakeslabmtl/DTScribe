    DTDFVocab:IsAutomatic true
]

// C18: Environment
instance BuildingFacilityEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, PressureSensor, OccupancySensor,
        EnergyMeter, ControlSystemStatusSensor, OccupancyActuator,
        HVACSetpointActuator, EnergyOptimizationActuator,
        PredictiveMaintenanceActuator, ControlLogicDeploymentActuator,
        BuildingGeometryModel, EnrichedBIMModel, PhysicsSimulationModel,
        OptimizationModel, ControlLogicModel, DTArtifactModel
]

instance SmartBuildingInfrastructureEnvironment : DTDFVocab:Environment [
    base:contains BuildingFacilityEnvironment,
        ModelDrivenEngineeringTool, BIMIntegrationLayer,
        MQTTProtocolStack, RealTimeDatabase, ChangeDataCaptureEngine,
        ImmersiveVisualizationPlatform, CustomServiceDevelopmentKit,
        PhysicsSimulationEngine, MLIntegrationService,
        BIMModelingTool, ModelCompiler, CI/CDPipeline,
        ContainerizationPlatform, EdgeComputingNode,
        RealTimeDataExchangeService, MonitoringVisualizationService,
        ControlLogicService, PredictiveAnalyticsService,
        OptimizationEngineEnabler, CustomServiceIntegrationService,
        ValidationService, DTArtifactGenerationService,
        DeploymentAutomationService, RuntimeInfrastructureService
