// C2: Acting Components
instance OccupancyActuator : DTDFVocab:ActingComponent [
    base:desc "Actuates occupancy-based lighting and HVAC systems in response to real-time occupancy data"
]

instance HVACSetpointActuator : DTDFVocab:Actuator [
    base:desc "Adjusts HVAC system setpoints based on predictive analytics and real-time environmental data"
]

instance EnergyOptimizationActuator : DTDFVocab:Actuator [
    base:desc "Modifies energy consumption patterns through dynamic control strategies for efficiency optimization"
]

instance PredictiveMaintenanceActuator : DTDFVocab:Actuator [
    base:desc "Automatically triggers maintenance actions based on predicted equipment failures derived from DT analytics"
]

instance ControlLogicDeploymentActuator : DTDFVocab:Actuator [
    base:desc "Deploys BIM-defined control logic directly into the DT framework for automated building operations"
]

// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Measures real-time temperature across building zones with sub-second latency requirements"
    DTDFVocab:producedData TemperatureDataStream
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Tracks air pressure variations in HVAC systems with high-frequency sampling (100Hz)"
    DTDFVocab:producedData PressureDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Detects real-time occupancy patterns using IoT devices with low-power consumption requirements"
    DTDFVocab:producedData OccupancyDataStream
]

instance EnergyMeter : DTDFVocab:SensingComponent [
    base:desc "Continuously measures energy consumption with millisecond-level precision for optimization analytics"
    DTDFVocab:producedData EnergyConsumptionDataStream
]

instance ControlSystemStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors HVAC/lighting control system status and fault conditions"
    DTDFVocab:producedData ControlSystemStatusDataStream
]

instance BIMDeviceModel : DTDFVocab:SensingComponent [
    base:desc "Represents physical building devices in enriched BIM models for control logic definition"
    DTDFVocab:producedData BIMDeviceMetadata
]

// C4: Data Transmitted
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyConsumptionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeter
]

instance ControlSystemStatusDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ControlSystemStatusSensor
]

instance BIMDeviceMetadata : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BIMDeviceModel
]

instance MQTTProtocolData : DTDFVocab:DataTransmitted [
    base:desc "Lightweight MQTT message payloads for low-latency communication between sensors and DT components"
    DTDFVocab:producedFrom TemperatureDataStream, PressureDataStream,
        OccupancyDataStream, EnergyConsumptionDataStream,
        ControlSystemStatusDataStream
]

instance TimeSeriesDatabaseData : DTDFVocab:DataTransmitted [
    base:desc "High-frequency time-series data stored in InfluxDB for real-time synchronization"
    DTDFVocab:producedFrom TemperatureDataStream, PressureDataStream,
        OccupancyDataStream, EnergyConsumptionDataStream
]

instance ChangeDataCaptureData : DTDFVocab:DataTransmitted [
    base:desc "CDC-captured discrepancies between physical and digital states for synchronization reconciliation"
    DTDFVocab:producedFrom TemperatureDataStream, PressureDataStream,
        OccupancyDataStream, EnergyConsumptionDataStream,
        ControlSystemStatusDataStream
]

// C5: Data
instance RealTimeEnvironmentData : DTDFVocab:Data [
    base:desc "Comprehensive real-time environmental metrics (temperature, pressure, occupancy) for operational monitoring"
    DTDFVocab:fromData TemperatureDataStream, PressureDataStream,
        OccupancyDataStream
    DTDFVocab:inputTo RealTimeDatabaseEnabler
]

instance EnergyPerformanceMetrics : DTDFVocab:Data [
    base:desc "Historical and real-time energy consumption patterns for optimization analytics"
    DTDFVocab:fromData EnergyConsumptionDataStream
    DTDFVocab:inputTo OptimizationEngineEnabler
]

instance ControlSystemHealthData : DTDFVocab:Data [
    base:desc "Fault detection and system status information for proactive maintenance"
    DTDFVocab:fromData ControlSystemStatusDataStream
    DTDFVocab:inputTo PredictiveMaintenanceService
]

instance BIMControlLogicData : DTDFVocab:Data [
    base:desc "Structured control logic definitions derived from enriched BIM models"
    DTDFVocab:fromData BIMDeviceMetadata
    DTDFVocab:inputTo ControlLogicService
]

instance SynchronizationValidationData : DTDFVocab:Data [
    base:desc "Data used to validate real-time synchronization accuracy between physical and digital twins"
    DTDFVocab:fromData MQTTProtocolData, ChangeDataCaptureData
    DTDFVocab:inputTo ValidationService
]

instance PredictiveAnalyticsData : DTDFVocab:Data [
    base:desc "DT-generated datasets for training custom ML models and predictive services"
    DTDFVocab:fromData RealTimeEnvironmentData, EnergyPerformanceMetrics
    DTDFVocab:inputTo MLIntegrationService
]

// C10: Models
instance BuildingGeometryModel : DTDFVocab:Model [
    base:desc "Geometric representation of building structure extracted from BIM for spatial alignment"
    DTDFVocab:inputTo BIMIntegrationLayer
]

instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with sensors, actuators, and control logic for DT integration"
    DTDFVocab:inputTo ModelDrivenEngineeringTool
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Discrete-event simulation model of building interactions (HVAC, occupancy patterns)"
    DTDFVocab:inputTo PhysicsSimulationEngine
]

instance OptimizationModel : DTDFVocab:Model [
    base:desc "Structured model for dynamic optimization of building parameters and energy efficiency"
    DTDFVocab:inputTo OptimizationEngineEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "BIM-derived control logic definitions for automated building operations"
    DTDFVocab:inputTo ControlLogicService
]

instance DTArtifactModel : DTDFVocab:Model [
    base:desc "Deployable DT artifacts generated via MDE transformations from enriched BIM"
    DTDFVocab:inputTo ModelCompiler
]

// C11: Enablers
instance ModelDrivenEngineeringTool : DTDFVocab:Enabler [
    base:desc "Automates transformation of enriched BIM models into deployable DT artifacts using M2T/M2M"
    DTDFVocab:enables DTArtifactGenerationService
]

instance BIMIntegrationLayer : DTDFVocab:Enabler [
    base:desc "Bridges static BIM representations with dynamic DT components via IFC/COBIE standards"
    DTDFVocab:enables BuildingGeometryModel, EnrichedBIMModel
]

instance MQTTProtocolStack : DTDFVocab:Enabler [
    base:desc "Provides lightweight MQTT communication with QoS levels for reliable low-latency data exchange"
    DTDFVocab:enables RealTimeDataExchangeService
]

instance RealTimeDatabase : DTDFVocab:Enabler [
    base:desc "Time-series database (InfluxDB) for high-frequency DT data storage and streaming"
    DTDFVocab:enables RealTimeDatabaseEnabler
]

instance ChangeDataCaptureEngine : DTDFVocab:Enabler [
    base:desc "Automatically reconciles discrepancies between physical and digital states via CDC mechanisms"
    DTDFVocab:enables SynchronizationValidationService
]

instance ImmersiveVisualizationPlatform : DTDFVocab:Enabler [
    base:desc "Unity 3D/WebGL framework for interactive 3D/2D DT visualization with AR support"
    DTDFVocab:enables MonitoringVisualizationService
]

instance CustomServiceDevelopmentKit : DTDFVocab:Enabler [
    base:desc "APIs and plugin framework for DT Engineers to extend functionality via JavaScript/TypeScript"
    DTDFVocab:enables CustomServiceIntegrationService
]

instance PhysicsSimulationEngine : DTDFVocab:Enabler [
    base:desc "Integrates discrete-event simulation for modeling building interactions and dynamics"
    DTDFVocab:enables PhysicsSimulationModel
]

instance MLIntegrationService : DTDFVocab:Enabler [
    base:desc "Supports pre-trained ML models (TensorFlow Lite) for edge deployment and custom training"
    DTDFVocab:enables PredictiveAnalyticsService
]

instance BIMModelingTool : DTDFVocab:Enabler [
    base:desc "Autodesk Revit/Graphisoft ArchiCAD for device modeling and control logic definition"
    DTDFVocab:enables BIMDeviceModel
]

instance ModelCompiler : DTDFVocab:Enabler [
    base:desc "Custom MDE-based compiler generating deployment-ready DT artifacts (Docker/Kubernetes)"
    DTDFVocab:enables DTArtifactModel
]

instance CI/CDPipeline : DTDFVocab:Enabler [
    base:desc "Automated workflows for testing, packaging, and deploying DT services via extension points"
    DTDFVocab:enables DeploymentAutomationService
]

instance ContainerizationPlatform : DTDFVocab:Enabler [
    base:desc "Docker/Kubernetes for scalable deployment of DT components with isolation"
    DTDFVocab:enables RuntimeInfrastructureService
]

instance EdgeComputingNode : DTDFVocab:Enabler [
    base:desc "Raspberry Pi/NVIDIA Jetson for real-time processing and sensor fusion at edge"
    DTDFVocab:enables EdgeProcessingService
]

// C6: Services
instance RealTimeDataExchangeService : DTDFVocab:Service [
    base:desc "Continuous bidirectional data exchange between physical building components and DT with sub-second latency"
    DTDFVocab:provides RealTimeEnvironmentData, SynchronizationValidationData
]

instance MonitoringVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D/2D interfaces for Facility Managers to monitor building states in real-time"
    DTDFVocab:provides ImmersiveVisualizationData
]

instance ControlLogicService : DTDFVocab:Service [
    base:desc "Automated deployment and management of BIM-defined control logic for building operations"
