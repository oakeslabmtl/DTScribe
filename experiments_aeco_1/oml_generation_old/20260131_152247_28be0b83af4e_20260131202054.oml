]

instance ValidationService : DTDFVocab:Service [
    base:desc "Automated testing of BIM-to-DT transformations and real-time synchronization protocols"
    DTDFVocab:provides SynchronizationValidationData
]

instance DTArtifactGenerationService : DTDFVocab:Service [
    base:desc "Creates deployable DT artifacts from enriched BIM models with minimal manual intervention"
