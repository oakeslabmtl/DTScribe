]

// C17: Insights/Actions
instance ImmersiveVisualizationData : DTDFVocab:Insight [
    base:desc "Real-time 3D/2D visualization of building states for Facility Managers to detect anomalies"
]

instance PredictiveMaintenanceInsights : DTDFVocab:Insight [
    base:desc "Predicted equipment failures and maintenance recommendations based on DT analytics"
    DTDFVocab:IsAutomatic true
]

instance EnergyOptimizationRecommendations : DTDFVocab:Insight [
    base:desc "Dynamic adjustments to energy consumption patterns for efficiency optimization"
    DTDFVocab:IsAutomatic true
]

instance ControlSystemHealthInsights : DTDFVocab:Insight [
    base:desc "Fault detection and system status information for proactive maintenance actions"
    DTDFVocab:IsAutomatic true
]

instance CustomAnalyticsService : DTDFVocab:Action [
    base:desc "Domain-specific analytics services developed by DT Engineers via plugin framework"
    DTDFVocab:IsAutomatic false
]

instance SynchronizationValidationData : DTDFVocab:Action [
    base:desc "Validation metrics ensuring real-time synchronization accuracy between physical and digital twins"
    DTDFVocab:IsAutomatic true
]

instance RealTimeDataValidation : DTDFVocab:Action [
    base:desc "Automated validation of data quality and consistency during synchronization"
    DTDFVocab:IsAutomatic true
]

instance DynamicControlStrategyAdjustment : DTDFVocab:Action [
