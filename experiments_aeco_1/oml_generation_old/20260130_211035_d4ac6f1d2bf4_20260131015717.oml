// C3: Physical sensing components
instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Light-level sensor embedded in the BIM model, used in the TwinLight and BOREALIS projects to provide runtime data to the twin."
    DTDFVocab:producedData LightLevelDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the BIM model, provides runtime occupancy data to the twin."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
    base:desc "Bidirectional data exchange via Eclipse Hono forwarding light-level readings to Eclipse Ditto in near real-time."
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
    base:desc "Bidirectional data exchange via Eclipse Hono forwarding occupancy readings to Eclipse Ditto in near real-time."
]

// C10: Data
instance LightLevelData : DTDFVocab:Data [
    base:desc "Live light-level sensor data stream used for monitoring and predictive analytics."
    DTDFVocab:fromData LightLevelDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy sensor data stream used for monitoring and predictive analytics."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Static BIM model enriched with control semantics, serving as the semantic backbone."
    DTDFVocab:inputTo EclipseDitto, UnrealEngine5
]

instance RuntimeDittoModel : DTDFVocab:Model [
    base:desc "Runtime representation of the digital twin stored in Eclipse Ditto, generated from model-to-text transformations."
    DTDFVocab:inputTo EclipseDitto
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides connectivity and forwards sensor data to the digital twin."
    DTDFVocab:enables RealTimeMonitoring, Simulation
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages twin instances and enables services such as predictive analytics and optimization."
    DTDFVocab:enables RealTimeMonitoring, Simulation, PredictiveAnalytics, Optimization, ImmersiveVisualization
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 delivers immersive 3‑D visualization of the building twin."
    DTDFVocab:enables ImmersiveVisualization
]

// C6: Services
instance RealTimeMonitoring : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building operation using live sensor data."
    DTDFVocab:provides OperationalCostReductionInsight, FacilityManagementDecisionSupport
]

instance Simulation : DTDFVocab:Service [
    base:desc "Simulation of building behavior for what‑if analysis."
    DTDFVocab:provides FacilityManagementDecisionSupport
]

instance PredictiveAnalytics : DTDFVocab:Service [
    base:desc "Predictive analytics for optimizing lighting and occupancy usage."
    DTDFVocab:provides OperationalCostReductionInsight, AdjustLightingAction
]

instance Optimization : DTDFVocab:Service [
    base:desc "Optimization of building operation to reduce operational costs."
    DTDFVocab:provides OperationalCostReductionInsight
]

instance ImmersiveVisualization : DTDFVocab:Service [
    base:desc "Immersive 3‑D visualization of the building twin via Unreal Engine 5."
    DTDFVocab:provides FacilityManagementDecisionSupport
]

// C17: Insights
instance OperationalCostReductionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating reduced operational costs through optimized lighting control."
]

instance FacilityManagementDecisionSupport : DTDFVocab:Insight [
    base:desc "Insight supporting enhanced decision‑making for facility managers."
]

// C17: Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting levels based on predictive analytics."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Dimmer actuator modelled in BIM, receives control commands from the twin to adjust light intensity."
]

instance LightingSwitchActuator : DTDFVocab:ActingComponent [
    base:desc "Switch actuator modelled in BIM, can be toggled by twin commands for on/off lighting control."
]

// C5: Environment & Components
instance LivingLabBuilding : DTDFVocab:Environment [
    base:desc "AECO domain building used as the Living Lab case study for the model‑driven digital twin framework."
    base:contains LightingDimmerActuator, LightingSwitchActuator, LightLevelSensor, OccupancySensor
]

instance BuildingControlSystem : DTDFVocab:Component [
    base:desc "Building control system integrating sensors and actuators for lighting management."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin are sent back through Eclipse Hono/Ditto to the physical actuators, enabling runtime control of building systems."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous near‑real‑time synchronization of sensor streams and control actions; no discrete batch intervals are specified."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular service‑oriented architecture consisting of a BIM‑derived model extraction layer, a Hono/Ditto configurator, a runtime twin store, and a visualization front‑end, linked through standardized extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the full building lifecycle: design (BIM creation), construction (device commissioning), and operation (runtime monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric is used to quantify how well the Digital Twin reflects its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Connectivity is realized through Eclipse Hono, which mediates device communication (via its protocol adapters) to Eclipse Ditto, enabling bidirectional data flow."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Relies on BIM as an industry‑standard modeling format and open‑source frameworks (Eclipse Hono, Ditto) that adhere to interoperable data exchange standards."
]