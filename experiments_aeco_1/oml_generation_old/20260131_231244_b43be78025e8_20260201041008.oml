instance BuildingEnvironment : DTDFVocab:Environment [
    base:desc "The virtual environment of the commercial building digital twin, containing structural geometry, HVAC, lighting, and control components."
    base:contains BuildingBIMModel, LightingControlActuator, HVACAirHandlerActuator, OccupancySensor
]

// Building BIM component
instance BuildingBIMModel : DTDFVocab:Component [
    base:desc "Enriched BIM model containing architectural geometry, photometric lighting data, and annotated controllers for HVAC, electrical, plumbing, and lighting."
]

// Acting components (actuators)
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling lighting fixtures, instantiated from BIM definition of controllable lighting devices."
]

instance HVACAirHandlerActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator regulating HVAC air handling units, defined in BIM as controllable devices."
]

// Sensing component
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Real‑time occupancy sensor providing live occupancy data streams for building operations."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// Data transmitted from the sensor
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// Data derived from the sensor
instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy status data derived from occupancy sensor streams."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler
]

// Models
instance BuildingGeometricModel : DTDFVocab:Model [
    base:desc "Geometric model capturing building structure and layout derived from enriched BIM."
    DTDFVocab:inputTo UnrealEngine5Enabler
]

instance BuildingBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model representing device control logic coded by Building Control Engineers."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance BuildingConfigurationalModel : DTDFVocab:Model [
    base:desc "Configurational model linking sensors, actuators, and controllers."
    DTDFVocab:inputTo EclipseHonoEnabler
]

// Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono enabler for device communication, handling command messages to actuators."
    DTDFVocab:enables ControlService, EnergyOptimizationService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto enabler providing device abstraction and twin representation."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 enabler rendering the visual twin with TwinComponent layer."
    DTDFVocab:enables VisualizationService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring sensor streams and system states in real‑time."
    DTDFVocab:provides OccupancyInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service providing predictive analytics and failure forecasting."
    DTDFVocab:provides TemperatureTrendInsight, EnergyEfficiencyInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing energy usage and system performance."
    DTDFVocab:provides EnergyEfficiencyInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Service enabling direct command issuance to building control systems."
    DTDFVocab:provides AdjustLightingAction, AdjustHVACAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service delivering interactive visualization dashboards for monitoring and control."
    DTDFVocab:provides OccupancyInsight, AdjustLightingAction
]

// Insights
instance OccupancyInsight : DTDFVocab:Insight [
    base:desc "Insight analyzing occupancy levels for comfort and energy use optimization."
]

instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Insight forecasting temperature trends to enable proactive HVAC adjustments."
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight measuring energy efficiency metrics and predicting cost implications."
]

// Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Action to adjust lighting levels based on occupancy and photometric data."
    DTDFVocab:IsAutomatic false
]

instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Action to modify HVAC setpoints for temperature control."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange capabilities enable continuous synchronization between the physical building and its digital twin, but the documents do not specify exact polling or push frequencies, latency thresholds, or temporal granularity beyond the term 'real‑time'."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT framework follows a modular architecture pattern with standardized extension points, enabling custom service integration and analytics. A central hub facilitates bidirectional data exchange between the physical building and the digital twin and provides a holistic approach to building lifecycle management. Runtime configuration management allows adaptability without full redeployment, supporting coordination among roles such as Building Control Engineers, Facility Managers, and DT Engineers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Initiation – Building control engineers enrich BIM models with sensor, actuator and controller elements, addressing BIM’s static limitations; Transformation – Using model‑driven engineering (MDE) the framework extracts structured representations from the enriched BIM and automatically generates deployable Digital‑Twin artifacts (model‑based digital assets); Deployment – Devices are provisioned, real‑time data‑exchange links are established to keep the digital twin synchronized with the physical building; Operation – Facility managers monitor the twin through immersive visualization dashboards, control physical infrastructure via the twin, and provide feedback for tuning; Evolution – DT engineers extend functionality by publishing custom services or analytics through standardized extension points; the modular architecture supports versioning and rollback. Governance is enforced through actor roles (Building Control Engineer, Facility Manager, DT Engineer) and lifecycle checkpoints defined in the deployment framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by validating enriched BIM models against defined schemas before conversion. Eclipse Ditto’s policy‑based validation enforces value ranges, units, and consistency for incoming sensor measurements, thereby preventing out‑of‑range data from corrupting the twin. Fault tolerance is achieved through Eclipse Hono’s at‑least‑once delivery semantics and Ditto’s persistent event storage, which safeguard against transient network failures. Pre‑execution checks for actuator commands ensure that potentially unsafe or conflicting actuations are rejected before reaching the physical device. The framework’s modular architecture allows for the integration of additional verification layers (e.g., simulation‑based validation) at defined extension points, thus supporting continuous quality assurance throughout the DT lifecycle."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT framework emphasizes interoperability across heterogeneous systems, supporting integration of external systems via standardized extension points and real‑time data exchange mechanisms. Specific data exchange protocols or interoperability standards are not detailed in the provided documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework aims for interoperability via bidirectional real‑time communication but does not specify compliance with particular industry standards; it acknowledges the absence of standardized data schemas and robust integration frameworks in many AECO deployments. Existing open‑source platforms such as Eclipse Ditto and BaSyx provide standard compliance for connectivity but require manual configuration, highlighting the need for automated, standard‑aligned solutions in AECO contexts."
]