// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "IoT temperature sensor deployed in walls, ceilings, and HVAC systems for real-time indoor environmental monitoring with sub-second latency in LEED Platinum academic building and university library."
    DTDFVocab:producedData IndoorEnvironmentalDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "High-precision humidity sensor integrated into distributed IoT network for indoor air quality monitoring with millisecond-level latency in research-oriented facilities."
    DTDFVocab:producedData IndoorEnvironmentalDataTransmitted
]

instance CarbonDioxideSensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor deployed in ceiling-mounted and wall-mounted positions for occupancy tracking and indoor air quality compliance monitoring in academic environments."
    DTDFVocab:producedData IndoorEnvironmentalDataTransmitted
]

instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient light sensor integrated into modular IoT architecture for dynamic lighting control and energy optimization in university library spaces."
    DTDFVocab:producedData IndoorEnvironmentalDataTransmitted
]

instance OccupancyMotionSensor : DTDFVocab:SensingComponent [
    base:desc "PIR motion sensor deployed for real-time occupancy detection and space utilization analysis in high-occupancy academic facilities."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance RFIDTagReader : DTDFVocab:SensingComponent [
    base:desc "RFID tag reader system for precise user tracking and occupancy pattern analysis in research-oriented library environments."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Structural vibration sensor for predictive maintenance of HVAC equipment in research-oriented academic buildings."
    DTDFVocab:producedData EquipmentHealthDataTransmitted
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Pressure sensor for monitoring HVAC system performance and equipment health in LEED-certified buildings."
    DTDFVocab:producedData EquipmentHealthDataTransmitted
]

instance TemperaturePressureSensor : DTDFVocab:SensingComponent [
    base:desc "Combined temperature and pressure sensor for chiller and pump monitoring in energy-efficient academic facilities."
    DTDFVocab:producedData EquipmentHealthDataTransmitted
]

// C4: Physical-to-virtual interaction
instance IndoorEnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor, HumiditySensor, CarbonDioxideSensor, LightSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyMotionSensor, RFIDTagReader
]

instance EquipmentHealthDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor, PressureSensor, TemperaturePressureSensor
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Semantically enriched BIM model containing geometric, spatial, and functional characteristics of building components (structural elements, HVAC systems, MEP infrastructure) in IFC/Revit/ArchiCAD formats."
    DTDFVocab:inputTo EclipseDittoEnabler, EclipseHonoEnabler, VirtuosoGraphDatabase
]

instance RealTimeEnvironmentalData : DTDFVocab:Data [
    base:desc "Millisecond-level latency environmental data stream including temperature, humidity, CO₂ levels, and light intensity from distributed IoT sensor networks in academic facilities."
    DTDFVocab:fromData IndoorEnvironmentalDataTransmitted
    DTDFVocab:inputTo EnergySimulationEnabler, VisualizationEnabler, OptimizationEnabler
]

instance OccupancyPatternData : DTDFVocab:Data [
    base:desc "Time-series occupancy data with sub-second resolution for space utilization analysis and energy-occupancy correlation in research-oriented buildings."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo SpaceUtilizationEnabler, ControlEnabler, PredictionEnabler
]

instance EquipmentHealthData : DTDFVocab:Data [
    base:desc "Time-series equipment health data including vibration, pressure, and temperature metrics for predictive maintenance of HVAC systems in academic buildings."
    DTDFVocab:fromData EquipmentHealthDataTransmitted
    DTDFVocab:inputTo PredictiveMaintenanceEnabler, ControlEnabler, SimulationEnabler
]

instance HistoricalTrendData : DTDFVocab:Data [
    base:desc "Aggregated daily, weekly, and seasonal environmental and occupancy data for pattern identification and energy consumption trend analysis."
    DTDFVocab:fromData IndoorEnvironmentalDataTransmitted, OccupancyDataTransmitted
    DTDFVocab:inputTo AnalyticsEnabler, ReportingEnabler
]

// C11: Enablers
instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto platform enabling real-time synchronization between physical assets and Digital Twin through bidirectional data exchange."
    DTDFVocab:enables RealTimeMonitoringService, ClosedLoopControlService, ResearchValidationService
]

instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono platform for IoT data ingestion, processing, and distribution with MQTT and RESTful APIs supporting heterogeneous sensor networks."
    DTDFVocab:enables DataIngestionService, DeviceManagementService
]

instance VirtuosoGraphDatabase : DTDFVocab:Enabler [
    base:desc "Virtuoso graph database for semantic data storage and querying of Digital Twin metadata, supporting RDF/SPARQL for ontology-based relationships."
    DTDFVocab:enables ModelIntegrationService, AnalyticsService
]

instance EnergySimulationEnabler : DTDFVocab:Enabler [
    base:desc "Energy simulation engine (EnergyPlus/TRNSYS) for physics-based modeling of HVAC systems and energy consumption patterns in academic buildings."
    DTDFVocab:enables EnergyOptimizationService, WhatIfAnalysisService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "itwin.js based 3D visualization platform for immersive Digital Twin interaction with geospatial heatmaps and AR overlays."
    DTDFVocab:enables RealTimeDashboardService, InteractiveSimulationService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Model-driven optimization framework implementing PID controllers, fuzzy logic, and machine learning for dynamic energy and thermal comfort optimization."
    DTDFVocab:enables OccupancyBasedOptimizationService, ThermalComfortService
]

instance PredictiveMaintenanceEnabler : DTDFVocab:Enabler [
    base:desc "AI/ML framework (TensorFlow/PyTorch) for time-series forecasting of equipment failures with 90%+ accuracy using LSTM networks."
    DTDFVocab:enables PredictiveMaintenanceService, RemainingUsefulLifeService
]

instance ControlEnabler : DTDFVocab:Enabler [
    base:desc "Model Predictive Control (MPC) system for automated HVAC and lighting control via OPC UA and Modbus protocols."
    DTDFVocab:enables ClosedLoopControlService, DemandResponsiveLightingService
]

instance SpaceUtilizationEnabler : DTDFVocab:Enabler [
    base:desc "Occupancy heatmap generation and space reconfiguration recommendation system for university library optimization."
    DTDFVocab:enables SpaceUtilizationAnalysisService, OccupancyPatternService
]

instance AnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Statistical and machine learning analytics engine for anomaly detection and energy-occupancy correlation analysis."
    DTDFVocab:enables AnomalyDetectionService, EnergyOccupancyCorrelationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink based simulation environment for testing control algorithms and predictive models against real-world data."
    DTDFVocab:enables AlgorithmTestingService, ScenarioSimulationService
]

instance DataIngestionService : DTDFVocab:Enabler [
    base:desc "MQTT-based data ingestion pipeline for real-time sensor data processing and validation."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveMaintenanceService
]

instance PredictionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for predictive analytics services that forecast future building performance based on current data patterns."
    DTDFVocab:enables PredictiveMaintenanceService
]

instance ReportingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for generating comprehensive reports on building performance metrics and operational insights."
    DTDFVocab:enables ReportingService
]

