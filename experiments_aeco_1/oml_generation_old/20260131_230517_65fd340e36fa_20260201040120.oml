// Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor sampling at 1-second intervals, part of the building MEP system"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor sampling at 1-second intervals across the office space"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor measuring presence (0 = unoccupied, 1 = occupied) with 1 s tick"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor sampling at 1-second intervals, output in ppm with validated ranges 400‑2000 ppm"
    DTDFVocab:producedData CO2DataTransmitted
]

// HonoService and DittoService (needed for references)
instance HonoService : DTDFVocab:Service [
    base:desc "Eclipse Hono MQTT service that handles telemetry ingestion"
]

instance DittoService : DTDFVocab:Service [
    base:desc "Eclipse Ditto service that stores twin state and events"
]

// Data Transmitted
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

// Telemetry Data Stored in Ditto/Hono
instance TemperatureTelemetryData : DTDFVocab:Data [
    base:desc "Stored temperature telemetry in Celsius range 20‑50 °C validated by policy"
    DTDFVocab:inputTo HonoBrokerEnabler, DittoTwinEnabler
    DTDFVocab:fromData TemperatureDataTransmitted
]

instance HumidityTelemetryData : DTDFVocab:Data [
    base:desc "Stored humidity telemetry in % range 0‑100 % validated by policy"
    DTDFVocab:inputTo HonoBrokerEnabler, DittoTwinEnabler
    DTDFVocab:fromData HumidityDataTransmitted
]

instance OccupancyTelemetryData : DTDFVocab:Data [
    base:desc "Stored occupancy telemetry binary 0/1 indicating presence"
    DTDFVocab:inputTo HonoBrokerEnabler, DittoTwinEnabler
    DTDFVocab:fromData OccupancyDataTransmitted
]

instance CO2TelemetryData : DTDFVocab:Data [
    base:desc "Stored CO₂ telemetry in ppm range 400‑2000 ppm validated by policy"
    DTDFVocab:inputTo HonoBrokerEnabler, DittoTwinEnabler
    DTDFVocab:fromData CO2DataTransmitted
]

// Enablers
instance HonoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT broker that ingests device telemetry with at‑least‑once QoS"
    DTDFVocab:enables HonoService
]

instance DittoTwinEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin service that maps device state to JSON twin representation and validates data via policies"
    DTDFVocab:enables DittoService, MonitoringService, ControlService
]

instance iTwinJSVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "iTwin.js library that integrates enriching BIM models with UE5 3D viewport rendering"
    DTDFVocab:enables VisualizationService
]

instance DockerKubernetesDeploymentEnabler : DTDFVocab:Enabler [
    base:desc "Docker/Kubernetes orchestrator that builds and deploys MDE-generated services to cloud / edge cluster"
    DTDFVocab:enables DeploymentService
]

instance GraphQLAPIEnabler : DTDFVocab:Enabler [
    base:desc "GraphQL API layer that provides structured queries to twin state and historical telemetry"
    DTDFVocab:enables QueryService
]

instance ModelDrivenEngineeringPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline that transforms enriched BIM into deployable twin artefacts and validates IFC metadata"
    DTDFVocab:enables ModelingService, OptimizationService, PredictionService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that drives MonitoringService"
    DTDFVocab:enables MonitoringService
]

instance ControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that drives ControlService"
    DTDFVocab:enables ControlService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that drives OptimizationService"
    DTDFVocab:enables OptimizationService
]

instance PredictionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that drives PredictionService"
    DTDFVocab:enables PredictionService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous real‑time telemetry monitoring service aggregates data from all sensors"
    DTDFVocab:provides TemperatureMonitoringInsight, HumidityMonitoringInsight, OccupancyMonitoringInsight, CO2MonitoringInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Model‑based simulation engine that evaluates HVAC and lighting schedules to recommend energy‑saving plans"
    DTDFVocab:provides HVACOptimizationInsight, LightingOptimizationInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Predictive analytics module that forecasts component failures and occupancy patterns using ARIMA/ML time‑series"
    DTDFVocab:provides FailurePredictionInsight, OccupancyPredictionInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Bidirectional command interface sending actuator setpoints via Hono/Ditto WebSocket"
    DTDFVocab:provides SetHVACSetpointAction, SetLightBrightnessAction, TurnOnLightAction, ChangeLightColorTempAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D BIM viewport with live data overlays and annotation tools for facility managers"
    DTDFVocab:provides VisualInspectionInsight
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Automated deployment engine that configures Hono and Ditto and launches twin"
    DTDFVocab:provides DeploymentInsight
]

instance QueryService : DTDFVocab:Service [
    base:desc "GraphQL API that enables querying of current twin state and historical telemetry"
    DTDFVocab:provides DataQueryInsight
]

instance ModelingService : DTDFVocab:Service [
    base:desc "Transforms enriched BIM into DT artifacts, ensures metadata consistency and validation"
    DTDFVocab:provides ModelingInsight
]

// Insights
instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Reports temperature anomalies and deviations from design setpoint"
]

instance HumidityMonitoringInsight : DTDFVocab:Insight [
    base:desc "Reports humidity deviations and triggers alerts when out of range"
]

instance OccupancyMonitoringInsight : DTDFVocab:Insight [
    base:desc "Tracks occupant presence informs HVAC and lighting scheduling"
]

instance CO2MonitoringInsight : DTDFVocab:Insight [
    base:desc "Monitors CO₂ levels to maintain indoor air quality standards"
]

instance HVACOptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommends HVAC schedule adjustments for energy savings while maintaining comfort"
]

instance LightingOptimizationInsight : DTDFVocab:Insight [
    base:desc "Provides energy‑saving lighting schedule and brightness level suggestions"
]

instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Forecasts impending HVAC component failure based on time‑series analysis"
]

instance OccupancyPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicts occupancy patterns for proactive HVAC load management"
]

instance VisualInspectionInsight : DTDFVocab:Insight [
    base:desc "Shows live overlay of device states in 3D BIM viewport"
]

instance DeploymentInsight : DTDFVocab:Insight [
    base:desc "Confirms deployment status and integration health of twin services"
]

instance DataQueryInsight : DTDFVocab:Insight [
    base:desc "Provides query results of twin state and historical telemetry via GraphQL"
]

instance ModelingInsight : DTDFVocab:Insight [
    base:desc "Confirms successful BIM‑to‑DT transformation and metadata validation"
]

// Actions
instance SetHVACSetpointAction : DTDFVocab:Action [
    base:desc "Adjusts HVAC setpoint remotely via Ditto WebSocket validated against hardware limits"
    DTDFVocab:IsAutomatic false
]

instance SetLightBrightnessAction : DTDFVocab:Action [
    base:desc "Changes light fixture brightness in 1% increments (0‑100 %) via Ditto command"
    DTDFVocab:IsAutomatic false
]

instance TurnOnLightAction : DTDFVocab:Action [
    base:desc "Toggles light fixture power transition up to 5 ms communicated via Ditto message"
    DTDFVocab:IsAutomatic false
]

instance ChangeLightColorTempAction : DTDFVocab:Action [
    base:desc "Adjusts light colour temperature (2000 K–65000 K) via Ditto command"
    DTDFVocab:IsAutomatic false
]

// Actuators (Acting Components)
instance LightFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Light fixture actuator supports power, brightness, and colour temperature control"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator controls setpoint and mode within hardware limits"
]

// Model
instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model of the commercial high‑rise office building, including device nodes and IFC metadata"
    DTDFVocab:inputTo ModelDrivenEngineeringPipelineEnabler
]

// Environment
instance HighRiseBuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, HumiditySensor, OccupancySensor, CO2Sensor, LightFixtureActuator, HVACActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Commands generated by the Digital Twin (e.g., switching a light on/off, adjusting HVAC set‑points) are serialized in JSON and transmitted over the Ditto WebSocket connection to the appropriate device. The command payload includes a command name, target device ID, and any required parameters. Validation and authentication on the command path are handled by Ditto’s security model (JWT/OAuth scopes + ACLs) and by Hono’s device‑side authentication tokens. After dispatch, the device acknowledges receipt by emitting a confirmation message on the same channel; the Twin waits for this acknowledgment before updating the digital state to avoid stale data. Conflict resolution follows a last‑write‑wins policy mediated by timestamps; command execution confirmation ensures idempotency, and the Twin can execute retrials or fallback actions if acknowledgments are not received within a configurable timeout."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Synchronization between physical building components and the Digital Twin occurs via a regular 1 second heartbeat mechanism, ensuring bidirectional state updates. The Digital Twin’s entanglement quality (ODTE) achieved a score of 0.997, indicating that any state change in the physical asset is reflected in the twin with negligible latency (practically <1 second). Control services operate at this 1‑second granularity, while higher‑frequency analytics can be layered on top if required."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized orchestration is achieved through a modular Digital Twin Framework that acts as a single hub. The framework ingests semantically enriched BIM models, performs model‑checking (5.53 s) and parsing (8.7 s), and initializes runtime artifacts in 0.3 s, totaling 14.53 s for the deployment of a building twin. The framework integrates Eclipse Hono for connection provisioning and Ditto for twin representation. Runtime configuration management allows dynamic updates without redeployment. Service‑oriented extensibility is achieved via well‑defined extension points that enable DT Engineers to plug in custom analytics or control logic, while the overall pattern follows a micro‑service style essential for AECO‑specific workflows."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Phases include: 1) Design‑time enrichment where Building Control Engineers model devices and control logic inside a BIM authoring tool (Revit) using custom families, property sets, and UUID metadata; 2) Semantic extraction where the framework uses model‑to‑model transformation to produce domain‑specific representations from the enriched IFC export (Table III F2); 3) Automated deployment where an MDE pipeline invokes proprietary tooling to generate, configure, and launch the DT artifacts with a single click (F3, R2); 4) Runtime operation where real‑time bidirectional data are exchanged through Eclipse Hono and Ditto, enabling live simulation and monitoring (F4, R3); 5) Extension and evolution where DT engineers attach modular services via standardized extension points (F6, R4); 6) Runtime configuration management that supports dynamic re‑configuration of deployed twins (F7). Governance is achieved by reproducible deployment artifacts, low‑overhead update mechanisms, and maintainability guidelines (NF3)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The fidelity of the DT is quantified through the Overall Digital Twin Entanglement (ODTE) metric, combining timeliness (0.997), reliability (1.0), and availability (1.0) based on a 12‑minute continuous test with a 1 s heartbeat. Model validity is enforced through a custom IFC model checker that verifies the presence of required metadata (Instance General UUID) before upload. Data validity is ensured by Ditto’s policy‑based validation engine, which enforces numeric ranges and units for sensor telemetry and pre‑execution safety checks for actuator commands. Fault tolerance is achieved via Hono’s at‑least‑once delivery and Ditto’s persistent event store, guaranteeing message persistence across network disruptions. These mechanisms detect and correct data inconsistencies, ensuring the DT remains an exact, up‑to‑date abstraction of the physical system."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The underlying network architecture stitches together an on‑premise edge layer (connected devices + Hono MQTT broker) and a cloud layer (Ditto event store). Communication protocols include MQTT (TLS/SSL protected) for telemetry ingress, HTTP/HTTPS for configuration and RESTful endpoints, and WebSocket (over TLS) for bidirectional command and status updates. The topology is a hierarchical broker + event hub model: local devices publish to the local Hono broker; Hono forwards to Ditto via the cloud over a secure VPN/WAN connection. Bandwidth requirements are modest for sensor streams but must sustain sub‑second latency; Ditto retains event history to support re‑consumption. Reliability is provided by Hono’s retained messages and Ditto’s persistent event topics, with optional clustering for redundancy. Security protocols encompass TLS encryption for all transport channels, mutual authentication via X.509 certificates or JWTs, and role‑based access control enforced by Ditto’s ACLs."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment of the Digital Twin framework is model‑driven and containerised, typically orchestrated on a Kubernetes cluster deployed in the public cloud (AWS/GCP/Azure) or on hybrid edge‑on‑premise infrastructures. The Hono broker and Ditto event hub run as stateless microservices with persistent storage backed by a NoSQL database (e.g., MongoDB or DynamoDB) for device telemetry and configuration. Compute and storage needs scale automatically with the number of devices or the volume of telemetry; auto‑scaling policies can spawn additional Ditto or Hono replicas. The automated deployment pipeline (Hono/Ditto Configurator) consumes enriched BIM files and generates deployment artefacts (configuration maps, Kubernetes manifests) that can be applied via CI/CD pipelines, ensuring reproducible setups. High availability is achieved through multi‑zone deployments, redundant topic partitions, and health‑check probes; the framework supports both rolling updates and blue‑green releases for zero‑downtime maintenance."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External integration relies on open IoT protocols: Eclipse Hono, a cloud‑first message broker supporting AMQP or MQTT, routes data between physical control devices and the Digital Twin; Ditto exposes a device twin registry over REST and WebSocket endpoints, enabling real‑time queries and command execution. The framework also interfaces with BIM tools (e.g., Revit) for design‑time model enrichment and with game engines (UE5) for immersive 3D rendering, establishing bidirectional flows from the physical building, through the middleware, to the visualization layer. Standardized extension points ensure compatibility with other enterprise systems, while the modular architecture supports both horizontal (peer twin) and vertical (BIM‑to‑Twin) integration patterns."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance is anchored in BIM and IFC standard formats; devices are modelled within Autodesk Revit and exported to IFC. The framework employs Eclipse Hono and Eclipse Ditto to uphold MQTT/HTTP‑based IoT interoperability, and aligns with the generic interoperability strategy defined by NF1, ensuring compatibility across heterogeneous BIM tools, IoT protocols, and visualisation systems. The use of open standards (IFC, MQTT, HTTP, JSON‑LD for Ditto) and adherence to Model‑Driven Engineering best practices provide a certification‑ready positioning for AECO environments, although explicit certification or formal compliance frameworks are not stated."
]