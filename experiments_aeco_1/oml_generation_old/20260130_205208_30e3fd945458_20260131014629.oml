// C3: Physical sensing components
instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector sensor extracted from the BIM model, providing live occupancy counts"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor embedded in the lighting control system, streaming light level data"
    DTDFVocab:producedData IlluminanceDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring indoor air temperature, contributes to HVAC control"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor monitoring indoor carbon‑dioxide concentration for air quality management"
    DTDFVocab:producedData CO2DataTransmitted
]

// C4: Physical-to-virtual interaction – Data transmitted
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance IlluminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

// C11: Data objects captured from sensors
instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy count data stream"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDittoTwinManager
]

instance IlluminanceData : DTDFVocab:Data [
    base:desc "Live illuminance (lux) measurements"
    DTDFVocab:fromData IlluminanceDataTransmitted
    DTDFVocab:inputTo EclipseDittoTwinManager
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Live indoor temperature readings"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseDittoTwinManager
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Live CO₂ concentration values"
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseDittoTwinManager
]

// C11: Enablers
instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono protocol gateway handling MQTT/AMQP streams from physical sensors"
    DTDFVocab:enables RealTimeMonitoringDashboard
]

instance EclipseDittoTwinManager : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto managing digital‑twin instances and persisting incoming sensor data"
    DTDFVocab:enables RealTimeMonitoringDashboard
    DTDFVocab:enables Interactive3DVisualization
    DTDFVocab:enables PredictiveAnalyticsService
    DTDFVocab:enables AdaptiveLightingOptimizationService
    DTDFVocab:enables BuildingPerformanceSimulationService
    DTDFVocab:enables FacilityManagerTaskPlanningService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 engine providing immersive 3‑D interactive building visualization"
    DTDFVocab:enables Interactive3DVisualization
]

instance ReinforcementLearningEngine : DTDFVocab:Enabler [
    base:desc "Reinforcement‑learning engine executing adaptive lighting optimisation policies"
    DTDFVocab:enables AdaptiveLightingOptimizationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Building performance simulation engine for what‑if analysis"
    DTDFVocab:enables BuildingPerformanceSimulationService
]

instance TaskPlanningEngine : DTDFVocab:Enabler [
    base:desc "Task‑planning engine supporting facility‑manager workflow automation"
    DTDFVocab:enables FacilityManagerTaskPlanningService
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards presenting live sensor streams"
    DTDFVocab:provides LiveSensorInsight
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "3‑D interactive visualization of the building twin in Unreal Engine 5"
    DTDFVocab:provides VisualizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics delivering forecasts and maintenance alerts"
    DTDFVocab:provides PredictiveMaintenanceAlert
]

instance AdaptiveLightingOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based adaptive lighting optimisation"
    DTDFVocab:provides LightingOptimizationRecommendation
    DTDFVocab:provides LightingActuationCommand
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance under varied operating conditions"
    DTDFVocab:provides SimulationInsight
]

instance FacilityManagerTaskPlanningService : DTDFVocab:Service [
    base:desc "Task‑planning services for facility‑manager workflows"
    DTDFVocab:provides PolicyUpdateInsight
]

// C17: Insights
instance LiveSensorInsight : DTDFVocab:Insight [
    base:desc "Insight providing an aggregated view of live sensor data for operators"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight delivering spatial context and status through 3‑D visualization"
]

instance PredictiveMaintenanceAlert : DTDFVocab:Insight [
    base:desc "Predictive maintenance alert generated from analytics on sensor trends"
]

instance LightingOptimizationRecommendation : DTDFVocab:Insight [
    base:desc "Optimization recommendation for lighting set‑points derived from RL policies"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Resulting insight from building performance simulation runs"
]

instance PolicyUpdateInsight : DTDFVocab:Insight [
    base:desc "Policy update insight derived from reinforcement‑learning outcomes"
]

// C17: Actions
instance LightingActuationCommand : DTDFVocab:Action [
    base:desc "Command to adjust lighting actuators to the recommended set‑points"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components (actuators)
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator capable of receiving dimming set‑points from the twin"
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve actuator controlling airflow based on temperature data"
]

instance MotorisedShadingActuator : DTDFVocab:ActingComponent [
    base:desc "Motorised shading actuator adjusting blinds in response to illuminance levels"
]

// C10: Models/Data
instance SemanticBIMGeometryModel : DTDFVocab:Model [
    base:desc "Semantic BIM geometry and topology extracted from IFC, describing building spaces"
    DTDFVocab:inputTo EclipseDittoTwinManager
]

instance EnrichedBIMExtensionsModel : DTDFVocab:Model [
    base:desc "BIM extensions enriched with sensor and actuator metadata"
    DTDFVocab:inputTo EclipseDittoTwinManager
]

instance RuntimeControlModel : DTDFVocab:Model [
    base:desc "Runtime control model governing device twin behaviours"
    DTDFVocab:inputTo EclipseDittoTwinManager
]

instance ReinforcementLearningPolicyModel : DTDFVocab:Model [
    base:desc "RL policies for adaptive lighting optimisation"
    DTDFVocab:inputTo ReinforcementLearningEngine
]

// C8: Environment (building twin composition)
instance LivingLabBuildingTwin : DTDFVocab:Environment [
    base:contains OccupancyDetector, IlluminanceSensor, TemperatureSensor, CO2Sensor
    base:contains LightingActuator, HVACValveActuator, MotorisedShadingActuator
    base:contains RealTimeMonitoringDashboard, Interactive3DVisualization, PredictiveAnalyticsService
    base:contains AdaptiveLightingOptimizationService, BuildingPerformanceSimulationService, FacilityManagerTaskPlanningService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., lighting set‑points, HVAC set‑points) are sent back to the physical actuators through the same Hono/Ditto middleware, enabling bidirectional, real‑time actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data exchange and command propagation occur in real‑time, with continuous streaming and sub‑second latency sufficient for live monitoring and control loops."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where BIM serves as the source of truth, a model‑driven pipeline automatically generates configuration artefacts, Hono/Ditto provide bidirectional connectivity, and Unreal Engine renders the virtual environment; extension points allow insertion of additional services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the full building lifecycle: design (BIM creation), construction (model enrichment with device metadata), operation (live sensor integration and control), and post‑occupancy adaptation (reinforcement‑learning updates)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is quantified using the Overall Digital Twin Entanglement (ODTE) metric; the framework emphasizes validation of the BIM‑derived model before deployment to ensure semantic consistency between PT and DT."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time connectivity is realised through Eclipse Hono and Eclipse Ditto, which together provide standard IoT messaging and state management for the twin’s data exchange layer."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach leverages BIM industry standards (e.g., IFC) as the semantic backbone and builds on open IoT standards supported by Eclipse Hono and Ditto for interoperability."
]