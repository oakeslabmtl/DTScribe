// C3: Physical sensing components
instance BIMEmbeddedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors are modeled directly in BIM, providing a semantic description of measurement type, location and connectivity."
    DTDFVocab:producedData SensorDataTransmitted
]

// C4: Physical-to-virtual interaction – data transmitted
instance SensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BIMEmbeddedSensor
]

// C10: Data created from transmitted stream
instance BuildingSensorData : DTDFVocab:Data [
    base:desc "Live sensor readings streamed from the building’s embedded BIM sensors."
    DTDFVocab:fromData SensorDataTransmitted
    DTDFVocab:inputTo DTFrameworkHub
]

// C2: Acting components (actuators/controllers)
instance BuildingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuators and controllers modelled in BIM, synthesized into runtime components that can be invoked by the Digital Twin."
]

// C10: Models derived from enriched BIM
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing geometric definitions and device (sensor/actuator) specifications."
    DTDFVocab:inputTo DTFrameworkHub
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model embodying the control logic defined by the Building Control Engineer."
    DTDFVocab:inputTo DTFrameworkHub
]

instance AnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model derived from semantic relationships among sensors, actuators and controllers."
    DTDFVocab:inputTo DTFrameworkHub
]

// C11: Enabler – central DT framework hub
instance DTFrameworkHub : DTDFVocab:Enabler [
    base:desc "Central DT Framework providing real‑time data exchange, synchronization of physical and virtual states, and hub for ingesting model artifacts."
    DTDFVocab:enables RealTimeMonitoringService,
                     SimulationAnalysisService,
                     OptimizationService,
                     PredictiveAnalyticsService,
                     DecisionSupportService
]

// C6: Services offered by the Digital Twin
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides continuous real‑time monitoring and visualization of current building states."
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance SimulationAnalysisService : DTDFVocab:Service [
    base:desc "Enables simulation and analysis of the building’s behavior under varying conditions."
    DTDFVocab:provides SimulationAnalysisInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimizes operational parameters to improve energy efficiency and occupant comfort."
    DTDFVocab:provides OptimizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Performs predictive analytics to forecast future performance and detect emerging faults."
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Delivers decision‑support capabilities, presenting recommendations to the Facility Manager."
    DTDFVocab:provides DecisionSupportInsight,
                     ExecuteActuationAction
]

// C17: Insights generated by services
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into current temperature, humidity, occupancy and system status."
]

instance SimulationAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulated scenarios outlining potential impacts on building performance."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal set‑points for HVAC, lighting and other controllable systems."
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Insight forecasting future energy consumption and identifying likely equipment failures."
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Insight presenting actionable recommendations for facility management decisions."
]

// C17: Action to actuate physical components
instance ExecuteActuationAction : DTDFVocab:Action [
    base:desc "Action to issue actuation commands (e.g., open/close, start/stop) through the real‑time data exchange channel."
    DTDFVocab:IsAutomatic false
]

// Additional optional linking of action to acting component (not part of mandatory flow)
instance ActuationCommand : DTDFVocab:Component [
    base:desc "Command payload sent to BuildingActuator to change physical state."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Through the same central hub, the Digital Twin issues control commands back to the building control systems, enabling Facility Managers to affect physical equipment in real time; the bidirectional exchange supports monitoring‑to‑control loops where the DT’s analytics generate actions that are enacted on the physical assets."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a full DT life‑cycle composed of (1) Device‑Modeling stage where building control engineers enrich BIM models with explicit sensor, actuator and controller entities; (2) Model‑Transformation stage that applies Model‑Driven Engineering (MDE) to extract a structured semantic representation and generate executable DT artifacts; (3) Deployment stage in which the generated artifacts are instantiated on the runtime platform; (4) Operation stage characterized by continuous real‑time data exchange between the physical building and its digital counterpart and interactive, immersive visualization for monitoring and control; and (5) Evolution stage where modular extension points allow DT engineers to plug in custom services, analytics or updated control logic. Transition between stages is automated by the MDE pipeline, and governance is expressed through the same pipeline, ensuring that each artefact is traceable to its originating BIM model."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection is realized via a modular architecture with standardized extension points and runtime configuration management, allowing heterogeneous components to interoperate; the network design emphasizes scalability, reliability, and low‑overhead updates, meeting non‑functional requirements for interoperability and maintainable communication across the DT infrastructure."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment follows a model‑driven approach where enriched BIM models are automatically transformed into operational Digital Twins; the DT Framework supports automated creation, configuration, and deployment on scalable infrastructure, with runtime configuration enabling adjustments without full redeployment and ensuring continuous availability across the building lifecycle."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution is built on the Building Information Modeling (BIM) standard, ensuring compatibility with established AECO‑specific standards. It adopts standardized extension points within its modular architecture to promote interoperability and to allow third‑party services to be integrated without breaking compliance. By grounding the entire twin lifecycle in BIM‑derived semantics, the framework aligns with industry‑wide specifications for data exchange and model representation."
]