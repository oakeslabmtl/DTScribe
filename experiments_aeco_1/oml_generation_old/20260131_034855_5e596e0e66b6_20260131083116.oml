prefix DTDFVocab: http://example.org/DTDFVocab
instance CurrentTemperatureInsight : DTDFVocab:Insight [
    base:desc "Real-time temperature monitoring data"
]

instance CurrentOccupancyInsight : DTDFVocab:Insight [
    base:desc "Real-time occupancy monitoring data"
]

instance CurrentEnergyUsageInsight : DTDFVocab:Insight [
    base:desc "Real-time energy usage monitoring data"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Results from building simulation for analysis"
]

instance EnergyConsumptionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics for optimizing energy consumption"
]

instance VisualComfortOptimizationInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics for optimizing visual comfort"
]

instance NonVisualHealthEffectsInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics for non-visual health effects"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization of building systems for decision support"
]

instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Validation of models during twinning process"
]

instance AdjustHVAC : DTDFVocab:Action [
    base:desc "Adjust HVAC system settings based on real-time data"
    DTDFVocab:IsAutomatic true
]

instance AdjustBlinds : DTDFVocab:Action [
    base:desc "Adjust window blinds to optimize visual comfort"
    DTDFVocab:IsAutomatic true
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of building operations for facility management"
    DTDFVocab:provides [CurrentTemperatureInsight, CurrentOccupancyInsight, CurrentEnergyUsageInsight]
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building operations for analysis and optimization"
    DTDFVocab:provides [SimulationResultInsight]
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for optimizing energy consumption, visual comfort, and non-visual health effects"
    DTDFVocab:provides [EnergyConsumptionOptimizationInsight, VisualComfortOptimizationInsight, NonVisualHealthEffectsInsight]
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of energy consumption based on real-time data"
    DTDFVocab:provides [AdjustHVAC]
]

instance VisualComfortOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of visual comfort in building spaces"
    DTDFVocab:provides [AdjustBlinds]
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization for facility management and decision support"
    DTDFVocab:provides [VisualizationInsight]
]

instance TwinningProcessService : DTDFVocab:Service [
    base:desc "Model-driven deployment process for automated BIM semantics extraction and runtime interface generation"
    DTDFVocab:provides [ModelValidationInsight]
]

instance BIMModelGenerationService : DTDFVocab:Service [
    base:desc "Service for generating BIM models"
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for IoT data exchange"
    DTDFVocab:enables [RealTimeMonitoringService, SimulationService, PredictiveAnalyticsService]
]

instance Ditto : DTDFVocab:Enabler [
    base:desc "Ditto for IoT data exchange"
    DTDFVocab:enables [RealTimeMonitoringService, SimulationService, PredictiveAnalyticsService]
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for 3D visualization"
    DTDFVocab:enables [InteractiveVisualizationService]
]

instance BIMTools : DTDFVocab:Enabler [
    base:desc "BIM tools for modeling"
    DTDFVocab:enables [BIMModelGenerationService]
]

instance ModelDrivenEngineering : DTDFVocab:Enabler [
    base:desc "Model-driven engineering principles for automated transformation pipelines"
    DTDFVocab:enables [TwinningProcessService]
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors that collect temperature data from the physical building environment"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors that collect occupancy data from the physical building environment"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnergyUsageSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors that collect energy usage data from the physical building environment"
    DTDFVocab:producedData EnergyUsageDataTransmitted
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyUsageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyUsageSensor
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Operational temperature data collected from building sensors"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo [EclipseHono, Ditto]
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Operational occupancy data collected from building sensors"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo [EclipseHono, Ditto]
]

instance EnergyUsageData : DTDFVocab:Data [
    base:desc "Operational energy usage data collected from building sensors"
    DTDFVocab:fromData EnergyUsageDataTransmitted
    DTDFVocab:inputTo [EclipseHono, Ditto]
]

instance BIMModel : DTDFVocab:Model [
    base:desc "BIM model for building infrastructure"
    DTDFVocab:inputTo [BIMTools]
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator in Building Control System for heating, ventilation, and air conditioning"
]

instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Controller for adjusting lighting levels in building spaces"
]

instance WindowBlindController : DTDFVocab:ActingComponent [
    base:desc "Controller for adjusting window blinds to optimize visual comfort"
]

instance ModularArchitecture : DTDFVocab:Component [
    base:desc "Modular architecture with standardized extension points supporting service-oriented DT development"
]

instance BuildingDigitalTwin : DTDFVocab:Environment [
    base:desc "A building infrastructure within the AECO domain, specifically demonstrated through a Living Lab case study, serving as a unified virtual representation for real-time monitoring, simulation, and life cycle optimization of physical assets."
    base:contains [TemperatureSensor, OccupancySensor, EnergyUsageSensor, HVACActuator, LightingController, WindowBlindController, ModularArchitecture]
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals generated by the DT and sent to physical actuators and controllers through Eclipse Hono and Ditto to adjust building operations in response to simulations and analytics."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization between physical and virtual components, with continuous data exchange and immediate response to environmental changes."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture orchestrated by a central DT framework that integrates Eclipse Hono and Ditto for data exchange, Unreal Engine for visualization, and BIM as the semantic backbone, with standardized extension points for service-oriented components."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the entire building life cycle from initial design through construction, operation, and refurbishment phases, with BIM serving as a semantic backbone for all stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Evaluated using the Overall Digital Twin Entanglement (ODTE) metric to measure interoperability and architectural soundness, ensuring accurate reflection of physical assets."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono and Ditto for real-time data exchange, leveraging IoT communication protocols for bidirectional communication between physical assets and the digital twin."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized extension points enabling integration with external systems and services, supporting scalable, service-oriented DT development across heterogeneous AECO environments."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to BIM standards and use of standardized extension points for interoperability, addressing fragmented data sources and lack of standardized integration mechanisms in AECO."
]