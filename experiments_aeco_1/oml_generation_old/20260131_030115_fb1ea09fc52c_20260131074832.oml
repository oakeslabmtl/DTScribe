instance PostOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy data collection devices for environmental monitoring in LEED Platinum academic building"
    DTDFVocab:producedData BuildingSensorDataTransmitted
]

instance BuildingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PostOccupancySensor
]

instance SensorData : DTDFVocab:Data [
    base:desc "Real-time sensor data collected from building systems for monitoring"
    DTDFVocab:fromData BuildingSensorDataTransmitted
    DTDFVocab:inputTo RealTimeMonitoringService, PredictiveAnalyticsService
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for controlling lighting systems within Building Control System (BCS)"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for controlling HVAC systems within Building Control System (BCS)"
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "IoT data ingestion platform for handling sensor data from physical building systems"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Digital twin management platform for device management and data synchronization"
    DTDFVocab:enables RealTimeMonitoringService, InteractiveVisualizationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "3D visualization engine for interactive building simulation and display"
    DTDFVocab:enables InteractiveVisualizationService
]

instance BIMTools : DTDFVocab:Enabler [
    base:desc "Building Information Modeling tools for creating and enriching semantic models"
    DTDFVocab:enables SimulationService, EnergyOptimizationService
]

instance ModelDrivenEngineering : DTDFVocab:Enabler [
    base:desc "Model-driven engineering approach for automated generation of runtime interfaces and model-driven deployment process including requirements elicitation, BIM enrichment, semantics extraction, and ODTE validation"
    DTDFVocab:enables SimulationService, EnergyOptimizationService, PredictiveAnalyticsService, InteractiveVisualizationService
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of building environmental conditions and system performance"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building operations for scenario testing and optimization"
    DTDFVocab:provides SimulationInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of energy consumption based on real-time data and predictive models"
    DTDFVocab:provides EnergyOptimizationInsight
]

instance VisualComfortOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of visual comfort through lighting and shading control"
    DTDFVocab:provides VisualComfortInsight
]

instance NonVisualHealthEffectsOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of non-visual health effects such as circadian rhythm support"
    DTDFVocab:provides HealthEffectsInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for maintenance and operational decisions"
    DTDFVocab:provides PredictiveInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization of building systems and data using Unreal Engine"
    DTDFVocab:provides VisualizationInsight
]

instance ReinforcementLearningAdaptiveControlService : DTDFVocab:Service [
    base:desc "Custom reinforcement learning-based adaptive control service for dynamic optimization"
    DTDFVocab:provides AdaptiveControlInsight
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time insight for infrastructure management decisions based on sensor data"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation insight for operational scenario analysis"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight for optimizing energy consumption in building operations"
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Insight for improving visual comfort through lighting adjustments"
]

instance HealthEffectsInsight : DTDFVocab:Insight [
    base:desc "Insight for balancing non-visual health effects such as circadian rhythm"
]

instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Predictive insight for infrastructure maintenance and operational decisions"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization insight for interactive building data display"
]

instance AdaptiveControlInsight : DTDFVocab:Insight [
    base:desc "Adaptive control insight for reinforcement learning-based system adjustments"
]

instance BIMModel : DTDFVocab:Model [
    base:desc "BIM model serving as semantic backbone with geometric, spatial, and functional characteristics"
    DTDFVocab:inputTo BIMTools, ModelDrivenEngineering
]

instance VisualizationModel : DTDFVocab:Model [
    base:desc "3D visualization model for Unreal Engine to display building data"
    DTDFVocab:inputTo UnrealEngine5
]

instance LEEDPlatinumBuilding : DTDFVocab:Environment [
    base:desc "LEED Platinum academic building in Living Lab context for real-time monitoring, simulation, and optimization of building operations"
    base:contains PostOccupancySensor, LightingActuator, HVACActuator, BIMModel, SensorData, VisualizationModel, EclipseHono, EclipseDitto, UnrealEngine5, BIMTools, ModelDrivenEngineering, RealTimeMonitoringService, SimulationService, EnergyOptimizationService, VisualComfortOptimizationService, NonVisualHealthEffectsOptimizationService, PredictiveAnalyticsService, InteractiveVisualizationService, ReinforcementLearningAdaptiveControlService, RealTimeMonitoringInsight, SimulationInsight, EnergyOptimizationInsight, VisualComfortInsight, HealthEffectsInsight, PredictiveInsight, VisualizationInsight, AdaptiveControlInsight
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "transmission of control signals (e.g., for lighting, HVAC) from the DT to physical Building Control Systems (BCS) via Eclipse Hono and Ditto for real-time adjustment"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "centralized framework where BIM models are transformed into runtime artifacts using MDE, with Eclipse Hono and Ditto for data exchange, Unreal Engine for visualization, and standardized extension points for modular services, orchestrated through coordinated roles for Building Control Engineers, Facility Managers, and DT Engineers"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "operational phase (as operated)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "validated using the Overall Digital Twin Entanglement (ODTE) metric to assess the reflection of physical counterpart, ensuring interoperability and architectural soundness"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real-time data exchange via Eclipse Hono and Ditto middleware for bidirectional communication, though specific protocols (e.g., MQTT) are not explicitly detailed in the provided documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Building Information Modeling (BIM) is used as a foundational standard; specific standards like IFC or MQTT are not explicitly referenced in the provided documents."
]