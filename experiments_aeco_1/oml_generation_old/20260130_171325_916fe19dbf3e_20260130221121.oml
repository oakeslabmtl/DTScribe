// C3: Physical sensing components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental light sensor modelled in BIM and connected via Eclipse Hono to provide telemetry to the twin."
    DTDFVocab:producedData LightDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental temperature sensor modelled in BIM and connected via Eclipse Hono to provide telemetry to the twin."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance MotionSensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy motion sensor modelled in BIM and connected via Eclipse Hono to provide telemetry to the twin."
    DTDFVocab:producedData MotionDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance MotionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionSensor
]

// C10: Data artifacts
instance LightData : DTDFVocab:Data [
    base:desc "Live light level measurements streamed via Eclipse Hono."
    DTDFVocab:fromData LightDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature measurements streamed via Eclipse Hono."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance MotionData : DTDFVocab:Data [
    base:desc "Live occupancy/motion events streamed via Eclipse Hono."
    DTDFVocab:fromData MotionDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance TwinRuntimeData : DTDFVocab:Data [
    base:desc "Runtime twin artifacts stored in Eclipse Ditto holding live property values and event streams."
    DTDFVocab:fromData LightDataTransmitted, TemperatureDataTransmitted, MotionDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C10: Models/Data
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "BIM model enriched with device metadata such as sensor/actuator IDs and tenant information."
    DTDFVocab:inputTo BIMEnabler, MDLEnabler
]

// C11: Enablers
instance BIMEnabler : DTDFVocab:Enabler [
    base:desc "Building Information Modeling supplies static semantics and the canonical structural model."
]

instance MDLEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering automates transformation of the enriched BIM into twin artifacts."
]

instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides MQTT‑based data ingestion for sensor telemetry."
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital‑twin state, storing live property values and allowing command execution."
    DTDFVocab:enables AutomatedOptimizationService, PredictiveAnalyticsService, BuildingPerformanceSimulationService, InteractiveVisualizationService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders 3‑D immersive visualizations of the building twin."
    DTDFVocab:enables InteractiveVisualizationService
]

instance ODTEMetricEnabler : DTDFVocab:Enabler [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric validates fidelity of the twin."
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring dashboards for energy consumption and occupant comfort."
    DTDFVocab:provides EnergyConsumptionInsight, ComfortLevelInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Offers 3‑D interactive visualization of the building in Unreal Engine 5."
    DTDFVocab:provides VisualizationInsight
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulates building performance under various operational scenarios."
    DTDFVocab:provides SimulationResultInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Runs predictive analytics to forecast future energy usage and comfort levels."
    DTDFVocab:provides FutureEnergyPredictionInsight
]

instance AutomatedOptimizationService : DTDFVocab:Service [
    base:desc "Automatically optimizes control strategies and adjusts set‑points."
    DTDFVocab:provides AdjustSetpointAction
]

// C17: Insights
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into building energy consumption."
]

instance ComfortLevelInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into occupant comfort levels."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Results of performance simulations, e.g., temperature distribution and HVAC loads."
]

instance FutureEnergyPredictionInsight : DTDFVocab:Insight [
    base:desc "Forecasted energy consumption based on predictive models."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "3‑D immersive visualization of the current building state."
]

// C17: Actions
instance AdjustSetpointAction : DTDFVocab:Action [
    base:desc "Automated adjustment of HVAC and lighting set‑points to optimize performance."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control actuator modelled in BIM, exposed via middleware for command execution."
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve actuator modelled in BIM, reachable through middleware for control actions."
]

instance BuildingControlActuator : DTDFVocab:ActingComponent [
    base:desc "General building control system actuator modelled in BIM for command execution."
]

// Environment composition
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains LightSensor, TemperatureSensor, MotionSensor, LightingControlActuator, HVACValveActuator, BuildingControlActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command messages generated by the twin (e.g., set‑point changes) sent through Eclipse Ditto to the middleware, which forwards them to actuators via Eclipse Hono, enabling closed‑loop control."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real‑time synchronization; sensor data is ingested and twin state updated continuously (sub‑second latency typical of MQTT‑based Hono streams)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where the enriched BIM model feeds a Hono/Ditto configurator, which discovers “twinnable” devices, establishes bidirectional connectivity, and exposes the twin to visualization and custom services via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the design stage (BIM model creation), deployment stage (automatic generation of runtime artefacts) and operation stage (continuous runtime monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Entanglement quality measured with the Overall Digital Twin Entanglement (ODTE) metric, indicating the degree of synchronization and semantic alignment between physical building and its twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time data transport using Eclipse Hono (typically MQTT) and twin management via Eclipse Ditto (HTTP/REST or WebSocket APIs)."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Relies on BIM standards for building data, adopts standardized extension points in the framework, and uses the ODTE metric as a common evaluation standard."
]