// C3: Physical sensing components
instance BuildingTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor defined within the BIM model by the Building Control Engineer, providing real‑time temperature measurements for the building."
    DTDFVocab:producedData BuildingTempDataStream
]

// C4: Physical-to-virtual interaction – Data transmitted from sensor
instance BuildingTempDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingTemperatureSensor
]

// C5: Data derived from transmitted stream
instance BuildingTemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature data synchronized from the physical sensor to the digital twin via the central hub."
    DTDFVocab:fromData BuildingTempDataStream
    DTDFVocab:inputTo CentralHubMiddleware
]

// C10: Models/Data – Enriched BIM model with device definitions
instance EnrichedBIMDeviceModel : DTDFVocab:Model [
    base:desc "BIM model enriched with device definitions for sensors and actuators, transformed by MDE into deployable DT artifacts."
    DTDFVocab:inputTo CentralHubMiddleware
]

// C11: Enablers – Central hub / standardized extension point
instance CentralHubMiddleware : DTDFVocab:Enabler [
    base:desc "Standardized extension point that merges real‑time sensor data with enriched BIM information and provides bidirectional continuous synchronization."
    DTDFVocab:enables RealTimeSyncService, RemoteActuationService
]

// C6: Services – Real‑time synchronization service
instance RealTimeSyncService : DTDFVocab:Service [
    base:desc "Service that continuously synchronizes physical sensor readings with their digital counterparts."
    DTDFVocab:provides BuildingTemperatureInsight
]

// C6: Services – Remote actuation service
instance RemoteActuationService : DTDFVocab:Service [
    base:desc "Service that exposes actuator control endpoints allowing remote invocation of BIM‑defined control logic."
    DTDFVocab:provides AdjustHVACAction
]

// C17: Insight – temperature state insight
instance BuildingTemperatureInsight : DTDFVocab:Insight [
    base:desc "Insight into the current building temperature state derived from synchronized sensor data."
]

// C17: Action – remote HVAC control
instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Remote invocation of HVAC actuator control logic defined in the BIM model."
    DTDFVocab:IsAutomatic false
]

// C2: Acting components – BIM‑modeled HVAC actuator
instance BuildingHVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator modeled as a BIM component by the Building Control Engineer, enabling remote control of HVAC systems via DT artifacts."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are issued from the deployed Digital Twin to the physical building via the same central hub. Facility managers use the DT interface for real‑time monitoring and to send control actions that are propagated to field devices. The documents state that the DT framework enables bidirectional data exchange and command propagation, yet they do not detail command formats, validation, authentication, feedback loops, or execution confirmations."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides continuous real-time data exchange, keeping the physical building and its digital counterpart synchronised at runtime; updates are performed continuously with no explicit fixed interval, implying a latency‑sensitive, fine‑grained temporal granularity suitable for real‑time monitoring and control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a modular, hub‑centric architecture: a central DT Framework acts as a hub enabling bidirectional data exchange between components, while standardized extension points allow DT Engineers to plug in custom services and analytics. Runtime configuration management permits on‑the‑fly adjustments without redeployment. Roles (Building Control Engineers, Facility Managers, DT Engineers) interact with the hub, establishing coordinated orchestration of services across the building lifecycle."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports the full DT life‑cycle, starting with device modeling inside the BIM environment (defining sensors, actuators, and controllers), followed by Model‑Driven Engineering (MDE) extraction of structured representations, automatic generation of deployable DT artifacts, deployment to the runtime environment, continuous real‑time data exchange for synchronization, and runtime operation with interactive visualization. Transition between stages is managed automatically by the MDE transformation chain; governance is implied through the role‑based responsibilities (Building Control Engineer, Facility Manager, DT Engineer) but no explicit governance model is described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin framework is described as a modular architecture with standardized extension points that supports interoperability across heterogeneous systems and ensures scalability from individual components to whole infrastructure. It relies on a central hub that mediates communication, but the specific network protocols, topology, bandwidth, latency, redundancy or security mechanisms are not enumerated in the provided material."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT solution is deployed as a central framework that can be configured at runtime without full redeployment, suggesting support for cloud, edge or on‑premise hosting environments. The modular design and runtime configuration management imply that computational and storage resources can be scaled as needed, although the documents do not give explicit details on hosting platforms, resource sizing, deployment models, or availability guarantees."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration is achieved through interoperability requirements that target heterogeneous systems; the framework exposes standardized extension points and supports bidirectional data exchange, allowing external enterprise systems or other Digital Twins to connect using compatible protocols, though no specific protocol is identified in the document."
]