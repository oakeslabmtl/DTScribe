// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modelled in BIM, detects presence of occupants in rooms for post‑occupancy analysis"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination (lighting) sensor modelled in BIM, measures light levels for TwinLight use case"
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modelled in BIM, measures ambient temperature for environmental monitoring"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor modelled in BIM, measures relative humidity for environmental monitoring"
    DTDFVocab:producedData HumidityDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

// C10: Data artifacts
instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy measurement stream from physical occupancy sensors"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo AnalyticsEnabler, OptimizationEnabler, HonoDittoConnector
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Illumination measurement stream from lighting sensors"
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo AnalyticsEnabler, OptimizationEnabler, HonoDittoConnector
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature measurement stream from environmental sensors"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo AnalyticsEnabler, OptimizationEnabler, HonoDittoConnector
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity measurement stream from environmental sensors"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo AnalyticsEnabler, OptimizationEnabler, HonoDittoConnector
]

// C10: Models
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Static BIM geometry and semantic data representing building infrastructure"
    DTDFVocab:inputTo UnrealEngine5VisualizationEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model for building control system (lighting, HVAC)"
    DTDFVocab:inputTo SimulationEnabler
]

instance RLPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning policy derived from post‑occupancy sensor data (BOREALIS project)"
    DTDFVocab:inputTo OptimizationEnabler
]

// C11: Enablers
instance UnrealEngine5VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders BIM geometry for real‑time visualization"
    DTDFVocab:enables RealTimeVisualizationService
]

instance AnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono and Ditto pipeline aggregates sensor streams for predictive analytics"
    DTDFVocab:enables PredictiveAnalyticsService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Energy‑optimization engine consumes sensor data and RL policies to generate set‑point recommendations"
    DTDFVocab:enables EnergyOptimizationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine executes control strategy models for what‑if analysis"
    DTDFVocab:enables ControlStrategySimulationService
]

instance HonoDittoConnector : DTDFVocab:Enabler [
    base:desc "Eclipse Hono/Ditto bidirectional communication layer streams device data to the twin"
    DTDFVocab:enables InteractiveMonitoringService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time 3D visualization of building state via Unreal Engine 5"
    DTDFVocab:provides RealTimeStateDashboardInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics computes future performance metrics from sensor data"
    DTDFVocab:provides PredictivePerformanceAnalyticsInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy‑optimization service generates recommendations to reduce consumption"
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance ControlStrategySimulationService : DTDFVocab:Service [
    base:desc "Simulation of control strategies for lighting and HVAC before deployment"
    DTDFVocab:provides PredictivePerformanceAnalyticsInsight
]

instance InteractiveMonitoringService : DTDFVocab:Service [
    base:desc "Interactive monitoring dashboards for facility managers"
    DTDFVocab:provides RealTimeStateDashboardInsight
]

// C17: Insights
instance RealTimeStateDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time state dashboards showing occupancy, illumination, temperature and humidity"
]

instance PredictivePerformanceAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive performance analytics forecasting energy use and comfort levels"
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendations for set‑point adjustments to improve efficiency"
]

// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modelled in BIM, receives commands from twin to adjust illumination"
]

instance HVACController : DTDFVocab:ActingComponent [
    base:desc "HVAC controller modelled in BIM, receives temperature set‑point commands from twin"
]

// Environment aggregation
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, IlluminationSensor, TemperatureSensor, HumiditySensor, LightingActuator, HVACController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points, HVAC adjustments) are sent back to the physical actuators through the same Hono/Ditto bidirectional channel."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where an enriched BIM model feeds a configurator that provisions devices in Hono/Ditto, a runtime twin service layer, and a UE5 visualization front‑end; extension points allow integration of custom services and analytics."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin spans design (BIM authoring), construction (deployment of runtime interfaces), and operation (continuous data exchange and optimization) phases of the building life‑cycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to quantify how well the twin reflects its physical counterpart; model validation is performed before deployment to ensure semantic correctness."
]