// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modelled in BIM that detects presence of people in building spaces"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor modelled in BIM that measures light levels in rooms"
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modelled in BIM that measures ambient temperature"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor modelled in BIM that measures relative humidity"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance PostOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy sensor used by the BOREALIS project for fine‑grained usage analytics"
    DTDFVocab:producedData PostOccupancyDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance PostOccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PostOccupancySensor
]

// C10: Data (runtime sensor streams)
instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy measurement stream"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Real‑time illumination level stream"
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature measurement stream"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Real‑time humidity measurement stream"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance PostOccupancyData : DTDFVocab:Data [
    base:desc "Post‑occupancy analytics data stream"
    DTDFVocab:fromData PostOccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

// C10: Models (static and runtime)
instance StaticBIMModel : DTDFVocab:Model [
    base:desc "Static BIM model enriched with sensor and actuator metadata"
    DTDFVocab:inputTo ModelDrivenPipeline
]

instance RuntimeDittoModel : DTDFVocab:Model [
    base:desc "Runtime model stored in Eclipse Ditto that captures live sensor streams and control policies"
    DTDFVocab:inputTo EclipseDitto
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Building performance simulation model generated by the model‑driven pipeline"
    DTDFVocab:inputTo ModelDrivenPipeline
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides MQTT/AMQP connectivity for continuous sensor streaming"
    DTDFVocab:enables DataIngestionService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital twin runtime state and persists live data"
    DTDFVocab:enables MonitoringDashboard,
                         PredictiveAnalytics,
                         EnergyOptimizationAlgorithm,
                         BuildingPerformanceSimulation
]

instance ModelDrivenPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline auto‑generates deployment descriptors and simulation artifacts"
    DTDFVocab:enables EnergyOptimizationAlgorithm,
                         BuildingPerformanceSimulation
]

instance UnrealEngine5Viz : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders immersive 3‑D visualizations of the twin"
    DTDFVocab:enables UnrealVisualization
]

// C6: Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service that ingests streamed sensor data from Hono into Ditto"
    DTDFVocab:provides DataIngestionInsight
]

instance MonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard displaying live building metrics"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance PredictiveAnalytics : DTDFVocab:Service [
    base:desc "Predictive analytics service generating forecasts and alerts"
    DTDFVocab:provides PredictiveAlert
]

instance EnergyOptimizationAlgorithm : DTDFVocab:Service [
    base:desc "Energy‑optimization algorithm that computes set‑point recommendations"
    DTDFVocab:provides EnergySavingRecommendation,
                         SetpointAdjustmentAction
]

instance BuildingPerformanceSimulation : DTDFVocab:Service [
    base:desc "Simulation service evaluating building performance under varied scenarios"
    DTDFVocab:provides SimulationResultInsight
]

instance UnrealVisualization : DTDFVocab:Service [
    base:desc "Interactive 3‑D visualization service powered by Unreal Engine 5"
    DTDFVocab:provides VisualizationInsight
]

// C17: Insights
instance DataIngestionInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data has been successfully ingested into the twin"
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Live KPI view of occupancy, illumination, temperature and humidity"
]

instance PredictiveAlert : DTDFVocab:Insight [
    base:desc "Forecasted anomaly or condition that may require preventive action"
]

instance EnergySavingRecommendation : DTDFVocab:Insight [
    base:desc "Optimization recommendation suggesting energy‑saving set‑points for HVAC and lighting"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Result of building performance simulation, including predicted energy consumption"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "3‑D visual context of the building state for stakeholder exploration"
]

// C17: Actions
instance SetpointAdjustmentAction : DTDFVocab:Action [
    base:desc "Proposed adjustment of HVAC or lighting set‑points based on optimization output"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator that adjusts lighting dimmer levels in building zones"
]

instance HVACValveController : DTDFVocab:ActingComponent [
    base:desc "Controller that modulates HVAC valve positions to regulate airflow"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command flow from the DT to the building control system through the Ditto middleware, issuing control set‑points (e.g., lighting levels, HVAC set‑points) that are executed by the physical actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near‑real‑time synchronization; sensor updates and control commands are exchanged continuously with latencies in the order of seconds, enabling live monitoring and immediate actuation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture where the DT framework acts as a hub linking the enriched BIM model, Hono/Ditto middleware, visualization client and custom analytics services into a coherent twin ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Supports the design stage (static BIM geometry), commissioning stage (enriched BIM with device metadata), operational stage (runtime data exchange and control) and can be extended to renovation or retro‑fit phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation before deployment and quantitative assessment of twin‑physical alignment using the Overall Digital Twin Entanglement (ODTE) metric to ensure semantic and state fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "IoT connectivity handled by Eclipse Hono using standard protocols (MQTT/AMQP over TLS) feeding data into Eclipse Ditto, which exposes a REST/WS API for the DT services and visualisation layer."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT components (Ditto services, Hono broker, transformation pipeline) are deployed as containerised micro‑services on a cloud or on‑premise platform; the Unreal Engine client runs on workstation hardware for interactive use."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Leverages BIM standards (e.g., IFC) for geometric and semantic data and uses open IoT standards (MQTT/AMQP, REST) through Eclipse Hono and Ditto to ensure interoperable integration."
]