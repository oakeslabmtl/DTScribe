// Environment
instance HighRiseOfficeBuildingEnvironment : DTDFVocab:Environment [
    base:contains HighRiseOfficeBuildingComponent, HVACSystemComponent, LightingSystemComponent, ElectricalDistributionComponent, OccupancySensingUnit
]

// Components
instance HighRiseOfficeBuildingComponent : DTDFVocab:Component [
    base:desc "High‑rise commercial office building enriched with IFC annotations."
]

instance HVACSystemComponent : DTDFVocab:Component [
    base:desc "HVAC subsystem comprising temperature control and air‑distribution units."
]

instance LightingSystemComponent : DTDFVocab:Component [
    base:desc "Lighting subsystem with light fixtures and dimmable controls."
]

instance ElectricalDistributionComponent : DTDFVocab:Component [
    base:desc "Electrical distribution network supplying power to all building loads."
]

instance OccupancySensingUnit : DTDFVocab:Component [
    base:desc "Occupancy sensing subsystem integrated with motion sensors and occupancy logic."
]

// Sensors
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor compliant with IFC twinnable assets, identified by UUID, publishes occupancy telemetry via MQTT."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor located in the HVAC system, exposing analog temperature readings."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Light‑level sensor attached to lighting fixtures, reporting illuminance."
    DTDFVocab:producedData LightLevelDataTransmitted
]

instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor in the electrical distribution system, measuring load currents."
    DTDFVocab:producedData CurrentDataTransmitted
]

// Data Transmitted
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
]

// Data
instance OccupancyTelemetry : DTDFVocab:Data [
    base:desc "Raw occupancy telemetry payload received via MQTT and forwarded to Ditto."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo HonoDittoEnabler
]

instance TemperatureTelemetry : DTDFVocab:Data [
    base:desc "Raw temperature telemetry payload from HVAC sensor."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo HonoDittoEnabler
]

instance LightLevelTelemetry : DTDFVocab:Data [
    base:desc "Raw light‑level telemetry payload from lighting sensor."
    DTDFVocab:fromData LightLevelDataTransmitted
    DTDFVocab:inputTo HonoDittoEnabler
]

instance CurrentTelemetry : DTDFVocab:Data [
    base:desc "Raw current telemetry payload from electrical distribution sensor."
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo HonoDittoEnabler
]

// Enabler
instance HonoDittoEnabler : DTDFVocab:Enabler [
    base:desc "MQTT (Hono) gateway forwarding telemetry to Eclipse Ditto and managing twin state."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, OptimizationService, ControlService, VisualizationService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of asset states via MQTT streams."
    DTDFVocab:provides AssetStateInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics forecasting HVAC loads and fault probabilities from historical telemetry."
    DTDFVocab:provides HVACLoadForecastInsight, FaultPreventionAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service generating energy‑saving control schedules validated by the simulation engine."
    DTDFVocab:provides EnergySavingScheduleInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Control service issuing actuator commands to building devices."
    DTDFVocab:provides ActuatorCommandAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive web‑based 3D visualization using itwin.js dashboards."
    DTDFVocab:provides ThreeDVisualizationInsight
]

// Insights
instance AssetStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current asset states derived from real‑time telemetry."
]

instance HVACLoadForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of HVAC loads based on predictive analytics."
]

instance EnergySavingScheduleInsight : DTDFVocab:Insight [
    base:desc "Energy‑saving control schedule derived from optimization algorithms."
]

instance ThreeDVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing immersive 3D view via itwin.js dashboard."
]

// Actions
instance FaultPreventionAction : DTDFVocab:Action [
    base:desc "Automatic action to pre‑empt faults using predictive alerts."
    DTDFVocab:IsAutomatic true
]

instance ActuatorCommandAction : DTDFVocab:Action [
    base:desc "Automatic action issuing actuator commands via Ditto."
    DTDFVocab:IsAutomatic true
]

// Acting Components
instance LightFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Light fixture actuator identified by UUID, communicates via MQTT through Eclipse Hono."
]

instance HVACSetpointActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC set‑point actuator controlling temperature via MQTT messages."
]

instance ElectricalSwitchActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical switch actuator controlling power distribution, operating via MQTT commands."
]

// Models
instance BuildingGeometryModel : DTDFVocab:Model [
    base:desc "Geometric representation exported from IFC, including spatial relationships, fed into UE5 scene."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance LightFeatureRenderModel : DTDFVocab:Model [
    base:desc "Photometric rendering model derived from Revit light families parsed by LightFeatureParser."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance SimulationEngineModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model for HVAC load forecasting and fault probability analysis."
    DTDFVocab:inputTo SimulationEngineEnabler
]

// Simulation Engine Enabler
instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Engine running physics‑based simulations with enriched BIM geometry."
    DTDFVocab:enables OptimizationService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Command flow from the digital twin to the physical building is orchestrated via the Ditto instance. Facility Managers or automated control logic issue control commands (e.g., switch state changes, actuator positions) through the UE5 front‑end, which are transmitted to Ditto over its WebSocket interface. Ditto then routes the command to the corresponding physical device through Eclipse Hono, following the same messaging topology used for telemetry. Each command is accompanied by a synchronous acknowledgement mechanism: UE5 only updates the rendered twin state after receiving a positive confirmation from the device (or from Ditto acknowledging receipt). Validation and conflict resolution are achieved implicitly by the deduplication and ordering guarantees of Hono’s messaging layer, while authentication or access control is implied by Ditto’s secure Edge‑to‑Edge communication framework, though explicit mechanisms are not described in the documents. "
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin receives real‑time state updates from the physical building through the Eclipse Hono data‑bridge and the Eclipse Ditto twin service at a fixed 1 s heartbeat. The measured ODTE timeliness score of 0.997 corresponds to a maximum propagation delay of ~ 1 s, ensuring sub‑second latency between a physical state change and its twin reflection. No explicit tighter deadline is required; the current configuration yields continuous synchronization with a temporal granularity of one second. Service‑specific timers (e.g., sensor polling, control command response) are similarly driven by 1‑second intervals, but may be adapted when higher resolution is needed."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The framework implements a cloud‑centric, modular service‑oriented architecture where a central ‘DT Hub’ (BIM‑based) orchestrates the lifecycle of individual building twins. Device models are enriched in the BIM environment and then transformed – via MDE‑driven model‑to‑model and model‑to‑text pipelines – into runtime artifacts that are automatically deployed onto an Eclipse Ditto twin instance per building. The Hub exposes standardized extension points for DT Engineers to plug analytics, control planners, or visualization services, and supports runtime configuration changes without full redeployment. Bidirectional communication with physical devices is mediated by Eclipse Hono, while the Ditto twin maintains the entity state graph. Resource management is handled by the underlying container platform (e.g., Kubernetes), with each twin’s services replicated and load‑balanced to scale across multiple buildings."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle is a model‑driven, continuous loop comprising: 1) Design and device modelling – Building Control Engineers create device families in Autodesk Revit, assigning Instance General UUIDs and IFC‑type classes (e.g., IFCLIGHTFIXTURETYPE). 2) Enrichment and IFC export – the enriched BIM model is exported to the IFC open‑standard format and uploaded to the platform. 3) Semantic extraction – an MDE‑based pipeline parses the IFC, extracts domain‑specific representations (e.g., a CyOnto device catalog) and validates mandatory metadata through an IFC model checker. 4) Transformation & artifact generation – model‑to‑text transformations produce deployable runtime artefacts (REST adapters, Ditto entity models, configuration manifests). 5) One‑click deployment – the framework’s orchestration engine automatically provisions, configures, and launches the DT in the runtime environment with zero manual setup. 6) Operational runtime – real‑time, bidirectional data flow is enabled via Eclipse Hono (MQTT broker) and Eclipse Ditto (digital‑twin store), feeding sensor streams directly into the twin. 7) Runtime re‑configuration – dynamic interface updates and parameter tuning are handled by the platform’s runtime configuration manager, allowing changes without full redeployment. 8) Decommissioning – lifecycle governance follows the Design Science Research artifacts and documentation, ensuring traceability of decisions and artefact lineage. Transition management is automated at each stage, preserving reproducibility and adhering to non‑functional requirements of interoperability, scalability, and maintainability."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by a dedicated model‑checking step that validates the presence of required metadata (e.g., Instance General UUIDs, appropriate IFC types) before processing. Semantic extraction produces a structured device graph that is automatically instantiated in Ditto, guaranteeing an exact mirror of the BIM structure. Validation and verification are performed at multiple layers: (1) static checks in the IFC via a rule engine, (2) policy‑based validation in Ditto that enforces unit and range constraints on sensor values and actuator commands, and (3) runtime fault tolerance using Eclipse Hono’s at‑least‑once delivery and Ditto’s persistent event storage. Uncertainty is quantified through the ODTE metric, with timeliness measured at ~1 s heartbeats, achieving a score of 0.997, and reliability and availability at 1.0 each. Error detection occurs when a missed or out‑of‑range message violates Ditto policies, triggering rollback or alert. Quality assurance includes automated one‑click deployment, continuous heartbeat synchronization, and periodic ODTE monitoring, ensuring the digital twin remains an accurate, up‑to‑date representation of the physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The underlying network infrastructure is composed of Eclipse Hono as the IoT messaging middleware and Eclipse Ditto as the digital twin registry. Devices in the building communicate with Hono typically over the standard MQTT protocol (directly or via Hono’s protocol adapters). Hono forwards messages to Ditto, which exposes the twin data over HTTP REST and WebSocket endpoints. The UE5 front‑end first performs an HTTP POST to seed the twin state and then establishes a WebSocket connection to subscribe to real‑time updates and to issue commands. The topology is thus device → Hono broker → Ditto server → UE5 front‑end, forming a distributed, loosely‑coupled architecture. Bandwidth and latency requirements are dictated by the need for real‑time synchronization, but explicit metrics are not defined in the documents. Reliability is provided by Hono’s at‑least‑once delivery semantics and Ditto’s durable message storage, while redundancy and failover are mentioned only in generic terms for the framework’s modular design. Security is implied through Hono/ Ditto’s built‑in authentication mechanisms, though no concrete protocol or certificate strategy is specified. "
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External system integration is achieved primarily through the Eclipse Hono and Eclipse Ditto stack. Hono forwards sensor/actuator telemetry via MQTT, AMQP, or HTTP to an MQTT broker that Ditto subscribes to. Ditto’s twin state graph can be queried via a REST/JSON API or WebSocket, allowing third‑party applications (e.g., facility management dashboards, AI analytics services) to receive live state updates. The BIM model import tool connects to Autodesk Revit through its API, and the processed models are visualised in Unreal Engine 5 (UE5). These dependencies expose IFC and IFCx transmission standards, while the twin service itself adheres to the OPC UA and JSON‑LD data representations exposed by Ditto. This chain of standardized protocols and formats enables interoperability with enterprise resource planning (ERP), building information management (BIM) workflows, and other domain‑specific OT systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework adheres to the Industry Foundation Classes (IFC) open standard for BIM export, ensuring semantic consistency across Autodesk Revit and downstream components. It leverages Eclipse Hono as an MQTT‑based IoT gateway compliant with OMA/OMV standards, and Eclipse Ditto as a digital ‑twin platform that follows the OMA Digital Twin specifications. Additional interoperability is achieved by adopting open‑source patterns for service extension and modular architecture, meeting the Non‑Functional NF1 requirement for cross‑tool compatibility. Compliance with ISO/IEC 21500 and IEEE 14929 for construction project management is implied through the model‑driven approach, although explicit certification is not mentioned."
]