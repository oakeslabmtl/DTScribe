// C10: Models/Data
instance LivingLabIFCModel : DTDFVocab:Model [
    base:desc "Component BIM reference model (IFC) of the living‑lab building"
    DTDFVocab:inputTo MDETransformationPipeline
]

instance DittoRuntimeEntityModel : DTDFVocab:Model [
    base:desc "Dynamic runtime model representation of building devices in Ditto"
    DTDFVocab:inputTo MDETransformationPipeline
]

// C3: Physical sensing components
instance OccupancySensorLivingLab : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor deployed in living‑lab building to detect room occupancy"
    DTDFVocab:producedData OccupancyTelemetry
]

instance AmbientLightSensorCorridor : DTDFVocab:SensingComponent [
    base:desc "Ambient light sensor located in corridor to measure illumination levels"
    DTDFVocab:producedData LightTelemetry
]

instance TemperatureSensorZoneA : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor in zone A of the commercial‑residential building"
    DTDFVocab:producedData TemperatureTelemetry
]

instance EnergyMeterMain : DTDFVocab:SensingComponent [
    base:desc "Energy meter measuring building‑wide power consumption"
    DTDFVocab:producedData EnergyTelemetry
]

// C4: Physical-to-virtual interaction
instance OccupancyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensorLivingLab
]

instance LightTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientLightSensorCorridor
]

instance TemperatureTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorZoneA
]

instance EnergyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeterMain
]

// C4 continued: Data
instance OccupancyData : DTDFVocab:Data [
    base:desc "Processed occupancy count data derived from telemetry"
    DTDFVocab:fromData OccupancyTelemetry
    DTDFVocab:inputTo EclipseDittoProvisioner
]

instance LightData : DTDFVocab:Data [
    base:desc "Processed illumination level data derived from telemetry"
    DTDFVocab:fromData LightTelemetry
    DTDFVocab:inputTo EclipseDittoProvisioner
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Processed temperature data derived from telemetry"
    DTDFVocab:fromData TemperatureTelemetry
    DTDFVocab:inputTo EclipseDittoProvisioner
]

instance EnergyData : DTDFVocab:Data [
    base:desc "Processed electrical consumption data derived from telemetry"
    DTDFVocab:fromData EnergyTelemetry
    DTDFVocab:inputTo EclipseDittoProvisioner
]

// C11: Enablers
instance EclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono broker for MQTT/HTTP device connectivity"
]

instance EclipseDittoProvisioner : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for device provisioning, property updates and ingestion"
    DTDFVocab:enables RealTimeMonitoringDashboardService, PredictiveAnalyticsEnergyService, LightingOptimizationService, HVACScheduleService, Immersive3DVisualizationService
]

instance MDETransformationPipeline : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline to transform enriched BIM into runtime Ditto entities"
]

instance UnrealEngine5Visualizer : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3D visualization of the building"
]

instance GitRepository : DTDFVocab:Enabler [
    base:desc "Git version‑control system for model artifacts and twin evolution"
]

// C6: Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard providing live visualization of telemetry"
    DTDFVocab:provides DashboardInsight
]

instance PredictiveAnalyticsEnergyService : DTDFVocab:Service [
    base:desc "Predictive analytics service for energy consumption forecasting"
    DTDFVocab:provides EnergyForecastInsight, EnergyForecastAction
]

instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Lighting optimization service recommending optimal illumination levels"
    DTDFVocab:provides LightingOptimizationInsight, LightingOptimizationAction
]

instance HVACScheduleService : DTDFVocab:Service [
    base:desc "HVAC scheduling service suggesting set‑point adjustments"
    DTDFVocab:provides HVACScheduleAdjustmentInsight, HVACScheduleAdjustmentAction
]

instance Immersive3DVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization service rendering building in Unreal Engine 5"
    DTDFVocab:provides BuildingVisualizationInsight
]

// C17: Insights
instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring dashboard provides live visualization of occupancy, lighting, temperature, and energy data"
]

instance EnergyForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of future building energy consumption based on current telemetry"
]

instance LightingOptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommendation for optimal lighting levels to reduce energy while maintaining illumination"
]

instance HVACScheduleAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Suggested HVAC set‑point schedules for improved energy efficiency"
]

instance BuildingVisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive 3D rendering of building model in Unreal Engine 5"
]

// C17: Actions
instance EnergyForecastAction : DTDFVocab:Action [
    base:desc "Generate energy consumption forecast report"
    DTDFVocab:IsAutomatic true
]

instance LightingOptimizationAction : DTDFVocab:Action [
    base:desc "Apply lighting optimization recommendations to actual lighting fixtures"
    DTDFVocab:IsAutomatic false
]

instance HVACScheduleAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjust HVAC set‑points per recommended schedule"
    DTDFVocab:IsAutomatic false
]

// C10: Physical Acting Components
instance CorridorLEDPanel : DTDFVocab:ActingComponent [
    base:desc "LED panel in corridor controlling lighting levels"
]

instance ArchitecturalLightFixture : DTDFVocab:ActingComponent [
    base:desc "Architectural lighting fixture for interior illumination"
]

instance HVACZoneVent : DTDFVocab:ActingComponent [
    base:desc "HVAC zone vent controlling airflow to zone"
]

instance HVACHdamper : DTDFVocab:ActingComponent [
    base:desc "HVAC damper adjusting air volume within ductwork"
]

// C17: Environment
instance LivingLabBuildingEnvironment : DTDFVocab:Environment [
    base:contains CorridorLEDPanel, ArchitecturalLightFixture, HVACZoneVent, HVACHdamper
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (e.g., dimming levels for lighting, set‑point adjustments for HVAC) generated by the DT services and pushed back to the physical devices via Ditto topics, transmitted over MQTT through Hono to the device endpoints."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near‑real‑time synchronization with sub‑second telemetry updates and real‑time control loops; the DT operates continuously at a consistent data rate (≈ 1 Hz sensor reporting, immediate command propagation)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A unified DT ecosystem where individual system twins (lighting, HVAC, building envelope) are provisioned and managed via the Hono/Ditto middleware, coordinated by a central DT framework that exposes APIs for stakeholder interaction and service extensibility."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans all life‑cycle stages: (i) As‑designed phase captured in the BIM model, (ii) As‑manufactured phase during construction where data is mapped to physical assets, and (iii) As‑operated phase where real‑time data and control maintain the operational twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Consistency checks during model validation, OEQ‑simulated validation against physical measurements, monitoring of semantic drift via consecutive ODTE metrics, and the use of formal model checks to ensure that the digital twin remains valid over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Devices connect over MQTT with TLS encryption through the Eclipse Hono broker; Ditto exposes a JSON‑based REST interface (for provisioning) and an MQTT topic space; the DT framework acts as a middleware gateway between the physical devices and the virtual representation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT components (Hono, Ditto, Unreal Engine instance) are deployed on a containerized Kubernetes cluster hosted on a public cloud provider (e.g., AWS EKS or Azure AKS), with persistent storage for sensor logs and configuration artifacts."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standard IoT protocols (MQTT, REST) enable the twin to exchange data with external building management systems, energy trading platforms, and other DTs within an ecosystem, allowing cross‑building analytics and federated simulations."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to IFC 4.0 for BIM representation, MQTT as the underlying communication protocol, Ditto's JSON schema for device properties, and general industry best‑practice guidelines for model‑driven engineering."
]