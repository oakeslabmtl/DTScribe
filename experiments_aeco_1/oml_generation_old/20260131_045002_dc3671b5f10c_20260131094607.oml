// Sensing Components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient light sensor embedded on the building façade"
    DTDFVocab:producedData LightSensorData
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor located in the HVAC return air duct"
    DTDFVocab:producedData TemperatureSensorData
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detection node using passive infrared (PIR) technology"
    DTDFVocab:producedData OccupancySensorData
]

// Actuating Components
instance ProgrammableLightingFixture : DTDFVocab:ActingComponent [
    base:desc "Smart LED fixture capable of receiving dimming and color commands from the Digital Twin"
]

instance HVACVent : DTDFVocab:ActingComponent [
    base:desc "Ventilated grid that can be actuated to adjust airflow based on DT control logic"
]

// Data Transmitted
instance LightSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance TemperatureSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancySensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

// Data (JSON payloads)
instance LightSensorReadingData : DTDFVocab:Data [
    base:desc "JSON payload of the latest light level and timestamp forwarded via Eclipse Hono MQTT broker"
    DTDFVocab:fromData LightSensorData
    DTDFVocab:inputTo HonoMiddleware
]

instance TemperatureReadingData : DTDFVocab:Data [
    base:desc "JSON payload of the latest temperature and timestamp forwarded via Eclipse Hono MQTT broker"
    DTDFVocab:fromData TemperatureSensorData
    DTDFVocab:inputTo HonoMiddleware
]

instance OccupancyReadingData : DTDFVocab:Data [
    base:desc "JSON payload of the occupancy status and timestamp forwarded via Eclipse Hono MQTT broker"
    DTDFVocab:fromData OccupancySensorData
    DTDFVocab:inputTo HonoMiddleware
]

// Additional Data
instance SensorMetadataData : DTDFVocab:Data [
    base:desc "Catalogue of sensor capabilities and calibration parameters stored in Eclipse Ditto"
    DTDFVocab:inputTo DittoDataReplication
]

instance BIMIFCModelData : DTDFVocab:Data [
    base:desc "IFC BIM model of the entire building, imported from Revit and replicated in Ditto"
    DTDFVocab:inputTo DittoDataReplication
]

instance RuntimeInterfaceDescriptorData : DTDFVocab:Data [
    base:desc "Auto‑generated runtime interface descriptors derived by the MDE toolkit"
    DTDFVocab:inputTo MDETooling
]

instance ControlLogicModelData : DTDFVocab:Data [
    base:desc "Procedural model for HVAC and lighting control logic, queried via REST/GraphQL"
    DTDFVocab:inputTo DittoDataReplication
]

// Models
instance BIMIFCModel : DTDFVocab:Model [
    base:desc "IFC BIM model representing the building's geometry and components"
    DTDFVocab:inputTo MDETooling
]

instance RuntimeInterfaceDescriptorModel : DTDFVocab:Model [
    base:desc "Runtime interface descriptors generated from BIM using the MDE pipeline"
    DTDFVocab:inputTo MDETooling
]

instance SensorMetadataModel : DTDFVocab:Model [
    base:desc "Model describing sensor metadata schema for registration in Ditto"
    DTDFVocab:inputTo MDETooling
]

instance ActuatorMetadataModel : DTDFVocab:Model [
    base:desc "Metadata model for actuation devices such as lighting fixtures and HVAC vents"
    DTDFVocab:inputTo MDETooling
]

instance ProceduralControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model defining sequencing of building operations"
    DTDFVocab:inputTo MDETooling
]

// Enablers
instance HonoMiddleware : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware facilitating MQTT based telemetry streams from physical devices to the Digital Twin"
    DTDFVocab:enables TelemetryProcessingService
]

instance DittoDataReplication : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto data replication engine storing twin state and enabling REST/GraphQL queries"
    DTDFVocab:enables TwinRegistryService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 rendering engine creating immersive 3D visualizations of the building"
    DTDFVocab:enables DataVisualizationService
]

instance MDETooling : DTDFVocab:Enabler [
    base:desc "Model‑to‑text MDE tooling generating runtime artifacts from BIM models"
    DTDFVocab:enables ModelGenerationService
]

instance BIMRevitAuthoring : DTDFVocab:Enabler [
    base:desc "Standard BIM authoring tool (Revit) used to produce IFC models for the twin"
]

instance HonoDittoConfigOrchestrator : DTDFVocab:Enabler [
    base:desc "Custom orchestrator configuring Eclipse Hono and Ditto connectors for the twin"
    DTDFVocab:enables TelemetryProcessingService
]

// Services
instance TelemetryProcessingService : DTDFVocab:Service [
    base:desc "Service aggregating and normalizing telemetry from the building’s sensors"
    DTDFVocab:provides DiagnosticReportInsight, EnergyUsageOptimizationInsight
]

instance TwinRegistryService : DTDFVocab:Service [
    base:desc "Service managing the Ditto twin registry, exposing twin state via REST/GraphQL"
    DTDFVocab:provides FacilityManagerDashboardInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service rendering immersive 3D dashboards of building performance in Unreal Engine 5"
    DTDFVocab:provides FacilityManagerDashboardInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service applying predictive analytics for future performance forecasting"
    DTDFVocab:provides PredictiveMaintenanceAlertInsight
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Service simulating building thermal and airflow characteristics using BIM models"
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing energy consumption based on real‑time data and predictive models"
    DTDFVocab:provides EnergyUsageOptimizationInsight
]

instance KnowledgeBaseTaskPlanningService : DTDFVocab:Service [
    base:desc "Service generating task planning recommendations from knowledge base"
]

instance ModelGenerationService : DTDFVocab:Service [
    base:desc "Service generating runtime interface descriptors and control logic from BIM via MDE tooling"
]

// Insights
instance DiagnosticReportInsight : DTDFVocab:Insight [
    base:desc "Diagnostic report detailing anomalies in sensor measurements and device health"
]

instance EnergyUsageOptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommendation to reduce energy usage based on real‑time telemetry and predictive models"
]

instance PredictiveMaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Alert for impending maintenance of HVAC vents and lighting fixtures"
]

instance FacilityManagerDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time facility manager dashboard summarizing building status and performance"
]

// Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Command to dim or change color of a programmable lighting fixture"
    DTDFVocab:IsAutomatic false
]

instance AdjustVentAction : DTDFVocab:Action [
    base:desc "Command to alter airflow of an HVAC vent"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control messages originating from the DT’s runtime services that are sent back to the building’s actuators through Hono’s MQTT topics and transmitted via Ditto’s device handlers, enabling state changes in lighting, HVAC, etc."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular service‑oriented architecture where a central Twin Engine aggregates BIM‑derived models, communicates with physical devices through Hono/Ditto, provides visualization via Unreal Engine, and exposes RESTful services for external stakeholders."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the complete lifecycle: design (ideal BIM), construction (manufactured elements), and operation (runtime monitoring and optimization)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The overall Digital Twin Entanglement (ODTE) metric is employed to quantify the alignment between the digital and physical representations, coupled with runtime verification of sensor data integrity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Network communication is based on MQTT over TLS for secure data exchange via Eclipse Hono, with Ditto using WebSocket endpoints for real‑time synchronization and JSON payloads."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Containerized deployment orchestrated by Kubernetes, with persistent storage for twin registries and policy definitions, and scalable MQTT broker instances for high‑throughput telemetry."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external BIM and building automation systems through standard REST APIs, IFC exchange, and the Hono/Ditto pub/sub middleware to enable cross‑system data flow."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership resides with the building owner; the DT service provider processes data under strict anonymity policies, ensuring that personal or sensitive information is not disclosed beyond the authorized platform."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to IFC for BIM interchange, ETS/ISO 17025 for sensor calibration, and ETSI standards for MQTT to guarantee interoperability across vendors."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Secure MQTT/TLS channels, role‑based access control in Ditto, audit logging of all commands, and runtime safety checks to prevent unsafe actuator states during remote operation."
]