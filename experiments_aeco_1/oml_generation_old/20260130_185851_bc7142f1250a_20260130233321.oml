// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined as a first‑class object in the enriched BIM model, capturing ambient temperature readings."
    DTDFVocab:producedData TemperatureDataStream
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor defined as a first‑class object in the enriched BIM model, measuring indoor humidity levels."
    DTDFVocab:producedData HumidityDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined as a first‑class object in the enriched BIM model, detecting presence of occupants."
    DTDFVocab:producedData OccupancyDataStream
]

// C4: DataTransmitted (sensor streams)
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Data (semantic payloads)
instance TemperatureData : DTDFVocab:Data [
    base:desc "Continuous temperature readings streamed from TemperatureSensor."
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo RealTimeDataExchangeEngine
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Continuous humidity readings streamed from HumiditySensor."
    DTDFVocab:fromData HumidityDataStream
    DTDFVocab:inputTo RealTimeDataExchangeEngine
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Continuous occupancy status streamed from OccupancySensor."
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo RealTimeDataExchangeEngine
]

// C2: Acting components (actuators)
instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve actuator modelled in BIM as a controller entity, exposing remote‑control interface for airflow regulation."
]

instance MotorizedBlindActuator : DTDFVocab:ActingComponent [
    base:desc "Motorized blind actuator modelled in BIM, allowing automated shading control via the DT."
]

// C11: Enablers
instance RealTimeDataExchangeEngine : DTDFVocab:Enabler [
    base:desc "Framework component that provides real‑time data exchange synchronising sensor/actuator streams between physical building and digital twin."
    DTDFVocab:enables RealTimeMonitoringService,
                     PredictiveAnalyticsService,
                     WhatIfSimulationService,
                     LifeCycleOptimizationService,
                     RemoteControlService,
                     InteractiveVisualizationService
]

instance MDEExtractionTool : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering (MDE) extraction tool that converts enriched BIM models into formal DT artifacts."
    DTDFVocab:enables ModelCompilationService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Game‑engine based visualization layer that maps DT data onto 3‑D BIM geometry."
    DTDFVocab:enables InteractiveVisualizationService
]

// C10: Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with explicit definitions of sensors, actuators, and controllers, forming the semantic foundation of the DT."
    DTDFVocab:inputTo MDEExtractionTool
]

instance DTCompilationModel : DTDFVocab:Model [
    base:desc "Formal model generated by MDE extraction, automatically compiled into deployable twin components."
    DTDFVocab:inputTo ModelCompilationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of system states (temperature, humidity, occupancy, equipment status)."
    DTDFVocab:provides BuildingStateInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics and forecasting of energy usage and equipment performance."
    DTDFVocab:provides EnergyForecastInsight,
                     EnergySavingRecommendationAction
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What‑if simulation service to evaluate design or operational changes."
    DTDFVocab:provides ScenarioOutcomeInsight
]

instance LifeCycleOptimizationService : DTDFVocab:Service [
    base:desc "Life‑cycle optimization service that continuously reduces operational costs and improves energy efficiency."
    DTDFVocab:provides OperationalCostReductionInsight
]

instance RemoteControlService : DTDFVocab:Service [
    base:desc "Remote control functionality enabling Facility Managers to operate physical infrastructure via the twin."
    DTDFVocab:provides AdjustHVACSetpointAction,
                     SwitchLightingAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3‑D visualization of the building using a game‑engine environment."
    DTDFVocab:provides SpatialAwarenessInsight
]

instance ModelCompilationService : DTDFVocab:Service [
    base:desc "Service that compiles extracted BIM models into executable digital twin components."
]

// C17: Insights
instance BuildingStateInsight : DTDFVocab:Insight [
    base:desc "Insight providing up‑to‑date state information of building systems for Facility Managers."
]

instance EnergyForecastInsight : DTDFVocab:Insight [
    base:desc "Insight delivering forecasts of future energy consumption based on current sensor trends."
]

instance ScenarioOutcomeInsight : DTDFVocab:Insight [
    base:desc "Insight presenting outcomes of what‑if scenarios to support design and operational decisions."
]

instance OperationalCostReductionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating opportunities for reducing operational costs and enhancing energy efficiency over the building lifecycle."
]

instance SpatialAwarenessInsight : DTDFVocab:Insight [
    base:desc "Insight giving Facility Managers spatial context of sensor readings within the 3‑D BIM visualization."
]

// C17: Actions
instance EnergySavingRecommendationAction : DTDFVocab:Action [
    base:desc "Action recommending adjustments to building operation to save energy (e.g., modify HVAC set‑points)."
    DTDFVocab:IsAutomatic false
]

instance AdjustHVACSetpointAction : DTDFVocab:Action [
    base:desc "Action allowing Facility Manager to remotely adjust HVAC temperature set‑points via the DT."
    DTDFVocab:IsAutomatic false
]

instance SwitchLightingAction : DTDFVocab:Action [
    base:desc "Action enabling remote switching of lighting systems through the DT interface."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication is supported, allowing the digital twin to transmit control signals back to the building management system for real‑time monitoring and control, but the document gives no specifics on command formats, validation, authentication, feedback, conflict resolution, or execution confirmation procedures."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates with live, continuous synchronization between the physical building and its digital counterpart, using real‑time monitoring of sensor data to keep the virtual model up‑to‑date. Synchronisation is performed continuously (i.e., as soon as new data become available), providing a real‑time view of the asset. No explicit latency bounds or discrete time‑step intervals are specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular hub‑and‑spoke architecture where a central DT framework acts as the coordination hub. It integrates BIM models, the Eclipse Hono IoT messaging backbone, the Eclipse Ditto digital‑twin engine, and a 3‑D visualisation layer (Unreal Engine) via defined APIs and message brokers. Extension points allow plug‑ins, and the framework orchestrates data flow and resource management across these components."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports a complete Digital Twin life‑cycle that starts with device modeling inside a BIM environment where Building Control Engineers define sensors, actuators and controllers and embed control logic. The enriched BIM model constitutes the design‑time semantic representation. Using Model‑Driven Engineering (MDE) principles the model is automatically transformed into a structured intermediate representation and then into deployable DT artifacts (runtime services, data adapters, visualisation components). These artifacts are instantiated on the execution platform, establishing the operational representation that continuously synchronises with the physical building via real‑time data exchange. Throughout the cycle, transition between phases is managed automatically by the model‑driven transformation pipeline, while governance is enforced by the defined actor roles (Building Control Engineer, Facility Manager, DT Engineer) and by the modular architecture with standardized extension points that control how custom services are integrated and evolved."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Before DT generation the input BIM model is validated, and the resulting twin’s fidelity is quantified using the Overall Digital Twin Entanglement (ODTE) metric, which measures how closely the digital representation reflects the physical counterpart. The framework thus incorporates model validation, metric‑based fidelity assessment, and MDE‑driven transformation to ensure data and model quality throughout the deployment lifecycle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "A modular architecture with standardized extension points and non‑functional requirements for interoperability, scalability, and maintainability is described, yet the document does not specify the underlying network protocols, topology, bandwidth, latency, redundancy, or security measures used for the technical connection."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin framework is presented as a centrally managed, runtime‑configurable hub that can integrate custom services and analytics, indicating flexibility in deployment; however, the document does not provide concrete information on hosting platforms, compute/storage resources, scalability mechanisms, deployment models, or availability/reliability assurances."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is realised through the incorporation of AECO‑specific standards such as BIM (e.g., building information models) and by coupling the DT to building control systems via Eclipse Hono and Eclipse Ditto. These components enable bidirectional data exchange between the physical building control infrastructure and the digital twin, allowing sensor data to flow into the twin and control signals to be sent back to the building systems. The architecture therefore supports interoperability with existing enterprise AECO tools and control platforms."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution adopts standardization at several levels. It builds on BIM as an industry‑wide standard modeling base and enriches BIM semantics to represent sensors, actuators and controllers, thereby standardizing the data model. The framework’s modular design provides 'standardized extension points' that define uniform interfaces for adding custom services or analytics, ensuring interoperability between components. While no external standards (e.g., ISO, IFC) are explicitly cited, the approach emphasizes a standardized methodology for model transformation and artifact generation, positioning the framework as a standard solution for DT deployment in the construction sector."
]