// C2: Acting Components
instance LightingDimmingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimming actuators embedded in the BIM model to enable real‑time manipulation of the building’s internal environment."
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor integrated into the BIM model to capture post‑occupancy data for the digital twin."
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor integrated into the BIM model to capture post‑occupancy data for the digital twin."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// C4: Physical-to-virtual interaction
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with sensor/actuator semantics and embedded control logic."
    DTDFVocab:inputTo MDEModelTransform, UMLBIMAugmentation
]
instance RuntimeInterfaceHono : DTDFVocab:Model [
    base:desc "Runtime interface generated via model‑to‑text transformations for Eclipse Hono."
    DTDFVocab:inputTo HonoMessageRouter
]
instance RuntimeInterfaceDitto : DTDFVocab:Model [
    base:desc "Runtime interface generated via model‑to‑text transformations for Eclipse Ditto."
    DTDFVocab:inputTo DittoTwinBroker
]
instance ReinforcementLearningPolicyData : DTDFVocab:Data [
    base:desc "Reinforcement‑learning policy data for lighting control optimized through post‑occupancy sensor data."
    DTDFVocab:inputTo HonoMessageRouter, DittoTwinBroker
]

// Data instances
instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy data captured by the occupancy sensor."
    DTDFVocab:inputTo HonoMessageRouter, DittoTwinBroker
    DTDFVocab:fromData OccupancyDataTransmitted
]
instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Environmental data captured by the environmental sensor."
    DTDFVocab:inputTo HonoMessageRouter, DittoTwinBroker
    DTDFVocab:fromData EnvironmentalDataTransmitted
]

// C11: Enablers
instance HonoMessageRouter : DTDFVocab:Enabler [
    base:desc "Eclipse Hono message router that publishes sensor data in real time to the message broker."
    DTDFVocab:enables MonitoringDashboardService, PredictiveAnalyticsService, SimulationModuleService, RLControlOptimizationService, TaskPlanningService, UnrealVisualizationService
]
instance DittoTwinBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin broker that synchronizes the physical state with the virtual twin representation."
    DTDFVocab:enables MonitoringDashboardService, PredictiveAnalyticsService, SimulationModuleService, RLControlOptimizationService, TaskPlanningService, UnrealVisualizationService
]
instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 rendering engine for immersive 3D visualization of the digital twin."
    DTDFVocab:enables UnrealVisualizationService
]
instance MDEModelTransform : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering tooling for model‑to‑text transformations that generate runtime artifacts."
    DTDFVocab:enables RuntimeInterfaceHono, RuntimeInterfaceDitto
]
instance UMLBIMAugmentation : DTDFVocab:Enabler [
    base:desc "UML/Domain‑Specific Modeling language tooling for augmenting BIM models with sensor/actuator semantics."
    DTDFVocab:enables EnrichedBIMModel
]

// C6: Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards for visualizing occupancy and environmental data."
    DTDFVocab:provides EnergyOptimizationInsight
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics and simulation modules that forecast energy consumption and maintenance needs."
    DTDFVocab:provides PredictiveMaintenanceInsight
]
instance SimulationModuleService : DTDFVocab:Service [
    base:desc "Simulation modules that provide design‑phase insights for stakeholder decision support."
    DTDFVocab:provides DesignPhaseSimulationInsight
]
instance RLControlOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based control optimization for lighting strategies."
    DTDFVocab:provides LightingControlStrategyInsight
    DTDFVocab:provides LightingDimmingAction
]
instance TaskPlanningService : DTDFVocab:Service [
    base:desc "Task planning for maintenance schedules."
    DTDFVocab:provides PredictiveMaintenanceInsight
]
instance UnrealVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D visualization using Unreal Engine 5."
    DTDFVocab:provides DesignPhaseSimulationInsight
]

// C17: Insights/Actions
instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Data‑driven energy consumption optimization."
]
instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance schedules."
]
instance LightingControlStrategyInsight : DTDFVocab:Insight [
    base:desc "Lighting control strategy selection."
]
instance DesignPhaseSimulationInsight : DTDFVocab:Insight [
    base:desc "Design‑phase simulation insights for stakeholder decision support."
]
instance LightingDimmingAction : DTDFVocab:Action [
    base:desc "Actuation command to dim lighting based on the optimized control policy."
    DTDFVocab:IsAutomatic true
]

// C10: Additional Models
instance ReinforcementLearningModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning model for adaptive lighting control."
    DTDFVocab:inputTo MDEModelTransform, UMLBIMAugmentation
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the digital twin (e.g., lighting setpoints, HVAC adjustments) are transmitted through Eclipse Ditto to the building automation system via Eclipse Hono, enabling bidirectional interaction."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time synchronization where sensor updates and control actions are processed immediately upon receipt, ensuring near real‑time consistency between the physical building and its digital twin."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation consists of a BIM‑based virtual representation, an Eclipse Ditto twin registry, an Eclipse Hono message broker, and an Unreal Engine visualisation layer, orchestrated through a modular, service‑oriented architecture."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (planning and BIM creation), construction (data extraction and model validation), and operation (real‑time monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation performed using the Overall Digital Twin Entanglement (ODTE) metric, comparing the DT’s simulated state against real sensor streams to quantify alignment and detect model drift."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication relies on Eclipse Hono as a message broker and Eclipse Ditto as a twin registry, facilitating real‑time data exchange between the physical building and its digital twin."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardised extension points expose APIs, allowing third‑party services and external information systems to plug into the digital twin ecosystem, supporting horizontal data exchange beyond the core DT stack."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM serves as the semantic backbone with its industry‑standardised property sets; communication follows ICT standards such as MQTT and the Eclipse Hono/​Ditto ecosystem, providing interoperability across building‑automation devices and software components."
]