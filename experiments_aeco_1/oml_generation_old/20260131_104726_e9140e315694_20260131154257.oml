// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Building Control System temperature sensor providing real-time environmental data for HVAC optimization and occupancy monitoring"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Motion and presence detection sensor for occupancy-based lighting and HVAC control systems"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnergyConsumptionMeter : DTDFVocab:SensingComponent [
    base:desc "Smart meter measuring real-time energy consumption across building systems for demand response and optimization"
    DTDFVocab:producedData EnergyDataTransmitted
]

instance HVACControllerSensor : DTDFVocab:SensingComponent [
    base:desc "Building automation system sensor monitoring HVAC system performance metrics including airflow, pressure, and equipment status"
    DTDFVocab:producedData HVACDataTransmitted
]

instance LightingSystemSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting control system sensor providing real-time data on lighting levels, occupancy, and energy usage"
    DTDFVocab:producedData LightingDataTransmitted
]

instance SecuritySystemSensor : DTDFVocab:SensingComponent [
    base:desc "Building security system sensor providing real-time alerts and status updates for access control and safety monitoring"
    DTDFVocab:producedData SecurityDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionMeter
]

instance HVACDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACControllerSensor
]

instance LightingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSystemSensor
]

instance SecurityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecuritySystemSensor
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Semantically enriched Building Information Model incorporating geometric, spatial, and component-wise representations with BCS metadata"
    DTDFVocab:inputTo ModelDrivenEngineeringFramework
]

instance BCSDeviceConfigurationModel : DTDFVocab:Model [
    base:desc "Structured model defining Building Control System components including sensors, actuators, and controllers with control logic and calibration parameters"
    DTDFVocab:inputTo BuildingInformationModelingPlatform
]

instance RealTimeBuildingStateModel : DTDFVocab:Model [
    base:desc "Dynamic model representing the current operational state of the physical building synchronized with sensor telemetry"
    DTDFVocab:inputTo RealTimeDataExchangeInfrastructure
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Time-series temperature data collected from building sensors with metadata including location, timestamp, and quality flags"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo SimulationAndAnalyticsEngines
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy pattern data including presence detection, movement tracking, and temporal occupancy profiles"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EnergyOptimizationService
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "Granular energy consumption metrics with breakdown by system, time intervals, and consumption patterns"
    DTDFVocab:fromData EnergyDataTransmitted
    DTDFVocab:inputTo EnergyOptimizationService
]

instance HVACPerformanceData : DTDFVocab:Data [
    base:desc "HVAC system performance metrics including airflow rates, pressure differentials, equipment status, and energy efficiency indicators"
    DTDFVocab:fromData HVACDataTransmitted
    DTDFVocab:inputTo ControlLogicService
]

instance LightingOperationData : DTDFVocab:Data [
    base:desc "Lighting system operational data including energy usage, luminaire status, and occupancy-based control parameters"
    DTDFVocab:fromData LightingDataTransmitted
    DTDFVocab:inputTo EnergyOptimizationService
]

instance SecurityAlertData : DTDFVocab:Data [
    base:desc "Security system alerts and status updates including access events, intrusion detection, and system health metrics"
    DTDFVocab:fromData SecurityDataTransmitted
    DTDFVocab:inputTo AnomalyDetectionService
]

// C11: Enablers
instance ModelDrivenEngineeringFramework : DTDFVocab:Enabler [
    base:desc "Core MDE framework enabling automated transformation of enriched BIM models into deployable Digital Twin artifacts using model transformation and code generation principles"
    DTDFVocab:enables BIMToDTTransformationService, AutomatedArtifactGenerationService, DeviceModelingService
]

instance BuildingInformationModelingPlatform : DTDFVocab:Enabler [
    base:desc "Foundational BIM platform providing geometric, spatial, and component-wise representations enriched with BCS semantic metadata"
    DTDFVocab:enables DeviceModelingService
]

instance RealTimeDataExchangeInfrastructure : DTDFVocab:Enabler [
    base:desc "Bidirectional data synchronization infrastructure supporting continuous streaming from sensors/actuators to DT and command execution to physical systems using industrial IoT protocols"
    DTDFVocab:enables RealTimeMonitoringService, ControlLogicService
]

instance InteractiveVisualizationEngine : DTDFVocab:Enabler [
    base:desc "3D BIM-integrated visualization platform providing immersive monitoring interfaces with real-time overlays and multi-user collaboration features"
    DTDFVocab:enables RealTimeMonitoringService
]

instance ModularDTArchitecture : DTDFVocab:Enabler [
    base:desc "Microservices-based DT architecture with standardized extension points enabling plugin integration, service discovery, and containerized deployment"
    DTDFVocab:enables CustomServiceDevelopmentService
]

instance SimulationAndAnalyticsEngines : DTDFVocab:Enabler [
    base:desc "Physics-based simulation and machine learning engines supporting predictive scenarios, optimization algorithms, and digital twin-specific analytics"
    DTDFVocab:enables PredictiveMaintenanceService, EnergyOptimizationService, AnomalyDetectionService
]

instance DatabaseManagementLayer : DTDFVocab:Enabler [
    base:desc "Hybrid data storage solution combining time-series databases for sensor telemetry and graph databases for semantic relationships with versioning support"
]

instance DeploymentAndLifecycleManagement : DTDFVocab:Enabler [
    base:desc "Automated deployment pipeline supporting model-to-text transformation, CI/CD integration, and rollback mechanisms for Digital Twin artifacts"
    DTDFVocab:enables AutomatedArtifactGenerationService
]

// C6: Services
instance DeviceModelingService : DTDFVocab:Service [
    base:desc "Service enabling Building Control Engineers to define sensors, actuators, and controllers within BIM environment with semantic metadata and control logic"
    DTDFVocab:provides DeviceConfigurationInsight, ControlLogicDefinitionAction
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous synchronization service providing up-to-date building system states through immersive visualization interfaces"
    DTDFVocab:provides SystemStateInsight, OperationalControlAction
]

instance CustomServiceDevelopmentService : DTDFVocab:Service [
    base:desc "Modular service platform enabling DT Engineers to integrate custom analytics, optimization algorithms, and domain-specific logic via standardized extension points"
    DTDFVocab:provides CustomAnalyticsInsight, ServiceExtensionAction
]

instance AutomatedArtifactGenerationService : DTDFVocab:Service [
    base:desc "Automated transformation pipeline converting enriched BIM models into deployable Digital Twin artifacts with minimal manual intervention"
    DTDFVocab:provides DeploymentArtifactInsight, ArtifactGenerationAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive analytics service forecasting equipment failures and maintenance requirements based on real-time operational data and historical patterns"
    DTDFVocab:provides MaintenanceForecastInsight, MaintenanceRecommendationAction
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy management service implementing dynamic load balancing, demand response, and occupancy-based optimization algorithms"
    DTDFVocab:provides EnergySavingsInsight, OptimizationRecommendationAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "AI-driven service identifying deviations from expected system behavior through pattern recognition and statistical analysis"
    DTDFVocab:provides AnomalyAlertInsight, CorrectiveActionRecommendationAction
]

instance ControlLogicService : DTDFVocab:Service [
    base:desc "Automated control service executing feedback loops and rule-based automation for building systems based on real-time sensor data"
    DTDFVocab:provides ControlExecutionInsight, SystemAdjustmentAction
]

instance BIMToDTTransformationService : DTDFVocab:Service [
    base:desc "Model transformation service extracting structured representations from enriched BIM models for Digital Twin deployment"
    DTDFVocab:provides ModelTransformationInsight, DTArtifactGenerationAction
]

// C17: Insights/Actions
instance DeviceConfigurationInsight : DTDFVocab:Insight [
    base:desc "Semantic model of Building Control System components with calibration parameters and control logic definitions"
]

instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Real-time operational state of building systems with synchronized sensor telemetry and equipment status"
]

instance CustomAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Domain-specific analytical results from integrated custom services including optimization metrics and predictive forecasts"
]

instance DeploymentArtifactInsight : DTDFVocab:Insight [
    base:desc "Generated Digital Twin artifacts including simulation models, control logic executables, and configuration files"
]

instance MaintenanceForecastInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance recommendations with failure probabilities and optimal intervention timelines"
]

instance EnergySavingsInsight : DTDFVocab:Insight [
    base:desc "Energy consumption patterns and optimization opportunities with potential savings estimates"
]

instance AnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Detected system anomalies with severity levels, root cause hypotheses, and impact assessments"
]

instance ControlExecutionInsight : DTDFVocab:Insight [
    base:desc "Execution status of automated control actions with performance metrics and adjustment recommendations"
]

instance ModelTransformationInsight : DTDFVocab:Insight [
    base:desc "Transformation mapping between BIM elements and corresponding Digital Twin representations"
]

