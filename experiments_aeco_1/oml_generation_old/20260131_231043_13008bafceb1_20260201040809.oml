// C2: Acting Components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture controlled via on/off, brightness, and color‑temperature commands within 0–100% brightness and 2000–6500K color temperature"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Measures ambient temperature via installed sensors in the office building"
    DTDFVocab:producedData TemperatureDataPacket
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Measures ambient humidity via installed sensors in the office building"
    DTDFVocab:producedData HumidityDataPacket
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Detects occupancy via installed sensors in the office building"
    DTDFVocab:producedData OccupancyDataPacket
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Measures CO₂ concentration via installed sensors in the office building"
    DTDFVocab:producedData CO2DataPacket
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance TemperatureDataPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance CO2DataPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model incorporating device metadata for sensors, actuators, and controllers"
    DTDFVocab:inputTo MDEPipeline
]

instance ValidationModel : DTDFVocab:Model [
    base:desc "Validation model enforcing metadata completeness and unit consistency during the MDE pipeline"
    DTDFVocab:inputTo MDEPipeline
]

instance ConversionModel : DTDFVocab:Model [
    base:desc "Conversion model transforming validated BIM into deployable twin artefacts"
    DTDFVocab:inputTo MDEPipeline
]

instance ConfigurationModel : DTDFVocab:Model [
    base:desc "Configuration model generating Ditto device artefacts and control parameters"
    DTDFVocab:inputTo MDEPipeline
]

instance TemperatureMeasurement : DTDFVocab:Data [
    base:desc "Recorded ambient temperature value with unit Celsius from the office building's temperature sensors"
    DTDFVocab:fromData TemperatureDataPacket
    DTDFVocab:inputTo EclipseHonoBroker
]

instance HumidityMeasurement : DTDFVocab:Data [
    base:desc "Recorded ambient humidity value with unit percentage from the office building's humidity sensors"
    DTDFVocab:fromData HumidityDataPacket
    DTDFVocab:inputTo EclipseHonoBroker
]

instance OccupancyMeasurement : DTDFVocab:Data [
    base:desc "Recorded occupancy status (present/absent) from the office building's occupancy sensors"
    DTDFVocab:fromData OccupancyDataPacket
    DTDFVocab:inputTo EclipseHonoBroker
]

instance CO2Measurement : DTDFVocab:Data [
    base:desc "Recorded CO₂ concentration value with unit ppm from the office building's CO₂ sensors"
    DTDFVocab:fromData CO2DataPacket
    DTDFVocab:inputTo EclipseHonoBroker
]

// C11: Enablers
instance EclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono message broker handling incoming real‑time sensor telemetry streams"
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto device broker receiving sensor data and managing digital twin entities"
    DTDFVocab:enables ControlService
]

instance MDEPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline converting enriched BIM to deployable twin artefacts"
    DTDFVocab:enables ModelGenerationService
]

instance PolicyEngine : DTDFVocab:Enabler [
    base:desc "Policy enforcement engine validating units and value ranges before persisting data"
    DTDFVocab:enables RealTimeMonitoringService
]

instance UnrealTwinController : DTDFVocab:Enabler [
    base:desc "UnrealTwinController mediates bidirectional message flow between TwinComponents and physical devices"
    DTDFVocab:enables ImmersiveVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring ingesting sensor streams for anomaly detection and state estimation"
    DTDFVocab:provides AnomalyDetectionInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics computing HVAC load forecasts and recommending energy‑saving schedules"
    DTDFVocab:provides EnergySavingScheduleRecommendationInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Control service that allows facility managers to issue commands to actuators via the building automation system"
    DTDFVocab:provides IssueControlCommandAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization rendering BIM model with live status overlays for interactive exploration"
    DTDFVocab:provides UpdateVisualizationAction
]

instance CustomAnalyticsExtensionService : DTDFVocab:Service [
    base:desc "Extensible custom analytics plugin service for DT engineers"
    DTDFVocab:provides CustomAnalyticsPluginInsight
]

instance ModelGenerationService : DTDFVocab:Service [
    base:desc "Service generating twin artefacts from enriched BIM"
    DTDFVocab:provides ModelGenerationInsight
]

// C17: Insights/Actions
instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight into anomalous sensor readings detected by the monitoring service"
]

instance EnergySavingScheduleRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommended energy‑saving HVAC schedules derived from predictive analytics"
]

instance IssueControlCommandAction : DTDFVocab:Action [
    base:desc "Actuator command to set light brightness or other device parameters"
    DTDFVocab:IsAutomatic false
]

instance UpdateVisualizationAction : DTDFVocab:Action [
    base:desc "Update the BIM rendering to reflect current sensor and actuator states"
    DTDFVocab:IsAutomatic false
]

instance CustomAnalyticsPluginInsight : DTDFVocab:Insight [
    base:desc "Custom analytic insight generated by a plugin"
]

instance ModelGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful conversion of BIM into twin artefacts"
]

// Example environment incorporating key components
instance OfficeBuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, HumiditySensor, OccupancySensor, CO2Sensor, LightTwinComponent,
           EnrichedBIMModel, ValidationModel, ConversionModel, ConfigurationModel
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized DT framework employing a modular micro‑service architecture with standardized extension points. The core hub manages bidirectional data exchange between enriched BIM models and operational DT instances, orchestrating resource allocation, runtime configuration, and low‑overhead lifecycle updates."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin lifecycle in the proposed framework follows four explicit phases. First, the Device Modeling stage involves building control engineers enriching a native BIM model (Level 3/4) with sensor, actuator, and controller entities (BCS components). Second, the Transformation stage applies Model‑Driven Engineering (MDE) techniques to automatically map the enriched BIM elements onto a structured semantic representation (e.g., ontology‑aligned JSON or UML models). Third, the Deployment stage generates executable DT artifacts—containerised micro‑services or runtime modules—that embody the control logic and can be instantiated on an edge or cloud platform. Finally, the Runtime Monitoring & Control stage synchronises real‑time telemetry from the physical building via bidirectional data‑exchange protocols, updates the digital twin state, and provides facility‑manager‑centric visualization interfaces. Transition between stages is governed by automated validation of BIM constraints and registration of the generated artifacts in a deployment registry, while governance is achieved through role‑based access controls for Building Control Engineers, Facility Managers, and DT Engineers."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is maintained by tightly coupling the BIM‑derived geometric model to the twin artefacts; geometric integrity is preserved via IFC export and UE 5 rendering, while behavioral fidelity is driven by the TwinComponent/FeatureParser correspondence.  Validation occurs at multiple stages: the conversion pipeline checks metadata completeness; Ditto enforces value‑range and unit policies for sensor data; pre‑execution checks guarantee that actuator commands cannot violate safety bounds.  Fault tolerance is achieved through Eclipse Hono’s at‑least‑once delivery semantics and Ditto’s persistent event storage, ensuring resilience against network or service failures.  Continuous synchronization between physical devices and twin state, combined with the aforementioned policies and validation layers, forms the system’s quality‑assurance loop for models and data."
]