// C3: Physical sensing components
instance BIMDefinedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors defined in the enriched BIM model that publish real‑time measurements via Eclipse Hono to Eclipse Ditto, synchronized with a 1‑second heartbeat mechanism."
    DTDFVocab:producedData HonoDittoStream
]

// C4: Physical‑to‑virtual data transmission
instance HonoDittoStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BIMDefinedSensor
]

// C5: Data produced from sensors
instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Real‑time sensor measurement stream stored in Eclipse Ditto, validated for units and ranges."
    DTDFVocab:fromData HonoDittoStream
    DTDFVocab:inputTo EclipseDittoPlatform
]

// C1: Acting components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in BIM with controllable on/off, brightness level, and color‑temperature (kelvin) attributes, addressed via Ditto device identifiers."
]

// C9: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched Building Information Model providing geometric foundation and device metadata for the digital twin."
    DTDFVocab:inputTo MDEDeploymentPipeline
]

instance SemanticRepresentationModel : DTDFVocab:Model [
    base:desc "Semantic representation extracted by MDE from the enriched BIM, constituting behavioral models and control logic."
    DTDFVocab:inputTo MDEDeploymentPipeline
]

instance DeviceMetadata : DTDFVocab:Data [
    base:desc "Metadata about sensors and actuators stored in the BIM model."
    DTDFVocab:inputTo ModularExtensionFramework
]

// C11: Enablers
instance EclipseDittoPlatform : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto instance storing twin state, applying policy‑based validation and providing persistent event storage."
    DTDFVocab:enables RealTimeSyncService, DeviceStateMonitoringService, ActuatorControlService
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 visualization component rendering twin geometry and supporting interactive 3‑D immersion for facility managers."
    DTDFVocab:enables Visualization3DService
]

instance ModularExtensionFramework : DTDFVocab:Enabler [
    base:desc "Modular extension point allowing DT engineers to plug custom analytics, optimization and prediction services."
    DTDFVocab:enables CustomAnalyticsExtensionService
]

instance MDEDeploymentPipeline : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline that extracts semantic models from the enriched BIM and automatically assembles deployable DT artifacts."
    DTDFVocab:enables DeployableArtifactGenerationService, SimulationAnalysisService
]

// C6: Services
instance RealTimeSyncService : DTDFVocab:Service [
    base:desc "Provides continuous real‑time data exchange between physical sensors and the digital twin, ensuring updates at least once per second."
    DTDFVocab:provides OperationalMetricsInsight
]

instance DeviceStateMonitoringService : DTDFVocab:Service [
    base:desc "Monitors device states and exposes them for visualization and analysis."
    DTDFVocab:provides OperationalMetricsInsight
]

instance ActuatorControlService : DTDFVocab:Service [
    base:desc "Controls actuators (e.g., lighting) via commands routed through UnrealTwinController to Ditto, respecting policy validation."
    DTDFVocab:provides OperateActuatorAction
]

instance Visualization3DService : DTDFVocab:Service [
    base:desc "Interactive 3‑D visualization in UE5 for facility managers to monitor and operate building systems."
    DTDFVocab:provides ImmersiveVisualizationInsight, OperateActuatorAction
]

instance CustomAnalyticsExtensionService : DTDFVocab:Service [
    base:desc "Custom analytics, optimization and predictive services added through the modular extension point."
    DTDFVocab:provides DecisionSupportInsight
]

instance DeployableArtifactGenerationService : DTDFVocab:Service [
    base:desc "Automatically generates deployable digital twin artifacts from the enriched BIM model."
    DTDFVocab:provides DecisionSupportInsight
]

instance SimulationAnalysisService : DTDFVocab:Service [
    base:desc "Supports simulation‑based analysis and predictive analytics on twin data."
    DTDFVocab:provides RunSimulationAction, DecisionSupportInsight
]

// C17: Insights
instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive visualisation enables facility managers to monitor system states and operate infrastructure."
]

instance OperationalMetricsInsight : DTDFVocab:Insight [
    base:desc "Up‑to‑date operational metrics supplied by real‑time data exchange support on‑the‑fly decision making."
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Analytics and predictions provide decision support for building control strategies."
]

// C19: Actions
instance OperateActuatorAction : DTDFVocab:Action [
    base:desc "Command to change actuator state (e.g., lighting on/off, brightness, color‑temperature)."
    DTDFVocab:IsAutomatic false
]

instance RunSimulationAction : DTDFVocab:Action [
    base:desc "Execute simulation‑based analysis on the twin model."
    DTDFVocab:IsAutomatic true
]

// C20: System components
instance BuildingInfrastructure : DTDFVocab:Component [
    base:desc "Physical building infrastructure captured in the enriched BIM, encompassing sensors, actuators, and control systems."
]

instance DTFrameworkHub : DTDFVocab:Component [
    base:desc "Central digital‑twin framework hub coordinating one twin instance per building asset."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin can send control commands back to the building’s control systems via the framework’s bidirectional exchange. Facility Managers interact with the DT to initiate actions, and the integrated services route the issued commands to the physical devices. Specific command formats, validation, and authentication mechanisms are handled by the services but are not detailed in the provided documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework implements real‑time data exchange that continuously synchronises the physical building with its digital twin; the documents state the exchange is real‑time but do not provide concrete synchronization intervals, latency limits, or temporal granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, model‑driven architecture where enriched BIM models are transformed via MDE techniques into deployable DT artifacts; a central DT Framework provides standardized extension points, runtime configuration management, and bidirectional data exchange, enabling integration of custom services and analytics while managing resources at the component level."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a full DT life‑cycle that starts with device modeling inside the BIM environment, where sensors, actuators and controllers are defined (functional requirement F1). Enriched BIM models are then transformed by model‑driven engineering (MDE) into structured DT artifacts. An automated deployment process (R2) generates reproducible runtime instances, establishing the transition from design‑time models to deployed twins. At runtime the twin maintains real‑time data exchange with the physical asset and provides interactive visualization for monitoring and control. The modular architecture with defined extension points (R4) enables later integration of custom services, allowing the twin to evolve while preserving the original semantic foundation. Governance is addressed by the automated, reproducible deployment and the modular extension mechanism."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through an automated pipeline that includes a Model‑Checking stage (5.53 s) and Model‑Parsing stage (8.7 s) before initialization. Eclipse Ditto enforces policy‑based validation of sensor values (range and unit checks) and pre‑execution validation of actuator commands to prevent conflicts. Fault tolerance is provided by Eclipse Hono’s at‑least‑once delivery and Ditto’s persistent event storage, mitigating network or service disruptions. The overall synchronization quality is quantified using the Overall Digital Twin Entanglement (ODTE) metric, with measured scores of Timeliness = 0.997, Reliability = 1.0, Availability = 1.0, indicating high fidelity and reliable data exchange. These mechanisms collectively constitute the quality assurance process for models and data in the Digital Twin."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed through non‑functional requirements for heterogeneous system integration and by exposing standardized extension points that allow external services to connect to the DT Framework; integration relies on BIM data and generic data‑exchange mechanisms, but no specific protocols (e.g., MQTT, OPC‑UA) or enterprise standards are detailed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is built around BIM, the de‑facto standard modelling paradigm in AECO, and leverages open‑source frameworks such as Eclipse Ditto and Eclipse Hono that implement widely adopted IoT connectivity standards (e.g., MQTT, JSON). The modular architecture defines standardised extension points to assure interoperability, and the automated deployment pipeline enforces a repeatable, standards‑compliant artefact generation process. No explicit certification or external industry standard references are given beyond BIM and the mentioned open‑source IoT standards."
]