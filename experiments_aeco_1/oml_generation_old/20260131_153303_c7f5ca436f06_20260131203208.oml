// C2: Acting Components
instance OccupancyController : DTDFVocab:ActingComponent [
    base:desc "Building control device for occupancy-based lighting and HVAC system activation/deactivation, embedded within the BCS and modeled in BIM to define control logic for bidirectional interaction with the DT"
]

instance HVACController : DTDFVocab:Actuator [
    base:desc "HVAC system controller that receives commands from the DT for adaptive temperature/humidity regulation, integrated with building infrastructure and synchronized via Eclipse Hono"
]

instance LightingController : DTDFVocab:Actuator [
    base:desc "Lighting control system actuator that adjusts lighting levels based on occupancy and environmental conditions, connected to the DT for real-time optimization"
]

instance EnergyMeter : DTDFVocab:Actuator [
    base:desc "Energy consumption meter that records real-time power usage data for building systems, interfaced with the DT for performance analytics"
]

// C3: Physical sensing components
instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy sensor integrated into building infrastructure for real-time energy consumption monitoring, synchronized with DT via Ditto and Eclipse Hono"
    DTDFVocab:producedData EnergyConsumptionData
]

instance EnvironmentalConditionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors measuring CO₂ levels, light intensity, and other environmental parameters for building performance monitoring, connected to DT for real-time analytics"
    DTDFVocab:producedData EnvironmentalParameterData
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detection system providing real-time occupancy data for adaptive building control, interfaced with DT via middleware protocols"
    DTDFVocab:producedData OccupancyData
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in building infrastructure for real-time environmental monitoring, synchronized with DT for HVAC optimization"
    DTDFVocab:producedData TemperatureData
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor measuring indoor air quality parameters, connected to DT for environmental condition monitoring"
    DTDFVocab:producedData HumidityData
]

// C4: Physical-to-virtual interaction
instance EnergyConsumptionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance EnvironmentalParameterData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalConditionSensor
]

instance OccupancyData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance TemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

// C10: Models/Data
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "Static BIM model enriched with device configurations and control logic by Building Control Engineers, containing geometric, spatial, and functional data augmented with runtime metadata"
]

instance RuntimeMetadataModel : DTDFVocab:Model [
    base:desc "Automatically generated metadata model containing sensor placements, control logic definitions, and middleware configurations for DT deployment"
]

instance PerformanceAnalyticsData : DTDFVocab:Data [
    base:desc "Processed real-time data combining energy consumption, environmental conditions, and occupancy patterns for building performance optimization"
    DTDFVocab:fromData EnergyConsumptionData, EnvironmentalParameterData, OccupancyData
]

instance ControlPolicyData : DTDFVocab:Data [
    base:desc "Iteratively refined control strategy data generated from post-occupancy analytics, used for adaptive building management"
    DTDFVocab:fromData PerformanceAnalyticsData
]

// C11: Enablers
instance ModelDrivenEngineeringTool : DTDFVocab:Enabler [
    base:desc "Automates the transformation of BIM models into runtime artifacts (model-to-model/model-to-text mappings) for DT deployment via MDE pipelines"
]

instance EclipseHonoMiddleware : DTDFVocab:Enabler [
    base:desc "Real-time data exchange middleware enabling bidirectional communication between physical sensors/actuators and the DT via low-latency protocols"
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Immersive visualization platform providing interactive DT visualization and simulation capabilities for building performance analysis"
]

instance StandardizedExtensionPoints : DTDFVocab:Enabler [
    base:desc "Modular architecture framework supporting plug-and-play integration of custom services through standardized extension points"
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of building performance metrics (energy consumption, environmental conditions) via Unreal Engine visualization"
    DTDFVocab:enables UnrealEngineVisualization
    DTDFVocab:provides PerformanceAnalyticsInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Energy optimization service using reinforcement learning for adaptive lighting and HVAC control strategies"
    DTDFVocab:enables StandardizedExtensionPoints
    DTDFVocab:provides PredictiveControlInsight
]

instance InteractiveSimulationService : DTDFVocab:Service [
    base:desc "Interactive simulation platform for performance analysis and decision-making support during design and operation phases"
    DTDFVocab:enables UnrealEngineVisualization
    DTDFVocab:provides SimulationInsight
]

instance CustomServiceIntegrationService : DTDFVocab:Service [
    base:desc "Framework for deploying additional plugins or analytics (IoT device management, AI-driven control strategies) via standardized extension points"
    DTDFVocab:enables StandardizedExtensionPoints
    DTDFVocab:provides CustomPluginIntegrationAction
]

// C17: Insights/Actions
instance PerformanceAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Real-time data-driven optimization recommendations based on energy consumption patterns, environmental conditions, and occupancy behavior"
]

instance PredictiveControlInsight : DTDFVocab:Insight [
    base:desc "Iteratively improved control strategy recommendations balancing energy efficiency, visual comfort, and non-visual health effects through reinforcement learning"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Virtual walkthrough and performance simulation results informing design decisions or refurbishment plans"
]

instance CustomPluginIntegrationAction : DTDFVocab:Action [
    base:desc "Deployment of additional IoT device management or AI-driven control strategies through standardized extension points"
    DTDFVocab:IsAutomatic true
]

// C17: Environment/Component
instance BuildingInfrastructureEnvironment : DTDFVocab:Environment [
    base:contains OccupancyDetector, TemperatureSensor, HumiditySensor, LightingController, HVACController
]

instance BIMModelEnvironment : DTDFVocab:Environment [
    base:contains EnergyConsumptionSensor, EnvironmentalConditionSensor, BIMEnrichedModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Virtual-to-physical interaction is enabled via **control signals and commands** generated by DT services, which are transmitted back to the physical building control systems (BCS) through the same middleware stack (Eclipse Hono/Ditto). This allows the DT to dynamically adjust lighting, HVAC settings, or other operational parameters in real-time based on predictive analytics or user inputs, ensuring adaptive building management."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates on a **real-time to near-real-time time scale**, with synchronization rates determined by sensor data acquisition frequencies. For adaptive lighting and energy optimization (BOREALIS), the framework supports **low-latency updates** (e.g., milliseconds to seconds) for control logic adjustments based on live operational data. The overall DT-to-physical synchronization adheres to the **Overall Digital Twin Entanglement (ODTE) metric**, ensuring high fidelity between the virtual and physical domains."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated as a **service-oriented, modular ecosystem** where:
  - **Core DT**: A unified virtual representation of the building, synchronized with physical data via Hono/Ditto.
  - **Subsystem Twins**: Individual DTs for lighting, HVAC, or energy systems, each managed as a service with defined interfaces.
  - **Analytics Services**: External or embedded services (e.g., reinforcement learning for adaptive control) are integrated via standardized extension points.
  - **Visualization Layer**: Unreal Engine provides a 3D immersive interface for monitoring and control, decoupled from the core DT logic."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the following life cycle stages of the physical building:
  1. **Design Phase**: Enriched BIM models are used to define static and dynamic asset representations (e.g., device configurations, control logic).
  2. **Construction Phase**: BIM models are validated and transformed into runtime artifacts (e.g., middleware configurations for Hono/Ditto) to support pre-commissioning and integration of IoT devices.
  3. **Operation Phase**: Real-time synchronization occurs via Ditto and Eclipse Hono, enabling adaptive control, monitoring, and optimization (e.g., energy efficiency, occupant comfort).
  4. **Refurbishment Phase**: DT services facilitate post-occupancy data-driven adjustments (e.g., reinforcement learning-based control policies) to improve performance over time."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
  1. **Overall Digital Twin Entanglement (ODTE) Metric**: Quantifies the alignment between the DT and its physical counterpart, emphasizing real-time synchronization accuracy.
  2. **Runtime Synchronization**: Real-time data exchange via Ditto and Eclipse Hono minimizes latency, reducing semantic drift between virtual and physical states.
  3. **Model Validation**: BIM models are validated before transformation to prevent inconsistencies in device configurations or control logic.
  4. **Uncertainty Handling**: While not explicitly quantified in the documents, the framework assumes that post-occupancy sensor data and control logic are iteratively refined to mitigate drift over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT technical connection relies on:
  1. **Network Protocols**: Middleware (Eclipse Hono/Ditto) uses standardized protocols (e.g., MQTT, WebSockets) for real-time data exchange between physical sensors/actuators and the DT.
  2. **Data Flow**: Sensors → Ditto (data ingestion) → Eclipse Hono (real-time routing) → DT (processing) → Control signals → Actuators.
  3. **Latency**: The system targets **sub-second synchronization** for critical control applications (e.g., adaptive lighting), with scalability ensured by distributed middleware architectures."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted and deployed as follows:
  1. **Runtime Environment**: Middleware (Eclipse Hono/Ditto) runs on edge or cloud infrastructure to support real-time data processing.
  2. **Visualization Layer**: Unreal Engine is deployed as a separate service, providing interactive 3D visualization for monitoring and simulation.
  3. **Modular Deployment**: The framework supports containerized or microservices-based deployment, with standardized extension points enabling seamless integration of new services (e.g., AI analytics)."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration occurs via:
  1. **BIM Interoperability**: BIM models are exchanged with other AECO tools (e.g., Revit, Navisworks) to ensure consistency across design, construction, and operation phases.
  2. **Middleware Extensions**: Eclipse Hono/Ditto support integration with external IoT platforms or enterprise systems (e.g., ERP, CMMS) via standardized APIs.
  3. **Service Orchestration**: Standardized extension points allow DT services to interact with third-party analytics or control systems (e.g., cloud-based AI services)."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership and privacy are addressed as follows:
  1. **Ownership**: Post-occupancy sensor data is owned by the **physical building owner**, while DT-generated analytics may be managed by the DT service provider (e.g., facility management firm).
  2. **Privacy Compliance**: The framework assumes adherence to AECO-specific regulations (e.g., GDPR for occupant data) and supports anonymization of sensitive information in real-time data streams.
  3. **Access Control**: Middleware (Ditto/Hono) enforces role-based access control (e.g., Facility Managers vs. DT Engineers) to restrict unauthorized data exposure."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework adheres to the following standards:
  1. **BIM Standards**: ISO 12006-2 (BIM execution planning), IFC (Industry Foundation Classes) for interoperable BIM data exchange.
  2. **Middleware Standards**: Eclipse Hono and Ditto leverage open protocols (e.g., MQTT, WebSockets) for real-time data exchange.
  3. **AECO-Specific Standards**: Integration with BIM-centric workflows (e.g., TwinLight, BOREALIS) to ensure compatibility with existing AECO tools and practices."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety are ensured through:
  1. **Cybersecurity**: Middleware (Eclipse Hono/Ditto) includes authentication (e.g., OAuth, JWT) and encryption (e.g., TLS) for data in transit.
  2. **Safety Mechanisms**: The DT does not execute remote commands on critical building systems (e.g., HVAC, fire suppression) without explicit authorization from Facility Managers.
  3. **Redundancy**: Real-time synchronization is designed to tolerate minor network failures, ensuring minimal disruption to building operations.
  4. **Audit Trails**: Middleware logs provide traceability for data changes and control actions, supporting compliance with safety and regulatory requirements."
]