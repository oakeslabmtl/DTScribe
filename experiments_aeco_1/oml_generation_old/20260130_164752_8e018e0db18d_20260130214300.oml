// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in the enriched BIM; live readings are ingested via Eclipse Hono and validated by Ditto policies."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor defined in the enriched BIM; measurements are streamed through Eclipse Hono at a one‑second heartbeat."
    DTDFVocab:producedData IlluminationDataTransmitted
]

// C2: Acting components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator (on/off, brightness level, colour‑temperature) linked through UnrealTwinController → DittoController → DittoDevice/Connection."
    DTDFVocab:producedData LightingCommandDataTransmitted
]

// C4: Physical‑to‑virtual interaction (data transmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance LightingCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingActuator
]

// C4: Data artifacts
instance OccupancyData : DTDFVocab:Data [
    base:desc "Validated occupancy measurement (unit: person count) persisted in Ditto’s event store."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Validated illumination level (unit: lux) persisted in Ditto’s event store."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance LightingCommandData : DTDFVocab:Data [
    base:desc "Actuation command containing on/off flag, brightness (0‑100 %), and colour‑temperature (Kelvin)."
    DTDFVocab:fromData LightingCommandDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

// C10: Enablers (tools, platforms, MDE components)
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono ingests sensor telemetry from physical building assets with at‑least‑once delivery."
    DTDFVocab:enables RealTimeSyncService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital twin state, validates policies, and synchronises data with the twin."
    DTDFVocab:enables RealTimeSyncService,
                     MonitoringDashboardService,
                     ControlInterfaceService,
                     AnalyticsOptimizationService
]

instance UnrealTwinController : DTDFVocab:Enabler [
    base:desc "Controller bridging the digital twin to Unreal Engine 5 for immersive 3‑D visualization."
    DTDFVocab:enables InteractiveVisualizationService
]

instance LightTwinComponent : DTDFVocab:Enabler [
    base:desc "Component that consumes Revit photometric values to render accurate lighting in UE5."
    DTDFVocab:enables InteractiveVisualizationService
]

instance ModelDrivenEngineeringEngine : DTDFVocab:Enabler [
    base:desc "MDE workflow that extracts geometric, semantic, and behavioral information from BIM and auto‑generates DT artifacts."
    DTDFVocab:enables ExtensibleCustomService,
                     AnalyticsOptimizationService
]

// C6: Services
instance RealTimeSyncService : DTDFVocab:Service [
    base:desc "Provides continuous bi‑directional synchronization of sensor measurements and actuator commands via Hono/Ditto."
    DTDFVocab:provides FacilityAlertInsight
]

instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Web‑based dashboards for facility managers showing live sensor states and alerts."
    DTDFVocab:provides FacilityAlertInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3‑D visualization of the BIM‑enriched model with live lighting updates."
    DTDFVocab:provides LightingQualityInsight
]

instance ControlInterfaceService : DTDFVocab:Service [
    base:desc "User interface allowing operators to issue lighting commands (on/off, brightness, colour‑temperature)."
    DTDFVocab:provides LightingOnOffAction,
                     SetBrightnessAction,
                     SetColorTemperatureAction
]

instance AnalyticsOptimizationService : DTDFVocab:Service [
    base:desc "Analytics engine delivering predictive maintenance and energy‑efficiency insights."
    DTDFVocab:provides EnergyEfficiencyInsight
]

instance ExtensibleCustomService : DTDFVocab:Service [
    base:desc "Standardized extension point for domain‑specific analytics and decision support."
    DTDFVocab:provides CustomInsight
]

// C17: Insights
instance FacilityAlertInsight : DTDFVocab:Insight [
    base:desc "Real‑time alerts (e.g., out‑of‑range sensor values, actuator failures) shown to facility managers."
]

instance LightingQualityInsight : DTDFVocab:Insight [
    base:desc "Assessment of illumination levels against photometric targets derived from Revit data."
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Trend analysis and recommendations for reducing building energy consumption."
]

instance CustomInsight : DTDFVocab:Insight [
    base:desc "User‑defined insight added via the extensible custom service extension point."
]

// C17: Actions
instance LightingOnOffAction : DTDFVocab:Action [
    base:desc "Command to switch a lighting actuator on or off."
    DTDFVocab:IsAutomatic false
]

instance SetBrightnessAction : DTDFVocab:Action [
    base:desc "Command to set the brightness level (0‑100 %) of a lighting actuator."
    DTDFVocab:IsAutomatic false
]

instance SetColorTemperatureAction : DTDFVocab:Action [
    base:desc "Command to set the colour temperature (Kelvin) of a lighting actuator."
    DTDFVocab:IsAutomatic false
]

// C10: Models/Data (BIM‑derived artifacts)
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "BIM model enriched with device definitions (sensors, actuators, controllers) and control logic."
    DTDFVocab:inputTo ModelDrivenEngineeringEngine
]

instance LightTwinComponentModel : DTDFVocab:Model [
    base:desc "Model containing Revit photometric values used by the LightTwinComponent for accurate UE5 rendering."
    DTDFVocab:inputTo LightTwinComponent
]

instance DeviceDefinitionModel : DTDFVocab:Model [
    base:desc "Structured representation of device metadata extracted from the BIM (semantic and behavioral information)."
    DTDFVocab:inputTo ModelDrivenEngineeringEngine
]

// C11: Enablers (tooling & enablers overview)
instance EclipseBasyxPlatform : DTDFVocab:Enabler [
    base:desc "Open‑source platform providing data management, communication, and service orchestration for the digital twin."
    DTDFVocab:enables RealTimeSyncService,
                     MonitoringDashboardService,
                     InteractiveVisualizationService,
                     ControlInterfaceService,
                     AnalyticsOptimizationService,
                     ExtensibleCustomService
]

// C5: Environment (the physical building)
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, IlluminationSensor, LightingActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control and monitoring commands originate from the digital twin via Eclipse Ditto and are delivered to physical building systems, enabling Facility Managers to interact with the twin for real‑time monitoring and control (Doc 1). The bidirectional communication supported by Ditto allows the twin to issue control messages, but the documents do not detail command formats, validation, authentication, feedback mechanisms, or execution confirmation procedures."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides continuous real‑time data exchange that keeps the physical building and its digital counterpart synchronized; synchronization is described as real‑time with no explicit period or latency values, implying a need for low latency but the exact granularity is not detailed in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT system follows a modular, hub‑and‑spoke architecture where a central DT Framework acts as a hub enabling bidirectional data exchange between devices, BIM models and custom services. Standardized extension points allow plug‑in of analytics or services, and runtime configuration management permits on‑the‑fly adaptation without redeployment. Coordination is achieved through the framework’s central hub which orchestrates device models, control logic and visualization."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports the full Digital Twin life‑cycle, starting with device modeling within enriched BIM models where sensors, actuators and controllers are defined (functional requirement F_X). Model‑Driven Engineering (MDE) extracts structured representations from these BIM models and automatically generates deployable DT artifacts (code, configuration). An automated deployment process (R2) reduces manual steps and ensures reproducible set‑up. At runtime the twin operates with continuous real‑time data exchange (R3) using Eclipse Hono for ingestion and Eclipse Ditto for state synchronization, providing live bidirectional sync between physical assets and the digital copy. The modular architecture with standardized extension points (R4) allows the integration of custom analytics services and supports iterative evolution of the twin post‑deployment. Governance is implicit in the minimal‑manual, reproducible pipeline and the defined extension points that enforce consistent integration practices."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assured through a three‑stage deployment pipeline: model checking (5.53 s), model parsing (8.7 s) and rapid initialization (0.3 s). Eclipse Ditto enforces policy‑based validation of sensor values and actuator commands, providing error detection and automatic rejection of out‑of‑range data. Fault tolerance is achieved by Hono’s at‑least‑once delivery and Ditto’s persistent event storage, guaranteeing that no updates are lost. The overall synchronization quality is quantified with the Overall Digital Twin Entanglement (ODTE) metric, which combines timeliness (0.997), reliability (1.0) and availability (1.0) measured over a 12‑minute window using a 1 s heartbeat. These mechanisms constitute the validation and quality‑assurance process for the DT models and data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical networking layer comprises Eclipse Hono for device data ingestion and Eclipse Ditto for digital twin services, embedded within a modular architecture with standardized extension points that promotes interoperability across heterogeneous systems (Doc 1, Doc 3). While the framework emphasizes scalability, maintainability, and low‑overhead updates (NF_X), the documents do not provide explicit specifications on network topology, bandwidth, latency, redundancy, or security protocols."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed through standardized extension points that allow integration with heterogeneous systems such as BIM tools, sensor networks and external analytics platforms. The framework emphasizes compliance with interoperability requirements (NF_X) and supports data exchange with external systems, although specific protocols or standards are not enumerated in the documents."
]