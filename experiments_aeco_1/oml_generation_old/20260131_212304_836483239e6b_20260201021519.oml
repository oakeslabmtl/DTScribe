// C2: Acting Components
instance SmartLightingActuator : DTDFVocab:ActingComponent [
    base:desc "Motorized lighting system embedded in Building Control Systems (BCS) that receives control signals from the Digital Twin to adjust lighting levels based on occupancy and environmental conditions. Semantically linked to BIM geometry for precise spatial control."
]

instance HVACController : DTDFVocab:ActingComponent [
    base:desc "Building Control System component responsible for regulating HVAC systems based on real-time data from sensors and control logic embedded in the Digital Twin. Enables dynamic adjustments to temperature, humidity, and airflow."
]

instance MotorizedShadeActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator system for motorized window shades that adjusts based on solar radiation data and occupant comfort preferences, synchronized with the Digital Twin's environmental modeling."
]

// C3: Physical Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy sensor deployed within operational buildings that detects human presence via infrared or ultrasonic technology. Feeds real-time occupancy data to the Digital Twin via Eclipse Hono."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental temperature sensor integrated into the building's BCS that measures real-time thermal conditions. Data is transmitted to the Digital Twin through Ditto middleware for analysis."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor that monitors moisture levels in building environments. Data is automatically ingested into the Digital Twin via standardized Hono/Ditto protocols for environmental control optimization."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient light sensor that measures illuminance levels for visual comfort analysis. Data is synchronized with the Digital Twin to inform adaptive lighting control policies."
    DTDFVocab:producedData LightLevelDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

// C10: Models/Data
instance BIMCoreModel : DTDFVocab:Model [
    base:desc "Static 3D Building Information Model serving as the semantic foundation for the Digital Twin, containing geometry, topology, and component relationships. Enriched with runtime semantics for device configurations."
    DTDFVocab:inputTo HonoConfigurator, DittoDeviceManager
]

instance RuntimeDataModel : DTDFVocab:Model [
    base:desc "Dynamic representation of operational data including sensor readings, control states, and environmental parameters extracted from physical systems via Hono/Ditto middleware."
    DTDFVocab:inputTo UnrealEngineVisualizer
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Domain-specific semantics embedded within BIM defining lighting schedules, occupancy-based adjustments, and control policies. Transformed into executable artifacts during deployment."
    DTDFVocab:inputTo MDETransformationEngine
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy patterns extracted from physical sensors and synchronized with the Digital Twin for space utilization analysis and control logic execution."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo OccupancyAnalyticsService
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Aggregated environmental parameters including temperature, humidity, and light levels processed by the Digital Twin for comfort and energy optimization."
    DTDFVocab:fromData TemperatureDataTransmitted, HumidityDataTransmitted, LightLevelDataTransmitted
    DTDFVocab:inputTo EnvironmentalOptimizationService
]

// C11: Enablers
instance HonoConfigurator : DTDFVocab:Enabler [
    base:desc "Middleware component that scans BIM models for 'twinnable' devices and generates runtime interfaces (e.g., Ditto tenants) via Model-Driven Engineering transformations. Automates device configuration for bidirectional communication."
]

instance DittoDeviceManager : DTDFVocab:Enabler [
    base:desc "Device twin management platform that maintains bidirectional communication channels between physical sensors/actuators and the Digital Twin. Handles device metadata and state synchronization."
]

instance UnrealEngineVisualizer : DTDFVocab:Enabler [
    base:desc "Immersive 3D visualization platform enabling real-time interaction with building data through Unreal Engine 5. Provides facility managers with spatial-temporal insights for decision-making."
]

instance MDETransformationEngine : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering engine that performs model-to-model and model-to-text transformations to generate runtime artifacts from BIM models, reducing manual configuration efforts."
    DTDFVocab:enables ControlLogicExecutionService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing live visualization of building operations through Unreal Engine 5, enabling facility managers to monitor environmental conditions and system performance in real-time."
    DTDFVocab:provides EnvironmentalDashboardInsight, OccupancyVisualizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service offering energy consumption forecasting, equipment failure prediction, and occupancy pattern analysis using historical and real-time data."
    DTDFVocab:provides EnergyConsumptionForecastInsight, MaintenanceRecommendationAction
]

instance OccupancyAnalyticsService : DTDFVocab:Service [
    base:desc "Service analyzing occupancy data to optimize space utilization, lighting schedules, and HVAC operations based on post-occupancy patterns."
    DTDFVocab:provides SpaceUtilizationInsight, ComfortOptimizationAction
]

instance EnvironmentalOptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing environmental parameters (temperature, humidity, lighting) to balance occupant comfort with energy efficiency using real-time sensor data."
    DTDFVocab:provides ComfortScoreInsight, EnergySavingsRecommendationAction
]

instance ControlLogicExecutionService : DTDFVocab:Service [
    base:desc "Service executing embedded control logic (e.g., lighting schedules, occupancy-based adjustments) by translating BIM models into executable control policies for physical actuators."
    DTDFVocab:provides ActuatorControlAction
]

// C17: Insights/Actions
instance EnvironmentalDashboardInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of environmental conditions (temperature, humidity, light levels) displayed through Unreal Engine 5 for facility managers."
]

instance OccupancyVisualizationInsight : DTDFVocab:Insight [
    base:desc "Spatial representation of occupancy patterns within the building, enabling analysis of space utilization and movement trends."
]

instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Predictive analysis of energy consumption patterns based on historical data and current operational conditions, informing proactive energy management."
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Automated suggestions for preventive maintenance based on equipment health monitoring and failure prediction models."
    DTDFVocab:IsAutomatic true
]

instance SpaceUtilizationInsight : DTDFVocab:Insight [
    base:desc "Analysis of how building spaces are utilized over time, identifying underutilized or overcrowded areas for optimization."
]

instance ComfortOptimizationAction : DTDFVocab:Action [
    base:desc "Automated adjustments to environmental controls (lighting, HVAC) to enhance occupant comfort based on real-time sensor data."
    DTDFVocab:IsAutomatic true
]

instance ComfortScoreInsight : DTDFVocab:Insight [
    base:desc "Quantitative assessment of occupant comfort derived from environmental parameters and occupancy patterns, displayed as a KPI dashboard."
]

instance EnergySavingsRecommendationAction : DTDFVocab:Action [
    base:desc "Suggestions for adjusting control policies to reduce energy consumption while maintaining acceptable comfort levels."
    DTDFVocab:IsAutomatic false
]

instance ActuatorControlAction : DTDFVocab:Action [
    base:desc "Execution of control commands to physical actuators (e.g., lighting, HVAC) based on processed Digital Twin data and embedded logic."
    DTDFVocab:IsAutomatic true
]

// C1: Architecture Components
instance CentralizedMiddleware : DTDFVocab:Component [
    base:desc "Centralized architecture component hosting core services like visualization, data processing, and control logic coordination. Manages interoperability between decentralized service instances."
]

instance DecentralizedServiceInstance : DTDFVocab:Component [
    base:desc "Modular service component deployed in a decentralized manner to handle specific functions like analytics plugins or domain-specific control logic. Supports scalable deployment across building zones."
]

instance ODTEEvaluator : DTDFVocab:Component [
    base:desc "Component implementing the Overall Digital Twin Entanglement metric to assess interoperability and coherence across distributed DT components, ensuring consistency in data flows."
]

instance BIMRuntimeBridge : DTDFVocab:Component [
    base:desc "Interface component that synchronizes static BIM models with dynamic runtime data, enabling bidirectional synchronization between virtual and physical systems."
]

// C16: Environments
instance BuildingInfrastructureEnvironment : DTDFVocab:Environment [
    base:desc "Physical and virtual environment encompassing the entire building infrastructure including BCS, sensors, actuators, and the Digital Twin system."
    base:contains CentralizedMiddleware, DecentralizedServiceInstance, BIMCoreModel, RuntimeDataModel, HonoConfigurator, DittoDeviceManager, UnrealEngineVisualizer, MDETransformationEngine, ControlLogicExecutionService, PredictiveAnalyticsService, OccupancyAnalyticsService, EnvironmentalOptimizationService
]

instance ControlZoneEnvironment : DTDFVocab:Environment [
    base:desc "Logical environment representing a specific building zone (e.g., lighting system, HVAC system) with its associated sensors, actuators, and control logic."
    base:contains OccupancySensor, TemperatureSensor, SmartLightingActuator, HVACController, MotorizedShadeActuator, LightLevelSensor, OccupancyData, EnvironmentalData, ControlLogicModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Virtual-to-physical interaction occurs through **control signals** generated by the DT and transmitted back to the physical system via actuators and controllers. The framework leverages Ditto’s **bidirectional communication capabilities** to send commands (e.g., adjust lighting levels, trigger HVAC adjustments) to physical devices. This interaction is **runtime-configurable**, allowing Facility Managers to modify operational parameters (e.g., energy optimization policies) directly through the DT interface. The BOREALIS project demonstrates this by using **reinforcement learning models** embedded in the DT to dynamically adjust lighting controls based on real-time sensor data, closing the loop between virtual and physical systems."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twinning time scale is primarily **real-time**, with synchronization occurring at **millisecond to second intervals** for critical operational data (e.g., sensor readings, control signals). The DT framework supports **iterative optimization** over longer time scales (e.g., hourly, daily, or weekly) through **reinforcement learning** (as demonstrated in the BOREALIS project), where control policies are refined based on post-occupancy data. This dual-time-scale approach ensures both immediate responsiveness and long-term adaptability."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated as a **service-oriented, modular architecture** with the following components:
   - **BIM Backbone**: Central repository for static and enriched models.
   - **Middleware Layer (Hono/Ditto)**: Handles data ingestion, device management, and bidirectional communication.
   - **Control Logic Layer**: Executes embedded policies (e.g., lighting schedules) and adapts based on runtime data.
   - **Visualization Layer (Unreal Engine)**: Provides immersive interfaces for monitoring and control.
   - **Extension Points**: Standardized interfaces for integrating custom services (e.g., AI plugins, predictive maintenance tools) developed by DT Engineers. The constellation is designed for **scalability**, allowing incremental deployment of services and components across building systems."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans **multiple life-cycle stages**, from **design (as-designed)** to **construction (as-manufactured)** and **operation (as-operated)**. During the **design phase**, BIM models are enriched with **runtime semantics** (e.g., sensor configurations, control logic) to prepare for DT deployment. In the **construction phase**, the framework automates the integration of physical devices (e.g., sensors, actuators) into the DT via middleware configuration. During **operation**, the DT enables **continuous monitoring, optimization, and adaptive evolution** of building systems. The framework also supports **post-occupancy adjustments**, such as those demonstrated in BOREALIS, where control policies are refined over time using operational data."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
   - **Overall Digital Twin Entanglement (ODTE) Metric**: Quantifies the **alignment between the DT and its physical twin (PT)**, evaluating data consistency, synchronization accuracy, and operational coherence.
   - **Model Validation**: BIM models undergo **formal validation** to detect inconsistencies (e.g., missing device metadata) before deployment.
   - **Runtime Monitoring**: The DT tracks **data drift** (e.g., semantic drift in sensor readings) and **control performance** to maintain fidelity. The BOREALIS project addresses validity by using **reinforcement learning** to iteratively improve control policies, reducing gaps between design and operational performance. Uncertainty and errors are mitigated via **real-time error correction mechanisms** embedded in the control logic layer."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT employs **Eclipse Hono and Ditto** as middleware for **real-time data exchange**, facilitating bidirectional communication between physical devices and the virtual twin. The framework extracts **metadata** (e.g., tenant IDs, device IDs, endpoint addresses) from the BIM model to configure these connections. While specific protocols (e.g., MQTT, CoAP, HTTP/REST) are implied by the middleware’s capabilities, the documents do not explicitly detail the exact protocols used beyond the mention of **tenant isolation** for secure data handling."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed in a **scalable, modular architecture** with **cloud-native services** to support distributed components. The framework emphasizes **low-overhead updates** and **maintainability**, enabling incremental deployment of new services and configurations. While the documents do not specify high-performance servers or exact cloud infrastructure, the focus is on **scalability** and **interoperability** across heterogeneous systems."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT supports **horizontal integration** through:
   - **Standardized extension points**: Allowing seamless integration with external systems (e.g., **ERP, CMMS**) via modular services.
   - **Interoperability frameworks**: Enabling communication with heterogeneous platforms (e.g., IoT devices, legacy BCS) through middleware (Eclipse Hono/Ditto).
   - **Modular architecture**: Facilitating the addition of new services (e.g., analytics, visualization) without disrupting core functionality. The framework ensures **scalable interoperability** across the AECO domain."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT adheres to the following standards:
   - **Building Information Modeling (BIM)**: As the foundational modeling paradigm for AECO infrastructure.
   - **Model-Driven Engineering (MDE)**: For automating the extraction of domain semantics and generation of runtime artifacts.
   The documents do not reference specific standards like **OMA LWM2M, QVT, or MOF**, but emphasize **BIM and MDE** as core methodologies for standardization."
]