// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled as a semantic object within the enriched BIM model, providing real-time temperature measurements."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled as a semantic object within the enriched BIM model, delivering real-time occupancy counts."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor modeled as a semantic object within the enriched BIM model, supplying real-time humidity levels."
    DTDFVocab:producedData HumidityDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

// C10: Data objects
instance TemperatureData : DTDFVocab:Data [
    base:desc "Timestamped temperature measurement stream used for monitoring and analysis."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DataIngestionLayer
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Timestamped occupancy measurement stream used for space utilization monitoring."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo DataIngestionLayer
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Timestamped humidity measurement stream used for indoor air quality monitoring."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo DataIngestionLayer
]

// C11: Enablers
instance DataIngestionLayer : DTDFVocab:Enabler [
    base:desc "Data ingestion layer that aggregates real‑time sensor streams, timestamps them and makes them available for visualization and control logic."
    DTDFVocab:enables RealTimeMonitoringService, SimulationAnalysisService, PredictiveAnalyticsService, OptimizationService, VisualizationDashboardService
]

instance ModelTransformationEngine : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering engine that transforms enriched BIM geometry, device definitions and control logic into executable Digital Twin components."
    DTDFVocab:enables RealTimeMonitoringService, SimulationAnalysisService, PredictiveAnalyticsService, OptimizationService, VisualizationDashboardService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of building state by integrating static BIM models with runtime sensor data."
    DTDFVocab:provides BuildingStateInsight
]

instance SimulationAnalysisService : DTDFVocab:Service [
    base:desc "Performs simulation‑based analysis using behavioral and analytical models for performance evaluation."
    DTDFVocab:provides SimulationResultInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Runs predictive analytics to forecast future building performance and energy consumption."
    DTDFVocab:provides PerformanceForecastInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Executes optimization routines for energy and operational efficiency."
    DTDFVocab:provides EnergyOptimizationAction
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Delivers visualization dashboards supporting decision‑making for designers, operators and facility managers."
    DTDFVocab:provides VisualizationInsight
]

// C17: Insights / Actions
instance BuildingStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current building conditions derived from fused BIM geometry and live sensor data."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight from simulation runs indicating potential performance issues and validating design decisions."
]

instance PerformanceForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of future building performance and energy usage generated by predictive models."
]

instance EnergyOptimizationAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of actuator set‑points and schedules to achieve optimized energy consumption."
    DTDFVocab:IsAutomatic true
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive visualizations of building state, sensor trends and optimization outcomes."
]

// C10: Models/Data
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Geometric model representing the building structure extracted from the BIM environment."
    DTDFVocab:inputTo ModelTransformationEngine
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model encoding the control logic defined by building control engineers."
    DTDFVocab:inputTo ModelTransformationEngine
]

instance PerformanceAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model derived for performance evaluation of the building's energy behavior."
    DTDFVocab:inputTo ModelTransformationEngine
]

// C2: Acting components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator modeled in BIM, supporting on‑off and set‑point adjustments via the Digital Twin."
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in BIM, providing on‑off commands and scheduling through the twin."
]

instance BuildingController : DTDFVocab:ActingComponent [
    base:desc "Controller unit defined in the BIM model that integrates sensor inputs and executes control logic within the Digital Twin."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Through the same bidirectional data exchange, the digital twin can issue control commands to the physical building for monitoring and control. Facility managers interact with the deployed DT to send commands that affect physical devices. The document does not detail command formats, validation, authentication, feedback loops, conflict resolution or execution confirmation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a lifecycle comprising (1) device modeling within BIM where sensors, actuators, and controllers are added; (2) model enrichment and extraction using model‑driven engineering (MDE) to produce structured representations; (3) automatic generation of deployable DT artifacts; (4) deployment of the twin and establishment of real‑time data exchange for continuous synchronization; (5) runtime operation with interactive visualization; and (6) post‑deployment extension via standardized extension points for custom services. Transition between phases is managed automatically by the MDE pipeline, and lifecycle governance is assigned to the three actor roles—Building Control Engineer (modeling and control‑logic definition), Facility Manager (monitoring and operation), and DT Engineer (service integration)."
]