// C3: Physical sensing components
instance BuildingAutomationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor definitions embedded in enriched BIM artifacts by building control engineers for building automation."
    DTDFVocab:producedData BuildingSensorDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmission)
instance BuildingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingAutomationSensor
]

// C10: Data
instance BuildingRealTimeSensorData : DTDFVocab:Data [
    base:desc "Real‑time data streams from building automation sensors, streamed into the Digital Twin via the central DT Framework hub."
    DTDFVocab:fromData BuildingSensorDataTransmitted
    DTDFVocab:inputTo DTFrameworkHub
]

// C10: Models/Data - Enriched BIM model
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched Building Information Modeling (BIM) artifacts containing geometric entities plus a unified semantic layer with sensor, actuator, and controller definitions."
    DTDFVocab:inputTo DTFrameworkHub
]

// C10: Models/Data - Control logic component
instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral control‑logic component extracted from the enriched BIM model linking geometric entities to control actions."
    DTDFVocab:inputTo ModelTransformationEnabler
]

// C10: Models/Data - Device analytical component
instance DeviceAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical device component extracted from the enriched BIM model providing device‑behavior semantics."
    DTDFVocab:inputTo ModelTransformationEnabler
]

// C11: Enablers - Central DT hub
instance DTFrameworkHub : DTDFVocab:Enabler [
    base:desc "Central DT Framework hub that transforms enriched BIM models and streams sensor data into deployable Digital Twin artifacts, enabling bidirectional communication."
    DTDFVocab:enables RealTimeSyncService
]

// C11: Enablers - Model‑driven transformation engine
instance ModelTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Engine that automates the transformation of enriched BIM models into executable Digital Twin components via model‑driven engineering."
    DTDFVocab:enables ModelGenerationService
]

// C6: Services - Real‑time synchronization
instance RealTimeSyncService : DTDFVocab:Service [
    base:desc "Implements real‑time data exchange, continuously synchronizing physical building sensor/device data with the Digital Twin."
    DTDFVocab:provides TwinSynchronizationInsight, HVACControlAction
]

// C6: Services - Model generation
instance ModelGenerationService : DTDFVocab:Service [
    base:desc "Automatically generates deployable Digital Twin artifacts from enriched BIM models."
    DTDFVocab:provides ModelGenerationInsight
]

// C17: Insights
instance TwinSynchronizationInsight : DTDFVocab:Insight [
    base:desc "Insight into the current synchronized state of the physical building and its Digital Twin."
]

instance ModelGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight that Digital Twin artifacts have been successfully generated from enriched BIM models."
]

// C17: Actions
instance HVACControlAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust the HVAC system based on twin analysis and embedded control logic."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Facility Managers interact with the deployed Digital Twin for real‑time monitoring and control, allowing the DT to issue commands that affect physical building systems. The DT therefore supports control flows from the virtual model back to physical actuators and devices. No details are given regarding command types, message formats, validation/authentication, feedback loops, conflict resolution, or execution confirmation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The model‑driven DT framework defines four lifecycle phases: (1) **Device Modeling** – building control engineers enrich BIM models with semantic definitions of sensors, actuators and controllers; (2) **Model Transformation & Artifact Generation** – Model‑Driven Engineering (MDE) extracts structured representations from the enriched BIM and automatically produces deployable DT artifacts (e.g., service descriptors, configuration files); (3) **Deployment & Runtime Operation** – the generated artifacts are instantiated, establishing real‑time data exchange that continuously synchronises the physical building system with its digital twin; (4) **Post‑Deployment Evolution** – a modular architecture with standardized extension points enables DT engineers to add custom services, analytics or plug‑ins, allowing the twin to evolve without redeploying the whole system. Transitions between phases are managed automatically by the MDE pipeline, and lifecycle governance is expressed through the role‑based responsibilities defined in Table I (Building Control Engineer, Facility Manager, DT Engineer)."
]