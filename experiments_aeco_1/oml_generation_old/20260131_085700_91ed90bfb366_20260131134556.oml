// C2: Acting Components
instance DimmableLEDFixture : DTDFVocab:ActingComponent [
    base:desc "Dimmable LED lighting fixture controllable via MQTT commands"
]

instance HVACValve : DTDFVocab:ActingComponent [
    base:desc "Valve actuator for HVAC airflow regulation, exposing setpoint via MQTT"
]

instance BlindsController : DTDFVocab:ActingComponent [
    base:desc "Motorized blinds actuator controlled through MQTT for daylight modulation"
]

// C3: Physical sensing components
instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Passive infrared occupancy sensor embedded in the building, sending occupancy status via MQTT"
    DTDFVocab:producedData HonoOccupancyData
]

instance AmbientLightSensor : DTDFVocab:SensingComponent [
    base:desc "Digital ambient light sensor measuring lux levels, streaming telemetry via MQTT"
    DTDFVocab:producedData HonoLightLevelData
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring room air temperature, publishing data over MQTT"
    DTDFVocab:producedData HonoTemperatureData
]

// C4: Physical-to-virtual interaction
instance HonoOccupancyData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance HonoLightLevelData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientLightSensor
]

instance HonoTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C10: Models/Data
instance BIM3DModel : DTDFVocab:Model [
    base:desc "3D BIM model enriched with sensor and actuator metadata, runtime telemetry, and embedded control logic"
    DTDFVocab:inputTo DittoEnabler
]

// C10 Data instances
instance OccupancyTelemetry : DTDFVocab:Data [
    base:desc "Telemetry stream of occupancy status captured by the occupancy detector"
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
    DTDFVocab:fromData HonoOccupancyData
]

instance LightLevelTelemetry : DTDFVocab:Data [
    base:desc "Telemetry stream of ambient light levels measured by the light sensor"
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
    DTDFVocab:fromData HonoLightLevelData
]

instance TemperatureTelemetry : DTDFVocab:Data [
    base:desc "Telemetry stream of air temperature posted by the temperature sensor"
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
    DTDFVocab:fromData HonoTemperatureData
]

// C11: Enablers
instance HonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT broker facilitating real‑time telemetry flow from physical devices to the twin"
    DTDFVocab:enables RealTimeMonitoringService, UnrealVisualizationService, PredictiveEnergyAnalyticsService, RLLightingOptimizationService, BuildingPerformanceSimulationService
]

instance DittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin store managing digital representation of building components and enabling control commands"
    DTDFVocab:enables RealTimeMonitoringService, UnrealVisualizationService, PredictiveEnergyAnalyticsService, RLLightingOptimizationService, BuildingPerformanceSimulationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‐time dashboards displaying occupancy, lighting, temperature, and airflow telemetry"
    DTDFVocab:provides OccupancyComfortInsight, EnergySavingsInsight
]

instance UnrealVisualizationService : DTDFVocab:Service [
    base:desc "3D immersive visualization of the building in Unreal Engine 5, showing sensor data and actuator states"
    DTDFVocab:provides OccupancyComfortInsight
]

instance PredictiveEnergyAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics engine computing future energy consumption based on historical telemetry"
    DTDFVocab:provides EnergySavingsInsight
]

instance RLLightingOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning agent optimizing lighting schedules to balance comfort and energy savings"
    DTDFVocab:provides LightingScheduleRecommendationAction
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation service modeling building performance under various control policies"
    DTDFVocab:provides EnergySavingsInsight, OccupancyComfortInsight
]

// C17: Insights & Actions
instance EnergySavingsInsight : DTDFVocab:Insight [
    base:desc "Insight on projected energy savings from optimized lighting and HVAC operations"
]

instance OccupancyComfortInsight : DTDFVocab:Insight [
    base:desc "Insight indicating current comfort levels based on occupancy, temperature, and lighting telemetry"
]

instance LightingScheduleRecommendationAction : DTDFVocab:Action [
    base:desc "Recommended lighting schedule generated by reinforcement‑learning agent"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control messages generated by the twin (e.g., light dimming, HVAC set‑point adjustments) are transmitted via Ditto to Eclipse Hono and delivered to the physical actuators"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (continuous) synchronization; sensor data is streamed and commands are transmitted with round‑trip latency in the order of seconds or less, maintaining live alignment between physical and virtual models."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "BIM model → Ditto twin registry → Hono MQTT broker → physical devices and sensors; complemented by visualization in Unreal and RL optimisation services"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "All major lifecycle phases: design (BIM creation), construction (device modelling), commissioning (middleware configuration), and operation (runtime monitoring and optimisation)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Evaluation of twin fidelity using the Overall Digital Twin Entanglement (ODTE) metric; management of semantic drift through bi‑directional synchronization and adherence to BIM semantics"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with building automation middleware (Eclipse Hono), external analytics pipelines (reinforcement‑learning modules), and potentially other DTs via Ditto’s messaging fabric"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Built upon the BIM semantic ecosystem; the framework adheres to industry‑level integration practices but does not specify additional external standards such as IFC or MQTT."
]