// C3: Physical sensing components
instance BuildingSensorTwin : DTDFVocab:SensingComponent [
    base:desc "Sensing elements are defined as part of the enriched BIM model and instantiated as digital twins that publish their measurements through Eclipse Hono."
    DTDFVocab:producedData SensorTelemetryStream
]

// C2: Acting components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture twin supporting on/off switching, dimming (brightness) and colour‑temperature (kelvin) adjustments, exposed as controllable device."
]

// C4: Data transmitted from sensors
instance SensorTelemetryStream : DTDFVocab:DataTransmitted [
    base:desc "Telemetry stream produced by BuildingSensorTwin, ingested by Eclipse Hono with at‑least‑once delivery semantics."
    DTDFVocab:producedFrom BuildingSensorTwin
]

// C10: Data derived from transmitted telemetry
instance SensorTelemetryData : DTDFVocab:Data [
    base:desc "Live sensor telemetry stored persistently in Eclipse Ditto after policy‑based validation."
    DTDFVocab:fromData SensorTelemetryStream
    DTDFVocab:inputTo ModelDrivenDeploymentEnabler
]

// C10: Models / Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Primary geometric/semantic model of the building enriched with sensor, actuator and controller definitions."
    DTDFVocab:inputTo ModelDrivenDeploymentEnabler
]

instance TwinComponentMappingModel : DTDFVocab:Model [
    base:desc "Behavioural model mapping device metadata (e.g., photometric values) to Unreal Engine 5 visual entities via TwinComponents."
    DTDFVocab:inputTo ModelDrivenDeploymentEnabler
]

instance ThingDescriptionModel : DTDFVocab:Model [
    base:desc "Generated JSON‑LD/Thing Description artifacts extracted from the enriched BIM for consumption by middleware."
    DTDFVocab:inputTo ModelDrivenDeploymentEnabler
]

// C11: Enablers
instance HonoIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono stack providing at‑least‑once MQTT/HTTP ingestion of sensor streams."
    DTDFVocab:enables RealTimeMonitoringService, DataSyncService
]

instance DittoPolicyEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto policy engine for persistent storage, validation of telemetry and command payloads."
    DTDFVocab:enables DeviceControlService, ExtensibleAnalyticsService
]

instance UnrealVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 integration enabling interactive 3‑D visualization of twin entities."
    DTDFVocab:enables VisualizationService
]

instance ModelDrivenDeploymentEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven deployment framework that extracts enriched BIM entities and generates deployable DT artifacts."
    DTDFVocab:enables RealTimeMonitoringService, DeviceControlService, DataSyncService,
               VisualizationService, ExtensibleAnalyticsService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of system states using live sensor telemetry."
    DTDFVocab:provides SystemStateInsight
]

instance DeviceControlService : DTDFVocab:Service [
    base:desc "Enables bidirectional control of physical actuators (e.g., lights) via Ditto policies and commands."
    DTDFVocab:provides DeviceControlAction
]

instance DataSyncService : DTDFVocab:Service [
    base:desc "Ensures continuous bidirectional synchronization between the physical building and its digital twin."
    DTDFVocab:provides SynchronizationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides interactive 3‑D visualization in UE5, allowing operators to view and interact with twin entities."
    DTDFVocab:provides VisualizationInsight
]

instance ExtensibleAnalyticsService : DTDFVocab:Service [
    base:desc "Platform for DT engineers to add custom analytics and services through standardized extension points."
    DTDFVocab:provides CustomAnalyticsInsight
]

// C17: Insights
instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Operational insight for facility managers to monitor system states and support decision making."
]

instance SynchronizationInsight : DTDFVocab:Insight [
    base:desc "Insight into the real‑time synchronization status between physical and virtual assets."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from interactive 3‑D visualizations, enhancing situational awareness."
]

instance CustomAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Insight generated by custom analytics extensions added by DT engineers."
]

// C17: Actions
instance DeviceControlAction : DTDFVocab:Action [
    base:desc "Action to issue on/off, dimming, or colour‑temperature commands to actuators such as LightTwinComponent."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Interactive visualisation interfaces allow Facility Managers to monitor and issue control commands to physical building assets through the digital twin. Real‑time monitoring and control are supported, but the documents do not describe command formats, validation/authentication mechanisms, feedback loops, conflict resolution, or execution confirmations."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange capabilities provide continuous synchronization between the physical building and its digital twin; the framework operates in a real‑time mode, but the documents do not specify exact synchronization frequencies, latency bounds, or temporal granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, service‑oriented constellation where the DT Framework acts as a central hub orchestrating bidirectional data exchange, integrating custom analytics services via standardized extension points, and allowing runtime re‑configuration without full redeployment."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Supports the complete DT lifecycle from initial device modeling within BIM (defining sensors, actuators, controllers), model extraction via model‑driven engineering (MDE), automatic generation of deployable DT artifacts, deployment, runtime operation with continuous real‑time data exchange, interactive visualization for monitoring/control, and modular extension through standardized plug‑in points, all governed by the model‑driven deployment framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and data quality are maintained by a multi‑layer validation pipeline. During the conversion stage, the framework validates enriched BIM models against schema constraints. Eclipse Ditto enforces policy‑based validation on both incoming sensor streams (checking ranges, units) and outgoing actuator commands (pre‑execution safety checks). Fault tolerance is achieved through Eclipse Hono’s at‑least‑once message delivery and Ditto’s persistent event storage, which together guarantee synchronization despite network interruptions. The use of the Observable pattern in the UnrealTwinController and FeatureParserControllers facilitates runtime error detection and corrective propagation. These mechanisms collectively provide verification, uncertainty mitigation and quality assurance for the DT’s geometric, behavioural and analytical models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The solution adopts a modular architecture with standardized extension points to achieve interoperability across heterogeneous systems and supports scalability from component level to whole‑infrastructure level. Specific network protocols, topology, bandwidth, latency, redundancy, or security details are not disclosed in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability across heterogeneous systems is addressed through standardized extension points that enable integration of external services and enterprise systems, supporting scalability and low‑overhead updates; specific data‑exchange protocols or standards are not detailed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The documents note that many AECO DT solutions lack standardized data schemas and rely on generic IoT standards; existing open‑source frameworks such as Eclipse Ditto and BaSyx provide standard‑compliant connectivity, while Bentley’s iTwin.js uses proprietary APIs. The proposed framework aims to bridge BIM with DT but does not specify adherence to particular industry standards, certifications, or interoperability specifications."
]