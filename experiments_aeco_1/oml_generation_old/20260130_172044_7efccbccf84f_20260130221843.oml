// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Physical temperature sensor modelled in BIM, streams temperature measurements to the twin."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Physical illumination sensor modelled in BIM, streams light level measurements to the twin."
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Physical CO₂ sensor modelled in BIM, streams indoor CO₂ concentration to the twin."
    DTDFVocab:producedData CO2DataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Physical occupancy sensor modelled in BIM, streams occupancy status to the twin."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Streamed temperature data from the physical temperature sensor."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseDitto, UnrealEngine5, SimulationEngine, RLAgentEngine
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Streamed illumination data from the physical illumination sensor."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseDitto, UnrealEngine5, SimulationEngine, RLAgentEngine
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Streamed CO₂ concentration data from the physical CO₂ sensor."
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseDitto, UnrealEngine5, SimulationEngine, RLAgentEngine
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Streamed occupancy status data from the physical occupancy sensor."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDitto, UnrealEngine5, SimulationEngine, RLAgentEngine
]

// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modelled in BIM, receives control commands from the twin."
]

instance HVACController : DTDFVocab:ActingComponent [
    base:desc "HVAC controller modelled in BIM, receives set‑point commands from the twin."
]

instance BCSActuator : DTDFVocab:ActingComponent [
    base:desc "General building control system actuator modelled in BIM."
]

// C11: Enablers (Tooling & Enablers)
instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages twin state and provides real‑time monitoring, optimization and RL control services."
    DTDFVocab:enables RealTimeMonitoring, EnergyUsageOptimization, RLBasedLightingControl
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders interactive 3‑D visualization of the building twin."
    DTDFVocab:enables InteractiveVisualization
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine executes building performance simulations."
    DTDFVocab:enables Simulation
]

instance RLAgentEngine : DTDFVocab:Enabler [
    base:desc "Reinforcement‑learning engine implements adaptive lighting control policies."
    DTDFVocab:enables RLBasedLightingControl
]

instance ServiceIntegrationPlatform : DTDFVocab:Enabler [
    base:desc "Modular service integration platform enabling additional twin services."
    DTDFVocab:enables ModularServiceIntegration
]

// C6: Services
instance RealTimeMonitoring : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of sensor streams and building status."
    DTDFVocab:provides EnergyConsumptionTrendsInsight
]

instance InteractiveVisualization : DTDFVocab:Service [
    base:desc "3‑D interactive visualization in Unreal Engine 5."
    DTDFVocab:provides LightingComfortEvaluationInsight
]

instance Simulation : DTDFVocab:Service [
    base:desc "Runs energy and comfort simulations for the building."
    DTDFVocab:provides OptimizedControlSetpointsInsight
]

instance EnergyUsageOptimization : DTDFVocab:Service [
    base:desc "Optimizes energy usage based on sensor data and simulation results."
    DTDFVocab:provides OptimizedControlSetpointsInsight
]

instance RLBasedLightingControl : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based lighting control adjusting illumination automatically."
    DTDFVocab:provides LightingControlAdjustmentAction
]

instance ModularServiceIntegration : DTDFVocab:Service [
    base:desc "Platform for integrating additional services into the digital twin."
    DTDFVocab:provides ServiceIntegrationInsight
]

// C17: Insights / Actions
instance EnergyConsumptionTrendsInsight : DTDFVocab:Insight [
    base:desc "Insight into building energy‑consumption trends derived from sensor data."
]

instance LightingComfortEvaluationInsight : DTDFVocab:Insight [
    base:desc "Evaluation of lighting comfort based on illumination and occupancy data."
]

instance OptimizedControlSetpointsInsight : DTDFVocab:Insight [
    base:desc "Recommended optimized control set‑points for HVAC and lighting systems."
]

instance LightingControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting actuator set‑points as decided by the RL policy."
    DTDFVocab:IsAutomatic true
]

instance ServiceIntegrationInsight : DTDFVocab:Insight [
    base:desc "Insight about the status and performance of integrated services."
]

// C10: Models / Data
instance BIMGeometricSemanticModel : DTDFVocab:Model [
    base:desc "BIM geometric and semantic model representing building geometry and asset attributes."
    DTDFVocab:inputTo EclipseDitto, UnrealEngine5
]

instance EnrichedControlSystemModel : DTDFVocab:Model [
    base:desc "Runtime model of building control systems enriched with device status."
    DTDFVocab:inputTo EclipseDitto, RLAgentEngine
]

instance SensorDataStreamModel : DTDFVocab:Model [
    base:desc "Model describing continuous streams for temperature, illumination, CO₂ and occupancy."
    DTDFVocab:inputTo EclipseDitto, SimulationEngine
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model implementing rule‑based and RL‑based strategies for actuators."
    DTDFVocab:inputTo EclipseDitto, RLAgentEngine
]

instance ReinforcementLearningPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning policy model for adaptive lighting control (BOREALIS scenario)."
    DTDFVocab:inputTo RLAgentEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command flow from the twin to the physical actuators using the same Hono/Ditto middleware, allowing the twin to issue lighting, HVAC or other control signals to the building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (continuous) synchronization between physical sensors and the digital twin, with data exchange occurring as soon as measurements are available."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where the enriched BIM model is processed by a configurator that generates device metadata for Hono/Ditto, a central digital‑twin framework mediates bidirectional communication, and services are added through standardized extension points; the whole system forms the digital twin constellation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports the design, construction and operational stages of the building life‑cycle, enabling the twin to evolve from a design‑time BIM model to an operational model enriched with runtime data."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation is performed before deployment, and the Overall Digital Twin Entanglement (ODTE) metric is used to quantify how closely the twin reflects its physical counterpart, providing a measure of fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional data exchange is realized through the Eclipse Hono middleware (device ingress) coupled with Eclipse Ditto (digital‑twin state management), forming the technical link between physical devices and the virtual model."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach leverages BIM as an established industry standard for building data and defines standardized extension points for modular services, ensuring interoperability across tools and platforms."
]