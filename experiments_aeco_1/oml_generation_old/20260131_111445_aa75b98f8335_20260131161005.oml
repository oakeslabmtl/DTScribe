// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "LED drivers and dimmers configured to receive commands from the DT for adaptive lighting control in TwinLight."
]

instance HVACController : DTDFVocab:ActingComponent [
    base:desc "Building Control System (BCS) device managing HVAC operations with real-time adjustments from the DT."
]

instance SmartPlug : DTDFVocab:ActingComponent [
    base:desc "Smart electrical outlet enabling remote control of connected devices based on DT optimization signals."
]

