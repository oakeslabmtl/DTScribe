// C3: Physical Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "IoT sensor deployed in physical building to detect occupancy patterns. Used in BOREALIS for reinforcement learning-based control optimization."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LuminositySensor : DTDFVocab:SensingComponent [
    base:desc "Lighting-specific sensor measuring ambient light levels. Integrated in TwinLight for adaptive lighting control."
    DTDFVocab:producedData LuminosityDataTransmitted
]

instance TemperatureHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor measuring temperature and humidity levels. Data used for HVAC optimization and comfort analysis."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Air quality sensor measuring CO2 levels to ensure ventilation system optimization."
    DTDFVocab:producedData AirQualityDataTransmitted
]

instance EnergyMeter : DTDFVocab:SensingComponent [
    base:desc "Device measuring real-time energy consumption across building systems. Data used for energy efficiency analytics."
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

instance DaylightSensor : DTDFVocab:SensingComponent [
    base:desc "Specialized sensor measuring natural daylight availability for adaptive lighting control in TwinLight."
    DTDFVocab:producedData DaylightDataTransmitted
]

instance GlareDetectionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor detecting glare conditions to optimize lighting systems for visual comfort."
    DTDFVocab:producedData GlareDetectionDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LuminosityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LuminositySensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureHumiditySensor
]

instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeter
]

instance DaylightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DaylightSensor
]

instance GlareDetectionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GlareDetectionSensor
]

// C10: Models/Data
instance StaticBIMModel : DTDFVocab:Model [
    base:desc "Semantically rich 3D representation of building geometry, topology, and component relationships in IFC or COBie formats."
    DTDFVocab:inputTo BIMToRuntimeTransformer, EclipseDitto
]

instance RuntimeSensorData : DTDFVocab:Data [
    base:desc "Real-time streams from IoT sensors (occupancy, environmental metrics, energy consumption) ingested via Eclipse Hono/Ditto."
    DTDFVocab:fromData OccupancyDataTransmitted, LuminosityDataTransmitted, EnvironmentalDataTransmitted, AirQualityDataTransmitted, EnergyConsumptionDataTransmitted, DaylightDataTransmitted, GlareDetectionDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Domain-specific configurations for lighting control (TwinLight) and reinforcement learning policies (BOREALIS) embedded within BIM or generated via model-to-text transformations."
    DTDFVocab:inputTo BIMToRuntimeTransformer, ReinforcementLearningLibraries
]

instance MiddlewareIntegrationMetadata : DTDFVocab:Data [
    base:desc "Metadata for middleware integration including tenant/device IDs and endpoint addresses to enable seamless data exchange."
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C11: Enablers
instance ModelDrivenEngineering : DTDFVocab:Enabler [
    base:desc "Automates extraction of domain semantics from BIM and generation of runtime artifacts (e.g., Hono/Ditto configurations) via model-to-model/text transformations."
    DTDFVocab:enables BIMToRuntimeTransformer, ModelValidationService
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Provides IoT connectivity and edge data processing for real-time sensor-to-DT communication."
    DTDFVocab:enables RealTimeDataIngestionService, BidirectionalSynchronizationService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Manages digital twin instances and their digital twins with standardized APIs for bidirectional synchronization."
    DTDFVocab:enables DigitalTwinManagementService, TwinFidelityEvaluation
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Enables rich, interactive 3D visualization of the DT for facility management and immersive monitoring."
    DTDFVocab:enables InteractiveVisualizationService, ScenarioSimulationService
]

instance BIMTools : DTDFVocab:Enabler [
    base:desc "Used for device modeling (e.g., Revit, ArchiCAD) and enrichment with runtime semantics."
    DTDFVocab:enables BIMModelEnrichmentService, DeviceConfigurationService
]

instance ReinforcementLearningLibraries : DTDFVocab:Enabler [
    base:desc "Integrated in BOREALIS for adaptive control optimization of building systems."
    DTDFVocab:enables AdaptiveControlOptimizationService, PolicyRefinementService
]

instance BIMToRuntimeTransformer : DTDFVocab:Enabler [
    base:desc "Scans BIM models to extract twinnable devices and generates runtime configurations for the DT."
    DTDFVocab:enables AutomatedDeploymentService, ConfigurationGenerationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous observation of building performance metrics (energy use, occupancy, environmental conditions) via sensor data streams."
    DTDFVocab:provides RealTimeDashboardInsight, EnergyAnomalyAlert
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Uses BOREALIS RL models to recommend optimal lighting/HVAC settings balancing energy efficiency, visual comfort, and health effects."
    DTDFVocab:provides EnergyEfficiencyRecommendation, VisualComfortOptimization
]

instance AutomatedControlService : DTDFVocab:Service [
    base:desc "Deploys control logic (lighting schedules, occupancy-based adjustments) directly from BIM models via TwinLight framework."
    DTDFVocab:provides LightingControlAdjustment, HVACSetpointAdjustment
]

instance ScenarioSimulationService : DTDFVocab:Service [
    base:desc "Enables what-if analysis for refurbishments, occupancy changes, and energy system optimizations before physical implementation."
    DTDFVocab:provides RefurbishmentImpactAnalysis, OccupancyScenarioAnalysis
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Provides facility managers with spatially aware alerts and immersive 3D building performance visualization via Unreal Engine 5."
    DTDFVocab:provides OccupancyHotspotVisualization, EnergyUseVisualization
]

instance AdaptiveControlOptimizationService : DTDFVocab:Service [
    base:desc "Dynamically optimizes building systems using reinforcement learning policies that adapt based on real-time feedback."
    DTDFVocab:provides RLBasedLightingOptimization, HVACAdaptiveControl
]

instance DigitalTwinManagementService : DTDFVocab:Service [
    base:desc "Manages DT instances and ensures bidirectional synchronization between physical and virtual representations."
    DTDFVocab:provides TwinFidelityEvaluation, SynchronizationValidation
]

instance RealTimeDataIngestionService : DTDFVocab:Service [
    base:desc "Ingests real-time sensor data streams from Eclipse Hono for processing and analysis."
    DTDFVocab:provides DataStreamProcessing, SensorDataNormalization
]

instance BidirectionalSynchronizationService : DTDFVocab:Service [
    base:desc "Ensures consistent synchronization between physical building systems and digital twin representations."
    DTDFVocab:provides StateConsistencyValidation, ConflictResolution
]

instance ModelValidationService : DTDFVocab:Service [
    base:desc "Validates BIM models for completeness and consistency before deployment to the digital twin."
    DTDFVocab:provides ModelCompletenessCheck, ConsistencyValidation
]

instance BIMModelEnrichmentService : DTDFVocab:Service [
    base:desc "Enriches BIM models with runtime semantics and device metadata for digital twin integration."
    DTDFVocab:provides SemanticEnrichment, DeviceMetadataIntegration
]

instance DeviceConfigurationService : DTDFVocab:Service [
    base:desc "Configures physical devices (sensors, actuators) with digital twin endpoints and communication protocols."
    DTDFVocab:provides DeviceRegistration, ProtocolConfiguration
]

instance AutomatedDeploymentService : DTDFVocab:Service [
    base:desc "Automates the deployment of digital twin configurations to physical building systems."
    DTDFVocab:provides ConfigurationDeployment, SystemIntegration
]

instance ConfigurationGenerationService : DTDFVocab:Service [
    base:desc "Generates runtime configurations for digital twin components based on BIM models."
    DTDFVocab:provides ConfigurationTemplateGeneration, ParameterMapping
]

instance PolicyRefinementService : DTDFVocab:Service [
    base:desc "Refines reinforcement learning policies based on historical and real-time performance data."
    DTDFVocab:provides PolicyEvaluation, ContinuousLearning
]

