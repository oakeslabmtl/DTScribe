instance IndoorTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor integrated into Building Control System for capturing indoor temperature data"
    DTDFVocab:producedData IndoorTemperatureDataTransmitted
]

instance LightIntensitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor integrated into Building Control System for capturing light intensity data"
    DTDFVocab:producedData LightIntensityDataTransmitted
]

instance CO2ConcentrationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor integrated into Building Control System for capturing CO2 concentration data"
    DTDFVocab:producedData CO2ConcentrationDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor integrated into Building Control System for capturing occupancy data"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor integrated into Building Control System for capturing humidity data"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance IndoorTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndoorTemperatureSensor
]

instance LightIntensityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightIntensitySensor
]

instance CO2ConcentrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2ConcentrationSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance IndoorTemperatureData : DTDFVocab:Data [
    base:desc "Real-time indoor temperature data from sensors"
    DTDFVocab:fromData IndoorTemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance LightIntensityData : DTDFVocab:Data [
    base:desc "Real-time light intensity data from sensors"
    DTDFVocab:fromData LightIntensityDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance CO2ConcentrationData : DTDFVocab:Data [
    base:desc "Real-time CO2 concentration data from sensors"
    DTDFVocab:fromData CO2ConcentrationDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy data from sensors"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Real-time humidity data from sensors"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance BIMModel : DTDFVocab:Model [
    base:desc "Building Information Model enriched with device-specific metadata for sensors, actuators, and controllers, and middleware configuration details for Eclipse Hono and Ditto"
    DTDFVocab:inputTo MDEMethodologies, BIMTools
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for IoT device connectivity"
    DTDFVocab:enables RealTimeMonitoringService, EnergyOptimizationService, VisualComfortManagementService, NonVisualHealthEffectsAnalysisService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for digital twin management"
    DTDFVocab:enables RealTimeMonitoringService, PerformanceAnalysisService, PredictiveAnalyticsService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for 3D visualization"
    DTDFVocab:enables 3DVisualizationService
]

instance BIMTools : DTDFVocab:Enabler [
    base:desc "Building Information Modeling tools for model creation and management"
]

instance MDEMethodologies : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering methodologies for automated transformations"
    DTDFVocab:enables ModelDrivenDeploymentService
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of building operational data"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance under various scenarios"
    DTDFVocab:provides SimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy consumption and system performance"
    DTDFVocab:provides EnergyOptimizationInsight, NonVisualHealthEffectsInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of energy consumption based on sensor data"
    DTDFVocab:provides EnergyOptimizationInsight, AdjustHVACAction
]

instance VisualComfortManagementService : DTDFVocab:Service [
    base:desc "Management of visual comfort through lighting and shading control"
    DTDFVocab:provides VisualComfortInsight, AdjustLightingAction
]

instance NonVisualHealthEffectsAnalysisService : DTDFVocab:Service [
    base:desc "Analysis of non-visual health effects from environmental factors"
    DTDFVocab:provides NonVisualHealthEffectsInsight, VentilationAdjustmentAction
]

instance 3DVisualizationService : DTDFVocab:Service [
    base:desc "3D visualization of building models and real-time data"
    DTDFVocab:provides 3DVisualizationInsight
]

instance PerformanceAnalysisService : DTDFVocab:Service [
    base:desc "Performance analysis of building systems for facility management"
    DTDFVocab:provides PerformanceAnalysisInsight
]

instance ModelDrivenDeploymentService : DTDFVocab:Service [
    base:desc "Model-driven deployment using automated extraction of domain semantics from BIM models"
    DTDFVocab:provides ODTEValidationInsight
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time status of building systems for operational awareness"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Predicted outcomes of building simulations for decision support"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Actionable insights for reducing energy consumption"
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Insights for optimizing visual comfort conditions"
]

instance NonVisualHealthEffectsInsight : DTDFVocab:Insight [
    base:desc "Insights for mitigating non-visual health impacts from environmental factors"
]

instance 3DVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of building data for enhanced understanding"
]

instance PerformanceAnalysisInsight : DTDFVocab:Insight [
    base:desc "Performance metrics for facility management decisions"
]

instance ODTEValidationInsight : DTDFVocab:Insight [
    base:desc "Validation of digital twin accuracy through Overall Digital Twin Entanglement metric"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for heating, ventilation, and air conditioning control systems"
]

instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Controller for automated lighting adjustment"
]

instance VentilationActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for ventilation system control"
]

instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Adjust heating, ventilation, and air conditioning settings based on energy optimization insights"
    DTDFVocab:IsAutomatic false
]

instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Adjust lighting levels based on visual comfort insights"
    DTDFVocab:IsAutomatic false
]

instance VentilationAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjust ventilation settings based on non-visual health effects insights"
    DTDFVocab:IsAutomatic false
]

instance BuildingEnvironment : DTDFVocab:Environment [
    base:desc "Building infrastructure in AECO domain, Living Lab case study"
    base:contains IndoorTemperatureSensor, LightIntensitySensor, CO2ConcentrationSensor, OccupancySensor, HumiditySensor, HVACActuator, LightingController, VentilationActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication enabled by Eclipse Hono and Ditto for sending control signals to Building Control Systems (BCS), though specific control protocols are not detailed in the document."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with continuous data flow; specific time intervals or rates are not specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service-oriented platform integrating BIM as the semantic backbone, Eclipse Hono/Ditto middleware for bidirectional data exchange, Unreal Engine for visualization, and standardized extension points for custom services, enabling holistic building life cycle management."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Entire building life cycle, including design, construction, operation, refurbishment, and adaptations during operation, with the digital twin covering as-operated representations of physical assets."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Evaluation of digital twin interoperability and architectural soundness using the Overall Digital Twin Entanglement (ODTE) metric, though specific verification/validation mechanisms beyond this metric are not detailed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono and Ditto middleware for real-time data exchange; specific IoT protocols (e.g., MQTT, AMQP) are not detailed in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM standards for semantic representation and standardized extension points for modular service integration, addressing fragmented data sources through unified integration frameworks."
]