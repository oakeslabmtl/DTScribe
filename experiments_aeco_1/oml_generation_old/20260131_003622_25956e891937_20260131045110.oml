instance LivingLabEnvironment : DTDFVocab:Environment [
    base:desc "Real-world infrastructure test environment comprising a building or facility equipped with IoT sensors, actuators, and integrated cyber-physical systems"
    base:contains LivingLabIoTSensor, LivingLabActuator, BuildingGeometricModel, BuildingSemanticModel, RealTimeSensorData, AnalyticsEnabler, SimulationService, AnalysisService, OptimizationService, DTFramework, DataSynchronizationService, VisualizationInsight, OperationalInsight, SimulationInsight, AnalysisInsight, OptimizationInsight, DataSynchronizationInsight
]

instance LivingLabIoTSensor : DTDFVocab:SensingComponent [
    base:desc "IoT sensor deployed in Living Lab infrastructure for monitoring physical parameters"
    DTDFVocab:producedData SensorDataTransmission
]

instance LivingLabActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator in Living Lab infrastructure for controlling building systems"
]

instance BuildingGeometricModel : DTDFVocab:Model [
    base:desc "BIM-derived geometric model of building components transformed via Model-Driven Engineering principles"
    DTDFVocab:inputTo AnalyticsEnabler
]

instance BuildingSemanticModel : DTDFVocab:Model [
    base:desc "BIM-derived semantic model of building components transformed via Model-Driven Engineering principles"
    DTDFVocab:inputTo AnalyticsEnabler
]

instance SensorDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LivingLabIoTSensor
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Real-time operational data from IoT sensors synchronized with digital twin"
    DTDFVocab:fromData SensorDataTransmission
    DTDFVocab:inputTo AnalyticsEnabler
]

instance AnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Modular architecture enabling integration of custom analytics services for operational insights"
    DTDFVocab:enables SimulationService, AnalysisService, OptimizationService
]

instance DTFramework : DTDFVocab:Enabler [
    base:desc "Framework facilitating bidirectional data flows between physical infrastructure and digital twin"
    DTDFVocab:enables DataSynchronizationService
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for simulating building performance under various scenarios"
    DTDFVocab:provides SimulationInsight
]

instance AnalysisService : DTDFVocab:Service [
    base:desc "Service for analyzing real-time operational data to identify trends and anomalies"
    DTDFVocab:provides AnalysisInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service for optimizing building operations based on predictive analytics"
    DTDFVocab:provides OptimizationInsight
]

instance DataSynchronizationService : DTDFVocab:Service [
    base:desc "Service for real-time bidirectional data synchronization between physical and virtual systems"
    DTDFVocab:provides DataSynchronizationInsight
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive visualization interface for real-time building monitoring and control"
]

instance OperationalInsight : DTDFVocab:Insight [
    base:desc "Actionable insights for operational decision-making generated by custom analytics services"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight into simulated building performance scenarios"
]

instance AnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight into operational trends and anomalies detected through data analysis"
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight for optimizing building operations using predictive analytics"
]

instance DataSynchronizationInsight : DTDFVocab:Insight [
    base:desc "Insight into synchronization status and data flow between physical and digital twins"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Facility Managers interact with the deployed digital twin for real-time monitoring and control, with bidirectional data exchange enabling control signals to be transmitted to physical building systems."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization between physical assets and digital twins through continuous data exchange for live monitoring and immediate insights in infrastructure management."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Model-driven framework with modular architecture integrating Eclipse Hono and Ditto for IoT data management and Unreal Engine for high-fidelity visualization, operating as a central hub for component orchestration and resource coordination."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle encompasses four key stages: (1) initial device modeling within BIM environments by Building Control Engineers, where sensors, actuators, and controllers are defined to establish a semantic foundation; (2) Model-Driven Engineering (MDE) transformation of enriched BIM models into structured, deployable DT artifacts with minimal manual intervention; (3) real-time data synchronization between physical infrastructure and the digital twin via continuous data exchange; and (4) evolution through modular extension points enabling DT Engineers to integrate custom analytics services, with Facility Managers utilizing interactive visualization for operational monitoring and control. Lifecycle governance is role-based, ensuring seamless transitions between stages through standardized workflows."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Nonfunctional requirements address interoperability across heterogeneous systems, though specific technical network infrastructure details such as communication protocols, topology, or security measures are not explicitly detailed in the provided documentation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The framework employs a modular architecture with standardized extension points for scalable deployment, supporting runtime configuration management to enable adjustments without full redeployment, and addresses scalability from individual components to entire infrastructure systems as part of nonfunctional requirements. Interactive visualization provides immersive interfaces for monitoring and control."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework's modular architecture includes standardized extension points to enable interoperable integration of custom services and analytics."
]