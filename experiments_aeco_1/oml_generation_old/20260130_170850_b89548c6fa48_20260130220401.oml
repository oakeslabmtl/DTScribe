// Central hub component
instance CentralDTFramework : DTDFVocab:Component [
    base:desc "Central DT Framework acting as hub, coordinating Building Control Engineers, Facility Managers and DT Engineers"
]

// Sensors
instance BIMTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in BIM for monitoring building environment"
    DTDFVocab:producedData TempTemperatureDataTransmitted
]

instance BIMOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM for detecting presence in spaces"
    DTDFVocab:producedData TempOccupancyDataTransmitted
]

// Data transmitted from sensors
instance TempTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BIMTemperatureSensor
]

instance TempOccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BIMOccupancySensor
]

// Data objects
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature readings streamed from the physical building"
    DTDFVocab:fromData TempTemperatureDataTransmitted
    DTDFVocab:inputTo DataStreamingMiddleware
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy status streamed from the physical building"
    DTDFVocab:fromData TempOccupancyDataTransmitted
    DTDFVocab:inputTo DataStreamingMiddleware
]

// Enablers
instance DataStreamingMiddleware : DTDFVocab:Enabler [
    base:desc "Middleware that streams real‑time sensor data to the central DT framework"
    DTDFVocab:enables RealTimeDataExchangeService
]

instance ModelTransformationEngine : DTDFVocab:Enabler [
    base:desc "Engine that transforms BIM semantic model into executable twin components"
    DTDFVocab:enables TwinDeploymentService
]

// Models
instance BIMSemanticModel : DTDFVocab:Model [
    base:desc "Unified semantic model extracted from BIM containing device definitions, control logic and semantic links"
    DTDFVocab:inputTo ModelTransformationEngine
]

instance DeployableTwinArtifact : DTDFVocab:Model [
    base:desc "Compiled twin artifact generated from intermediate semantic model ready for deployment"
    DTDFVocab:inputTo TwinDeploymentService
]

// Services
instance RealTimeDataExchangeService : DTDFVocab:Service [
    base:desc "Service that continuously exchanges real‑time building data with the digital twin"
    DTDFVocab:provides VisualisationInsight
    DTDFVocab:provides ControlCommandAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization interface allowing facility managers to monitor states and issue commands"
    DTDFVocab:provides EnergyOptimizationInsight
    DTDFVocab:provides FaultDetectionInsight
]

instance TwinDeploymentService : DTDFVocab:Service [
    base:desc "Service that deploys compiled twin artifacts to the central DT framework"
    DTDFVocab:provides DeploymentInsight
]

// Insights
instance VisualisationInsight : DTDFVocab:Insight [
    base:desc "Insight presenting live building status via immersive visual interface"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight offering energy‑optimisation recommendations derived from custom analytics"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting faults in building systems based on streamed sensor data"
]

instance DeploymentInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful deployment of twin artifacts"
]

// Actions
instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Action allowing facility manager to issue control commands to actuators"
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides continuous, real-time data exchange between the physical building and its digital counterpart, implying synchronization at the granularity of incoming sensor streams; no explicit latency or frequency values are given, but the intent is sub-second, real-time updates for monitoring and control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, service-oriented constellation: a central DT Framework integrates enriched BIM models, provides bidirectional data exchange, supports standardized extension points for custom services, and enables runtime configuration management, allowing components to be added or updated without redeployment."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a five‑stage life‑cycle for a building digital twin: (1) **Device modeling** – building control engineers enrich the BIM model with explicit sensor, actuator and controller entities; (2) **Model transformation** – model‑driven engineering (MDE) extracts a structured, platform‑independent representation from the enriched BIM; (3) **Artifact generation & deployment** – the structured model is automatically compiled into deployable DT artefacts (services, data bindings) and instantiated in the runtime environment; (4) **Operational runtime** – real‑time data exchange synchronises physical building state with the twin, enabling monitoring, visualization and control; (5) **Evolution & maintenance** – standardized extension points allow DT engineers to inject custom services, analytics or updates, with the lifecycle governed by role‑based responsibilities (engineer, facility manager, DT engineer). Transitions between stages are managed by automated pipelines that trigger on model changes, ensuring traceability and governance."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is achieved through standardized extension points and non-functional requirements (NF_X) that address heterogeneous system integration; the DT exchanges data with BIM tools and other enterprise systems via generic, protocol-agnostic interfaces, though specific protocols are not listed."
]