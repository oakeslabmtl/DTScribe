// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor deployed in the building, annotated in the BIM model and connected via Eclipse Hono"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor measuring light levels, annotated in the BIM model and connected via Eclipse Hono"
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring ambient temperature, annotated in the BIM model and connected via Eclipse Hono"
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C10: Data instances
instance OccupancyData : DTDFVocab:Data [
    base:desc "Stream of occupancy counts from the building"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Stream of illumination measurements from building spaces"
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Stream of temperature readings from building zones"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

// C11: Enablers (tooling and enablers)
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides device connectivity and continuous streaming of sensor measurements"
    DTDFVocab:enables MonitoringDashboardService, VisualizationService, SimulationService, PredictiveAnalyticsService, OptimizationService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital twins and stores runtime data streams"
    DTDFVocab:enables MonitoringDashboardService, VisualizationService, SimulationService, PredictiveAnalyticsService, OptimizationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders interactive 3D visualization of the building twin"
    DTDFVocab:enables VisualizationService
]

instance BIMAuthoringTool : DTDFVocab:Enabler [
    base:desc "BIM authoring tools create the enriched BIM model representing the building"
    DTDFVocab:enables SimulationService, OptimizationService
]

instance ModelDrivenEngineering : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering techniques generate and evolve the twin model and deployment artifacts"
    DTDFVocab:enables SimulationService, OptimizationService
]

instance ModelValidatorConfigurator : DTDFVocab:Enabler [
    base:desc "Model validator/configurator validates the BIM model and configures middleware components"
    DTDFVocab:enables MonitoringDashboardService, VisualizationService
]

// C6: Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards displaying sensor data and twin state"
    DTDFVocab:provides RealTimeInsight, DecisionSupportInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization using Unreal Engine 5"
    DTDFVocab:provides RealTimeInsight, VisualizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance based on the twin model"
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics to forecast building conditions"
    DTDFVocab:provides PredictiveAnalyticsInsight, DecisionSupportInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization services to improve building operation efficiency"
    DTDFVocab:provides OptimizationInsight, DecisionSupportInsight
]

// C17: Insights
instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into current building performance"
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics insight forecasting future building states"
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Decision‑support insight enabling facility managers to optimise performance"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization insight for spatial understanding of building state"
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization insight recommending actions to improve energy usage"
]

// C2: Acting components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in BIM, controllable via the digital twin framework"
]

instance BuildingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Building control system component (e.g., HVAC controller) modeled in BIM and exposed through the framework"
]

// C10: Models/Data (core model)
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM artifact containing building geometry, device metadata, and middleware information"
    DTDFVocab:inputTo EclipseHono, EclipseDitto, ModelValidatorConfigurator
]

instance TwinConfigurationData : DTDFVocab:Data [
    base:desc "Generated configuration artifacts for deployment of device twins"
    DTDFVocab:inputTo EclipseDitto, ModelValidatorConfigurator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (e.g., lighting set‑points) generated by the digital twin are transmitted back to the physical actuators via the same Hono/Ditto bidirectional communication pipeline."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Operates in real‑time, continuously synchronising sensor streams and control actions between the physical asset and its twin (exact update frequency not specified)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central DT Framework hub that interconnects BIM‑derived device twins, the Hono/Ditto middleware, and the Unreal Engine visualization layer, with standardized extension points for additional services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Supports the design stage (BIM authoring), deployment stage (automated generation of runtime artifacts), and operation stage (runtime monitoring, control, and analytics)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation is performed before deployment, and the Overall Digital Twin Entanglement (ODTE) metric is used to quantify the fidelity between the physical building and its digital twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication is realized via Eclipse Hono (device protocol layer, typically MQTT/AMQP) and Eclipse Ditto (HTTP/WebSocket twin API), enabling real‑time data exchange between PT and DT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework is built on BIM standards as the semantic backbone for model interoperability; it leverages standard open‑source components such as Eclipse Hono and Ditto."
]