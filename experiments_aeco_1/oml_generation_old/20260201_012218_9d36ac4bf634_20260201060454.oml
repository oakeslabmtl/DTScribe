// Differentiated Actuating Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting devices equipped with an on/off switch, brightness level, and color‑temperature parameter derived from Revit photometric metadata, controlled via the UnrealTwinController through DittoController and EclipseHono MQTT transport."
]
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC units providing activation control and setpoint adjustment, interfaced by the DittoController and transmitted via EclipseHono MQTT following at‑least‑once delivery semantics."
]

// Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the building, transmitting measurements continuously to the Digital Twin."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor embedded in the building, transmitting measurements continuously to the Digital Twin."
    DTDFVocab:producedData HumidityDataTransmitted
]
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the building, transmitting presence data continuously to the Digital Twin."
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance EquipmentStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Equipment status sensor embedded in the building, transmitting operational state data continuously to the Digital Twin."
    DTDFVocab:producedData EquipmentStatusDataTransmitted
]

// Data Transmitted Instances
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance EquipmentStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EquipmentStatusSensor
]

// Data Instances
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature measurement data streamed from the building's sensors."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DittoRegistry
]
instance HumidityData : DTDFVocab:Data [
    base:desc "Real‑time humidity measurement data streamed from the building's sensors."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo DittoRegistry
]
instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy measurement data streamed from the building's sensors."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo DittoRegistry
]
instance EquipmentStatusData : DTDFVocab:Data [
    base:desc "Real‑time equipment status measurement data streamed from the building's sensors."
    DTDFVocab:fromData EquipmentStatusDataTransmitted
    DTDFVocab:inputTo DittoRegistry
]

// Enablers
instance MDEExtractionTool : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering tool that extracts semantic representations from the enriched BIM model and registers TwinComponents in Deref."
    DTDFVocab:enables BuildingMonitoringService, PredictiveMaintenanceService, EnergyOptimizationService
]
instance DittoRegistry : DTDFVocab:Enabler [
    base:desc "Ditto registry that receives sensor telemetry, conducts policy validation, and maintains the durable event store."
    DTDFVocab:enables BuildingMonitoringService, PredictiveMaintenanceService, EnergyOptimizationService
]
instance DittoController : DTDFVocab:Enabler [
    base:desc "Ditto controller that broker commands through the Ditto REST/WS endpoints, validates payloads, and forwards them via EclipseHono MQTT to the physical devices."
    DTDFVocab:enables HVACControlService, LightingControlService
]
instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Ditto framework that manages DittoDevices, enforces policy validation for value ranges and units, and persists events."
    DTDFVocab:enables ImmersiveVisualizationService
]
instance EclipseHonoTransport : DTDFVocab:Enabler [
    base:desc "Eclipse Hono message transport layer that provides MQTT transport for bi‑directional data exchange between virtual and physical layers."
    DTDFVocab:enables BuildingMonitoringService, PredictiveMaintenanceService, EnergyOptimizationService
]
instance UE5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 visualization interface that renders immersive views of the twin and consumes live telemetry."
    DTDFVocab:enables ImmersiveVisualizationService
]

// Services
instance BuildingMonitoringService : DTDFVocab:Service [
    base:desc "Monitoring service exposing real‑time state of building devices and generating insights for Facility Managers."
    DTDFVocab:provides TemperatureTrendInsight, HumidityAlertInsight, OccupancyAnalyticsInsight, EquipmentFailureInsight
]
instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive analytics service that generates failure alerts based on sensor telemetry."
    DTDFVocab:provides EquipmentFailureInsight
]
instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy optimization service providing real‑time energy usage analytics."
    DTDFVocab:provides EnergyConsumptionInsight
]
instance HVACControlService : DTDFVocab:Service [
    base:desc "HVAC control service that issues real‑time command execution to HVAC actuators."
    DTDFVocab:provides ExecuteHVACCommandAction
]
instance LightingControlService : DTDFVocab:Service [
    base:desc "Lighting control service that issues real‑time command execution to lighting actuators."
    DTDFVocab:provides ExecuteLightingCommandAction
]
instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization service providing visual insights into building operation."
    DTDFVocab:provides HVACPerformanceInsight, LightingEfficiencyInsight, VisualInteractionInsight
]

// Insights
instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Insight into temperature trends derived from continuous temperature telemetry."
]
instance HumidityAlertInsight : DTDFVocab:Insight [
    base:desc "Instantaneous humidity alerts generated when recorded values approach or exceed defined thresholds."
]
instance OccupancyAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Insight into occupancy patterns derived from occupancy sensor data."
]
instance EquipmentFailureInsight : DTDFVocab:Insight [
    base:desc "Predictive insight indicating potential equipment failures based on sensor telemetry."
]
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into energy consumption levels for operational optimization."
]
instance HVACPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight into HVAC system performance visualized within the UE5 environment."
]
instance LightingEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight into lighting efficiency derived from brightness and power usage data."
]
instance VisualInteractionInsight : DTDFVocab:Insight [
    base:desc "Insight into user interaction and visualization fidelity within the immersive interface."
]

// Actions
instance ExecuteHVACCommandAction : DTDFVocab:Action [
    base:desc "Action to execute on‑off or setpoint commands to HVAC actuators via the DittoController."
    DTDFVocab:IsAutomatic false
]
instance ExecuteLightingCommandAction : DTDFVocab:Action [
    base:desc "Action to execute on‑off, brightness, and color‑temperature changes on lighting actuators via the DittoController."
    DTDFVocab:IsAutomatic false
]

// Models / Data Structures
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing geometric representations of the building and embedded device configurations, including photometric metadata for lighting."
    DTDFVocab:inputTo MDEExtractionTool
]
instance BehavioralControlModel : DTDFVocab:Model [
    base:desc "Behavioral control logic defined by the Building Control Engineer within the BIM and extracted during MDE."
    DTDFVocab:inputTo MDEExtractionTool
]
instance AnalyticalPolicyModel : DTDFVocab:Model [
    base:desc "Policy‑based data validation rules encoded in EclipseDitto for ensuring value ranges and units."
    DTDFVocab:inputTo EclipseDitto
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals originating from the DT are sent back to the physical building control system (BCS). Commands such as HVAC set‑points, lighting schedules, or actuator controls are issued through the same data exchange infrastructure used for sensor data. The framework validates that the command aligns with the current BIM model before delivery, ensuring consistency between the virtual model and physical operations. Confirmation of command execution is received as feedback from the BCS, and any conflicts are handled by the operator or via the DT’s conflict resolution logic. Specific command message formats, authentication, or conflict resolution protocols are not described in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The documented system is designed for real‑time data exchange between the physical building and its digital twin, providing continuous synchronization.  While explicit refresh rates or latency targets are not specified, the architecture supports near‑zero latency for monitoring and control through real‑time data pipelines, and runtime configuration allows adjusting update intervals to meet application‑specific service time‑scales and granularities."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is organized around a central DT Framework that acts as the hub for the building’s digital twin. This framework orchestrates the entire twin lifecycle by ingesting enriched BIM models and generating operational twin instances. It supports bidirectional, real‑time data exchange between the physical building and its digital counterpart, enabling continuous synchronization. The architecture is modular, exposing standardized extension points that allow DT engineers to integrate custom services and analytics without requiring a full redeployment. Runtime configuration management further enhances adaptability, enabling adjustments to the twin’s behavior on demand. Overall, the constellation provides a cohesive, centralized orchestration for monitoring, control, and service integration across the building life cycle."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports four main lifecycle stages: (1) **Device Modeling** – Building Control Engineers enrich BIM models with explicit sensor, actuator, and controller descriptions (Definition of BCS components) to overcome BIM’s static representation limitation; (2) **Model Transformation** – Applying Model‑Driven Engineering (MDE) principles, the enriched BIM is automatically parsed into a structured, deployable Digital Twin artifact, managing the transition from static architectural representation to a dynamic runtime model; (3) **Deployment & Runtime Operation** – The generated DT is deployed to the edge or cloud, with real‑time data exchange protocols maintaining continuous synchronization with the physical building; Facility Managers then monitor and interact with the twin via interactive visualization interfaces; (4) **Service Extension & Governance** – A modular architecture with standardized extension points allows DT Engineers to integrate custom analytics or control plugins, enabling governance of evolution and reduced manual configuration during any lifecycle transition."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and data integrity are maintained by policy‑based validation in Eclipse Ditto, which checks incoming sensor values against defined range and unit constraints and rejects out‑of‑range readings. Prior to executing actuator commands, the DittoController performs pre‑execution checks to prevent unsafe operations. Fault tolerance is achieved through Eclipse Hono’s at‑least‑once message delivery and Ditto’s persistent event storage, guaranteeing that no telemetry or command is lost. Continuous real‑time data exchange between the physical building and the Digital Twin serves as a runtime synchronization benchmark, validating that the twin state matches the on‑site state. While the documents do not specify quantitative uncertainty models, the described policy validations and persistent storage provide a robust quality‑assurance foundation for the Digital Twin.”}"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Document 1 references real‑time data exchange and modular, extensible architecture but does not detail the underlying network infrastructure.  The framework’s scalability and interoperability requirements (see Section II of Document 1) imply the use of a publish/subscribe middleware capable of supporting low‑latency, high‑throughput messaging across heterogeneous systems.  Specific protocols, topology, bandwidth, latency guarantees, or security mechanisms are not explicitly described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework is built upon the BIM semantic backbone, extending standard Building Information Modeling (BIM) representations (e.g., IFC) with device‑level annotations for sensors, actuators, and controllers. It removes fragmented, case‑specific data schemas by generating a unified, machine‑readable model from enriched BIM, thereby ensuring interoperability across stakeholders. The solution adheres to BIM standards for data exchange and adopts a modular architecture with standardized extension points to support additional services, but does not rely on external communication protocols beyond the real‑time data exchange mechanisms referenced in the literature. No specific industry certification or compliance frameworks are cited in the provided documents."
]