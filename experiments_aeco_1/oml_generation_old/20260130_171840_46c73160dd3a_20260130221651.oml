// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in the BIM environment and addressable via generated runtime interfaces"
]

instance HVACControlActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC control hardware modeled in the BIM environment and addressable via generated runtime interfaces"
]

// C3: Physical sensing components
instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor (e.g., temperature, humidity) embedded in the BIM model and streamed via Eclipse Hono"
    DTDFVocab:producedData EnvironmentalDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the BIM model and streamed via Eclipse Hono"
    DTDFVocab:producedData OccupancyDataStream
]

instance EnergySensor : DTDFVocab:SensingComponent [
    base:desc "Energy consumption sensor embedded in the BIM model and streamed via Eclipse Hono"
    DTDFVocab:producedData EnergyDataStream
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance EnvironmentalDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergySensor
]

// C10: Models/Data (time‑series sensor data)
instance EnvironmentalSensorData : DTDFVocab:Data [
    base:desc "Time‑series data from EnvironmentalSensor"
    DTDFVocab:fromData EnvironmentalDataStream
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancySensorData : DTDFVocab:Data [
    base:desc "Time‑series data from OccupancySensor"
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance EnergySensorData : DTDFVocab:Data [
    base:desc "Time‑series data from EnergySensor"
    DTDFVocab:fromData EnergyDataStream
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// Static BIM model enriched with device metadata
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Static BIM geometry and semantic data enriched with device metadata"
    DTDFVocab:inputTo ModelDrivenTransformationPipeline
]

// Generated Ditto twin definition
instance DittoTwinDefinition : DTDFVocab:Model [
    base:desc "Runtime twin definition generated for Eclipse Ditto"
    DTDFVocab:inputTo ModelDrivenTransformationPipeline
]

// Unreal Engine 5 visualization model
instance UnrealVisualizationModel : DTDFVocab:Model [
    base:desc "3D visualization model for Unreal Engine 5 generated from the enriched BIM"
    DTDFVocab:inputTo UnrealEngine5
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono adapters (e.g., MQTT) ingest real‑time sensor streams"
    DTDFVocab:enables RealTimeMonitoringService, RuntimeConfigurationManagementService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto synchronizes incoming data and stores twin state"
    DTDFVocab:enables RealTimeMonitoringService, SimulationService, PredictiveAnalyticsService, OptimizationService
]

instance ModelDrivenTransformationPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven pipeline that enriches BIM, validates models, generates artefacts and deploys the twin"
    DTDFVocab:enables RuntimeConfigurationManagementService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 provides interactive 3D visualization of the digital twin"
    DTDFVocab:enables Interactive3DVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building state via continuous sensor updates"
    DTDFVocab:provides RealTimeInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building operations based on current twin state"
    DTDFVocab:provides PredictiveInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics to forecast energy demand and occupancy trends"
    DTDFVocab:provides PredictiveInsight, DecisionSupportInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization of building operations (e.g., HVAC scheduling, lighting control)"
    DTDFVocab:provides OptimizationAction
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization of the building twin in Unreal Engine 5"
    DTDFVocab:provides VisualizationInsight
]

instance RuntimeConfigurationManagementService : DTDFVocab:Service [
    base:desc "Runtime configuration management of devices and twin artefacts"
    DTDFVocab:provides ConfigurationInsight
]

// C17: Insights / Actions
instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Real‑time insights on temperature, occupancy and energy consumption"
]

instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Predictive insights on future energy usage and occupant behaviour"
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Decision‑support information enabling facility managers to select optimal control strategies"
]

instance OptimizationAction : DTDFVocab:Action [
    base:desc "Automated adjustment of lighting and HVAC setpoints based on optimization results"
    DTDFVocab:IsAutomatic true
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D view of current building state for stakeholder engagement"
]

instance ConfigurationInsight : DTDFVocab:Insight [
    base:desc "Insight into device configuration status and required runtime updates"
]

// C5: Environment (the digital twin constellation)
instance LivingLabBuilding : DTDFVocab:Environment [
    base:contains EnvironmentalSensor, OccupancySensor, EnergySensor,
                LightingActuator, HVACControlActuator,
                EnrichedBIMModel, DittoTwinDefinition, UnrealVisualizationModel,
                CentralTwinPlatform
]

// C1: Multiplicities – Central platform aggregating devices
instance CentralTwinPlatform : DTDFVocab:Component [
    base:desc "Centralized DT framework that aggregates multiple twinnable devices and manages them collectively"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin’s logic (e.g., lighting control setpoints) are sent back through Ditto/Hono to the corresponding actuators in the building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization between physical assets and the twin (no discrete batch rates are specified)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture where a central DT framework connects BIM, Hono, Ditto, and Unreal Engine, with standardized extension points for adding custom services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the full building lifecycle: design (BIM creation), construction (device modeling and metadata enrichment), and operation (runtime data integration and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A model validation step is performed before generation; the Overall Digital Twin Entanglement (ODTE) metric is used to quantify the fidelity between the physical building and its twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication mediated by Eclipse Hono (protocol adapters such as MQTT for sensor ingestion) and Eclipse Ditto (HTTP/WS APIs for twin state management)."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The architecture’s standardized extension points permit integration of external services and analytics platforms, facilitating horizontal information exchange beyond the core twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach follows BIM standards for building data, provides standardized extension points for interoperability, and employs the ODTE metric as a common assessment standard."
]