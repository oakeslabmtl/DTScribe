// Acting Components
instance LEDLightingFixtureDimmer : DTDFVocab:ActingComponent [
    base:desc "LED lighting fixture equipped with dimmer controller, integrated into BIM-controlled lighting system enabling twin to command lighting levels and schedules."
]

// Physical Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in building, modeled in BIM."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Luminance (light level) sensor embedded in building, modeled in BIM."
    DTDFVocab:producedData LightLevelDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in building, modeled in BIM."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// Data Transmitted
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// Runtime Data
instance OccupancyData : DTDFVocab:Data [
    base:desc "Runtime occupancy data stream from OccupancySensor."
    DTDFVocab:inputTo EclipseHonoEnabler, DittoEnabler
    DTDFVocab:fromData OccupancyDataTransmitted
]

instance LightLevelData : DTDFVocab:Data [
    base:desc "Runtime light level data stream from LightLevelSensor."
    DTDFVocab:inputTo EclipseHonoEnabler, DittoEnabler
    DTDFVocab:fromData LightLevelDataTransmitted
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Runtime temperature data stream from TemperatureSensor."
    DTDFVocab:inputTo EclipseHonoEnabler, DittoEnabler
    DTDFVocab:fromData TemperatureDataTransmitted
]

// Models and Embedded Data
instance BIMIFCModel : DTDFVocab:Model [
    base:desc "BIM (IFC) model providing geometry, topology, and functional attributes."
    DTDFVocab:inputTo TransformPipelineEnabler
]

instance DeviceMetadata : DTDFVocab:Data [
    base:desc "Embedded control logic and device metadata extracted from BIM."
    DTDFVocab:inputTo TransformPipelineEnabler
]

// Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware for real‑time data exchange."
    DTDFVocab:enables RealTimeDataExchangeService
]

instance DittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto service for device twin management and real‑time data exchange."
    DTDFVocab:enables RealTimeDataExchangeService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive visualization of digital twin."
    DTDFVocab:enables VisualizationService
]

instance TransformPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation pipeline converting enriched BIM into DT artifacts."
    DTDFVocab:enables ModelTransformationService
]

instance AutomatedDeploymentOrchestrator : DTDFVocab:Enabler [
    base:desc "Automated deployment orchestrator for deploying DT artifacts via Hono/Ditto configurator."
    DTDFVocab:enables DeploymentService
]

// Services
instance RealTimeDataExchangeService : DTDFVocab:Service [
    base:desc "Service enabling continuous synchronization of building states via Eclipse Hono and Ditto middleware."
    DTDFVocab:provides DataSynchronizationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service providing immersive visualization through Unreal Engine 5."
    DTDFVocab:provides VisualDashboardInsight
]

instance ModelTransformationService : DTDFVocab:Service [
    base:desc "Service transforming BIM models into runtime configuration artifacts."
    DTDFVocab:provides TransformationInsight
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Service orchestrating deployment of DT artifacts via Hono/Ditto configurator."
    DTDFVocab:provides DeploymentInsight
]

instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Service providing real‑time monitoring dashboards."
    DTDFVocab:provides PerformanceInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service offering predictive analytics for light‑level and occupancy forecasting."
    DTDFVocab:provides ForecastingInsight
]

instance AdaptiveLightingControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning driven adaptive lighting control service."
    DTDFVocab:provides AdaptiveLightingAction
]

instance TaskPlanningService : DTDFVocab:Service [
    base:desc "Task planning service for facility operations."
    DTDFVocab:provides TaskPlanningInsight
]

// Insights
instance DataSynchronizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time data synchronization between physical devices and digital twin."
]

instance VisualDashboardInsight : DTDFVocab:Insight [
    base:desc "Immersive visualization of building states through Unreal Engine 5."
]

instance TransformationInsight : DTDFVocab:Insight [
    base:desc "Transformation of BIM models into DT artifacts."
]

instance DeploymentInsight : DTDFVocab:Insight [
    base:desc "Deployment of DT artifacts via Hono/Ditto configurator."
]

instance PerformanceInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring of building performance."
]

instance ForecastingInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics for light‑level and occupancy forecasting."
]

instance TaskPlanningInsight : DTDFVocab:Insight [
    base:desc "Facilitated task planning for facility operations."
]

instance LightingSchedulingInsight : DTDFVocab:Insight [
    base:desc "Operational insight for lighting scheduling."
]

instance EnergyConsumptionReductionInsight : DTDFVocab:Insight [
    base:desc "Operational insight for reducing energy consumption."
]

instance ComfortOptimizationInsight : DTDFVocab:Insight [
    base:desc "Operational insight for optimizing occupant comfort."
]

// Actions
instance AdaptiveLightingAction : DTDFVocab:Action [
    base:desc "Action to adjust lighting levels and schedules based on reinforcement learning policies."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., lighting dimming, HVAC setpoints) are published via Ditto to the building’s actuator middleware, providing bidirectional, real‑time interaction between virtual and physical domains."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates on a real‑time continuous synchronization loop; updates are event‑driven through Hono/Ditto without a predefined time bucket, enabling instantaneous reflection of physical changes."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestration architecture where the BIM-based digital twin acts as a central hub, exposing virtual representations via Ditto endpoints, receiving sensor data from Hono, and interfacing with external service plugins through modular extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT supports all lifecycle phases—design (BIM), fabrication (metadata mapping to device IDs), and operation (runtime data integration), thereby aligning as‑designed, as‑manufactured, and as‑operated representations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Alignment quantified with the Overall Digital Twin Entanglement (ODTE) metric, monitoring semantic drift, and employing automated validation from model transformation and runtime data consistency checks."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional data flow established through Eclipse Hono and Ditto middleware, enabling real‑time synchronization between IoT devices and the Digital Twin services."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of Building Information Modeling (BIM) standards for data representation; integration with industry‑standard interfacing components such as Hono and Ditto, ensuring semantic interoperability."
]