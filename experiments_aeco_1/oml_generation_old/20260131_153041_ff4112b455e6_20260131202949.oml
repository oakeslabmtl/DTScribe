// C2: Acting Components
instance OccupancyLightActuator : DTDFVocab:ActingComponent [
    base:desc "Building control device for occupancy-based lighting adjustment, modeled within BIM environment for automated commissioning and real-time control logic integration via Eclipse Hono middleware"
]

instance HVACActuator : DTDFVocab:Actuator [
    base:desc "HVAC system actuators for real-time temperature and airflow control, explicitly defined by Building Control Engineers in BIM for bidirectional communication with physical systems"
]

instance EnergyConsumptionActuator : DTDFVocab:Actuator [
    base:desc "Actuator for energy consumption optimization controls, integrated with BIM for automated commissioning and real-time operational adjustments"
]

// C3: Physical Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor embedded within building infrastructure for occupancy detection, integrated into BIM model to extract tenant IDs and endpoint addresses for real-time data acquisition via Ditto middleware"
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in building infrastructure for real-time temperature monitoring, integrated with BIM for metadata extraction and synchronized data exchange with digital twin via Ditto/Hono"
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Energy consumption sensor embedded in building infrastructure for real-time energy monitoring, integrated with BIM for tenant ID and endpoint address metadata extraction"
]

instance HVACStatusSensor : DTDFVocab:SensingComponent [
    base:desc "HVAC system status sensor for real-time monitoring of system performance and operational parameters, integrated with BIM for data synchronization"
]

// C4: Data Transmission
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance HVACStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACStatusSensor
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring and visualization service for immersive 3D interaction using Unreal Engine, providing operational insights for Facility Managers"
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service for operational optimization (e.g., energy efficiency), enabling data-driven decision-making via reinforcement learning control policies"
]

instance CustomServiceIntegration : DTDFVocab:Service [
    base:desc "Framework for custom service integration by DT Engineers, supporting modular extension points for domain-specific services (e.g., reinforcement learning-based control policies from BOREALIS)"
]

// C11: Enablers
instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Immersive 3D visualization platform (Unreal Engine 5) for interactive monitoring and real-time data presentation within the digital twin environment"
]

instance DittoMiddleware : DTDFVocab:Enabler [
    base:desc "Middleware platform (Ditto) for real-time data synchronization between physical sensors and digital twin, ensuring bidirectional communication via Eclipse Hono"
]

instance ModelDrivenEngineering : DTDFVocab:Enabler [
    base:desc "Model-driven engineering principles for automating BIM model enrichment, transformation into runtime artifacts, and iterative model governance"
]

instance EclipseHonoProtocol : DTDFVocab:Enabler [
    base:desc "Real-time data exchange protocol (Eclipse Hono) for bidirectional communication between physical building systems and digital twin components"
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing embedded runtime semantics (sensor configurations, control logic) extracted via model-driven transformations for semantic coherence between static and dynamic data"
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Real-time operational data (sensor readings, control signals) processed via Ditto middleware, synchronized with visualization models in Unreal Engine"
]

instance VisualizationModel : DTDFVocab:Data [
    base:desc "3D visualization model generated in Unreal Engine for interactive monitoring and immersive presentation of digital twin data"
]

instance PredictiveModel : DTDFVocab:Data [
    base:desc "Predictive analytics model for operational optimization (e.g., energy efficiency) integrated with digital twin services"
]

// C17: Insights/Actions
instance OccupancyInsight : DTDFVocab:Insight [
    base:desc "Real-time occupancy patterns and trends derived from sensor data for facility management optimization"
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Energy consumption trends and efficiency metrics for operational optimization and predictive maintenance"
]

instance HVACPerformanceInsight : DTDFVocab:Insight [
    base:desc "Real-time HVAC system performance metrics and operational efficiency indicators"
]

instance PredictiveMaintenanceAction : DTDFVocab:Action [
    base:desc "Automatic triggering of predictive maintenance actions based on sensor data anomalies and degradation patterns"
    DTDFVocab:IsAutomatic true
]

instance HVACOptimizationAction : DTDFVocab:Action [
    base:desc "Automated adjustment of HVAC settings for energy efficiency and comfort optimization, triggered by predictive analytics"
    DTDFVocab:IsAutomatic true
]

instance LightingScheduleAdjustment : DTDFVocab:Action [
    base:desc "Dynamic adjustment of lighting schedules based on occupancy patterns and energy consumption insights"
    DTDFVocab:IsAutomatic true
]

// Relationships
OccupancySensor DTDFVocab:producedData OccupancyDataTransmitted
TemperatureSensor DTDFVocab:producedData TemperatureDataTransmitted
EnergyConsumptionSensor DTDFVocab:producedData EnergyConsumptionDataTransmitted
HVACStatusSensor DTDFVocab:producedData HVACStatusDataTransmitted

OccupancyDataTransmitted DTDFVocab:fromData OccupancyInsight
EnergyConsumptionDataTransmitted DTDFVocab:fromData EnergyConsumptionInsight
HVACStatusDataTransmitted DTDFVocab:fromData HVACPerformanceInsight

OccupancyInsight DTDFVocab:inputTo UnrealEngineVisualization
EnergyConsumptionInsight DTDFVocab:inputTo PredictiveAnalyticsService
HVACPerformanceInsight DTDFVocab:inputTo PredictiveAnalyticsService

UnrealEngineVisualization DTDFVocab:enables RealTimeMonitoringService
DittoMiddleware DTDFVocab:enables PredictiveAnalyticsService
ModelDrivenEngineering DTDFVocab:enables CustomServiceIntegration
EclipseHonoProtocol DTDFVocab:enables HVACOptimizationAction

RealTimeMonitoringService DTDFVocab:provides OccupancyInsight
PredictiveAnalyticsService DTDFVocab:provides HVACPerformanceInsight
PredictiveAnalyticsService DTDFVocab:provides PredictiveMaintenanceAction
CustomServiceIntegration DTDFVocab:provides LightingScheduleAdjustment

EnrichedBIMModel DTDFVocab:inputTo ModelDrivenEngineering
RealTimeOperationalData DTDFVocab:inputTo DittoMiddleware
VisualizationModel DTDFVocab:inputTo UnrealEngineVisualization
PredictiveModel DTDFVocab:inputTo PredictiveAnalyticsService

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Facilitates control signal transmission from the digital twin to physical actuators via **Eclipse Hono** and Ditto. The framework automates the generation of runtime interfaces from BIM models, allowing the DT to execute control logic (e.g., adaptive lighting, HVAC adjustments) based on real-time operational data, ensuring seamless synchronization with physical building systems."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Operates on a **real-time (sub-second to near-real-time) time scale** for bidirectional data synchronization between physical and virtual systems. The framework ensures low-latency communication via optimized middleware (Eclipse Hono/Ditto) and automated model transformations, enabling continuous updates and adaptive control strategies."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A **service-oriented DT architecture** with a centralized deployment model, orchestrated via the DT Framework. The constellation includes the **BIM-based physical model**, **runtime middleware (Eclipse Hono/Ditto)**, **visualization layer (Unreal Engine)**, and **custom services** (e.g., adaptive lighting controls from BOREALIS). The framework supports horizontal integration with external systems (e.g., IoT platforms) via standardized APIs."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the entire **building life cycle**, from **design (ideal representation)** through **manufacturing (as-manufactured validation)** to **operation (real-time monitoring and optimization)**. The framework automates transitions between these stages by leveraging BIM as a semantic backbone and model-driven transformations to maintain consistency across phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Ensures **high fidelity** by validating BIM models against physical assets and measuring **Overall Digital Twin Entanglement (ODTE)** to quantify alignment between virtual and physical systems. The framework addresses **uncertainty** through automated data normalization and **verification/validation** mechanisms, ensuring robustness in real-time operations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Utilizes **Eclipse Hono** and **Ditto** for bidirectional communication protocols, enabling low-latency data exchange between physical sensors/actuators and the digital twin. The technical connection employs **standardized APIs** for interoperability with BIM tools and IoT platforms, ensuring seamless integration across heterogeneous systems."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployed as a **scalable, cloud-based or edge-computing solution**, leveraging the DT Framework’s modular architecture. The framework supports **standardized extension points** for hosting custom services, enabling flexible deployment configurations (e.g., centralized cloud hosting or distributed edge nodes). Unreal Engine provides a **local visualization layer** for immersive interaction."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Supports integration with **external information systems** (e.g., IoT platforms, building management systems) via standardized APIs and middleware (Eclipse Hono/Ditto). The framework enables **seamless data exchange** with other DTs or operational systems, facilitating cross-domain collaboration in AECO workflows."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not explicitly detailed in the documents, but implied to follow **BIM-centric governance models** where data ownership is primarily tied to the **physical building owner**. Privacy is managed through **standardized data protocols** (e.g., Ditto’s secure data exchange) and **role-based access controls** within the DT Framework."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adheres to **AECO-specific standards** like **BIM (Building Information Modeling)** for semantic consistency, **Eclipse Hono/Ditto** for real-time data exchange, and **Unreal Engine** for visualization. The framework includes **standardized extension points** for modular service integration, ensuring interoperability with existing AECO tools and IoT platforms."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Implements **cybersecurity measures** via Ditto’s secure data protocols and Eclipse Hono’s middleware for protecting real-time data transmission. The framework ensures **safety** by enabling remote control of physical systems only under validated conditions, with **human-in-the-loop validation** for critical operations (e.g., HVAC adjustments)."
]