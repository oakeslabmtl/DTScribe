// C2: Acting Components
instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Actuated lighting fixture embedded in the BIM model, controlled via Eclipse Ditto command bus."
]

instance HVACDamperActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC damper embedded in the BIM model, positioning controlled through Ditto."
]

instance HeatingCoolingSetpointActuator : DTDFVocab:ActingComponent [
    base:desc "Heating and cooling setpoint actuator, driven by Ditto control commands."
]

// C3: Physical sensing components
instance BuildingTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in the BIM, measures ambient temperature and publishes telemetry."
    DTDFVocab:producedData BuildingTemperatureDataTransmitted
]

instance BuildingLightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor modeled in the BIM, captures lighting level for adaptive control."
    DTDFVocab:producedData BuildingLightDataTransmitted
]

instance BuildingOccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector embedded in the BIM, reports presence data via MQTT over TLS."
    DTDFVocab:producedData BuildingOccupancyDataTransmitted
]

instance BuildingCO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor modeled in BIM, provides indoor air quality telemetry."
    DTDFVocab:producedData BuildingCO2DataTransmitted
]

instance BuildingPowerMeter : DTDFVocab:SensingComponent [
    base:desc "Power meter device in the BIM, measures electrical consumption for energy monitoring."
    DTDFVocab:producedData BuildingPowerDataTransmitted
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance BuildingTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingTemperatureSensor
]

instance BuildingLightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingLightSensor
]

instance BuildingOccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingOccupancyDetector
]

instance BuildingCO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingCO2Sensor
]

instance BuildingPowerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingPowerMeter
]

// C10: Models/Data
instance BIMIFCDomainModel : DTDFVocab:Model [
    base:desc "BIM IFC model transformed into a domain model via MDE."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance DeviceStateModel : DTDFVocab:Model [
    base:desc "Device state model stored in Ditto shadows, representing current twin status."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model for building automation, encoded in Ops DSL."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance SyntheticSimulationModel : DTDFVocab:Model [
    base:desc "Synthetic data model for simulation scenarios, generated by RL libraries."
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C10: Data
instance BuildingTemperatureData : DTDFVocab:Data [
    base:desc "Temperature measurement telemetry received via MQTT over TLS by Eclipse Hono."
    DTDFVocab:inputTo EclipseHonoEnabler
    DTDFVocab:fromData BuildingTemperatureDataTransmitted
]

instance BuildingLightData : DTDFVocab:Data [
    base:desc "Lighting level telemetry received via MQTT over TLS by Eclipse Hono."
    DTDFVocab:inputTo EclipseHonoEnabler
    DTDFVocab:fromData BuildingLightDataTransmitted
]

instance BuildingOccupancyData : DTDFVocab:Data [
    base:desc "Occupancy telemetry received via MQTT over TLS by Eclipse Hono."
    DTDFVocab:inputTo EclipseHonoEnabler
    DTDFVocab:fromData BuildingOccupancyDataTransmitted
]

instance BuildingCO2Data : DTDFVocab:Data [
    base:desc "CO₂ telemetry received via MQTT over TLS by Eclipse Hono."
    DTDFVocab:inputTo EclipseHonoEnabler
    DTDFVocab:fromData BuildingCO2DataTransmitted
]

instance BuildingPowerData : DTDFVocab:Data [
    base:desc "Power consumption telemetry received via MQTT over TLS by Eclipse Hono."
    DTDFVocab:inputTo EclipseHonoEnabler
    DTDFVocab:fromData BuildingPowerDataTransmitted
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono IoT gateway, publishes sensor telemetry over MQTT/AMQP to Ditto topics."
    DTDFVocab:enables DataIngestionService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto broker, manages device twins and publishes state changes."
    DTDFVocab:enables EnergyOptimizationService,
                     OccupancySchedulingService,
                     AdaptiveLightingControlService,
                     RealTimeMonitoringDashboardService,
                     ImmersiveVisualizationService
]

// C6: Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service that ingests telemetry from Hono and persists state changes in Ditto."
    DTDFVocab:provides DataStreamInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Service performing energy optimization using BIM models and telemetry."
    DTDFVocab:provides EnergyConsumptionForecastInsight,
                     HVACSetpointAdjustmentAction
]

instance OccupancySchedulingService : DTDFVocab:Service [
    base:desc "Service scheduling occupancy based on predictive models."
    DTDFVocab:provides OccupantComfortIndexInsight,
                     RecommendationEngineInsight
]

instance AdaptiveLightingControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based adaptive lighting control."
    DTDFVocab:provides LightingScheduleAdjustmentAction
]

instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring dashboards."
    DTDFVocab:provides RealTimeMonitoringDashboardInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D visualization in Unreal Engine 5."
    DTDFVocab:provides ImmersiveVisualizationInsight
]

// C17: Insights/Actions
instance DataStreamInsight : DTDFVocab:Insight [
    base:desc "Insight indicating telemetry stream health and integrity."
]

instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of future energy consumption based on current telemetry."
]

instance OccupantComfortIndexInsight : DTDFVocab:Insight [
    base:desc "Index measuring occupant comfort derived from CO₂, temperature and lighting data."
]

instance RecommendationEngineInsight : DTDFVocab:Insight [
    base:desc "Recommendations for improved comfort and efficiency."
]

instance RealTimeMonitoringDashboardInsight : DTDFVocab:Insight [
    base:desc "Dashboard insight presenting live building metrics."
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight enabling real‑time immersive visualization in Unreal Engine 5."
]

instance LightingScheduleAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting schedules via reinforcement learning."
    DTDFVocab:IsAutomatic true
]

instance HVACSetpointAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of HVAC setpoints for energy savings."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control command events generated by the DT (e.g., lighting schedules, HVAC setpoints) are published by Ditto to the middleware and forwarded via Hono to the building control system, which actuates the physical hardware."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous data exchange at sub‑second intervals (typical MQTT QoS 1, latency < 1 s), with event‑driven updates; DT services execute at a tens‑of‑milliseconds scale for control loops and at minute‑scale for analytics and optimization."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Central DT framework coordinating device twins, middleware (Hono/Ditto), simulation engine (Unreal), and analytics modules, forming a service‑oriented architecture with defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (BIM creation), Commissioning (embedding device metadata), Construction (hardware installation), Operation (real‑time monitoring/optimization), and Retrofitting/Evolution (iterative updates and reinforcement learning)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Alignment verified by the Overall Digital Twin Entanglement (ODTE) metric, sensor calibration, QoS‑based data integrity checks, and periodic cross‑validation against BIM‑derived geometric constraints."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT over TLS 1.2 between physical devices and Hono gateway, Ditto REST/WS for twin updates, and CoAP for constrained devices; all connected through a secure private network with IPsec VPN to the DT host."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital twin services are hosted on an on‑premise Docker cluster running Eclipse Ditto, Hono, and Unreal Engine 5 instances, with optional cloud scaling via Kubernetes in a secure private VNet."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external building automation standards (BACnet, KNX), industry data repositories, and other DT platforms via standard MQTT/REST interfaces, enabling interoperability beyond the local DT."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data generated by the physical building remains owned by the PT owner; the DT provider accesses it only under service agreements, with GDPR‑compliant data handling and encryption at rest and in transit."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of IFC for BIM modeling, MQTT for messaging, OGC SensorThings API for sensor data representation, and ISO/IEC 20922 for digital twin architecture guidance."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "TLS encryption for all network traffic, mutual authentication for devices and services, role‑based access control in Ditto, audit logging, and safety‑critical operation checks to ensure remote commands cannot trigger hazardous actions during human presence."
]