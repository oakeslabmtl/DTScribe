// C3: Physical sensing components
instance AmbientLightSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient light sensor defined as a custom Revit family with Instance General UUID, located in the building envelope."
    DTDFVocab:producedData DataTransmittedAmbientLight
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined as a custom Revit family with Instance General UUID, located in the HVAC zone."
    DTDFVocab:producedData DataTransmittedTemperature
]

// C4: Data transmitted from sensors
instance DataTransmittedAmbientLight : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientLightSensor
]

instance DataTransmittedTemperature : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C10: Models/Data
instance AmbientLightData : DTDFVocab:Data [
    base:desc "Ambient light level reported by the sensor, validated by Eclipse Ditto policy engine."
    DTDFVocab:fromData DataTransmittedAmbientLight
    DTDFVocab:inputTo EclipseDittoRepository
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Indoor temperature reported by the sensor, validated by Eclipse Ditto policy engine."
    DTDFVocab:fromData DataTransmittedTemperature
    DTDFVocab:inputTo EclipseDittoRepository
]

// C11: Enablers
instance EclipseDittoRepository : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto repository managing persistent state for device telemetry and actuator commands."
    DTDFVocab:enables RealTimeMonitoringService
    DTDFVocab:enables LightingControlService
]

instance ModelDrivenAnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Analytics engine derived from enriched IFC model for predictive maintenance and optimization."
    DTDFVocab:enables PredictiveAnalyticsService
]

instance iTwinJSVisualizer : DTDFVocab:Enabler [
    base:desc "iTwin.js client providing web-based immersive 3D visualization of the BIM and twin components."
    DTDFVocab:enables ImmersiveVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Monitors building physical states in real‑time via Eclipse Ditto, providing live telemetry insight."
    DTDFVocab:provides LiveBuildingStateInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Offers predictive maintenance and energy optimization using model‑driven analytics."
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Delivers interactive 3D visualization through iTwin.js and UE5, synchronized with real‑time twin state."
    DTDFVocab:provides ImmersiveVisualizationInsight
]

instance LightingControlService : DTDFVocab:Service [
    base:desc "Executes actuator commands on the lighting fixture with pre‑execution safety checks, via Eclipse Ditto."
    DTDFVocab:provides LightingControlAction
]

// C17: Insights/Actions
instance LiveBuildingStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time view of sensor states, facilitating immediate anomaly detection."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predicts upcoming maintenance events and optimizes energy usage based on sensor trends."
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D visualization that reflects the current state of the building and its devices."
]

instance LightingControlAction : DTDFVocab:Action [
    base:desc "Controls the lighting fixture: on/off, brightness percentage (0‑100 %), color temperature (2000‑6500 K) with safety constraints."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance LightFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture actuator (IFCLIGHTFIXTURETYPE) accepts control messages via Eclipse Ditto; safety constraints via policy engine enforce brightness 0‑100 % and color temperature 2000‑6500 K; commands forwarded by DittoController over MQTT/Hono."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originated in UE5 or other custom services are serialized as JSON payloads and sent to Ditto over a secure WebSocket channel. Ditto routes the command to the appropriate device via Hono using the same MQTT/AMQP transport, referencing the device’s tenant and endpoint metadata. Each command execution is acknowledged by the physical device; the acknowledgment is received by Hono, forwarded to Ditto, and only after confirmation does UE5 update the twin’s state. This feedback loop provides explicit command execution confirmation and conflict resolution, as the digital twin accepts updates only after device acknowledgment, ensuring consistency between virtual and physical states.
"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates in a near‑real‑time regime, using a 1 second heartbeat loop to push state updates between the physical building and its digital counterpart via Eclipse Hono (MQTT‑based message broker) and Eclipse Ditto (twin registry). This schedule yields an ODTE timeliness score of 0.997, signifying negligible latency. Deployment of the entire twin – from model checking (5.53 s) and parsing (8.7 s) to initialization (0.3 s) – completes in 14.53 s, enabling rapid provisioning and update cycles."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, service‑oriented architecture centered around a DT Framework that acts as a bidirectional hub. Components are produced by a model‑driven engineering (MDE) pipeline that extracts enriched BIM models (via Revit) into structured runtime artifacts, which are then instantiated as Eclipse Ditto twins. Custom plugins and analytics are attached through standardized extension points, while runtime configuration management allows hot‑deployment of changes without full redeployment. The framework coordinates device modeling (handled by Building Control Engineers), monitoring and control (by Facility Managers), and service extension (by DT Engineers). Resource management is lightweight; the deployment process takes 14.53 s and a 1 s heartbeat ensures continuous synchronization."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Twin lifecycle follows a structure that begins with BIM‑based device modeling, where Building Control Engineers populate Revit families and assign Unique Identifiers (IFC Type, Instance General UUID) for BCS devices. These enriched models are exported to IFC and undergo a semantic extraction phase (per F2) that leverages MDE to produce structured domain representations. An automated one‑click deployment phase (F3) transforms these representations into fully‑configured DT artifacts (including Ditto entities, Hono device registrations, and Kubernetes deployment manifests). During runtime, real‑time bidirectional data exchange (F4) and interactive 3D visualization (F5) enable operation of the Twin. Dynamic runtime configuration management (F7) provides governance for updating interfaces, parameters and services without redeployment, thereby closing the loop for maintenance and evolution."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through a multi‑stage validation pipeline: 1) static model checking of the IFC file guarantees presence of Instance General UUIDs and correct IFC types; 2) semantic extraction verifies that the structured representation matches the enriched BIM; 3) runtime validation via Ditto’s policy engine enforces value ranges and units for all sensor readings; 4) pre‑execution checks on actuator commands prevent unsafe states.  Fault tolerance is achieved with Hono’s at‑least‑once delivery and Ditto’s persistent event storage, allowing data recovery after network outages.  Synchronization quality is quantified using the Overall Digital Twin Entanglement (ODTE) metric, measured over a continuous 12‑minute window with a 1‑second heartbeat: timeliness = 0.997, reliability = 1.0, availability = 1.0, yielding an ODTE score of 0.997, indicating near‑perfect bidirectional consistency."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT infrastructure is composed of three key communication layers: 1) Device‑to‑Gateway via MQTT (or AMQP) on Hono; 2) Gateway‑to‑Twin via Ditto’s WebSocket API; 3) Twin‑to‑Client via HTTP POST for bootstrapping and WebSocket for ongoing updates. The topology is a hierarchical star with the building’s local gateway acting as a single ingress point feeding into a Ditto service cluster. Bandwidth requirements are modest for telemetry (a few kilobits per second per device) but latency must be under a few hundred milliseconds to support real‑time control. Reliability is achieved through Hono’s QoS guarantees and Ditto’s message store, with optional redundancy by replicating the Ditto cluster. Security is enforced through TLS for all transport layers, with device authentication based on tenant and device identifiers extracted from the BIM model.
"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External integration is achieved primarily through Eclipse Hono and Eclipse Ditto, which expose MQTT and REST interfaces for publishing and subscribing to building sensor data and actuator commands. The framework exposes standardized APIs that enable third‑party services, analytics, and other enterprise systems (e.g., BIM repositories, UE5 visualization engines) to plug in via well‑defined extension points. The use of open standards (MQTT, JSON payloads, RESTful services) facilitates interoperability with heterogeneous systems, while the modular architecture supports integration of additional DTs or external IoT platforms."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework aligns with BIM industry standards by employing the IFC (Industry Foundation Classes) data format for model exchange and by adhering to IFC type definitions (e.g., IFCLIGHTFIXTURETYPE). It incorporates open source integration stacks that use Eclipse Hono (leveraging MQTT or AMQP protocols) and Eclipse Ditto (REST and WebSocket APIs) for real‑time data exchange, both of which are industry‑approved messaging standards. Interoperability is achieved through the use of ISO‑based schema mapping within the semantic extraction layer and by providing standardized extension points that allow the inclusion of additional IoT protocols and third‑party analytics services."
]