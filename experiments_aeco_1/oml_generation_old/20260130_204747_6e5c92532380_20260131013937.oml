// C3: Physical sensing components
instance EnvironmentSensor : DTDFVocab:SensingComponent [
    base:desc "Environment sensor captured in the BIM model for temperature, humidity, and other environmental parameters."
    DTDFVocab:producedData EnvironmentSensorDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy sensor data captured in the BIM model to detect presence and occupancy levels."
    DTDFVocab:producedData OccupancySensorDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance EnvironmentSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentSensor
]

instance OccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Data (derived from transmitted data)
instance EnvironmentLiveData : DTDFVocab:Data [
    base:desc "Live environmental telemetry (temperature, humidity) streamed from the building."
    DTDFVocab:fromData EnvironmentSensorDataTransmitted
    DTDFVocab:inputTo EclipseHonoMessaging, EclipseDittoPlatform
]

instance OccupancyLiveData : DTDFVocab:Data [
    base:desc "Live occupancy telemetry streamed from post‑occupancy sensors."
    DTDFVocab:fromData OccupancySensorDataTransmitted
    DTDFVocab:inputTo EclipseHonoMessaging, EclipseDittoPlatform
]

// C10: Models (static and runtime)
instance BIMStaticModel : DTDFVocab:Model [
    base:desc "Static BIM geometry and semantic model used as the semantic backbone."
    DTDFVocab:inputTo EclipseDittoPlatform, UnrealEngine5Visualization
]

instance RuntimeMetadataModel : DTDFVocab:Model [
    base:desc "BIM‑enriched model with runtime metadata for devices and control logic."
    DTDFVocab:inputTo EclipseDittoPlatform
]

instance DittoThingModel : DTDFVocab:Model [
    base:desc "Generated Eclipse Ditto thing models derived from BIM metadata."
    DTDFVocab:inputTo EclipseDittoPlatform
]

instance HonoTopicModel : DTDFVocab:Model [
    base:desc "Eclipse Hono topic definitions autogenerated from BIM device specifications."
    DTDFVocab:inputTo EclipseHonoMessaging
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control‑logic models derived from BIM‑based specifications for building automation."
    DTDFVocab:inputTo EclipseDittoPlatform
]

// C11: Enablers (tooling and platforms)
instance EclipseHonoMessaging : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides MQTT/HTTP messaging for sensor telemetry into the Digital Twin."
    DTDFVocab:enables RealTimeMonitoringDashboard, ImmersiveVisualizationService, BuildingPerformanceSimulation, PredictiveAnalyticsService, EnergyOptimizationService
]

instance EclipseDittoPlatform : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto stores and updates twin state, exposing interfaces for services."
    DTDFVocab:enables RealTimeMonitoringDashboard, ImmersiveVisualizationService, BuildingPerformanceSimulation, PredictiveAnalyticsService, EnergyOptimizationService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders immersive 3‑D visualization of the twin state."
    DTDFVocab:enables ImmersiveVisualizationService
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards presenting live sensor data and twin state."
    DTDFVocab:provides RealTimeOperationalInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "3‑D immersive visualization in Unreal Engine 5 for stakeholder interaction."
    DTDFVocab:provides ImmersiveVisualizationInsight
]

instance BuildingPerformanceSimulation : DTDFVocab:Service [
    base:desc "Building‑performance simulation using twin data and control‑logic models."
    DTDFVocab:provides SimulationOutcomeInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics generating optimisation recommendations for energy and comfort."
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that issues commands to actuators for energy savings."
    DTDFVocab:provides AdjustLightingAction, AdjustHVACAction
]

// C17: Insights
instance RealTimeOperationalInsight : DTDFVocab:Insight [
    base:desc "Provides stakeholders with real‑time operational insights from live sensor streams."
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Delivers immersive visualization feedback of building conditions and twin state."
]

instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Shows simulation outcomes that inform adjustments to building operation."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Generates optimisation recommendations for lighting, HVAC, and energy consumption."
]

// C17: Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Command to adjust lighting fixtures based on optimization recommendations."
    DTDFVocab:IsAutomatic false
]

instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Command to adjust HVAC valve settings according to optimization recommendations."
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture represented in BIM that can receive command messages from the twin."
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve represented in BIM that can receive command messages from the twin."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points) are sent back through Ditto to Hono and delivered to the corresponding actuators, providing bidirectional control of the physical assets."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization between physical assets and the twin, driven by the streaming capabilities of Hono and Ditto."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central DT framework acting as hub that connects the enriched BIM model, the Hono/Ditto communication layer, the Unreal Engine visualization, and plug‑in services; roles include Building Control Engineer, Facility Manager, and DT Engineer."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers design (as‑designed BIM), construction/as‑built (enriched BIM with device metadata), and operation (as‑operated with live sensor streams)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Alignment between physical building and its twin is quantified using the Overall Digital Twin Entanglement (ODTE) metric; model validation is performed prior to deployment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time bi‑directional communication is realized through Eclipse Hono handling device telemetry and command channels, and Eclipse Ditto maintaining the digital twin’s state; together they provide the technical link between PT and DT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM is employed as the industry‑standard modeling framework; the ODTE metric provides a standardized measure of twin entanglement; the framework adopts open‑source standards (Eclipse Hono, Eclipse Ditto) for interoperability."
]