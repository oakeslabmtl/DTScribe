    base:desc "Real-time operational data enabling immersive visualization of building operations (HVAC, occupancy, etc.)."
]

instance CustomAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Context-aware insights generated by custom services integrated through modular architecture."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance recommendations generated by integrated analytics modules."
]

