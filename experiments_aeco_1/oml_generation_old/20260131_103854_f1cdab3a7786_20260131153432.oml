// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental temperature sensor deployed in physical buildings, providing real-time readings for BCS monitoring and control logic implementation."
    DTDFVocab:producedData TemperatureSensorDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Environmental humidity sensor deployed in physical buildings, providing real-time readings for BCS monitoring and control logic implementation."
    DTDFVocab:producedData HumiditySensorDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy detection sensor providing real-time occupancy data for adaptive building control systems and energy optimization."
    DTDFVocab:producedData OccupancySensorDataTransmitted
]

instance HVACControllerStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring HVAC controller status and operational parameters for real-time synchronization with digital twin."
    DTDFVocab:producedData HVACControllerStatusDataTransmitted
]

instance LightingSystemSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring lighting system status and energy consumption for real-time building automation."
    DTDFVocab:producedData LightingSystemDataTransmitted
]

instance SecuritySystemSensor : DTDFVocab:SensingComponent [
    base:desc "Security system sensor providing real-time status updates for integrated building management systems."
    DTDFVocab:producedData SecuritySystemDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance TemperatureSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
    base:desc "Structured telemetry data from temperature sensors, normalized and enriched with spatial metadata from BIM models."
]

instance HumiditySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
    base:desc "Structured telemetry data from humidity sensors, normalized and enriched with spatial metadata from BIM models."
]

instance OccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
    base:desc "Occupancy detection data transmitted in real-time, mapped to BIM spatial elements for contextual analysis."
]

instance HVACControllerStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACControllerStatusSensor
    base:desc "Real-time status data from HVAC controllers, including operational parameters and performance metrics."
]

instance LightingSystemDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSystemSensor
    base:desc "Real-time lighting system status and energy consumption data for building automation."
]

instance SecuritySystemDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecuritySystemSensor
    base:desc "Security system status updates transmitted in real-time for integrated building management."
]

// C10: Models/Data
instance BimEnrichedModel : DTDFVocab:Model [
    base:desc "Building Information Model enriched with semantic annotations for BCS components (sensors, actuators, controllers) serving as the unified semantic foundation for DT deployment."
    DTDFVocab:inputTo BimIntegrationLayer
]

instance BcsComponentModel : DTDFVocab:Model [
    base:desc "Structured representation of BCS components (sensors, actuators, controllers) extracted from enriched BIM models via MDE principles."
    DTDFVocab:inputTo AutomatedTransformationPipeline
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Continuous stream of real-time operational data from physical buildings, synchronized bidirectionally with the digital twin."
    DTDFVocab:fromData TemperatureSensorDataTransmitted, HumiditySensorDataTransmitted, OccupancySensorDataTransmitted, HVACControllerStatusDataTransmitted, LightingSystemDataTransmitted, SecuritySystemDataTransmitted
    DTDFVocab:inputTo RuntimeSynchronizationEngine
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Definition of control logic for building automation systems, tightly coupled with BCS component configurations."
    DTDFVocab:inputTo ControlLogicImplementationService
]

instance CustomServiceModel : DTDFVocab:Model [
    base:desc "Models for custom services and plugins developed by DT Engineers, integrated through standardized extension points."
    DTDFVocab:inputTo CustomServiceDevelopmentEnvironment
]

// C11: Enablers
instance BimIntegrationLayer : DTDFVocab:Enabler [
    base:desc "Semantic foundation layer that addresses BIM's limitations by supporting dynamic, lifecycle-aware modeling of BCS components."
    DTDFVocab:enables DeviceModelingService, RealTimeMonitoringService
]

instance AutomatedTransformationPipeline : DTDFVocab:Enabler [
    base:desc "MDE-driven workflow converting enriched BIM models into deployable DT artifacts with minimal manual intervention."
    DTDFVocab:enables DeviceModelingService, ControlLogicImplementationService
]

instance ModularRuntime : DTDFVocab:Enabler [
    base:desc "Modular architecture executing DT services with standardized APIs for interoperability and plug-and-play integration."
    DTDFVocab:enables CustomServiceIntegrationService, RealTimeMonitoringService
]

instance RuntimeSynchronizationEngine : DTDFVocab:Enabler [
    base:desc "Manages bidirectional data flow between physical buildings and digital twins, ensuring real-time operational alignment."
    DTDFVocab:enables RealTimeMonitoringService, ImmersiveVisualizationService
]

instance CustomServiceDevelopmentEnvironment : DTDFVocab:Enabler [
    base:desc "Development environment supporting DT Engineers in extending functionality via plugins or microservices."
    DTDFVocab:enables CustomServiceIntegrationService
]

// C6: Services
instance DeviceModelingService : DTDFVocab:Service [
    base:desc "Enables semantic modeling of BCS components within BIM environment, defining control logic and device configurations via MDE principles."
    DTDFVocab:provides BcsComponentConfigurationInsight, AutomatedTransformationInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides continuous bidirectional data exchange between physical building and digital twin, ensuring synchronized system states."
    DTDFVocab:provides SystemStateInsight, OperationalDataInsight
]

instance CustomServiceIntegrationService : DTDFVocab:Service [
    base:desc "Offers modular architecture with standardized extension points for integrating custom services, plugins, or analytics modules."
    DTDFVocab:provides CustomAnalyticsInsight, PredictiveMaintenanceInsight
]

instance ControlLogicImplementationService : DTDFVocab:Service [
    base:desc "Allows definition and deployment of control logic directly within BIM-DT framework for automated building operations."
    DTDFVocab:provides ControlLogicExecutionInsight, AdaptiveBuildingOperationsInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Delivers interactive, real-time visualizations of building operations for monitoring, diagnosis, and scenario simulation."
    DTDFVocab:provides VisualDiagnosisInsight, EnergySimulationInsight
]

// C17: Insights/Actions
instance BcsComponentConfigurationInsight : DTDFVocab:Insight [
    base:desc "Structured representations of BCS components ready for real-time synchronization and runtime operation."
]

instance AutomatedTransformationInsight : DTDFVocab:Insight [
    base:desc "Validation of semantic models ensuring adherence to BCS component standards before transformation."
]

