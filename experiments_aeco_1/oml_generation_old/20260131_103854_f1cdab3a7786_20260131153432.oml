    base:desc "Actionable insights from executed control logic within the DT environment."
]

instance AdaptiveBuildingOperationsInsight : DTDFVocab:Insight [
    base:desc "Automated or semi-automated building operations based on real-time sensor data and control logic."
]

instance VisualDiagnosisInsight : DTDFVocab:Insight [
    base:desc "Diagnostic information visualized through immersive interfaces for operational oversight."
]

