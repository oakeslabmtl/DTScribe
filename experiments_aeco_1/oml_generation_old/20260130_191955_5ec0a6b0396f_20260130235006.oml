// C3: Physical sensing components
instance BIMDefinedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors are defined within the BIM model by the Building Control Engineer and linked to real‑time data exchange mechanisms that keep the Digital Twin continuously synchronized with physical measurements."
    DTDFVocab:producedData BIMSensorDataTransmission
]

// C4: Physical-to-virtual interaction
instance BIMSensorDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BIMDefinedSensor
]

// C10: Data
instance BIMSensorDataStream : DTDFVocab:Data [
    base:desc "Continuous sensor streams received through a real‑time data exchange layer (Eclipse Hono/MQTT AMQP) for monitoring by the Facility Manager."
    DTDFVocab:fromData BIMSensorDataTransmission
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

// C10: Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model combining 3‑D geometry, spatial and functional semantics with instantiated device models for sensors, actuators and controllers, extracted via MDE pipelines into JSON‑LD/NGSI‑LD."
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

// C11: Enablers
instance RealTimeDataExchangeEnabler : DTDFVocab:Enabler [
    base:desc "Standardized extension point integrating Eclipse Hono for MQTT/AMQP device connectivity and Eclipse Ditto for digital‑twin state management, providing continuous synchronization between physical assets and their twin."
    DTDFVocab:enables AnalyticsEngineService, VisualizationDashboardService, ActuationControlService
]

// C6: Services (Analytics)
instance AnalyticsEngineService : DTDFVocab:Service [
    base:desc "Custom analytics plug‑ins that consume sensor data streams to compute operational insights such as energy consumption trends and fault detection."
    DTDFVocab:provides EnergyConsumptionTrendInsight, FaultDetectionInsight
]

// C6: Services (Visualization)
instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Immersive visualisation dashboards presenting analytics insights to facility managers for monitoring and control."
    DTDFVocab:provides EnergyConsumptionTrendInsight, FaultDetectionInsight
]

// C6: Services (Actuation Control)
instance ActuationControlService : DTDFVocab:Service [
    base:desc "Service that receives remote command requests from the twin interface and forwards them to HVAC actuators."
    DTDFVocab:provides RemoteActuationAction
]

// C17: Insights
instance EnergyConsumptionTrendInsight : DTDFVocab:Insight [
    base:desc "Computed energy consumption trends derived from continuous sensor data to support facility management decisions."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Automated fault detection alerts generated from sensor anomalies to enable proactive maintenance."
]

// C2: Acting Components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator modeled in the BIM model and addressed through generated Digital Twin artifacts, enabling the Facility Manager to issue remote commands to physical HVAC systems."
]

// C17: Actions
instance RemoteActuationAction : DTDFVocab:Action [
    base:desc "Remote command issued from the Digital Twin to activate or adjust HVAC actuators."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Through the bidirectional data exchange hub, the digital twin can issue control commands back to the physical building, enabling Facility Managers to perform real‑time monitoring and control. The description mentions control flows from the DT to the physical system but does not detail command formats, validation/authentication mechanisms, conflict resolution, or execution confirmations."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a complete DT life‑cycle that starts with device modeling directly in the BIM environment (definition of sensors, actuators and controllers), proceeds to a model‑driven engineering (MDE) step that extracts a structured representation and automatically generates deployable DT artefacts, continues with runtime operation where real‑time data exchange keeps the physical building and its digital counterpart synchronised, and ends with interactive visualisation and modular extension points that allow facility managers and DT engineers to monitor, control and evolve the twin. Transition between stages is managed by the model‑driven deployment pipeline that governs the transformation from enriched BIM models to executable DT services, and governance is enforced through the framework’s modular architecture and standardized extension points."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates Eclipse Hono and Eclipse Ditto for real‑time, bidirectional data exchange with physical assets. It leverages standardized integration frameworks and interoperability standards to connect external enterprise systems and other Digital Twins, enabling seamless incorporation of user‑centered control strategies."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework is built on the BIM standard as the core data model and employs standardized extension points within its modular architecture to promote interoperability across heterogeneous building automation components. It aims for compliance with BIM‑related specifications and supports integration with other systems through these generic, standards‑based interfaces, but no specific certification requirements or additional industry standards are cited."
]