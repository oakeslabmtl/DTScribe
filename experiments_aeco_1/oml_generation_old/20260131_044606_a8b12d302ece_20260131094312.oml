// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the BIM model, exposed as a Ditto device for environmental monitoring."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor embedded in the BIM model, exposed as a Ditto device for indoor air quality monitoring."
    DTDFVocab:producedData CO2DataTransmitted
]

instance MotionSensor : DTDFVocab:SensingComponent [
    base:desc "Motion sensor embedded in the BIM model, exposed as a Ditto device for occupancy detection."
    DTDFVocab:producedData MotionDataTransmitted
]

instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor embedded in the BIM model, exposed as a Ditto device for illumination measurement."
    DTDFVocab:producedData LightDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance MotionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionSensor
]

instance LightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

// C5: Data (from transmission)
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature readings streamed to the digital twin via MQTT."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Real-time CO₂ concentration readings streamed to the digital twin via MQTT."
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance MotionData : DTDFVocab:Data [
    base:desc "Real-time occupancy status (motion detected) streamed to the digital twin via MQTT."
    DTDFVocab:fromData MotionDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance LightData : DTDFVocab:Data [
    base:desc "Real-time light level readings streamed to the digital twin via MQTT."
    DTDFVocab:fromData LightDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance HighFrequencySensorStreamData : DTDFVocab:Data [
    base:desc "High‑frequency sensor streams (e.g., 1 Hz for temperature) aggregated for analytics."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance ControlHistoryLogsData : DTDFVocab:Data [
    base:desc "Historical logs of control actions (HVAC, lighting, blinds) for audit and analytics."
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C6: Acting Components
instance HospitalityHVACUnit : DTDFVocab:ActingComponent [
    base:desc "HVAC unit modeled in BIM, instantiated as a Ditto virtual device controlling temperature."
]

instance CampusLightingFixture : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture modeled in BIM, instantiated as a Ditto virtual device controlling illumination."
]

instance OperableBuildingBlind : DTDFVocab:ActingComponent [
    base:desc "Operable blind modeled in BIM, instantiated as a Ditto virtual device controlling shading."
]

// C10: Models/Data
instance IFC4BIMModel : DTDFVocab:Model [
    base:desc "IFC4 BIM model enriched with device and control annotations for the LEED Platinum campus building."
    DTDFVocab:inputTo EMFXtextMDEEnabler
]

instance DittoRuntimeJSONSchema : DTDFVocab:Model [
    base:desc "Ditto-based runtime JSON schemas for sensor and actuator devices."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance UnrealEngineSceneModel : DTDFVocab:Model [
    base:desc "Unreal Engine 5 scene assets representing the campus building for immersive 3D visualization."
    DTDFVocab:inputTo UnrealEngineEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides MQTT transport for real‑time telemetry streams."
    DTDFVocab:enables RealTimeMonitoringDashboardService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto acts as the data broker for Ditto virtual devices and event handling."
    DTDFVocab:enables PredictiveAnalyticsEnergyService, TaskPlanningMaintenanceService
]

instance EMFXtextMDEEnabler : DTDFVocab:Enabler [
    base:desc "EMF/Xtext MDE tools perform model transformation from BIM to runtime metadata."
    DTDFVocab:enables HVACOptimizationService, LightingOptimizationService
]

instance BOREALISEnabler : DTDFVocab:Enabler [
    base:desc "BOREALIS reinforcement learning framework for continuous optimization."
    DTDFVocab:enables HVACOptimizationService, LightingOptimizationService
]

instance TwinLightEnabler : DTDFVocab:Enabler [
    base:desc "TwinLight handles model drift correction for the digital twin."
    DTDFVocab:enables PredictiveAnalyticsEnergyService
]

instance UnrealEngineEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 provides immersive 3D rendering of the campus building twin."
    DTDFVocab:enables ImmersiveVisualizationService
]

instance DockerKubernetesEnabler : DTDFVocab:Enabler [
    base:desc "Docker/Kubernetes orchestrate containerized internal subsystem twins."
    DTDFVocab:enables HVACOptimizationService, LightingOptimizationService
]

// C6: Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring dashboards for energy, occupancy, and environmental conditions."
    DTDFVocab:provides EnergySavingsInsight, OccupantComfortIndexInsight
]

instance PredictiveAnalyticsEnergyService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy consumption and optimization recommendations."
    DTDFVocab:provides EnergyConsumptionPredictionInsight, OptimizationRecommendationInsight
]

instance HVACOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes HVAC schedules based on real‑time telemetry and predictive models."
    DTDFVocab:provides HVACScheduleAdjustmentAction
]

instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes lighting schedules and settings for occupant comfort and energy savings."
    DTDFVocab:provides LightingScheduleAdjustmentAction
]

instance TaskPlanningMaintenanceService : DTDFVocab:Service [
    base:desc "Provides maintenance reminders and task planning based on equipment health data."
    DTDFVocab:provides MaintenanceReminderAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Delivers immersive 3D visualization of the campus building twin via Unreal Engine 5."
    DTDFVocab:provides VisualImmersionInsight
]

// C17: Insights
instance EnergySavingsInsight : DTDFVocab:Insight [
    base:desc "Insights on energy savings opportunities derived from real‑time monitoring."
]

instance OccupantComfortIndexInsight : DTDFVocab:Insight [
    base:desc "Insights into occupant comfort indices such as temperature, humidity, and CO₂ levels."
]

instance EnergyConsumptionPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted energy consumption trends based on historical data and predictive models."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for scheduling HVAC and lighting to balance comfort and efficiency."
]

instance VisualImmersionInsight : DTDFVocab:Insight [
    base:desc "Visualization insights indicating structural integrity and spatial awareness in the 3D twin."
]

// C17: Actions
instance HVACScheduleAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatically adjusts HVAC schedule to optimize energy usage while maintaining comfort."
    DTDFVocab:IsAutomatic true
]

instance LightingScheduleAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatically adjusts lighting schedule for optimal illumination and energy saving."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceReminderAction : DTDFVocab:Action [
    base:desc "Notifies facility managers of required maintenance tasks based on sensor data."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT generates control command messages (e.g., setpoint changes, actuator activation) which are forwarded by Ditto to Eclipse Hono and then delivered via MQTT to the physical controlling devices, closing the causal loop."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Live data ingestion occurs at sub‑second to 1‑minute intervals depending on sensor publish frequency; control loops operate at 1–10 Hz; simulation and optimization tasks run at real‑time or near‑real‑time based on the Unreal Engine rendering pipeline."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized DT hub (Ditto) connected to Hono for transport; multiple micro‑services (control logic, analytics, visualization) deployed as Docker containers; Unreal Engine runtime linked via WebSocket to display live state; all components coordinated through a model‑driven deployment pipeline."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Encompasses the full lifecycle: design (BIM creation), manufacturing/construction (BIM interpreted for on‑site commissioning), and operation (runtime monitoring and control). The DT aligns with the design‑time BIM, anchors to the constructed model, and evolves during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Odte metric used to quantify entanglement between DT and physical system; semantic drift monitored via diffs between BIM and runtime; validation via test suites against real sensor data and control response; uncertainty quantified through confidence intervals on forecasted energy consumption."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication established over MQTT/WS using TLS 1.2; Eclipse Hono routes MQTT messages to Ditto via HTTPS; Ditto exposes REST and WebSocket APIs for external services; on‑premise data nodes communicate over LAN with 802.11n or Ethernet."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Containerised deployment on Kubernetes cluster; Ditto and Hono run as stateful sets; Unreal Engine server runs on a dedicated GPU node; deployment files generated by MDE tooling and applied with Helm charts; cloud‑agnostic (supports on‑prem or public cloud)."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Exposes REST endpoints for external BIM servers, building management systems (BMS), and other DTs via standardized IoT protocols; enables bi‑directional data exchange with enterprise asset management systems."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Sensor data is owned by the building (PT) and is encrypted in transit (TLS) and at rest; DT provider implements role‑based access control; GDPR compliant data handling policies applied; no explicit data sharing without consent."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adheres to IFC4 for BIM, MQTT and OWS protocols for device communication, and OGC SensorThings API for sensor data representation; follows ISO 15926 for semantic interoperability where applicable."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "All MQTT traffic protected by TLS and client certificates; authentication via OAuth2/OIDC; command validation layer ensures control messages respect safety constraints (placeholders for emergency shutdown); role‑based access controls enforce least privilege; fail‑safe state machines implemented in the control logic to prevent unsafe actuator states."
]