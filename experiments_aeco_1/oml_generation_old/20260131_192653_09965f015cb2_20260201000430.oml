// C4: Physical-to-virtual interaction
instance BimEnrichedDeviceConfigurationData : DTDFVocab:DataTransmitted [
    base:desc "Semantically enriched device configurations extracted from BIM models to enable dynamic BCS representation in the Digital Twin"
    DTDFVocab:producedFrom BimEnrichedDeviceConfigurationSensor
]

instance OperationalBuildingMetricsData : DTDFVocab:DataTransmitted [
    base:desc "Real-time operational data from heterogeneous IoT/edge sensors including environmental conditions, occupancy patterns, and system performance metrics"
    DTDFVocab:producedFrom EnvironmentalSensor, OccupancySensor, SystemPerformanceSensor
]

instance BimGeometricData : DTDFVocab:DataTransmitted [
    base:desc "3D geometric representations and spatial metadata from BIM models serving as foundational geometric data for the Digital Twin"
    DTDFVocab:producedFrom BimGeometryExtractor
]

instance BimFunctionalMetadataData : DTDFVocab:DataTransmitted [
    base:desc "Functional metadata including behavioral models and control logic extracted from enriched BIM models for Digital Twin operations"
    DTDFVocab:producedFrom BimControlLogicExtractor
]

// C10: Models/Data
instance EnrichedBimModel : DTDFVocab:Model [
    base:desc "Semantically enriched BIM model incorporating geometric, spatial, and functional metadata for building components including structural elements, HVAC systems, and electrical panels"
    DTDFVocab:inputTo BimDataIntegrationEnabler, ModelTransformationEnabler
]

instance DeviceBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model representing control logic and operational characteristics of BCS devices derived from enriched BIM models"
    DTDFVocab:inputTo DittoDataSynchronizationEnabler, ControlLogicEnabler
]

instance AnalyticalPerformanceModel : DTDFVocab:Model [
    base:desc "Analytical model for performance simulation including energy consumption, structural integrity, and environmental impact assessments"
    DTDFVocab:inputTo SimulationIntegrationEnabler, OptimizationEnabler
]

instance OperationalDataStore : DTDFVocab:Data [
    base:desc "Centralized repository for real-time operational data synchronized between physical assets and Digital Twin including temperature, humidity, occupancy, and system performance metrics"
    DTDFVocab:fromData OperationalBuildingMetricsData
    DTDFVocab:inputTo DittoDataSynchronizationEnabler, RealTimeMonitoringService
]

instance GeometricDataStore : DTDFVocab:Data [
    base:desc "Structured storage of 3D geometric representations and spatial metadata from BIM models used for visualization and analysis"
    DTDFVocab:fromData BimGeometricData
    DTDFVocab:inputTo VisualizationService, StructuralAnalysisService
]

instance FunctionalMetadataStore : DTDFVocab:Data [
    base:desc "Repository of functional metadata including device configurations, control logic, and behavioral models extracted from enriched BIM"
    DTDFVocab:fromData BimFunctionalMetadataData
    DTDFVocab:inputTo ControlLogicEnabler, ModelDrivenDeploymentService
]

// C11: Enablers
instance DesignScienceResearchFramework : DTDFVocab:Enabler [
    base:desc "Design Science Research methodology framework enabling model-driven automation artifacts including requirements elicitation, prototyping, and experimentation phases for Digital Twin operationalization"
    DTDFVocab:enables ModelDrivenDeploymentService, QualityAssuranceService
]

instance EclipseHonoMiddleware : DTDFVocab:Enabler [
    base:desc "Eclipse Hono real-time data integration middleware enabling secure, scalable ingestion of IoT/edge sensor data with protocol translation (MQTT, CoAP) and authentication/authorization"
    DTDFVocab:enables RealTimeMonitoringService, DataQualityService
]

instance EclipseDittoMiddleware : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin-specific middleware facilitating event-driven data synchronization between physical and digital representations with CRUD operations and versioning support"
    DTDFVocab:enables DittoDataSynchronizationEnabler, ControlLogicEnabler
]

instance BimDataIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Modular extension point enabling integration of enriched BIM models with Digital Twin framework through standardized interfaces"
    DTDFVocab:enables VisualizationService, StructuralAnalysisService
]

instance ModelTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Model-to-model and model-to-text transformation engine automating generation of deployable Digital Twin artifacts from enriched BIM models"
    DTDFVocab:enables ModelDrivenDeploymentService
]

instance DittoDataSynchronizationEnabler : DTDFVocab:Enabler [
    base:desc "Event-driven data synchronization component enabling bidirectional communication between physical assets and Digital Twin representations"
    DTDFVocab:enables RealTimeMonitoringService, OperationalDataStore
]

instance ControlLogicEnabler : DTDFVocab:Enabler [
    base:desc "Modular service integration platform enabling deployment of custom control logic plugins for Digital Twin operations"
    DTDFVocab:enables ControlService
]

instance SimulationIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Standardized extension point enabling integration of third-party simulation engines for performance analysis and optimization"
    DTDFVocab:enables OptimizationService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Data-driven optimization framework enabling life-cycle-encompassing performance optimization through simulation and predictive analytics"
    DTDFVocab:enables OptimizationService, DecisionSupportService
]

instance QualityAssuranceService : DTDFVocab:Enabler [
    base:desc "Automated validation framework ensuring semantic consistency and operational compliance of Digital Twin artifacts"
    DTDFVocab:enables ModelDrivenDeploymentService
]

instance VersionControlService : DTDFVocab:Enabler [
    base:desc "Modular plugin integration platform enabling dynamic extension of Digital Twin capabilities through standardized interfaces"
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Live synchronization service providing continuous tracking of asset performance including energy consumption, structural integrity, and environmental conditions with anomaly detection"
    DTDFVocab:provides OperationalPerformanceInsight, AnomalyAlertAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Data-driven decision support service enabling predictive maintenance, energy optimization, and resource allocation optimization"
    DTDFVocab:provides MaintenanceRecommendationInsight, EnergyOptimizationInsight, ResourceAllocationInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Automated control service enabling closed-loop feedback for operational adjustments including HVAC setpoints and structural load balancing"
    DTDFVocab:provides OperationalAdjustmentAction, IoTDeviceActuationAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D/4D/5D visualization service providing real-time overlays of operational data including temperature maps and occupancy heatmaps"
    DTDFVocab:provides VisualizationInsight, SimulationPlaybackInsight
]

instance ModelDrivenDeploymentService : DTDFVocab:Service [
    base:desc "Automated deployment service enabling reproducible setup of Digital Twin environments with seamless BIM and operational system integration"
    DTDFVocab:provides DeploymentConfigurationInsight, ScalableDeploymentAction
]

instance StructuralAnalysisService : DTDFVocab:Service [
    base:desc "Structural performance analysis service enabling simulation of construction progress and failure scenarios"
    DTDFVocab:provides StructuralIntegrityInsight, FailureScenarioInsight
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Comprehensive decision support service integrating real-time monitoring, simulation, and predictive analytics for facility management"
