// C18: Environment/Component
instance AecoDigitalTwinEnvironment : DTDFVocab:Environment [
    base:desc "Centralized Digital Twin environment coordinating interactions between Building Control Engineers, Facility Managers, and DT Engineers"
    base:contains BimBasedInfrastructureSystem, OperationalBuildingSystem
]

instance BimBasedInfrastructureSystem : DTDFVocab:Component [
    base:desc "Semantically rich, object-based 3D infrastructure system incorporating geometric, spatial, and functional characteristics of building components"
    base:isContainedIn AecoDigitalTwinEnvironment
]

instance OperationalBuildingSystem : DTDFVocab:Component [
    base:desc "Dynamic operational environment including interconnected structural, mechanical, electrical, and facade systems requiring real-time monitoring and control"
    base:isContainedIn AecoDigitalTwinEnvironment
]

