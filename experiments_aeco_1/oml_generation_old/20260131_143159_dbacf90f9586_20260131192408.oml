// C3: Physical Sensing Components
instance EnvironmentalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled sensor capturing real-time temperature data across building infrastructure for DT analysis"
    DTDFVocab:producedData EnvironmentalTemperatureDataTransmitted
]

instance EnvironmentalHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled sensor capturing real-time humidity data across building infrastructure for DT analysis"
    DTDFVocab:producedData EnvironmentalHumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled sensor detecting occupancy status in building spaces for adaptive system control"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightingLevelSensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled sensor measuring ambient lighting levels for adaptive lighting system optimization"
    DTDFVocab:producedData LightingLevelDataTransmitted
]

instance EnergyConsumptionMeter : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled meter capturing real-time energy consumption data from building systems"
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

instance PostOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Specialized sensor capturing post-occupancy data used in BOREALIS project for adaptive lighting optimization"
    DTDFVocab:producedData PostOccupancyDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance EnvironmentalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalTemperatureSensor
]

instance EnvironmentalHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalHumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightingLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingLevelSensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionMeter
]

instance PostOccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PostOccupancySensor
]

// C10: Models/Data
instance BimStaticModel : DTDFVocab:Model [
    base:desc "Building Information Model representing geometric, spatial, and functional aspects of building infrastructure"
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance RuntimeOperationalData : DTDFVocab:Data [
    base:desc "Real-time operational data captured from IoT sensors including environmental conditions, occupancy, and energy metrics"
    DTDFVocab:fromData EnvironmentalTemperatureDataTransmitted, EnvironmentalHumidityDataTransmitted,
                 OccupancyDataTransmitted, LightingLevelDataTransmitted, EnergyConsumptionDataTransmitted,
                 PostOccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Embedded control logic models executing optimization algorithms and reinforcement learning policies"
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance ReinforcementLearningModel : DTDFVocab:Model [
    base:desc "Reinforcement learning model used in BOREALIS project for iterative optimization of building control policies"
    DTDFVocab:inputTo EclipseDittoEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono providing IoT data ingestion and real-time messaging for bidirectional communication between PT and DT"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, AutomatedCommissioningService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto managing digital twin instances, their metadata, and things with standardized APIs"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, AutomatedCommissioningService,
                 SimulationService, CustomServiceIntegrationService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 enabling rich, interactive 3D visualization of building infrastructure for immersive monitoring"
    DTDFVocab:enables RealTimeMonitoringService, SimulationService
]

instance ModelDrivenEngineeringEnabler : DTDFVocab:Enabler [
    base:desc "Model-driven engineering automating extraction of domain semantics from BIM models and generating runtime interfaces"
    DTDFVocab:enables CustomServiceIntegrationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real-time monitoring and visualization of building performance via Unreal Engine 5 immersive interfaces"
    DTDFVocab:provides BuildingPerformanceInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service providing predictive analytics and optimization for energy consumption and visual comfort using reinforcement learning"
    DTDFVocab:provides EnergyOptimizationInsight, VisualComfortInsight
    DTDFVocab:provides EnergyConsumptionAdjustmentAction, LightingSystemAdjustmentAction
]

instance AutomatedCommissioningService : DTDFVocab:Service [
    base:desc "Service enabling automated commissioning and bidirectional control of building systems like lighting and HVAC"
    DTDFVocab:provides SystemCommissioningInsight
    DTDFVocab:provides LightingSystemAdjustmentAction, HvacSystemAdjustmentAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service enabling simulation and scenario testing for evaluating design changes or operational adjustments"
    DTDFVocab:provides ScenarioSimulationInsight
]

instance CustomServiceIntegrationService : DTDFVocab:Service [
    base:desc "Service enabling custom service integration via standardized extension points for domain-specific plugins"
    DTDFVocab:provides CustomAnalyticsInsight
]

// C17: Insights/Actions
instance BuildingPerformanceInsight : DTDFVocab:Insight [
    base:desc "Real-time insights into overall building performance metrics and operational status"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics insights for optimizing energy consumption patterns"
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics insights for optimizing visual comfort conditions"
]

instance SystemCommissioningInsight : DTDFVocab:Insight [
    base:desc "Insights into automated commissioning status and system readiness"
]

instance ScenarioSimulationInsight : DTDFVocab:Insight [
    base:desc "Insights from simulated scenarios evaluating design changes or operational adjustments"
]

instance CustomAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Domain-specific analytics insights from integrated custom services"
]

instance EnergyConsumptionAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of energy consumption patterns based on predictive analytics"
    DTDFVocab:IsAutomatic true
]

instance LightingSystemAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting systems as demonstrated in TwinLight and BOREALIS projects"
    DTDFVocab:IsAutomatic true
]

instance HvacSystemAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of HVAC systems for optimal performance"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance BuildingControlSystemActuator : DTDFVocab:ActingComponent [
    base:desc "Building Control System incorporating sensors, actuators, and controllers embedded in building infrastructure"
]

instance LightingSystemActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting system actuators enabling bidirectional control as demonstrated in TwinLight and BOREALIS projects"
]

instance HvacSystemActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC system actuators enabling bidirectional control for optimal building performance"
]

// C1: Multiplicities/Architecture
instance ModularServiceOrientedArchitecture : DTDFVocab:Component [
    base:desc "Modular, service-oriented architecture enabling scalable deployment of twins for individual buildings or larger infrastructure systems"
]

instance FederatedDigitalTwinDeployment : DTDFVocab:Component [
    base:desc "Federated or distributed twins implementation for specific zones or campuses"
]

instance DynamicTwinEvolution : DTDFVocab:Component [
    base:desc "Dynamic evolution capability supporting integration of new services or components without full redeployment"
]

// C12: Twinning Process
instance ModelEnrichmentProcess : DTDFVocab:Component [
    base:desc "Model enrichment process extending BIM models with device metadata for runtime capabilities"
]

instance ModelValidationProcess : DTDFVocab:Component [
    base:desc "Model validation process ensuring enriched BIM models comply with domain-specific constraints"
]

instance ModelTransformationProcess : DTDFVocab:Component [
    base:desc "Model-to-model and model-to-text transformations generating runtime artifacts from BIM models"
]

instance ArtifactDeploymentProcess : DTDFVocab:Component [
    base:desc "Deployment process initializing DT with real-time data streams via Eclipse Hono/Ditto middleware"
]

instance RuntimeEvolutionProcess : DTDFVocab:Component [
    base:desc "Runtime evolution process enabling continuous synchronization with PT and service integration via extension points"
]

// C13: Environment
instance AeCoDigitalTwinEnvironment : DTDFVocab:Environment [
    base:desc "Digital Twin environment for AECO domain focusing on building infrastructures"
    base:contains BimStaticModel, RuntimeOperationalData, ControlLogicModel,
                 ReinforcementLearningModel, ModularServiceOrientedArchitecture,
                 FederatedDigitalTwinDeployment, DynamicTwinEvolution,
                 ModelEnrichmentProcess, ModelValidationProcess, ModelTransformationProcess,
                 ArtifactDeploymentProcess, RuntimeEvolutionProcess,
                 EclipseHonoEnabler, EclipseDittoEnabler, UnrealEngine5Enabler,
                 ModelDrivenEngineeringEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The virtual-to-physical interaction is enabled through **bidirectional communication channels** established via the **Eclipse Hono/Ditto middleware stack**. The DT system generates **control signals** (e.g., lighting adjustments, HVAC setpoints) based on real-time analytics or predefined optimization logic (e.g., reinforcement learning in **BOREALIS**) and transmits these signals back to the physical twin (PT) via the middleware. This interaction is supported by **standardized extension points** in the DT framework, allowing for modular integration of custom services (e.g., adaptive control strategies) that can dynamically adjust physical systems. The framework ensures low-latency communication to maintain synchronization between the virtual and physical domains."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT system operates primarily at **real-time synchronization scales**, aligning with the **millisecond-to-second** range for sensor data ingestion and control signal execution. The **BOREALIS** project’s reinforcement learning model iteratively refines control policies over **minutes-to-hours** based on post-occupancy feedback. While the system is designed for **low-latency interactions**, specific time-scale details (e.g., millisecond precision for certain operations) are not explicitly documented in the provided sources."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated as a **service-oriented architecture** with the following components:
  1. **BIM Model Repository**: Stores the **enriched BIM models** with device metadata (e.g., sensor configurations, control logic).
  2. **Middleware Layer (Eclipse Hono/Ditto)**: Facilitates **real-time data exchange** and **bidirectional communication** between the PT and DT.
  3. **DT Framework Core**: Manages **automated deployment**, **runtime synchronization**, and **service orchestration**.
  4. **Visualization Layer (Unreal Engine 5)**: Provides **interactive 3D interfaces** for facility managers and engineers.
  5. **Custom Service Plugins**: Integrated via **standardized extension points** to extend functionality (e.g., AI-driven optimization, predictive maintenance).
  The constellation is designed for **scalability** and **interoperability**, allowing DT instances to be deployed across **heterogeneous infrastructure systems** while maintaining consistency through **model-driven automation**."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT system spans the **entire building life cycle**, from **design and construction** to **operation and refurbishment**. Key stages include:
  1. **Design phase**: The DT is initialized using **BIM models** enriched with device metadata (e.g., sensors, actuators) to create a virtual representation of the **as-designed** building.
  2. **Construction phase**: The DT is updated to reflect **as-manufactured** deviations (e.g., material substitutions, spatial adjustments) via model-to-model transformations.
  3. **Operation phase**: The DT evolves to represent the **as-operated** building, incorporating real-time data from sensors and user feedback (e.g., occupancy patterns, energy usage) to optimize performance.
  4. **Refurbishment phase**: The DT supports **adaptive reconfiguration**, allowing for the integration of new systems (e.g., retrofitted sensors, upgraded controls) without disrupting operations. The framework ensures continuity across these phases through **automated model-driven deployment** and **runtime adaptability**."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
  1. **Semantic Alignment**: The DT maintains **high fidelity** by leveraging **BIM’s rich semantic model** to represent physical components and their relationships accurately.
  2. **Real-time Synchronization**: **Eclipse Hono/Ditto** ensures **low-latency data exchange**, minimizing divergence between the PT and DT.
  3. **Validation Mechanisms**: The **ODTE metric** quantifies the **entanglement** between the DT and PT, providing a measurable indicator of synchronization quality.
  4. **Uncertainty Management**: The framework incorporates **error handling** and **data normalization** to address inconsistencies (e.g., sensor failures, communication delays).
  5. **Verification and Testing**: The **Living Lab case study** demonstrates the DT’s validity through **real-world deployment**, where operational data is cross-validated with physical measurements. The framework also supports **simulation-based testing** to evaluate DT behavior under hypothetical scenarios."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin system uses **Eclipse Hono** and **Eclipse Ditto** as middleware for real-time data exchange, enabling **bidirectional communication** between the physical and virtual worlds. The connection is established through **standardized protocols** supported by Hono and Ditto, though specific protocols (e.g., MQTT, AMQP) are not detailed in the document. The framework ensures **low-latency synchronization** for operational control and analytics."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin framework supports **horizontal integration** through **standardized extension points** for modular service integration, enabling interoperability with external systems. While specific external systems (e.g., ERP, CMMS) or standards (e.g., OPC UA) are not detailed, the architecture is designed to accommodate **third-party services** and **data exchange protocols** for broader ecosystem compatibility."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin framework adheres to **AECO-specific standards**, primarily **Building Information Modeling (BIM)**, to ensure compatibility with existing industry practices. The use of **Model-driven Engineering (MDE)** principles standardizes the deployment process, though specific standards (e.g., IFC, ISO 19650) are not explicitly mentioned in the document."
]