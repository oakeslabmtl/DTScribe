// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modelled in BIM, capable of receiving control commands from the twin."
]

instance BCSController : DTDFVocab:ActingComponent [
    base:desc "Building Control System (BCS) controller modelled in BIM, orchestrates various building services."
]

// C3: Physical sensing components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor provisioned through TwinLight and BOREALIS projects, streams illumination levels."
    DTDFVocab:producedData LightingTelemetryTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor provisioned through TwinLight and BOREALIS projects, detects presence in spaces."
    DTDFVocab:producedData OccupancyTelemetryTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor (temperature, humidity, CO₂) provisioned through TwinLight and BOREALIS projects."
    DTDFVocab:producedData EnvironmentalTelemetryTransmitted
]

// C4: Physical-to-virtual interaction
instance LightingTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance OccupancyTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnvironmentalTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C10: Models/Data
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "BIM geometry model representing the 3‑D shape of the building."
    DTDFVocab:inputTo UnrealEngine5Enabler
]

instance SpatialTopologyModel : DTDFVocab:Model [
    base:desc "Spatial topology model describing rooms, floors, and zones derived from BIM."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance DeviceMetadataModel : DTDFVocab:Model [
    base:desc "Metadata model enriching BIM with device identifiers, capabilities, and tenant info."
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance RuntimeDeviceModel : DTDFVocab:Model [
    base:desc "Runtime model generated by model‑driven transformations, maps live devices to twin entities."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Model of reinforcement‑learning control policies (BOREALIS) for lighting optimization."
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance LightingTelemetryData : DTDFVocab:Data [
    base:desc "Live illumination level data streamed from LightingSensor."
    DTDFVocab:fromData LightingTelemetryTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance OccupancyTelemetryData : DTDFVocab:Data [
    base:desc "Live occupancy status data streamed from OccupancySensor."
    DTDFVocab:fromData OccupancyTelemetryTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance EnvironmentalTelemetryData : DTDFVocab:Data [
    base:desc "Live environmental measurements (temperature, humidity, CO₂) streamed from EnvironmentalSensor."
    DTDFVocab:fromData EnvironmentalTelemetryTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides secure, scalable device connectivity for telemetry ingestion."
    DTDFVocab:enables RealTimeMonitoringService, LightingControlOptimizationService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital twin entities, state synchronization, and command routing."
    DTDFVocab:enables RealTimeMonitoringService, Interactive3DVisualizationService, PredictiveAnalyticsService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders immersive 3‑D visualizations of the twin."
    DTDFVocab:enables Interactive3DVisualizationService
]

instance MDEPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline automates generation and deployment of runtime artifacts."
    DTDFVocab:enables PredictiveAnalyticsService, LightingControlOptimizationService
]

instance ExtensionPointEnabler : DTDFVocab:Enabler [
    base:desc "Standardized extension points allow modular addition of new services."
    DTDFVocab:enables SimulationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of sensor telemetry and system health."
    DTDFVocab:provides EnergyConsumptionOptimizationInsight, LightingComfortBalancingInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Delivers interactive 3‑D visualization of the building via Unreal Engine 5."
    DTDFVocab:provides LightingComfortBalancingInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Runs predictive analytics on historical and live data to forecast maintenance needs."
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance LightingControlOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes lighting control using reinforcement‑learning policies (BOREALIS)."
    DTDFVocab:provides EnergyConsumptionOptimizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Enables simulation of building operations for scenario testing."
    DTDFVocab:provides EnergyConsumptionOptimizationInsight
]

// C17: Insights
instance EnergyConsumptionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending adjustments to reduce overall energy consumption."
]

instance LightingComfortBalancingInsight : DTDFVocab:Insight [
    base:desc "Insight balancing illumination levels for occupant comfort while saving energy."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Insight predicting component degradation to schedule proactive maintenance."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional control commands generated by the twin are sent back through the same Hono/Ditto middleware to the actuators, enabling live actuation of building services."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, event‑driven real‑time synchronization: sensor data are ingested and made available to the twin as soon as they are generated, enabling near‑instantaneous updates between physical and virtual worlds."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture where the DT Framework acts as a central hub linking enriched BIM models, the Hono/Ditto configurator, and visualization components, with defined extension points for custom services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the design stage (BIM model), construction/commissioning (device configuration), and operational stage (runtime sensor data and control), thus covering as‑designed and as‑operated representations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Entanglement quality is measured with the Overall Digital Twin Entanglement (ODTE) metric to assess how faithfully the twin reflects its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time data exchange is realized through Eclipse Hono (device gateway) and Eclipse Ditto (digital twin server), which handle bidirectional communication between physical devices and the virtual model."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework leverages BIM standards as the semantic basis and provides standardized extension points; it also follows industry‑wide DT integration practices through Hono and Ditto."
]