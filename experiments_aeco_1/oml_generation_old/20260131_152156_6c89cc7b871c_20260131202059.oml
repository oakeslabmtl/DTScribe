    base:desc "Data acquisition system for HVAC system operational parameters in building facilities"
]

instance LightingControlSensor : DTDFVocab:SensingComponent [
    base:desc "Data acquisition system for lighting control system performance metrics"
]

instance EnergyManagementSensor : DTDFVocab:SensingComponent [
    base:desc "Data acquisition system for energy management system efficiency metrics"
]

instance ThermalSimulationModel : DTDFVocab:SensingComponent [
    base:desc "Digital representation of thermal processes in building structures for simulation purposes"
]

instance AirflowSimulationModel : DTDFVocab:SensingComponent [
    base:desc "Digital representation of airflow dynamics in indoor environments for simulation purposes"
]

instance EnergyFlowSimulationModel : DTDFVocab:SensingComponent [
    base:desc "Digital representation of energy flow patterns in building systems for simulation purposes"
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndoorTemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndoorHumiditySensor
]

instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualitySensor
]

instance HVACDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACControlSensor
]

instance LightingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingControlSensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyManagementSensor
]

instance SimulationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ThermalSimulationModel, AirflowSimulationModel, EnergyFlowSimulationModel
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature readings from indoor environmental monitoring sensors"
    DTDFVocab:fromData TemperatureDataTransmitted
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Real-time humidity readings from indoor environmental monitoring sensors"
    DTDFVocab:fromData HumidityDataTransmitted
]

instance AirQualityData : DTDFVocab:Data [
    base:desc "Real-time air quality measurements from indoor environmental sensors"
    DTDFVocab:fromData AirQualityDataTransmitted
]

instance HVACData : DTDFVocab:Data [
    base:desc "Operational data from HVAC control systems for energy management"
    DTDFVocab:fromData HVACDataTransmitted
]

instance LightingData : DTDFVocab:Data [
    base:desc "Performance metrics from lighting control systems"
    DTDFVocab:fromData LightingDataTransmitted
]

instance EnergyData : DTDFVocab:Data [
    base:desc "Energy consumption metrics from energy management systems"
    DTDFVocab:fromData EnergyDataTransmitted
]

instance SimulationData : DTDFVocab:Data [
    base:desc "Simulated environmental parameters from building simulation models"
    DTDFVocab:fromData SimulationDataTransmitted
]

// C10: Models/Data
instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "3D BIM-based computational framework for semantically rich representation of building components"
    DTDFVocab:inputTo BIMEnabler
]

instance EnvironmentalSimulationModel : DTDFVocab:Model [
    base:desc "Model-driven engineering framework for accurate thermal, airflow, and energy flow simulations"
    DTDFVocab:inputTo SimulationEnabler
]

instance RealTimeDataIntegrationModel : DTDFVocab:Model [
    base:desc "Model for real-time synchronization between physical assets and digital twins using Eclipse Hono and Ditto protocols"
    DTDFVocab:inputTo DataSyncEnabler
]

// C11: Enablers
instance BIMEnabler : DTDFVocab:Enabler [
    base:desc "BIM-based platform for semantically rich object-oriented 3D representations of building components"
    DTDFVocab:enables BuildingBIMModel
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Model-driven engineering framework for accurate simulation representations of physical processes"
    DTDFVocab:enables EnvironmentalSimulationModel
]

instance DataSyncEnabler : DTDFVocab:Enabler [
    base:desc "Real-time data synchronization framework using Eclipse Hono and Ditto protocols for live synchronization"
    DTDFVocab:enables RealTimeDataIntegrationModel
]

instance EclipseBasyxPlatform : DTDFVocab:Enabler [
    base:desc "Open-source platform for real-time data processing and edge computing in digital twin applications"
    DTDFVocab:enables MonitoringService, OptimizationService, PredictionService, ControlService
]

instance ItwinJSLibrary : DTDFVocab:Enabler [
    base:desc "JavaScript library for 3D modeling, data integration, and visualization of infrastructure digital twins"
    DTDFVocab:enables VisualizationService, ResearchSupportService
]

instance ModelDrivenEngineeringFramework : DTDFVocab:Enabler [
    base:desc "Framework for automated generation of digital twin models from high-level specifications"
    DTDFVocab:enables BuildingBIMModel, EnvironmentalSimulationModel
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "General-purpose simulation tool for validating digital twin models against real-world data"
    DTDFVocab:inputTo EnvironmentalSimulationModel
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time and historical data collection of indoor environmental parameters (temperature, humidity, air quality)"
    DTDFVocab:provides TemperatureInsight, HumidityInsight, AirQualityInsight, AnomalyDetectionAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Model-based optimization of energy systems, HVAC settings, and lighting schedules"
    DTDFVocab:provides HVACParameterTuningInsight, LightingScheduleOptimizationInsight, PredictiveMaintenanceRecommendationAction
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Forecasting future states of indoor environments using machine learning and simulation models"
    DTDFVocab:provides TemperatureForecastInsight, HumidityForecastInsight, EnergyDemandForecastInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Automated control of physical systems (HVAC, lighting) based on digital twin predictions"
    DTDFVocab:provides DynamicEnvironmentAdjustmentAction, OccupancyBasedControlAction, AdaptiveControlStrategyAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D/4D visualizations of the physical twin for real-time data exploration"
    DTDFVocab:provides GeospatialSensorMappingInsight, SimulationVisualizationInsight, CollaborativeViewingAction
]

instance ResearchSupportService : DTDFVocab:Service [
    base:desc "Research-specific functionalities for controlled experiments and data-driven hypothesis testing"
    DTDFVocab:provides ExperimentPlanningAction, DataIntegrationAction, ReproducibilityFrameworkAction
]

