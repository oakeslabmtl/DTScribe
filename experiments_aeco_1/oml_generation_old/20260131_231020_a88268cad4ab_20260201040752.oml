// Environment representing the single AECO domain building
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains BuildingAsset
]

// Component: The physical building with its enriched BIM model
instance BuildingAsset : DTDFVocab:Component [
    base:desc "Single building with BIM model enriched with sensors, actuators, and controllers"
]

// Sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the building, publishing telemetry via Eclipse Hono to the digital twin"
    DTDFVocab:producedData TemperatureTelemetry
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor embedded in the building, publishing telemetry via Eclipse Hono to the digital twin"
    DTDFVocab:producedData HumidityTelemetry
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Energy consumption sensor embedded in the building, publishing telemetry via Eclipse Hono to the digital twin"
    DTDFVocab:producedData EnergyTelemetry
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the building, publishing telemetry via Eclipse Hono to the digital twin"
    DTDFVocab:producedData OccupancyTelemetry
]

// Acting component: lighting fixture actuator
instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture actuator exposing on/off state, brightness percentage, and color temperature, controlled via DittoController nodes through Hono"
]

// Data transmitted via Hono edge adapter
instance TemperatureTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
    base:desc "Temperature data transmitted from sensor through Hono; filtered and unit‑normalized by the edge adapter"
]

instance HumidityTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
    base:desc "Humidity data transmitted from sensor through Hono; filtered and unit‑normalized by the edge adapter"
]

instance EnergyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
    base:desc "Energy consumption data transmitted from sensor through Hono; filtered and unit‑normalized by the edge adapter"
]

instance OccupancyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
    base:desc "Occupancy data transmitted from sensor through Hono; filtered and unit‑normalized by the edge adapter"
]

// Processed data stored in Ditto
instance TemperatureData : DTDFVocab:Data [
    base:desc "Validated temperature data, stored in Ditto after schema enforcement"
    DTDFVocab:inputTo HonoEdgeAdapter
    DTDFVocab:fromData TemperatureTelemetry
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Validated humidity data, stored in Ditto after schema enforcement"
    DTDFVocab:inputTo HonoEdgeAdapter
    DTDFVocab:fromData HumidityTelemetry
]

instance EnergyData : DTDFVocab:Data [
    base:desc "Validated energy consumption data, stored in Ditto after schema enforcement"
    DTDFVocab:inputTo HonoEdgeAdapter
    DTDFVocab:fromData EnergyTelemetry
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Validated occupancy data, stored in Ditto after schema enforcement"
    DTDFVocab:inputTo HonoEdgeAdapter
    DTDFVocab:fromData OccupancyTelemetry
]

// Enablers (middleware and engineering tools)
instance HonoEdgeAdapter : DTDFVocab:Enabler [
    base:desc "Hono edge adapter performing data preprocessing: filtering duplicate readings, normalizing units"
    DTDFVocab:enables MonitoringService, PredictionService
]

instance DittoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto instance managing state validation, schema enforcement, and change streams for real‑time synchronization"
    DTDFVocab:enables ControlService, OptimizationService
]

instance MDETransformer : DTDFVocab:Enabler [
    base:desc "MDE tool extracting structured representations from enriched BIM, generating runtime twin artefacts"
    DTDFVocab:enables VisualizationService
]

// Models
instance BIMModel : DTDFVocab:Model [
    base:desc "Enriched IFC/BIM model containing building control system device metadata"
    DTDFVocab:inputTo MDETransformer
]

instance MDEConversionModel : DTDFVocab:Model [
    base:desc "Runtime twin artefacts (DittoDevice twins and connections) generated from BIM by MDE"
    DTDFVocab:inputTo MDETransformer
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous acquisition of environmental and equipment data mapped onto the BIM‑based digital twin"
    DTDFVocab:provides TemperatureInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Execution of actuated commands via twin control logic, enabling remote operation of physical infrastructure"
    DTDFVocab:provides ActuateLightingAction
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Lightweight predictive analytics on real‑time data to forecast component failures or occupancy trends"
    DTDFVocab:provides FailurePredictionInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Data‑driven analysis recommending energy‑saving strategies and improving system efficiency"
    DTDFVocab:provides EnergySavingRecommendationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive dashboards overlaying twin status onto the BIM model for inspection and interaction"
    DTDFVocab:provides BIMOverlayAction
]

// Insights
instance TemperatureInsight : DTDFVocab:Insight [
    base:desc "Insight derived from processed temperature data for building health monitoring"
]

instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Prediction of component failures based on real‑time sensor analytics"
]

instance EnergySavingRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for energy‑saving strategies derived from data analysis"
]

// Actions
instance ActuateLightingAction : DTDFVocab:Action [
    base:desc "Command to set lighting fixture state, brightness, or color temperature remotely"
    DTDFVocab:IsAutomatic false
]

instance BIMOverlayAction : DTDFVocab:Action [
    base:desc "Interactive visualization action to overlay twin status onto the BIM model in the rendering engine"
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time data exchange between the physical building and its digital twin, enabling synchronization as soon as sensor or BIM updates become available. The system does not specify explicit polling intervals or latency thresholds, but the real‑time data exchange capabilities imply sub‑second to real‑time performance, ensuring that the virtual replica reflects the state of the physical asset with minimal delay."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a modular architecture pattern with a clear separation of concerns. Core components include a central hub that facilitates bidirectional data exchange, runtime configuration management for dynamic adaptation, and standardized extension points for service integration. Resource management is performed by the hub, which orchestrates sensor data ingestion, analytics services, and visualization modules. System‑wide coordination relies on the hub’s orchestration layer that manages event routing, data flow, and versioning of models."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin life cycle is stratified into (1) **Design & Enrichment** where Building Control Engineers embed sensors, actuators, and controllers into BIM models, extending the BIM geometry with functional metadata; (2) **Transformation** where Model‑Driven Engineering (MDE) principles automatically extract structured representations from the enriched BIM, producing deployable DT artifacts while preserving semantic integrity; (3) **Automated Deployment** enabled by requirement R2, which reduces manual configuration and ensures a reproducible, version‑controlled DT setup; (4) **Runtime Operation** featuring continuous real‑time data exchange via Eclipse Hono and Ditto (requirement R3), interactive visualization for monitoring and control, and ongoing synchronization between physical assets and the twin; and (5) **Evolution & Governance** where the modular architecture (requirement R4) and defined extension points allow the twin to scale, incorporate new services, and adhere to governance practices that coordinate model updates, runtime policies, and change management."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is guaranteed by Eclipse Ditto’s policy‑based validation engine, which applies schema constraints on sensor values (ranges, units) and verifies actuator command integrity before execution. Validation errors trigger immediate message rejection and audit logging. Fault tolerance is achieved via Eclipse Hono’s at‑least‑once delivery semantics and Ditto’s event persistence, replaying lost updates to restore consistency. Continuous synchronization between digital twins and physical devices is monitored by heartbeat messages; discrepancies trigger corrective actions or escalated alerts. An integrated quality assurance pipeline checks for version drift between the BIM source and runtime twins, applying automated diffing of device metadata to detect unauthorized modifications."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical infrastructure relies on Eclipse Hono as the message broker and Eclipse Ditto for twin representation, providing a bidirectional, publish/subscribe communication path. The system is designed to support real‑time data transfer, but specific bandwidth, latency, or redundancy mechanisms are not detailed in the documents. Network topology is conceptualized as a layered middleware system, with Hono routing messages from physical devices to Ditto’s twin service. Security is handled by the standard authentication and authorization mechanisms offered by both Hono and Ditto, although explicit security protocols are not named."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through data exchange between the Digital Twin and BIM models, sensor networks, and AI/analytics services. The design accounts for interoperability across heterogeneous systems, enabling the DT to ingest BIM representation during deployment and maintain real‑time synchronization with sensor feeds. The framework is open to integrating with other enterprise systems and additional Digital Twins via standard interfaces exposed by the central hub, although specific protocols are not defined within the provided documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture adopts Eclipse Ditto and Eclipse Hono to meet real‑time connectivity requirements; these open‑source frameworks provide standardized messaging support (MQTT, HTTP, AMQP) and a JSON‑based twin model, thereby ensuring interoperability with industrial and IoT ecosystems. The framework’s model‑driven approach also aligns with BIM (IFC) semantics, offering a pathway to compliance with AECO primary data standards and fostering integration with existing digital‑primed workflows."
]