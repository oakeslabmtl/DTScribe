// C3: Physical sensing components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental light sensor whose metadata are stored in the BIM model and whose data are streamed through Eclipse Hono"
    DTDFVocab:producedData LightDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental temperature sensor whose metadata are stored in the BIM model and whose data are streamed through Eclipse Hono"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy sensor (e.g., motion/occupancy detector) whose metadata are stored in the BIM model and whose data are streamed through Eclipse Hono"
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance LightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Data
instance LightData : DTDFVocab:Data [
    base:desc "Real‑time light intensity measurements from LightSensor"
    DTDFVocab:fromData LightDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature measurements from TemperatureSensor"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy status from OccupancySensor"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// C10: Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Static BIM model enriched with device metadata (device ID, tenant, endpoint) for lighting control components"
    DTDFVocab:inputTo ModelDrivenPipelineEnabler, EclipseDittoEnabler
]

instance RuntimeTwinModel : DTDFVocab:Model [
    base:desc "Runtime twin model stored in Eclipse Ditto, representing current state of building systems"
    DTDFVocab:inputTo EclipseDittoEnabler, UnrealEngine5Enabler
]

// C11: Enablers
instance BIMAuthoringToolEnabler : DTDFVocab:Enabler [
    base:desc "BIM authoring tools used to create and enrich the static building model"
    DTDFVocab:enables ModelingService
]

instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides IoT connectivity for real‑time sensor data ingestion"
    DTDFVocab:enables MonitoringDashboardService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto hosts the digital twin, processes incoming data and maintains twin state"
    DTDFVocab:enables MonitoringDashboardService, PredictiveAnalyticsService, EnergyOptimizationService, SimulationService
]

instance ModelDrivenPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation pipeline validates enriched BIM and generates Hono/Ditto configurations"
    DTDFVocab:enables ModelingService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders the 3‑D interactive visualization of the digital twin"
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards displaying current energy consumption and sensor status"
    DTDFVocab:provides RealTimeEnergyConsumptionInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3‑D interactive visualization in Unreal Engine 5 for facility managers"
    DTDFVocab:provides RealTimeEnergyConsumptionInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics that forecast lighting demand based on occupancy and usage patterns"
    DTDFVocab:provides PredictedLightingDemandInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy optimisation service that recommends and executes illumination set‑points"
    DTDFVocab:provides AdjustIlluminationAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance for scenario analysis"
    DTDFVocab:provides PredictedLightingDemandInsight
]

instance ModelingService : DTDFVocab:Service [
    base:desc "Model management service that handles BIM enrichment and pipeline execution"
    DTDFVocab:provides ModelManagementInsight
]

// C17: Insights
instance RealTimeEnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight into current energy consumption patterns of the building"
]

instance PredictedLightingDemandInsight : DTDFVocab:Insight [
    base:desc "Insight predicting future lighting demand based on occupancy and usage trends"
]

instance ModelManagementInsight : DTDFVocab:Insight [
    base:desc "Insight regarding the status and validity of enriched BIM models"
]

// C17: Actions
instance AdjustIlluminationAction : DTDFVocab:Action [
    base:desc "Action to adjust illumination levels of dimmable luminaires via lighting control devices"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance DimmableLuminaireActingComponent : DTDFVocab:ActingComponent [
    base:desc "Dimmable luminaire modelled as a BIM object, enriched with device ID, tenant and endpoint metadata"
]

instance LightingSwitchActingComponent : DTDFVocab:ActingComponent [
    base:desc "Lighting switch modelled as a BIM object, enriched with device ID, tenant and endpoint metadata"
]

instance LightingControllerActingComponent : DTDFVocab:ActingComponent [
    base:desc "Lighting controller (e.g., DALI gateway) modelled as a BIM object, enriched with device ID, tenant and endpoint metadata"
]

// Environment composition
instance BuildingLivingLabEnvironment : DTDFVocab:Environment [
    base:desc "Living Lab building environment containing sensors, actuators, models and twin infrastructure"
    base:contains LightSensor, TemperatureSensor, OccupancySensor,
                DimmableLuminaireActingComponent, LightingSwitchActingComponent, LightingControllerActingComponent,
                EnrichedBIMModel, RuntimeTwinModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT issues control commands (e.g., set lighting level, turn fixtures on/off) which are sent from the Ditto twin to Eclipse Hono and routed to the corresponding lighting actuators in the building, achieving bidirectional synchronization."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data exchange and command propagation occur continuously, supporting near‑real‑time synchronization between physical sensors/actuators and the digital twin; the system is designed to process incoming sensor streams and emit control actions with latency low enough for live operational monitoring."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where the enriched BIM model feeds a configurator that generates Hono/Ditto configurations; Ditto maintains the twin state, Hono handles messaging, and Unreal Engine provides the user interface; services can be added via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers design (BIM creation), construction (device commissioning) and operation (runtime monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric is used to quantify the fidelity between physical asset and its twin; model validation performed before deployment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical devices publish sensor data to Eclipse Hono, which forwards it to Eclipse Ditto where the twin state is updated. Control commands originate in Ditto and are sent back through Hono to the devices, establishing a bidirectional technical connection between PT and DT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework leverages BIM standards for building information, open IoT communication standards via Eclipse Hono, and standardized extension points for service integration."
]