// C2: Acting Components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator modeled in the BIM model, able to receive control commands from the twin"
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled as a device in the BIM model, receives set‑point commands from the twin"
]

instance BuildingController : DTDFVocab:ActingComponent [
    base:desc "Building control system controller represented in the BIM model, orchestrates actuators"
]

// C3: Physical sensing components
instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor (temperature, humidity, CO2) embedded in the BIM model providing live measurements"
    DTDFVocab:producedData EnvironmentalSensorDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the BIM model detecting presence and space usage"
    DTDFVocab:producedData OccupancySensorDataTransmitted
]

instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor embedded in the BIM model measuring illumination levels"
    DTDFVocab:producedData LightingSensorDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance EnvironmentalSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance OccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

// C5: Data (live measurements)
instance EnvironmentalMeasurementData : DTDFVocab:Data [
    base:desc "Live environmental measurements (temp, humidity, CO2) streamed from sensors"
    DTDFVocab:fromData EnvironmentalSensorDataTransmitted
    DTDFVocab:inputTo HonoGateway, DittoPlatform
]

instance OccupancyMeasurementData : DTDFVocab:Data [
    base:desc "Live occupancy counts streamed from occupancy sensors"
    DTDFVocab:fromData OccupancySensorDataTransmitted
    DTDFVocab:inputTo HonoGateway, DittoPlatform
]

instance LightingMeasurementData : DTDFVocab:Data [
    base:desc "Live illumination levels streamed from lighting sensors"
    DTDFVocab:fromData LightingSensorDataTransmitted
    DTDFVocab:inputTo HonoGateway, DittoPlatform
]

// C10: Models/Data (static BIM and transformation)
instance StaticBIMModel : DTDFVocab:Model [
    base:desc "Static BIM model containing geometry and spatial relationships of the Living Lab building"
    DTDFVocab:inputTo ModelTransformationEngine
]

instance RuntimeArtifactModel : DTDFVocab:Model [
    base:desc "Model‑driven transformation output describing device metadata and control logic generated from the BIM model"
    DTDFVocab:inputTo DittoPlatform
]

// C11: Enablers
instance BIMAuthoringTool : DTDFVocab:Enabler [
    base:desc "Tooling used to author and enrich the BIM model with device and middleware metadata"
]

instance ModelTransformationEngine : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation pipeline that converts the enriched BIM model into runtime artifacts"
    DTDFVocab:enables DittoPlatform
]

instance HonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono protocol gateway translating sensor MQTT/CoAP streams to Eclipse Ditto"
    DTDFVocab:enables DittoPlatform
]

instance DittoPlatform : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital‑twin platform ingesting live sensor streams and hosting twin state"
    DTDFVocab:enables RealTimeMonitoringDashboard, Interactive3DVisualization, PredictiveAnalyticsService, EnergyOptimizationService, DecisionSupportService
]

instance UnrealEngine5VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime providing immersive 3‑D interactive visualization of the twin"
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards presenting live building KPIs"
    DTDFVocab:provides EnergyConsumptionTrendInsight
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "3‑D interactive visualization of the building in Unreal Engine 5"
    DTDFVocab:provides ComfortLevelEvaluationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics that forecast energy use and comfort based on sensor data"
    DTDFVocab:provides OptimizedLightingSetpointInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that computes energy‑saving control set‑points"
    DTDFVocab:provides OptimizedLightingSetpointInsight
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Decision‑support service delivering actionable recommendations to facility managers"
    DTDFVocab:provides RecommendLightingSetpointAction
]

// C17: Insights
instance EnergyConsumptionTrendInsight : DTDFVocab:Insight [
    base:desc "Insight on energy consumption trends derived from aggregated sensor data"
]

instance ComfortLevelEvaluationInsight : DTDFVocab:Insight [
    base:desc "Insight evaluating occupant comfort levels using temperature, humidity and occupancy data"
]

instance OptimizedLightingSetpointInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting optimal lighting set‑points for energy efficiency while maintaining comfort"
]

// C17: Actions
instance RecommendLightingSetpointAction : DTDFVocab:Action [
    base:desc "Action recommending a lighting control set‑point to the facility manager"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command flow from the twin to physical actuators through the same Hono/Ditto integration, allowing the twin to issue control set-points or actuation commands to the building control system."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real-time synchronization (sub-second to second-scale) between physical sensor updates and twin state updates, as enabled by the Hono/Ditto real-time data pipeline."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service-oriented architecture where the DT framework acts as a central hub linking enriched BIM models, the Hono/Ditto middleware, visualization components, and custom services; components communicate through defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin spans the design, construction, and operational phases of the building lifecycle, supporting scenarios from as-designed (BIM) through as-built to as-operated representations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed using the Overall Digital Twin Entanglement (ODTE) metric; model validation is performed before deployment; continuous synchronization mitigates semantic drift between the BIM model and the physical asset."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Technical connectivity is achieved using Eclipse Hono for inbound device telemetry and command channels and Eclipse Ditto for twin state storage and bidirectional synchronization, forming the real‑time communication backbone."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework standardizes BIM semantics through a modeling methodology, uses standardized extension points, and aligns with established BIM and model-driven engineering standards for interoperability."
]