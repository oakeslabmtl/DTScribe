    base:desc "Dynamic recommendation engine suggesting energy optimization measures based on real-time consumption data"
    DTDFVocab:IsAutomatic false
]

instance SpatialAwarenessInsight : DTDFVocab:Insight [
    base:desc "3D/4D spatial representation of building systems enabling facility managers to visualize operational states"
]

instance UserInteractionAction : DTDFVocab:Action [
    base:desc "Direct manipulation interface allowing facility managers to interact with digital twin representations"
    DTDFVocab:IsAutomatic false
]

instance MaintenancePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance analysis providing failure probability forecasts for building components"
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Automated maintenance scheduling recommendations based on predictive analytics"
    DTDFVocab:IsAutomatic true
]

