// C2: Acting Components
instance HVACControlValve : DTDFVocab:ActingComponent [
    base:desc "Building control actuator integrated within BIM environment for HVAC system regulation, configured via model-driven engineering principles with standardized extension points for safety constraints and runtime synchronization"
]

instance MotorizedShadeActuator : DTDFVocab:ActingComponent [
    base:desc "Device modeling capability within BIM for motorized window shades, enabling remote control through standardized interfaces with implicit safety mechanisms via framework's modular architecture"
]

instance SecuritySystemController : DTDFVocab:ActingComponent [
    base:desc "Building control component for security systems modeled within BIM, supporting remote operation through the digital twin interface with implicit fail-safe mechanisms"
]

// C3: Physical Sensing Components
instance BuildingEnvironmentTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "BIM-integrated sensor for real-time environmental temperature monitoring with generalized measurement capabilities for synchronization with digital twin"
    DTDFVocab:producedData BuildingEnvironmentTemperatureDataTransmitted
]

instance BuildingEnvironmentHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "BIM-enriched sensor for humidity monitoring with real-time data acquisition capabilities for digital twin synchronization"
    DTDFVocab:producedData BuildingEnvironmentHumidityDataTransmitted
]

instance BuildingEnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor integrated within BIM framework for real-time energy consumption monitoring with model-driven data collection mechanisms"
    DTDFVocab:producedData BuildingEnergyConsumptionDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance BuildingEnvironmentTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingEnvironmentTemperatureSensor
]

instance BuildingEnvironmentHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingEnvironmentHumiditySensor
]

instance BuildingEnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingEnergyConsumptionSensor
]

// C10: Models/Data
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "Foundational BIM model augmented with device-specific configurations, control logic, and semantic annotations for BCS components as input to model-driven engineering workflows"
    DTDFVocab:inputTo BIMDeviceModelingTool, ModelDrivenEngineeringFramework
]

instance BehavioralControlModel : DTDFVocab:Model [
    base:desc "Model representing building control system behaviors including sensor-actuator interactions and control logic defined within BIM environment"
    DTDFVocab:inputTo ControlLogicSimulationEngine, DeviceOrchestrationService
]

instance AnalyticalPredictionModel : DTDFVocab:Model [
    base:desc "Custom analytics model integrated via modular architecture for predictive maintenance, energy optimization, or occupancy forecasting"
    DTDFVocab:inputTo CustomAnalyticsPlugin
]

instance BuildingEnvironmentTemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature data stream from physical building systems synchronized with digital twin via Eclipse Hono/Ditto protocols"
    DTDFVocab:fromData BuildingEnvironmentTemperatureDataTransmitted
    DTDFVocab:inputTo RealTimeVisualizationEngine
]

instance BuildingEnvironmentHumidityData : DTDFVocab:Data [
    base:desc "Real-time humidity data stream processed through model-driven framework for environmental condition monitoring"
    DTDFVocab:fromData BuildingEnvironmentHumidityDataTransmitted
    DTDFVocab:inputTo RealTimeVisualizationEngine
]

instance BuildingEnergyConsumptionData : DTDFVocab:Data [
    base:desc "Continuous energy consumption metrics transmitted from physical building systems to digital twin for operational analysis"
    DTDFVocab:fromData BuildingEnergyConsumptionDataTransmitted
    DTDFVocab:inputTo EnergyOptimizationService
]

// C11: Enablers
instance BIMDeviceModelingTool : DTDFVocab:Enabler [
    base:desc "Toolset enabling Building Control Engineers to define and configure sensors, actuators, and controllers directly within BIM environment"
    DTDFVocab:enables DeviceOrchestrationService
]

instance ModelDrivenEngineeringFramework : DTDFVocab:Enabler [
    base:desc "Core framework implementing MDE principles to transform enriched BIM models into deployable DT artifacts with automated validation"
    DTDFVocab:enables RuntimeSynchronizationService
]

instance EclipseHonoIntegration : DTDFVocab:Enabler [
    base:desc "Real-time data exchange protocol enabling continuous bidirectional communication between physical BCS components and digital twin"
    DTDFVocab:enables RealTimeDataStreamingService
]

instance ControlLogicSimulationEngine : DTDFVocab:Enabler [
    base:desc "Engine for simulating and validating control logic configurations before deployment to physical systems"
    DTDFVocab:enables ControlLogicValidationService
]

instance CustomAnalyticsPlugin : DTDFVocab:Enabler [
    base:desc "Modular extension point for integrating custom analytics services including predictive maintenance and energy optimization algorithms"
    DTDFVocab:enables EnergyOptimizationService, PredictiveMaintenanceService
]

instance RealTimeVisualizationEngine : DTDFVocab:Enabler [
    base:desc "Immersive 3D/4D visualization engine integrating real-time data streams into BIM-based interfaces for facility managers"
    DTDFVocab:enables InteractiveVisualizationService
]

// C6: Services
instance DeviceOrchestrationService : DTDFVocab:Service [
    base:desc "Service enabling Building Control Engineers to deploy and reconfigure sensors, actuators, and controllers directly within BIM environment"
    DTDFVocab:provides DeviceConfigurationInsight, ControlLogicAction
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous state visualization and anomaly detection service for facility managers based on real-time data synchronization"
    DTDFVocab:provides EnvironmentalConditionInsight, AlertNotificationAction
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Custom analytics service for dynamic energy consumption optimization integrated via modular architecture"
    DTDFVocab:provides EnergyConsumptionInsight, OptimizationRecommendationAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D/4D visualization interface enabling facility managers to interact with digital twin representations"
    DTDFVocab:provides SpatialAwarenessInsight, UserInteractionAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Custom analytics service for predictive maintenance analysis integrated through framework's extension points"
    DTDFVocab:provides MaintenancePredictionInsight, MaintenanceRecommendationAction
]

