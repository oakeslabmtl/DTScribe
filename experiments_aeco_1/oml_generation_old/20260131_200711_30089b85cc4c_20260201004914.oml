    base:desc "Automated alert system triggering notifications for anomalies or threshold breaches in building systems"
    DTDFVocab:IsAutomatic true
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Continuous monitoring and analysis of building energy consumption patterns and trends"
]

