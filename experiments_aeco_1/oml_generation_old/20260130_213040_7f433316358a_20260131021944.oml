// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator defined in the BIM model, controllable via the digital twin for adaptive lighting."
]

instance HVACValveController : DTDFVocab:ActingComponent [
    base:desc "HVAC valve controller defined in the BIM model, addressable through the digital twin."
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the building, configuration stored in BIM, streaming live data via Eclipse Hono."
    DTDFVocab:producedData TemperatureDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the building, configuration stored in BIM, streaming live data via Eclipse Hono."
    DTDFVocab:producedData OccupancyDataStream
]

instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor embedded in the building, configuration stored in BIM, streaming live data via Eclipse Hono."
    DTDFVocab:producedData LightingDataStream
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightingDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

// C5: Data (from transmitted streams)
instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature measurements from the building."
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy counts from the building."
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance LightingData : DTDFVocab:Data [
    base:desc "Live lighting level measurements from the building."
    DTDFVocab:fromData LightingDataStream
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Core enriched BIM containing geometry, spatial layout, and sensor/actuator metadata."
    DTDFVocab:inputTo ModelDrivenEngineering, EclipseHono, EclipseDitto, UnrealEngine5
]

instance TwinStateModel : DTDFVocab:Model [
    base:desc "Digital twin state model stored in Eclipse Ditto, reflecting the latest sensor values."
    DTDFVocab:inputTo VisualizationService, PredictiveAnalyticsService
]

instance VisualizationModel : DTDFVocab:Model [
    base:desc "3D visualization model prepared for rendering in Unreal Engine 5."
    DTDFVocab:inputTo VisualizationService
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides device connectivity and MQTT/HTTPS ingestion for sensor streams."
    DTDFVocab:enables RealTimeMonitoringService, EnergyOptimizationService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages the digital twin state, persisting incoming data and exposing REST/WS APIs."
    DTDFVocab:enables SimulationService, PredictiveAnalyticsService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders immersive 3D visualizations of the building twin."
    DTDFVocab:enables VisualizationService
]

instance BOREALIS : DTDFVocab:Enabler [
    base:desc "BOREALIS reinforcement‑learning engine optimizes lighting schedules based on twin data."
    DTDFVocab:enables EnergyOptimizationService
]

instance BIMModeling : DTDFVocab:Enabler [
    base:desc "Building Information Modeling tool stores geometry, spatial relations, and device metadata."
    DTDFVocab:enables ModelDrivenEngineering
]

instance ModelDrivenEngineering : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering transforms enriched BIM into code and configuration artifacts."
    DTDFVocab:enables RealTimeMonitoringService, SimulationService, PredictiveAnalyticsService, EnergyOptimizationService, VisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of sensor streams and twin state."
    DTDFVocab:provides VisualAnalyticsInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs simulation scenarios on the twin for what‑if analysis."
    DTDFVocab:provides PredictiveAlertsInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Applies predictive analytics to forecast energy consumption."
    DTDFVocab:provides EnergyForecastInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes energy usage via adaptive lighting using reinforcement learning."
    DTDFVocab:provides OptimizationRecommendationInsight, AdaptiveLightingAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Renders immersive 3D visualization of the building in Unreal Engine 5."
    DTDFVocab:provides Immersive3DVisualizationInsight
]

// C17: Insights/Actions
instance VisualAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Visual analytics dashboards generated from live twin data."
]

instance PredictiveAlertsInsight : DTDFVocab:Insight [
    base:desc "Predictive alerts about potential comfort or safety issues."
]

instance EnergyForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasts of future energy consumption based on current trends."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for lighting schedules and HVAC set‑points to reduce energy use."
]

instance AdaptiveLightingAction : DTDFVocab:Action [
    base:desc "Automatically adjusts lighting levels according to the reinforcement‑learning policy."
    DTDFVocab:IsAutomatic true
]

instance Immersive3DVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D view of the building with live sensor overlay."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points, HVAC adjustments) are sent back to actuators via the same Hono/Ditto middleware, enabling bidirectional actuation of the physical building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework operates at real‑time scale, delivering continuous, low‑latency synchronization between physical sensors/actuators and the virtual twin; data exchange occurs as soon as new measurements are available."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized DT framework that ingests enriched BIM models, uses a Hono/Ditto configurator to generate runtime interfaces, connects physical devices to the twin, and visualizes the twin in Unreal Engine 5; custom services can be added through defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin spans the full building life‑cycle: design (BIM creation), construction (model enrichment with device metadata), operation (live data integration), and post‑occupancy adaptation (e.g., reinforcement‑learning based control refinement)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric quantifies how closely the twin reflects its physical counterpart, addressing semantic drift and ensuring continuous verification of model‑data consistency."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Integration of Eclipse Hono and Eclipse Ditto provides the technical link: devices transmit telemetry to Hono, which routes it to Ditto where the twin’s digital representation is updated; Ditto exposes APIs for command issuance that are relayed back through Hono to the devices, enabling real‑time bidirectional communication."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is built on the BIM standard as the semantic backbone and follows standardized extension points to ensure interoperability across tools and services."
]