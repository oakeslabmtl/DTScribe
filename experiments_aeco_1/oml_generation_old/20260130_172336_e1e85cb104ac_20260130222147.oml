// C3: Physical sensing components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Physical light sensor embedded in the BIM model streaming illuminance data"
    DTDFVocab:producedData BuildingTelemetryStream
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Physical occupancy detector embedded in the BIM model streaming presence data"
    DTDFVocab:producedData BuildingTelemetryStream
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Physical temperature sensor embedded in the BIM model streaming ambient temperature"
    DTDFVocab:producedData BuildingTelemetryStream
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Physical humidity sensor embedded in the BIM model streaming relative humidity"
    DTDFVocab:producedData BuildingTelemetryStream
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance BuildingTelemetryStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor, OccupancyDetector, TemperatureSensor, HumiditySensor
]

// C10: Models/Data
instance BIMModel : DTDFVocab:Model [
    base:desc "BIM model serving as static semantic backbone, automatically transformed into runtime artefacts"
    DTDFVocab:inputTo EclipseDitto, PredictiveAnalyticsEngine
]

instance RuntimeInterfaceModel : DTDFVocab:Model [
    base:desc "Automatically generated runtime interfaces from BIM metadata for live twin interaction"
    DTDFVocab:inputTo EclipseDitto
]

instance BuildingSensorData : DTDFVocab:Data [
    base:desc "Aggregated sensor measurements (light, occupancy, temperature, humidity) streamed via Eclipse Hono and stored in Eclipse Ditto"
    DTDFVocab:fromData BuildingTelemetryStream
    DTDFVocab:inputTo EclipseDitto, PredictiveAnalyticsEngine
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides MQTT/AMQP ingestion of sensor streams from the physical building"
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto stores and synchronizes the digital twin representation of the Living Lab building"
    DTDFVocab:enables RealTimeMonitoringService, VisualizationService, SimulationService, PredictiveAnalyticsService, OptimizationService, AdaptiveControlService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders immersive 3D visualization of the building twin"
    DTDFVocab:enables VisualizationService
]

instance PredictiveAnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Engine executing predictive analytics and reinforcement‑learning policies for the twin"
    DTDFVocab:enables PredictiveAnalyticsService, AdaptiveControlService, OptimizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building sensor streams for facility management"
    DTDFVocab:provides LightingAdjustmentInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D interactive visualization using Unreal Engine 5"
    DTDFVocab:provides VisualizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance based on BIM geometry and live sensor data"
    DTDFVocab:provides SimulationResultInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics forecasting energy use and occupancy patterns"
    DTDFVocab:provides EnergyConsumptionOptimizationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization of lighting and energy consumption based on analytics outcomes"
    DTDFVocab:provides LightingAdjustmentAction, EnergySavingAction
]

instance AdaptiveControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based adaptive control of building systems"
    DTDFVocab:provides RLPolicyUpdateAction
]

// C17: Insights
instance LightingAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal lighting levels based on occupancy and ambient light"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive view of building geometry, occupancy and environmental conditions"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Predicted thermal and lighting performance for scenario analysis"
]

instance EnergyConsumptionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Forecasted energy consumption enabling proactive optimization actions"
]

// C17: Actions
instance LightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting fixtures to optimal intensity"
    DTDFVocab:IsAutomatic true
]

instance EnergySavingAction : DTDFVocab:Action [
    base:desc "Control of HVAC dampers to reduce energy use while maintaining comfort"
    DTDFVocab:IsAutomatic true
]

instance RLPolicyUpdateAction : DTDFVocab:Action [
    base:desc "Update of reinforcement‑learning policy from post‑occupancy data"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture actuator defined in the BIM model, controllable via the digital twin"
]

instance HVACDamperActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC damper actuator defined in the BIM model, controllable via the digital twin"
]

// Environment and Component
instance LivingLabEnvironment : DTDFVocab:Environment [
    base:contains LivingLabBuildingComponent
]

instance LivingLabBuildingComponent : DTDFVocab:Component [
    base:desc "Physical representation of the Living Lab academic building"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points, HVAC adjustments) are sent back to the physical actuators through the same Hono/Ditto bidirectional communication channel."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real‑time updates (sub‑second to second latency) enabled by continuous data exchange through Hono/Ditto."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where enriched BIM models feed a configurator that produces device metadata, which is consumed by Hono/Ditto middleware; the twin visualizes data in Unreal Engine and exposes extension points for custom services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the design phase (BIM creation), construction, operation/maintenance, and refurbishment/adaptation stages of the building lifecycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Entanglement measured with the Overall Digital Twin Entanglement (ODTE) metric to assess how closely the twin mirrors the physical building; semantic drift mitigation discussed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "IP‑based network using Eclipse Hono (supports MQTT, AMQP) for device protocol translation and Eclipse Ditto for twin state management and REST/WebSocket APIs."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adopts BIM standards (e.g., IFC) for semantic consistency and utilizes standardized extension points within the model‑driven framework; Eclipse Ditto follows OMA LwM2M/NGSI‑LD‑like data models."
]