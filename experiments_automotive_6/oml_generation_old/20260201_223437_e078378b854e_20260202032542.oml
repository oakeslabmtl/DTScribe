// =============================
// C17: Insights
// =============================
instance RealTimeVehicleSpeedInsight : DTDFVocab:Insight [
    base:desc "Displays current vehicle speed on the operator UI"
]

instance RealTimeSteeringAngleInsight : DTDFVocab:Insight [
    base:desc "Shows current steering angle on the operator UI"
]

instance RealTimeObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Presents detected and tracked objects from LiDAR clustering"
]

instance RealTimeProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Illustrates the projected trajectory computed by the ACC model"
]

instance ACCPerformanceInsight : DTDFVocab:Insight [
    base:desc "Reports ACC algorithm performance metrics (e.g., head‑way, acceleration)"
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Summarizes session data into downloadable reports"
]

// =============================
// C17: Actions
// =============================
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets the desired cruising speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking"
    DTDFVocab:IsAutomatic false
]

// =============================
// C6: Services
// =============================
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualizes real‑time vehicle state, projected path, object tracks and generates reports"
    DTDFVocab:provides RealTimeVehicleSpeedInsight
    DTDFVocab:provides RealTimeSteeringAngleInsight
    DTDFVocab:provides RealTimeObjectTracksInsight
    DTDFVocab:provides RealTimeProjectedPathInsight
    DTDFVocab:provides ReportGenerationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs the ACC algorithm on the digital twin instead of on‑board"
    DTDFVocab:provides ACCPerformanceInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, and issue emergency‑brake commands"
    DTDFVocab:provides EnableACCAction
    DTDFVocab:provides DisableACCAction
    DTDFVocab:provides SetDesiredSpeedAction
    DTDFVocab:provides EmergencyBrakeAction
]

// =============================
// C11: Enablers
// =============================
instance ClusteringTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Processes LiDAR data with DBSCAN and Kalman‑filter to produce object tracks"
    DTDFVocab:enables DataMonitoringService
]

instance ACCAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Executes the ACC control algorithm in the digital twin (computation offloading)"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Handles operator commands to enable/disable ACC, set speed, or trigger emergency brake"
    DTDFVocab:enables RemoteManagementService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Renders real‑time visualizations using the 3‑D model"
    DTDFVocab:enables DataMonitoringService
]

// =============================
// C10: Models
// =============================
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point clouds for object segmentation"
    DTDFVocab:inputTo ClusteringTrackingEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based multi‑object tracking"
    DTDFVocab:inputTo ClusteringTrackingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm implementing ISO 15622 performance‑class I"
    DTDFVocab:inputTo ACCAlgorithmEnabler
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model rendering vehicle state, path and object tracks"
    DTDFVocab:inputTo VisualizationEnabler
]

// =============================
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// =============================
instance HokuyoLiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARSensor
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseDepthCameraSensor
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelEncoderSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoFeedbackSensor
]

// =============================
// C3: Physical sensing components
// =============================
instance HokuyoLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2‑D LiDAR providing real‑time point‑cloud scans"
    DTDFVocab:producedData HokuyoLiDARDataTransmitted
]

instance IntelDeepSenseDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering synchronized depth images"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance WheelEncoderSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel‑encoder derived vehicle speed sensor"
    DTDFVocab:producedData SpeedDataTransmitted
]

instance SteeringServoFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Steering servo feedback sensor providing steering angle"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// =============================
// C5: Data items
// =============================
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Point‑cloud stream from Hokuyo LiDAR"
    DTDFVocab:fromData HokuyoLiDARDataTransmitted
    DTDFVocab:inputTo ClusteringTrackingEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth images from Intel D435i camera"
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo ClusteringTrackingEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed measurements derived from wheel encoders"
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo ACCAlgorithmEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle feedback from the steering servo"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo ACCAlgorithmEnabler
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks generated by DBSCAN clustering and Kalman‑filter tracking"
    DTDFVocab:fromData LiDARPointCloudData
    DTDFVocab:inputTo VisualizationEnabler
]

instance ProjectedPathData : DTDFVocab:Data [
    base:desc "Projected vehicle path computed by the ACC control model"
    DTDFVocab:fromData VehicleSpeedData
    DTDFVocab:inputTo VisualizationEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity sends control commands (enable/disable ACC, modify desired speed, emergency‑brake command, and computed desired speed) back to the PT over the same Wi‑Fi/ROS 2 link. Commands are received by the Actuation FE on the Physical Twin Entity, which converts them to motor‑voltage and steering‑servo signals."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is designed for real‑time operation with an end‑to‑end network latency bound of ≤100 ms (per 3GPP TS 22.185) and clock synchronization accuracy of 100 ms across all DTS components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation follows the ISO 23247 reference architecture extended with a Physical Twin Entity (analogous to the OME). Functional Entities (Data Collection, Data Translation, Presentation, Controlling, Reporting, Actuation) are realized as separate ROS 2 packages deployed across the three physical hosts, communicating via ROS 2 topics over Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed primarily during the operational stage of the vehicle for monitoring, control, and remote management, and is also used in the development and testing phases to troubleshoot ACC behavior."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time fidelity is enforced by the ≤100 ms latency and clock‑sync constraints. Model validity is addressed by using established algorithms (DBSCAN, Kalman filter, ISO 15622 ACC logic) and by storing raw sensor data for offline verification. Safety‑critical operation mandates that the DT respect these timing bounds."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange between PT and DT occurs over a Wi‑Fi network using ROS 2 messaging. The Data Translation FE performs serialization, message‑type alignment, and unit conversion. No other transport protocol is specified; OPC UA is mentioned only as a possible alternative."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the Jetson Orin Nano on the vehicle. The Digital Twin Entity (ACC computation, data collection, reporting) runs on external compute hardware (e.g., a cloud server or workstation) hosting ROS 2 nodes and the SQL database. The User Entity (UI) runs on an operator workstation displaying 3‑D visualizations."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The design follows ISO 23247 (Digital Twin Manufacturing Framework) for the layered reference architecture, ISO 15622 for ACC functionality, ISO/IEC 30173 for digital‑twin concepts, and adopts the 3GPP TS 22.185 latency guideline. OPC UA (IEC 62541) is cited as an optional communication standard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations include the requirement for ≤100 ms end‑to‑end latency, 100 ms clock synchronization, and adherence to ISO 15622 ACC specifications for safe vehicle control. Specific cybersecurity mechanisms are not detailed in the document."
]