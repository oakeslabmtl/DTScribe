// C3: Physical sensing components
instance HokuyoLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2‑D LiDAR providing range measurements used for point‑cloud generation."
    DTDFVocab:producedData HokuyoLiDARDataTransmitted
]

instance IntelDeepSenseCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera supplying 3‑D perception data."
    DTDFVocab:producedData IntelDeepSenseCameraDataTransmitted
]

instance VehicleTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle telemetry source delivering ego speed and steering angle."
    DTDFVocab:producedData VehicleTelemetryDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance HokuyoLiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARSensor
]

instance IntelDeepSenseCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseCameraSensor
]

instance VehicleTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleTelemetrySensor
]

// C10: Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud frames streamed over UDP."
    DTDFVocab:fromData HokuyoLiDARDataTransmitted
    DTDFVocab:inputTo PerceptionEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames from the Intel DeepSense camera."
    DTDFVocab:fromData IntelDeepSenseCameraDataTransmitted
    DTDFVocab:inputTo PerceptionEnabler
]

instance TelemetryData : DTDFVocab:Data [
    base:desc "Ego vehicle speed and steering angle telemetry."
    DTDFVocab:fromData VehicleTelemetryDataTransmitted
    DTDFVocab:inputTo ControlInterfaceEnabler
]

// C10: Models
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering model processing raw LiDAR point clouds to produce object clusters."
    DTDFVocab:inputTo PerceptionEnabler
]

instance TrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter tracking model maintaining object tracks over time."
    DTDFVocab:inputTo PerceptionEnabler
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "ACC model determining lead vehicle and computing desired following speed."
    DTDFVocab:inputTo CloudACCEnabler
]

// C11: Enablers
instance PerceptionEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware component handling perception pipeline (clustering, tracking) and providing data to the UI."
    DTDFVocab:enables DataMonitoringService
]

instance CloudACCEnabler : DTDFVocab:Enabler [
    base:desc "Cloud compute (NVIDIA Jetson Orin‑Nano) executing the ACC algorithm off‑loaded from the vehicle."
    DTDFVocab:enables ComputationOffloadingService
]

instance ControlInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Control interface allowing remote commands (enable/disable ACC, set speed, emergency brake) to be sent to vehicle actuators."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "User interface visualising real‑time vehicle state, projected paths, and detected object tracks; supports viewing, saving, and reporting ACC data."
    DTDFVocab:provides VehicleStateInsight, ReportGenerationAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes the ACC algorithm on the digital twin and returns the computed desired speed to the vehicle."
    DTDFVocab:provides DesiredSpeedComputationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to remotely enable/disable ACC, set a desired speed, and issue emergency‑brake commands."
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current ego speed, steering angle, and surrounding object states."
]

// C17: Actions
instance ReportGenerationAction : DTDFVocab:Action [
    base:desc "Generate, save, and export reports on collected ACC‑relevant data."
    DTDFVocab:IsAutomatic false
]

instance DesiredSpeedComputationAction : DTDFVocab:Action [
    base:desc "Compute desired following speed based on tracked objects and ego state."
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Remote command to enable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Remote command to set a specific desired speed for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Remote emergency‑brake command to stop the vehicle immediately."
    DTDFVocab:IsAutomatic false
]

// C2: Acting components (physical actuators)
instance VedderSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller converting desired speed commands into motor voltage for closed‑loop speed control."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Dedicated steering servo receiving steering angle commands to set vehicle heading."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The ACC Controlling functional entity runs in the DT, determines the lead vehicle and computes a desired speed. The computed speed is packaged by the Data Translation FE and sent back to the vehicle over the same Wi‑Fi UDP link. On the physical side the Actuation FE receives the command and drives the motor and steering servo to achieve the requested speed. The documents do not detail command message schemas, authentication, conflict resolution, or explicit execution acknowledgments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires a clock synchronization accuracy of 100 ms between physical and digital components, as imposed by hardware limitations. This accuracy is needed for safe vehicular operation and aligns with standards that demand stricter (<100 ms) synchronization for safety‑critical tasks. All functional entities share this common time base to enable computation off‑loading and coordinated control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The orchestration follows the ISO 23247 reference architecture, mapping each functional entity to a ROS 2 package that contains one or more ROS 2 nodes implementing the entity's functionality. The Physical Twin Entity hosts sensor, actuator, and compute resources (e.g., point‑cloud clustering & tracking); the Digital Twin Entity provides data management and control mechanisms; the User Entity contains the split User Interface FE (visualization and control panel). Entities are deployed on distinct hardware, and system‑wide coordination is realized through ROS 2 publish/subscribe and service calls across the packages, respecting the entity‑based structure of ISO 23247."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and system validity are governed by explicit requirements. Requirement R6 mandates that the Digital Twin implement the ACC functionality in accordance with ISO 15622, ensuring compliance with an established automotive control standard. Requirement R7 limits end‑to‑end network latency to a maximum of 100 ms, while Requirement R8 requires clock synchronization across system components to within 100 ms accuracy. These constraints serve as validation criteria for timing fidelity and synchronization integrity, providing a basis for verification of the Digital Twin’s real‑time performance."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS uses a two‑layer communication architecture: intra‑entity component communication occurs on a ROS2 network, while inter‑entity (physical‑digital) communication is carried out over Wi‑Fi using UDP at the transport layer. No specific bandwidth, latency, reliability, redundancy, or security protocol details are provided in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin System is deployed on edge hardware rather than a central cloud. The physical twin runs on an on‑board NVIDIA Jetson Orin Nano microcomputer that hosts the sensors, low‑level motor and steering control, and the Actuation functional entity. The digital twin entity is hosted on a separate edge node equipped with an NVIDIA Jetson NX (including an antenna for Wi‑Fi communication) where the ACC Controlling, Data Translation, Point Cloud Clustering & Tracking, and visualization services execute. The user interface runs on a workstation or remote console that accesses the digital twin over the same Wi‑Fi link. Each entity is therefore instantiated on its own compute platform, allowing independent scaling of CPU/GPU resources and storage (local SSD for data logging). The documents mention that each entity has been deployed on a different hardware component, indicating a distributed edge deployment model."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system follows the ISO 23247 standard for digital twins in manufacturing. ISO 23247 Part 2 defines an entity‑based reference architecture composed of the Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity, and User Entity, each built from Functional Entities that perform tasks such as actuation, data transformation, and user interfacing. The standard permits implementation using protocols such as OPC Unified Architecture (OPC UA)."
]