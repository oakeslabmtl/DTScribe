// C1: Sensing Components
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "Raw LiDAR point cloud data sensor for 2D plane data acquisition in autonomous vehicle systems"
]

instance MotorActuationSensor : DTDFVocab:SensingComponent [
    base:desc "Raw motor actuation signals sensor for vehicle control systems"
]

instance SteeringActuationSensor : DTDFVocab:SensingComponent [
    base:desc "Raw steering servo actuation signals sensor for vehicle control systems"
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state data sensor (position, speed, etc.) for autonomous vehicle monitoring"
]

instance BatteryStateSensor : DTDFVocab:SensingComponent [
    base:desc "Battery state of charge (SoC) and voltage sensor for energy storage systems"
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor for monitoring environmental conditions in manufacturing and aerospace systems"
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Pressure sensor for monitoring operational parameters in industrial processes"
]

instance IoTSensorNetwork : DTDFVocab:SensingComponent [
    base:desc "Network of IoT sensors for continuous monitoring across manufacturing and automotive environments"
]

instance PLCSensor : DTDFVocab:SensingComponent [
    base:desc "Programmable Logic Controller sensors for industrial automation and manufacturing processes"
]

// C2: Produced Data Types
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance MotorActuationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorActuationSensor
]

instance SteeringActuationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringActuationSensor
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance BatteryStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BatteryStateSensor
]

instance TemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

instance IoTSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IoTSensorNetwork
]

instance PLCData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PLCSensor
]

// C3: Data Processing Components
instance DataTranslationFE : DTDFVocab:FunctionalEntity [
    base:desc "Data Translation Functional Entity performing unit conversions (e.g., LiDAR distance units to meters) and message serialization for interoperability"
]

instance PreProcessingFE : DTDFVocab:FunctionalEntity [
    base:desc "Pre-processing Functional Entity validating raw sensor inputs (e.g., LiDAR noise filtering, clustering accuracy checks)"
]

instance PointCloudProcessingFE : DTDFVocab:FunctionalEntity [
    base:desc "Point Cloud Clustering & Tracking Functional Entity processing LiDAR data into structured object tracks and vehicle state representations"
]

instance ActuationCommandFE : DTDFVocab:FunctionalEntity [
    base:desc "Raw actuation FE translating motor/steering signals into vehicle control commands"
]

instance DataPreProcessingFE : DTDFVocab:FunctionalEntity [
    base:desc "Data Pre-Processing FE ensuring consistency and alignment with digital twin semantics for vehicle state data"
]

instance VisualizationFE : DTDFVocab:FunctionalEntity [
    base:desc "Point Cloud to Visualization FE transforming raw LiDAR data into 3D renderable point clouds for real-time visualization"
]

instance ReportingFE : DTDFVocab:FunctionalEntity [
    base:desc "Reporting FE aggregating vehicle state data for user-facing dashboards (e.g., ACC control panels)"
]

// C4: Data Integration Mechanisms
instance LiDARVisualizationData : DTDFVocab:Data [
    base:desc "Structured 3D point cloud data generated from LiDAR processing for visualization purposes"
    DTDFVocab:fromData LiDARPointCloudData
    DTDFVocab:inputTo PointCloudProcessingFE, VisualizationFE
]

instance VehicleStateDashboardData : DTDFVocab:Data [
    base:desc "Processed vehicle state data for user dashboards (position, speed, control parameters)"
    DTDFVocab:fromData VehicleStateData
    DTDFVocab:inputTo ReportingFE
]

instance ActuationCommandData : DTDFVocab:Data [
    base:desc "Processed actuation commands for vehicle control systems"
    DTDFVocab:fromData MotorActuationData, SteeringActuationData
    DTDFVocab:inputTo ActuationCommandFE
]

instance AnomalyDetectionData : DTDFVocab:Data [
    base:desc "Processed sensor data for anomaly detection in manufacturing and automotive systems"
    DTDFVocab:fromData IoTSensorData, PLCData
    DTDFVocab:inputTo DataTranslationFE, PreProcessingFE
]

instance BatteryStateAnalysisData : DTDFVocab:Data [
    base:desc "Processed battery state data for health monitoring and degradation prediction"
    DTDFVocab:fromData BatteryStateData
    DTDFVocab:inputTo DataTranslationFE, PreProcessingFE
]

// C5: Models
instance LiDARProcessingModel : DTDFVocab:Model [
    base:desc "Point Cloud Clustering & Tracking model for LiDAR data processing"
    DTDFVocab:inputTo PointCloudProcessingFE
]

instance VehicleStateModel : DTDFVocab:Model [
    base:desc "Vehicle state representation model combining position, speed, and control parameters"
    DTDFVocab:inputTo VehicleStateDashboardData
]

instance ActuationControlModel : DTDFVocab:Model [
    base:desc "Closed-loop actuation control model for vehicle steering and motor management"
    DTDFVocab:inputTo ActuationCommandData
]

instance AnomalyDetectionModel : DTDFVocab:Model [
    base:desc "AI/ML model for anomaly detection in manufacturing and automotive systems"
    DTDFVocab:inputTo AnomalyDetectionData
]

instance BatteryHealthModel : DTDFVocab:Model [
    base:desc "AI/ML model for battery state of charge and degradation prediction"
    DTDFVocab:inputTo BatteryStateAnalysisData
]

// C6: Enablers
instance ROS2Communication : DTDFVocab:Enabler [
    base:desc "Robot Operating System 2 for intra-entity real-time message passing between software components"
    DTDFVocab:enables LiDARVisualizationData, ActuationCommandData
]

instance WiFiUDPNetwork : DTDFVocab:Enabler [
    base:desc "Wi-Fi UDP network for low-latency, high-throughput data translation between Digital Twin and User Entity"
    DTDFVocab:enables VehicleStateDashboardData, AnomalyDetectionData
]

instance OPCUAProtocol : DTDFVocab:Enabler [
    base:desc "OPC Unified Architecture for bidirectional data exchange between Digital Twin and Observable Manufacturing Elements"
    DTDFVocab:enables BatteryStateAnalysisData, AnomalyDetectionData
]

instance TensorFlowAI : DTDFVocab:Enabler [
    base:desc "TensorFlow framework for deep learning-based predictions (e.g., battery degradation, failure prediction)"
    DTDFVocab:enables AnomalyDetectionModel, BatteryHealthModel
]

instance ScikitLearnAI : DTDFVocab:Enabler [
    base:desc "Scikit-learn framework for classic ML models (e.g., regression for battery degradation)"
    DTDFVocab:enables BatteryHealthModel
]

instance ANSYSSimulation : DTDFVocab:Enabler [
    base:desc "ANSYS for physics-based simulations (e.g., thermal management in batteries)"
    DTDFVocab:enables BatteryHealthModel
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for control system design and digital twin validation"
    DTDFVocab:enables ActuationControlModel
]

instance AWSIoTGreengrass : DTDFVocab:Enabler [
    base:desc "AWS IoT Greengrass for localized processing in resource-constrained environments"
    DTDFVocab:enables LiDARVisualizationData, ActuationCommandData
]

instance PostgreSQLDatabase : DTDFVocab:Enabler [
    base:desc "PostgreSQL relational database for structured data storage (sensor logs, historical records)"
    DTDFVocab:enables VehicleStateDashboardData, BatteryStateAnalysisData
]

instance MongoDBDatabase : DTDFVocab:Enabler [
    base:desc "MongoDB NoSQL database for scalable unstructured data storage (IoT telemetry, AI model outputs)"
    DTDFVocab:enables AnomalyDetectionData
]

instance Neo4jGraphDB : DTDFVocab:Enabler [
    base:desc "Neo4j graph database for relationship-heavy data mapping in cyber-physical systems"
    DTDFVocab:enables LiDARProcessingModel
]

instance AWSDataLake : DTDFVocab:Enabler [
    base:desc "AWS S3 data lake for raw data ingestion and long-term archiving"
    DTDFVocab:enables LiDARPointCloudData
]

instance BlockchainAudit : DTDFVocab:Enabler [
    base:desc "Blockchain technology for immutable audit logs in supply chain twins"
    DTDFVocab:enables AnomalyDetectionData
]

instance NVIDIAJetson : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetson edge computing platform for localized processing"
    DTDFVocab:enables ActuationCommandData
]

instance NVIDIAOmniverse : DTDFVocab:Enabler [
    base:desc "NVIDIA Omniverse for high-fidelity vehicle simulations"
    DTDFVocab:enables VehicleStateModel
]

instance SiemensDigitalTwin : DTDFVocab:Enabler [
    base:desc "Siemens Digital Twin platform for smart factory integration"
    DTDFVocab:enables BatteryStateAnalysisData
]

instance TableauDashboard : DTDFVocab:Enabler [
    base:desc "Tableau visualization tool for interactive dashboards with role-based access"
    DTDFVocab:enables VehicleStateDashboardData
]

instance UnityAR : DTDFVocab:Enabler [
    base:desc "Unity platform for augmented reality visualization in maintenance training"
