import DTDFVocab from "https://w3id.org/DTDFVocab"
instance HokuyoUST10LX_LiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR for point cloud data",
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]
instance IntelD435i_Camera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i Depth Camera for visual data",
    DTDFVocab:producedData DepthCameraVisualDataTransmitted
]
instance SpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor",
    DTDFVocab:producedData SpeedDataTransmitted
]
instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle steering angle sensor",
    DTDFVocab:producedData SteeringAngleDataTransmitted
]
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LX_LiDAR
]
instance DepthCameraVisualDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435i_Camera
]
instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SpeedSensor
]
instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "LiDAR point cloud data",
    DTDFVocab:fromData LiDARPointCloudDataTransmitted,
    DTDFVocab:inputTo MATLABSimulink, SQLDatabase
]
instance DepthCameraVisualData : DTDFVocab:Data [
    base:desc "Depth camera visual data",
    DTDFVocab:fromData DepthCameraVisualDataTransmitted,
    DTDFVocab:inputTo ROS2Middleware, Python38
]
instance SpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed data",
    DTDFVocab:fromData SpeedDataTransmitted,
    DTDFVocab:inputTo ROS2Middleware, CppCompiler
]
instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Vehicle steering angle data",
    DTDFVocab:fromData SteeringAngleDataTransmitted,
    DTDFVocab:inputTo ROS2Middleware, CppCompiler
]
instance VehicleStateData : DTDFVocab:Data [
    base:desc "Combined vehicle speed and steering angle data",
    DTDFVocab:fromData SpeedDataTransmitted, SteeringAngleDataTransmitted,
    DTDFVocab:inputTo ROS2Middleware, SQLDatabase
]
instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks data",
    DTDFVocab:fromData LiDARPointCloudDataTransmitted, DepthCameraVisualDataTransmitted,
    DTDFVocab:inputTo ROS2Middleware, Python38
]
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN algorithm for point cloud clustering",
    DTDFVocab:inputTo MATLABSimulink, SQLDatabase
]
instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter for object tracking",
    DTDFVocab:inputTo ROS2Middleware, Python38
]
instance ACCControlModel : DTDFVocab:Model [
    base:desc "ISO 15622-based adaptive cruise control model",
    DTDFVocab:inputTo ROS2Middleware, SQLDatabase
]
instance JetpackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for hardware acceleration",
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for communication",
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]
instance Python38 : DTDFVocab:Enabler [
    base:desc "Python 3.8 for scripting",
    DTDFVocab:enables DataMonitoringService
]
instance CppCompiler : DTDFVocab:Enabler [
    base:desc "C++ compiler for high-performance code",
    DTDFVocab:enables RemoteManagementService
]
instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for point cloud processing",
    DTDFVocab:enables DataMonitoringService
]
instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL database for data storage",
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time display, saving, and reporting of vehicle state, object tracks, and projected path",
    DTDFVocab:provides VehicleStateVisualization, ObjectTracksVisualization, ProjectedPathVisualization, TroubleshootingReports
]
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloading ACC logic to cloud"
]
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote enable/disable ACC, set desired speed, emergency braking via UI",
    DTDFVocab:provides EnableACC, DisableACC, SetDesiredSpeed, EmergencyBraking
]
instance VehicleStateVisualization : DTDFVocab:Insight [
    base:desc "Real-time visualization of vehicle state for operator decision-making"
]
instance ObjectTracksVisualization : DTDFVocab:Insight [
    base:desc "Real-time visualization of object tracks for operator decision-making"
]
instance ProjectedPathVisualization : DTDFVocab:Insight [
    base:desc "Real-time visualization of projected path for operator decision-making"
]
instance TroubleshootingReports : DTDFVocab:Insight [
    base:desc "Reports for developer troubleshooting"
]
instance EnableACC : DTDFVocab:Action [
    base:desc "Remote enable ACC via UI",
    DTDFVocab:IsAutomatic false
]
instance DisableACC : DTDFVocab:Action [
    base:desc "Remote disable ACC via UI",
    DTDFVocab:IsAutomatic false
]
instance SetDesiredSpeed : DTDFVocab:Action [
    base:desc "Set desired speed via UI",
    DTDFVocab:IsAutomatic false
]
instance EmergencyBraking : DTDFVocab:Action [
    base:desc "Emergency braking activation via UI",
    DTDFVocab:IsAutomatic false
]
instance Motor : DTDFVocab:ActingComponent [
    base:desc "Motor for converting desired speed commands into motor voltage"
]
instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Steering servo for adjusting steering angle"
]
instance TraxxasSlashChassis : DTDFVocab:Component [
    base:desc "Traxxas Slash 4x4 Premium chassis for 1/10-scale autonomous vehicle"
]
instance JetsonNX : DTDFVocab:Component [
    base:desc "NVIDIA Jetson NX module for processing"
]
instance JetsonOrinNano : DTDFVocab:Component [
    base:desc "NVIDIA Jetson Orin Nano microcomputer for sensor processing"
]
instance VedderESC : DTDFVocab:Component [
    base:desc "Vedder Electronic Speed Controller for motor control"
]
instance AutonomousVehicleEnvironment : DTDFVocab:Environment [
    base:contains TraxxasSlashChassis, JetsonNX, JetsonOrinNano, HokuyoUST10LX_LiDAR, IntelD435i_Camera, VedderESC, Motor, SteeringServo
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Transmission of ACC control commands (desired speed, emergency braking, enable/disable) from the digital twin to the physical twin's motor and steering actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with network latency ≤100 ms and clock synchronization accuracy of 100 ms as per 3GPP 22.185 for V2V communication."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Entity-based architecture with Physical Twin Entity (on vehicle), Digital Twin Entity (cloud), User Entity (separate UI), and Cross-System Entity (Data Translation); components communicate via ROS2 internally and Wi-Fi between entities."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design phase for experimentation and validation, and operation phase for optimization and health monitoring, supporting end-to-end digital threads throughout the vehicle lifecycle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "ROS2 for intra-component communication; Wi-Fi for inter-entity communication with Data Translation component handling serialization, message alignment, and unit conversions."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity deployed on vehicle's Jetson Orin Nano; Digital Twin Entity and Data Storage hosted in cloud; User Entity on separate machine for UI."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture for digital twins; ACC implementation based on ISO 15622."
]