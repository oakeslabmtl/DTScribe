// ------------------------------------------------------------ // Return code: 1 | Stderr:
// C3: Physical sensing components
// ------------------------------------------------------------

instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2‑D LiDAR providing raw distance measurements as point‑clouds"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera used for visual perception (optional additional data)"
    DTDFVocab:producedData DepthImageTransmitted
]

instance ChassisEncoder : DTDFVocab:SensingComponent [
    base:desc "Vehicle chassis encoders deriving ego‑vehicle speed and steering angle"
    DTDFVocab:producedData EgoStateTransmitted
]

// ------------------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// ------------------------------------------------------------

instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]

instance EgoStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChassisEncoder
]

// ------------------------------------------------------------
// C10: Data instances
// ------------------------------------------------------------

instance RawLiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud frames streamed in real‑time over Wi‑Fi"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames from the Intel D435i camera"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance EgoVehicleStateData : DTDFVocab:Data [
    base:desc "Ego‑vehicle speed and steering‑angle values derived from chassis encoders"
    DTDFVocab:fromData EgoStateTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance ObjectTrackTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of object tracks produced by DBSCAN clustering and Kalman filtering"
    DTDFVocab:fromData RawLiDARPointCloudData
    DTDFVocab:inputTo ROS2Middleware
]

instance GeneratedReportData : DTDFVocab:Data [
    base:desc "Automated PDF/HTML reports containing vehicle state, object tracks and ACC performance"
    DTDFVocab:fromData EgoVehicleStateData
    DTDFVocab:inputTo ROS2Middleware
]

// ------------------------------------------------------------
// C10: Model instances
// ------------------------------------------------------------

instance ACCControlModel : DTDFVocab:Model [
    base:desc "ACC control model compliant with ISO‑15622 Performance Class I, executed off‑board"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering followed by Kalman filter tracking for raw LiDAR point‑clouds"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualisation model rendering vehicle path and object tracks in the DT UI"
    DTDFVocab:inputTo JetPackSDK
]

// ------------------------------------------------------------
// C11: Enabler instances
// ------------------------------------------------------------

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware (packages per Functional Entity) handling data transport and node lifecycle"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance MatlabSimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment used for ACC algorithm and point‑cloud processing"
    DTDFVocab:enables ComputationOffloadingService
]

instance JetPackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK on the Jetson platform for 3‑D visualisation rendering"
    DTDFVocab:enables DataMonitoringService
]

instance WiFiNetwork : DTDFVocab:Enabler [
    base:desc "Wi‑Fi link used for real‑time streaming of ego‑state and LiDAR point‑clouds"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance OpcUaTranslator : DTDFVocab:Enabler [
    base:desc "Optional OPC‑UA (IEC 62541) gateway for protocol translation between entities"
    DTDFVocab:enables RemoteManagementService
]

// ------------------------------------------------------------
// C6: Service instances
// ------------------------------------------------------------

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualising real‑time vehicle state, projected path and object tracks"
    DTDFVocab:provides RealTimeVisualizationInsight, AutomatedReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Execution of ACC algorithm in the cloud with results returned to the PT"
    DTDFVocab:provides ACCControlDecisionInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI‑driven enable/disable of ACC, desired‑speed setting, and emergency‑brake activation"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustSpeedAction, EmergencyBrakeAction
]

// ------------------------------------------------------------
// C17: Insights and Actions
// ------------------------------------------------------------

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualisation of vehicle state, path and object tracks for operator situational awareness"
]

instance AutomatedReportInsight : DTDFVocab:Insight [
    base:desc "Automated generation of time‑series reports summarising vehicle performance and object tracking"
]

instance ACCControlDecisionInsight : DTDFVocab:Insight [
    base:desc "Computed Adaptive Cruise Control (ACC) command based on vehicle and environment data"
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Remotely enable the ACC function on the physical twin"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Remotely disable the ACC function on the physical twin"
    DTDFVocab:IsAutomatic false
]

instance AdjustSpeedAction : DTDFVocab:Action [
    base:desc "Set a new desired speed for the vehicle via remote management UI"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Trigger an emergency brake command on the physical twin"
    DTDFVocab:IsAutomatic false
]

// ------------------------------------------------------------
// C2: Acting components (Physical actuators)
// ------------------------------------------------------------

instance VedderESC : DTDFVocab:ActingComponent [
    base:desc "Vedder electronic speed controller receiving motor voltage commands to control vehicle speed"
]

instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Servo motor receiving angle commands to steer the vehicle"
]

// ------------------------------------------------------------
// Entity constellation (ISO‑23247 inspired)
// ------------------------------------------------------------

instance PhysicalTwinEntity : DTDFVocab:Environment [
    base:desc "On‑board entity containing sensors, actuators and ROS 2 nodes on the 1/10‑scale autonomous vehicle"
    base:contains HokuyoLiDAR, IntelDepthCamera, ChassisEncoder, VedderESC, SteeringServo
]

instance DigitalTwinEntity : DTDFVocab:Environment [
    base:desc "Off‑board entity (cloud/edge) hosting computation, visualisation and management services"
    base:contains ROS2Middleware, MatlabSimulinkEngine, JetPackSDK, ACCControlModel, PointCloudClusteringTrackingModel, Visualization3DModel
]

instance UserEntity : DTDFVocab:Environment [
    base:desc "Operator workstation providing UI for monitoring, reporting and remote management"
    base:contains DataMonitoringService, RemoteManagementService
]

instance CrossSystemEntity : DTDFVocab:Environment [
    base:desc "Cross‑system entity providing data translation (e.g., OPC‑UA) between PT, DT and User entities"
    base:contains OpcUaTranslator, WiFiNetwork
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT: desired speed values for the ESC, enable/disable ACC flags, emergency‑brake commands, and steering adjustments. These commands are issued by the Controlling Functional Entity (ACC) and the Actuation Functional Entity on the Physical Twin Entity."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates in real‑time with a hard end‑to‑end latency bound of ≤100 ms (per 3GPP TS 22.185) and clock synchronization accuracy of 100 ms across all DTS components; data collection and ACC computation occur at each perception cycle (on the order of tens of milliseconds)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates a Physical Twin Entity (sensor acquisition and actuation), a Digital Twin Entity (data collection, ACC computation, visualization, reporting), a User Entity (UI for monitoring and remote commands), and a Cross‑System Data Translation Entity; intra‑entity messaging uses ROS 2 topics, inter‑entity communication uses Wi‑Fi over standardized interfaces."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during the design and development phase as a high‑fidelity simulation/experiment platform, and during operation as a monitoring, optimization and remote‑control platform for the running vehicle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High fidelity is achieved by using raw sensor data (LiDAR, camera) and real‑time processing; validity is ensured through latency ≤100 ms, clock sync ≤100 ms, compliance with ISO 15622 ACC safety class, and continuous UI reporting for operator verification."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Components communicate via a standardized interface (R1) implemented with ROS 2 messages within the DT and Wi‑Fi links for PT‑DT exchange; the Data Translation FE handles serialization, message‑type alignment and unit conversion, and OPC UA is suggested as an optional transport protocol."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity runs on external compute resources (cloud or edge server), the Physical Twin Entity executes on the vehicle‑mounted NVIDIA Jetson Orin Nano, and the User Entity UI runs on a workstation or browser client; each entity is packaged as ROS 2 nodes deployed on its respective hardware."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system follows ISO 23247 reference architecture, ISO 15622 for ACC functional requirements, ISO/IEC 30173:2023 for digital‑twin terminology, and leverages 3GPP TS 22.185 latency guidelines; optional OPC UA (IEC 62541) may be used for data exchange."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations include adherence to ISO 15622 ACC class‑I requirements, strict latency (≤100 ms) and clock‑sync (≤100 ms) constraints, and remote command validation via the UI. Security measures are not explicitly described in the document."
]