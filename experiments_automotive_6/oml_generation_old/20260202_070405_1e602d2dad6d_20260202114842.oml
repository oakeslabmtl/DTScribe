// C3: Physical Sensing Components
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST10LX LiDAR retrofitted on the vehicle, producing high‑frequency point‑cloud data"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera mounted on the vehicle, capturing RGB‑D point‑clouds"
    DTDFVocab:producedData DepthCameraPointCloudTransmitted
]

instance FrontWheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel‑speed sensor on the front wheel, measuring rotational speed for vehicle state"
    DTDFVocab:producedData VehicleStateTransmitted
]

instance RearWheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel‑speed sensor on the rear wheel, measuring rotational speed for vehicle state"
    DTDFVocab:producedData VehicleStateTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor measuring the steering wheel angle for vehicle state"
    DTDFVocab:producedData VehicleStateTransmitted
]

// C4: Data Transmitted from Physical Sensors
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthCameraPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FrontWheelSpeedSensor, RearWheelSpeedSensor, SteeringAngleSensor
]

// C10: Data Instances Derived from Transmitted Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data serialized in the Digital Twin for perception"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
    DTDFVocab:fromData LiDARPointCloudTransmitted
]

instance DepthCameraPointCloudData : DTDFVocab:Data [
    base:desc "Raw depth‑camera point‑cloud data serialized in the Digital Twin for perception"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
    DTDFVocab:fromData DepthCameraPointCloudTransmitted
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Instantaneous vehicle state (speed, steering angle) transmitted for real‑time monitoring and control"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
    DTDFVocab:fromData VehicleStateTransmitted
]

// C10: Models Representing Logic and Dynamics
instance AccISO15622BasicACCModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control controller implementing ISO 15622 basic ACC strategy"
    DTDFVocab:inputTo PythonNodeLifecycleEnabler, CppNodeLifecycleEnabler
]

instance LidarClusteringDBSCANKalmanTrackerModel : DTDFVocab:Model [
    base:desc "LiDAR point‑cloud clustering via DBSCAN with Kalman‑filter tracking for object detection"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance VehicleDynamicsVehicleModel : DTDFVocab:Model [
    base:desc "Vehicle dynamics representation using experimental DT data for simulation and validation"
    DTDFVocab:inputTo CppNodeLifecycleEnabler
]

// C11: Enablers Supporting Services and Models
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS~2 middleware stack (Galactic/rolling) managing communication between physical and digital nodes"
    DTDFVocab:enables RealTimeDataMonitoringService, DataReportingService, AccSubsystemOffloadingService, RemoteControlManagementService, SQLDataStorageService
]

instance PythonNodeLifecycleEnabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 node lifecycle management for high‑level control logic"
    DTDFVocab:enables AccSubsystemOffloadingService
]

instance CppNodeLifecycleEnabler : DTDFVocab:Enabler [
    base:desc "C++ node lifecycle management for low‑latency vehicle dynamics and actuator control"
    DTDFVocab:enables RemoteControlManagementService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment providing DBSCAN clustering and Kalman‑filter tracking"
    DTDFVocab:enables AccSubsystemOffloadingService
]

instance NVIDIAJetPackSDK5Enabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5 SDK enabling GPU acceleration for perception and control"
    DTDFVocab:enables AccSubsystemOffloadingService, RemoteControlManagementService
]

instance GitHubRepositoryEnabler : DTDFVocab:Enabler [
    base:desc "GitHub repository host for source code, documentation, and open‑source artifacts"
    DTDFVocab:enables DataReportingService, SQLDataStorageService
]

instance OPCUADataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "OPC UA interface for optional data translation between DT and legacy systems"
    DTDFVocab:enables DataReportingService
]

// C6: Services Provided by the Digital Twin
instance RealTimeDataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time data monitoring and visualization of vehicle telemetry"
    DTDFVocab:provides HumanReadableReportInsight, PerformanceMetricInsight, ObjectTrackVisualizationInsight
]

instance DataReportingService : DTDFVocab:Service [
    base:desc "3D rendering and report generation service for human‑readable insights"
    DTDFVocab:provides HumanReadableReportInsight
]

instance AccSubsystemOffloadingService : DTDFVocab:Service [
    base:desc "Computation offloading of the ACC subsystem, including lead‑vehicle detection and speed computation per ISO 15622"
    DTDFVocab:provides EnableAccelerationAction, SetDesiredSpeedAction, UpdateAccParametersAction
]

instance RemoteControlManagementService : DTDFVocab:Service [
    base:desc "Remote management via a control panel for enabling/disabling ACC, setting desired speed, and triggering emergency brake"
    DTDFVocab:provides EnableAccelerationAction, SetDesiredSpeedAction, TriggerEmergencyBrakeAction
]

instance SQLDataStorageService : DTDFVocab:Service [
    base:desc "External SQL database storage for real‑time vehicle state, object tracks, and histogram time‑series"
]

// C17: Insights for Operators
instance HumanReadableReportInsight : DTDFVocab:Insight [
    base:desc "Human‑readable report summarizing vehicle performance and object track visualizations"
]

instance PerformanceMetricInsight : DTDFVocab:Insight [
    base:desc "Quantitative performance metrics such as latency, tracking accuracy, and ACC compliance"
]

instance ObjectTrackVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visual representation of tracked objects within the Digital Twin environment"
]

// C17: Actions Exposed to Users
instance EnableAccelerationAction : DTDFVocab:Action [
    base:desc "Action to enable or disable the Adaptive Cruise Control subsystem"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to set a desired speed for the vehicle in real‑time"
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Emergency braking action triggered remotely via the control panel"
    DTDFVocab:IsAutomatic false
]

instance UpdateAccParametersAction : DTDFVocab:Action [
    base:desc "Remote update of ACC controller parameters for tuning and debugging"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin outputs desired speed commands, steering adjustments, and emergency braking commands via the Actuation FE to the vehicle’s controller, and forwards ACC‑control decisions and remote‑management commands received from the UI to the vehicle over the same Wi‑Fi network."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data acquisition and processing with an end‑to‑end latency target of ≤100 ms from vehicle to Digital Twin; data updates occur on the perception cycle (~50–200 ms for LiDAR processing); the DT operates at synchronous timestamps synced to ±100 ms clock precision."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is orchestrated as a distributed system: Vehicle (Physical Twin Entity) hosts sensor acquisition nodes; Digital Twin Entity runs on an external server or edge device providing data processing, ACC computation, reporting, and actuation; User Entity hosts a 3‑D visualization and control‑panel UI; all communicate via ROS2 topics over a Wi‑Fi network, with Data Translation FE ensuring protocol and unit consistency."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT undergoes design (conceptual modeling and mapping to ISO 23247 entities), implementation (ROS2 node development), validation (simulation and real‑world testing of ACC per ISO 15622), deployment (real‑time operation with cloud offloading), and operation (ongoing monitoring, remote management, and iterative refinement)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity achieved by using actual on‑board sensors and real‑time LiDAR processing; validity ensured by adhering to ISO 15622 for ACC control and ISO 23247 for architectural structure; latency measurements confirm <100 ms end‑to‑end; validation via real‑vehicle ACC operations and automated data logging."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange uses ROS2 over a Wi‑Fi link; Data Translation FE serializes ROS2 messages, aligns signal types, and performs unit conversions; inter‑entity communication follows ISO 23247 entity interfaces, while intra‑entity communication uses ROS2 topics and services."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital Twin runs on external compute (edge or cloud) with ROS2 master; Physical Twin entities run on the vehicle’s Jetson devices; the Whole system can be deployed across distributed nodes connected by Wi‑Fi; optional cloud hosting not specified, but offload implied."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adopts ISO 23247 reference architecture with Functional Entities, ISO 15622 ACC control strategy, and ROS 2 middleware; data translation may leverage OPC UA as per ISO 23247 optional guidance."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is safety‑critical, mandating ≤100 ms latency and accurate clock synchronization (≤100 ms). It implements real‑time control of vehicle actuators (speed, steering), with the capability for emergency braking. No explicit cybersecurity or safety certification procedures are described; the design relies on secure Wi‑Fi communication and standard industrial protocols (ROS 2, OPC UA)."
]