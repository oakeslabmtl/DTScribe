// ======================
// C2: Acting Components
// ======================
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Provides motor voltage commands for speed control of the 1/10‑scale autonomous vehicle"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Controls the steering servo to adjust vehicle heading"
]

instance EmergencyBrakingActuator : DTDFVocab:ActingComponent [
    base:desc "Issues an emergency‑braking command to the onboard electronic speed controller"
]

// ======================
// C3: Physical Sensing Components
// ======================
instance HokuyoLiDARUST10LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2‑D LiDAR delivering real‑time point‑cloud streams"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera providing RGB‑D images"
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of vehicle longitudinal speed"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of steering wheel angle"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// ======================
// C4: Data Transmitted (Physical → Virtual)
// ======================
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARUST10LX
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ObjectTracksTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudTransmitted, DepthImageTransmitted
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedTransmitted, SteeringAngleTransmitted
]

// ======================
// C5: Data (Virtual)
// ======================
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw point‑cloud data produced by the LiDAR"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames generated by the RealSense camera"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Timestamped vehicle longitudinal speed values"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Timestamped steering angle measurements"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks derived from DBSCAN clustering and Kalman filtering"
    DTDFVocab:fromData ObjectTracksTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Combined vehicle speed and steering state used by the ACC controller"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

// ======================
// C11: Enablers
// ======================
instance ROS2DDSMiddleware : DTDFVocab:Enabler [
    base:desc "ROS 2 DDS middleware handling topic‑based communication over Wi‑Fi"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "ISO 23247 Data Translation functional entity that serialises and unit‑converts data streams"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance MATLABSimulinkRuntime : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink runtime executing DBSCAN clustering and Kalman‑filter tracking"
    DTDFVocab:enables ComputationOffloadingService
]

instance NVIDIAJetpack5SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK providing GPU‑accelerated computation for the ACC controller"
    DTDFVocab:enables ComputationOffloadingService
]

instance VisualizationRenderer : DTDFVocab:Enabler [
    base:desc "3‑D visualization renderer used by the UI to display vehicle state and object tracks"
    DTDFVocab:enables DataMonitoringService
]

// ======================
// C6: Services
// ======================
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI service that visualises real‑time vehicle state, projected path and object tracks; generates time‑series reports"
    DTDFVocab:provides RealTimeVisualizationInsight, AnalyticalReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes the ACC algorithm (lead‑vehicle detection and speed computation) in the digital twin"
    DTDFVocab:provides AccComputationInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, adjust desired speed, or trigger emergency braking via the UI"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakingAction
]

// ======================
// C17: Insights & Actions
// ======================
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visual insight of vehicle speed, steering angle, object tracks and projected path"
]

instance AnalyticalReportInsight : DTDFVocab:Insight [
    base:desc "Generated analytical report summarising recent vehicle dynamics and detected objects"
]

instance AccComputationInsight : DTDFVocab:Insight [
    base:desc "ACC controller output indicating safe following speed and brake command suggestion"
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator adjusts the desired cruising speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking of the vehicle"
    DTDFVocab:IsAutomatic false
]

// ======================
// C10: Models
// ======================
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering algorithm used to segment raw LiDAR data"
    DTDFVocab:inputTo MATLABSimulinkRuntime
]

instance KalmanFilterTrackerModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based multi‑object tracker applied to clustered points"
    DTDFVocab:inputTo MATLABSimulinkRuntime
]

instance ACCControllerModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control controller compliant with ISO 15622, computing safe speed set‑points"
    DTDFVocab:inputTo NVIDIAJetpack5SDK
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model rendering vehicle state, projected path and object tracks in the UI"
    DTDFVocab:inputTo VisualizationRenderer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity sends the computed desired speed (ACC output) and remote‑management commands (enable/disable ACC, set desired speed, emergency brake) back to the PT over the same Wi‑Fi/ROS2 channel, where the Actuation FE converts them into motor voltage and servo commands."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is designed for sub‑100 ms end‑to‑end network latency and clock synchronization accuracy of 100 ms, enabling real‑time ACC control loops at the perception‑cycle rate."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 reference model: Physical Twin Entity hosts data pre‑processing and actuation FEs; Digital Twin Entity hosts Data Collecting, Reporting, Presentation, and Controlling FEs; User Entity hosts separate Visualization and Control‑Panel UI FEs; all entities communicate via ROS2 intra‑node messaging and Wi‑Fi inter‑entity links."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is used during the operated (run‑time) stage for monitoring, off‑loading, and remote management, and also supports development‑time troubleshooting of the ACC subsystem."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Sensor data are processed in real time with DBSCAN clustering and Kalman filtering to ensure accurate object tracking; the ACC algorithm adheres to ISO 15622 specifications; latency ≤100 ms and clock sync ≤100 ms are enforced to maintain safety‑critical performance; reporting UI provides verification of system behavior."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The PT communicates with the DT over a Wi‑Fi network using ROS2/DDS as the standardized communication interface (R1); Data Translation FE performs serialization, message‑type alignment, and unit conversion for all exchanged data streams."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the NVIDIA Jetson Orin Nano mounted on the vehicle; Digital Twin Entity is hosted on external compute resources (e.g., cloud or edge server) to provide off‑loaded computation; User Entity runs on a desktop workstation; each entity is packaged as a ROS2 node set."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The design follows ISO 23247 (Digital Twin Manufacturing Framework) for entity and functional decomposition, ISO 15622 for ACC functionality, and uses ROS2 (DDS) as a standardized communication middleware; R1 mandates a standardized interface between all components."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by limiting network latency to ≤100 ms, enforcing clock synchronization within 100 ms, and implementing ACC per ISO 15622; remote management commands are executed through controlled UI interfaces, and the system design acknowledges the safety‑critical nature of off‑loading computation and actuation."
]