// Sensing Components
instance HokuyoUST10LXLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR generating raw point clouds"
    DTDFVocab:producedData RawPointCloudDataTransmitted
]

instance IntelD435iDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera providing RGB‑D data"
    DTDFVocab:producedData RGBDDataTransmitted
]

instance OnboardSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard vehicle speed sensor measuring vehicle speed"
    DTDFVocab:producedData VehicleSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring heading"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// Data Transmitted
instance RawPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDARSensor
]

instance RGBDDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCameraSensor
]

instance VehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OnboardSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Data
instance RawPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data stream"
    DTDFVocab:fromData RawPointCloudDataTransmitted
    DTDFVocab:inputTo NVIDIAJetpackSDKEnabler
]

instance RGBDData : DTDFVocab:Data [
    base:desc "RGB‑D sensor data stream"
    DTDFVocab:fromData RGBDDataTransmitted
    DTDFVocab:inputTo NVIDIAJetpackSDKEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed measurement data"
    DTDFVocab:fromData VehicleSpeedDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle measurement data"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance ClusteringResultsData : DTDFVocab:Data [
    base:desc "DBSCAN clustering result of point cloud data"
    DTDFVocab:fromData RawPointCloudDataTransmitted
    DTDFVocab:inputTo NVIDIAJetpackSDKEnabler
]

instance TrackingData : DTDFVocab:Data [
    base:desc "Kalman‑filter tracking of detected objects"
    DTDFVocab:fromData ClusteringResultsData
    DTDFVocab:inputTo NVIDIAJetpackSDKEnabler
]

instance ACCControlCommandData : DTDFVocab:Data [
    base:desc "ACC algorithm computed control command"
    DTDFVocab:fromData VehicleSpeedDataTransmitted
    DTDFVocab:inputTo NVIDIAJetpackSDKEnabler
]

// Models
instance StateSpaceModelVehicleDynamics : DTDFVocab:Model [
    base:desc "State‑space model of vehicle dynamics for ACC simulation"
    DTDFVocab:inputTo NVIDIAJetpackSDKEnabler
]

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm for LiDAR point clouds"
    DTDFVocab:inputTo NVIDIAJetpackSDKEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter tracking of object states"
    DTDFVocab:inputTo NVIDIAJetpackSDKEnabler
]

instance SQLDatabase : DTDFVocab:Model [
    base:desc "SQL database for persistent storage of state and track time‑series"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance ThreeDVisualizationModel : DTDFVocab:Model [
    base:desc "3D visualization model for rendering vehicle state and object tracks"
    DTDFVocab:inputTo NVIDIAJetpackSDKEnabler
]

// Acting Components
instance VedderElectronicSpeedControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller actuating motor voltage"
]

instance SteeringServoControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Servo controller actuating steering wheel"
]

instance EmergencyBrakingActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency braking actuator commanded by DT"
]

// Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware (Python, C++) used for data collection, translation and actuation"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance NVIDIAJetpackSDKEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK providing GPU acceleration for computation and visualization"
    DTDFVocab:enables ComputationOffloadingService, VisualizationService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI, data logging, and report generation for ACC monitoring"
    DTDFVocab:provides VehicleSpeedInsight, SteeringAngleInsight, ProjectedPathInsight, DetectedObjectTracksInsight, PerformanceIssueDetectionInsight, ACCParameterTuningInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management of ACC, including enable/disable, desired speed setting, and emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, TriggerEmergencyBrakingAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D rendering of vehicle state and object tracks for driver UI"
    DTDFVocab:provides ThreeDRenderingInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm executed on the DT and sending ACC control commands to the PT"
    DTDFVocab:provides ACCControlInsight
]

// Insights
instance VehicleSpeedInsight : DTDFVocab:Insight [
    base:desc "Driver UI displays real‑time vehicle speed"
]

instance SteeringAngleInsight : DTDFVocab:Insight [
    base:desc "Driver UI displays real‑time steering angle"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Driver UI displays projected path"
]

instance DetectedObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Driver UI displays detected object tracks"
]

instance PerformanceIssueDetectionInsight : DTDFVocab:Insight [
    base:desc "Data logs and reports enable developers to identify performance issues"
]

instance ACCParameterTuningInsight : DTDFVocab:Insight [
    base:desc "Developers tune ACC parameters based on logs and reports"
]

instance ThreeDRenderingInsight : DTDFVocab:Insight [
    base:desc "3D rendering of vehicle state and object tracks"
]

instance ACCControlInsight : DTDFVocab:Insight [
    base:desc "ACC algorithm computes control commands based on vehicle dynamics"
]

// Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Remote operator enables Automotive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Remote operator disables Automotive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking command"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Desired speed and steering commands generated by the ACC Controlling FE are converted into motor voltage and servo control signals, transmitted over Wi‑Fi ROS 2 topics to the actuator controllers on the PT; remote enable/disable and emergency braking commands are also sent via ROS 2."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT is required to maintain end‑to‑end latency ≤100 ms and synchronize clocks to 100 ms accuracy. Real‑time monitoring and control run in a tight loop at or below this 100 ms cycle, enabling near real‑time interaction."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An ISO 23247‑based entity architecture where the Physical Twin Entity encapsulates sensors and actuators, the Digital Twin Entity implements data collection, preprocessing, ACC control and reporting, the User Entity delivers 3‑D visualization and command panels, and the Cross‑System Entity handles data translation; all components communicate over ROS 2 topics across Wi‑Fi links."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (CAD modeling of vehicle platforms), Manufacturing (physical twin assembly and retrofitting), Operation (real‑time fleet operation and data monitoring), and Development (systematic testing/validation of digital twin services)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time fidelity ensured by DBSCAN and Kalman filter tracking, ACC control validated against ISO 15622 specification, end‑to‑end latency (<100 ms) verified, 100 ms clock synchronization, and data translation maintaining unit consistency; safety controls enforced by restricting computation to DT and limiting actuator commands to compliant ranges."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual and virtual‑to‑physical communication uses Wi‑Fi network employing ROS2 (DDS) over UDP/IP. Data Translation FE performs serialization, unit conversion, and message alignment. The network adheres to ISO 23247 Data Translation FE specifications."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "On‑board execution on NVIDIA Jetson Orin Nano (Digital Twin services, sensor data collection), remote host (UI, 3‑D visualization, command input) possibly a laptop or cloud server; assembled into a ROS 2 ecosystem."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture for entity‑based DT; ISO 15622 for ACC behavior; ROS 2 for middleware; NVIDIA Jetpack, ROS 2 and standard sensor drivers; adherence to ISO/IEC 30173 terminology."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security aspects are not detailed; safety is addressed through compliance with ISO 15622 ACC spec, stringent latency and clock synchronization requirements, and real‑time control to prevent hazardous events. No specific cybersecurity measures (e.g., encryption, authentication) are reported."
]