// C3: Physical sensing components
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel speed sensor measuring ego vehicle speed."
    DTDFVocab:producedData VehicleStateDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring vehicle steering angle."
    DTDFVocab:producedData VehicleStateDataTransmitted
]

instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR for point cloud acquisition."
    DTDFVocab:producedData LiDARObjectTracksDataTransmitted
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera for RGB‑D imaging."
    DTDFVocab:producedData DepthCameraPointCloudDataTransmitted
]

// C4: Physical-to-virtual interaction
instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor, SteeringAngleSensor
]

instance LiDARObjectTracksDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthCameraPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

// C10: Models/Data
instance EgoVehicleStateData : DTDFVocab:Data [
    base:desc "Ego vehicle state (speed and steering angle) received by the Digital Twin."
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo ACCComputationEnabler
]

instance LiDARObjectTracksData : DTDFVocab:Data [
    base:desc "LiDAR‑derived object tracks (positions and velocities) received by the Digital Twin."
    DTDFVocab:fromData LiDARObjectTracksDataTransmitted
    DTDFVocab:inputTo ClusteringTrackingEnabler
]

instance DepthCameraPointCloudData : DTDFVocab:Data [
    base:desc "Point cloud data from the Intel D435i depth camera received by the Digital Twin."
    DTDFVocab:fromData DepthCameraPointCloudDataTransmitted
    DTDFVocab:inputTo VisualizationEnabler
]

// C11: Enablers
instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler feeding ego vehicle state data into the ACC algorithm."
    DTDFVocab:enables ACCComputationService
]

instance ClusteringTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler feeding LiDAR tracks into the clustering and tracking model."
    DTDFVocab:enables ClusteringTrackingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler feeding point‑cloud and tracking data into 3‑D visualization."
    DTDFVocab:enables VisualizationService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler allowing remote control of ACC and emergency braking."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance ACCComputationService : DTDFVocab:Service [
    base:desc "ACC computation performed on the Digital Twin based on ego vehicle state."
    DTDFVocab:provides ACCStatusInsight, EnableACCAction, DisableACCAction, SetDesiredSpeedAction
]

instance ClusteringTrackingService : DTDFVocab:Service [
    base:desc "Object tracking via DBSCAN clustering and Kalman filtering of LiDAR data."
    DTDFVocab:provides TrackingInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3‑D rendering of vehicle and surrounding environment using point‑cloud and tracking data."
    DTDFVocab:provides VisualizationInsight, ThreeDVisualizationAction, RealTimeMonitoringDashboardInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables remote control of ACC parameters and emergency braking."
    DTDFVocab:provides RemoteManagementInsight, EmergencyBrakingAction
]

// C17: Insights
instance ACCStatusInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time monitoring of ACC mode availability and status on the Digital Twin."
]

instance TrackingInsight : DTDFVocab:Insight [
    base:desc "Insight showing tracked object positions and predicted paths using DBSCAN and Kalman filtering."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing the 3‑D rendering of vehicle and environment."
]

instance RemoteManagementInsight : DTDFVocab:Insight [
    base:desc "Insight detailing remote enable/disable ACC, desired speed settings, and emergency braking status."
]

instance RealTimeMonitoringDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time dashboard displaying vehicle state and object tracks."
]

// C17: Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action allowing operators to enable Adaptive Cruise Control from the Digital Twin interface."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Action allowing operators to disable Adaptive Cruise Control from the Digital Twin interface."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to set the desired speed for the ACC algorithm."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Action to trigger emergency braking directly from the Digital Twin."
    DTDFVocab:IsAutomatic true
]

instance ThreeDVisualizationAction : DTDFVocab:Action [
    base:desc "Action to toggle or control the 3‑D visualization of the vehicle environment."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends desired speed commands back to the vehicle; the Actuation FE converts desired speed into motor voltage, which is transmitted over Wi‑Fi and applied to the Electronic Speed Controller, enabling remote ACC control and the UI issues enable/disable ACC, set desired speed, and emergency braking commands."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with end‑to‑end latency ≤ 100 ms from vehicle to DT and clock synchronization accuracy of ≤ 100 ms, ensuring time‑synchronised data for ACC computation and actuation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates sensors and actuators in the Physical Twin Entity, data collection, reporting, and ACC computation within the Digital Twin Entity, and user interaction via 3D Visualization and Control Panel in the User Entity, all coordinated by the Cross‑System Data Translation entity; ROS2 nodes communicate over Wi‑Fi with shared message topics."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT operates in the operated stage; it is developed and verified against R1‑R8 during a construction phase and deployed for real‑time operation and remote management of the 1/10‑scale vehicle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time fidelity maintained via 100 ms latency bound. Sensor data validation using filtering; ACC control validated against ISO 15622 specs. Model uncertainties addressed through filtering and emulation tests. Safety‑critical constraints require continuous integrity checks."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication uses ROS2 over a Wi‑Fi network for inter‑entity messaging; the Data Translation FE serializes data into message types, and sensor data is delivered via ROS2 topics; connectivity between PT and DT is wireless with typical 2.4 GHz Wi‑Fi links."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Components run on the vehicle’s NVIDIA Jetson Orin Nano for on‑board processing (Physical Twin and part of Digital Twin), off‑loaded ACC computation on an external server or cloud host, and UI on a user workstation; deployment follows containerised ROS2 packages."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 Part 2 reference architecture is applied for the DT structure, ROS2 communication interfaces conform to standard middleware practices, NVIDIA Jetpack SDK follows NVIDIA standards, and communication interfaces are standardized per R1."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical remote operations necessitate coverage of communication latency, fail‑safe actuation, and adherence to ISO 15622 safety constraints. The design acknowledges the risk of remote execution causing accidents, requiring robust safety mechanisms; however explicit safety measures are not detailed."
]