// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing 2D laser scans of the surroundings"
    DTDFVocab:producedData LiDARPointCloudTransmission
]

instance IntelRealSenseCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D images"
    DTDFVocab:producedData DepthImageTransmission
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle internal measurements of speed and steering angle from chassis electronics"
    DTDFVocab:producedData VehicleStateTransmission
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance LiDARPointCloudTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthImageTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseCamera
]

instance VehicleStateTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance ObjectTracksTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom KalmanFilterTrackerModel
]

// C10: Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data streamed in real time over Wi‑Fi"
    DTDFVocab:fromData LiDARPointCloudTransmission
    DTDFVocab:inputTo DBSCANClusteringModel
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames from the RealSense camera transmitted to the Digital Twin"
    DTDFVocab:fromData DepthImageTransmission
    DTDFVocab:inputTo DBSCANClusteringModel
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Ego‑vehicle speed and steering‑angle values transmitted continuously"
    DTDFVocab:fromData VehicleStateTransmission
    DTDFVocab:inputTo ACCControlModelISO15622
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Detected and tracked object positions and velocities"
    DTDFVocab:fromData ObjectTracksTransmission
    DTDFVocab:inputTo DataVisualizationEnabler
]

// C10: Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN‑based point‑cloud clustering module for object detection"
    DTDFVocab:inputTo KalmanFilterTrackerModel
]

instance KalmanFilterTrackerModel : DTDFVocab:Model [
    base:desc "Kalman‑filter tracker that fuses clusters into continuous object tracks"
    DTDFVocab:inputTo ACCControlModelISO15622, Visualization3DModel
]

instance ACCControlModelISO15622 : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) model compliant with ISO 15622 for lead‑vehicle detection and speed computation"
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model used to render vehicle state, object tracks and projected path in the UI"
    DTDFVocab:inputTo DataVisualizationEnabler
]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware used for all functional entities, packaged as ROS2 nodes"
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService, DataMonitoringUIService, ReportGenerationService
]

instance WiFiCommunication : DTDFVocab:Enabler [
    base:desc "Wi‑Fi networking layer for real‑time data exchange between Physical Twin and Digital Twin"
    DTDFVocab:enables DataMonitoringUIService, RemoteManagementService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Remote compute resources that execute the ACC algorithm and return desired speed"
    DTDFVocab:enables ComputationOffloadingService
]

instance DataVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Visualization pipeline enabling the UI service for rendering vehicle state, tracks and projected path"
    DTDFVocab:enables DataMonitoringUIService
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL database storing time‑series vehicle data for reporting"
    DTDFVocab:enables ReportGenerationService
]

// C6: Services
instance DataMonitoringUIService : DTDFVocab:Service [
    base:desc "UI service that visualises vehicle state, object tracks and projected path"
    DTDFVocab:provides InsightVehicleState, InsightObjectTracks, InsightProjectedPath,
                ActionEnableACC, ActionDisableACC, ActionSetDesiredSpeed, ActionEmergencyBrake
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service that offloads the ACC algorithm to the remote Digital Twin and returns the desired speed"
    DTDFVocab:provides ActionComputeDesiredSpeed
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management service allowing operators to enable/disable ACC, set desired speed, and trigger emergency braking"
    DTDFVocab:provides ActionEnableACC, ActionDisableACC, ActionSetDesiredSpeed, ActionEmergencyBrake
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Service that generates time‑series reports from the SQL database"
    DTDFVocab:provides InsightReportGeneration
]

// C17: Insights
instance InsightVehicleState : DTDFVocab:Insight [
    base:desc "Real‑time insight of ego‑vehicle speed and steering angle displayed in the UI"
]

instance InsightObjectTracks : DTDFVocab:Insight [
    base:desc "Real‑time insight of detected object tracks visualised on the UI"
]

instance InsightProjectedPath : DTDFVocab:Insight [
    base:desc "Projected trajectory of the vehicle based on ACC computation displayed in the UI"
]

instance InsightReportGeneration : DTDFVocab:Insight [
    base:desc "Post‑mission analytical report of time‑series vehicle data"
]

// C17: Actions
instance ActionEnableACC : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance ActionDisableACC : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance ActionSetDesiredSpeed : DTDFVocab:Action [
    base:desc "Operator command to set a new desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance ActionEmergencyBrake : DTDFVocab:Action [
    base:desc "Operator command to trigger immediate emergency braking"
    DTDFVocab:IsAutomatic false
]

instance ActionComputeDesiredSpeed : DTDFVocab:Action [
    base:desc "Automatic computation of desired speed by remote ACC model"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance VehicleSpeedActuator : DTDFVocab:ActingComponent [
    base:desc "ESC controller converting desired speed into motor voltage commands"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Servo actuator adjusting steering angle according to command"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator that applies emergency brake command from the Digital Twin"
]

// C9: Components (entities)
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical Twin Entity running on vehicle hardware with sensors and actuators"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital Twin Entity executed on remote compute/cloud"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User Entity hosted on operator workstations providing the UI"
]

// Environment
instance DTConstellationEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity, DigitalTwinEntity, UserEntity
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT, including desired speed values for the motor, enable/disable ACC signals, emergency‑braking commands, and steering adjustments, all routed through the Actuation FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All DT services operate in real‑time with an end‑to‑end network latency requirement of ≤100 ms (R7) and clock synchronization accuracy of 100 ms (R8)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation comprises a Physical Twin Entity (data pre‑processing and actuation FEs), a Digital Twin Entity (data collection, reporting, ACC controlling, and presentation FEs), a User Entity (3D visualization and control‑panel UI FEs), and a Cross‑System Data Translation FE; components are deployed on the vehicle, a remote server, and operator workstations."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed primarily in the operational stage to monitor, control, and analyse the running vehicle, while also supporting design‑time experimentation through high‑fidelity simulation components."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT maintains sub‑100 ms latency and clock sync to ensure temporal fidelity; tracking accuracy relies on DBSCAN clustering and Kalman filtering, and ACC behavior follows ISO 15622 specifications, providing a validated functional fidelity for safety‑critical operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑digital communication uses a Wi‑Fi network with data serialized by the Data Translation FE; intra‑entity messaging uses ROS2 topics/services, and optional OPC UA is mentioned as a possible implementation for the Data Translation FE."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity components run on the NVIDIA Jetson Orin Nano aboard the vehicle; the Digital Twin Entity (including ACC computation and database) runs on a remote cloud/edge server; the User Entity UI runs on a workstation connected via the same Wi‑Fi network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Reference Architecture, Functional Entities), uses ISO 15622 for ACC functional requirements, and references ISO/IEC 30173 for digital‑twin terminology."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed for a safety‑critical ACC function with latency and synchronization constraints (≤100 ms); remote management commands (including emergency braking) are supported, but specific security mechanisms (e.g., authentication, encryption) are not described in the document."
]