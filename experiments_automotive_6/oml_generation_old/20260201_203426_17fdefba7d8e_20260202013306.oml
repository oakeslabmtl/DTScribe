// C3: Physical sensing components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing real‑time point‑cloud object tracks"
    DTDFVocab:producedData LiDARObjectTracksTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering dense depth point‑clouds"
    DTDFVocab:producedData DepthCameraPointCloudTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Internal vehicle speed sensor delivering ego‑vehicle speed values"
    DTDFVocab:producedData SpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor providing real‑time wheel steering angle"
    DTDFVocab:producedData SteeringDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LiDARObjectTracksTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C10: Data
instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Clustered and tracked object tracks derived from LiDAR point‑clouds"
    DTDFVocab:fromData LiDARObjectTracksTransmitted
    DTDFVocab:inputTo AccComputationEnabler, DataTranslationEnabler
]

instance DepthCameraPointCloudData : DTDFVocab:Data [
    base:desc "Depth camera point‑cloud used for supplemental environment perception"
    DTDFVocab:fromData DepthCameraPointCloudTransmitted
    DTDFVocab:inputTo AccComputationEnabler
]

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Ego‑vehicle speed value transmitted from speed sensor"
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo AccComputationEnabler, DataTranslationEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering wheel angle transmitted from steering‑angle sensor"
    DTDFVocab:fromData SteeringDataTransmitted
    DTDFVocab:inputTo AccComputationEnabler, DataTranslationEnabler
]

// C10: Models
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering combined with Kalman‑filter tracking for object detection"
    DTDFVocab:inputTo AccComputationEnabler
]

instance AccControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model based on ISO 15622 (lead‑vehicle detection and speed computation)"
    DTDFVocab:inputTo AccComputationEnabler
]

// C11: Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247 Data Translation functional entity routing sensor data to UI monitoring"
    DTDFVocab:enables DataMonitoringService
]

instance AccComputationEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247 Computation Offloading functional entity executing ACC algorithms in the digital twin"
    DTDFVocab:enables ComputationOffloadingService, ReportingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247 Remote Management functional entity handling operator commands"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualizes speed, steering angle, object tracks and projected path in real‑time"
    DTDFVocab:provides RealTimeSpeedInsight, RealTimeSteeringInsight, RealTimeObjectTracksInsight, ProjectedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC control algorithm off‑board and returns desired speed for actuation"
    DTDFVocab:provides DesiredSpeedInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator UI enables/disables ACC, adjusts desired speed, and triggers emergency braking"
    DTDFVocab:provides EnableAccAction, DisableAccAction, AdjustDesiredSpeedAction, EmergencyBrakingAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Generates time‑series reports stored in SQL database for post‑run analysis"
    DTDFVocab:provides RunReportInsight
]

// C17: Insights
instance RealTimeSpeedInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of ego‑vehicle speed"
]

instance RealTimeSteeringInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of steering angle"
]

instance RealTimeObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of detected object tracks"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected future path of ego‑vehicle based on current state and ACC plan"
]

instance DesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Computed desired speed from ACC algorithm presented to operator"
]

instance RunReportInsight : DTDFVocab:Insight [
    base:desc "Generated post‑run analytical report containing time‑series of speed, steering, and object tracks"
]

// C17: Actions
instance EnableAccAction : DTDFVocab:Action [
    base:desc "Operator enables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableAccAction : DTDFVocab:Action [
    base:desc "Operator disables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator adjusts the ACC target speed"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking"
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Motor drive (Vedder ESC) converting desired speed commands into motor voltage"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo applying steering angle commands to wheels"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT sends ACC control commands (desired speed, enable/disable ACC, emergency‑brake) and actuation voltage set‑points back to the PT over the same Wi‑Fi link; commands are issued by the Controlling FE (ACC) and Actuation FE and executed by the motor/steering actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with end‑to‑end network latency bounded to ≤100 ms (per 3GPP TS 22.185) and clock synchronization accuracy of 100 ms across all DT components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A coordinated constellation where the Physical Twin Entity provides sensor data and actuation, the Digital Twin Entity hosts the ACC algorithm, data collection, storage and visualization, and the User Entity offers a 3D visualization and control‑panel UI; all entities communicate via standardized ROS2 interfaces and a Wi‑Fi link."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT supports the design/verification stage (simulation‑based testing), development stage (troubleshooting with data collection), and operational stage (runtime monitoring, control and remote management of the ACC system)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity sensor data (LiDAR point clouds) processed with DBSCAN/Kalman filter; ACC algorithm conforms to ISO 15622; latency ≤100 ms and clock sync ≤100 ms ensure temporal fidelity; safety‑critical nature imposes real‑time constraints and validation through on‑board testing."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional Wi‑Fi link between PT and DT; intra‑entity communication via ROS2 (publish/subscribe) using the Data Translation FE for serialization and unit conversion; optional OPC UA mentioned as a possible transport but not used."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the on‑board NVIDIA Jetson Orin Nano; Digital Twin Entity runs on an external compute platform (cloud or workstation) hosting ROS2 nodes for ACC, data collection, storage and visualization; User Entity UI runs on a workstation connected to the DT via the same network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Architecture follows ISO 23247 (Digital Twin Manufacturing Framework) entity model; ACC functionality complies with ISO 15622; communication latency benchmark follows 3GPP TS 22.185; ROS2 provides an open‑source middleware standard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical operation mandates latency ≤100 ms and clock sync ≤100 ms; remote commands include emergency braking; however, specific cybersecurity mechanisms (e.g., authentication, encryption) are not described in the document."
]