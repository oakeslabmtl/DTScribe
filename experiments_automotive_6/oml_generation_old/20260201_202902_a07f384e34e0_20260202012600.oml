// C3: Physical sensing components
instance LiDARUnitSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR unit that produces raw point‑cloud data for the 1/10‑scale autonomous vehicle"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor measuring longitudinal speed of the scale vehicle"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance VehiclePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor providing X‑Y coordinates of the vehicle on the test track"
    DTDFVocab:producedData VehiclePositionTransmitted
]

instance MotorAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Rotary encoder measuring the drive‑motor shaft angle"
    DTDFVocab:producedData MotorAngleTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering servo position sensor reporting the current steering angle"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// C4: Data transmitted from physical to virtual
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARUnitSensor
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance VehiclePositionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehiclePositionSensor
]

instance MotorAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorAngleSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C10: Data objects
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud frame acquired from the vehicle"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataPreProcessingEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Instantaneous vehicle speed value (m/s)"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehiclePositionData : DTDFVocab:Data [
    base:desc "Current vehicle XY position on the test arena"
    DTDFVocab:fromData VehiclePositionTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance MotorAngleData : DTDFVocab:Data [
    base:desc "Drive‑motor shaft angle (degrees)"
    DTDFVocab:fromData MotorAngleTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering servo angle (degrees)"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

// C10: Models
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Geometric processing model that clusters LiDAR points and tracks objects"
    DTDFVocab:inputTo ACCControlEnabler
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "Analytical ACC behavioral model that computes desired speed from lead‑vehicle detection"
    DTDFVocab:inputTo ACCControlEnabler
]

// C11: Enablers
instance DataPreProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Software component that runs PointCloudClusteringTrackingModel on incoming LiDAR data"
    DTDFVocab:enables ComputationOffloadingService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation FE that serialises streams, aligns message types and performs unit conversions"
    DTDFVocab:enables ComputationOffloadingService
]

instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "Controlling FE that hosts AdaptiveCruiseControlModel and issues desired‑speed commands"
    DTDFVocab:enables ComputationOffloadingService
]

instance MotorActuationEnabler : DTDFVocab:Enabler [
    base:desc "Motor Actuation FE that receives speed commands and drives the vehicle’s motor via ROS2 service"
    DTDFVocab:enables RemoteManagementService
]

instance SteeringActuationEnabler : DTDFVocab:Enabler [
    base:desc "Steering Servo Actuation FE that receives steering‑angle commands and positions the steering servo"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides a UI that displays real‑time vehicle state, projected path and object tracks; allows data saving and report generation"
    DTDFVocab:provides VehicleStateInsight
    DTDFVocab:provides GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes the ACC algorithm in the cloud and sends the computed speed command back to the vehicle"
    DTDFVocab:provides ACCStatusInsight
    DTDFVocab:provides SetDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed and issue emergency‑brake commands via the UI"
    DTDFVocab:provides EnableACCAction
    DTDFVocab:provides DisableACCAction
    DTDFVocab:provides SetDesiredSpeedAction
    DTDFVocab:provides EmergencyBrakeAction
]

// C17: Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current vehicle speed, position, and actuator states useful for monitoring"
]

instance ACCStatusInsight : DTDFVocab:Insight [
    base:desc "Insight indicating whether ACC is active and the currently computed desired speed"
]

// C17: Actions
instance GenerateReportAction : DTDFVocab:Action [
    base:desc "User‑initiated action to generate a PDF/CSV report of logged vehicle data"
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Command to enable Adaptive Cruise Control on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Command to disable Adaptive Cruise Control on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Command to set the target speed for the ACC controller"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediate brake command issued by the operator to stop the vehicle"
    DTDFVocab:IsAutomatic false
]

// C2: Acting components (physical actuators)
instance MotorActuationComponent : DTDFVocab:ActingComponent [
    base:desc "Motor Actuation FE that drives the vehicle’s drive‑motor based on speed commands from the DT"
]

instance SteeringServoActuationComponent : DTDFVocab:ActingComponent [
    base:desc "Steering Servo Actuation FE that positions the steering servo based on angle commands from the DT"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity sends control commands back to the Physical Twin Entity to actuate the vehicle. Commands include desired speed values computed by the off‑loaded ACC service, ACC enable/disable requests, and emergency‑brake commands issued from the User Interface Control Panel FE. These commands are transmitted over the same Wi‑Fi/UDP link and are processed by the Actuation FE, which forwards them to the vehicle actuators (motor, steering servo). The DT receives confirmation of execution via updated vehicle state data displayed in the 3D Visualization, providing a feedback loop. No explicit validation, authentication, or conflict‑resolution mechanisms are described in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires clock synchronization between vehicle and digital twin with an accuracy of 100 ms, as mandated by safety‑critical vehicular standards and limited by the available hardware. Real‑time ACC services (data monitoring, computation off‑loading, remote management) demand low end‑to‑end latency communication; the off‑loaded ACC controller must receive sensor updates and return the desired speed within a latency budget comparable to the 100 ms synchronization window to maintain safe vehicle operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DTS follows the ISO 23247 reference architecture with an entity‑based decomposition. Software components are mapped to Functional Entities (FEs) and implemented as ROS 2 packages; each package hosts ROS 2 nodes that realize the functionality of its FE. The three services—Data Monitoring, Computation Off‑loading, and Remote Management—are orchestrated through ROS 2 topics and services, enabling modular integration and runtime allocation of compute resources (e.g., cloud or edge) while preserving low‑latency communication with the vehicle. Resource management is achieved by delegating the ACC control loop to the Digital Twin Entity while the Physical Twin Entity handles sensor acquisition and actuation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is driven by the safety‑critical nature of the ACC use case and the need for low end‑to‑end latency; the architecture enforces a 100 ms clock‑synchronisation bound and uses ROS 2 for deterministic intra‑entity communication. Validation and verification are implicitly handled by the Data Translation FE, which performs unit conversion and message‑type alignment, reducing data‑type errors. Uncertainty sources include sensor noise from the LiDAR and timing jitter; the 100 ms synchronization requirement bounds the timing uncertainty. No explicit quantitative validation procedures or error‑correction mechanisms are described; quality assurance relies on the structured entity‑based design and adherence to ISO 23247 functional entities."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system relies on two complementary communication stacks. Inside each entity, software components are packaged as ROS 2 nodes that exchange messages via the DDS protocol of ROS 2. Between entities (Physical Twin, Digital Twin, User), a Wi‑Fi network is used with UDP transport. The architecture requires end‑to‑end latency low enough to support real‑time ACC control; a clock synchronisation accuracy of 100 ms is required for safe operation. No bandwidth figures, redundancy schemes, or security protocols (e.g., TLS) are mentioned."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Computation that implements the ACC algorithm is off‑loaded from the resource‑constrained ECU to the Digital Twin, which may run on cloud resources (“allocate compute to better‑suited equipment, e.g., in the cloud”). The DT services are deployed as ROS 2 packages, each representing a functional entity (Data Translation FE, Data Monitoring FE, Controlling FE, etc.). The documents do not give quantitative CPU, memory or storage requirements, nor detail scalability mechanisms or specific cloud/edge platforms. Availability is implied by the need for low latency and continuous monitoring, but no explicit redundancy or reliability provisions are described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system is based on ISO 23247 (parts 1‑4), which defines the overall framework, reference architecture, digital representation of physical manufacturing elements and information exchange. The architecture uses the ISO‑defined entities (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity) and implements them as ROS 2 packages. OPC Unified Architecture is cited as a possible protocol for device coordination. For safety‑critical automotive applications the authors recommend complementing ISO 23247 with ISO 26262 and note that many automotive standards require clock synchronisation tighter than 100 ms. The standard’s independence from specific formats and protocols enables integration with the automotive de‑facto software architecture AUTOSAR, allowing hardware‑agnostic component definition. No specific certification or additional compliance framework beyond referencing these standards is described."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The automotive digital‑twin case study emphasizes that safety‑critical aspects must be treated as a first‑class concern and recommends the adoption of established automotive safety standards, in particular ISO 26262‑1:2018 “Road vehicles – Functional safety”. The authors argue that the ISO 23247 reference architecture (RA) on its own is insufficient for safety‑critical applications and that safety processes defined in ISO 26262 should be integrated into the digital‑twin architecture. They also point out that existing automotive software frameworks such as AUTOSAR, which specify software components in a hardware‑agnostic way, can be reused to embed safety mechanisms in the digital twin. No explicit cybersecurity protocols, access‑control, authentication, or threat‑mitigation strategies are detailed in the provided documents."
]