// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR capturing 3D point clouds of the vehicle's environment for object detection and tracking"
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance IntelDeepsenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera providing depth perception and object detection for the autonomous vehicle"
    DTDFVocab:producedData CameraFeedDataTransmitted
]

instance EgoVehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensors continuously monitoring ego vehicle speed, steering angle, and motor/servo states"
    DTDFVocab:producedData EgoVehicleStateDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance CameraFeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iCamera
]

instance EgoVehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoVehicleStateSensor
]

instance ProcessedObjectTracksDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PointCloudClusteringAndTrackingModel
]

instance ObjectTrackAnomalyDetector : DTDFVocab:Model [
    base:desc "Model for detecting object track deviations or vehicle state anomalies"
    DTDFVocab:inputTo ROS2Middleware
]

instance ACCRelevantEventsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ObjectTrackAnomalyDetector
]

// C10: Models/Data
instance PointCloudClusteringAndTrackingModel : DTDFVocab:Model [
    base:desc "Point Cloud Clustering & Tracking model using DBSCAN algorithm for object detection and Kalman filter for track maintenance"
    DTDFVocab:inputTo ROS2Middleware
]

instance ACCLogicModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control logic model compliant with ISO 15622 performance class I"
    DTDFVocab:inputTo ROS2Middleware
]

instance CREOSimulateIntegrationModel : DTDFVocab:Model [
    base:desc "CREO Simulate integration for offline analysis of brake systems and predictive maintenance"
    DTDFVocab:inputTo ROS2Middleware
]

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 3D point cloud data from Hokuyo UST-10LX LiDAR for environment perception"
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
    DTDFVocab:inputTo PointCloudClusteringAndTrackingModel
]

instance CameraFeedData : DTDFVocab:Data [
    base:desc "Depth camera feeds from Intel Deepsense D435i for object detection and environment perception"
    DTDFVocab:fromData CameraFeedDataTransmitted
    DTDFVocab:inputTo PointCloudClusteringAndTrackingModel
]

instance EgoVehicleStateData : DTDFVocab:Data [
    base:desc "Real-time ego vehicle state data including speed, steering angle, and motor/servo states"
    DTDFVocab:fromData EgoVehicleStateDataTransmitted
    DTDFVocab:inputTo ACCLogicModel
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Processed object tracks containing size, position, and velocity information from point cloud processing"
    DTDFVocab:fromData ProcessedObjectTracksDataTransmitted
    DTDFVocab:inputTo ACCLogicModel
]

instance TimeSeriesVehicleStateData : DTDFVocab:Data [
    base:desc "SQL-stored time-series data of vehicle state and object tracks for historical analysis and reporting"
    DTDFVocab:inputTo SQLDatabase
]

instance ACCRelevantEventsData : DTDFVocab:Data [
    base:desc "Processed ACC-relevant events including lead vehicle detection and proximity alerts"
    DTDFVocab:fromData ACCRelevantEventsDataTransmitted
    DTDFVocab:inputTo ACCLogicModel
]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "Robot Operating System 2 middleware aggregating sensor data streams into structured topics for transmission"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, DataReportingService, PredictiveMaintenanceInsightsService
]

instance NVIDIAJetpack50SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for Jetson Orin Nano development and hardware integration"
    DTDFVocab:enables DataCollectionFunctionalEntity, ActuationFunctionalEntity
]

instance Python38 : DTDFVocab:Enabler [
    base:desc "Python 3.8 programming language for rapid prototyping of DT components"
    DTDFVocab:enables DataPreProcessingFunctionalEntity, ReportingFunctionalEntity
]

instance CPlusPlus : DTDFVocab:Enabler [
    base:desc "C++ programming language for implementing ROS2 nodes and performance-critical components"
    DTDFVocab:enables DataCollectionFunctionalEntity, ActuationFunctionalEntity
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for complex systems modeling including point cloud clustering and tracking"
    DTDFVocab:enables PointCloudClusteringAndTrackingModel
]

instance CREOSimulate : DTDFVocab:Enabler [
    base:desc "CREO Simulate for predictive maintenance analysis of brake systems and component health monitoring"
    DTDFVocab:enables CREOSimulateIntegrationModel
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL-based database for storing time-series vehicle state and object track data"
    DTDFVocab:enables DataStorageFunctionalEntity
]

instance WiFiNetwork : DTDFVocab:Enabler [
    base:desc "Wi-Fi network providing communication between Physical Twin and Digital Twin entities with 100ms latency constraints"
    DTDFVocab:enables DataCollectionFunctionalEntity, ActuationFunctionalEntity
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of ego vehicle state, object tracks, and projected driving path via 3D Visualization UI"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC logic execution in the Digital Twin (cloud/edge) to reduce Physical Twin computational load"
    DTDFVocab:provides ACCParameterOptimizationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables enable/disable ACC, desired speed adjustment, and emergency braking via Control Panel"
    DTDFVocab:provides RemoteSystemControlAction
]

instance DataReportingService : DTDFVocab:Service [
    base:desc "Generates human-readable reports of vehicle state and object tracks as time-series data"
    DTDFVocab:provides MaintenanceReportInsight
]

instance PredictiveMaintenanceInsightsService : DTDFVocab:Service [
    base:desc "Supports health monitoring of brake systems and other components via CREO Simulate integration"
    DTDFVocab:provides ComponentHealthInsight
]

// C17: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization of ego vehicle state, object tracks, and projected driving path for real-time monitoring"
]

instance ACCParameterOptimizationAction : DTDFVocab:Action [
    base:desc "Adjustments to desired speed, following distance, and braking thresholds based on real-time data"
    DTDFVocab:IsAutomatic true
]

instance RemoteSystemControlAction : DTDFVocab:Action [
    base:desc "Remote enable/disable of ACC, desired speed adjustment, and emergency braking commands"
    DTDFVocab:IsAutomatic false
]

instance MaintenanceReportInsight : DTDFVocab:Insight [
    base:desc "Human-readable reports of vehicle state and object tracks as time-series data for analysis"
]

instance ComponentHealthInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance insights for brake system health and motor wear analysis"
]

instance ObjectTrackAnomalyInsight : DTDFVocab:Insight [
    base:desc "Detection of object track deviations or vehicle state anomalies triggering alerts"
]

instance DriverTransparencyInsight : DTDFVocab:Insight [
    base:desc "Transparency reports of projected driving path improving ADAS trust"
]

// C2: Acting Components
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Converts desired speed commands into motor voltage commands via Vedder Electronic Speed Controller"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Controls the steering angle of the vehicle integrated into the lower-level chassis"
]

instance EmergencyBrakingActuator : DTDFVocab:ActingComponent [
    base:desc "Executes remote emergency braking commands to halt the vehicle's motor"
]

// C1: Components
instance TraxxasSlash4x4Vehicle : DTDFVocab:Component [
    base:desc "1/10th-scale autonomous vehicle retrofitted with autonomy components for ACC Digital Twin development"
]

instance NVIDIAJetsonOrinNano : DTDFVocab:Component [
    base:desc "Microcomputer handling data processing and autonomy logic execution"
]

instance VedderElectronicSpeedController : DTDFVocab:Component [
    base:desc "Electronic speed controller interfacing motor voltage commands with the vehicle's motor"
]

instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "On-vehicle component hosting ROS2 nodes for data collection, processing, and actuation"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Cloud/edge component hosting core services including ACC logic, data collection, and visualization"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "Remote UI component for visualization and control operations"
]

// C7: Functional Entities
instance DataCollectionFunctionalEntity : DTDFVocab:FunctionalEntity [
    base:desc "Collects real-time ego vehicle state data and forwards ACC-relevant events to Digital Twin"
    DTDFVocab:inputTo ROS2Middleware
    DTDFVocab:inputTo WiFiNetwork
]

instance DataPreProcessingFunctionalEntity : DTDFVocab:FunctionalEntity [
    base:desc "Processes raw LiDAR point clouds and camera feeds into object tracks using DBSCAN and Kalman filter"
    DTDFVocab:inputTo Python38
    DTDFVocab:inputTo MATLABSimulink
]

instance ActuationFunctionalEntity : DTDFVocab:FunctionalEntity [
    base:desc "Executes motor, steering, and emergency braking commands based on Digital Twin decisions"
    DTDFVocab:inputTo CPlusPlus
    DTDFVocab:inputTo NVIDIAJetpack50SDK
]

instance DataStorageFunctionalEntity : DTDFVocab:FunctionalEntity [
    base:desc "SQL-based storage for time-series vehicle state and object track data"
    DTDFVocab:inputTo SQLDatabase
]

instance ReportingFunctionalEntity : DTDFVocab:FunctionalEntity [
    base:desc "Generates human-readable reports of vehicle state and object tracks"
    DTDFVocab:inputTo Python38
]

instance ThreeDVisualizationUI : DTDFVocab:FunctionalEntity [
    base:desc "3D visualization component for real-time monitoring of vehicle state and environment"
]

instance ControlPanel : DTDFVocab:FunctionalEntity [
    base:desc "Remote control interface for enabling/disabling ACC and adjusting system parameters"
]

// C8: Environments
instance AutonomousVehicleEnvironment : DTDFVocab:Environment [
    base:desc "Operational environment for the 1/10th-scale autonomous vehicle with ACC capabilities"
    base:contains TraxxasSlash4x4Vehicle, NVIDIAJetsonOrinNano, HokuyoUST10LXLiDAR,
                  IntelDeepsenseD435iCamera, VedderElectronicSpeedController
]

instance DigitalTwinCloudEnvironment : DTDFVocab:Environment [
    base:desc "Cloud/edge hosting environment for Digital Twin services and data processing"
    base:contains DigitalTwinEntity, DataStorageFunctionalEntity
]

instance UserInterfaceEnvironment : DTDFVocab:Environment [
    base:desc "Remote user interface environment for visualization and control"
    base:contains UserEntity, ThreeDVisualizationUI, ControlPanel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Data transmitted from the DT to the PT includes: **1) Desired speed commands** computed by the **ACC Controlling FE** and sent to the **Actuation FE** for motor voltage conversion. **2) Remote management commands** (enable/disable ACC, set desired speed, emergency braking) via the **Control Panel User Interface FE**. **3) Actuation signals** for steering and motor control, synchronized with the PT’s clock (100 ms accuracy). **4) Data Storage FE** logs (via SQL database) are not directly sent to the PT but used for offline analysis."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates with **real-time synchronization** constrained by **R7 (100 ms end-to-end latency)** for ACC control and **R8 (100 ms clock synchronization accuracy)**. Services like **Data Monitoring** and **Remote Management** require **sub-second latency** (<100 ms) to maintain safety-critical operation. **Data Storage** and **Report Generation** are non-real-time, operating asynchronously. The **Physical-to-Virtual interaction** (sensor data) occurs at **perception cycle rates** (e.g., LiDAR/camera refresh rates), while **Virtual-to-Physical interaction** (actuation commands) aligns with **ACC control loops** (typically <100 ms)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation follows an **entity-based architecture** inspired by **ISO 23247**, comprising: **1) Physical Twin Entity**: Hosts **Point Cloud Clustering & Tracking** (Data Pre-Processing FE), **Actuation** (Actuation FE), and **Vehicle State** sensors. **2) Digital Twin Entity**: Hosts **ACC logic** (Controlling FE), **Data Collection** (Data Collecting FE), **Report Generation** (Reporting FE), and **Visualization Pre-Processing** (Presentation FE). **3) User Entity**: Hosts **3D Visualization** and **Control Panel** (both mapped to User Interface FE). **4) Cross-System Entity**: **Data Translation FE** for serialization and unit conversion. The constellation is **distributed** across hardware: PT (on-vehicle), DT (cloud/edge), and UI (remote)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers **design, development, and operation** stages of the PT’s lifecycle. **1) Design Phase**: Used as a **cyber-physical experimentation facility** for ACC algorithm validation via **3D CAD integration** and **simulator components** (e.g., MATLAB/Simulink). **2) Development Phase**: Supports **troubleshooting** via **data monitoring** and **remote management** for developers. **3) Operation Phase**: Enables **real-time optimization** (e.g., fuel economy via spark ignition DT), **health monitoring** (e.g., brake systems), and **predictive maintenance**. The DT represents the PT **as operated**, not as designed or manufactured."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through: **1) Real-Time Constraints**: **100 ms end-to-end latency** (3GPP V2V compliant) and **100 ms clock synchronization** for event ordering. **2) Data Accuracy**: **LiDAR + Camera fusion** for object tracking (DBSCAN + Kalman filter). **3) Validation**: **ISO 15622 compliance** for ACC logic (performance class I). **4) Verification**: **ROS2 node lifecycle management** ensures deterministic behavior. **5) Uncertainty Handling**: **Data Translation FE** performs unit conversions and error checking. **6) Safety**: **Emergency braking** overrides ACC commands for fail-safe operation. **7) Simulation Integration**: **CREO Simulate** for offline validation of predictive maintenance models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT-PT connection uses: **1) Network Protocol**: **Wi-Fi** for inter-entity communication (DT ↔ PT). **2) Intra-System Protocol**: **ROS2 topics** (UDP/TCP) for intra-entity data exchange. **3) Data Translation**: **Data Translation FE** serializes data, aligns message types, and performs unit conversions (e.g., motor voltage commands). **4) Synchronization**: **Clock synchronization** (100 ms accuracy) via **NTP-like mechanisms** (not specified in detail). **5) Latency**: **<100 ms end-to-end latency** (3GPP V2V compliant) enforced via **Wi-Fi + ROS2 optimizations**. **6) Security**: Not explicitly detailed but implied via **remote management authentication** (e.g., Control Panel access control)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed across **three hardware layers**: **1) Physical Twin (On-Vehicle)**: **NVIDIA Jetson Orin Nano** (compute), **LiDAR/Camera** (sensors), and **Vedder ESC** (actuation). **2) Digital Twin (Cloud/Edge)**: Hosts **ACC logic**, **Data Collection**, and **Reporting FEs** on external servers. **3) User Interface (Remote)**: **3D Visualization** and **Control Panel** accessed via web/mobile interfaces. **4) Data Storage**: **SQL database** (external to vehicle) for time-series data. The **Physical Twin Entity** is deployed on-vehicle, while the **Digital Twin Entity** is offloaded to cloud/edge for computation offloading."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration includes: **1) External Data Sources**: **3D CAD models** (for design phase validation) and **simulator data** (e.g., CREO Simulate). **2) Standardized Interfaces**: **ROS2 topics** and **ISO 23247 FEs** enable interoperability with other DTs or systems. **3) Cloud/Edge Services**: **Computation offloading** to external servers for ACC logic. **4) Product Lifecycle Management**: **Digital thread** integration for end-to-end vehicle data flow. **5) Third-Party Tools**: **MATLAB/Simulink** for complex algorithm development. **6) V2V/V2X Standards**: **3GPP V2V latency requirements** guide network design."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT adheres to the following standards: **1) ISO 23247**: Reference architecture for **entity-based DT design** (mapped to automotive use case). **2) ISO 15622**: **ACC system requirements** (performance class I compliance). **3) 3GPP TS 22.185**: **V2V communication latency** (<100 ms). **4) ROS2**: **Middleware standard** for inter-component communication. **5) IEC 62541 (OPC UA)**: Potential for **Data Translation FE** implementation (not explicitly used). The architecture also draws from **automotive IoT** and **cyber-physical systems** best practices."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety measures include: **1) Safety-Critical Constraints**: **100 ms latency/clock sync** for real-time operation. **2) Fail-Safe Mechanisms**: **Emergency braking** overrides ACC commands. **3) Remote Management Safeguards**: **Authentication** for Control Panel access (implied). **4) Data Integrity**: **Clock synchronization** ensures event ordering. **5) Redundancy**: **LiDAR + Camera fusion** for robust object tracking. **6) Compliance**: **ISO 15622** ensures ACC safety. **7) Network Security**: **Wi-Fi encryption** (not detailed) for DT-PT communication. **8) Human-in-the-Loop**: **Fully Autonomous Digital Twin** with **operator oversight** (per David & Bork taxonomy). Risks include **remote operation accidents** if latency exceeds 100 ms or clock sync fails."
]