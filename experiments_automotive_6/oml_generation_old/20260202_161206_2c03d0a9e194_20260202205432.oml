// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Industrial temperature probe (PT100) for continuous monitoring of equipment and process temperatures with manufacturing-grade tolerances (±0.1%). Used for real-time process monitoring and predictive maintenance."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "High-precision pressure sensor for monitoring hydraulic systems, pneumatic components, and fluid dynamics in manufacturing processes."
    DTDFVocab:producedData PressureDataTransmitted
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Kistler vibration sensor for monitoring rotating machinery health through frequency analysis and amplitude measurements."
    DTDFVocab:producedData VibrationDataTransmitted
]

instance FlowRateSensor : DTDFVocab:SensingComponent [
    base:desc "Industrial flow meter for monitoring fluid dynamics in manufacturing processes, supporting continuous and batch production lines."
    DTDFVocab:producedData FlowRateDataTransmitted
]

instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Limit switch and encoder system for tracking equipment status and positional data in automated manufacturing systems."
    DTDFVocab:producedData PositionDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Environmental humidity sensor for facility-level monitoring and process control in manufacturing environments."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance NoiseSensor : DTDFVocab:SensingComponent [
    base:desc "Acoustic sensor for monitoring noise levels in industrial environments, supporting occupational safety compliance."
