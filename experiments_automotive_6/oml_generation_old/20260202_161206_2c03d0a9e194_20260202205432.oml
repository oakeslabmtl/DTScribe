]

instance WearableBiosensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled wearable biosensor (ECG/EEG) for cyber-biophysical systems, interfacing biological data with digital twin models."
    DTDFVocab:producedData BiosensorDataTransmitted
]

instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Velodyne or InnovizTech LiDAR system for 2D/3D point cloud data acquisition in automotive and robotic applications, supporting object tracking and path planning."
    DTDFVocab:producedData LidarPointCloudDataTransmitted
]

instance RadarSensor : DTDFVocab:SensingComponent [
    base:desc "Hella or Continental automotive radar system for vehicle state monitoring, collision avoidance, and environmental perception."
    DTDFVocab:producedData RadarDataTransmitted
]

instance IMUSensor : DTDFVocab:SensingComponent [
    base:desc "Bosch BNO055 inertial measurement unit for vehicle orientation, acceleration, and angular velocity tracking in automotive applications."
    DTDFVocab:producedData IMUDataTransmitted
]

instance BatteryManagementSensor : DTDFVocab:SensingComponent [
    base:desc "Tesla Model 3 battery management system sensor for monitoring voltage, current, temperature, and state of charge in electric vehicle battery packs."
    DTDFVocab:producedData BatteryManagementDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

instance VibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
]

instance FlowRateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FlowRateSensor
]

instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance NoiseDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom NoiseSensor
]

instance BiosensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WearableBiosensor
]

instance LidarPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance RadarDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RadarSensor
]

instance IMUDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IMUSensor
]

instance BatteryManagementDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BatteryManagementSensor
]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Software component for LiDAR point cloud clustering and tracking, converting raw sensor data into structured object tracks for 3D visualization and path planning."
    DTDFVocab:inputTo PointCloudClusteringEngine
]

instance VehicleStateModel : DTDFVocab:Model [
    base:desc "Digital representation of vehicle state including motor actuation, steering servo status, and dynamic behavior for real-time monitoring and control."
    DTDFVocab:inputTo VehicleStateSimulationEngine
]

instance ManufacturingProcessModel : DTDFVocab:Model [
    base:desc "Multi-physics simulation model representing manufacturing processes including thermal, mechanical, and fluid dynamics for process optimization and anomaly detection."
    DTDFVocab:inputTo ProcessSimulationEngine
]

instance BiosensorDataModel : DTDFVocab:Model [
    base:desc "Digital twin model for biosensor data integration, incorporating probabilistic models for biological variability and sensor noise in cyber-biophysical systems."
    DTDFVocab:inputTo BiosensorAnalysisEngine
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Continuous temperature measurements from industrial processes and equipment, used for real-time monitoring and predictive maintenance."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DataLakeStorage
]

instance PressureData : DTDFVocab:Data [
    base:desc "High-precision pressure measurements from hydraulic and pneumatic systems, supporting process control and equipment health monitoring."
    DTDFVocab:fromData PressureDataTransmitted
    DTDFVocab:inputTo ProcessSimulationEngine
]

instance VibrationData : DTDFVocab:Data [
    base:desc "Frequency and amplitude data from rotating machinery, used for condition monitoring and predictive maintenance."
    DTDFVocab:fromData VibrationDataTransmitted
    DTDFVocab:inputTo FaultDetectionEngine
]

instance LidarPointCloudData : DTDFVocab:Data [
    base:desc "Structured 2D/3D point cloud data derived from raw LiDAR scans, supporting object tracking, path planning, and 3D visualization."
    DTDFVocab:fromData LidarPointCloudDataTransmitted
    DTDFVocab:inputTo VisualizationEngine
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Real-time vehicle state information including motor actuation, steering servo status, and dynamic behavior for monitoring and control."
    DTDFVocab:fromData IMUDataTransmitted, BatteryManagementDataTransmitted
    DTDFVocab:inputTo ControlSystemInterface
]

instance BiosensorData : DTDFVocab:Data [
    base:desc "Biological data from wearable sensors including ECG, EEG, and other physiological metrics for cyber-biophysical system monitoring."
    DTDFVocab:fromData BiosensorDataTransmitted
    DTDFVocab:inputTo HealthMonitoringEngine
]

// C11: Enablers
instance DataLakeStorage : DTDFVocab:Enabler [
    base:desc "Cloud-based data lake (AWS IoT Greengrass or Azure Digital Twins) for storing and managing time-series data from industrial sensors and IoT devices."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveMaintenanceService
]

instance ProcessSimulationEngine : DTDFVocab:Enabler [
    base:desc "Multi-physics simulation engine (ANSYS or COMSOL) for modeling manufacturing processes, supporting process optimization and anomaly detection."
    DTDFVocab:enables ProcessOptimizationService, AnomalyDetectionService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "3D/4D visualization engine (Unreal Engine or Blender) for creating immersive digital replicas of manufacturing plants and vehicles."
    DTDFVocab:enables VisualizationService, TrainingSimulationService
]

instance FaultDetectionEngine : DTDFVocab:Enabler [
    base:desc "AI/ML-based fault detection engine using LSTM networks or isolated forest algorithms for identifying equipment faults and anomalies."
    DTDFVocab:enables PredictiveMaintenanceService, AnomalyDetectionService
]

instance ControlSystemInterface : DTDFVocab:Enabler [
    base:desc "ROS2-based control system interface for bidirectional communication between digital twin and physical actuators, enabling real-time adaptive control."
    DTDFVocab:enables ClosedLoopControlService
]

instance PointCloudClusteringEngine : DTDFVocab:Enabler [
    base:desc "Software engine for LiDAR point cloud clustering and tracking, converting raw sensor data into structured object tracks."
    DTDFVocab:enables PathPlanningService, ObjectTrackingService
]

instance VehicleStateSimulationEngine : DTDFVocab:Enabler [
    base:desc "Vehicle dynamics simulation engine (CarSim or ADAMS) for modeling and predicting vehicle behavior under various conditions."
    DTDFVocab:enables VehiclePerformanceService
]

instance BiosensorAnalysisEngine : DTDFVocab:Enabler [
    base:desc "AI/ML engine for analyzing biosensor data, incorporating probabilistic models for biological variability and sensor noise."
    DTDFVocab:enables HealthMonitoringService
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Functional entity for data translation and serialization, ensuring cross-compatibility between sensor outputs and digital twin inputs via standardized message formats."
    DTDFVocab:enables DataIntegrationService
]

instance EdgeComputingNode : DTDFVocab:Enabler [
    base:desc "Edge computing platform (NVIDIA Jetson or AWS IoT Greengrass) for localized data processing and low-latency control in industrial and automotive applications."
    DTDFVocab:enables EdgeBasedActuationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing continuous real-time telemetry and monitoring of equipment health, process parameters, and environmental conditions."
