    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance ActuationFeedbackData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ActuationFeedbackSensor
]

instance TemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

instance BatterySoCData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BatterySoCSensor
]

instance ProcessData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ManufacturingProcessSensor
]

// C5: Data Processing Entities (Functional Entities)
instance DataPreProcessingFE : DTDFVocab:FunctionalEntity [
    base:desc "FE responsible for aligning message types, normalizing units (e.g., converting LiDAR coordinates to standardized formats)"
]

instance ActuationFE : DTDFVocab:FunctionalEntity [
