// C3: Physical sensing components
instance HokuyoLiDARUST10LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR providing 2‑D laser scans for object detection"
    DTDFVocab:producedData LiDARObjectTracksMsg
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D images for perception"
    DTDFVocab:producedData DepthImageMsg
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board speed sensor reporting ego‑vehicle longitudinal speed"
    DTDFVocab:producedData EgoVehicleStateMsg
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor reporting the current wheel steering angle"
    DTDFVocab:producedData EgoVehicleStateMsg
]

// C4: Physical‑to‑virtual interaction (Data Transmitted)
instance EgoVehicleStateMsg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor, SteeringAngleSensor
]

instance LiDARObjectTracksMsg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARUST10LX, IntelRealSenseD435iDepthCamera
]

instance DepthImageMsg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
]

// C10: Data entities
instance VehicleStateData : DTDFVocab:Data [
    base:desc "Aggregated ego‑vehicle state comprising speed and steering angle"
    DTDFVocab:fromData EgoVehicleStateMsg
    DTDFVocab:inputTo ROS2MiddlewareEnabler, ComputationOffloadingEnabler
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks derived from LiDAR point clouds via DBSCAN clustering and Kalman filtering"
    DTDFVocab:fromData LiDARObjectTracksMsg
    DTDFVocab:inputTo ROS2MiddlewareEnabler, ClusteringTrackingEnabler, SQLDatabaseEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth images from the RealSense D435i used for perception pipelines"
    DTDFVocab:fromData DepthImageMsg
    DTDFVocab:inputTo ROS2MiddlewareEnabler, ClusteringTrackingEnabler
]

// C10: Models / Algorithms
instance ACCControlModelISO15622 : DTDFVocab:Model [
    base:desc "ACC control model implementing ISO 15622 performance‑class I logic"
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering model for object detection"
    DTDFVocab:inputTo ClusteringTrackingEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking model for maintaining object tracks over time"
    DTDFVocab:inputTo ClusteringTrackingEnabler
]

// C11: Enablers (middleware / processing)
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware over Wi‑Fi handling real‑time message exchange"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService, ComputationOffloadingService, Visualization3DService, ReportGenerationService
]

instance DataTranslationFEEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation Front‑End for serialization, unit conversion, and optional OPC UA interfacing"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Offloads ACC algorithm execution from PT to DT using ROS 2 services"
    DTDFVocab:enables ComputationOffloadingService
]

instance ClusteringTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Executes DBSCAN clustering and Kalman filter tracking (MATLAB/Simulink) on received perception data"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database storing historic vehicle state and object track records"
    DTDFVocab:enables ReportGenerationService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI displaying vehicle speed, steering angle, object tracks and projected path"
    DTDFVocab:provides RealTimeVehicleStateInsight, RealTimeObjectTracksInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes the ACC control algorithm in the Digital Twin"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, or trigger emergency brake"
    DTDFVocab:provides ParameterAdjustmentSuggestionInsight
]

instance Visualization3DService : DTDFVocab:Service [
    base:desc "3‑D visualization of ego vehicle trajectory and surrounding object tracks"
    DTDFVocab:provides ThreeDVisualizationInsight
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generates time‑series CSV reports from stored vehicle and object data"
    DTDFVocab:provides ReportCSVInsight
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Live visualization of current speed and steering angle"
]

instance RealTimeObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Live visualization of detected object tracks and predicted paths"
]

instance ThreeDVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3‑D view of ego vehicle and environment"
]

instance ReportCSVInsight : DTDFVocab:Insight [
    base:desc "CSV report containing time‑stamped vehicle state and object track data"
]

instance ParameterAdjustmentSuggestionInsight : DTDFVocab:Insight [
    base:desc "DT suggests ACC parameter adjustments based on historic performance"
]

// C17: Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Command to enable Adaptive Cruise Control in the vehicle"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set a new desired speed for the ACC controller"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediate emergency braking command"
    DTDFVocab:IsAutomatic true
]

// C2: Acting components (actuators)
instance VedderMotorDriveActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder electronic speed controller receiving voltage commands for vehicle propulsion"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo receiving angle commands to adjust wheel steering"
]

// C1: Entities (Physical Twin, Digital Twin, User, Cross‑System)
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "1/10‑scale autonomous vehicle equipped with sensors and actuators, hosted on Jetson‑NX"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "External compute node running ROS 2, ACC model, clustering/tracking pipelines, and SQL database"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "Operator workstation providing UI for monitoring and remote management"
]

instance CrossSystemEntity : DTDFVocab:Component [
    base:desc "Facilitates data translation and protocol mediation among PT, DT, and User"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT sends ACC‑computed desired speed, enable/disable ACC commands, and emergency‑brake signals back to the PT over Wi‑Fi; Data Translation FE serializes and unit‑converts these commands, which are applied by the Actuation FE to the motor and steering actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with end‑to‑end network latency limited to ≤100 ms (R7) and clock synchronization accuracy of 100 ms (R8)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An ISO 23247‑based architecture mapping Physical Twin Entity (OME analogue), Digital Twin Entity (data collection, reporting, ACC control), User Entity (UI FE), and Cross‑System Entity (data translation), realized as ROS 2 packages across vehicle and external host."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Compliance with ISO 15622 ACC specification; real sensor data used for object tracking; latency ≤100 ms and clock sync ≤100 ms to maintain temporal fidelity; data stored in SQL database for validation; reporting FE generates human‑readable logs."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional Wi‑Fi link between PT and DT; ROS 2 topics for intra‑entity communication; Data Translation FE performs serialization, message‑type alignment, and unit conversion across the network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the on‑board NVIDIA Jetson Orin Nano; Digital Twin Entity and User Entity run on external compute (e.g., cloud or workstation) connected via Wi‑Fi; each functional entity is packaged as an independent ROS 2 node."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Designed according to ISO 23247 reference architecture; ACC functionality follows ISO 15622; concepts from ISO/IEC 30173:2023 and optional OPC UA (IEC 62541) mentioned for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "System is designed for safety‑critical operation with latency ≤100 ms and synchronized clocks; remote management commands are acknowledged but specific security mechanisms are not detailed in the document."
]