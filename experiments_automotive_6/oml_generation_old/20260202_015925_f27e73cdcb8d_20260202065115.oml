instance HokuyoUST10LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR for point cloud data"
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance IntelDeepsenseD435i : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i Depth Camera for visual and depth sensing"
    DTDFVocab:producedData VisualDataTransmitted, DepthDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor for ego vehicle speed"
    DTDFVocab:producedData VehicleSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor for steering angle"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LX
]

instance VisualDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435i
]

instance DepthDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435i
]

instance VehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Point cloud data from Hokuyo UST-10LX LiDAR"
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
    DTDFVocab:inputTo Python38
]

instance VisualData : DTDFVocab:Data [
    base:desc "Visual data from Intel Deepsense D435i"
    DTDFVocab:fromData VisualDataTransmitted
    DTDFVocab:inputTo Python38
]

instance DepthData : DTDFVocab:Data [
    base:desc "Depth data from Intel Deepsense D435i"
    DTDFVocab:fromData DepthDataTransmitted
    DTDFVocab:inputTo Python38
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed data"
    DTDFVocab:fromData VehicleSpeedDataTransmitted
    DTDFVocab:inputTo MATLABSimulink
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle data"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo MATLABSimulink
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Combined vehicle state data (speed and steering angle)"
    DTDFVocab:fromData VehicleSpeedDataTransmitted, SteeringAngleDataTransmitted
    DTDFVocab:inputTo SQLDatabase
]

instance DBSCANBasedPointCloudClustering : DTDFVocab:Model [
    base:desc "DBSCAN-based point cloud clustering model for object detection"
    DTDFVocab:inputTo Python38
]

instance KalmanFilterForObjectTracking : DTDFVocab:Model [
    base:desc "Kalman filter for object tracking"
    DTDFVocab:inputTo MATLABSimulink
]

instance ACCControlLogic : DTDFVocab:Model [
    base:desc "ACC control logic for lead vehicle detection and speed computation"
    DTDFVocab:inputTo CPlusPlus
]

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for communication between components"
    DTDFVocab:enables DataMonitoringService, ObjectTrackingService, ACCService
]

instance NVIDIAJetpack50SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for hardware acceleration"
    DTDFVocab:enables DataMonitoringService, ObjectTrackingService, ACCService
]

instance Python38 : DTDFVocab:Enabler [
    base:desc "Python 3.8 for machine learning and scripting"
    DTDFVocab:enables DataMonitoringService, ObjectTrackingService
]

instance CPlusPlus : DTDFVocab:Enabler [
    base:desc "C++ for real-time control systems"
    DTDFVocab:enables ACCService
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for complex systems modeling"
    DTDFVocab:enables ObjectTrackingService
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL database for storing vehicle state data"
    DTDFVocab:enables DataMonitoringService
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data monitoring service for real-time visualization, saving, and reporting of vehicle state"
    DTDFVocab:provides RealTimeVisualizationOfObjectTracks, RealTimeVisualizationOfVehicleState, RealTimeVisualizationOfProjectedPath, PerformanceMonitoringReport, TroubleshootingReport
]

instance ObjectTrackingService : DTDFVocab:Service [
    base:desc "Object tracking service for vehicle state and path projection"
    DTDFVocab:provides RealTimeVisualizationOfObjectTracks, RealTimeVisualizationOfProjectedPath
]

instance ACCService : DTDFVocab:Service [
    base:desc "Adaptive Cruise Control service for lead vehicle detection and speed computation"
    DTDFVocab:provides ACCAction
]

instance RealTimeVisualizationOfObjectTracks : DTDFVocab:Insight [
    base:desc "Real-time data visualization of object tracks for driver transparency"
]

instance RealTimeVisualizationOfVehicleState : DTDFVocab:Insight [
    base:desc "Real-time data visualization of vehicle state for driver transparency"
]

instance RealTimeVisualizationOfProjectedPath : DTDFVocab:Insight [
    base:desc "Real-time data visualization of projected path for driver transparency"
]

instance PerformanceMonitoringReport : DTDFVocab:Insight [
    base:desc "Report generation for performance monitoring"
]

instance TroubleshootingReport : DTDFVocab:Insight [
    base:desc "Report generation for troubleshooting"
]

instance ACCAction : DTDFVocab:Action [
    base:desc "Automatic speed adjustment for adaptive cruise control"
    DTDFVocab:IsAutomatic true
]

instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller converting desired speed to voltage commands"
]

instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Steering servo for vehicle steering control"
]

instance TraxxasSlash4x4 : DTDFVocab:Component [
    base:desc "Traxxas Slash 4x4 Premium teleoperated vehicle base for 1/10-scale autonomous vehicle"
]

instance NVIDIAJetsonNX : DTDFVocab:Component [
    base:desc "NVIDIA Jetson NX microcomputer for processing"
]

instance NVIDIAOrinNano : DTDFVocab:Component [
    base:desc "NVIDIA Orin Nano microcomputer for processing"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Transmission of ACC control commands (desired speed, emergency braking) and remote management commands (enable/disable ACC, set desired speed) from DT to PT via motor and steering actuation components."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time operation with end-to-end latency ≤100 ms and clock synchronization accuracy of 100 ms, as per 3GPP TS 22.185 and hardware constraints."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Entity-based architecture with Physical Twin Entity (on vehicle), Digital Twin Entity (cloud), User Entity (cloud), and Cross-System Entity; components communicate via ROS2 intra-entity and Wi-Fi inter-entity."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational phase of the vehicle lifecycle, focusing on real-time monitoring and control during vehicle operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Safety-critical system with latency ≤100 ms and clock sync accuracy of 100 ms; specific verification and validation methods not detailed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "ROS2 network for intra-entity communication; Wi-Fi for inter-entity communication; OPC UA considered for Data Translation FE per ISO 23247."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity deployed on vehicle-mounted NVIDIA Jetson Orin Nano; Digital Twin and User Entities hosted in cloud infrastructure."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 Digital Twin Manufacturing Framework reference architecture adapted for automotive systems."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety-critical system design compliant with ISO 15622 for ACC; cybersecurity measures not addressed."
]