// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-110LX LiDAR providing 3‑D point‑clouds"
    DTDFVocab:producedData LiDARPointCloudStream
]

instance IntelDeepSenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera providing depth images"
    DTDFVocab:producedData DepthImageStream
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of vehicle speed extracted from chassis controller"
    DTDFVocab:producedData SpeedTelemetryStream
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of steering angle extracted from chassis controller"
    DTDFVocab:producedData SteeringAngleStream
]

// C2: Acting components
instance MotorDriverActuator : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller driving the vehicle motor"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Servo motor governing the steering mechanism"
]

// C4: Physical‑to‑virtual interaction (Data Transmitted)
instance LiDARPointCloudStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthImageStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseDepthCamera
]

instance SpeedTelemetryStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C5: Data objects
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 3‑D point‑cloud data from LiDAR"
    DTDFVocab:fromData LiDARPointCloudStream
    DTDFVocab:inputTo ObjectDetectionEnabler, VisualizationEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames from depth camera"
    DTDFVocab:fromData DepthImageStream
    DTDFVocab:inputTo ObjectDetectionEnabler, VisualizationEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed telemetry"
    DTDFVocab:fromData SpeedTelemetryStream
    DTDFVocab:inputTo ACCControlEnabler, DataCollectionEnabler, DataTranslationEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle telemetry"
    DTDFVocab:fromData SteeringAngleStream
    DTDFVocab:inputTo ACCControlEnabler, DataCollectionEnabler, DataTranslationEnabler
]

// C10: Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering model for object detection"
    DTDFVocab:inputTo ObjectDetectionEnabler
]

instance KalmanFilterTrackerModel : DTDFVocab:Model [
    base:desc "Kalman‑filter tracker producing continuous object tracks"
    DTDFVocab:inputTo ObjectDetectionEnabler
]

instance ACCControlModelISO15622 : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model defined by ISO 15622 (performance class I)"
    DTDFVocab:inputTo ACCControlEnabler
]

instance VisualizationPreprocessingModel : DTDFVocab:Model [
    base:desc "Pre‑processing model for 3‑D visualization of vehicle state"
    DTDFVocab:inputTo VisualizationEnabler
]

// C11: Enablers
instance DataCollectionEnabler : DTDFVocab:Enabler [
    base:desc "Aggregates sensor data and persists vehicle state and tracks in SQL database"
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Serialises and unit‑converts data for inter‑entity exchange"
    DTDFVocab:enables RemoteManagementService
]

instance ObjectDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Executes clustering and tracking models to generate object tracks"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "Runs ACC control model and outputs desired speed and enable/disable signals"
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Prepares data for 3‑D visualization dashboard"
    DTDFVocab:enables Visualization3DService
]

instance ReportingEnabler : DTDFVocab:Enabler [
    base:desc "Generates time‑series reports from persisted vehicle data"
    DTDFVocab:enables ReportGenerationService
]

instance ActuationEnabler : DTDFVocab:Enabler [
    base:desc "Translates desired speed commands into motor voltage signals for actuators"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI displays real‑time speed, steering angle, object tracks and projected path"
    DTDFVocab:provides RealTimeVisualizationInsight, DesiredSpeedAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC algorithm on the DT and returns desired speed to the PT"
    DTDFVocab:provides ACCDecisionInsight, DesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, modify desired speed, and trigger emergency braking"
    DTDFVocab:provides ACCEnableAction, ACCDisableAction, EmergencyBrakeAction
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generates time‑series reports of vehicle state and tracks"
    DTDFVocab:provides TimeSeriesReportInsight
]

instance Visualization3DService : DTDFVocab:Service [
    base:desc "Provides 3‑D visualization of vehicle trajectory and environment"
    DTDFVocab:provides ThreeDVisualizationInsight
]

// C17: Insights
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualisation of speed, steering angle, object tracks and projected path"
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "ACC algorithm decision output (desired speed, enable status)"
]

instance TimeSeriesReportInsight : DTDFVocab:Insight [
    base:desc "Time‑series report of vehicle state and object tracks"
]

instance ThreeDVisualizationInsight : DTDFVocab:Insight [
    base:desc "3‑D visualisation of vehicle trajectory and surrounding environment"
]

// C18: Actions
instance DesiredSpeedAction : DTDFVocab:Action [
    base:desc "Desired speed command sent from DT to PT"
    DTDFVocab:IsAutomatic true
]

instance ACCEnableAction : DTDFVocab:Action [
    base:desc "Operator enables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance ACCDisableAction : DTDFVocab:Action [
    base:desc "Operator disables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking on the PT"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity generates ACC control outputs (desired speed) via a Controlling FE, which are transmitted back to the PT over Wi‑Fi using ROS 2 messages; remote management commands (enable/disable ACC, set speed, emergency brake) are also sent through the same channel and enacted by the Actuation FE on the vehicle hardware."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is required to maintain end‑to‑end latency of ≤ 100 ms from PT to DT (per 3GPP TS 22.185) and clock synchronization accuracy of ≤ 100 ms across all components; data collection and ACC computation therefore operate at real‑time rates consistent with the vehicle’s perception cycle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of the Physical Twin Entity (sensor/actuator interface), the Digital Twin Entity (data collection, ACC computation, visualization preprocessing, reporting, data storage) and the User Entity (3‑D visualization and control‑panel UI). Functional Entities communicate via ROS 2 intra‑node messages and across entities via Wi‑Fi with a Data Translation FE handling serialization."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication uses a Wi‑Fi network with ROS 2 (DDS) messaging; intra‑entity communication occurs over the ROS 2 publish/subscribe system. The Data Translation Functional Entity performs serialization, message‑type alignment and unit conversion for all streams."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the vehicle’s NVIDIA Jetson Orin Nano; the Digital Twin Entity is hosted on a remote server/cloud platform; the User Entity UI runs on a workstation or laptop. Each entity is packaged as independent ROS 2 nodes deployed on its respective hardware."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) for entity‑based design, ISO 15622 for ACC functionality, ISO/IEC 30173:2023 for generic DT concepts, and 3GPP TS 22.185 for latency requirements."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed for a safety‑critical ACC function with a hard latency bound of 100 ms and clock sync of 100 ms; remote commands (e.g., emergency braking) are executed under these safety constraints, but explicit security mechanisms are not described in the document."
]