// ===========================================================
// Entities (ISO 23247 entity‑based hierarchy)
// ===========================================================
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical Twin Entity hosts data‑preprocessing, actuation and generic automotive functions (e.g., point‑cloud clustering & tracking). Deployed on dedicated vehicle hardware."
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital Twin Entity manages data‑management, control logic and computation offloading. Deployed on a separate computing platform (NVIDIA Jetson)."
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User Entity provides 3‑D visualisation UI and control panels for operators and developers."
]

// ===========================================================
// Physical Sensing Components
// ===========================================================
instance HokuyoLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2‑D LiDAR providing raw point clouds for perception."
    DTDFVocab:producedData LiDARDataTransmitted
]

instance DeepsenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera supplying depth images."
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance WheelEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel encoder measuring wheel rotation for vehicle speed and odometry."
    DTDFVocab:producedData WheelEncoderDataTransmitted
]

instance IMUSensor : DTDFVocab:SensingComponent [
    base:desc "Inertial Measurement Unit delivering orientation and acceleration data."
    DTDFVocab:producedData IMUDataTransmitted
]

// ===========================================================
// Physical‑to‑Virtual Data Transmission
// ===========================================================
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARSensor
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DeepsenseDepthCamera
]

instance WheelEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelEncoderSensor
]

instance IMUDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IMUSensor
]

// ===========================================================
// Raw Data Instances
// ===========================================================
instance RawLiDARData : DTDFVocab:Data [
    base:desc "Unprocessed LiDAR point‑cloud frames streamed over UDP/ROS2."
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo PointCloudClusteringTrackingModel, ComputationOffloadingEnabler, DataMonitoringEnabler
]

instance RawDepthCameraData : DTDFVocab:Data [
    base:desc "Raw depth images from the D435i sensor."
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo PointCloudClusteringTrackingModel, DataMonitoringEnabler
]

instance RawWheelEncoderData : DTDFVocab:Data [
    base:desc "Wheel rotation counts used to derive vehicle speed."
    DTDFVocab:fromData WheelEncoderDataTransmitted
    DTDFVocab:inputTo ACCModel, ComputationOffloadingEnabler, DataMonitoringEnabler
]

instance RawIMUData : DTDFVocab:Data [
    base:desc "Orientation and linear acceleration measurements."
    DTDFVocab:fromData IMUDataTransmitted
    DTDFVocab:inputTo ACCModel, ComputationOffloadingEnabler, DataMonitoringEnabler
]

// ===========================================================
// Processed Data (Outputs of Models)
// ===========================================================
instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Clustered object tracks generated by the perception pipeline."
    DTDFVocab:inputTo DataMonitoringEnabler, ComputationOffloadingEnabler
]

instance ACCControlCommandData : DTDFVocab:Data [
    base:desc "Longitudinal control commands (desired speed) produced by the ACC model."
    DTDFVocab:inputTo DataMonitoringEnabler, RemoteManagementEnabler
]

// ===========================================================
// Models (Functional Entities)
// ===========================================================
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Perception pipeline that runs DBSCAN clustering on LiDAR data and tracks objects with a Kalman filter."
    DTDFVocab:inputTo ComputationOffloadingEnabler, DataMonitoringEnabler
]

instance ACCModel : DTDFVocab:Model [
    base:desc "Analytical Adaptive Cruise Control model that consumes vehicle‑state data and object tracks to compute desired speed."
    DTDFVocab:inputTo ComputationOffloadingEnabler, RemoteManagementEnabler
]

// ===========================================================
// Enablers (middleware / runtime platforms)
// ===========================================================
instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "ROS2/DDS middleware that aggregates raw and processed data for real‑time 3‑D visualisation and report generation."
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "GPU‑accelerated NVIDIA Jetpack environment that executes perception and ACC models remotely and returns control commands."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Bidirectional UDP/ROS2 channel allowing operators to enable/disable ACC, set target speed and issue emergency brake."
    DTDFVocab:enables RemoteManagementService
]

// ===========================================================
// Services (DT concrete services)
// ===========================================================
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Displays real‑time vehicle state, projected path and detected object tracks; allows saving and generating historic reports."
    DTDFVocab:provides RealTimeVisualizationInsight, ReportGenerationAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm in the digital twin and streams the resulting desired speed back to the vehicle."
    DTDFVocab:provides OffloadACCComputationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to control ACC remotely: enable/disable, set target speed, trigger emergency braking."
    DTDFVocab:provides EnableACCAction, SetTargetSpeedAction, EmergencyBrakeAction
]

// ===========================================================
// Insights and Actions
// ===========================================================
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides operators with live 3‑D visualization of vehicle trajectory and surrounding objects."
]

instance ReportGenerationAction : DTDFVocab:Action [
    base:desc "Generates and stores historic state data reports for post‑run analysis."
    DTDFVocab:IsAutomatic false
]

instance OffloadACCComputationAction : DTDFVocab:Action [
    base:desc "Offloads ACC computation to the digital twin and receives desired speed."
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Activates the Adaptive Cruise Control function remotely."
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Sets a new target speed for the ACC controller via the UI."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issues an immediate braking command to stop the vehicle safely."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the digital twin are issued to the physical twin through the Actuation functional entity (FE). The ACC Controlling FE computes a desired speed based on lead‑vehicle detection and sends a speed command, while remote‑management functions (enable/disable ACC, set desired speed, emergency‑brake) are also transmitted. Commands are serialized by the Data Translation FE and transmitted over the same Wi‑Fi UDP channel used for sensor data. Upon receipt, the Actuation FE drives the motor and steering‑servo to realise the commanded actions. Explicit acknowledgement or confirmation of command execution is not detailed in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin requires a shared notion of time across devices; synchronization accuracy of 100 ms is mandated (hardware‑limited) and complies with safety‑critical vehicular standards that often demand tighter (<100 ms) sync. This 100 ms bound governs the coordination needed for computation off‑loading between the physical and digital components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration is built on the ISO 23247 reference architecture; software components are mapped to Functional Entities and each FE is packaged as an individual ROS 2 package containing one or more ROS 2 nodes. Communication and coordination among the three entities occur via ROS 2 middleware, allowing distributed execution across heterogeneous compute resources."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The architecture requires that all devices share a common notion of time with a synchronization accuracy of 100 ms, as stated: many standards mandate stricter clock synchronization than 100 ms for safety‑critical vehicular applications, but the system limits to 100 ms accuracy due to hardware limitations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS employs a two‑layer network architecture. Internally, software components exchange messages on a ROS2 (DDS) network, providing publish‑subscribe communication within the digital environment. Communication between the physical twin and the digital twin occurs over a Wi‑Fi network using UDP at the transport layer. The system is required to support low end‑to‑end latency to satisfy safety‑critical ACC operation, although specific latency or bandwidth figures are not provided. No explicit reliability, redundancy, or security protocols are described in the supplied material."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "ACC computation is offloaded from the vehicle’s resource‑constrained ECU to the Digital Twin, which can run on cloud resources as indicated by the statement that computation is allocated to 'better‑suited equipment, e.g., in the cloud.' No further details on the hosting platform, computational or storage capacity, scalability mechanisms, deployment models, or availability guarantees are given in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability follows ISO 23247 part 2 and may employ standards such as OPC Unified Architecture for data exchange, although the present implementation uses ROS 2 topics/services. The design therefore supports integration with external enterprise systems or other digital twins through OPC UA or ROS 2 bridges, aligning with the standard’s information‑exchange guidelines."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system is built on the ISO 23247 Digital Twin framework for manufacturing. Specifically, Part 2 of ISO 23247, which defines the entity‑based reference architecture (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity) is used as the primary design basis. The implementation follows the ISO‑defined entities but introduces a Physical Twin Entity that extends the standard’s OME concept. Functional Entities are instantiated as ROS 2 packages, aligning with the standard’s allowance for arbitrary FE implementation (e.g., OPC UA, ROS 2). The design acknowledges deviations from the ISO model and notes their impact on ownership and engineering processes."
]