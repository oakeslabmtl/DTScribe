// ==================== Physical Sensing Components ====================

instance EgoSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of ego vehicle speed from the Jetson platform via ROS2 topic"
    DTDFVocab:producedData EgoSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of steering angle from the Jetson platform via ROS2 topic"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

instance HokuyoLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR providing 2‑D point clouds, fused on Jetson and exposed via ROS2"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering depth images, published via ROS2"
    DTDFVocab:producedData DepthImageTransmitted
]

// ==================== Data Transmitted (Physical → Virtual) ====================

instance EgoSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARSensor
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCameraSensor
]

instance PTtoDTVirtualStream : DTDFVocab:DataTransmitted [
    base:desc "Aggregated stream of ego speed, steering angle, and processed object tracks transmitted over Wi‑Fi"
    DTDFVocab:producedFrom EgoSpeedSensor, SteeringAngleSensor, HokuyoLiDARSensor, IntelDepthCameraSensor
]

// ==================== Data Instances ====================

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed (m/s) after unit conversion"
    DTDFVocab:fromData EgoSpeedDataTransmitted
    DTDFVocab:inputTo DataCollectingFE, DataTranslationFE
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering wheel angle (degrees) after unit conversion"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo DataCollectingFE, DataTranslationFE
]

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "3‑D point cloud from LiDAR, converted to PCD format"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataCollectingFE, DBSCANClusteringModel
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image from the D435i camera, converted to ROS2 Image message"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo DataCollectingFE
]

instance PTtoDTCombinedData : DTDFVocab:Data [
    base:desc "Combined packet containing speed, steering angle and object tracks"
    DTDFVocab:fromData PTtoDTVirtualStream
    DTDFVocab:inputTo DataCollectingFE
]

// ==================== Acting (Physical) Components ====================

instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder electronic speed controller receiving motor voltage commands"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Servo actuator receiving steering angle commands"
]

// ==================== Function Elements (Enablers) ====================

instance DataCollectingFE : DTDFVocab:Enabler [
    base:desc "Data Collecting FE aggregates sensor streams over Wi‑Fi"
    DTDFVocab:enables VisualizationFE, ACCAlgorithmFE, ReportingFE
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Cross‑System Data Translation FE serializes, unit‑converts and optionally uses OPC‑UA"
    DTDFVocab:enables DataCollectingFE
]

instance VisualizationFE : DTDFVocab:Enabler [
    base:desc "Visualization FE renders real‑time vehicle state and object tracks on the UI"
    DTDFVocab:enables DataMonitoringService
]

instance ACCAlgorithmFE : DTDFVocab:Enabler [
    base:desc "ACC algorithm executing in the Digital Twin, consuming ego state and object tracks"
    DTDFVocab:enables ComputationOffloadingService
]

instance ReportingFE : DTDFVocab:Enabler [
    base:desc "Reporting FE formats stored data into human‑readable time‑series reports"
    DTDFVocab:enables DataMonitoringService
]

instance RemoteControlFE : DTDFVocab:Enabler [
    base:desc "Remote Management FE receives operator commands and forwards them to physical actuators"
    DTDFVocab:enables RemoteManagementService
]

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware enabling topic‑based communication among all FEs and components"
    DTDFVocab:enables DataCollectingFE, DataTranslationFE, VisualizationFE, ACCAlgorithmFE, RemoteControlFE
]

instance JetPack5SDKEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK providing GPU acceleration for perception models"
    DTDFVocab:enables DBSCANClusteringModel, KalmanFilterTrackingModel
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment used for developing clustering and tracking algorithms"
    DTDFVocab:enables DBSCANClusteringModel, KalmanFilterTrackingModel
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database for persistent storage of ego state and object tracks"
    DTDFVocab:enables ReportingFE
]

// ==================== Models (Data Processing) ====================

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering applied to LiDAR point cloud for object candidate generation"
    DTDFVocab:inputTo ACCAlgorithmFE, ReportingFE
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter tracking that fuses clustered detections into object tracks"
    DTDFVocab:inputTo ACCAlgorithmFE
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "ACC control model compliant with ISO 15622 (Performance Class I) computing Desired Speed"
    DTDFVocab:inputTo RemoteControlFE
]

instance ReportingModel : DTDFVocab:Model [
    base:desc "Reporting model that formats ego state and tracks into PDF/CSV reports"
    DTDFVocab:inputTo ReportingFE
]

// ==================== Services ====================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI service visualising real‑time vehicle state, projected path, object tracks and providing downloadable reports"
    DTDFVocab:provides RealTimeVehicleStateInsight, HumanReadableReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC computation to the Digital Twin and returns Desired Speed"
    DTDFVocab:provides ACCDecisionInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set target speed, and trigger emergency braking remotely"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetTargetSpeedAction, EmergencyBrakeAction
]

// ==================== Insights ====================

instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time visual feedback of ego speed, steering angle and projected trajectory"
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "Automated ACC decision providing Desired Speed for actuation"
]

instance HumanReadableReportInsight : DTDFVocab:Insight [
    base:desc "Generated human‑readable report of object tracks and speed profiles"
]

// ==================== Actions ====================

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets a target speed for the ACC algorithm"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers an emergency braking maneuver"
    DTDFVocab:IsAutomatic false
]

// ==================== System Entities (Multiplicities) ====================

instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical Twin deployed on the vehicle's Jetson hardware, hosts sensors and actuators"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital Twin hosted on external compute (cloud or workstation), runs ACC, visualization and reporting"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User Entity providing the UI for monitoring and remote management"
]

// ==================== Environment ====================

instance VehicleSystemEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity, DigitalTwinEntity, UserEntity,
                EgoSpeedSensor, SteeringAngleSensor, HokuyoLiDARSensor, IntelDepthCameraSensor,
                MotorVoltageActuator, SteeringServoActuator
]

// ==================== Engineering Process ====================

instance RequirementDrivenProcess : DTDFVocab:Component [
    base:desc "Requirement‑driven engineering process (R1‑R8) mapping software components to ISO 23247 functional entities"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity sends computed Desired Speed values back to the PT for motor actuation, and transmits remote‑management commands (enable/disable ACC, modify Desired Speed, emergency brake) that are interpreted by the Actuation FE on the PT to drive the motor controller and steering servo."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates at sub‑second time‑scale with a maximum end‑to‑end network latency requirement of 100 ms (R7) and clock synchronization accuracy of 100 ms (R8), ensuring real‑time data collection and control loop closure."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates the Physical Twin Entity (sensing and actuation), Digital Twin Entity (data collection, ACC computation, reporting, visualization), User Entity (3D visualization and control panel UI), and a Cross‑System Data Translation FE. Intra‑entity communication uses ROS 2 topics; inter‑entity communication uses Wi‑Fi with serialized messages via the Data Translation FE."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is used during the operational stage of the vehicle for monitoring, control, and reporting, and also supports design‑time experimentation (e.g., virtual testing of ACC) as indicated by the discussion of DTs as cyber‑physical experimentation facilities."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT maintains fidelity by adhering to real‑time latency (<100 ms) and clock sync (<100 ms) constraints, using high‑fidelity sensor data (LiDAR, depth camera) and validated ACC algorithms per ISO 15622. Safety‑critical aspects are addressed by limiting ACC to Performance Class I and by ensuring deterministic off‑loading of computation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual data is transmitted over a Wi‑Fi network using ROS 2 messages serialized by the Data Translation FE; virtual‑to‑physical commands follow the same Wi‑Fi link back to the PT where they are deserialized and applied via ROS 2 subscribers in the Actuation FE."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the vehicle’s Jetson Orin Nano; the Digital Twin Entity is hosted on an external compute platform (e.g., a workstation or cloud server) that runs the ACC, visualization, and reporting services; the User Entity (UI) runs on a user workstation. Each FE is packaged as an independent ROS 2 module."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) reference architecture, adopts ISO 15622 for ACC functionality, references ISO/IEC 30173:2023 for DT concepts, and mentions optional use of OPC UA (IEC 62541) for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The design acknowledges safety‑critical constraints by imposing a maximum 100 ms latency, requiring clock synchronization within 100 ms, and limiting ACC to a non‑road‑curvature (Performance Class I) implementation. Remote commands are mediated through the User Interface FE, and the system relies on standardized communication interfaces to reduce integration risks."
]