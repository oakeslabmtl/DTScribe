// Sensing Components
instance HokuyoUST110LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST 110LX LiDAR sensor providing dense 3D point cloud data"
    DTDFVocab:producedData LiDARPointCloudStream
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera capturing RGB‑D imagery"
    DTDFVocab:producedData DepthImageStream
]

instance WheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle wheel speed sensor delivering real‑time rpm values"
    DTDFVocab:producedData WheelSpeedSignal
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor producing steering angle in degrees"
    DTDFVocab:producedData SteeringAngleSignal
]

instance EgoStateTelemetryBus : DTDFVocab:SensingComponent [
    base:desc "Onboard telemetry bus transmitting vehicle ego state (position, velocity, heading)"
    DTDFVocab:producedData EgoStateSignal
]

// Data Transmitted
instance LiDARPointCloudStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST110LXLidar
]

instance DepthImageStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

instance WheelSpeedSignal : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedSensor
]

instance SteeringAngleSignal : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance EgoStateSignal : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoStateTelemetryBus
]

// Data (processed or raw)
instance LiDARPointCloudRawData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data stream received from LiDARPointCloudStream"
    DTDFVocab:inputTo LiDARProcessingEnabler
    DTDFVocab:fromData LiDARPointCloudStream
]

instance DepthImageRawData : DTDFVocab:Data [
    base:desc "Raw depth image data stream received from DepthImageStream"
    DTDFVocab:inputTo DepthProcessingEnabler
    DTDFVocab:fromData DepthImageStream
]

instance WheelSpeedRawData : DTDFVocab:Data [
    base:desc "Raw wheel speed data received from WheelSpeedSignal"
    DTDFVocab:inputTo SpeedProcessingEnabler
    DTDFVocab:fromData WheelSpeedSignal
]

instance SteeringAngleRawData : DTDFVocab:Data [
    base:desc "Raw steering angle data received from SteeringAngleSignal"
    DTDFVocab:inputTo SteeringProcessingEnabler
    DTDFVocab:fromData SteeringAngleSignal
]

instance EgoStateRawData : DTDFVocab:Data [
    base:desc "Raw vehicle ego state data received from EgoStateSignal"
    DTDFVocab:inputTo EgoStateProcessingEnabler
    DTDFVocab:fromData EgoStateSignal
]

// Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering model applied to LiDAR point clouds for object detection"
    DTDFVocab:inputTo PointCloudClusteringTrackingEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking model computing trajectories of detected objects"
    DTDFVocab:inputTo TrackingEnabler
]

instance ACCRuleBasedModel : DTDFVocab:Model [
    base:desc "Rule‑based ACC controller computing desired velocity from lead vehicle distance"
    DTDFVocab:inputTo ACCControllerEnabler
]

// Enablers (ROS2 nodes / feature engineering)
instance LiDARProcessingEnabler : DTDFVocab:Enabler [
    base:desc "DataPreProcessing FE processing raw LiDAR point clouds prior to clustering"
    DTDFVocab:enables LiDARProcessingService
]

instance DepthProcessingEnabler : DTDFVocab:Enabler [
    base:desc "DataPreProcessing FE processing raw depth images for camera‑based perception"
    DTDFVocab:enables DepthProcessingService
]

instance PointCloudClusteringTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Featurization engine performing DBSCAN clustering on LiDAR data"
    DTDFVocab:enables PointCloudClusteringTrackingService
]

instance TrackingEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter tracking engine for object trajectory estimation"
    DTDFVocab:enables TrackingService
]

instance ACCControllerEnabler : DTDFVocab:Enabler [
    base:desc "AccController FE executing rule‑based ACC logic"
    DTDFVocab:enables ACCControllerService
]

instance SpeedProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing engine for vehicle speed signals"
    DTDFVocab:enables SpeedProcessingService
]

instance SteeringProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing engine for steering angle signals"
    DTDFVocab:enables SteeringProcessingService
]

instance EgoStateProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing engine for ego state telemetry data"
    DTDFVocab:enables EgoStateProcessingService
]

instance ROS2NetworkEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware facilitating inter‑entity communication over Wi‑Fi"
    DTDFVocab:enables ROS2CommunicationService
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "ISO 23247 DataTranslation FE serializing and unit‑converting data for the DT"
    DTDFVocab:enables DataTranslationService
]

// Services (High level functionalities)
instance LiDARProcessingService : DTDFVocab:Service [
    base:desc "Service for LiDARProcessingEnabler"
]

instance DepthProcessingService : DTDFVocab:Service [
    base:desc "Service for DepthProcessingEnabler"
]

instance PointCloudClusteringTrackingService : DTDFVocab:Service [
    base:desc "Service for PointCloudClusteringTrackingEnabler"
]

instance TrackingService : DTDFVocab:Service [
    base:desc "Service for TrackingEnabler"
]

instance ACCControllerService : DTDFVocab:Service [
    base:desc "Service for ACCControllerEnabler"
]

instance SpeedProcessingService : DTDFVocab:Service [
    base:desc "Service for SpeedProcessingEnabler"
]

instance SteeringProcessingService : DTDFVocab:Service [
    base:desc "Service for SteeringProcessingEnabler"
]

instance EgoStateProcessingService : DTDFVocab:Service [
    base:desc "Service for EgoStateProcessingEnabler"
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring service providing real‑time state display, logging, and report generation"
    DTDFVocab:provides SystemHealthInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation Offloading service running ACC algorithm remotely to compute desired speed"
    DTDFVocab:provides ACCDesiredSpeedInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service enabling ACC enable/disable, speed modification, and emergency braking"
    DTDFVocab:provides ACCRemoteManagementInsight
]

instance ThreeDVisualizationService : DTDFVocab:Service [
    base:desc "3D Visualization service rendering vehicle and surrounding object tracks in RViz"
    DTDFVocab:provides VisualizationInsight
]

instance TrafficPathProjectionService : DTDFVocab:Service [
    base:desc "Traffic Path Projection service displaying projected driving paths in a virtual cockpit"
    DTDFVocab:provides PathProjectionInsight
]

instance ROS2CommunicationService : DTDFVocab:Service [
    base:desc "Service managing ROS2 network communication over Wi‑Fi"
    DTDFVocab:provides ROS2CommunicationInsight
]

instance DataTranslationService : DTDFVocab:Service [
    base:desc "Service handling ISO 23247 data translation for the Digital Twin"
    DTDFVocab:provides DataTranslationInsight
]

// Insights & Actions
instance SystemHealthInsight : DTDFVocab:Insight [
    base:desc "Insight into overall system health derived from monitoring telemetry logs"
]

instance ACCDesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Insight into ACC computed desired speed for adaptive cruise control"
]

instance ACCRemoteManagementInsight : DTDFVocab:Insight [
    base:desc "Insight into ACC remote management commands and status"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight into 3D visualization of vehicle and detected objects"
]

instance PathProjectionInsight : DTDFVocab:Insight [
    base:desc "Insight into projected traffic paths presented in the virtual cockpit"
]

instance ROS2CommunicationInsight : DTDFVocab:Insight [
    base:desc "Insight into ROS2 network communication quality and delays"
]

instance DataTranslationInsight : DTDFVocab:Insight [
    base:desc "Insight into data translation and unit conversion metadata"
]

instance AdjustAcceleratorCommand : DTDFVocab:Action [
    base:desc "Action to adjust the accelerator command sent to the motor actuation FE"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to trigger emergency braking actuator via the EmergencyBrakeActuationFE"
    DTDFVocab:IsAutomatic false
]

// Actuating Components
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller translating desired speed commands into motor voltage"
    DTDFVocab:producedData MotorCommandSignal
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo adjusting steering angle based on command from ACC controller"
    DTDFVocab:producedData SteeringCommandSignal
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency braking actuator driven by the Digital Twin’s Actuation FE via the EmergencyBrakeAction"
    DTDFVocab:producedData BrakingSignal
]

// Data produced by actuators
instance MotorCommandSignal : DTDFVocab:Data [
    base:desc "Desired motor voltage command generated by the MotorActuator"
]

instance SteeringCommandSignal : DTDFVocab:Data [
    base:desc "Desired steering angle command generated by the SteeringServoActuator"
]

instance BrakingSignal : DTDFVocab:Data [
    base:desc "Brake command signal produced by the EmergencyBrakeActuator"
]

// Data storage and reporting
instance LiDARClusteringOutput : DTDFVocab:Data [
    base:desc "Output data from LiDAR clustering processing"
]

instance SQLDatabaseData : DTDFVocab:Data [
    base:desc "External SQL database storing processed LiDAR clusters, tracking logs, and ACC velocity trajectories"
    DTDFVocab:inputTo DataReportingEnabler
    DTDFVocab:fromData LiDARClusteringOutput
] // TODO: Fixed reference to LiDARClusteringOutput

instance DataReportingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler responsible for exporting data to the external SQL database"
    DTDFVocab:enables DataReportingService
]

instance DataReportingService : DTDFVocab:Service [
    base:desc "Service generating human‑readable time‑series reports from stored telemetry logs"
    DTDFVocab:provides ReportGenerationInsight
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight into generated performance and operation reports for operator decision‑making"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT: acceleration and braking commands translated into motor voltage commands via the Actuation FE, steering angle adjustments via the steering servo FE, and emergency braking signals, all dispatched over the same Wi‑Fi link using ROS 2 publish/subscribe messages as mandated by the ISO 23247 Data Translation FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All DT services operate in real‑time with an end‑to‑end communication latency constrained to ≤100 ms (R7) and clock synchronization accuracy of 100 ms (R8)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated by a hierarchical ISO 23247 reference architecture: the Physical Twin Entity runs data‑preprocessing and actuation, the Digital Twin Entity handles data collection, analytics, and user‑facing services, the User Entity exposes 3D visualization and control panels, and the Cross‑System Entity mediates data translation; all coordinated via ROS 2 topics over Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Phase 0 – Physical Twin manufacturing (building the 1/10‑scale vehicle); Phase 1 – Requirements definition (R1–R8); Phase 2 – Architecture design per ISO 23247 entities and FEs; Phase 3 – Implementation and deployment of ROS2 nodes; Phase 4 – System release and integration; Phase 5 – Runtime operation and remote management."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity sensor data (LiDAR × depth camera), sub‑100 ms latency validation, 100 ms clock‑sync verification, real‑time vehicle state logging, and verification of ACC control logic against ISO 15622 specifications; uncertainty mitigation through Kalman‑filtering and DBSCAN clustering, and validation via offline simulations and comparative data analysis."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication over Wi‑Fi between PT and DT; intra‑DT ROS2 message exchange; Data Translation FE serializes messages into ROS2 payloads; external data storage accessed via networked SQL server."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital Twin components run on an external edge node (e.g., a cloud server or workstation) connected via Wi‑Fi; Physical Twin Entity runs on the on‑board NVIDIA Jetson Orin Nano; the User Entity runs on an operator’s workstation or tablet; all nodes are managed through ROS2 launch files."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture, ISO/IEC 30173:2023 for terminology, ISO 15622 for ACC, 3GPP 22.185 for latency, optional OPC UA for data translation, and adherence to ROS 2 middleware standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical control loop for ACC and emergency braking with 100 ms latency requirement, real‑time data integrity via clock synchronization, human‑in‑the‑loop monitoring through 3D UI, and compliance with ISO 15622 ACC safety specifications; cybersecurity details are not covered in the document."
]