// C3: Physical sensing components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Onboard LiDAR sensor providing raw point cloud data for environmental mapping with rotational scanning capabilities."
    DTDFVocab:producedData RawLiDARPointCloudData
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Depth camera providing spatial awareness through RGB-D data acquisition with Intel RealSense technology."
    DTDFVocab:producedData DepthCameraSpatialData
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor suite capturing motor, steering, and servo actuation states for vehicle state monitoring."
    DTDFVocab:producedData ProcessedVehicleStateData
]

// C4: Physical-to-virtual interaction
instance RawLiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
    base:desc "Unprocessed point cloud data transmitted via Wi-Fi UDP from LiDAR sensor to Digital Twin Entity."
]

instance DepthCameraSpatialData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
    base:desc "RGB-D data transmitted via Wi-Fi UDP for spatial context integration."
]

instance ProcessedVehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
    base:desc "Structured vehicle state data (motor, steering, servo actuation) transmitted via ROS2 network."
]

instance ActuationFeedbackData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
    base:desc "Motor, steering, and servo actuation commands and execution states transmitted via ROS2 network."
]

instance EnvironmentalObjectTracks : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
    base:desc "Clustering and tracking results of point cloud data generating object tracks and projected driving paths."
]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Model performing noise filtering, object segmentation, and track generation from raw LiDAR point clouds."
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance VehicleStateProcessingModel : DTDFVocab:Model [
    base:desc "Model extracting actionable states from raw motor, steering, and servo actuation data."
    DTDFVocab:inputTo VehicleStateProcessingEnabler
]

instance RawLiDARPointCloudDataProcessed : DTDFVocab:Data [
    base:desc "Processed LiDAR point cloud data after noise filtering and object segmentation."
    DTDFVocab:fromData RawLiDARPointCloudData
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance ProcessedVehicleStateDataStructured : DTDFVocab:Data [
    base:desc "Structured vehicle state data with extracted actionable states for visualization and control."
    DTDFVocab:fromData ProcessedVehicleStateData
    DTDFVocab:inputTo VehicleStateProcessingEnabler
]

instance EnvironmentalContextData : DTDFVocab:Data [
    base:desc "Generated object tracks and projected driving paths from point cloud clustering and tracking."
    DTDFVocab:fromData EnvironmentalObjectTracks
    DTDFVocab:inputTo EnvironmentalContextEnabler
]

instance ActuationCommandData : DTDFVocab:Data [
    base:desc "Motor, steering, and servo actuation commands with execution state feedback."
    DTDFVocab:fromData ActuationFeedbackData
    DTDFVocab:inputTo ActuationControlEnabler
]

// C11: Enablers
instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Software component performing point cloud clustering, tracking, and noise filtering using ROS2 packages."
    DTDFVocab:enables RealTimeEnvironmentalMonitoringService, ObjectTrackingService
]

instance VehicleStateProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Software component preprocessing vehicle state data for visualization and control via ROS2 topics."
    DTDFVocab:enables VehicleStateMonitoringService, AdaptiveCruiseControlService
]

instance EnvironmentalContextEnabler : DTDFVocab:Enabler [
    base:desc "Software component generating object tracks and projected driving paths from processed LiDAR data."
    DTDFVocab:enables PathPlanningService, CollisionAvoidanceService
]

instance ActuationControlEnabler : DTDFVocab:Enabler [
    base:desc "Software component translating digital commands to physical actuation via OPC UA and ROS2 interfaces."
    DTDFVocab:enables AutonomousControlService, ActuationFeedbackService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Software component ensuring data serialization, message type alignment, and unit conversions across components."
    DTDFVocab:enables DataConsistencyService, CrossEntityCommunicationService
]

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 network framework enabling real-time intra-entity communication between software components."
    DTDFVocab:enables RealTimeDataExchangeService, ComponentCoordinationService
]

instance WiFiUDPCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "Wi-Fi UDP transport layer enabling real-time inter-entity communication between Physical and Digital Twin."
    DTDFVocab:enables PhysicalToVirtualDataTransmissionService, LowLatencyCommunicationService
]

// C6: Services
instance RealTimeEnvironmentalMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real-time monitoring of environmental conditions using processed LiDAR data."
    DTDFVocab:provides EnvironmentalConditionInsight
]

instance ObjectTrackingService : DTDFVocab:Service [
    base:desc "Service generating and maintaining object tracks from point cloud data for situational awareness."
    DTDFVocab:provides ObjectTrackInsight
]

instance VehicleStateMonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring vehicle state parameters (motor, steering, servo) in real-time."
    DTDFVocab:provides VehicleStateInsight
]

instance AdaptiveCruiseControlService : DTDFVocab:Service [
    base:desc "Service implementing adaptive cruise control using processed vehicle state and environmental data."
    DTDFVocab:provides SpeedAdjustmentAction
]

instance PathPlanningService : DTDFVocab:Service [
    base:desc "Service generating projected driving paths based on object tracks and environmental context."
    DTDFVocab:provides PathOptimizationInsight
]

instance CollisionAvoidanceService : DTDFVocab:Service [
    base:desc "Service detecting and avoiding collisions using object tracks and path planning data."
    DTDFVocab:provides CollisionAvoidanceAction
]

instance AutonomousControlService : DTDFVocab:Service [
    base:desc "Service providing closed-loop autonomous control of vehicle actuation systems."
    DTDFVocab:provides ActuationCommandAction
]

instance ActuationFeedbackService : DTDFVocab:Service [
    base:desc "Service monitoring and reporting actuation command execution states."
    DTDFVocab:provides ActuationStatusInsight
]

instance DataConsistencyService : DTDFVocab:Service [
    base:desc "Service ensuring data consistency across entities through translation and validation."
    DTDFVocab:provides DataConsistencyInsight
]

instance CrossEntityCommunicationService : DTDFVocab:Service [
    base:desc "Service managing cross-entity data exchange between Physical, Digital, and User Entities."
    DTDFVocab:provides CommunicationStatusInsight
]

instance RealTimeDataExchangeService : DTDFVocab:Service [
    base:desc "Service enabling real-time data exchange between software components via ROS2 topics."
    DTDFVocab:provides DataExchangeStatusInsight
]

instance ComponentCoordinationService : DTDFVocab:Service [
    base:desc "Service coordinating software components within the Digital Twin Entity."
    DTDFVocab:provides ComponentCoordinationInsight
]

instance PhysicalToVirtualDataTransmissionService : DTDFVocab:Service [
    base:desc "Service transmitting physical sensor data to the Digital Twin Entity via Wi-Fi UDP."
    DTDFVocab:provides DataTransmissionStatusInsight
]

instance LowLatencyCommunicationService : DTDFVocab:Service [
    base:desc "Service ensuring low-latency communication between Physical and Digital Twin Entities."
    DTDFVocab:provides LatencyPerformanceInsight
]

// C17: Insights/Actions
