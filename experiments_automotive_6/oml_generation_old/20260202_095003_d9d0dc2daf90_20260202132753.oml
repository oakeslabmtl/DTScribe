]

// C2: Acting Components
instance VehicleActuationController : DTDFVocab:ActingComponent [
    base:desc "Actuation component converting digital commands to physical actions for motor, steering, and servo systems."
]

instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller adjusting motor voltage based on input commands to achieve target speed."
]

