    base:desc "Optimized driving paths generated from object tracks and environmental context."
]

instance CollisionAvoidanceAction : DTDFVocab:Action [
    base:desc "Automatic collision avoidance maneuvers triggered by object detection."
    DTDFVocab:IsAutomatic true
]

instance ActuationCommandAction : DTDFVocab:Action [
    base:desc "Generated actuation commands for motor, steering, and servo systems."
    DTDFVocab:IsAutomatic true
]

instance ActuationStatusInsight : DTDFVocab:Insight [
    base:desc "Execution status of actuation commands including motor, steering, and servo states."
]

instance DataConsistencyInsight : DTDFVocab:Insight [
    base:desc "Verification of data consistency across Physical, Digital, and User Entities."
]

instance CommunicationStatusInsight : DTDFVocab:Insight [
    base:desc "Status of cross-entity communication between Physical and Digital Twin."
]

instance DataExchangeStatusInsight : DTDFVocab:Insight [
