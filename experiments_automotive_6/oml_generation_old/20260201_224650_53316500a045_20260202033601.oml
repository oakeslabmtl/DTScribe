instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor capturing point cloud data"
    DTDFVocab:producedData LiDARPointCloundsDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing vehicle state data including speed and position"
    DTDFVocab:producedData VehicleStateDataTransmitted
]

instance SteeringSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing steering angle data"
    DTDFVocab:producedData SteeringDataTransmitted
]

instance ServoInputSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing servo input signals"
    DTDFVocab:producedData ServoInputDataTransmitted
]

instance LiDARPointCloundsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance SteeringDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringSensor
]

instance ServoInputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ServoInputSensor
]

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data transmitted over Wi-Fi UDP"
    DTDFVocab:fromData LiDARPointCloundsDataTransmitted
    DTDFVocab:inputTo PointCloudClusteringSoftwareComponent
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state data including speed, position, and orientation"
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo DataTranslationComponent
]

instance SteeringData : DTDFVocab:Data [
    base:desc "Steering angle data"
    DTDFVocab:fromData SteeringDataTransmitted
    DTDFVocab:inputTo DataTranslationComponent
]

instance ServoInputData : DTDFVocab:Data [
    base:desc "Servo input signals data"
    DTDFVocab:fromData ServoInputDataTransmitted
    DTDFVocab:inputTo DataTranslationComponent
]

instance PointCloudClusteringSoftwareComponent : DTDFVocab:Component, DTDFVocab:Enabler [
    base:desc "Software component for processing raw LiDAR point clouds into clustered and tracked data"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance DataTranslationComponent : DTDFVocab:Component, DTDFVocab:Enabler [
    base:desc "Component for serializing data, aligning message types, and performing unit conversions for all data streams"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance ROS2Middleware : DTDFVocab:Component, DTDFVocab:Enabler [
    base:desc "ROS2 middleware facilitating internal communication between software components"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of vehicle state data, projected driving path, detected object tracks via UI with reporting capabilities"
    DTDFVocab:provides RealTimeVehicleStateVisualization, ProjectedDrivingPathVisualization, DetectedObjectTracksVisualization, ReportingCapability
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC system lead vehicle detection, speed calculation based on distance, and actuation commands offloaded to cloud resources"
    DTDFVocab:provides LeadVehicleDetectionInsight, SpeedCalculationInsight, ActuationCommandsAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote enable/disable ACC, desired speed setting, emergency braking commands"
    DTDFVocab:provides EnableACCCmd, DisableACCCmd, SetDesiredSpeedCmd, EmergencyBrakingCmd
]

instance RealTimeVehicleStateVisualization : DTDFVocab:Insight [
    base:desc "Real-time visualization of vehicle state data"
]

instance ProjectedDrivingPathVisualization : DTDFVocab:Insight [
    base:desc "Visualization of projected driving path"
]

instance DetectedObjectTracksVisualization : DTDFVocab:Insight [
    base:desc "Visualization of detected object tracks"
]

instance ReportingCapability : DTDFVocab:Insight [
    base:desc "Reporting capabilities for collected data"
]

instance LeadVehicleDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of lead vehicle for ACC"
]

instance SpeedCalculationInsight : DTDFVocab:Insight [
    base:desc "Speed calculation based on distance to lead vehicle"
]

instance ActuationCommandsAction : DTDFVocab:Action [
    base:desc "Actuation commands for ACC system"
    DTDFVocab:IsAutomatic true
]

instance EnableACCCmd : DTDFVocab:Action [
    base:desc "Remote enable command for ACC system"
    DTDFVocab:IsAutomatic false
]

instance DisableACCCmd : DTDFVocab:Action [
    base:desc "Remote disable command for ACC system"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedCmd : DTDFVocab:Action [
    base:desc "Setting desired speed for ACC system"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingCmd : DTDFVocab:Action [
    base:desc "Emergency braking command"
    DTDFVocab:IsAutomatic false
]

instance PhysicalTwinEntity : DTDFVocab:Environment [
    base:desc "Physical Twin Entity deployed on separate hardware"
    base:contains LiDARSensor, VehicleStateSensor, SteeringSensor, ServoInputSensor, DataPreProcessingComponent, ActuationComponent, DeviceCommunicationComponent, PointCloudClusteringSoftwareComponent
]

instance DigitalTwinEntity : DTDFVocab:Environment [
    base:desc "Digital Twin Entity deployed on separate hardware"
    base:contains ComputationOffloadingComponent, RemoteManagementComponent
]

instance UserEntity : DTDFVocab:Environment [
    base:desc "User Entity deployed on separate hardware"
    base:contains ThreeDVisualizationSubcomponent, ControlPanelSubcomponent
]

instance DataPreProcessingComponent : DTDFVocab:Component [
    base:desc "Data pre-processing component in Physical Twin Entity"
]

instance ActuationComponent : DTDFVocab:Component [
    base:desc "Actuation component in Physical Twin Entity"
]

instance DeviceCommunicationComponent : DTDFVocab:Component [
    base:desc "Device communication component in Physical Twin Entity"
]

instance ComputationOffloadingComponent : DTDFVocab:Component [
    base:desc "Component for offloading ACC computations to cloud resources"
]

instance RemoteManagementComponent : DTDFVocab:Component [
    base:desc "Component for handling remote management commands"
]

instance ThreeDVisualizationSubcomponent : DTDFVocab:Component [
    base:desc "3D Visualization subcomponent of User Interface FE"
]

instance ControlPanelSubcomponent : DTDFVocab:Component [
    base:desc "Control Panel subcomponent of User Interface FE"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands for Adaptive Cruise Control (ACC) are processed by the Controlling FE, serialized via the Data Translation component, and transmitted over Wi-Fi UDP to the Actuation FE for motor and steering servo actuation. Command types beyond ACC, message formats, validation/authentication mechanisms, feedback systems, and execution confirmation details are not specified."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires 100 ms clock synchronization accuracy for computation offloading between devices, adhering to safety-critical vehicular standards but constrained by hardware limitations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows ISO 23247 RA, organizing software components into three entities mapped to ROS2 packages. Each entity is deployed on dedicated hardware: Physical Twin Entity (handling general automotive functions like Point Cloud Clustering & Tracking), Digital Twin Entity (data management and control), and User Entity (3D Visualization and Control Panel). This deviates from ISO 23247 by extending the Physical Twin Entity beyond the standard's OME to encompass broader system resources."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Internal software components communicate via ROS2, while inter-entity communication uses Wi-Fi with UDP transport layer. Network topology, bandwidth, latency requirements, reliability mechanisms, and security protocols are not detailed in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with ISO 23247:2021 Digital Twin Framework for Manufacturing standard, which includes four parts: Overview and general principles (Part 1), Reference architecture (Part 2), Digital representation of physical manufacturing elements (Part 3), and Information exchange (Part 4). Part 2 defines an entity-based reference architecture comprising Observable Manufacturing Elements (OME), Data Collection and Device Control Entity, Digital Twin Entity, and User Entity. Functional Entities (FEs) implement specific tasks, with OPC Unified Architecture (OPC UA) cited as a possible implementation for interoperability."
]