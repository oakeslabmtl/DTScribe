]

instance DataTranslationService : DTDFVocab:Service [
    base:desc "Ensures interoperability between entities via ROS2 message serialization and unit conversion."
    DTDFVocab:provides DataInteroperabilityInsight
]

instance ROS2CommunicationService : DTDFVocab:Service [
    base:desc "Facilitates modular software integration and message passing between ROS2 nodes across the DT constellation."
