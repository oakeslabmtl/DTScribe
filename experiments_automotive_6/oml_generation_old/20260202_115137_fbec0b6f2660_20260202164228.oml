instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Captures raw point clouds for object detection and tracking in the vehicle's proximity using Hokuyo UST-10LX LiDAR sensor."
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelDeepsenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Provides depth perception and environmental context for the ego vehicle using Intel Deepsense D435i depth camera."
    DTDFVocab:producedData DepthCameraData
]

instance EgoVehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Continuously monitors the ego vehicle's speed via onboard sensors integrated with the lower-level chassis."
    DTDFVocab:producedData EgoVehicleSpeedData
]

instance EgoVehicleSteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Continuously monitors the ego vehicle's steering angle via onboard sensors integrated with the lower-level chassis."
    DTDFVocab:producedData EgoVehicleSteeringAngleData
]

instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iCamera
]

instance EgoVehicleSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoVehicleSpeedSensor
]

instance EgoVehicleSteeringAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoVehicleSteeringAngleSensor
]

instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Implements DBSCAN clustering algorithm (Python/C++) to segment raw LiDAR data into object clusters for perception."
    DTDFVocab:inputTo PointCloudClusteringAndTrackingEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Uses Kalman filtering (MATLAB/Simulink) to estimate and update object tracks (position, velocity, size) over time."
    DTDFVocab:inputTo PointCloudClusteringAndTrackingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Follows ISO 15622 for performance class I ACC (no road curvature capabilities), computing desired speed based on lead vehicle distance."
    DTDFVocab:inputTo ACCControlEnabler
]

instance EgoVehicleStateData : DTDFVocab:Data [
    base:desc "Real-time and historical data on ego vehicle speed and steering angle for ACC performance analysis."
    DTDFVocab:fromData EgoVehicleSpeedData, EgoVehicleSteeringAngleData
    DTDFVocab:inputTo PerformanceAnalyticsEnabler, ACCControlEnabler
]

instance ObjectTrackDataProcessed : DTDFVocab:Data [
    base:desc "Processed object tracks (lead vehicle position, velocity, size) generated from raw sensor data via clustering and Kalman filtering."
    DTDFVocab:fromData LiDARPointCloudData, DepthCameraData
    DTDFVocab:inputTo ACCControlEnabler, PredictiveMaintenanceEnabler
]

instance ACCControlParametersData : DTDFVocab:Data [
    base:desc "Data-driven adjustments to ACC control parameters (e.g., desired speed, braking thresholds) based on operational feedback."
    DTDFVocab:inputTo ParameterOptimizationEnabler
]

instance BrakeSystemHealthData : DTDFVocab:Data [
    base:desc "Brake system health metrics collected for predictive maintenance planning via integration with CREO Simulate."
    DTDFVocab:inputTo PredictiveMaintenanceEnabler
]

instance ADASDecisionVisualizationData : DTDFVocab:Data [
    base:desc "Visualizations of ADAS decision-making (e.g., projected driving path) for driver transparency."
    DTDFVocab:inputTo DriverFeedbackEnabler
]

instance PointCloudClusteringAndTrackingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2-based module implementing DBSCAN clustering (Python/C++) and Kalman filtering (MATLAB/Simulink) for object tracking."
    DTDFVocab:enables ObjectTrackingService
]

instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "Computes ACC control logic (ISO 15622 compliant) for desired speed based on lead vehicle distance and ego vehicle state."
    DTDFVocab:enables ACCComputationService, RemoteManagementService
]

instance PerformanceAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Analyzes real-time and historical data for ACC performance metrics (e.g., fuel economy, safety compliance)."
    DTDFVocab:enables PerformanceAnalyticsService
]

instance ParameterOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Adjusts ACC control parameters dynamically based on operational feedback and data-driven insights."
    DTDFVocab:enables ParameterOptimizationService
]

instance PredictiveMaintenanceEnabler : DTDFVocab:Enabler [
    base:desc "Integrates with CREO Simulate for brake system health monitoring and proactive maintenance planning."
    DTDFVocab:enables PredictiveMaintenanceService
]

instance DriverFeedbackEnabler : DTDFVocab:Enabler [
    base:desc "Generates visualizations of ADAS decision-making (e.g., projected driving path) to improve driver trust."
    DTDFVocab:enables DriverFeedbackService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Handles ROS2 message serialization and unit conversion for interoperability between entities with ≤100 ms latency."
    DTDFVocab:enables DataTranslationService
]

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "Modular software integration, message passing, and node lifecycle management using Robot Operating System 2 (ROS2)."
    DTDFVocab:enables ROS2CommunicationService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "Complex tasks like point cloud clustering, Kalman filtering, and ACC control logic implemented in MATLAB/Simulink."
    DTDFVocab:enables SimulationAndModelingService
]

instance Jetpack50SDKEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for programming the Jetson Orin Nano microcomputer and integrating autonomy components."
    DTDFVocab:enables JetsonOrinNanoIntegrationService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database for storing timeseries data (object tracks, vehicle state) and generating human-readable reports."
    DTDFVocab:enables DataStorageService, ReportingService
]

instance WiFiNetworkEnabler : DTDFVocab:Enabler [
    base:desc "Wi-Fi network for inter-entity communication (PT to DT Entity) with ≤100 ms latency."
    DTDFVocab:enables NetworkCommunicationService
]

instance ROS2VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D CAD-based rendering via ROS2 visualization tools for real-time monitoring of the vehicle's environment."
    DTDFVocab:enables RealTimeVisualizationService
]

instance ObjectTrackingService : DTDFVocab:Service [
    base:desc "Generates and updates object tracks (position, velocity, size) from raw sensor data using clustering and Kalman filtering."
    DTDFVocab:provides ObjectTrackInsight
]

instance ACCComputationService : DTDFVocab:Service [
    base:desc "Computes desired speed for ACC based on lead vehicle distance and ego vehicle state (offloaded from PT to DT Entity)."
