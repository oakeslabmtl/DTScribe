// ------------------------------------------------------------------
// Physical Sensing Components – C3
// ------------------------------------------------------------------
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR providing point clouds for clustering & tracking."
    DTDFVocab:producedData LidarPointCloudDataTrans
]

instance IntelDepthSenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DepthSense D435i depth camera providing visual data for object detection."
    DTDFVocab:producedData DepthImageDataTrans
]

instance VehicleInternalStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle internal sensor delivering real‑time speed and steering angle measurements."
    DTDFVocab:producedData VehicleStateDataTrans
]

// ------------------------------------------------------------------
// Physical‑to‑Virtual Interaction – C4
// ------------------------------------------------------------------
instance LidarPointCloudDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthImageDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthSenseD435iCamera
]

instance VehicleStateDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleInternalStateSensor
]

// ------------------------------------------------------------------
// Data – C10
// ------------------------------------------------------------------
instance LidarPointCloudData : DTDFVocab:Data [
    base:desc "Raw point cloud data from Hokuyo UST‑10LX LiDAR."
    DTDFVocab:fromData LidarPointCloudDataTrans
    DTDFVocab:inputTo DataProcessingFEEnabler
    DTDFVocab:inputTo DataTranslationFEEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Raw depth image data from Intel DepthSense D435i camera."
    DTDFVocab:fromData DepthImageDataTrans
    DTDFVocab:inputTo DataProcessingFEEnabler
    DTDFVocab:inputTo DataTranslationFEEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle speed and steering angle measurements."
    DTDFVocab:fromData VehicleStateDataTrans
    DTDFVocab:inputTo DataCollectionFEEnabler
    DTDFVocab:inputTo DataTranslationFEEnabler
    DTDFVocab:inputTo ACCComputationEnabler
]

// ------------------------------------------------------------------
// Models – C10
// ------------------------------------------------------------------
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point clouds for object detection."
    DTDFVocab:inputTo DataProcessingFEEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter tracking of object tracks derived from clustered LiDAR points."
    DTDFVocab:inputTo DataProcessingFEEnabler
]

instance ACCAlgorithmModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) decision‑making algorithm computing desired speed."
    DTDFVocab:inputTo ACCComputationEnabler
]

instance VisualizationPipelineModel : DTDFVocab:Model [
    base:desc "3‑D visualization pipeline for live vehicle state and environment."
    DTDFVocab:inputTo VisualizationFEEnabler
]

instance TimeSeriesReportingModel : DTDFVocab:Model [
    base:desc "Time‑series reporting model for vehicle and traffic state."
    DTDFVocab:inputTo ReportingFEEnabler
]

// ------------------------------------------------------------------
// Enablers – C11
// ------------------------------------------------------------------
instance DataProcessingFEEnabler : DTDFVocab:Enabler [
    base:desc "Pre‑processing FE that clusters LiDAR and tracks objects."
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationFEEnabler : DTDFVocab:Enabler [
    base:desc "Serializes, aligns, and converts units before publishing downstream FEs."
    DTDFVocab:enables ComputationOffloadingService
    DTDFVocab:enables RemoteManagementService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "FE performing ACC decision‑making algorithm."
    DTDFVocab:enables ComputationOffloadingService
]

instance VisualizationFEEnabler : DTDFVocab:Enabler [
    base:desc "3‑D visualization FE."
    DTDFVocab:enables ThreeDVisualizationService
]

instance RemoteUIEnabler : DTDFVocab:Enabler [
    base:desc "Remote UI FE for operator controls."
    DTDFVocab:enables RemoteManagementService
]

instance DataCollectionFEEnabler : DTDFVocab:Enabler [
    base:desc "FE that records vehicle state to a real‑time SQL database."
    DTDFVocab:enables DataMonitoringService
]

instance ReportingFEEnabler : DTDFVocab:Enabler [
    base:desc "FE responsible for time‑series reporting of vehicle and traffic state."
    DTDFVocab:enables DataMonitoringService
]

// ------------------------------------------------------------------
// Services – C6
// ------------------------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI displaying vehicle speed, steering, projected driving path, and object tracks; can generate time‑series reports."
    DTDFVocab:provides StructuredReportsInsight
    DTDFVocab:provides PerformanceTrackingInsight
    DTDFVocab:provides ParameterTuningRecommendationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm runs in the cloud on the Digital Twin Entity for offloading."
    DTDFVocab:provides SpeedAdjustmentAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote UI for enabling/disabling ACC, setting desired speed, and issuing emergency braking commands."
    DTDFVocab:provides SpeedAdjustmentAction
    DTDFVocab:provides EmergencyBrakeAction
]

instance ThreeDVisualizationService : DTDFVocab:Service [
    base:desc "Displays live vehicle state and surrounding environment using a presentation FE."
    DTDFVocab:provides LiveEnvironmentInsight
]

// ------------------------------------------------------------------
// Insights – C17
// ------------------------------------------------------------------
instance StructuredReportsInsight : DTDFVocab:Insight [
    base:desc "Structured reports of vehicle and traffic state."
]

instance PerformanceTrackingInsight : DTDFVocab:Insight [
    base:desc "Performance metrics tracking of vehicle operation."
]

instance ParameterTuningRecommendationInsight : DTDFVocab:Insight [
    base:desc "Parameter tuning recommendations to operators."
]

instance LiveEnvironmentInsight : DTDFVocab:Insight [
    base:desc "Live visualization of vehicle state and surrounding environment."
]

// ------------------------------------------------------------------
// Actions – C17
// ------------------------------------------------------------------
instance SpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjustment of desired speed by operator."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Emergency braking command issued by operator."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity publishes desired speed and steering commands via ROS 2 topics to the Data Translation FE, which then forwards the actuators to the Physical Twin Entity; emergency brake and ACC enable/disable signals issued in the UI are also routed through the Actuation FE to the vehicle’s electronic speed controller; all commands are transmitted over the same Wi‑Fi connection ensuring sub‑100 ms end‑to‑end latency."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time DT with an end‑to‑end latency requirement of ≤100 ms (3GPP 22.185). Data is processed per perception cycle, ensuring the DT’s decisions reflect the latest sensor information."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation is a three‑entity, entity‑based architecture: (1) Physical Twin Entity on the vehicle comprising sensors and actuators; (2) Digital Twin Entity running the computational models, data storage, and user services; (3) User Entity delivering a 3‑D visualization UI and control panel; cross‑entity Data Translation FE mediates data exchange."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The engineering lifecycle comprises (1) Requirements definition (R1–R8), (2) Architecture design based on ISO 23247 mapping of functional entities, (3) Implementation of SW packages as ROS2 nodes, (4) Deployment on distributed hardware, and (5) Verification via live testing on the 1/10‑scale vehicle.  No explicit manufacturing or mass‑production phases are described; the DT lifecycle stops at deployment and operational validation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time fidelity is enforced by the ≤ 100 ms end‑to‑end latency requirement, ensuring timely ACC decisions.  The DT’s sensor‑based models (DBSCAN, Kalman) operate on raw data, with unit conversions handled by the Data Translation FE, guaranteeing consistency between virtual and physical representations.  No formal static verification or probabilistic error bounds are detailed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication occurs over Wi‑Fi using the ROS2 middleware (DDS/RTPS).  The Data Translation FE provides serialization and unit conversion, enabling seamless exchange of messages between the Physical Twin Entity, Digital Twin Entity, and User Entity."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT computation offloading (ACC) runs on a cloud host; the Local DT components (data collection, actuation) run on the onboard NVIDIA Jetson Orin Nano; the Physical Twin Entity resides on the vehicle’s hardware.  All components communicate over the vehicle‑to‑cloud Wi‑Fi link and intra‑vehicle ROS2 network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture is the core design framework; ISO 30173 terminology is referenced for generic DT concepts; ROS 2 provides an open‑source messaging standard; OPC UA is considered for future data translation; all FEs adhere to the entity‑based RA."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical: end‑to‑end latency capped at 100 ms, emergency braking capability. No specific security mechanisms (encryption, authentication) are described in the document."
]