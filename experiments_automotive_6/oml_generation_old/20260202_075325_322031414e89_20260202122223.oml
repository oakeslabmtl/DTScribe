]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor suite collecting real-time telemetry including motor, steering, servo actuation states, and overall vehicle dynamics for adaptive cruise control (ACC) logic."
    DTDFVocab:producedData VehicleStateTelemetry
]

instance ActuationFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing feedback from motor, steering, and servo actuators to ensure closed-loop control system integrity in autonomous vehicle operations."
    DTDFVocab:producedData ActuationFeedbackData
]

instance ACCRelevantSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor suite providing ACC-specific data including projected driving paths, object tracks, and vehicle state information for adaptive cruise control functionality."
