// ----------------------------
// Sensing Components & Data Flow
// ----------------------------

// LiDAR sensor providing point‑cloud data
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor providing point‑cloud data for clustering model."
    DTDFVocab:producedData LiDARPointCloudStream
]

instance LiDARPointCloudStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud frames transmitted over Wi‑Fi UDP."
    DTDFVocab:fromData LiDARPointCloudStream
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

// Motor status sensor
instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting motor status values."
    DTDFVocab:producedData MotorStatusStream
]

instance MotorStatusStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Motor status data transmitted over Wi‑Fi UDP."
    DTDFVocab:fromData MotorStatusStream
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

// Steering servo position sensor
instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting steering servo position."
    DTDFVocab:producedData SteeringServoStream
]

instance SteeringServoStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
]

instance SteeringServoData : DTDFVocab:Data [
    base:desc "Steering servo position data transmitted over Wi‑Fi UDP."
    DTDFVocab:fromData SteeringServoStream
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

// Vehicle state sensor (pose, velocity, etc.)
instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor providing overall vehicle state (pose, velocity)."
    DTDFVocab:producedData VehicleStateStream
]

instance VehicleStateStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state data transmitted over Wi‑Fi UDP."
    DTDFVocab:fromData VehicleStateStream
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

// ----------------------------
// Models / Data
// ----------------------------

instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "ROS2 node that clusters and tracks LiDAR point‑cloud on a 2‑D plane to produce object tracks."
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance ACCOffloadModel : DTDFVocab:Model [
    base:desc "Cloud‑hosted ACC algorithm (lead‑vehicle detection, desired‑speed calculation, speed command generation)."
    DTDFVocab:inputTo CloudComputeEnabler
]

// ----------------------------
// Enablers (Tooling & Enablers)
// ----------------------------

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware that routes sensor streams to functional elements and models."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance CloudComputeEnabler : DTDFVocab:Enabler [
    base:desc "Cloud‑based compute platform hosting the off‑loaded ACC algorithm."
    DTDFVocab:enables ComputationOffloadingService
]

instance WiFiCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "Low‑latency bi‑directional Wi‑Fi link using UDP for vehicle‑DT communication."
    DTDFVocab:enables RemoteManagementService, DataMonitoringService
]

instance CustomUIEnabler : DTDFVocab:Enabler [
    base:desc "Customized UI integrating data visualization, reporting, and command‑and‑control."
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

// ----------------------------
// Services
// ----------------------------

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Graphical UI displays real‑time vehicle state, projected driving path and detected object tracks; allows saving and reporting."
    DTDFVocab:provides RealTimeVehicleStateInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm in the cloud digital twin and returns desired speed to the vehicle for actuation."
    DTDFVocab:provides DesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, set a target speed, and issue an emergency‑brake command via the UI."
    DTDFVocab:provides EnableACCAction, SetTargetSpeedAction, EmergencyBrakeAction
]

// ----------------------------
// Insights & Actions
// ----------------------------

instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current vehicle pose, velocity and sensor‑derived object tracks."
]

instance DesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action that sets the vehicle's desired speed based on ACC computation."
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator‑initiated action to enable adaptive cruise control."
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets a target cruising speed for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediate brake command issued by the operator in an emergency."
    DTDFVocab:IsAutomatic false
]

// ----------------------------
// Acting Components (Physical Twin)
// ----------------------------

instance SteeringActuator : DTDFVocab:ActingComponent [
    base:desc "Steering actuator accessed via ROS2 node for remote control commands."
]

instance ThrottleActuator : DTDFVocab:ActingComponent [
    base:desc "Throttle actuator accessed via ROS2 node for speed command execution."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the digital twin – ACC enable/disable, desired speed set‑point, and emergency‑brake request – are packaged as control messages and sent back to the vehicle over the same Wi‑Fi UDP link. The messages are consumed by the Actuation FE (Motor, Steering, Servo) which executes the actuation on the physical twin. The DT UI allows the operator to issue these commands; the system validates the command type against the ACC service model before transmission. Execution confirmation is provided by the vehicle‑state feedback that is fed back through the same data‑monitoring pipeline."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires clock synchronization between devices with an accuracy of 100 ms, which is the maximum tolerated offset given hardware limitations; this synchronization is needed for computation offloading and safety‑critical vehicular functions."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin follows the ISO 23247 reference architecture, organizing functionality into three entities (Physical Twin Entity, Digital Twin Entity, User Entity). Each functional entity (FE) is implemented as an individual ROS 2 package containing one or more ROS 2 nodes, and the packages are deployed on separate hardware components, providing a distributed, entity‑based orchestration of data management, control, actuation, and user interaction."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS uses a two‑level network architecture. Inside the digital twin, all software components communicate via ROS 2 middleware (publish/subscribe). Interaction between the physical twin and the digital twin crosses the physical boundary over a Wi‑Fi network, using UDP as the transport protocol. The architecture therefore comprises a ROS 2 intra‑entity mesh and an inter‑entity Wi‑Fi/UDP link. The design requires low end‑to‑end latency to satisfy safety‑critical ACC control, though exact latency or bandwidth figures are not specified. Reliability is addressed by ROS 2 quality‑of‑service settings and by the stateless nature of UDP; no explicit redundancy or security mechanisms are described in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin services (Data Monitoring, Computation Offloading, Remote Management) are intended to run on external compute resources that are more capable than the vehicle’s ECU, exemplified by cloud‑based execution of the ACC algorithm. The DTS therefore can be deployed on a cloud platform (or edge server) that provides sufficient CPU for the ACC decision logic, storage for collected sensor data and generated reports, and network connectivity to the vehicle. Scalability is achieved by allocating additional cloud instances for larger data volumes, though concrete scaling mechanisms are not detailed. Availability is implied by the need for continuous remote management, but specific redundancy or SLA provisions are not mentioned."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system explicitly adheres to ISO 23247 – Digital Twin Framework for Manufacturing (all four parts). It adopts the entity‑based reference architecture comprising Observable Manufacturing Elements, Data Collection and Device Control Entity, Digital Twin Entity, and User Entity. The implementation may employ OPC Unified Architecture for device coordination, as suggested by the standard. Clock‑synchronisation requirements from vehicular safety‑critical standards (sub‑100 ms) are recognised, and the implementation targets 100 ms accuracy due to hardware constraints. No additional certification or interoperability frameworks are mentioned."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The case study notes that the ISO 23247 reference architecture (RA) is inadequate for safety‑critical automotive Digital Twin applications. It recommends elevating safety to a first‑class citizen by explicitly adopting existing automotive functional‑safety standards, specifically ISO 26262. This implies that safety analyses required by ISO 26262—such as hazard analysis, risk assessment, and definition of safety goals—should be integrated into the DT development process. The document does not detail specific cybersecurity protocols, access‑control or authentication mechanisms, but emphasizes that safety considerations must be addressed through alignment with ISO 26262's systematic safety lifecycle."
]