// C3: Physical sensing components
instance HokuyoUST10LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2D LiDAR delivering real‑time 2D point clouds."
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance IntelDeepSenseD435i : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense‑D435i depth camera providing 3D depth maps and RGB imagery."
    DTDFVocab:producedData DepthMapDataTransmitted
]

instance VehicleECU : DTDFVocab:SensingComponent [
    base:desc "Vehicle ECU streaming speed, steering angle, inertial navigation, and GPS outputs over CAN bus."
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// C2: Acting components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller that accepts desired speed commands via OPCUA and translates them into motor voltage signals applied to the drive motor, respecting operational limits such as voltage range and acceleration limits."
]

// C4: Data transmitted (from sensors to twin)
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LX
]

instance DepthMapDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435i
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleECU
]

instance ACCCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CloudComputeEnabler
]

// C10: Models/Data (data objects)
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "LiDAR point cloud data (individual points on a 2D plane)."
    DTDFVocab:inputTo ROS2Enabler
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
]

instance DepthMapData : DTDFVocab:Data [
    base:desc "RGB depth map and depth imagery from the DeepSense D435i camera."
    DTDFVocab:inputTo ROS2Enabler
    DTDFVocab:fromData DepthMapDataTransmitted
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state information comprising speed, steering angle, inertial navigation, and GPS data."
    DTDFVocab:inputTo OPCUAEnabler
    DTDFVocab:fromData VehicleStateDataTransmitted
]

instance ACCCommandData : DTDFVocab:Data [
    base:desc "ACC desired speed command computed by cloud compute."
    DTDFVocab:inputTo OPCUAEnabler
    DTDFVocab:fromData ACCCommandDataTransmitted
]

// C11: Enablers
instance ROS2Enabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware enabling real‑time message passing between vehicle nodes and twin services."
    DTDFVocab:enables DataMonitoringService
]

instance OPCUAEnabler : DTDFVocab:Enabler [
    base:desc "OPC UA interface for device control and remote command writing."
    DTDFVocab:enables RemoteManagementService, ComputationOffloadingService
]

instance CloudComputeEnabler : DTDFVocab:Enabler [
    base:desc "Cloud compute resource that performs ACC algorithm offloading."
    DTDFVocab:enables ComputationOffloadingService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Relational SQL database persisting vehicle and telemetry data for historical analysis."
    DTDFVocab:enables DataMonitoringService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of vehicle state, trajectory projections, and object tracks; allows viewing, saving, and report generation."
    DTDFVocab:provides ViewVehicleStateAction, SaveDataAction, GenerateReportAction, LatencyInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm is offloaded from vehicle ECU to cloud compute; computes desired speed based on lead vehicle distance and returns command to vehicle."
    DTDFVocab:provides OffloadAccAlgorithmAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, and issue emergency braking via UI."
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, EmergencyBrakeCommandAction, SafetyComplianceInsight
]

// C17: Insights
instance LatencyInsight : DTDFVocab:Insight [
    base:desc "End‑to‑end latency of control commands between vehicle and digital twin."
]

instance SafetyComplianceInsight : DTDFVocab:Insight [
    base:desc "Safety‑critical compliance status of ACC interactions and command execution."
]

// C17: Actions
instance ViewVehicleStateAction : DTDFVocab:Action [
    base:desc "View live vehicle state data, projected paths, and object tracks in the UI."
    DTDFVocab:IsAutomatic false
]

instance SaveDataAction : DTDFVocab:Action [
    base:desc "Save current telemetry and state data to the SQL database."
    DTDFVocab:IsAutomatic false
]

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Generate reports from persisted vehicle state and telemetry data."
    DTDFVocab:IsAutomatic false
]

instance OffloadAccAlgorithmAction : DTDFVocab:Action [
    base:desc "Trigger ACC algorithm offloading to cloud compute."
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control via UI command."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set desired speed for vehicle via UI command."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeCommandAction : DTDFVocab:Action [
    base:desc "Issue emergency braking command to vehicle."
    DTDFVocab:IsAutomatic false
]

// Component and Environment definitions
instance VehicleTwin : DTDFVocab:Component [
    base:desc "Digital twin instance representing the 1/10‑scale autonomous vehicle."
]

instance VehicleTwinEnvironment : DTDFVocab:Environment [
    base:contains VehicleTwin
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands flow from the Digital Twin to the physical vehicle through the same Wi‑Fi/UDP channel. The ACC subsystem sends desired speed setpoints that are translated into motor actuation messages by the Actuation FE. The User Interface FE can issue emergency braking commands, which are serialized by the Data Translation FE, authenticated and validated by the Controlling FE before being forwarded to the vehicle. Feedback on command execution is provided by sensor streams (e.g., updated vehicle speed and brake status) which are consumed by the Data Monitoring service and displayed in real time. Conflict resolution mechanisms and detailed authentication procedures are not specified in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Physical and digital twin components share a common clock reference and must maintain a clock synchronization accuracy of no more than 100 milliseconds, in accordance with safety‑critical vehicular standards. The architecture requires that any data exchange between the physical sensors, actuator controllers, and the digital twin’s computational nodes respects this temporal bound, ensuring that end‑to‑end latency from sensor acquisition to actuator command execution does not exceed 100 milliseconds. No further synchronization frequency or protocol specifications are provided in the source documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 Reference Architecture, mapping functional software components into three core entities – User, Digital Twin, and Physical Twin – and then deploying each Feature Extractor (FE) as a distinct ROS 2 package comprising one or more ROS 2 nodes.  The Digital Twin Entity houses data‑management and control logic, the Physical Twin Entity handles pre‑processing, point‑cloud clustering, tracking, and device communication, while the User Entity provides a 3 D visualization and control‑panel interface.  Resource allocation, communication, and coordination are managed by ROS 2 middleware under the umbrella of the ISO 23247 orchestration framework, ensuring modularity and clear ownership of functionality across heterogeneous hardware components."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin’s technical network comprises a ROS2 intra‑process communication layer and a Wi‑Fi based inter‑entity communication layer that uses UDP in the transport layer. The Wi‑Fi link is expected to sustain a maximum end‑to‑end latency of 100 ms to meet real‑time performance requirements. Bandwidth requirements are not quantified, but the architecture assumes sufficient capacity to transmit high‑frequency LiDAR point clouds and vehicle telemetry. Reliability strategies such as packet retransmission or redundant links are not described, and no specific security protocols are enumerated beyond the use of authentication within the Controlling FE."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin components are distributed across heterogeneous hardware: compute resources are allocated to equipment best suited for the workload, including options in the cloud or on‑premise, while data storage resides on a device external to the vehicle. Deployment models support modular placement of entities on distinct hardware components, allowing scalability by adding or relocating compute nodes. Availability and reliability are implied by deploying functional elements on separate devices, but explicit redundancy or high‑availability configurations are not detailed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin is compliant with ISO 23247 – Digital twin framework for manufacturing, Part 2: Reference Architecture, which prescribes an entity‑based reference architecture and mandates adherence to ISO guidance for digital twin implementation. Interoperability is achieved by implementing OPC Unified Architecture (OPC UA) for data exchange between the Data Collection and Device Control Entity and the observed manufacturing elements, enabling integration with existing manufacturing execution systems (MES) and enterprise resource planning (ERP) platforms. No additional certification or compliance frameworks are specified in the provided documents."
]