// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor mounted on the 1/10‑scale autonomous vehicle that continuously outputs raw point‑cloud data."
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance VehicleStateSensors : DTDFVocab:SensingComponent [
    base:desc "Sensors collecting vehicle‑state information such as speed, odometry, and steering angle."
    DTDFVocab:producedData VehicleStateTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensors
]

// C10: Models/Data
instance PointCloudClusteringAndTrackingModel : DTDFVocab:Model [
    base:desc "Geometric processing that clusters raw LiDAR points using DBSCAN and tracks them with a Kalman filter to generate object tracks."
]

instance ACCBehaviorModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model that identifies the lead vehicle, computes desired speed based on inter‑vehicle distance, and generates control commands."
]

// C10: Data items
instance RawLiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data as published on ROS2 topics."
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle speed, odometry, and steering angle data."
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Object tracks (position, velocity) generated by Point Cloud Clustering & Tracking."
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance SpeedCommandData : DTDFVocab:Data [
    base:desc "Desired speed command computed by the ACC model."
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

// C11: Enablers
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Cross‑System Data Translation functional entity that serialises messages, aligns types and performs unit conversions."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance DataMonitoringFE : DTDFVocab:Enabler [
    base:desc "3D Visualization and Control Panel functional entities that display real‑time vehicle state and allow user interaction."
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingFE : DTDFVocab:Enabler [
    base:desc "ACC functional entity executed in the digital twin for off‑loading computation."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementFE : DTDFVocab:Enabler [
    base:desc "Control Panel UI enabling operators to enable/disable ACC, set speed, or trigger emergency brake."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring service providing real‑time vehicle state, projected path, object tracks, data saving, report generation and 3D visualization."
    DTDFVocab:provides InsightRealTimeVisualization, InsightDataLogging
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation Offloading service where the ACC algorithm runs on the digital twin and returns speed commands."
    DTDFVocab:provides InsightOffloadedComputation
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service allowing operators to enable/disable ACC, set target speed, and issue emergency brake."
    DTDFVocab:provides ActionEnableACC, ActionSetTargetSpeed, ActionEmergencyBrake
]

// C17: Insights / Actions
instance InsightRealTimeVisualization : DTDFVocab:Insight [
    base:desc "Provides a real‑time 3‑D visualization of vehicle state, object tracks and projected path."
]

instance InsightDataLogging : DTDFVocab:Insight [
    base:desc "Enables saving of sensor streams and generated reports for later analysis."
]

instance InsightOffloadedComputation : DTDFVocab:Insight [
    base:desc "Indicates that ACC computation is performed on the digital twin rather than on the physical vehicle."
]

instance ActionEnableACC : DTDFVocab:Action [
    base:desc "Command to enable or disable the Adaptive Cruise Control functionality."
    DTDFVocab:IsAutomatic false
]

instance ActionSetTargetSpeed : DTDFVocab:Action [
    base:desc "Command to set a desired target speed for the vehicle."
    DTDFVocab:IsAutomatic false
]

instance ActionEmergencyBrake : DTDFVocab:Action [
    base:desc "Command to immediately stop the vehicle by applying maximum braking."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated in the Digital Twin Entity by the ACC Controlling FE, which identifies the lead vehicle, computes a desired speed, and sends this speed value to the Physical Twin Entity. Remote‑management commands (enable/disable ACC, set desired speed, emergency brake) are issued by the user through the Control Panel UI FE. All outgoing command messages are processed by the Data Translation FE for serialization, type alignment and unit conversion, then transmitted over the same Wi‑Fi/UDP link to the Physical Twin Entity, where the Actuation FE converts the desired speed into motor voltage commands (or triggers braking) and applies them to the vehicle actuators. The system provides implicit feedback through the continuous streaming of updated vehicle state back to the Digital Twin, confirming command execution."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DTS requires that all participating devices maintain a shared notion of time with a maximum clock‑synchronisation error of 100 ms, which is the accuracy enforced due to hardware limits. This time base is needed for computation off‑loading and coordinated actuation. The system is designed to support low‑latency end‑to‑end communication (unspecified exact latency) for the ACC service, ensuring that the digital twin can receive sensor data, compute a desired speed and send the command back within the control loop."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin follows the ISO 23247 entity‑based reference architecture, consisting of three top‑level entities – Physical Twin Entity, Digital Twin Entity and User Entity – each instantiated as one or more Functional Entities (FEs). Every FE is packaged as an individual ROS 2 package containing ROS 2 nodes, forming a ROS 2 middleware network for intra‑entity communication. Inter‑entity messages are carried over a Wi‑Fi network using UDP at the transport layer. A dedicated Data Translation FE (implemented according to IEC 62541 / OPC‑UA) serialises, aligns and unit‑converts all data streams. The architecture supports three services (Data Monitoring, Computation Off‑loading of the ACC controller to a cloud or edge compute node, and Remote Management) and uses the ROS 2 ecosystem together with UDP to orchestrate the overall DTS."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS uses a hybrid network architecture. Within each entity, software components communicate via ROS 2 (DDS‑based) middleware, providing publish/subscribe semantics. Between entities (Physical Twin, Digital Twin, User) communication occurs over a Wi‑Fi network using UDP at the transport layer. The architecture requires clock synchronization accuracy of 100 ms across devices (as required for safety‑critical vehicular applications). The system is designed to support low end‑to‑end latency communication suitable for real‑time ACC operation, although exact bandwidth or latency numbers are not specified. No explicit redundancy or security protocols (e.g., encryption, authentication) are described in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin System is deployed as a set of ROS 2 packages, each containing one or more ROS 2 nodes that implement the functional entities (Data Translation, Visualization, Data Collection, ACC Controlling, etc.). The Physical Twin Entity (including Data Pre‑Processing and Actuation FEs) runs on the on‑board hardware of the 1/10‑scale autonomous vehicle, while the Digital Twin Entity and User Entity run on external computing resources capable of data storage and processing (e.g., a cloud or edge server). Collected vehicle state and object tracks are stored in an external SQL database (Data Storage component). Off‑loading of the ACC computation to the DT demonstrates cloud‑based execution, although the precise hosting platform is not detailed. Scalability, availability and reliability mechanisms (e.g., load balancing, failover) are not described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through the use of the OPC UA specification (IEC 62541) for the Data Translation FE, which can serialize and map data to external services. The internal component integration relies on ROS 2 (DDS‑based) for intra‑entity communication and UDP over Wi‑Fi for inter‑entity exchange, allowing the DTS to interoperate with external cloud platforms used for computation off‑loading. No other enterprise‑level protocols are explicitly mentioned."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The prototype is built to comply with ISO 23247 (Digital Twin Framework for Manufacturing), adopting its entity‑based reference architecture. Safety considerations are aligned with ISO 26262, as recommended for automotive DTs. Communication between the Data Translation FE and devices can use OPC UA (IEC 62541) or a custom layer. The design also references AUTOSAR principles, treating software components as hardware‑agnostic to facilitate integration with existing automotive standards. No explicit certification or interoperability framework beyond these standards is described."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The digital twin follows the ISO 15622 Adaptive Cruise Control specification, implementing the basic control strategy for performance class I ACC (no road‑curvature capabilities) as described in Section 6.1‑6.2 of the standard. Safety is explicitly addressed by aligning with ISO 26262 functional‑safety requirements; the case study notes that safety should be a first‑class citizen in automotive DT architectures and recommends adopting ISO 26262 for safety‑critical DT functions. The reference architecture (ISO 23247) is extended to promote the physical twin as a first‑class entity, enabling safety‑critical functional elements (e.g., Data Pre‑Processing FE and Actuation FE) to be deployed on‑vehicle. These measures together provide a safety‑critical design approach, incorporating risk‑assessment guidance from ISO 26262 and compliance with ACC performance standards."
]