// C2: Acting Components
instance AdaptiveCruiseControlMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Motor actuation feature that converts desired speed commands into voltage commands for propulsion system via Vedder Electronic Speed Controller"
]

instance SteeringServoActuator : DTDFVocab:ActuatingComponent [
    base:desc "Embedded steering servo component in lower-level chassis for real-time steering adjustments"
]

instance EmergencyBrakingCommandActuator : DTDFVocab:ActingComponent [
    base:desc "Handles emergency braking commands transmitted from Control Panel UI to physical twin for immediate actuation"
]

// C3: Physical Sensing Components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR for 3D object detection and tracking in ego vehicle's proximity"
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i Depth Camera for high-resolution 3D environmental mapping"
    DTDFVocab:producedData DepthCameraPointCloudData
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring ego vehicle speed transmitted at high frequency"
    DTDFVocab:producedData VehicleSpeedData
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring ego vehicle steering angle transmitted at high frequency"
    DTDFVocab:producedData SteeringAngleData
]

// C4: Data Transmitted
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthCameraPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]

instance ObjectTrackData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR, IntelDepthCamera
]

instance VehicleSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ProcessedObjectTrackData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ObjectTrackData
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of ego vehicle speed, steering angle, object tracks, and projected driving path via 3D Visualization FE"
    DTDFVocab:provides PerformanceInsights
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC control logic (lead vehicle detection, speed computation) from vehicle's ECU to cloud/edge computing"
    DTDFVocab:provides PredictiveAnalytics
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to enable/disable ACC, set desired speed, and trigger emergency braking via Control Panel UI"
    DTDFVocab:provides EmergencyBrakingCommand
]

instance TroubleshootingService : DTDFVocab:Service [
    base:desc "Data collection/reporting for troubleshooting motor/servo health and optimization"
    DTDFVocab:provides MotorHealthInsights, FuelEconomyOptimization
]

// C10: Models/Data
instance EgoVehicle3DModel : DTDFVocab:Model [
    base:desc "3D CAD representation of the ego vehicle visualized via 3D Visualization FE"
]

instance Environment3DModel : DTDFVocab:Model [
    base:desc "3D CAD representation of the ego vehicle's environment visualized via 3D Visualization FE"
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "ACC logic (lead vehicle detection, speed computation) implemented via Controlling FE (ISO 15622-compliant)"
]

instance TimeseriesReportingModel : DTDFVocab:Model [
    base:desc "Timeseries reports of vehicle state/object tracks generated via Reporting FE"
]

instance LiDARPointCloudDataStorage : DTDFVocab:Data [
    base:desc "Raw LiDAR point clouds stored in SQL databases"
    DTDFVocab:fromData LiDARPointCloudData
]

instance VehicleStateDataStorage : DTDFVocab:Data [
    base:desc "Ego vehicle state (speed/steering) data stored in SQL databases"
    DTDFVocab:fromData VehicleSpeedData, SteeringAngleData
]

instance ObjectTrackDataStorage : DTDFVocab:Data [
    base:desc "Processed object tracks (position, velocity, size) stored in SQL databases"
    DTDFVocab:fromData ProcessedObjectTrackData
]

// C11: Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 (Robot Operating System 2) for inter-component communication and real-time data processing"
]

instance ROS2NodeImplementationEnabler : DTDFVocab:Enabler [
    base:desc "Python 3.8/C++ for ROS2 node implementation on Jetson hardware"
]

instance NVIDIAJetpackEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for Jetson hardware deployment"
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for complex algorithms (point cloud clustering, Kalman filtering)"
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation Feature Engine (ISO 23247-compliant) for serialization, unit conversions, and message alignment"
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Cloud/edge server infrastructure for storing sensor data and reports"
    DTDFVocab:inputTo TimeseriesReportingModel
]

instance RealTimeProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Hardware acceleration on Jetson Orin Nano for real-time processing"
]

instance ROS2MessageFormattingEnabler : DTDFVocab:Enabler [
    base:desc "Standardized ROS2 message types for rendering and data exchange"
    DTDFVocab:inputTo EgoVehicle3DModel, Environment3DModel
]

instance 3DVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D Visualization Feature Engine using standardized formats for rendering"
    DTDFVocab:inputTo RealTimeMonitoringService
]

// C17: Insights/Actions
instance PerformanceInsights : DTDFVocab:Insight [
    base:desc "Real-time monitoring of ACC system metrics (following distance, speed deviations)"
]

instance PredictiveAnalytics : DTDFVocab:Insight [
    base:desc "Data collection/reporting enables troubleshooting (motor/servo health) and optimization (fuel economy improvements)"
]

instance MotorHealthInsights : DTDFVocab:Insight [
    base:desc "Troubleshooting of motor/servo health via data collection/reporting"
]

instance FuelEconomyOptimization : DTDFVocab:Insight [
    base:desc "Optimization of fuel economy improvements via data analysis"
]

instance EmergencyBrakingCommand : DTDFVocab:Action [
    base:desc "Emergency braking commands transmitted from Control Panel UI to physical twin"
    DTDFVocab:IsAutomatic false
]

// Feature Engines
instance PointCloudClusteringFE : DTDFVocab:FeatureEngine [
    base:desc "Point Cloud Clustering Feature Engine using DBSCAN algorithm for object detection"
    DTDFVocab:inputTo ROS2NodeImplementationEnabler, MATLABSimulinkEnabler
    DTDFVocab:outputTo ObjectTrackData
]

instance KalmanFilterTrackingFE : DTDFVocab:FeatureEngine [
    base:desc "Kalman Filter Tracking Feature Engine for object tracking using Kalman filters"
    DTDFVocab:inputTo ROS2NodeImplementationEnabler, MATLABSimulinkEnabler
    DTDFVocab:outputTo ProcessedObjectTrackData
]

instance MotorActuationFE : DTDFVocab:FeatureEngine [
    base:desc "Motor Actuation Feature Engine that converts speed commands to motor voltage commands"
    DTDFVocab:inputTo ROS2NodeImplementationEnabler, RealTimeProcessingEnabler
    DTDFVocab:outputTo AdaptiveCruiseControlMotorActuator
]

instance SteeringServoActuationFE : DTDFVocab:FeatureEngine [
    base:desc "Steering Servo Actuation Feature Engine for real-time steering adjustments"
    DTDFVocab:inputTo ROS2NodeImplementationEnabler, RealTimeProcessingEnabler
    DTDFVocab:outputTo SteeringServoActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT transmits control commands to the physical twin via Wi-Fi network (UDP-based) to execute ACC functionality: (1) **Desired speed adjustments** (settable via Control Panel UI); (2) **Emergency braking commands** (triggered remotely); (3) **Actuation FE** converts speed commands into motor voltage signals (via Vedder Speed Controller) and steering commands into servo actuation. The system adheres to ISO 15622 ACC standards for performance class I, ensuring safe following distance maintenance."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates on a **real-time time scale** with the following synchronization requirements: (1) **Data collection and processing rate**: Object tracks and ego vehicle state updated every perception cycle (~10–30 Hz, depending on sensor latency); (2) **End-to-end latency**: ≤100 ms (3GPP V2V communication specification); (3) **Clock synchronization**: Devices synchronized to within ±100 ms (critical for event ordering in distributed systems)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation consists of three primary entities (ISO 23247-based) with custom adaptations: (1) **Physical Twin Entity**: Hosts sensor processing (Point Cloud Clustering & Tracking FE, Data Pre-Processing FE) and actuation (Actuation FE) on the vehicle’s hardware; (2) **Digital Twin Entity**: Manages data collection (Data Collecting FE), reporting (Reporting FE), and ACC control logic (Controlling FE) on external servers/cloud; (3) **User Entity**: Provides 3D Visualization (User Interface FE) and Control Panel (User Interface FE) for remote management. The **Data Translation FE** bridges inter-entity communication via Wi-Fi/UDP."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the following lifecycle stages: (1) **Design Phase**: Used as a cyber-physical experimentation platform for ACC system validation (simulated 3D CAD integration); (2) **Manufacturing Phase**: Not directly applicable (physical twin is a prototype); (3) **Operational Phase**: Enables real-time monitoring, remote management, and predictive maintenance (e.g., health monitoring of motors/servos). The DT covers the **operated** representation phase of the physical twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through: (1) **Verification**: ISO 15622 ACC performance class I validation; (2) **Validation**: Real-time latency testing (3GPP 22.185), clock synchronization accuracy (±100 ms), and sensor calibration (LiDAR/depth camera); (3) **Uncertainty Management**: DBSCAN/Kalman filter for object tracking reduces noise in sensor data; (4) **Error Handling**: Data Translation FE handles unit conversions and message alignment to prevent compatibility issues. The DT’s validity is validated during operational phase (remote management, emergency braking testing)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT employs the following technical connections: (1) **Internal Communication**: ROS2-based inter-component communication (ROS2 network); (2) **Inter-Entity Communication**: Wi-Fi (UDP) for low-latency data transfer between entities (≤100 ms end-to-end latency); (3) **Network Protocols**: Data Translation FE serializes/aligns messages using standardized ROS2 message types; (4) **Hardware Synchronization**: NTP-based clock synchronization (±100 ms accuracy) for distributed systems."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed across two hardware tiers: (1) **Onboard Hardware**: NVIDIA Jetson Orin Nano (real-time processing for ACC control, sensor fusion); (2) **External Hosting**: Cloud/edge servers for data storage (SQL databases), reporting, and visualization. The Digital Twin Entity and User Entity are hosted externally to offload computational burden from the vehicle’s ECU."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT integrates horizontally with external systems via: (1) **Vehicle-to-Vehicle (V2V) Communication**: Wi-Fi-based data exchange with other autonomous vehicles (e.g., lead vehicle tracking); (2) **Data Storage Systems**: SQL databases for historical reporting (e.g., timeseries data of vehicle state); (3) **CAD/Simulation Tools**: 3D CAD representations for design validation (e.g., ACC path planning). No explicit integration with other DTs is mentioned."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership is transferred to external storage devices (cloud/edge) for offloaded data, ensuring resource constraints are met. Privacy considerations are not explicitly addressed in the documents, though the system emphasizes real-time monitoring and remote management without explicit security protocols. Data traceability is implied through SQL-based storage and ROS2 logging mechanisms."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT adheres to the following standards: (1) **ISO 23247**: Reference architecture for DTs (adapted for automotive); (2) **ISO 15622**: Adaptive Cruise Control performance requirements (class I); (3) **3GPP 22.185**: V2V communication latency specifications; (4) **ROS2**: Middleware for inter-component communication; (5) **OPC UA/IEC 62541**: Potential for Data Translation FE (not explicitly implemented but referenced in ISO 23247)."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety are addressed through:
  1. **Safety**:
     - Latency constraints (<100ms) ensure real-time responsiveness for critical control commands (e.g., emergency braking).
     - Human-in-the-Loop autonomy with explicit safety validation (Fully Autonomous Digital Twin with Human-in-the-Loop).
     - Control logic adheres to ISO 15622 for ACC performance class I.
  2. **Security**:
     - No explicit mention of user authentication, encryption, or hardware isolation for security.
     - Clock synchronization (±100ms) ensures event ordering but does not explicitly address cybersecurity risks.
     - Remote operation is validated via the Control Panel UI, but no details on remote operation validation protocols are provided."
]