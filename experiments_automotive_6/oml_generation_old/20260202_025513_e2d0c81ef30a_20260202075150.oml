// Physical sensing components
instance HokuyoUST10LxLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR sensor providing point cloud data for object detection."
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance IntelD435iDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera providing RGB-D images for scene perception."
    DTDFVocab:producedData DepthImageDataTransmitted
]

instance WheelEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel encoder providing vehicle rotation speed for ego vehicle state estimation."
    DTDFVocab:producedData WheelEncoderDataTransmitted
]

instance IMUSensor : DTDFVocab:SensingComponent [
    base:desc "Inertial Measurement Unit providing orientation and acceleration data for vehicle state."
    DTDFVocab:producedData IMUDataTransmitted
]

instance ProximityDetectionSensor : DTDFVocab:SensingComponent [
    base:desc "Proximity sensor providing distance measurements for object detection."
    DTDFVocab:producedData ProximityDataTransmitted
]

// Physical-to-virtual interaction
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LxLiDARSensor
]

instance DepthImageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCameraSensor
]

instance VehicleStateVectorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelEncoderSensor, IMUSensor
]

instance WheelEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelEncoderSensor
]

instance IMUDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IMUSensor
]

instance ProximityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProximityDetectionSensor
]

// Data instances
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data transmitted over ROS2 DDS."
    DTDFVocab:inputTo LiDARProcessingEnabler
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image data from Intel D435i sensor."
    DTDFVocab:inputTo LiDARProcessingEnabler
    DTDFVocab:fromData DepthImageDataTransmitted
]

instance VehicleStateVectorData : DTDFVocab:Data [
    base:desc "Vehicle state vector including speed and steering angle derived from wheel encoder and IMU."
    DTDFVocab:inputTo ACCControlEnabler
    DTDFVocab:fromData VehicleStateVectorDataTransmitted
]

instance WheelEncoderData : DTDFVocab:Data [
    base:desc "Wheel encoder rotation count data."
    DTDFVocab:inputTo ACCControlEnabler
    DTDFVocab:fromData WheelEncoderDataTransmitted
]

instance IMUData : DTDFVocab:Data [
    base:desc "IMU orientation and acceleration data."
    DTDFVocab:inputTo ACCControlEnabler
    DTDFVocab:fromData IMUDataTransmitted
]

instance ProximityData : DTDFVocab:Data [
    base:desc "Proximity sensor distance measurements."
    DTDFVocab:inputTo LiDARProcessingEnabler
    DTDFVocab:fromData ProximityDataTransmitted
]

// Models
instance DBSCANModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm applied to LiDAR point cloud for obstacle segmentation."
    DTDFVocab:inputTo LiDARProcessingEnabler
]

instance KalmanFilterModel : DTDFVocab:Model [
    base:desc "Kalman filter for smooth object tracking based on cluster centroids."
    DTDFVocab:inputTo ObjectTrackingEnabler
]

instance ACCControlLawModel : DTDFVocab:Model [
    base:desc "ACC control law compliant with ISO 15622, generating cruise control commands."
    DTDFVocab:inputTo ACCControlEnabler
]

// Enablers
instance LiDARProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler executing LiDAR clustering using DBSCAN and preparing data for tracking."
    DTDFVocab:enables LiDARClusteringService
]

instance ObjectTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler executing Kalman filter for object state estimation."
    DTDFVocab:enables ObjectTrackingService
]

instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler executing ACC control law using vehicle state data."
    DTDFVocab:enables ACCControlService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Enabler storing trajectory and sensor data into an SQL database."
    DTDFVocab:enables DataStorageService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler preparing 3D meshes and visualization for remote operator."
    DTDFVocab:enables VisualizationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler running Simulink/Python scripts for complex signal processing and scenario simulation."
    DTDFVocab:enables SimulationService
]

// Services
instance LiDARClusteringService : DTDFVocab:Service [
    base:desc "Service that clusters LiDAR point clouds and updates object candidates."
    DTDFVocab:provides LiDARClusterInsight
]

instance ObjectTrackingService : DTDFVocab:Service [
    base:desc "Service that fuses clustered data with Kalman filter to produce refined object tracks."
    DTDFVocab:provides ObjectTracksInsight
]

instance ACCControlService : DTDFVocab:Service [
    base:desc "Service that applies ACC adjustments and emergency braking based on vehicle state."
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakeAction, ACCParameterTuningAction
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Service that archives sensor streams and vehicle state into a relational database."
    DTDFVocab:provides StoreDataAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that renders 3D visualizations of vehicle, tracks, and projected path."
    DTDFVocab:provides VisualizeSceneAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs Simulink/Python simulations and generates prediction insights."
    DTDFVocab:provides SimulationPredictionInsight
]

// Insights
instance RealTimeReportingInsight : DTDFVocab:Insight [
    base:desc "Real‑time reporting of vehicle state and object tracks enabling operator decisions."
]

instance LiDARClusterInsight : DTDFVocab:Insight [
    base:desc "Insight into clustered obstacles derived from LiDAR data."
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Insight into tracked object states used for ACC decision making."
]

instance SimulationPredictionInsight : DTDFVocab:Insight [
    base:desc "Simulation predictions of vehicle dynamics and environment for scenario analysis."
]

// Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Command to enable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Command to disable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to adjust desired speed setpoint for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to trigger emergency braking."
    DTDFVocab:IsAutomatic true
]

instance ACCParameterTuningAction : DTDFVocab:Action [
    base:desc "Action to fine‑tune ACC parameters based on maintenance data."
    DTDFVocab:IsAutomatic false
]

instance VisualizeSceneAction : DTDFVocab:Action [
    base:desc "Action to render a 3‑D visualization of vehicle and tracked objects."
    DTDFVocab:IsAutomatic true
]

instance StoreDataAction : DTDFVocab:Action [
    base:desc "Action to command storage of sensor and vehicle state data."
    DTDFVocab:IsAutomatic true
]

// Acting components
instance ElectricMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Electric motor actuator controlled by the Digital Twin to drive the vehicle."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator controlled by the Digital Twin to adjust vehicle steering."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin computes desired speed and emergency braking signals (ACC control law from ISO 15622) and sends these actuation commands back to the vehicle’s motor and brake actuators via the Data Collection and Device Control Entity over ROS 2 on Wi‑Fi"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "End‑to‑end network latency constrained to ≤100 ms, clock synchronization accuracy of ≤100 ms; ACC loop operates at vehicle perception update rate (~10–20 Hz), with DT processing performed in near real‑time"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "ISO 23247 reference architecture: Data Translation FE (cross‑system), Physical Twin Entity FE (Point Cloud clustering, Actuation), Digital Twin Entity FE (Data Collection, Reporting, ACC controlling), User Entity FE (3‑D visualization, Control panel); intra‑entity ROS 2 communication, inter‑entity Wi‑Fi transport, composition of SW components per service"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design/prototyping (requirement elicitation and architecture mapping), Deployment/operation (real‑time ACC execution on the physical twin), Evaluation (performance assessment of safety‑critical latency), Maintenance/modification (future upgrades such as enhanced safety features and higher clock precision)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time fidelity maintained via ≤100 ms end‑to‑end latency and 100 ms clock sync; validation through comparison of DT‑generated desired speed and tracks against vehicle telemetry; visualization aids human sanity checking; no explicit statistical uncertainty quantification reported"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication over Wi‑Fi using ROS 2 DDS (UDP/TCP transport), intra‑entity ROS 2 nodes communicate via local DDS domain; Data Translation FE handles serialization, unit conversion, and message type alignment; network protocols include ROS 2, DDS, and underlying TCP/UDP stacks"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital Twin services run on an edge or cloud server; Physical Twin Entity operates on the vehicle’s Jetson Orin Nano; User Entity runs on a remote workstation; deployment spans local edge and remote cloud networks connected via Wi‑Fi"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture adopted, ACC control law per ISO 15622, terminology per ISO 30173, ROS 2 middleware, optional OPC UA for data translation"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical real‑time constraints (≤100 ms latency), remote actuation necessitates secure communication; however specific cybersecurity mechanisms are not detailed in the document"
]