// ----------------------------------------------------------
// Sensing Components
// ----------------------------------------------------------
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor that generates raw point‑cloud data for the 1/10‑scale autonomous vehicle."
    DTDFVocab:producedData LiDARRawPointCloud
]

instance MotorSpeedEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor speed encoder providing vehicle propulsion speed measurements."
    DTDFVocab:producedData MotorSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor reporting vehicle heading."
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// ----------------------------------------------------------
// Data Transmitted (raw streams)
// ----------------------------------------------------------
instance LiDARRawPointCloud : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
    base:desc "Raw point‑cloud data stream emitted by the LiDAR sensor."
]

instance MotorSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSpeedEncoderSensor
    base:desc "Timestamped motor speed data stream."
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
    base:desc "Timestamped steering angle data stream."
]

// ----------------------------------------------------------
// Data (processed / ready for use)
// ----------------------------------------------------------
instance LiDARRawData : DTDFVocab:Data [
    base:desc "Raw point‑cloud data used as input to clustering and tracking."
    DTDFVocab:fromData LiDARRawPointCloud
    DTDFVocab:inputTo PointCloudClusteringTrackingModel, DataTranslationFE
]

instance MotorSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed data used by the ACC control logic."
    DTDFVocab:fromData MotorSpeedDataTransmitted
    DTDFVocab:inputTo ACCControlModel, DataTranslationFE
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle data used by the ACC control logic."
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo ACCControlModel, DataTranslationFE
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Processed object tracks resulting from DBSCAN clustering and Kalman filtering of LiDAR data."
    DTDFVocab:fromData LiDARRawPointCloud
    DTDFVocab:inputTo ACCControlModel, DataTranslationFE
]

instance ACCSpeedCommandTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ACCControlModel
    base:desc "Speed command data emitted by the ACC model."
]

instance ACCSpeedCommandData : DTDFVocab:Data [
    base:desc "Speed command sent to the motor actuator."
    DTDFVocab:fromData ACCSpeedCommandTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

// ----------------------------------------------------------
// Models
// ----------------------------------------------------------
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Geometric perception model that clusters raw LiDAR point clouds using DBSCAN and tracks objects with a Kalman filter."
    DTDFVocab:inputTo DataTranslationFE
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Behavioral ACC model that uses vehicle speed, steering angle, and object tracks to compute a desired speed command."
    DTDFVocab:inputTo DataTranslationFE
]

// ----------------------------------------------------------
// Enablers
// ----------------------------------------------------------
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Data Translation functional entity (ISO 23247) that serialises messages, aligns types and performs unit conversions for every data stream."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

// ----------------------------------------------------------
// Services
// ----------------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service that visualises real‑time vehicle state, projected path and object tracks, and supports data saving and reporting."
    DTDFVocab:provides RealTimeVehicleStateInsight, DecisionSupportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service that offloads the ACC algorithm to the cloud, receives sensor data, computes the desired speed, and returns the speed command."
    DTDFVocab:provides ComputeACCSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service that lets operators enable/disable ACC, set desired speed, and issue emergency brake via the UI control panel."
    DTDFVocab:provides SetDesiredSpeedAction, EnableACCAction, DisableACCAction, EmergencyBrakeAction
]

// ----------------------------------------------------------
// Insights
// ----------------------------------------------------------
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight that shows real‑time vehicle state, projected driving path and object tracks on the 3D visualization UI."
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Insight that supports operator decision making by allowing monitoring and direct intervention via the control panel."
]

// ----------------------------------------------------------
// Actions
// ----------------------------------------------------------
instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets the desired cruising speed for the ACC controller."
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator enables the Adaptive Cruise Control functionality."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator disables the Adaptive Cruise Control functionality."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers an emergency brake, immediately stopping the vehicle."
    DTDFVocab:IsAutomatic false
]

instance ComputeACCSpeedAction : DTDFVocab:Action [
    base:desc "Automatic ACC computation that determines the speed command based on sensor inputs."
    DTDFVocab:IsAutomatic true
]

// ----------------------------------------------------------
// Acting Components (Physical Twin)
// ----------------------------------------------------------
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Motor actuator that drives the vehicle propulsion based on speed set‑points."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo that adjusts vehicle heading according to steering commands."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin runs the ACC Controlling FE, which identifies the lead vehicle and computes a desired speed. The computed speed is transmitted back to the vehicle where the Actuation FE converts the speed command into motor voltage signals to drive the vehicle. Remote‑management commands issued from the User Interface FE (control panel) – enable/disable ACC, set desired speed, emergency brake – are also sent to the Actuation FE. Commands travel over the same Wi‑Fi/UDP link and are packaged by the Data Translation FE. Validation, authentication and conflict‑resolution mechanisms are not described in the provided documents, nor is an explicit acknowledgement of command execution; the system relies on actuation feedback displayed in the UI."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DTS requires a shared notion of time among devices with a clock synchronization accuracy of 100 ms (the maximum tolerated error due to hardware limits). All services—data monitoring, computation offloading, and remote management—depend on low end‑to‑end latency communication, realized through ROS 2 intra‑process messaging and inter‑entity UDP over Wi‑Fi, though explicit latency bounds beyond the 100 ms sync are not specified."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DTS follows the ISO 23247 reference architecture adapted for automotive use: a three‑entity constellation (Physical Twin, Digital Twin, User) with functional entities implemented as ROS 2 packages. Intra‑entity communication uses ROS 2 topics/services; inter‑entity communication uses UDP over Wi‑Fi. The Data Translation FE serializes, aligns, and unit‑converts all streams. Computation offloading moves the ACC control logic to a cloud resource, while actuation remains on the physical vehicle. Resource management is realized by mapping each functional entity to dedicated ROS 2 nodes running on the appropriate hardware component."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system uses a hybrid network architecture. Within each entity (Physical Twin, Digital Twin, User) software components are packaged as ROS 2 nodes and communicate via a ROS 2 DDS‑based network. Inter‑entity communication (e.g., between Physical Twin Entity and Digital Twin Entity) is carried out over a Wi‑Fi network using UDP at the transport layer. The DT must support low end‑to‑end latency to satisfy ACC requirements, and clock synchronization between devices is required with an accuracy of 100 ms (limited by hardware). No explicit bandwidth, redundancy, or security protocol (e.g., TLS) is mentioned in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin services are implemented as ROS 2 packages that can be deployed on external compute resources; the paper refers to off‑loading the ACC computation to the DT, suggesting cloud or edge execution, though the exact hosting platform is not detailed. Data collected (object tracks, vehicle state) are stored in an external SQL database (Data Storage FE). Computational requirements include the ACC Controlling FE, point‑cloud processing, and visualization, but quantitative CPU, memory or storage specifications are not provided. Scalability mechanisms, deployment models (cloud, edge, on‑premise) and availability/redundancy strategies are not described in the supplied material."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved via ROS 2 middleware for internal data flow and UDP/Wi‑Fi links for external vehicle‑DT communication. Although the implementation uses ROS 2, the architecture references IEC 62541 (OPC UA) as an alternative for the Data Translation FE, indicating potential interoperability with OPC‑UA‑enabled enterprise systems. Cloud resources are employed for computation offloading, enabling horizontal scaling beyond the on‑board ECUs."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built according to the ISO 23247 Digital Twin Manufacturing Framework, using its entity‑based reference architecture (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity). Safety considerations are aligned with ISO 26262, as recommended for automotive DTs. Communication and data translation may employ OPC UA (IEC 62541) as mentioned for the Data Translation FE. The implementation leverages ROS 2, which is compatible with AUTOSAR concepts for hardware‑agnostic software components."
]