// C3: Physical Sensing Components
instance LiDARHokuyoUST10LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST10LX LiDAR capturing 3‑D point clouds via ROS2"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance DepthCameraIntelDeepsenseD435i : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera providing RGB‑D streams via ROS2"
    DTDFVocab:producedData DepthPointCloudTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board vehicle speed sensor connected to Jetson Orin Nano through ROS2"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor integrated on chassis and publishing ROS2 topic"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// C3: Physical Acting Components
instance MotorSpeedActuatorVedderESC : DTDFVocab:ActingComponent [
    base:desc "Vedder electronic speed controller translating command voltages to motor speed"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Integrated steering servo receiving motor voltage signals from Jetson Orin Nano"
]

instance JetsonOrinNanoActuationProcessor : DTDFVocab:ActingComponent [
    base:desc "NVIDIA Jetson Orin Nano executing actuation commands via ROS2 nodes"
]

// C4: Data Transmitted (Physical - Virtual)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARHokuyoUST10LX
]

instance DepthPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DepthCameraIntelDeepsenseD435i
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C10: Models/Data
instance LiDARPointCloud : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data transmitted from sensor"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo MatlabSimulinkClusteringEnabler
]

instance DepthPointCloud : DTDFVocab:Data [
    base:desc "Raw depth point cloud data transmitted from camera"
    DTDFVocab:fromData DepthPointCloudTransmitted
    DTDFVocab:inputTo MatlabSimulinkClusteringEnabler
]

instance VehicleSpeed : DTDFVocab:Data [
    base:desc "Vehicle speed measurements transmitted from speed sensor"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo CppRos2NodeLifecycleEnabler
]

instance SteeringAngle : DTDFVocab:Data [
    base:desc "Steering angle measurements transmitted from steering sensor"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo CppRos2NodeLifecycleEnabler
]

instance ObjectTrack : DTDFVocab:Data [
    base:desc "Object tracks produced by Kalman filter from LiDAR clustering"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo CppRos2NodeLifecycleEnabler
]

instance AccPerformanceReport : DTDFVocab:Data [
    base:desc "ACC performance report including speed, fuel consumption, trajectory"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo DataStorageService
]

instance SqlLogEntry : DTDFVocab:Data [
    base:desc "SQL database log entry capturing telemetry and events"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataStorageService
]

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering model for point cloud segmentation in MATLAB"
    DTDFVocab:inputTo MatlabSimulinkClusteringEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking model for object tracks in MATLAB"
    DTDFVocab:inputTo MatlabSimulinkClusteringEnabler
]

instance ACCControllerModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control controller implementing ISO 15622 performance class I in ROS2 C++"
    DTDFVocab:inputTo CppRos2NodeLifecycleEnabler
]

instance PoseStateModel : DTDFVocab:Model [
    base:desc "Vehicle pose and state model for dynamics prediction in Python 3.8"
    DTDFVocab:inputTo Python3RapidPrototypingEnabler
]

// C11: Enablers (tooling & enablers)
instance Ros2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware enabling inter‑entity communication"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, Visualization3DService, DataStorageService
]

instance Python3RapidPrototypingEnabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 rapid prototyping environment"
    DTDFVocab:enables DataMonitoringService
]

instance CppRos2NodeLifecycleEnabler : DTDFVocab:Enabler [
    base:desc "C++ ROS2 node lifecycle management for real‑time controllers"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance MatlabSimulinkClusteringEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink tooling for point‑cloud clustering and tracking"
    DTDFVocab:enables DataMonitoringService
]

instance NvidiaJetpackSDKEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK for GPU acceleration on Jetson Orin Nano"
    DTDFVocab:enables DataMonitoringService
]

instance GitHubSourceControlEnabler : DTDFVocab:Enabler [
    base:desc "GitHub hosted source code management and CI/CD"
    DTDFVocab:enables DataMonitoringService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time data monitoring service providing vehicle state and object tracks"
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTrackInsight, ProjectionPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation offloading service running ACC logic on external compute"
    DTDFVocab:provides AccPerformanceReportInsight, PerformanceReportInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management service enabling operator control of ACC and vehicle actuation"
    DTDFVocab:provides RemoteACCParameterAdjustmentAction, SetDesiredSpeedAction, EmergencyBrakeAction, ToggleACCAction
]

instance Visualization3DService : DTDFVocab:Service [
    base:desc "3‑D visualization service rendering vehicle state and environment"
    DTDFVocab:provides Visualization3DInsight
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Data storage and report generation service using SQL database"
    DTDFVocab:provides PerformanceReportInsight
]

// C17: Insights / Actions
instance PerformanceReportInsight : DTDFVocab:Insight [
    base:desc "Comprehensive performance report including speed, fuel, and trajectory"
]

instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time vehicle state UI showing speed, steering, and projected path"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Visualized object tracks on the live video feed"
]

instance ProjectionPathInsight : DTDFVocab:Insight [
    base:desc "Projected vehicle path displayed in the UI"
]

instance Visualization3DInsight : DTDFVocab:Insight [
    base:desc "3‑D visual representation of the vehicle and surrounding environment"
]

instance AccPerformanceReportInsight : DTDFVocab:Insight [
    base:desc "ACC performance report including speed, fuel consumption, trajectory"
]

instance RemoteACCParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjust ACC parameters in real‑time via remote UI"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets desired cruising speed for ADAS"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Trigger emergency braking through MDT"
    DTDFVocab:IsAutomatic false
]

instance ToggleACCAction : DTDFVocab:Action [
    base:desc "Toggle ACC on/off remotely"
    DTDFVocab:IsAutomatic false
]

// Environments
instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:contains LiDARHokuyoUST10LX, DepthCameraIntelDeepsenseD435i, VehicleSpeedSensor, SteeringAngleSensor, MotorSpeedActuatorVedderESC, SteeringServoActuator, JetsonOrinNanoActuationProcessor
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains DataMonitoringService, ComputationOffloadingService, RemoteManagementService, Visualization3DService, DataStorageService
]

instance CrossSystemEnvironment : DTDFVocab:Environment [
    base:contains Ros2MiddlewareEnabler, Python3RapidPrototypingEnabler, CppRos2NodeLifecycleEnabler, MatlabSimulinkClusteringEnabler, NvidiaJetpackSDKEnabler, GitHubSourceControlEnabler
]

instance UserEnvironment : DTDFVocab:Environment [
    base:contains RealTimeVehicleStateInsight, ObjectTrackInsight, Visualization3DInsight
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Desired speed and steering set‑points generated by the ACC controller in the Digital Twin Entity are converted to motor voltage commands by the Actuation FE and transmitted over Wi‑Fi to the Vedder ESC and steering servo; emergency braking commands and ACC enable/disable signals are also sent from the User Entity to the Physical Twin Entity."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Operations performed in real‑time with end‑to‑end latency ≤ 100 ms, clocks synchronized to within 100 ms, and vehicle state updated at each perception cycle (≈ 10 Hz)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation follows ISO 23247’s entity‑based RA: the Physical Twin Entity subsumes sensor/actuator interfaces, the Digital Twin Entity hosts simulation and control FEs, the User Entity hosts the 3‑D visualization and control panel, and the Cross‑System Entity mediates data translation; all are connected via ROS 2 topics over Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle spans the design stage (simulation and validation of ACC logic using the ROS 2/SIMULINK models), the validation stage (online evaluation of ACC performance during field trials), and the operational stage (ongoing monitoring, remote management, and data logging during vehicle operation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity ensured by real‑time data acquisition, DBSCAN + Kalman‑filter tracking, and compliance with ISO 15622 ACC rules; validity verified through field‑trial latency tests (≤ 100 ms) and ACC performance against vehicle trajectory; uncertainty managed by timestamp synchronization and 100 ms clock alignment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication occurs over a standard Wi‑Fi network using ROS 2 DDS transport; the Data Translation FE serializes messages, performs unit conversions, and aligns timestamps; the Physical Twin Entity communicates over the vehicle’s Ethernet/Serial optical network to the Jetson."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hybrid deployment: on‑board Jetson Orin Nano handles sensor data ingestion and actuation, an off‑board host (cloud or local server) runs the Digital Twin Entity FEs (ACC controller, visualization), and a SQL database server stores logs; the system runs ROS 2 nodes across vehicle and host hardware, using NVIDIA Jetpack 5.0 on the Edge device."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture and standard, ISO 15622 for ACC, ROS 2 middleware, OPC UA for data translation where applied, and NVIDIA JetPack SDK."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety compliance through ISO 15622 ACC spec and real‑time latency ≤ 100 ms; mechanical safety via actuators controlled only by Digital Twin Entity; no explicit cybersecurity mechanisms described, but all wireless communication is encapsulated in ROS 2 DDS which supports encryption if configured."
]