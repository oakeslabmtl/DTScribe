// ---------- C3: Physical sensing components ----------
instance HokuyoUST10LXLidarSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2‑D LiDAR, max range 10 m, 40 Hz scan rate, publishes planar range scans as point‑cloud data"
    DTDFVocab:producedData LiDARRawDataTransmitted
]

instance IntelRealSenseD435iDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera (RGB‑D), up‑to 30 Hz, provides dense 3‑D point clouds"
    DTDFVocab:producedData DepthCameraRawDataTransmitted
]

instance VehicleMotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board ECU sensor reporting motor speed, torque and health status"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

instance SteeringServoSignalSensor : DTDFVocab:SensingComponent [
    base:desc "Steering servo feedback sensor delivering PWM signal representing wheel angle"
    DTDFVocab:producedData SteeringSignalDataTransmitted
]

// ---------- C4: Data transmitted from sensors ----------
instance LiDARRawDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidarSensor
]

instance DepthCameraRawDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCameraSensor
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleMotorStatusSensor
]

instance SteeringSignalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSignalSensor
]

// ---------- C10: Raw data instances ----------
instance LiDARRawPointCloudData : DTDFVocab:Data [
    base:desc "Raw planar point‑cloud stream from LiDAR sensor"
    DTDFVocab:fromData LiDARRawDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler, DataTranslationEnabler, GPUAcceleratedComputeEnabler
]

instance DepthCameraRawPointCloudData : DTDFVocab:Data [
    base:desc "Dense 3‑D point‑cloud frames from depth camera"
    DTDFVocab:fromData DepthCameraRawDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler, DataTranslationEnabler
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Vehicle motor status (speed, torque, temperature) values"
    DTDFVocab:fromData MotorStatusDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler, DataTranslationEnabler
]

instance SteeringSignalData : DTDFVocab:Data [
    base:desc "Steering servo PWM feedback representing current wheel angle"
    DTDFVocab:fromData SteeringSignalDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler, DataTranslationEnabler
]

// ---------- C10: Models ----------
instance PointCloudClusteringAndTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point clouds followed by Kalman‑filter tracking of object clusters"
    DTDFVocab:inputTo GPUAcceleratedComputeEnabler
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "ACC control‑logic consumes tracked object data to compute desired speed and spacing"
    DTDFVocab:inputTo GPUAcceleratedComputeEnabler
]

// ---------- C11: Enablers ----------
instance UDPWiFiLinkEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi UDP transport layer linking the physical twin to the digital twin"
    DTDFVocab:enables RemoteManagementService
]

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware handling ROS topics and message distribution within the DT"
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data‑Translation functional entity serialises streams, aligns message types and performs unit conversions"
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService
]

instance GPUAcceleratedComputeEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 GPU‑accelerated compute used for clustering/tracking and ACC off‑loading"
    DTDFVocab:enables ComputationOffloadingService
]

instance DatabaseStorageEnabler : DTDFVocab:Enabler [
    base:desc "Relational SQL database storing logged vehicle data for monitoring UI and reporting"
    DTDFVocab:enables DataMonitoringService
]

// ---------- C6: Services ----------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Displays real‑time vehicle state, projected driving path and nearby object tracks allows view, save and report generation"
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTracksInsight, ProjectedDrivingPathInsight, ReportGenerationAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Migrates ACC algorithm to the cloud, processes sensor data and returns desired speed for actuation"
    DTDFVocab:provides ACCDesiredSpeedInsight, ACCControlAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to enable/disable ACC, set target speed and issue emergency braking via low‑latency link"
    DTDFVocab:provides EnableACCAction, DisableACCAction, EmergencyBrakingAction, SetTargetSpeedAction
]

// ---------- C17: Insights ----------
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Live visualization of ego‑vehicle speed, heading and status derived from sensor fusion"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Current tracked objects (position, velocity, confidence) generated by clustering & tracking model"
]

instance ProjectedDrivingPathInsight : DTDFVocab:Insight [
    base:desc "Projected future trajectory of the ego vehicle based on current speed and planned maneuvers"
]

instance ACCDesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Desired speed and head‑way distance computed by the ACC control‑logic"
]

// ---------- C17: Actions ----------
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to activate Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to deactivate Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Safety‑critical command to apply full braking instantly"
    DTDFVocab:IsAutomatic true
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets a new target speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance ReportGenerationAction : DTDFVocab:Action [
    base:desc "Automatic generation of a PDF/CSV report containing logged vehicle data and insights"
    DTDFVocab:IsAutomatic true
]

instance ACCControlAction : DTDFVocab:Action [
    base:desc "Action representing ACC computed speed command sent to the vehicle actuators"
    DTDFVocab:IsAutomatic true
]

// ---------- C2: Acting components ----------
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller driving the vehicle motor, receives voltage commands from DT"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Servo motor that adjusts wheel angle, receives PWM setpoints from DT"
]

// ---------- C5: Environments ----------
instance LaboratoryTestEnvironment : DTDFVocab:Environment [
    base:contains HokuyoUST10LXLidarSensor, IntelRealSenseD435iDepthCameraSensor,
                 VehicleMotorStatusSensor, SteeringServoSignalSensor,
                 VedderElectronicSpeedController, SteeringServoActuator,
                 DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin (desired speed for ACC, ACC enable/disable signals, and emergency‑brake requests) are packaged by the Data Translation component, transmitted over the Wi‑Fi UDP link to the Physical Twin, and received by the vehicle’s actuation front‑ends (motor, steering servo). The DT does not specify additional validation, authentication, or acknowledgment mechanisms; command execution is implied by the actuation front‑ends applying the received values."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system mandates that all participating devices share a common notion of time for computation offloading, requiring clock synchronization accuracy of 100 ms (the limit imposed by hardware). This synchronization level is set to satisfy safety‑critical vehicular application standards that often require stricter than 100 ms alignment."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 reference model: the Physical Twin Entity hosts sensors, actuators and low‑level processing; the Digital Twin Entity provides the digital representation and control logic; the User Entity supplies visualization and control‑panel interfaces. Each Functional Entity is realized as an individual ROS 2 package containing one or more ROS 2 nodes, and the packages are distributed across distinct compute nodes, using ROS 2 middleware for inter‑entity communication and overall system orchestration."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT development follows the ISO 23247 framework, beginning with an architectural design phase where key software components are identified and their relationships to sensors/actuators are defined (Fig. 2, Tab. I). The identified components are then mapped onto Functional Entities (FEs) and each FE is realized as an individual ROS 2 package containing one or more ROS 2 nodes. After implementation, the packages are deployed on separate hardware units that correspond to the three ISO entities (User Entity, Digital Twin Entity, Physical Twin Entity). The lifecycle therefore consists of design → FE mapping → ROS 2 package implementation → distributed deployment, without explicit governance or transition management steps described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The physical‑digital twin link uses a Wi‑Fi network with UDP transport. Internal communication among digital‑twin software components is handled by a ROS 2 network. The system is required to support low end‑to‑end latency communication, but specific bandwidth, latency thresholds, reliability, redundancy or security mechanisms are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The ACC algorithm is offloaded from the on‑board ECU to external computational resources constituting the digital twin (referred to as the DT system). The documents mention that the offloading can be to “better‑suited equipment, e.g., in the cloud,” implying a cloud or remote edge deployment, but they do not specify exact hosting platforms, storage capacities, scalability or availability mechanisms."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The ISO 23247 standard mentions that integration with external systems can be achieved via protocols such as OPC Unified Architecture (OPC UA). While the present implementation does not specify a concrete external‑system link, the possibility of employing OPC UA for data exchange and interoperability is noted."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is explicitly designed to comply with the ISO 23247 Digital Twin framework for manufacturing, adopting the Part 2 reference architecture with its Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, and User Entity. The implementation respects industry timing standards for safety‑critical vehicular applications that mandate clock synchronization tighter than 100 ms, and the design enforces a 100 ms synchronization accuracy due to hardware constraints. No additional certification or interoperability standards are mentioned."
]