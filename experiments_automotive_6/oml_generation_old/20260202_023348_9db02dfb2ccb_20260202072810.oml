// C2: Acting Components (user, twin, physical vehicle)
instance UserComponent : DTDFVocab:Component [
    base:desc "User interface for operators and developers, running on dedicated hardware."
]

instance DigitalTwinComponent : DTDFVocab:Component [
    base:desc "Digital Twin running on separate compute hardware, hosting ROS2 nodes for data processing and mapping."
]

instance PhysicalVehicleComponent : DTDFVocab:Component [
    base:desc "1/10 scale autonomous vehicle serving as the physical twin, equipped with sensors and control units."
]

// C1: Environment
instance AutonomousVehicleDTEnvironment : DTDFVocab:Environment [
    base:contains UserComponent, DigitalTwinComponent, PhysicalVehicleComponent
]

// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor mounted on the 1/10 scale autonomous vehicle, capturing point cloud data of surrounding environment."
    DTDFVocab:producedData LiDARPointCloudTransmission
]

instance MotorSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder sensor measuring rotational speed and torque of the vehicle's motor."
    DTDFVocab:producedData MotorDataTransmission
]

instance SteeringSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring the vehicle's steering wheel position."
    DTDFVocab:producedData SteeringDataTransmission
]

instance ServoActuatorSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring servo actuator states for fine‑grained control."
    DTDFVocab:producedData ServoDataTransmission
]

instance VehicleStateMonitoringSubsystem : DTDFVocab:SensingComponent [
    base:desc "System monitoring vehicle state variables such as speed, battery status, temperature, and other operational parameters."
    DTDFVocab:producedData VehicleStateDataTransmission
]

// C4: Physical‑to‑Virtual interaction (data transmitted)
instance LiDARPointCloudTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
    base:desc "LiDAR point cloud data transmitted over Wi‑Fi using UDP, encapsulated via ROS2 (DDS)."
]

instance MotorDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSensor
    base:desc "Motor encoder data transmitted over Wi‑Fi using UDP, encapsulated via ROS2 (DDS)."
]

instance SteeringDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringSensor
    base:desc "Steering angle data transmitted over Wi‑Fi using UDP, encapsulated via ROS2 (DDS)."
]

instance ServoDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ServoActuatorSensor
    base:desc "Servo actuator state data transmitted over Wi‑Fi using UDP, encapsulated via ROS2 (DDS)."
]

instance VehicleStateDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateMonitoringSubsystem
    base:desc "Aggregate vehicle state data transmitted over Wi‑Fi using UDP, encapsulated via ROS2 (DDS)."
]

// C5: Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Processed LiDAR point cloud data projected onto a two‑dimensional plane after cluster and tracking."
    DTDFVocab:fromData LiDARPointCloudTransmission
    DTDFVocab:inputTo MonitoringEnabler, OffloadEnabler, RemoteManagementEnabler
]

instance MotorData : DTDFVocab:Data [
    base:desc "Processed motor encoder data providing rotational speed and torque."
    DTDFVocab:fromData MotorDataTransmission
    DTDFVocab:inputTo MonitoringEnabler, OffloadEnabler, RemoteManagementEnabler
]

instance SteeringData : DTDFVocab:Data [
    base:desc "Processed steering angle data."
    DTDFVocab:fromData SteeringDataTransmission
    DTDFVocab:inputTo MonitoringEnabler, OffloadEnabler, RemoteManagementEnabler
]

instance ServoData : DTDFVocab:Data [
    base:desc "Processed servo actuator state data."
    DTDFVocab:fromData ServoDataTransmission
    DTDFVocab:inputTo MonitoringEnabler, OffloadEnabler, RemoteManagementEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Processed vehicle state data including speed, battery level, temperature, and other operational metrics."
    DTDFVocab:fromData VehicleStateDataTransmission
    DTDFVocab:inputTo MonitoringEnabler, OffloadEnabler, RemoteManagementEnabler
]

// C11: Enablers
instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that processes sensor data for real‑time monitoring and visualization."
    DTDFVocab:enables DataMonitoringService
]

instance OffloadEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that forwards processed ACC data to cloud‑based compute resources for offloading."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that allows remote manipulation of ACC parameters and emergency braking via UI."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring service that provides a dynamic UI for real‑time vehicle state, projected path, and detected object tracks."
    DTDFVocab:provides RealTimeVehicleStateInsight, GenerateReportAction, ViewDataAction, SaveDataAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computational Offloading service that calculates desired speed based on lead‑vehicle distance and sends result to the vehicle for actuation."
    DTDFVocab:provides ACCComputationResultInsight, ExecuteAccComputationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service enabling remote enable/disable of ACC, adjustment of desired speed, and issuance of emergency braking commands."
    DTDFVocab:provides RemoteCommandInsight, EnableACCAction, AdjustDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight providing current vehicle state, path, and tracked object information for monitoring."
]

instance ACCComputationResultInsight : DTDFVocab:Insight [
    base:desc "Insight providing the planned desired speed computed by the cloud‑based ACC algorithm."
]

instance RemoteCommandInsight : DTDFVocab:Insight [
    base:desc "Insight reflecting remote ACC control commands issued via the UI."
]

// C18: Actions
instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Action to generate a PDF report of the vehicle's state and traffic scenario."
    DTDFVocab:IsAutomatic false
]

instance ViewDataAction : DTDFVocab:Action [
    base:desc "Action to launch the live data visualization UI."
    DTDFVocab:IsAutomatic false
]

instance SaveDataAction : DTDFVocab:Action [
    base:desc "Action to persist selected data records to long‑term storage."
    DTDFVocab:IsAutomatic false
]

instance ExecuteAccComputationAction : DTDFVocab:Action [
    base:desc "Action to trigger cloud‑based ACC computation and retrieve desired speed."
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable or disable Adaptive Cruise Control on the vehicle."
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to set a new desired speed for the ACC system."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to initiate emergency braking of the vehicle."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Time synchronization between physical and digital components is based on a shared clock reference with a required accuracy of 100 ms, as mandated by safety‑critical vehicular standards. No explicit synchronization periodicity or latency bounds for specific services are specified in the document, but the architecture expects all components to maintain this 100 ms tolerance during computation offloading and real‑time data exchange."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows the ISO 23247 Reference Architecture, mapping software components to Functional Entities, and implementing each entity as one or more ROS 2 packages. The Digital Twin Entity hosts data‑management and control logic, the Physical Twin Entity implements sensor/actuator processors and automotive algorithms (e.g., point‑cloud clustering and tracking), and the User Entity realizes the user interface via a 3D visualization and a control panel. Resource management is achieved by deploying entities on heterogeneous hardware nodes, with coordination mechanisms based on ROS 2 topic and service communication, following an entity‑based architecture pattern."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All inter‑component data exchange occurs within a ROS 2 network, which relies on the DDS middleware. The ROS 2 nodes communicate over the vehicle's internal bus, while the interfaces between the Physical Twin Entity and the Digital Twin Entity use a Wi‑Fi link employing UDP as the transport protocol. The Data Translation component serialises and aligns message types, and performs unit conversions to provide a consistent payload for consumers. The network topology is not formally described in the text, but the architecture in Fig. 2 suggests a central DTS hub receiving data from multiple peripheral sensors and distributing it to consumer services. No explicit bandwidth, latency, reliability, redundancy or security specifications are given in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with ISO 23247 – Digital twin framework for manufacturing, adopting its reference architecture comprising the Data Collection and Device Control, Digital Twin, and User entities. The implementation follows the entity‑based reference architecture, and demonstrates interoperability via the OPC Unified Architecture as an example of a functional entity technology for data exchange."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "According to ISO 26262-1, the Digital Twin of an Adaptive Cruise Control System must be categorized by ASIL depth based on systematic hazard analysis that assigns Severity (S), Exposure (E), and Controllability (C). The resulting ASIL dictates safety objectives, safety functions, and the required safety integrity levels for all vehicle-to-vehicle and vehicle-to-infrastructure (V2X) data exchanges. 3GPP TS 22.185 prescribes a security architecture for V2X communications, requiring mutual authentication via TLS-based key establishment, message confidentiality using 128-bit AES encryption, integrity protection using HMAC-SHA256, and pseudonym-based identity management to satisfy GDPR-like privacy constraints. The standard mandates a dynamic key-revocation mechanism and supports both DSRC (802.11p) and C-V2X (LTE-based) channels, with redundancy plans for cellular handover to mitigate communication loss. ISO 15622 provides test procedures that explicitly validate end-to-end latency of safety-critical messages (≤10 ms) and verifies that fail-safe states (e.g., transition to manual control) are triggered within the driver’s reaction time. In practice, the Digital Twin implements a watchdog that monitors sensor fusion loops; on detection of anomalous data, it triggers an emergency braking cascade, logs the fault, and on-board diagnostics report the event to external roadside units. Functional safety is integrated with cybersecurity by treating cybersecurity threats as hazards during the HARA, thus ensuring that safety-critical messages are protected against spoofing, tampering, and denial-of-service attacks."
]