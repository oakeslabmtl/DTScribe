// Sensors
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing full-density point clouds"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera providing RGB‑D frames"
    DTDFVocab:producedData DepthFrameTransmitted
]

instance SpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor (tachometer) feeding speed data"
    DTDFVocab:producedData VehicleSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor feeding steering data"
    DTDFVocab:producedData VehicleSteeringDataTransmitted
]

// Data transmitted from sensors
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthFrameTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]

instance VehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SpeedSensor
]

instance VehicleSteeringDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Data instances produced from transmitted data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "LiDAR point cloud data stream"
    DTDFVocab:inputTo DataTranslationEnabler, VisualizationEnabler
    DTDFVocab:fromData LiDARPointCloudTransmitted
]

instance DepthFrameData : DTDFVocab:Data [
    base:desc "Depth camera RGB‑D frame data"
    DTDFVocab:inputTo DataTranslationEnabler, VisualizationEnabler
    DTDFVocab:fromData DepthFrameTransmitted
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed measurement data"
    DTDFVocab:inputTo DataTranslationEnabler, ACCControlEnabler
    DTDFVocab:fromData VehicleSpeedDataTransmitted
]

instance VehicleSteeringData : DTDFVocab:Data [
    base:desc "Vehicle steering angle measurement data"
    DTDFVocab:inputTo DataTranslationEnabler, ACCControlEnabler
    DTDFVocab:fromData VehicleSteeringDataTransmitted
]

// Models used within the DT
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN‑based point cloud clustering for object extraction"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking model for object tracks"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "ISO 15622 acceleration‑by‑distance ACC controller"
    DTDFVocab:inputTo ACCControlEnabler
]

// Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Cross‑system data translation FE that serializes, unit‑converts and dispatches data to downstream components"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService, VisualizationService
]

instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that feeds vehicle state data to the ACC controller and offloads computation to cloud"
    DTDFVocab:enables ComputationOffloadingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that supplies sensor data to the 3‑D visualization FE"
    DTDFVocab:enables VisualizationService
]

instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that enables UI‑driven remote management commands"
    DTDFVocab:enables RemoteManagementService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Monitors real‑time vehicle state, object tracks, projected path, logs, and generates reports"
    DTDFVocab:provides ACCPerformanceMetricsInsight, VehicleStateSnapshotReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computes ACC algorithm in cloud and sends desired speed commands back to vehicle"
    DTDFVocab:provides SendDesiredSpeedCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI‑driven control of ACC (enable/disable, set desired speed, trigger emergency braking)"
    DTDFVocab:provides ToggleACCAction, AdjustDesiredSpeedAction, TriggerEmergencyBrakeAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3‑D rendering of vehicle and surrounding objects via visualization FE"
    DTDFVocab:provides VehicleSceneVisualizationInsight
]

// Insights
instance ACCPerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Real‑time ACC performance metrics (gap maintenance, speed corrections)"
]

instance VehicleStateSnapshotReportInsight : DTDFVocab:Insight [
    base:desc "Time‑series snapshots of vehicle state and projected path stored in SQL"
]

instance VehicleSceneVisualizationInsight : DTDFVocab:Insight [
    base:desc "3‑D rendering of vehicle and surroundings"
]

// Actions
instance SendDesiredSpeedCommandAction : DTDFVocab:Action [
    base:desc "Desired speed command sent from cloud ACC to vehicle"
    DTDFVocab:IsAutomatic true
]

instance ToggleACCAction : DTDFVocab:Action [
    base:desc "User command to enable or disable ACC"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "User command to alter desired speed"
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "User-triggered emergency braking"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT outputs ACC‑generated desired speed and steering commands via ROS2 topics that are consumed by the Physical Twin Entity’s Actuation FE, which writes voltage commands to the Vedder Electronic Speed Controller and PWM signals to the steering servo; additionally, remote‑management commands such as ACC enable/disable, desired speed setpoint, and emergency‑brake tokens are conveyed in the same manner."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates in real‑time with a maximum end‑to‑end latency of 100 ms (as per ISO 22407 V2, 3GPP 22.185) and clock synchronization accuracy of 100 ms across all participating nodes, ensuring that encounter data and commands are processed within sub‑100 ms cycles typical of ACC perception‑control loops."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT orchestrates its functional entities across a layered RA: the Physical Twin Entity handles sensor acquisition and actuation; the Digital Twin Entity processes data, runs ACC logic and generates reports; the User Entity exposes a 3D visualization and control panel; the Cross‑System Data Translation FE synchronizes message formats; all are distributed as ROS 2 packages over Wi‑Fi and run on a hybrid edge‑to‑cloud topology."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "This Digital Twin behaves as an operational twin during live vehicle runs, providing real‑time monitoring and control. It also supports a developmental phase where data is collected for validation and debugging, as the system is initially prototyped in a 1/10‑scale testbed."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time LiDAR data are processed by DBSCAN and Kalman filtering (validated against ground‑truth tracks in the 1/10‑scale vehicle), the ACC controller follows ISO 15622 specifications for safe deceleration, and end‑to‑end latency is bounded at 100 ms; however, the paper does not detail formal verification, testing procedures, or statistical error bounds for the models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication occurs over Wi‑Fi (IEEE 802.11) using ROS 2’s DDS implementation; the Data Translation FE serializes ROS messages, converts units, and forwards them across the network; timestamps are aligned via NTP with 100 ms accuracy."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Compute is partitioned between the on‑board Jetson Orin Nano (handling sensor acquisition and low‑level actuation) and a remote cloud node that hosts the Digital Twin Entity for ACC processing and data logging; the User Entity runs on a desktop or mobile device with cloud connectivity; all nodes are orchestrated through ROS 2 launch files."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture (with ISO 23247 parts 1‑4) provides the EA, ISO 15622 specifies the ACC control logic, ROS 2 follows the DDS standard (IEEE 1680?); additionally, OPC UA (IEC 62541) is referenced though not used directly; the PT’s sensors comply with industry standards for LiDAR and depth camera."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed for a safety‑critical automotive context, enforcing a maximum 100 ms end‑to‑end latency, synchronizing clocks to 100 ms, and integrating a human‑in‑the‑loop; however, explicit cybersecurity mechanisms (authentication, encryption) are not described in the document."
]