// Physical Sensing Components
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "On-board LiDAR (Hokuyo UST-10LX) generating 3D point cloud data."
    DTDFVocab:producedData ROS2TopicLiDARPointCloud
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera providing depth images."
    DTDFVocab:producedData ROS2TopicDepthImage
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor (wheel encoder) measuring ego speed."
    DTDFVocab:producedData ROS2TopicEgoVehicleState
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring ego steering angle."
    DTDFVocab:producedData ROS2TopicEgoVehicleState
]

// Physical-to-Virtual Interaction: ROS 2 Topics
instance ROS2TopicLiDARPointCloud : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance ROS2TopicDepthImage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

instance ROS2TopicEgoVehicleState : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor, SteeringAngleSensor
]

// Data Entities
instance DataLiDARPointCloud : DTDFVocab:Data [
    base:desc "Temporal point cloud data received from Hokuyo UST-10LX via ROS 2."
    DTDFVocab:inputTo ROS2ServiceEnabler
    DTDFVocab:fromData ROS2TopicLiDARPointCloud
]

instance DataDepthImage : DTDFVocab:Data [
    base:desc "Depth image data received from Intel D435i via ROS 2."
    DTDFVocab:inputTo ROS2ServiceEnabler
    DTDFVocab:fromData ROS2TopicDepthImage
]

instance DataEgoSpeed : DTDFVocab:Data [
    base:desc "Ego speed value derived from VehicleSpeedSensor via ROS 2."
    DTDFVocab:inputTo ROS2ServiceEnabler
    DTDFVocab:fromData ROS2TopicEgoVehicleState
]

instance DataSteeringAngle : DTDFVocab:Data [
    base:desc "Ego steering angle derived from SteeringAngleSensor via ROS 2."
    DTDFVocab:inputTo ROS2ServiceEnabler
    DTDFVocab:fromData ROS2TopicEgoVehicleState
]

// Models
instance ACCControllerModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control controller model compliant with ISO 15622."
    DTDFVocab:inputTo ROS2ServiceEnabler
]

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering model for point cloud segmentation."
    DTDFVocab:inputTo ROS2ServiceEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking model for state estimation."
    DTDFVocab:inputTo ROS2ServiceEnabler
]

// Acting Components
instance VedderESCActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage command via Vedder ESC for speed control."
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Remote emergency braking command routed through actuation FE."
]

// Enablers
instance ROS2ServiceEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware enabling all digital twin services."
    DTDFVocab:enables ServiceDataMonitoring, ServiceComputationalOffloading, ServiceRemoteManagement, ServiceReportGeneration
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation FE serializes and aligns message types before passing to the digital twin."
    DTDFVocab:enables ServiceDataMonitoring, ServiceComputationalOffloading, ServiceRemoteManagement, ServiceReportGeneration
]

// Services
instance ServiceDataMonitoring : DTDFVocab:Service [
    base:desc "Real-time display of speed, steering, tracks, and projected path."
    DTDFVocab:provides InsightVehicleState
]

instance ServiceComputationalOffloading : DTDFVocab:Service [
    base:desc "ACC algorithm executed on cloud, sending desired speed back to vehicle."
    DTDFVocab:provides ActionUpdateDesiredSpeed
]

instance ServiceRemoteManagement : DTDFVocab:Service [
    base:desc "Enable/disable ACC, change desired speed, and trigger emergency braking."
    DTDFVocab:provides ActionEnableACC, ActionDisableACC, ActionChangeDesiredSpeed, ActionTriggerEmergencyBrake
]

instance ServiceReportGeneration : DTDFVocab:Service [
    base:desc "Generate human-readable reports of vehicle state with timestamps."
    DTDFVocab:provides InsightPerformanceReport
]

// Insights
instance InsightVehicleState : DTDFVocab:Insight [
    base:desc "Remote operators receive real-time diagnostics of vehicle dynamics and ACC behavior."
]

instance InsightPerformanceReport : DTDFVocab:Insight [
    base:desc "Human-readable performance report of vehicle state over time."
]

// Actions
instance ActionEnableACC : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance ActionDisableACC : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance ActionChangeDesiredSpeed : DTDFVocab:Action [
    base:desc "Adjust desired speed for Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance ActionTriggerEmergencyBrake : DTDFVocab:Action [
    base:desc "Trigger emergency braking via actuation FE."
    DTDFVocab:IsAutomatic false
]

instance ActionUpdateDesiredSpeed : DTDFVocab:Action [
    base:desc "Update desired speed command from cloud computation."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital twin issues desired speed commands, steering adjustments, emergency braking signals, and ACC enable/disable instructions through the actuation FE; commands are transmitted back to the physical twin over Wi‑Fi using ROS 2 services and topics, then converted to motor voltage or servo signals"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time interactions with low end‑to‑end latency ≤100 ms from vehicle to digital twin; clock synchronization of all components within 100 ms accuracy; data streams updated at each perception cycle (typically 10–20 Hz), ACC decision loop operating at ~60 Hz in cloud"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical Twin Entity on vehicle encapsulating point cloud clustering & tracking FE and actuation FE; Digital Twin Entity on cloud hosting visualization FE, data collection FE, report generation FE, ACC controlling FE; User Entity comprising 3D visualization FE and control panel FE; Cross‑System Entity providing data translation FE for inter‑entity communication; all components orchestrated via ROS 2 over Wi‑Fi"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design and development (requirements R1–R8, case‑based iterative implementation), validation and testing (real‑time performance, latency, safety checks), operation (remote monitoring and management), and maintenance (online updates of ACC parameters, UI features)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Reliance on real sensing data for high fidelity; latency requirement of ≤100 ms ensures temporal validity; clock sync within 100 ms ensures event ordering; verification through requirement compliance (R7 latency, R8 clock sync) and validation via real‑time vehicle testing; no explicit statistical uncertainty metrics reported"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication over Wi‑Fi (802.11ac) with ROS 2 DDS topics; intra‑entity communication via ROS 2 DDS messages; Data Translation FE serializes data in ROS 2 message types, with possible use of JSON or binary payloads; no explicit transport protocols beyond ROS 2 documented"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital Twin Entity deployed on a cloud server (public or private), leveraging NVIDIA JetPack for GPU acceleration; Physical Twin Entity on embedded Jetson Orin/NX; User Entity executed on operator workstation or laptop with 3D rendering; overall three‑tier deployment across vehicle, cloud, and workstation"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture (part 2), ISO 15622 for ACC design, use of ROS 2 conforming to DDS standards, and adherence to automotive IT security guidelines (not explicitly stated)"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical constraints: requirement R6 for ACC implementation, requirement R7 limiting network latency to ≤100 ms, requirement R8 ensuring clock synchronization within 100 ms; no detailed cybersecurity protocols described, but acknowledgment of safety‑critical nature and need for low latency and accurate timekeeping"
]