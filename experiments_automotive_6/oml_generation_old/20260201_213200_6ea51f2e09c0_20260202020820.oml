// C3: Physical sensing components
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor that streams 3D point‑cloud data from the 1/10‑scale vehicle"
    DTDFVocab:producedData LiDARRawDataTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that reports motor status (rpm, torque) of the physical twin"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

instance SteeringServoPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures steering‑servo angular position"
    DTDFVocab:producedData SteeringPositionDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor suite that provides overall vehicle state (speed, pose, battery level)"
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// C4: Physical-to-virtual interaction – transmitted data
instance LiDARRawDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance SteeringPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoPositionSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// C10: Models/Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream received from the physical twin"
    DTDFVocab:fromData LiDARRawDataTransmitted
    DTDFVocab:inputTo DataTranslationModel, PointCloudClusteringTrackingModel
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Motor status telemetry (rpm, torque) transmitted from the vehicle"
    DTDFVocab:fromData MotorStatusDataTransmitted
    DTDFVocab:inputTo DataTranslationModel
]

instance SteeringPositionData : DTDFVocab:Data [
    base:desc "Steering servo angular position telemetry"
    DTDFVocab:fromData SteeringPositionDataTransmitted
    DTDFVocab:inputTo DataTranslationModel
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state telemetry (speed, pose, battery) from the physical twin"
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo DataTranslationModel
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Extracted object tracks generated by point‑cloud clustering & tracking"
    DTDFVocab:inputTo DataStorageEnabler, ROS2MiddlewareEnabler
]

instance DesiredSpeedData : DTDFVocab:Data [
    base:desc "Desired speed value computed by off‑loaded ACC algorithm"
    DTDFVocab:inputTo RemoteControlEnabler, ROS2MiddlewareEnabler
]

instance DataTranslationModel : DTDFVocab:Model [
    base:desc "ISO 23247 Data Translation FE that serialises streams, aligns message types and performs unit conversion"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "ROS2 node implementing point‑cloud clustering and tracking to extract object tracks"
    DTDFVocab:inputTo DataStorageEnabler, ROS2MiddlewareEnabler
]

// C11: Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware network that aggregates DT entities and routes messages"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Software component that stores telemetry, processed tracks and reports"
    DTDFVocab:enables DataMonitoringService
]

instance CloudACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Cloud computing resource that runs the off‑loaded Adaptive Cruise Control algorithm"
    DTDFVocab:enables ComputationOffloadingService
]

instance UserInterfaceVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3‑D visualization UI that consumes geometric and state data for operator monitoring"
    DTDFVocab:enables DataMonitoringService
]

instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Control panel FE that forwards operator commands (enable/disable ACC, set speed, emergency brake) to the physical twin"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Streams real‑time vehicle state, projected driving path and detected object tracks; allows saving and reporting"
    DTDFVocab:provides RealTimeVehicleStateInsight, DetectedObjectTracksInsight, ProjectedDrivingPathInsight, SaveReportAction, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC algorithm in the cloud, returns desired speed to the vehicle"
    DTDFVocab:provides DesiredSpeedInsight, DesiredSpeedCalculationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, set desired speed, and issue emergency‑brake commands via UI"
    DTDFVocab:provides ACCStatusInsight, EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current vehicle speed, pose and system health"
]

instance DetectedObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Insight showing positions and trajectories of objects detected by clustering"
]

instance ProjectedDrivingPathInsight : DTDFVocab:Insight [
    base:desc "Insight of the planned driving path generated by the ACC module"
]

instance DesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Insight of the speed setpoint calculated by the ACC algorithm"
]

instance ACCStatusInsight : DTDFVocab:Insight [
    base:desc "Insight indicating whether Adaptive Cruise Control is currently enabled"
]

// C17: Actions
instance SaveReportAction : DTDFVocab:Action [
    base:desc "Action to persist the current monitoring session as a report"
    DTDFVocab:IsAutomatic false
]

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Action to generate a formatted report from collected telemetry"
    DTDFVocab:IsAutomatic false
]

instance DesiredSpeedCalculationAction : DTDFVocab:Action [
    base:desc "Automatic computation of desired speed based on lead‑vehicle detection"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to activate Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to deactivate Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator command to set a manual desired speed for the vehicle"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator command to issue an immediate brake to stop the vehicle"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DTS sends control commands back to the vehicle over the same Wi‑Fi/UDP link. Commands include an ACC enable/disable flag, a desired speed value calculated by the off‑loaded ACC algorithm, and an emergency‑braking command. Command messages are generated by the Controlling FE and transmitted to the vehicle where the actuation FE (Motor, Steering Servo) applies them. The documents do not describe message payload formats, authentication, validation, feedback, or confirmation mechanisms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires a shared notion of time across devices, imposing a clock‑synchronisation accuracy of 100 ms (the limit set by the hardware). This accuracy governs the latency budget for computation off‑loading and keeps the digital twin temporally aligned with the physical twin."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration follows the ISO 23247 reference architecture: every Functional Entity is implemented as an individual ROS 2 package containing one or more ROS 2 nodes. ROS 2 topics and services interconnect the Physical Twin Entity (sensors, actuators, compute), the Digital Twin Entity (data management, control logic) and the User Entity (3‑D visualization, control panel). Resource ownership resides with the Physical Twin Entity, while the other entities consume these resources through ROS 2 communication, achieving system‑wide coordination."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The architecture mandates a shared notion of time across devices with a clock‑synchronization accuracy of 100 ms, limited by hardware capabilities; safety‑critical vehicular standards may require tighter bounds. No additional model validation, uncertainty quantification, or quality‑assurance processes are described in the provided documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑component communication inside the DTS uses ROS 2. Communication between the physical twin entity and the digital twin entity occurs over a Wi‑Fi network with UDP as the transport protocol. The architecture follows a client–server topology where the vehicle streams sensor data to the DTS and receives control messages in return. The system is required to provide low end‑to‑end latency for safety‑critical ACC functions, but exact bandwidth, latency, reliability, redundancy, or security protocol specifications are not provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The ACC service is off‑loaded from the vehicle to the Digital Twin, which may be executed on cloud‑based compute resources (the document references “in the cloud”). No concrete details on the hosting platform, storage capacity, CPU/GPU requirements, scalability mechanisms, deployment models, or availability guarantees are given."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The documents mention OPC Unified Architecture as an example protocol that could be employed for information exchange with external systems, consistent with ISO 23247 part 4 (Information exchange). No specific external integration implementation is detailed for the presented digital twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built on the ISO 23247 Digital Twin framework for manufacturing, using its entity‑based reference architecture (User Entity, Digital Twin Entity, Physical Twin Entity). The design mentions potential use of OPC Unified Architecture for communication, and notes that many standards for safety‑critical vehicular applications require clock synchronization tighter than 100 ms; the implementation adopts a 100 ms synchronization accuracy due to hardware limits."
]