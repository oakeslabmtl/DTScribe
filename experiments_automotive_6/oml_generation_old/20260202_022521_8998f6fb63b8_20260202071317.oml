// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor that generates raw point‑cloud data sampled on a 2‑D plane while the vehicle operates on‑road."
    DTDFVocab:producedData LiDARUDPPointCloudData
]

// C4: Physical-to-virtual interaction
instance LiDARUDPPointCloudData : DTDFVocab:DataTransmitted [
    base:desc "Raw LiDAR point‑cloud data transmitted via Wi‑Fi using UDP to the Digital Twin’s Data Translation front‑end."
    DTDFVocab:producedFrom LiDARSensor
]

// C10: Models/Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Transformed LiDAR point‑cloud data after Data Translation FE, ready for clustering, tracking, and projected path generation."
    DTDFVocab:fromData LiDARUDPPointCloudData
    DTDFVocab:inputTo DataMonitoringEnabler, ComputationOffloadingEnabler, RemoteManagementEnabler
]

// C11: Enablers
instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that aggregates processed LiDAR data and forwards it to the Data Monitoring service for real‑time visualization."
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that runs the ACC algorithm within the Digital Twin, computing desired speed based on inter‑vehicle distance."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that accepts remote operator commands for ACC enabling/disabling, target speed, and emergency braking."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring service that streams real‑time vehicle state, projected driving path, and nearby object tracks via a user interface; allows data export, save, and report generation."
    DTDFVocab:provides VehicleStateInsight, ExportDataAction, SaveDataAction, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation Offloading service that executes the ACC algorithm on the Twin, identifies the lead vehicle, computes desired speed based on inter‑vehicle distance, and transmits the speed back to the vehicle."
    DTDFVocab:provides ACCAlgorithmInsight, TransmitSpeedCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service that enables operators to enable/disable ACC, set target speed, and issue emergency braking commands."
    DTDFVocab:provides RemoteControlInsight, EnableACCAction, DisableACCAction, SetTargetSpeedAction, EmergencyBrakeAction
]

// C10: Models/Data (Insights)
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight that displays the real‑time vehicle state, projected driving path, and nearby object tracks."
]

instance ACCAlgorithmInsight : DTDFVocab:Insight [
    base:desc "Insight into the ACC algorithm execution, monitoring lead vehicle detection and desired speed computation."
]

instance RemoteControlInsight : DTDFVocab:Insight [
    base:desc "Insight reflecting the remote operator's control actions such as ACC enable/disable, target speed adjustments, and emergency braking."
]

// C10: Models/Data (Actions)
instance ExportDataAction : DTDFVocab:Action [
    base:desc "Action that initiates export of collected vehicle data from the Twin."
    DTDFVocab:IsAutomatic false
]

instance SaveDataAction : DTDFVocab:Action [
    base:desc "Action that saves current data snapshots within the Twin."
    DTDFVocab:IsAutomatic false
]

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Action that generates reports from the vehicle data within the Twin."
    DTDFVocab:IsAutomatic false
]

instance TransmitSpeedCommandAction : DTDFVocab:Action [
    base:desc "Action that transmits the computed desired speed from the Twin back to the vehicle for actuation."
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable the Adaptive Cruise Control system on the vehicle."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Action to disable the Adaptive Cruise Control system on the vehicle."
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Action that sets a target speed for the vehicle via the Twin."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action that performs emergency braking by commanding the Twin."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin synchronizes with the physical twin using a shared time base that is certified to stay within 100 ms of the physical devices' clocks. Each ROS2 node attaches timestamps to every published message; the system is designed to sample primary sensor streams at a maximum rate of 10 Hz with a satisfaction of end‑to‑end control‑feedback latency of under 200 ms, meeting ISO 23247 safety‑critical timing constraints."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows the ISO 23247 reference architecture, dividing responsibilities into three entities – User, Digital Twin, and Physical Twin. Software functions are split into functional elements (FEs), each implemented as a ROS2 package containing one or more ROS2 nodes. The User Entity hosts a single User‑Interface FE split into visualization and control panel sub‑components running on a dedicated machine. The Digital‑Twin Entity owns data‑management, control mechanisms and data‑storage FE components. The Physical‑Twin Entity handles sensor pre‑processing, point‑cloud clustering & tracking, actuation logic and general automotive functionality, and runs on the vehicle’s on‑board computer. These entities are located on separate hardware and communicate through ROS2 topics and services, providing a decentralized yet tightly coordinated orchestration across the DTS."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS employs a dual‑layer communication architecture: an internal ROS2 network for intra‑software component messaging (e.g., between the Data Translation FE, Point Cloud Clustering & Tracking, and visualization modules) and an external Wi‑Fi network using UDP at the transport layer for inter‑entity communication between the physical twin (sensors) and the digital twin. The UDP protocol is used for its low‑latency characteristics; however, the document does not specify bandwidth, latency requirements, reliability, redundancy, or security mechanisms beyond the choice of UDP."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "This Digital Twin system follows ISO 23247 – Digital twin framework for manufacturing, which defines a four‑part structure: overview and general principles, a reference architecture, digital representation of physical manufacturing elements, and information exchange. It adopts the standard’s entity‑based reference architecture (Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity, User Entity) and implements functional entities for tasks such as data collection, control, visualization, and user interaction. The implementation uses OPC UA for device‑to‑data collection and Digital Twin interfaces, ensuring interoperable, secure data exchange. The system thereby complies with ISO 23247, implements OPC Unified Architecture for interoperability, and is subject to any certification or compliance frameworks required by the standard."
]