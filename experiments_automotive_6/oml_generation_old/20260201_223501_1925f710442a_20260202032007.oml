// C3: Physical sensing components
instance HokuyoUST110LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-110LX LiDAR providing 2-D point clouds"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering depth images"
    DTDFVocab:producedData DepthCameraTransmitted
]

instance VehicleSpeedFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed feedback derived from motor/ESC"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle feedback from servo encoder"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST110LXLiDAR
]

instance DepthCameraTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedFeedbackSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleEncoderSensor
]

instance ObjectTrackTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DBSCANClusteringTrackingModel, KalmanFilterTrackingModel
]

// C5: Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 2‑D LiDAR point cloud stream"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo RenderingEnabler, DataTranslationEnabler
]

instance DepthCameraData : DTDFVocab:Data [
    base:desc "Depth images from RealSense camera"
    DTDFVocab:fromData DepthCameraTransmitted
    DTDFVocab:inputTo RenderingEnabler, DataTranslationEnabler
]

instance VehicleSpeedTelemetryData : DTDFVocab:Data [
    base:desc "Real‑time vehicle speed telemetry"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo ComputationOffloadingEnabler, DataTranslationEnabler
]

instance SteeringAngleTelemetryData : DTDFVocab:Data [
    base:desc "Real‑time steering‑angle telemetry"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo ComputationOffloadingEnabler, DataTranslationEnabler
]

instance ObjectTrackTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of object tracks generated by DBSCAN + Kalman filtering"
    DTDFVocab:fromData ObjectTrackTransmitted
    DTDFVocab:inputTo ReportingEnabler, DataTranslationEnabler
]

// C10: Models
instance DBSCANClusteringTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering module for object detection"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based tracking module refining DBSCAN clusters"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ACCControllerModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) controller implementing ISO 15622 class I logic"
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

instance Rendering3DModel : DTDFVocab:Model [
    base:desc "3‑D rendering model for visualising vehicle and environment"
    DTDFVocab:inputTo RenderingEnabler
]

// C11: Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ROS2‑based data translation FE handling serialization, unit conversion and Wi‑Fi transport"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, ReportingService, Visualization3DService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that offloads ACC computation from physical twin to digital twin"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that forwards UI control commands (ACC enable/disable, speed set, emergency brake) to the physical twin"
    DTDFVocab:enables RemoteManagementService
]

instance ReportingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that aggregates time‑series data and writes reports to an SQL database"
    DTDFVocab:enables ReportingService
]

instance RenderingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that supplies 3‑D scene data to the visualization UI"
    DTDFVocab:enables Visualization3DService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI visualisation of speed, steering, object tracks and projected path"
    DTDFVocab:provides Visual3DInsight, SpeedSteeringReadoutsInsight, PredictedPathInsight, ObjectTrackHistoryInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm execution in the digital twin returning speed set‑points"
    DTDFVocab:provides AdjustACCParametersAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote UI controls to enable/disable ACC, set speed, and trigger emergency braking"
    DTDFVocab:provides EnableACCAction, EmergencyBrakeAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Generation of time‑series reports stored in a SQL database"
    DTDFVocab:provides HistoricalReportInsight
]

instance Visualization3DService : DTDFVocab:Service [
    base:desc "3‑D visualisation of the vehicle and its environment"
    DTDFVocab:provides Visual3DInsight
]

// C17: Insights
instance Visual3DInsight : DTDFVocab:Insight [
    base:desc "Real‑time 3‑D view of vehicle and surrounding objects"
]

instance SpeedSteeringReadoutsInsight : DTDFVocab:Insight [
    base:desc "Live read‑outs of vehicle speed and steering angle"
]

instance PredictedPathInsight : DTDFVocab:Insight [
    base:desc "Predicted vehicle trajectory based on ACC planning"
]

instance ObjectTrackHistoryInsight : DTDFVocab:Insight [
    base:desc "Historical view of object‑track trajectories"
]

instance HistoricalReportInsight : DTDFVocab:Insight [
    base:desc "Aggregated performance reports from SQL database"
]

// C17: Actions
instance AdjustACCParametersAction : DTDFVocab:Action [
    base:desc "Operator adjusts ACC target speed or following distance"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "System issues emergency brake command to motor ESC"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator enables or disables the ACC function"
    DTDFVocab:IsAutomatic false
]

// C14: Entities (optional for completeness)
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "On‑board Jetson computers hosting sensing, tracking and control FE"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "External compute node running ACC, rendering and data services"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "Remote UI providing visualization and control panels"
]

// Environment grouping
instance AutonomousVehicleEnvironment : DTDFVocab:Environment [
    base:contains HokuyoUST110LXLiDAR, IntelRealSenseD435iDepthCamera, VehicleSpeedFeedbackSensor, SteeringAngleEncoderSensor, PhysicalTwinEntity, DigitalTwinEntity, UserEntity
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin sends computed ACC commands (desired speed) back to the vehicle for actuation, as well as remote‑management commands (enable/disable ACC, modify desired speed, emergency brake) issued by the User Interface FE. These commands are translated by the Data Translation FE and delivered over the Wi‑Fi link to the Physical Twin Entity's Actuation FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in real‑time with a maximum end‑to‑end network latency of 100 ms (per 3GPP TS 22.185) and clocks synchronised to ≤100 ms accuracy, satisfying the timing requirements of ACC computation offloading and remote management."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of the Physical Twin Entity (sensors, actuators, and data‑pre‑processing FE), the Digital Twin Entity (data collection, ACC controlling FE, reporting, and presentation FEs), the User Entity (3‑D visualisation and control‑panel UI FEs), and a Cross‑System Data Translation FE linking them. Communication inside the DT uses ROS 2; inter‑entity links use Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during design (simulation of ACC), development/testing (remote monitoring and debugging), and operation (real‑time monitoring and remote control of the physical vehicle)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by using high‑resolution LiDAR point clouds and real‑time clustering/tracking algorithms, and by adhering to ISO 15622 ACC specifications. Validity is supported by the 100 ms latency bound, 100 ms clock synchronisation, and safety‑critical design constraints (e.g., emergency braking command)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑digital communication uses a Wi‑Fi network (IEEE 802.11) carrying ROS 2 messages; data are serialized and unit‑converted by the Data Translation FE. The same Wi‑Fi link carries command messages from the DT back to the vehicle."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity and User Entity run on external compute platforms (e.g., a desktop or cloud VM) separate from the on‑board Jetson hardware that hosts the Physical Twin Entity. Each Functional Entity is deployed as an independent ROS 2 package."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) for entity/functional decomposition, ISO 15622 for ACC control logic, ISO/IEC 30173 for digital‑twin terminology, and 3GPP TS 22.185 for latency requirements. Optional OPC UA (IEC 62541) is mentioned for data translation, and ROS 2 provides the middleware implementation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by limiting end‑to‑end latency to 100 ms, synchronising clocks within 100 ms, and implementing emergency braking via the DT. No explicit cybersecurity mechanisms (e.g., authentication, encryption) are described in the document."
]