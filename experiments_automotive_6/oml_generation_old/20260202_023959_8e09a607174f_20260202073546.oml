// Physical Vehicle Component
instance PhysicalVehicle : DTDFVocab:Component [
    base:desc "1/10 scale teleoperated autonomous vehicle serving as the physical twin, retrofitted with advanced sensor and control technology, a dual‑tier chassis, and autonomous control elements."
]

// Sensing Components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor mounted on vehicle, capturing point clouds of surrounding environment."
    DTDFVocab:producedData LiDARDataTransmitted
]

instance MotorActuationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for motor actuation signals on the vehicle."
    DTDFVocab:producedData MotorActuationDataTransmitted
]

instance SteeringActuationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for steering actuation signals on the vehicle."
    DTDFVocab:producedData SteeringActuationDataTransmitted
]

instance ServoActuationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for servo actuation signals on the vehicle."
    DTDFVocab:producedData ServoActuationDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing derived vehicle state such as speed, acceleration, and heading."
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// Data Transmitted
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance MotorActuationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorActuationSensor
]

instance SteeringActuationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringActuationSensor
]

instance ServoActuationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ServoActuationSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// Data Instances
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "LiDAR point cloud data in vehicle coordinate system."
    DTDFVocab:fromData LiDARDataTransmitted
]

instance MotorActuationData : DTDFVocab:Data [
    base:desc "Motor actuation signal data."
    DTDFVocab:fromData MotorActuationDataTransmitted
]

instance SteeringActuationData : DTDFVocab:Data [
    base:desc "Steering actuation signal data."
    DTDFVocab:fromData SteeringActuationDataTransmitted
]

instance ServoActuationData : DTDFVocab:Data [
    base:desc "Servo actuation signal data."
    DTDFVocab:fromData ServoActuationDataTransmitted
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Derived vehicle state data including speed, acceleration, and heading."
    DTDFVocab:fromData VehicleStateDataTransmitted
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Dynamic tracks of surrounding objects extracted from LiDAR point cloud clustering."
    DTDFVocab:fromData LiDARPointCloudData
]

// Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation component that serializes, aligns message types, and performs unit conversions for all vehicle sensor data streams."
    DTDFVocab:inputTo LiDARPointCloudData, MotorActuationData, SteeringActuationData, ServoActuationData, VehicleStateData
    DTDFVocab:enables DataMonitoringService
]

instance PointCloudClusteringEnabler : DTDFVocab:Enabler [
    base:desc "Point Cloud Clustering & Tracking sub‑service that extracts and tracks object tracks from LiDAR point clouds."
    DTDFVocab:inputTo LiDARPointCloudData
    DTDFVocab:enables ROS2NetworkEnabler
]

instance ROS2NetworkEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 network component that transmits processed point clouds, object tracks, and vehicle state over an internal network to 3D Visualization and Data Monitoring services."
    DTDFVocab:inputTo LiDARPointCloudData, VehicleStateData, ObjectTrackData
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Computation Offloading enabler that runs the Adaptive Cruise Control algorithm on vehicle state and object tracks, returning speed commands to the on‑board ECU."
    DTDFVocab:inputTo VehicleStateData, ObjectTrackData
    DTDFVocab:enables ComputationOffloadingService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring service providing real‑time vehicle state, projected trajectory, and dynamic object tracks for operators."
    DTDFVocab:provides RealTimeVehicleStateInsight, ProjectedTrajectoryInsight, ObjectTrackInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computing Offloading service that runs the ACC algorithm and returns speed commands to the vehicle ECU, relieving the vehicle of heavy processing."
    DTDFVocab:provides SpeedCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service that allows operators to enable/disable ACC, set desired speed, or trigger an emergency brake."
    DTDFVocab:provides ACCEnableAction, DesiredSpeedSetAction, EmergencyBrakeAction
]

// Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight showing real‑time vehicle state including speed, acceleration, and heading."
]

instance ProjectedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight projecting the vehicle's future trajectory based on current state and ACC logic."
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Insight displaying dynamic tracks of surrounding objects identified by LiDAR clustering."
]

// Actions
instance SpeedCommandAction : DTDFVocab:Action [
    base:desc "Action representing the speed command sent from the DT to the vehicle ECU."
    DTDFVocab:IsAutomatic true
]

instance ACCEnableAction : DTDFVocab:Action [
    base:desc "Action to enable or disable Adaptive Cruise Control via the Remote Management UI."
    DTDFVocab:IsAutomatic false
]

instance DesiredSpeedSetAction : DTDFVocab:Action [
    base:desc "Action enabling operators to set the desired cruising speed for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action that triggers an emergency brake command from the operator control interface."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Time synchronization across all connected devices is mandated to share a common notion of time, with a required accuracy of 100 ms to satisfy safety-critical vehicular standards that often demand stricter limits. The data exchange and computation‑offloading processes are therefore synchronized on a 100 ms temporal grid, ensuring that physical and digital states are aligned with that granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is architected following ISO 23247, with distinct entity layers: a Physical Twin Entity that hosts the underlying compute, sensors, actuators and general automotive logic (e.g., point‑cloud clustering and tracking); a Digital Twin Entity that encapsulates data management and control mechanisms; and a User Entity that contains the User Interface FE split into 3D Visualization and Control Panel components. Each entity is instantiated as one or more ROS 2 packages, each comprising one or more ROS 2 nodes that communicate via ROS 2 topics and services. The entities are deployed on separate hardware platforms, leading to a distributed orchestration that respects 100 ms clock‑synchronization across nodes. Resource management and system‑wide coordination are handled by the ROS 2 middleware, which routes messages and service calls among nodes, while ownership of functionality is determined by the physical deployment of each entity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin System (DTS) employs an internal ROS 2 network based on DDS for communication between software components, while inter‑entity communication (e.g., between the DTS and external vehicle or user interfaces) is carried out over a Wi‑Fi radio link using the User Datagram Protocol (UDP) at the transport layer, as illustrated in Figure 2. This architecture supports real‑time, low‑latency data exchange for sensor streams and control command distribution."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system is designed in accordance with ISO 23247 – Digital twin framework for manufacturing, adopting its entity‑based reference architecture.  It follows Part 2 of the standard, which defines four core entities – Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity, and User Entity – each composed of Functional Entities for specific tasks such as actuator control, data transformation and user interfacing.  The implementation may use OPC Unified Architecture as an example of a Functional Entity communication protocol, ensuring interoperability with industrial automation systems."
]