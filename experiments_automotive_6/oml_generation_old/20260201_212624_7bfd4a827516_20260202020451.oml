// ------------------------------------------------------------
// Sensing Components
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "360° LiDAR providing point‑cloud data of the vehicle environment"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance DepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Depth camera supplying dense depth images for near‑field geometry"
    DTDFVocab:producedData DepthCameraImageTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor suite reporting vehicle state (speed, pose, acceleration)"
    DTDFVocab:producedData VehicleStateTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring electric motor status (rpm, torque, temperature)"
    DTDFVocab:producedData MotorStatusTransmitted
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Steering servo position sensor delivering steering angle feedback"
    DTDFVocab:producedData SteeringServoTransmitted
]

// ------------------------------------------------------------
// Data Transmitted (Physical‑to‑Virtual)
// each DataTransmitted aggregates the originating sensor(s)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance DepthCameraImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DepthCameraSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance MotorStatusTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance SteeringServoTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
]

// ------------------------------------------------------------
// Data (Virtual representation)
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw point‑cloud stream received from LiDAR"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance DepthCameraImageData : DTDFVocab:Data [
    base:desc "Depth images received from depth camera"
    DTDFVocab:fromData DepthCameraImageTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state vector (speed, pose, acceleration) for monitoring and control"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Motor operational parameters used for health monitoring"
    DTDFVocab:fromData MotorStatusTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance SteeringServoData : DTDFVocab:Data [
    base:desc "Steering angle feedback used by ACC control logic"
    DTDFVocab:fromData SteeringServoTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

// ------------------------------------------------------------
// Models / Data (Processing & Persistence)
instance PointCloudGeometryModel : DTDFVocab:Model [
    base:desc "Geometric point‑cloud model of the vehicle environment generated from LiDAR and depth‑camera data"
    DTDFVocab:inputTo ROS2Middleware
]

instance ObjectClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm applied to point‑cloud data for object segmentation"
    DTDFVocab:inputTo NVIDIAJetPackGPU
]

instance ObjectTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based state estimator providing dynamic motion predictions of tracked objects"
    DTDFVocab:inputTo NVIDIAJetPackGPU
]

instance TrajectoryDatabaseModel : DTDFVocab:Model [
    base:desc "Relational SQL database persisting historic trajectories and configuration parameters"
    DTDFVocab:inputTo DatabaseEngine
]

// ------------------------------------------------------------
// Enablers (Tools & Middleware)
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS 2 publish/subscribe middleware (DDS over Ethernet) used for intra‑DT communication"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance NVIDIAJetPackGPU : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK providing GPU‑accelerated processing for clustering and tracking"
    DTDFVocab:enables ComputationOffloadingService
]

instance MATLABSimulinkACC : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink model‑based design of the Adaptive Cruise Control (ACC) controller"
    DTDFVocab:enables ComputationOffloadingService
]

instance CloudComputeNode : DTDFVocab:Enabler [
    base:desc "Cloud compute resource where ACC algorithm is off‑loaded and desired speed is generated"
    DTDFVocab:enables ComputationOffloadingService
]

instance DatabaseEngine : DTDFVocab:Enabler [
    base:desc "SQL database engine storing sensor histories and ACC configuration"
    DTDFVocab:enables DataMonitoringService
]

instance DDSoverEthernetNetwork : DTDFVocab:Enabler [
    base:desc "Low‑latency DDS over Ethernet network satisfying safety‑critical timing requirements"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

// ------------------------------------------------------------
// Services (Digital Twin Capabilities)
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "GUI streams real‑time vehicle state, projected driving path, and detected object tracks; users can view, save, and generate reports"
    DTDFVocab:provides RealTimeVisualizationInsight, GenerateReportAction, SaveDataAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm (lead‑vehicle detection, distance‑based speed calculation, desired‑speed generation) runs in the DT cloud and returns desired speed for actuation"
    DTDFVocab:provides DesiredSpeedComputationInsight, SendDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, manually set desired speed, and issue emergency‑braking commands via UI"
    DTDFVocab:provides ACCStatusInsight, EnableACCAction, DisableACCAction, EmergencyBrakeAction
]

// ------------------------------------------------------------
// Insights
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides operators with up‑to‑date visualisation of vehicle state, trajectory, and surrounding objects"
]

instance DesiredSpeedComputationInsight : DTDFVocab:Insight [
    base:desc "Indicates that ACC desired speed has been computed based on perceived lead‑vehicle distance"
]

instance ACCStatusInsight : DTDFVocab:Insight [
    base:desc "Shows current ACC mode (enabled/disabled) and any manual speed overrides"
]

// ------------------------------------------------------------
// Actions
instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Creates a PDF/CSV report of the collected monitoring data"
    DTDFVocab:IsAutomatic false
]

instance SaveDataAction : DTDFVocab:Action [
    base:desc "Persists selected sensor data and model outputs to the SQL database"
    DTDFVocab:IsAutomatic false
]

instance SendDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Transmits the cloud‑computed desired speed back to the vehicle ECU for actuation"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables the Adaptive Cruise Control function on the physical vehicle"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disables the Adaptive Cruise Control function on the physical vehicle"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issues an emergency‑braking command to the vehicle’s actuation system"
    DTDFVocab:IsAutomatic true
]

// ------------------------------------------------------------
// Environment (Top‑level Entities per ISO 23247)
instance PhysicalTwinEntity : DTDFVocab:Environment [
    base:contains LiDARPointCloudSensor, DepthCameraSensor, VehicleStateSensor, MotorStatusSensor, SteeringServoSensor
]

instance DigitalTwinEntity : DTDFVocab:Environment [
    base:contains ROS2Middleware, NVIDIAJetPackGPU, MATLABSimulinkACC, CloudComputeNode, DatabaseEngine, DDSoverEthernetNetwork,
    PointCloudGeometryModel, ObjectClusteringModel, ObjectTrackingModel, TrajectoryDatabaseModel,
    DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance UserEntity : DTDFVocab:Environment [
    base:contains DataMonitoringService, RemoteManagementService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin sends control commands back to the vehicle, including the desired speed computed by the off‑loaded ACC algorithm, ACC enable/disable flags, speed set‑points, and emergency‑brake commands. Commands are formatted by the Data Translation FE (serialization, unit conversion) and transmitted over the same Wi‑Fi UDP link to the vehicle’s actuation FE, where they are applied by the motor and steering servo actuators. The vehicle’s response (updated vehicle state) is fed back to the DT for confirmation. Specific validation, authentication or conflict‑resolution mechanisms are not described."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Device coordination requires a shared notion of time; the system mandates clock synchronization accuracy of 100 ms (the limit imposed by hardware) to support computation offloading between devices."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 reference model, mapping each functional entity (FE) to an individual ROS 2 package; each package contains one or more ROS 2 nodes that implement the FE’s functionality. Entities are organized as Physical Twin, Digital Twin, and User entities, with the User Interface FE split into visualization and control‑panel sub‑components, and a Data Storage component that does not align to any FE. This ROS 2‑based, entity‑centric deployment coordinates the software components across the vehicle hardware."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication between the physical and digital twins uses a Wi‑Fi network with UDP as the transport protocol. Internally, software components within the DT communicate via a ROS 2 publish/subscribe network. The architecture relies on the ISO 23247 Data Translation functional element to ensure consistent message formats. The system requires low end‑to‑end latency for ACC remote management, but exact bandwidth, latency, reliability, redundancy or security protocol specifications are not provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built on the ISO 23247 Digital Twin framework for manufacturing, using its entity‑based reference architecture (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity). Functional Entities are implemented as ROS 2 packages, aligning with the ROS 2 ecosystem standards. For time synchronization, the design follows vehicular safety‑critical standards that demand clock synchronization tighter than 100 ms; the implementation targets a 100 ms synchronization accuracy due to hardware limitations."
]