// ==============================
// C1: Physical Sensing Components
// ==============================
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-110LX LiDAR providing raw point clouds"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDeepsenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera delivering depth images"
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded ego‑vehicle speed sensor (km/h) on the 1/10‑scale vehicle"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded steering‑angle sensor (degrees) on the vehicle"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// ==============================
// C2: Physical Acting Components
// ==============================
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage actuation for speed control (implemented by the Actuation FE)"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuation for direction control"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency braking command that overrides normal actuation"
]

// ==============================
// C3: Physical‑to‑Virtual Interaction (Data Transmitted)
// ==============================
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseDepthCamera
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ObjectTracksTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR, IntelDeepsenseDepthCamera
]

// ==============================
// C4: Digital Twin Data Artifacts
// ==============================
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data stream"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ROS2Middleware, JetsonComputeNode
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames from the D435i camera"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo ROS2Middleware, JetsonComputeNode
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego‑vehicle speed values (km/h)"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo ROS2Middleware, JetsonComputeNode
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Ego‑vehicle steering‑angle values (degrees)"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo ROS2Middleware, JetsonComputeNode
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Tracked object list with positions and velocities"
    DTDFVocab:fromData ObjectTracksTransmitted
    DTDFVocab:inputTo ROS2Middleware, MATLABSimulinkProcessingEnabler
]

// ==============================
// C5: Models / Algorithms
// ==============================
instance DBSCANKalmanObjectTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR points plus Kalman filter for trajectory estimation"
    DTDFVocab:inputTo MATLABSimulinkProcessingEnabler
]

instance ACCControlModelISO15622 : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control logic implementing ISO 15622 lead‑vehicle following and desired‑speed computation"
    DTDFVocab:inputTo JetsonComputeNode
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model for rendering object tracks and projected vehicle path"
    DTDFVocab:inputTo JetsonComputeNode
]

instance SQLTimeSeriesDatabaseModel : DTDFVocab:Model [
    base:desc "SQL database schema for persisting time‑series vehicle state and diagnostic reports"
    DTDFVocab:inputTo SQLDatabaseEnabler
]

// ==============================
// C6: Enablers (Software / Middleware)
// ==============================
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 DDS middleware over Wi‑Fi for intra‑ and inter‑entity communication"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance JetsonComputeNode : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetson Orin Nano compute node running ROS2 packages and AI models"
    DTDFVocab:enables ComputationOffloadingService, DataMonitoringService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database engine (e.g., SQLite/PostgreSQL) for storage of vehicle state and reports"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance MATLABSimulinkProcessingEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment used for DBSCAN clustering and Kalman filtering"
    DTDFVocab:enables ComputationOffloadingService
]

instance OPCUATranslatorEnabler : DTDFVocab:Enabler [
    base:desc "Optional OPC‑UA translator for data‑type standardisation in Data Translation FE"
    DTDFVocab:enables DataMonitoringService
]

instance WiFiNetworkEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi network linking physical twin and digital twin devices"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

// ==============================
// C7: Services
// ==============================
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualises real‑time speed, steering angle, object tracks, projected path and generates diagnostic reports"
    DTDFVocab:provides LiveVehicleStateInsight, ObjectTracksVisualizationInsight, ProjectedPathInsight, ACCDesiredSpeedInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC algorithm (lead‑vehicle detection and speed computation per ISO 15622) in the DT and returns control set‑points"
    DTDFVocab:provides ACCDesiredSpeedInsight, ACCParameterAdjustmentAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI enables operators to enable/disable ACC, adjust desired speed, and issue emergency braking"
    DTDFVocab:provides ACCParameterAdjustmentAction, EmergencyBrakingAction
]

// ==============================
// C8: Insights
// ==============================
instance LiveVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Live display of ego‑vehicle speed and steering angle"
]

instance ObjectTracksVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of detected object tracks in 3‑D space"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected vehicle trajectory based on ACC set‑points"
]

instance ACCDesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Computed desired speed for ACC following the lead vehicle"
]

// ==============================
// C9: Actions
// ==============================
instance ACCParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Operator adjusts ACC desired speed or enable/disable flag"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking command overriding normal actuation"
    DTDFVocab:IsAutomatic false
]

// ==============================
// C10: Environment (Vehicle)
// ==============================
instance VehicleEnvironment : DTDFVocab:Environment [
    base:contains HokuyoLiDAR, IntelDeepsenseDepthCamera, VehicleSpeedSensor, SteeringAngleSensor,
                MotorVoltageActuator, SteeringServoActuator, EmergencyBrakeActuator,
                ROS2Middleware, JetsonComputeNode, WiFiNetworkEnabler
]

// ==============================
// C11: High‑Level Component Definitions
// ==============================
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical twin hosting sensors, actuators and ROS2 nodes on the 1/10‑scale vehicle"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital twin processing streams, models and services on external compute"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "Operator UI providing monitoring, control and reporting capabilities"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends desired speed commands, ACC enable/disable signals, modified speed set‑points, and emergency braking commands back to the PT over the same ROS2/Wi‑Fi link. The Actuation FE converts the desired speed into motor voltage and the steering FE (if used) into servo positions, which are applied on the vehicle."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates in real time with a maximum end‑to‑end communication latency of 100 ms (per 3GPP 22.185) and clock synchronisation accuracy of 100 ms across all DT components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Adapted ISO 23247 architecture with four entities: Physical Twin Entity (sensing, actuation, point‑cloud clustering), Digital Twin Entity (data collection, ACC, reporting, visualization pre‑processing), User Entity (3D UI and control panel), and Cross‑System Entity (Data Translation). Entities are distributed across vehicle‑side hardware and external compute, communicating over ROS2 and Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT supports the operational stage (real‑time monitoring, remote control, and off‑loaded ACC computation) and the development stage (data collection, debugging, and reporting for developers). It is also used as a cyber‑physical experimentation platform during design."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity representation achieved by processing raw LiDAR data with DBSCAN and Kalman filtering, ACC behavior conforms to ISO 15622, latency and clock‑sync constraints (≤100 ms) ensure timely interaction for safety‑critical operation, and external storage allows post‑run validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication between PT and DT over a Wi‑Fi network using ROS2 messages; Data Translation FE serialises, type‑aligns and converts units; optional OPC UA noted but not employed; ROS2 packages encapsulate each FE."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital Twin Entity components run on external compute (e.g., a PC or cloud host) separate from the vehicle, while the Physical Twin Entity (sensors, point‑cloud clustering) runs on the vehicle’s Jetson Orin Nano. Each Functional Entity is deployed as a ROS2 package on its respective hardware."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The design follows ISO 23247 (Digital Twin Manufacturing Framework) reference architecture, ISO 15622 (ACC functional requirements), ISO/IEC 30173 (conceptual DT terminology), and 3GPP 22.185 (latency requirement). ROS2 (DDS) and OPC UA are referenced as standard middleware options."
]