// Sensing Components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR sensor providing 3D point clouds"
    DTDFVocab:producedData LiDARPointCloud
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera providing RGB-D data"
    DTDFVocab:producedData DepthCameraRGBD
]

instance WheelEncoder : DTDFVocab:SensingComponent [
    base:desc "Wheel encoder measuring ego vehicle speed"
    DTDFVocab:producedData EgoSpeed
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring vehicle steering angle"
    DTDFVocab:producedData SteeringAngleData
]

// Data Transmitted
instance LiDARPointCloud : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthCameraRGBD : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

instance EgoSpeed : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelEncoder
]

instance SteeringAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Data
instance RawLiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data from Hokuyo LiDAR"
    DTDFVocab:fromData LiDARPointCloud
    DTDFVocab:inputTo DataTranslationFE
]

instance RawDepthCameraRGBDData : DTDFVocab:Data [
    base:desc "Raw RGB-D data from Intel D435i depth camera"
    DTDFVocab:fromData DepthCameraRGBD
    DTDFVocab:inputTo DataTranslationFE
]

instance EgoVehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed data from wheel encoder"
    DTDFVocab:fromData EgoSpeed
    DTDFVocab:inputTo DataTranslationFE
]

instance SteeringAngleValueData : DTDFVocab:Data [
    base:desc "Steering angle data from steering angle sensor"
    DTDFVocab:fromData SteeringAngleData
    DTDFVocab:inputTo DataTranslationFE
]

// Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering for point cloud segmentation"
    DTDFVocab:inputTo DataTranslationFE
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter for multi-object tracking"
    DTDFVocab:inputTo DataTranslationFE
]

instance ACCControlLawModel : DTDFVocab:Model [
    base:desc "ACC control law computing following speed from lead vehicle distance"
    DTDFVocab:inputTo CloudOffloadingService
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3D visualization model for virtual cockpit"
    DTDFVocab:inputTo RvizVisualization
]

// Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for inter-process communication"
    DTDFVocab:enables ROS2DataExchangeService
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Data Translation Front End for message serialization"
    DTDFVocab:enables ROS2SerializationService
]

instance JetPackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK for Jetson Orin Nano"
    DTDFVocab:enables JetPackRuntimeService
]

instance SQLDatabaseService : DTDFVocab:Enabler [
    base:desc "External SQL database service for telemetry storage"
    DTDFVocab:enables DataPersistenceService
]

instance RvizVisualization : DTDFVocab:Enabler [
    base:desc "ROS2 rviz for 3D visualization"
    DTDFVocab:enables RvizVisualizationService
]

instance WebGLVisualization : DTDFVocab:Enabler [
    base:desc "Custom WebGL interface for 3D visualization"
    DTDFVocab:enables WebGLVisualizationService
]

instance MATLABSimulinkModule : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink module for complex algorithms (e.g., clustering, tracking)"
    DTDFVocab:enables SimulinkExecutionService
]

instance PythonNodeImplementation : DTDFVocab:Enabler [
    base:desc "Python 3.8 implementation of ROS2 nodes"
    DTDFVocab:enables PythonNodeService
]

instance CPPNodeImplementation : DTDFVocab:Enabler [
    base:desc "C++ implementation of ROS2 nodes"
    DTDFVocab:enables CPPNodeService
]

instance RoboRacerProject : DTDFVocab:Enabler [
    base:desc "Open-source RoboRacer project for vehicle retrofitting"
    DTDFVocab:enables VehicleRetrofittingService
]

instance JetsonNXAntenna : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetson NX antenna for wireless connectivity"
    DTDFVocab:enables WirelessConnectivityService
]

// Acting Components
instance VedderESCActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller for motor speed control"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator for steering angle control"
]

instance EmergencyBrakingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for emergency braking commands"
]

// Services and their Insight/Action Relations
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time data monitoring and visualization service"
    DTDFVocab:provides PerformanceDashboardInsight, LeadVehicleDistanceAlertInsight, ACCEventLogInsight, TrajectorySpeedInsight
]

instance RemoteControlService : DTDFVocab:Service [
    base:desc "Remote management control panel for ACC enable/disable, speed adjustment, emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Data storage service persisting telemetry into SQL database"
    DTDFVocab:provides TelemetryReportInsight, PredictiveMaintenanceInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D visualization service for virtual cockpit"
    DTDFVocab:provides ThreeDVisualizationInsight
]

instance ROS2DataExchangeService : DTDFVocab:Service [
    base:desc "Service exposing ROS2 data exchange capabilities"
    DTDFVocab:provides DataSensingInsight
]

instance ROS2SerializationService : DTDFVocab:Service [
    base:desc "Service providing ROS2 message serialization"
    DTDFVocab:provides SerializationInsight
]

instance JetPackRuntimeService : DTDFVocab:Service [
    base:desc "Service running applications on JetPack SDK"
    DTDFVocab:provides RuntimeInsight
]

instance DataPersistenceService : DTDFVocab:Service [
    base:desc "Service handling telemetry data persistence in SQL database"
    DTDFVocab:provides PersistenceInsight
]

instance RvizVisualizationService : DTDFVocab:Service [
    base:desc "Service for rendering 3D visualization via rviz"
    DTDFVocab:provides VizServiceInsight
]

instance WebGLVisualizationService : DTDFVocab:Service [
    base:desc "Service for rendering 3D visualization via WebGL"
    DTDFVocab:provides WebGLServiceInsight
]

instance SimulinkExecutionService : DTDFVocab:Service [
    base:desc "Service executing MATLAB/Simulink models"
    DTDFVocab:provides SimulinkExecutionInsight
]

instance PythonNodeService : DTDFVocab:Service [
    base:desc "Service running Python ROS2 nodes"
    DTDFVocab:provides PythonNodeInsight
]

instance CPPNodeService : DTDFVocab:Service [
    base:desc "Service running C++ ROS2 nodes"
    DTDFVocab:provides CPPNodeInsight
]

instance VehicleRetrofittingService : DTDFVocab:Service [
    base:desc "Service integrating open-source RoboRacer components for vehicle retrofitting"
    DTDFVocab:provides VehicleRetrofittingInsight
]

instance WirelessConnectivityService : DTDFVocab:Service [
    base:desc "Service managing wireless connectivity via Jetson NX antenna"
    DTDFVocab:provides WirelessConnectivityInsight
]

instance CloudOffloadingService : DTDFVocab:Service [
    base:desc "Service offloading ACC computation to cloud or edge node"
    DTDFVocab:provides ACCControlInsight
]

