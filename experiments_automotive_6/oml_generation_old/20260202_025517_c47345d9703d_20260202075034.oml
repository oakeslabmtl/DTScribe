// Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set desired speed for Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Trigger emergency braking"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "ACC control outputs generated in the Digital Twin Entity are sent over ROS 2 topics to the Actuation FE, which converts the desired speed into motor‑voltage commands and steering‑angle commands, then forwards them to the vehicle’s Electronic Speed Controller and steering actuator; emergency‑braking signals are likewise routed through the same mechanism."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with end‑to‑end latency constrained to ≤100 ms between vehicle and Digital Twin; all clocks synchronized within 100 ms; sensor streams (LiDAR, depth camera) supplied at their native rates (≈10–20 Hz), ensuring near‑instantaneous data propagation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Entity‑based architecture per ISO 23247: Physical Twin Entity hosts sensor‑processing FEs; Digital Twin Entity contains data‑collection, reporting, control, and visualization FEs; User Entity provides 3‑D visualization FE and control‑panel FE; Data Translation FE acts as a cross‑system bridge; components deployed across vehicle (Jetson Orin Nano), edge/cloud servers, and a UI client, interconnected through ROS 2 topics over Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design – ACC requirements defined and ISO 23247 RA selected; Development – ROS 2 packages implemented, FE mapping performed, hardware integration; Deployment – installation on vehicle and cloud/edge servers; Operation – live monitoring, remote control, telemetry collection; Maintenance – incremental updates to ACC logic, UI, and data pipelines."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Temporal fidelity ensured by bounding latency to ≤100 ms and clock skew to ≤100 ms; algorithmic validity achieved through use of proven DBSCAN clustering and Kalman‑filter tracking; data integrity maintained by Data Translation FE’s serialization; however, explicit statistical validation or hardware fault tolerance is not detailed in the document."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "PT and DT communicate over Wi‑Fi using ROS 2 topics; underlying transport follows ROS 2 QoS policies (default UDP/TCP), providing low‑latency packet delivery; Data Translation FE serializes messages into standardized ROS 2 message types; cross‑entity routing occurs across wireless links between Jetson Orin Nano and edge/cloud nodes."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin runs on Jetson Orin Nano mounted on the vehicle; Digital Twin and User Entities operate on a cloud/edge server (e.g., NVIDIA Jetson NX or a cloud VM); the UI is served via a web or desktop client; telemetry data stored in an external SQL database hosted on a server; ROS 2 hub or broker facilitates message passing across distributed nodes."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not in Document."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not in Document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture adopted for overall design; ACC control logic per ISO 15622 referenced; ROS 2 open standard for middleware; Data Translation FE uses standardized ROS 2 message types; software packaging follows ROS 2 conventions."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Not in Document."
]