instance SimulinkExecutionInsight : DTDFVocab:Insight [
    base:desc "Insight into MATLAB/Simulink execution"
]

instance PythonNodeInsight : DTDFVocab:Insight [
    base:desc "Insight into Python ROS2 node execution"
