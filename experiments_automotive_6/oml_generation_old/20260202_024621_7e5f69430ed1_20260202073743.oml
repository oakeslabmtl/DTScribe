// Sensing Components
instance LiDARScanner : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor capturing 3D point clouds of the vehicle environment"
    DTDFVocab:producedData LiDARDataTransmitted
]

instance OnBoardCamera : DTDFVocab:SensingComponent [
    base:desc "On‑board camera capturing real‑time visual frames of the vehicle surroundings"
    DTDFVocab:producedData CameraDataTransmitted
]

instance VehicleStateTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Telemetry sensor providing vehicle state data such as speed, acceleration, and GPS position"
    DTDFVocab:producedData TelemetryDataTransmitted
]

// Data Transmitted
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARScanner
]

instance CameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OnBoardCamera
]

instance TelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateTelemetrySensor
]

// Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of vehicle state such as speed, acceleration, and GPS position"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Visualization and monitoring of detected object tracks derived from LiDAR processing"
]

// Actions
instance SaveTelemetryReportAction : DTDFVocab:Action [
    base:desc "Action to save collected telemetry data and generate statistical reports"
    DTDFVocab:IsAutomatic false
]

instance DesiredSpeedAction : DTDFVocab:Action [
    base:desc "Desired speed command computed by ACC algorithm and sent back to vehicle actuators"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable the Adaptive Cruise Control system"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to set a desired speed for the vehicle"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to trigger emergency braking on the vehicle"
    DTDFVocab:IsAutomatic false
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real‑time vehicle state visualization, projected trajectory, and nearby object tracks"
    DTDFVocab:provides VehicleStateInsight, ObjectTrackInsight, SaveTelemetryReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service executing ACC decision logic remotely on cloud to compute desired speed"
    DTDFVocab:provides DesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service allowing operators to enable/disable ACC, set desired speeds, or issue emergency braking commands"
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Component that serializes sensor streams, aligns ROS2 message types, performs unit conversions, and verifies data integrity for the Digital Twin"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance LiDARPointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Point‑cloud clustering and tracking SW component transforming raw 3‑D point clouds into 2‑D plane points and projected driving paths"
    DTDFVocab:enables DataMonitoringService
]

instance ACCOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that forwards vehicle telemetry data to the cloud for ACC decision logic execution"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler handling remote commands such as ACC enable/disable, desired speed setting, and emergency braking"
    DTDFVocab:enables RemoteManagementService
]

instance WiFiInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Low‑latency vehicle‑to‑twin 5G/Wi‑Fi/DSRC link enabling real‑time data exchange between Physical and Digital Twins"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance CloudACCComputeEnabler : DTDFVocab:Enabler [
    base:desc "Cloud computing resource executing the offloaded ACC algorithm"
    DTDFVocab:enables ComputationOffloadingService
]

instance TelemetryStreamCollectorEnabler : DTDFVocab:Enabler [
    base:desc "Telemetry collection infrastructure streaming sensor and state data to the twin"
    DTDFVocab:enables DataMonitoringService
]

// Data
instance LiDARPointCloud : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data stream"
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance CameraFrame : DTDFVocab:Data [
    base:desc "Individual camera frame captured by the on‑board camera"
    DTDFVocab:fromData CameraDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance LiDARClustersData : DTDFVocab:Data [
    base:desc "0‑based 2‑D plane points and object tracks derived from LiDAR point clouds"
    DTDFVocab:fromData LiDARPointCloud
    DTDFVocab:inputTo LiDARPointCloudProcessingEnabler
]

instance VehicleTelemetryData : DTDFVocab:Data [
    base:desc "Vehicle telemetry data including speed, acceleration, and GPS position"
    DTDFVocab:fromData TelemetryDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, ACCOffloadingEnabler
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin synchronizes its internal state with the physical vehicle using a shared time base that achieves 100 ms absolute accuracy, as constrained by safety‑critical vehicular standards. Computation offloading between on‑board units depends on this coarse time alignment, enabling coordinated sensor fusion, vehicle‑to‑vehicle communication, and actuator command scheduling. All ROS2 nodes within the twin use the standard ROS time source, ensuring that timestamps on published messages and logged data are consistent across the distributed deployment."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration follows the ISO 23247 Reference Architecture, mapping each Functional Element (FE) onto a ROS2 package that contains one or more ROS2 nodes. The system adopts an entity‑based structure: User Entity (visualization, control panel), Digital Twin Entity (data storage, control logic), and Physical Twin Entity (sensor/actuator handling, point‑cloud clustering, tracking). Resources such as compute nodes, sensors, and actuators are allocated per entity, enabling distributed processing across a vehicle’s network. ROS2 topics, services, and actions provide the intra‑system coordination mechanism, while the underlying middleware ensures message ordering, QoS, and fault tolerance. This constellation deviates from ISO 23247 by introducing a Physical Twin Entity that integrates general automotive functionality directly into the twin’s core resources."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin System’s internal communication relies on ROS 2, which uses the Data Distribution Service (DDS) over UDP multicast for low‑latency, high‑throughput message distribution.  Inter‑entity communication is carried out over a Wi‑Fi link using UDP at the transport layer, as described in the architecture diagram.  The documentation does not provide explicit bandwidth, latency, reliability, redundancy, or security requirements for the network infrastructure."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliant with ISO 23247 – Digital Twin Framework for Manufacturing, adopting its reference architecture. The Digital Twin Entity is implemented per ISO 23247 Part 2 using an OPC Unified Architecture (OPC UA) stack for interoperability, ensuring adherence to the standard’s requirements for data structure, security, and communication protocols. The system references ISO 23247 Part 3 for digital representation of manufacturing elements and Part 4 for information exchange, thereby aligning with the specification for data exchange and model representation. The publicly available implementation on GitHub (https://github.com/McSCert/Automotive-Digital-Twin) follows the ISO 23247 guidance, demonstrating compliance with industry interoperability standards and providing a foundation for potential certification in OEM manufacturing environments."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "ISO 26262‑1:2018 mandates a formal hazard analysis and functional safety concept that requires the identification of safety goals, the application of FMEA and fault‑tree analyses, and the definition of fail‑safe mechanisms such as redundancy, graceful degradation and deterministic reaction times. The standard also prescribes a safety lifecycle covering requirements, design, implementation, verification and validation, and defines a safety case that must be maintained throughout a vehicle’s operational life. 3GPP TS 22.185 for V2X services specifies that all V2X messages must be sent with protection of confidentiality, integrity, authentication and non‑repudiation. The architecture relies on a V2X Public Key Infrastructure (PKI) with certificates to authenticate nodes, AES‑128/256 encryption to ensure confidentiality, and hash‑based message authentication codes or digital signatures to guarantee integrity. Closely related is the use of access‑control lists and role‑based privileges on the UDS and 5G core network, along with intrusion‑detection and DDoS mitigation mechanisms. Through these measures, the system achieves a multi‑layered defense that addresses both cybersecurity threats and functional safety risks."
]