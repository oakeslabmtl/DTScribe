// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor providing 3D point cloud measurements of the vehicle surroundings"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor package providing speed and steering angle measurements"
    DTDFVocab:producedData VehicleStateTransmitted
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// C10: Raw Data (from physical twin)
instance RawLiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data streamed from the physical vehicle"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance RawVehicleStateData : DTDFVocab:Data [
    base:desc "Raw vehicle state data (speed, steering angle) streamed from the physical vehicle"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

// C10: Processed Data (outputs of models)
instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks derived from clustering and tracking of LiDAR point clouds"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ProcessedVehicleStateData : DTDFVocab:Data [
    base:desc "Filtered vehicle state (speed, steering angle) after preprocessing"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ProjectedDrivingPathData : DTDFVocab:Data [
    base:desc "Projected driving path computed by the ACC algorithm"
    DTDFVocab:inputTo RemoteControlEnabler
]

instance DesiredSpeedData : DTDFVocab:Data [
    base:desc "Desired speed set‑point computed by the offloaded ACC control algorithm"
    DTDFVocab:inputTo RemoteControlEnabler
]

// C11: Enablers (tools & middleware)
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware providing real‑time topic communication between functional entities"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Software component that serializes, aligns message types, and performs unit conversions for transmitted data"
    DTDFVocab:enables DataMonitoringService
]

instance CloudComputationEnabler : DTDFVocab:Enabler [
    base:desc "Cloud platform that executes the ACC control algorithm (lead‑vehicle detection, speed set‑point computation)"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Interface that forwards desired speed and control commands from the digital twin to the vehicle actuation entity"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Graphical UI displays real‑time vehicle state, projected path and object tracks allows saving and reporting of ACC‑relevant data"
    DTDFVocab:provides InsightACCStateVisualization
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC control algorithm in the cloud and returns desired speed to the vehicle for actuation"
    DTDFVocab:provides InsightDesiredSpeedComputation
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, and issue emergency‑brake command via UI"
    DTDFVocab:provides ActionEnableACC, ActionDisableACC, ActionEmergencyBrake
]

// C17: Insights / Actions
instance InsightACCStateVisualization : DTDFVocab:Insight [
    base:desc "Provides operators with up‑to‑date visualization of ACC‑relevant state for monitoring and reporting"
]

instance InsightDesiredSpeedComputation : DTDFVocab:Insight [
    base:desc "Represents the computed desired speed set‑point derived from cloud‑based ACC algorithm"
]

instance ActionEnableACC : DTDFVocab:Action [
    base:desc "Command to enable Adaptive Cruise Control on the physical vehicle"
    DTDFVocab:IsAutomatic false
]

instance ActionDisableACC : DTDFVocab:Action [
    base:desc "Command to disable Adaptive Cruise Control on the physical vehicle"
    DTDFVocab:IsAutomatic false
]

instance ActionEmergencyBrake : DTDFVocab:Action [
    base:desc "Immediate emergency braking command issued to the vehicle"
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance VehicleActuationComponent : DTDFVocab:ActingComponent [
    base:desc "ROS 2 package receiving control commands from the Digital Twin and forwarding them to vehicle actuators (motor drives, steering)"
]

// C10: Models / analytical components
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Clustering and tracking algorithm that converts raw LiDAR point clouds into object tracks"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ACCControlAlgorithmModel : DTDFVocab:Model [
    base:desc "ACC control algorithm performing lead‑vehicle detection and speed set‑point computation in the cloud"
    DTDFVocab:inputTo RemoteControlEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin Entity are sent back to the vehicle over the same Wi‑Fi/UDP link. The commands include ACC enable/disable, a desired speed set‑point, and an emergency‑brake request. These commands are received by the Actuation FE in the Physical Twin Entity, which converts the desired speed into the appropriate motor voltage/actuation signal for the vehicle. The system operates in real time to meet low end‑to‑end latency requirements, but the documents do not describe explicit validation, authentication, or acknowledgement mechanisms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires clock synchronization between devices with an accuracy of 100 ms, as dictated by hardware limitations; this defines the maximum permissible time drift for computation offloading and coordination between the Physical Twin Entity and Digital Twin Entity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration follows the ISO 23247 reference architecture: software components are first identified, then mapped to Functional Entities that are implemented as individual ROS‑2 packages (each containing ROS‑2 nodes). The Physical Twin Entity hosts sensor, actuator and compute resources; the Digital Twin Entity provides data management and control logic; the User Entity offers a 3D visualization and control panel UI. Coordination between entities relies on ROS‑2 communication primitives and the shared 100 ms time base."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS uses a hybrid network architecture. Inside each entity, software components communicate via a ROS 2 middleware network (publish/subscribe and services). Between entities, a Wi‑Fi network transports UDP packets for both sensor data (physical→virtual) and control commands (virtual→physical). Clock synchronisation across devices is required to within 100 ms accuracy to satisfy safety‑critical timing constraints. No explicit bandwidth or redundancy mechanisms are described, and security protocols are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the vehicle’s on‑board compute hardware, hosting sensor drivers and the Data Pre‑Processing and Actuation FEs as ROS 2 packages. The Digital Twin Entity is deployed on external compute resources that may reside in the cloud or at the edge, providing sufficient CPU, memory and storage to run the Data Translation, Data Collection, Reporting and 3D Visualization services. The architecture supports off‑loading of the ACC algorithm to this remote platform, enabling scalable compute and storage while maintaining low end‑to‑end latency for control loops."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built to conform to the ISO 23247 Digital Twin framework for manufacturing, specifically leveraging Part 2 (Reference Architecture) to define an entity‑based structure (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity) and to allocate functionality to Functional Entities. Communication and device coordination may employ OPC Unified Architecture (OPC UA) as suggested by the standard, though the implementation described uses ROS 2 as the middleware. The design also respects industry‑specified time‑synchronization limits (≤100 ms) for safety‑critical vehicular applications, aligning with standards that mandate stricter clock synchronization. No additional certification or compliance frameworks are mentioned."
]