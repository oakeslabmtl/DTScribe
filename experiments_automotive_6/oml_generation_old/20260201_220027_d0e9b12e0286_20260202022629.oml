// C3: Physical sensing components
instance HokuyoLiDARUST110LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑110LX 2‑D LiDAR (range up to 10 m, 0.25° resolution, 40 Hz scan rate) mounted on the vehicle"
    DTDFVocab:producedData LiDARDataTransmitted
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera (RGB‑D, depth range 0.2‑10 m, 30 fps) providing dense 3‑D depth images"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance VehicleMotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting motor status (RPM, torque) from the vehicle's ECU"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

instance SteeringServoPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring steering servo position"
    DTDFVocab:producedData SteeringPosDataTransmitted
]

instance VehiclePoseSensor : DTDFVocab:SensingComponent [
    base:desc "Pose sensor delivering vehicle position, orientation and speed"
    DTDFVocab:producedData VehiclePoseDataTransmitted
]

// C4: DataTransmitted
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARUST110LX
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleMotorStatusSensor
]

instance SteeringPosDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoPositionSensor
]

instance VehiclePoseDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehiclePoseSensor
]

// C10: Data
instance RawLiDARPointCloud : DTDFVocab:Data [
    base:desc "Raw 3‑D point cloud generated from LiDAR range scans"
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance DepthImage : DTDFVocab:Data [
    base:desc "Dense depth image produced by the RealSense depth camera"
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Motor RPM and torque status values"
    DTDFVocab:fromData MotorStatusDataTransmitted
    DTDFVocab:inputTo RemoteControlEnabler
]

instance SteeringPositionData : DTDFVocab:Data [
    base:desc "Current steering servo angle"
    DTDFVocab:fromData SteeringPosDataTransmitted
    DTDFVocab:inputTo RemoteControlEnabler
]

instance VehiclePoseData : DTDFVocab:Data [
    base:desc "Vehicle pose (position, orientation) and longitudinal speed"
    DTDFVocab:fromData VehiclePoseDataTransmitted
    DTDFVocab:inputTo ACCComputationEnabler
]

instance ProcessedObjectTracksData : DTDFVocab:Data [
    base:desc "Clustered and Kalman‑filtered object tracks (position, velocity) derived from LiDAR"
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo DataMonitoringEnabler
]

// C10: Models
instance EuclideanClusteringModel : DTDFVocab:Model [
    base:desc "Euclidean clustering algorithm for segmenting point clouds into individual object clusters"
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Linear Kalman filter used to predict and update object state over time"
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance ACCDecisionModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model performing lead‑vehicle detection and desired‑speed computation"
    DTDFVocab:inputTo ACCComputationEnabler
]

instance TrajectoryVisualizationModel : DTDFVocab:Model [
    base:desc "Generates motion trajectories and projected driving path for UI visualization"
    DTDFVocab:inputTo DataMonitoringEnabler
]

// C11: Enablers
instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 node that executes Euclidean clustering and Kalman‑filter tracking on incoming point clouds"
    DTDFVocab:enables DataMonitoringService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Cloud computing resource that runs the ACC algorithm (lead‑vehicle detection, desired speed calculation)"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Middleware component handling low‑latency command exchange for ACC enable/disable and emergency braking"
    DTDFVocab:enables RemoteManagementService
]

instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Provides processed vehicle and object trajectory data to the monitoring UI"
    DTDFVocab:enables DataMonitoringService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI displays real‑time vehicle state, projected path, and detected object tracks; supports view, save and report generation"
    DTDFVocab:provides InsightVehicleStateVisualization, ActionGenerateReport
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm on cloud resources and returns the computed speed to the physical vehicle for actuation"
    DTDFVocab:provides InsightDesiredSpeedComputation, ActionSetDesiredSpeed
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI allows operators to enable/disable ACC, set desired speed, and issue emergency‑brake commands with low‑latency bidirectional communication"
    DTDFVocab:provides ActionEnableACC, ActionDisableACC, ActionEmergencyBrake
]

// C17: Insights
instance InsightVehicleStateVisualization : DTDFVocab:Insight [
    base:desc "Provides operators with a real‑time spatial view of vehicle state and surrounding object tracks"
]

instance InsightDesiredSpeedComputation : DTDFVocab:Insight [
    base:desc "Calculates the appropriate cruise speed based on inter‑vehicle distance and lead‑vehicle detection"
]

// C17: Actions
instance ActionGenerateReport : DTDFVocab:Action [
    base:desc "Generates and exports historic data reports for analysis"
    DTDFVocab:IsAutomatic false
]

instance ActionSetDesiredSpeed : DTDFVocab:Action [
    base:desc "Sets the target speed on the vehicle according to the ACC computation"
    DTDFVocab:IsAutomatic true
]

instance ActionEmergencyBrake : DTDFVocab:Action [
    base:desc "Issues an emergency‑brake command to the vehicle"
    DTDFVocab:IsAutomatic false
]

instance ActionEnableACC : DTDFVocab:Action [
    base:desc "Enables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance ActionDisableACC : DTDFVocab:Action [
    base:desc "Disables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Component
instance BrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Physical actuator that applies braking force to the vehicle upon receiving an emergency‑brake command"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin (e.g., ACC enable/disable, desired speed set‑point, emergency braking) are sent back to the Physical Twin over the same Wi‑Fi UDP link. The commands are formatted by the Data Translation component to match the vehicle’s control message schema and are consumed by the Actuation functional entity (Actuation FE) which drives the motor and steering servos. The DT UI (Control Panel) provides the operator interface for issuing these commands. Details on validation, authentication, conflict resolution, or acknowledgement of command execution are not described in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin requires that all devices share a common notion of time with clock synchronization accuracy of ±100 ms; this accuracy limit is imposed by the hardware and enables computation offloading among devices. Although many safety‑critical vehicular standards demand tighter synchronization, the system itself operates with the 100 ms bound, and no additional latency budgets for other services are specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Overall orchestration is based on the ISO 23247 reference architecture, realized through ROS2. Each Functional Entity is packaged as an individual ROS2 package containing one or more ROS2 nodes; the three entities are deployed on distinct compute platforms, enabling resource‑specific management (sensors/actuators in the Physical Twin Entity, data management in the Digital Twin Entity, UI in the User Entity). Coordination among entities is achieved via ROS2 middleware message passing."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT’s internal software components communicate via a ROS 2 network, while inter‑entity communication between the Physical Twin and the Digital Twin uses a Wi‑Fi network employing UDP at the transport layer. The architecture is illustrated in Figure 2, showing a layered deployment where sensor data flows from the physical sensors to the DT services. No quantitative bandwidth, latency, redundancy, or security protocol specifications are given."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system demonstrates computation off‑loading of the ACC functionality to a Digital Twin that can run on better‑suited equipment such as cloud resources, implying a cloud‑based hosting model. The documents mention the need for low end‑to‑end latency but do not provide concrete details on the hosting platform, computational or storage sizing, scalability mechanisms, deployment models, or availability guarantees."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Inter‑entity communication uses ROS2, while integration with external enterprise systems or other Digital Twins can be performed through standard interfaces such as OPC Unified Architecture (OPC UA) as suggested by ISO 23247; no further protocol specifics are detailed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system follows the ISO 23247 standard (Digital Twin framework for manufacturing), specifically leveraging Part 2 (Reference Architecture) which defines an entity‑based architecture comprising Observable Manufacturing Elements, Data Collection and Device Control Entities, Digital Twin Entities, and User Entities, each built from Functional Entities. The standard permits the use of technologies such as OPC Unified Architecture (OPC UA) for data exchange, indicating adherence to open industrial communication standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin System shall be built respecting the safety-critical nature of the vehicle function, complying with ISO 15622:2018 “Intelligent Transport Systems – Adaptive Cruise Control Systems – Performance Requirements and Test Procedures,” which defines the performance and test criteria that the twin must meet for ACC functionality. In addition, ISO 26262‑1:2018 “Road vehicles – Functional safety” governs the safety lifecycle, requiring hazard analysis, risk assessment, and the implementation of fail-safe mechanisms for safety-critical components of the twin. These standards together mandate that the twin’s behavior be validated against ACC safety requirements and that functional‑safety processes be applied, although specific cybersecurity protocols or authentication mechanisms are not detailed in the cited documents."
]