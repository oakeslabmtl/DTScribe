// ------------------------------------------------------------
// C3: Physical sensing components
// ------------------------------------------------------------

instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing distance measurements as raw point cloud streams."
    DTDFVocab:producedData LiDARRawDataTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering RGB-D data streams."
    DTDFVocab:producedData DepthCameraRawDataTransmitted
]

instance VedderESC : DTDFVocab:SensingComponent [
    base:desc "Vedder Electronic Speed Controller reporting motor state feedback."
    DTDFVocab:producedData MotorStateRawDataTransmitted
]

// ------------------------------------------------------------
// C4: Physical-to-virtual interaction (DataTransmitted)
// ------------------------------------------------------------

instance LiDARRawDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthCameraRawDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

instance MotorStateRawDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VedderESC
]

// ------------------------------------------------------------
// C10: Data instances (post‑translation / pre‑processing)
// ------------------------------------------------------------

instance LiDARProcessedData : DTDFVocab:Data [
    base:desc "Processed LiDAR point‑cloud after clustering & tracking."
    DTDFVocab:fromData LiDARRawDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, ROS2MiddlewareEnabler
]

instance DepthCameraProcessedData : DTDFVocab:Data [
    base:desc "Processed RGB‑D frames after depth alignment and unit conversion."
    DTDFVocab:fromData DepthCameraRawDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, ROS2MiddlewareEnabler
]

instance MotorStateProcessedData : DTDFVocab:Data [
    base:desc "Motor speed and torque feedback after smoothing and unit normalization."
    DTDFVocab:fromData MotorStateRawDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

// ------------------------------------------------------------
// C10: Models / Algorithms
// ------------------------------------------------------------

instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Point‑cloud clustering algorithm used to group LiDAR returns into object hypotheses."
    DTDFVocab:inputTo DataTranslationEnabler
]

instance PointCloudTrackingModel : DTDFVocab:Model [
    base:desc "Object tracking model that maintains trajectories of clustered LiDAR objects."
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ACCAlgorithmModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) algorithm that detects lead vehicle, computes desired speed and generates throttle/brake commands."
    DTDFVocab:inputTo NVIDIAJetpackEnabler
]

// ------------------------------------------------------------
// C11: Enablers (tools / middleware)
// ------------------------------------------------------------

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS‑2 middleware handling real‑time data exchange over Wi‑Fi (UDP) between Physical Twin, Digital Twin and User Entity."
    DTDFVocab:enables DataMonitoringService, RemoteManagementService, ComputationOffloadingService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data translation FE that serialises messages, aligns types and performs unit conversions."
    DTDFVocab:enables DataMonitoringService
]

instance NVIDIAJetpackEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK providing GPU‑accelerated perception and control algorithms for ACC computation."
    DTDFVocab:enables ComputationOffloadingService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Data storage component persisting sensor streams for later analysis."
    DTDFVocab:enables DataMonitoringService
]

// ------------------------------------------------------------
// C6: Services offered by the Digital Twin
// ------------------------------------------------------------

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time 3‑D visualization, vehicle state display, and report generation for operators."
    DTDFVocab:provides VisualMonitoringInsight, ReportGenerationAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm in the cloud and returns speed commands to the vehicle."
    DTDFVocab:provides ACCEnableAction, DesiredSpeedSetAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, and issue emergency‑brake commands."
    DTDFVocab:provides EmergencyBrakeAction
]

// ------------------------------------------------------------
// C17: Insights and Actions exposed to the User Entity
// ------------------------------------------------------------

instance VisualMonitoringInsight : DTDFVocab:Insight [
    base:desc "Operators can visually monitor sensor data, vehicle trajectory and nearby object tracks in a 3‑D UI."
]

instance ReportGenerationAction : DTDFVocab:Action [
    base:desc "Generate and save PDF/CSV reports of logged vehicle data."
    DTDFVocab:IsAutomatic false
]

instance ACCEnableAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control processing on the Digital Twin."
    DTDFVocab:IsAutomatic false
]

instance DesiredSpeedSetAction : DTDFVocab:Action [
    base:desc "Set a desired cruise speed that the ACC algorithm will attempt to maintain."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issue an emergency braking command to the vehicle actuators."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin—such as the computed desired speed for the ACC algorithm, ACC enable/disable commands, and emergency‑brake requests—are transmitted back to the physical twin over the same Wi‑Fi UDP link. The commands are consumed by the Actuation FE on the physical side, which translates the desired speed into motor voltage commands and triggers actuation of steering or braking. The documents do not specify explicit validation, authentication, or acknowledgment mechanisms for these command messages."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates with a shared time reference required for computation offloading, enforcing a clock synchronization accuracy of 100 ms across devices; although safety‑critical vehicular standards mandate stricter synchronization, the system limits to 100 ms because of hardware constraints."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall constellation follows the ISO 23247 reference architecture, mapping each functional entity to a ROS2 package that runs on the designated hardware, thereby aligning the Physical Twin Entity (sensor/actuator and preprocessing services), the Digital Twin Entity (data management and control services), and the User Entity (3D visualization and control‑panel services) within an entity‑based modular structure."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS internal software components communicate via a ROS 2 network (publish/subscribe model). Communication between the Physical Twin Entity and the Digital Twin Entity occurs over a Wi‑Fi network using UDP at the transport layer. The documents do not provide quantitative latency, bandwidth, reliability, redundancy, or security specifications."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The computational part of the DT that runs the ACC algorithm is off‑loaded from the resource‑constrained ECU to external compute resources described as “in the cloud”. The DT therefore is deployed on cloud infrastructure that provides sufficient processing and storage for data collection, reporting and remote management. Details on edge or on‑premise deployment, scalability mechanisms or availability guarantees are not provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is explicitly based on the ISO 23247 standard for manufacturing digital twins. ISO 23247 defines four parts: (1) overview and general principles, (2) reference architecture (adopted in the design), (3) digital representation of physical manufacturing elements, and (4) information exchange. The architecture adopts the ISO 23247 entity model—Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, and User Entity—while introducing a Physical Twin Entity to host compute, sensor, and actuator resources. Communication and interoperability are implemented using ROS 2 packages and nodes, not the OPC UA example mentioned in the background. Timing synchronization for distributed computation off‑loading requires a clock accuracy of 100 ms, stated as a hardware limitation, even though many safety‑critical vehicular standards demand tighter synchronization. No additional certification or industry‑specific compliance frameworks are reported in the documents."
]