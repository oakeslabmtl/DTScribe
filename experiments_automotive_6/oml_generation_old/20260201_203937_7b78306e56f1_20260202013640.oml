// C2: Acting Components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder electronic speed controller driving the motor, receives speed commands"
]

instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuating the vehicle steering angle"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency brake actuator that sets motor voltage to zero for rapid stop"
]

// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2‑D LiDAR providing real‑time point clouds of surroundings"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelRealSenseCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera supplying depth images and infrared data"
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board speed sensor delivering ego‑vehicle speed via ROS2 topic"
    DTDFVocab:producedData SpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor publishing current steering angle via ROS2 topic"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseCamera
]

instance SpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ObjectTrackTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

// C5: Data objects
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 2‑D LiDAR point‑cloud streams"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ClusteringNode
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames from RealSense camera"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo VisualizationNode
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Time‑series of vehicle speed and steering angle"
    DTDFVocab:fromData SpeedTransmitted
    DTDFVocab:inputTo DataTranslationEntity, ACCComputationNode, ReportingNode
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Structured object tracks (position, velocity) generated from LiDAR clustering and Kalman‑filter tracking"
    DTDFVocab:fromData ObjectTrackTransmitted
    DTDFVocab:inputTo TrackingNode, VisualizationNode, ReportingNode
]

// C10: Models/Data
instance ACCControlModel : DTDFVocab:Model [
    base:desc "ACC control model compliant with ISO 15622 executing on the digital twin"
    DTDFVocab:inputTo ACCComputationNode
]

instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering model for extracting object candidates"
    DTDFVocab:inputTo ClusteringNode
]

instance ObjectTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based object‑tracking model maintaining tracks over time"
    DTDFVocab:inputTo TrackingNode
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model used by UI to render vehicle, projected path and object tracks"
    DTDFVocab:inputTo VisualizationNode
]

instance RelationalSQLDatabaseModel : DTDFVocab:Model [
    base:desc "Relational SQL database schema storing time‑series vehicle state and object tracks"
    DTDFVocab:inputTo ReportingNode
]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware (DDS) handling topic communication between components"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, ReportingService
]

instance DataTranslationEntity : DTDFVocab:Enabler [
    base:desc "Cross‑system Data Translation Functional Entity for serialization and unit conversion"
    DTDFVocab:enables DataMonitoringService, ReportingService
]

instance ACCComputationNode : DTDFVocab:Enabler [
    base:desc "ROS 2 node running the ISO 15622 ACC algorithm on the digital twin"
    DTDFVocab:enables ComputationOffloadingService
]

instance ClusteringNode : DTDFVocab:Enabler [
    base:desc "ROS 2 node performing DBSCAN clustering on LiDAR point clouds"
    DTDFVocab:enables DataMonitoringService
]

instance TrackingNode : DTDFVocab:Enabler [
    base:desc "ROS 2 node applying Kalman‑filter tracking to clustering outputs"
    DTDFVocab:enables DataMonitoringService, ReportingService
]

instance VisualizationNode : DTDFVocab:Enabler [
    base:desc "ROS 2 node rendering 3‑D visualizations in the operator UI"
    DTDFVocab:enables DataMonitoringService
]

instance ReportingNode : DTDFVocab:Enabler [
    base:desc "ROS 2 node generating human‑readable time‑series reports of vehicle state and object tracks"
    DTDFVocab:enables ReportingService
]

instance JetPackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK providing GPU acceleration for computation offloading"
    DTDFVocab:enables ComputationOffloadingService
]

instance WiFiNetwork : DTDFVocab:Enabler [
    base:desc "Wi‑Fi networking linking vehicle Jetson to off‑board digital twin"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualizes real‑time vehicle state, projected path and object tracks stores data and generates reports"
    DTDFVocab:provides VehicleStateInsight, ObjectTrackInsight, VisualizationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm (ISO 15622) runs on the digital twin, reducing ECU load"
    DTDFVocab:provides ACCPerformanceInsight, ACCControlAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI permits remote enable/disable of ACC, speed set‑point changes, and emergency braking"
    DTDFVocab:provides RemoteEnableACCAction, RemoteDisableACCAction, SetSpeedSetpointAction, EmergencyBrakeAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Reporting FE generates human‑readable time‑series reports of vehicle state and object tracks"
    DTDFVocab:provides ReportingInsight
]

// C17: Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Current vehicle speed and steering angle for operator situational awareness"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Detected object positions and velocities visualized on UI"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Projected vehicle path and 3‑D environment visualization"
]

instance ACCPerformanceInsight : DTDFVocab:Insight [
    base:desc "Metrics showing ACC performance and reduced ECU load"
]

instance ReportingInsight : DTDFVocab:Insight [
    base:desc "Compiled report of time‑series vehicle state and object tracks"
]

// C17: Actions
instance RemoteEnableACCAction : DTDFVocab:Action [
    base:desc "Remotely enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance RemoteDisableACCAction : DTDFVocab:Action [
    base:desc "Remotely disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetSpeedSetpointAction : DTDFVocab:Action [
    base:desc "Change target speed set‑point for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issue emergency brake command by setting motor voltage to zero"
    DTDFVocab:IsAutomatic true
]

instance ACCControlAction : DTDFVocab:Action [
    base:desc "ACC control command generated by the ACC computation node"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin sends desired speed commands, ACC enable/disable signals, desired speed adjustments, and emergency‑brake commands back to the vehicle over the ROS 2/Wi‑Fi link; an Actuation Functional Entity converts these commands into motor voltage and steering‑servo control signals."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "End‑to‑end communication latency bounded at ≤100 ms (R7) and component clocks synchronized within 100 ms accuracy (R8). Data collection and control operate at the perception‑cycle rate (tens of Hz), supporting real‑time interaction."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Entity‑based architecture derived from ISO 23247: Physical Twin Entity hosts Data Pre‑Processing and Actuation FEs; Digital Twin Entity hosts Data Collection, Reporting, Controlling, and Presentation FEs; User Entity hosts Visualization and Control‑Panel UI FEs; Cross‑System Data Translation FE mediates inter‑entity communication over ROS 2 within entities and Wi‑Fi between entities."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during design/testing (simulation of ACC), during manufacturing validation, and throughout operation for monitoring, remote management and performance reporting."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Safety‑critical operation enforced by latency ≤100 ms and clock sync ≤100 ms. ACC logic follows ISO 15622 specifications. Sensor data is processed with proven DBSCAN clustering and Kalman filtering, and results are stored in a SQL database for traceability. Real‑time performance was validated on the physical testbed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Intra‑entity communication via ROS 2 DDS on the same host; inter‑entity communication over a Wi‑Fi network using ROS 2 topics. A Data Translation Functional Entity performs message serialization, type alignment and unit conversion for all exchanged data."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the vehicle‑mounted NVIDIA Jetson Orin Nano; Digital Twin Entity runs on an external compute platform (e.g., cloud or workstation) that hosts the ACC algorithm and data services; the User Entity UI runs on a remote workstation accessed over the Wi‑Fi link."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 (Digital Twin Manufacturing Framework) for architecture, ISO 15622 for ACC functionality, ISO/IEC 30173 for DT terminology, OPC UA (IEC 62541) mentioned as optional data translation protocol, and 3GPP TS 22.185 referenced for latency requirements."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed through real‑time latency limits (≤100 ms), clock synchronization (≤100 ms), and remote command validation for emergency braking. No explicit security mechanisms (e.g., authentication, encryption) are described in the document."
]