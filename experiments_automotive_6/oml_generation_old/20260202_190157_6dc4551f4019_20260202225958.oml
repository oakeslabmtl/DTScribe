    base:desc "Secure over-the-air update of ACC firmware/software on autonomous vehicles with version validation."
    DTDFVocab:IsAutomatic false
]

instance InteractiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization of sensor data, object tracks, and vehicle state information for user interaction."
]

// C1: System Under Study
instance AutonomousVehicleDigitalTwinSystem : DTDFVocab:System [
    base:desc "1/10-scale autonomous vehicle Digital Twin implementing Adaptive Cruise Control (ACC) with real-time sensor fusion, edge computing, and remote management capabilities."
    DTDFVocab:hasEnvironment AutomotiveTestingEnvironment
]

// C2: Acting Components
instance VehicleActuatorInterface : DTDFVocab:ActingComponent [
    base:desc "Interface component receiving control commands from ACC algorithm to adjust vehicle speed and steering via physical actuators."
]

// C5: Environment
instance AutomotiveTestingEnvironment : DTDFVocab:Environment [
    base:desc "Controlled testing environment simulating various driving conditions (traffic density, weather) for validating ACC algorithms in the 1/10-scale autonomous vehicle system."
    base:contains HokuyoUST10LXLiDAR, IntelDeepsenseD435iDepthCamera, VehicleStateSensor
]

// C12: Relationships
instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor capturing speed, acceleration, steering angle, and inter-vehicle distance data for ACC control."
    DTDFVocab:producedData VehicleStateData
]

// Additional Data Flow Connections
instance FilteredObjectTracks : DTDFVocab:Data [
    base:desc "Processed object track data output from Kalman filter tracking model for ACC decision-making."
    DTDFVocab:fromData ObjectTrackData
    DTDFVocab:inputTo ACCControlAlgorithm
]

