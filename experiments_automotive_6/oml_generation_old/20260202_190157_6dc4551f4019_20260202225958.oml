    base:desc "Functional Entity implementing DBSCAN clustering algorithm for converting raw LiDAR point clouds into structured object representations."
    DTDFVocab:inputTo ROS2DataProcessingEnabler
]

instance ObjectTrackingFE : DTDFVocab:FunctionalEntity [
    base:desc "Functional Entity implementing Kalman filter-based motion estimation for tracking detected objects with high precision."
