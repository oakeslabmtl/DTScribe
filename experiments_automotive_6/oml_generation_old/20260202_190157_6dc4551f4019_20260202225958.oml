    base:desc "Primary entity interfacing with physical sensors and actuators, aggregating raw data streams and executing control commands for the autonomous vehicle."
    base:contains HokuyoUST10LXLiDAR, IntelDeepsenseD435iDepthCamera, VehicleActuatorInterface
]

instance DigitalTwinEntity : DTDFVocab:Entity [
    base:desc "Digital representation of the autonomous vehicle implementing high-fidelity computational models for real-time monitoring, simulation, and ACC control."
    base:contains PointCloudClusteringModel, KalmanFilterTrackingModel, ACCControlAlgorithm, DataTranslationFE
]

