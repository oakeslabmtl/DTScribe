]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service offloading ACC computations from embedded platform to edge server with 100ms latency constraint for real-time responsiveness."
    DTDFVocab:provides DynamicWorkloadDistributionAction
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring service visualizing sensor data streams and ACC-specific metrics for autonomous driving engineers."
    DTDFVocab:provides SensorDataVisualizationInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing continuous visualization of vehicle state parameters (speed, distance, acceleration) for situational awareness."
    DTDFVocab:provides VehicleStateVisualizationInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service enabling over-the-air firmware updates and diagnostic capabilities for ACC system on autonomous vehicles."
    DTDFVocab:provides FirmwareUpdateAction
]

instance UserInterfaceService : DTDFVocab:Service [
    base:desc "Service providing 3D visualization and control panel interfaces for user interaction with the Digital Twin system."
    DTDFVocab:provides InteractiveVisualizationInsight
]

// C17: Insights/Actions
instance ObjectDetectionInsight : DTDFVocab:Insight [
    base:desc "Structured object detection results from LiDAR point clouds enabling obstacle avoidance in autonomous driving scenarios."
]

instance MotionTrackingInsight : DTDFVocab:Insight [
    base:desc "Kalman filter-based object tracking data providing accurate spatial positioning and motion estimation for ACC decision-making."
]

