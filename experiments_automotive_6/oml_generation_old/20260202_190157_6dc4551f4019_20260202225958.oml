    base:desc "Automatic adjustment of vehicle speed based on environmental perception and ACC algorithm outputs."
    DTDFVocab:IsAutomatic true
]

instance DynamicWorkloadDistributionAction : DTDFVocab:Action [
    base:desc "Dynamic redistribution of ACC computation workload between on-board and offloaded edge systems to maintain real-time performance."
    DTDFVocab:IsAutomatic true
]

instance SensorDataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of raw and processed sensor data streams for autonomous driving system monitoring."
]

instance VehicleStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization of vehicle state parameters including speed, acceleration, and inter-vehicle distance for situational awareness."
]

