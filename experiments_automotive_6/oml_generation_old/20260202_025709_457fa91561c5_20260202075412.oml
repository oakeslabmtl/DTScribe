// C3: Physical sensing components
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR used to capture point‑clouds of the surrounding environment."
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance IntelD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Intel D435i RGB‑D camera providing depth images for scene perception."
    DTDFVocab:producedData DepthImageDataTransmitted
]

instance VehicleStateTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor transducing speed and steering‑angle signals from onboard electronics."
    DTDFVocab:producedData VehicleStateTelemetryDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmitted)
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthImageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iCamera
]

instance VehicleStateTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateTelemetrySensor
]

// C10: Models/Data
instance ACCControllerModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control controller implementing ISO 15622 class I."
    DTDFVocab:inputTo DataProcessingFE
]

instance DBSCANPointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering model used to group spatial points into obstacles."
    DTDFVocab:inputTo DataProcessingFE
]

instance KalmanFilterObjectTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter model for estimating object tracks from clustered point‑cloud data."
    DTDFVocab:inputTo DataProcessingFE
]

// C4: Raw Data assets
instance LiDARStreamData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream received from Hokuyo UST-10LX."
    DTDFVocab:inputTo DataProcessingFE
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
]

instance DepthImageStreamData : DTDFVocab:Data [
    base:desc "Raw depth image stream received from Intel D435i."
    DTDFVocab:inputTo DataProcessingFE
    DTDFVocab:fromData DepthImageDataTransmitted
]

instance VehicleStateTelemetryStreamData : DTDFVocab:Data [
    base:desc "Vehicle state telemetry stream of speed and steering angle."
    DTDFVocab:inputTo DataProcessingFE
    DTDFVocab:fromData VehicleStateTelemetryDataTransmitted
]

instance DerivedObjectTracksData : DTDFVocab:Data [
    base:desc "Object‑track estimates generated by DBSCAN clustering and Kalman filtering."
    DTDFVocab:inputTo DataTranslationFE
    DTDFVocab:fromData LiDARStreamData
]

instance TimeSeriesReportsData : DTDFVocab:Data [
    base:desc "Time‑series reports of vehicle performance and environment interactions."
    DTDFVocab:inputTo DataTranslationFE
    DTDFVocab:fromData DerivedObjectTracksData
]

// C2: Acting Components
instance DigitalTwinActuationFE : DTDFVocab:ActingComponent [
    base:desc "Digital Twin Actuation Functional Entity translating desired speed to motor voltage and steering servo commands."
]

instance PhysicalTwinMotorActuationFE : DTDFVocab:ActingComponent [
    base:desc "Physical Twin Motor Actuation FE directly controlling the motor via Vedder ESC."
]

instance PhysicalTwinSteeringServoActuationFE : DTDFVocab:ActingComponent [
    base:desc "Physical Twin Steering Servo Actuation FE directly controlling the steering servo."
]

// C11: Enablers
instance DataProcessingFE : DTDFVocab:Enabler [
    base:desc "Data Collection and Processing FE ingesting raw sensor streams, performing preprocessing, clustering, and filtering."
    DTDFVocab:enables ComputationOffloadingService, DataMonitoringService
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "OPC‑UA like Data Translation FE serializing processed data to SQL database."
    DTDFVocab:enables DataMonitoringService
]

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware facilitating communication between on‑board Jetson, remote server, and UI workstation."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance NVIDIAJetpackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK providing GPU acceleration for perception algorithms."
    DTDFVocab:enables DataProcessingFE
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of vehicle state, object tracks, 3D visualization, and persistence to SQL database."
    DTDFVocab:provides ACCPerformanceInsight, VehicleDynamicsInsight, EnvironmentalInteractionInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation offloading whereby ACC logic is executed on the Digital Twin, reducing on‑board ECU load."
    DTDFVocab:provides ACCControllerModel
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management allowing operators to control ACC state, modify desired speed, and issue emergency braking."
    DTDFVocab:provides ActionSetACCState, ActionModifyDesiredSpeed, ActionEmergencyBraking
]

// C17: Insights
instance ACCPerformanceInsight : DTDFVocab:Insight [
    base:desc "Real‑time ACC performance insight generated by the DT’s reporting tools."
]

instance VehicleDynamicsInsight : DTDFVocab:Insight [
    base:desc "Insight into vehicle dynamics obtained from processed telemetry."
]

instance EnvironmentalInteractionInsight : DTDFVocab:Insight [
    base:desc "Insight into environmental interactions derived from object tracks and sensor fusion."
]

// C17: Actions
instance ActionSetACCState : DTDFVocab:Action [
    base:desc "Operator action to enable or disable ACC."
    DTDFVocab:IsAutomatic false
]

instance ActionModifyDesiredSpeed : DTDFVocab:Action [
    base:desc "Operator action to modify desired ACC speed."
    DTDFVocab:IsAutomatic false
]

instance ActionEmergencyBraking : DTDFVocab:Action [
    base:desc "Operator action to issue emergency braking."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT’s Controlling FE computes ACC decisions (desired vehicle speed) and sends actuation commands back to the vehicle’s motor and steering servo through the Data Translation FE. Remote management commands issued via the UI (enable/disable ACC, set desired speed, trigger emergency braking) are likewise transmitted to the PT and applied to the actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All DT services operate in real‑time with an end‑to‑end latency requirement of ≤100 ms between the vehicle and the Digital Twin Entity. Clock synchronization across all hardware components is maintained to within 100 ms accuracy, ensuring consistent event ordering and data integrity during computation offloading."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system’s constellation consists of three entities mapped to the ISO 23247 RA: Physical Twin Entity hosting sensors and actuators; Digital Twin Entity encapsulating data collection, processing, and control FEs; and User Entity providing a 3‑D visualization and control panel UI. Communications flow via a ROS 2 network within the vehicle and a Wi‑Fi network for remote DT interaction."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The study follows a traditional engineering lifecycle: 1) Requirement Definition (R1‑R8); 2) Architecture Design based on ISO 23247 RA; 3) Implementation of software components as ROS 2 packages; 4) Validation during operation (real‑time monitoring, latency tests); and 5) Deployment for remote management. No explicit manufacturing‑phase modeling is included, as the twin is only instantiated during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "PT–DT communication occurs over a Wi‑Fi network; data serialization and unit alignment are performed by the Data Translation FE. Inside the vehicle, inter‑entity messages are exchanged over the ROS 2 publish/subscribe network. The DT accepts serialized messages compatible with ROS 2 messages and uses standard UDP/TCP transport as per ROS 2 DDS profile."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity and associated data‑processing services are deployed on a remote server (cloud or edge) capable of providing low‑latency response. The User Entity (UI) runs on a client workstation that interfaces with the DT via Wi‑Fi. The overall deployment is thus a hybrid edge‑to‑cloud model."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) for entity and FE mapping, ISO 15622 for the ACC controller definition, and ROS 2 as the middleware. Data translation adheres to standard serialization practices (e.g., OPC UA‑like), ensuring compliance with industrial communication standards."
]