// ===========================================
// C3: Physical sensing components
// ===========================================

// LiDAR sensor on the PT
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-110LX 2‑D LiDAR providing raw point‑cloud scans"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

// Depth camera on the PT
instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering depth images"
    DTDFVocab:producedData DepthImageTransmitted
]

// Vehicle speed measurement sensor
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board speed sensor measuring ego vehicle speed"
    DTDFVocab:producedData SpeedDataTransmitted
]

// Steering‑angle sensor
instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting the current steering wheel angle"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// ===========================================
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// ===========================================

instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Transmitted object tracks (output of Kalman tracker)
instance ObjectTracksTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom KalmanTrackerModel
]

// Transmitted ACC set‑point (output of ACC control model)
instance ACCSetpointTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ACCControlModel
]

// ===========================================
// C5: Data definitions
// ===========================================

instance RawLiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data as received from HokuyoLiDAR"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DBSCANClusteringModel, DataTranslationEnabler
]

instance RawDepthImageData : DTDFVocab:Data [
    base:desc "Depth image captured by IntelDepthCamera"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed measured by VehicleSpeedSensor"
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo ACCControlModel, DataTranslationEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering angle measured by SteeringAngleSensor"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo ACCControlModel, DataTranslationEnabler
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks generated by KalmanTrackerModel"
    DTDFVocab:fromData ObjectTracksTransmitted
    DTDFVocab:inputTo ACCControlModel, DataTranslationEnabler
]

instance ACCSetpointData : DTDFVocab:Data [
    base:desc "Speed set‑point computed by ACCControlModel for actuation"
    DTDFVocab:fromData ACCSetpointTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler, DataTranslationEnabler
]

// ===========================================
// C10: Models/Data (Algorithmic components)
// ===========================================

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering module segmenting LiDAR point‑clouds"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance KalmanTrackerModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based tracker producing object tracks"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "ACC control model (ISO‑15622 performance class‑I) computing speed set‑point"
    DTDFVocab:inputTo DataTranslationEnabler
]

// ===========================================
// C11: Enablers (Software / Middleware)
// ===========================================

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware handling pub/sub of all DT topics"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Cross‑system Data Translation Functional Entity (unit conversion, serialization)"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance JetsonSDKEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK on Jetson Orin Nano providing GPU‑accelerated compute"
    DTDFVocab:enables ComputationOffloadingService
]

instance OPCUAEnabler : DTDFVocab:Enabler [
    base:desc "Optional OPC‑UA layer for secure remote command exchange"
    DTDFVocab:enables RemoteManagementService
]

// ===========================================
// C6: Services
// ===========================================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI service visualising real‑time speed, steering, object tracks and projected path; generates time‑series reports"
    DTDFVocab:provides RealTimeVisualizationInsight, ReportGenerationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm on the external Digital Twin rather than the on‑board ECU"
    DTDFVocab:provides ACCComputationInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI controls allowing operators to enable/disable ACC, adjust desired speed, and trigger emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakeAction
]

// ===========================================
// C17: Insights
// ===========================================

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visual insight of speed, steering angle, object tracks and projected path"
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Automatically generated time‑series report for post‑mission analysis"
]

instance ACCComputationInsight : DTDFVocab:Insight [
    base:desc "Computed ACC set‑point and lead‑vehicle detection insight"
]

// ===========================================
// C17: Actions
// ===========================================

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator adjusts the desired cruising speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator (or safety system) issues emergency brake, disabling motor driver"
    DTDFVocab:IsAutomatic true
]

// ===========================================
// C2: Acting components (actuators)
// ===========================================

instance VehicleMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Vehicle motor receiving voltage commands from the Digital Twin"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo executing angle commands from the Digital Twin"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency braking actuator that disables the motor driver on command"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT over the same Wi‑Fi link: desired longitudinal speed (computed by the ACC Controlling FE), ACC enable/disable flags, and an emergency‑brake command. Commands are packaged by the Data Translation FE and delivered to the Actuation FE on the Physical Twin Entity, which converts them to motor voltage or steering signals."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is required to maintain end‑to‑end communication latency ≤ 100 ms (R7) and clock synchronization accuracy of 100 ms across all DT components (R8). Data collection and ACC computation occur at the vehicle’s perception cycle rate (approximately 10 Hz), ensuring near‑real‑time operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture follows the ISO 23247 entity‑based RA: Physical Twin Entity (data pre‑processing and actuation FEs), Digital Twin Entity (data collection, reporting, ACC Controlling FE, Presentation FE), User Entity (3D Visualization and Control Panel UI FEs), and a Cross‑System Data Translation FE. Inter‑entity communication uses ROS 2 over Wi‑Fi, with data translation handling serialization and unit conversion."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during design (cyber‑physical experimentation with simulation), development (debugging and data collection), and operation (real‑time monitoring and remote ACC management). The case study emphasizes the operational stage for remote management and the development stage for data‑driven troubleshooting."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by using well‑known algorithms (DBSCAN for clustering, Kalman filter for tracking) and by conforming the ACC controller to ISO 15622 specifications. Validity is addressed through strict latency (≤ 100 ms) and clock‑sync constraints (≤ 100 ms) to maintain causal ordering of sensor data and control commands in this safety‑critical context."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual and virtual‑to‑physical data are exchanged over a Wi‑Fi network using ROS 2 topics. The Data Translation FE serialises messages, performs unit conversion, and can optionally employ OPC UA (IEC 62541) for standardized communication. All intra‑DT components communicate via ROS 2 DDS."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity and User Entity run on external compute hardware (e.g., a desktop or cloud server) separate from the vehicle’s on‑board Jetson. Data storage resides on an external device (SQL database) as required by R3. The Physical Twin Entity runs on the vehicle’s Jetson Orin Nano."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built on ISO 23247 (Digital Twin Manufacturing Framework) for architectural guidance, ISO 15622 for ACC functionality, and references ISO/IEC 30173:2023 for digital‑twin terminology. OPC UA (IEC 62541) is mentioned as a possible protocol for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations include a maximum 100 ms communication latency, 100 ms clock synchronization, and compliance with ISO 15622 ACC safety requirements. Remote commands (including emergency braking) are delivered over a secured Wi‑Fi link, and the architecture isolates actuation logic within the Physical Twin Entity to mitigate inadvertent control actions."
]