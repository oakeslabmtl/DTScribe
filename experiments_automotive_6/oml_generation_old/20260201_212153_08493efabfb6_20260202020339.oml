// ====================== // Return code: 1 | Stderr:
// 1. Sensing Components
// ======================
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor producing raw point‑cloud data for the vehicle"
    DTDFVocab:producedData LiDARPointCloudTransmission
]

instance MotorFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Motor feedback sensor providing motor speed and torque measurements"
    DTDFVocab:producedData MotorFeedbackTransmission
]

instance SteeringServoStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Steering servo status sensor reporting steering angle and health"
    DTDFVocab:producedData SteeringStatusTransmission
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor aggregating odometry, velocity, and pose"
    DTDFVocab:producedData VehicleStateTransmission
]

// =============================
// 2. Data Transmitted (Physical→Virtual)
// =============================
instance LiDARPointCloudTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance MotorFeedbackTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorFeedbackSensor
]

instance SteeringStatusTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoStatusSensor
]

instance VehicleStateTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// ==================
// 3. Virtual Data
// ==================
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Serialized LiDAR point‑cloud after unit conversion and UDP transport"
    DTDFVocab:fromData LiDARPointCloudTransmission
    DTDFVocab:inputTo DataMonitoringEnabler
]

instance MotorFeedbackData : DTDFVocab:Data [
    base:desc "Motor speed and torque data after translation and unit conversion"
    DTDFVocab:fromData MotorFeedbackTransmission
    DTDFVocab:inputTo DataMonitoringEnabler
]

instance SteeringStatusData : DTDFVocab:Data [
    base:desc "Steering angle and health status after translation"
    DTDFVocab:fromData SteeringStatusTransmission
    DTDFVocab:inputTo RemoteManagementEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle odometry, velocity and pose after translation"
    DTDFVocab:fromData VehicleStateTransmission
    DTDFVocab:inputTo RemoteManagementEnabler, ComputationOffloadingEnabler
]

// ==================
// 4. Computational Models
// ==================
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Point‑cloud clustering and object‑tracking algorithm used for 3‑D visualization"
    DTDFVocab:inputTo DataMonitoringEnabler
]

instance ACCAlgorithmModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm (lead‑vehicle detection, distance‑based speed computation, desired speed output) executed on cloud resources"
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

// ===============
// 5. Enablers
// ===============
instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware package exposing data to the Data Monitoring Service and to the clustering model"
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Cloud compute environment that runs the ACC model and returns desired speed commands"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware handling bidirectional command exchange for remote ACC control and emergency braking"
    DTDFVocab:enables RemoteManagementService
]

// ===============
// 6. Services
// ===============
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time vehicle state visualization, projected path, and object tracks supports historical data browsing and report generation"
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTracksInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes the ACC algorithm on cloud resources and transmits the computed desired speed back to the vehicle"
    DTDFVocab:provides DesiredSpeedInsight, SetDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to enable/disable ACC, set desired speed, and issue emergency brake commands via the UI"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// ====================
// 7. Insights & Actions
// ====================
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Live visualization of vehicle pose, speed and trajectory on the UI"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Visualization of detected objects and their tracks generated by the clustering model"
]

instance DesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Computed desired speed output from the ACC algorithm"
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Command to activate Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Command to deactivate Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Command to set a new desired speed for the vehicle (either from UI or ACC model output)"
    DTDFVocab:IsAutomatic true
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediate braking command issued by the operator"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the ACC Controlling FE (e.g., desired speed, enable/disable ACC, emergency braking) are packaged by the Data Translation FE, transmitted over the same Wi‑Fi UDP link to the Physical Twin Entity, and received by the Actuation FE which drives the motor, steering and servo actuators. The command messages follow the format defined by the Data Translation component (aligned with ISO 23247). Validation occurs within the Data Translation and Actuation FE before actuation; feedback of execution status is sent back through the same channel to the DTS."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires clock synchronization between devices with a maximum error of 100 ms; this bound is imposed because hardware can only support 100 ms accuracy, whereas safety‑critical vehicular standards often demand tighter sync (<100 ms). The synchronization interval is therefore set to maintain ≤100 ms offset, enabling computation off‑loading between the physical twin and its digital counterpart."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration follows the ISO 23247 reference architecture: functional entities are mapped to ROS 2 packages, each package containing one or more ROS 2 nodes that realize the FE functionality. The three entities are deployed on distinct compute nodes (e.g., vehicle ECU, sensor processor) and communicate via ROS 2 topics/services, providing system‑wide coordination of data collection, actuation, and user interaction. This component‑based integration implements the Digital Twin Entity for data management, the Physical Twin Entity for sensor/actuator handling, and the User Entity for 3D visualization and control panel."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The system requires a shared notion of time across devices with a synchronization accuracy of 100 ms, as mandated by hardware limitations and safety‑critical vehicular application constraints. This timing requirement underpins the validity of actuation and data fusion in the Digital Twin. No additional model validation, uncertainty quantification, or quality assurance procedures are described in the source materials."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS employs a two‑layer communication architecture: (1) an internal ROS 2 (DDS) network for all software component interactions, and (2) an external Wi‑Fi network using UDP for bi‑directional data exchange between the Physical Twin and the Digital Twin. The system is required (Requirement R7) to maintain end‑to‑end network latency of at most 100 ms, and (Requirement R8) to provide clock synchronization between the twin entities (e.g., via NTP or ROS 2 time sync). Reliability is supported by ROS 2’s QoS policies, while security mechanisms are not explicitly detailed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture explicitly follows the ISO 23247 reference architecture, adopting its entity‑based model (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity) and mapping software components to Functional Entities. Implementation of Functional Entities is realized as ROS 2 packages, each containing one or more ROS 2 nodes. The documents note that OPC Unified Architecture (OPC UA) can be used for communication, reflecting adherence to industrial interoperability standards. Additionally, timing requirements reference vehicular safety standards that mandate clock synchronization accuracy better than 100 ms, indicating compliance with relevant time‑synchronization specifications."
]