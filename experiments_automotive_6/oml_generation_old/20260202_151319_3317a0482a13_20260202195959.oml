// C2: Acting Components
instance LowerLevelChassisActuator : DTDFVocab:ActingComponent [
    base:desc "Lower-level chassis component responsible for steering and speed control via motor voltage commands in the autonomous vehicle's physical twin"
]

instance UpperLevelChassisActuator : DTDFVocab:ActingComponent [
    base:desc "Upper-level chassis component hosting autonomy components (NVIDIA Jetson Orin Nano) executing actuation logic via ActuationFE for ACC control"
]

instance JetsonOrinNanoActuationNode : DTDFVocab:ActingComponent [
    base:desc "NVIDIA Jetson Orin Nano microcomputer node executing ACC control logic via ActuationFE, converting desired speed to motor voltage commands"
]

instance VedderElectronicSpeedController : DTDFVocab:Actuator [
    base:desc "Vedder Electronic Speed Controller managing speed control commands for the autonomous vehicle's lower-level chassis"
]

// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing 3D object detection for autonomous vehicle perception"
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i Depth Camera providing environmental perception data for autonomous vehicle"
    DTDFVocab:producedData DepthCameraData
]

instance EgoVehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor measuring ego-vehicle speed for adaptive cruise control"
    DTDFVocab:producedData VehicleSpeedData
]

instance EgoVehicleSteeringSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor measuring ego-vehicle steering angle for adaptive cruise control"
    DTDFVocab:producedData VehicleSteeringData
]

// C4: Physical-to-Virtual Interaction Data Streams
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
    DTDFVocab:producedFrequency 10Hz
]

instance DepthCameraData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
    DTDFVocab:producedFrequency 30Hz
]

instance VehicleSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoVehicleSpeedSensor
    DTDFVocab:producedFrequency 100Hz
]

instance VehicleSteeringData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoVehicleSteeringSensor
    DTDFVocab:producedFrequency 100Hz
]

instance ObjectTrackData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudData, DepthCameraData
    DTDFVocab:producedFrequency 10Hz
]

instance EgoVehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedData, VehicleSteeringData
    DTDFVocab:producedFrequency 100Hz
]

// C5: Data Models
instance LiDARPointCloudModel : DTDFVocab:Model [
    base:desc "Point cloud model derived from Hokuyo UST-10LX LiDAR data for object detection and tracking"
    DTDFVocab:inputTo ROS2Middleware
]

instance ObjectTrackModel : DTDFVocab:Model [
    base:desc "Object tracking model implementing DBSCAN clustering and Kalman filtering for LiDAR/Depth camera data"
    DTDFVocab:inputTo ROS2Middleware, NVIDIAJetPack50SDK
]

instance VehicleStateModel : DTDFVocab:Model [
    base:desc "Ego-vehicle state model combining speed and steering angle data for adaptive cruise control"
    DTDFVocab:inputTo ROS2Middleware
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model implementing ISO 15622 Class I control loop for speed adjustment"
    DTDFVocab:inputTo ROS2Middleware, NVIDIAJetPack50SDK
]

instance VisualizationPipelineModel : DTDFVocab:Model [
    base:desc "3D visualization pipeline for rendering ego-vehicle state and object tracks in real-time"
    DTDFVocab:inputTo ROS2Middleware, NVIDIAJetPack50SDK
]

instance SQLReportingModel : DTDFVocab:Model [
    base:desc "SQL database model for storing historical data and generating human-readable reports"
    DTDFVocab:inputTo SQLDatabase
]

// C6: Data
instance RawLiDARData : DTDFVocab:Data [
    base:desc "Raw point cloud data transmitted from Hokuyo UST-10LX LiDAR"
    DTDFVocab:fromData LiDARPointCloudData
    DTDFVocab:unit Millimeters
]

instance ProcessedObjectTracks : DTDFVocab:Data [
    base:desc "Processed object tracks generated from LiDAR/Depth camera data via DBSCAN and Kalman filtering"
    DTDFVocab:fromData ObjectTrackData
    DTDFVocab:unit Meters, Velocity
]

instance EgoVehicleState : DTDFVocab:Data [
    base:desc "Real-time ego-vehicle state combining speed and steering angle data"
    DTDFVocab:fromData EgoVehicleStateData
    DTDFVocab:unit MetersPerSecond, Radians
]

instance PerceptionDataBundle : DTDFVocab:Data [
    base:desc "Bundle containing ego-vehicle state and detected object tracks for adaptive cruise control"
    DTDFVocab:fromData EgoVehicleState, ProcessedObjectTracks
]

instance HistoricalDataArchive : DTDFVocab:Data [
    base:desc "Archived historical data stored in SQL database for reporting and analysis"
    DTDFVocab:fromData SQLReportingModel
]

// C7: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware enabling modular communication between components in the decentralized digital twin architecture"
    DTDFVocab:enables DataCollectionService, DataTranslationService, VisualizationService, ComputationOffloadingService, RemoteManagementService
]

instance NVIDIAJetPack50SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for hardware integration and real-time processing on Jetson Orin Nano devices"
    DTDFVocab:enables ObjectTrackModel, VisualizationPipelineModel, ACCControlModel
]

instance Python38 : DTDFVocab:Enabler [
    base:desc "Python 3.8 programming language for rapid prototyping and custom algorithms in the digital twin"
    DTDFVocab:enables DataTranslationService, ComputationOffloadingService
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for complex simulations including point cloud clustering and ACC control logic"
    DTDFVocab:enables ObjectTrackModel, ACCControlModel
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL database system for storing historical data and generating reports"
    DTDFVocab:enables SQLReportingService
]

// C8: Services
instance DataCollectionService : DTDFVocab:Service [
    base:desc "Service aggregating real-time data streams (speed, steering, object tracks) from physical twin via ROS2"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance DataTranslationService : DTDFVocab:Service [
    base:desc "Service performing unit conversions and message type alignment between ROS2 topics for data consistency"
    DTDFVocab:provides DataConsistencyAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service providing real-time 3D visualization of ego-vehicle state and object tracks via visualization pipeline"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service delegating ACC control logic from vehicle ECUs to off-board hardware (Jetson Orin Nano) for resource optimization"
    DTDFVocab:provides PerformanceOptimizationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service enabling remote activation/deactivation of ACC and speed adjustments via user interface"
    DTDFVocab:provides RemoteControlAction
]

instance SQLReportingService : DTDFVocab:Service [
    base:desc "Service generating human-readable reports from historical data stored in SQL database"
    DTDFVocab:provides HistoricalAnalysisInsight
]

// C17: Insights/Actions
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of ego-vehicle state (speed, steering angle) and detected object tracks for operators"
]

instance DataConsistencyAction : DTDFVocab:Action [
    base:desc "Ensuring data consistency through unit conversions and message type alignment between ROS2 topics"
    DTDFVocab:IsAutomatic true
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D rendering of ego-vehicle paths and detected object tracks for adaptive cruise control testing"
]

instance PerformanceOptimizationAction : DTDFVocab:Action [
    base:desc "Delegating computationally intensive ACC control logic to off-board hardware for better performance"
    DTDFVocab:IsAutomatic true
]

instance RemoteControlAction : DTDFVocab:Action [
    base:desc "Remote activation/deactivation of ACC and speed adjustments via user interface"
    DTDFVocab:IsAutomatic false
]

instance HistoricalAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analysis of historical data for ACC performance optimization and maintenance predictions"
]

// C12: User Components
instance UserVisualizationFE : DTDFVocab:Component [
    base:desc "Frontend component handling 3D visualization of ego-vehicle state and object tracks for operators"
]

instance UserControlPanelFE : DTDFVocab:Component [
    base:desc "Frontend component managing remote activation/deactivation of ACC and speed adjustments"
]

instance UserReportingFE : DTDFVocab:Component [
    base:desc "Frontend component generating and displaying human-readable reports from SQL database"
]

// C13: Digital Twin Entity Components
instance CentralDigitalTwinEntity : DTDFVocab:Component [
    base:desc "Centralized Digital Twin Entity hosting data collection, reporting, and visualization components"
    DTDFVocab:contains DataCollectionFE, VisualizationPreProcessingFE, DataTranslationFE, SQLReportingFE
]

instance DataCollectionFE : DTDFVocab:Component [
    base:desc "Frontend component aggregating real-time data streams from physical twin via ROS2"
]

instance VisualizationPreProcessingFE : DTDFVocab:Component [
    base:desc "Frontend component pre-processing data for 3D rendering in the visualization pipeline"
]

instance DataTranslationFE : DTDFVocab:Component [
    base:desc "Frontend component performing unit conversions and message type alignment between ROS2 topics"
]

instance SQLReportingFE : DTDFVocab:Component [
    base:desc "Frontend component generating human-readable reports from stored historical data"
]

// C14: Physical Twin Entity Components
instance DistributedPhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Distributed Physical Twin Entity hosting point cloud processing and actuation components"
    DTDFVocab:contains JetsonOrinNanoProcessingNode, ActuationFE
]

instance JetsonOrinNanoProcessingNode : DTDFVocab:Component [
    base:desc "Processing node running on NVIDIA Jetson Orin Nano for point cloud clustering and tracking"
]

instance ActuationFE : DTDFVocab:Component [
    base:desc "Actuation Frontend executing speed control logic for ACC"
]

// C15: Environment
instance AutonomousVehicleEnvironment : DTDFVocab:Environment [
    base:contains LowerLevelChassisActuator, UpperLevelChassisActuator, HokuyoUST10LXLiDAR,
    IntelDeepsenseD435iDepthCamera, JetsonOrinNanoProcessingNode
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin interacts with the physical twin through **Wi-Fi communication** (UDP-based) for inter-entity control, transmitting commands such as enabling/disabling ACC, setting desired speed, or triggering emergency braking. The **Actuation FE** in the Physical Twin Entity converts these commands into motor voltage signals for the Vedder Electronic Speed Controller, ensuring low-latency actuation (≤100 ms end-to-end)."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin operates at a **real-time scale**, with synchronization requirements of **≤100 ms end-to-end latency** between the vehicle and DT Entity, aligned with 3GPP V2V communication standards. Clock synchronization is maintained to **±100 ms accuracy** across distributed devices to ensure event ordering and data integrity. The DT processes data at **perception cycle rates** (typically 10–30 Hz for LiDAR-based tracking) and executes control logic in response to user commands or real-time state updates."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation consists of three primary entities, mapped from ISO 23247: **1) Physical Twin Entity** (hosts sensor data processing, actuation, and middleware components like ROS2 nodes for LiDAR tracking and motor control); **2) Digital Twin Entity** (aggregates data collection, reporting, and visualization components; decomposes into **Data Collection FE**, **Reporting FE**, and **Presentation FE**); **3) User Entity** (split into **3D Visualization FE** and **Control Panel FE** for remote management). The **Data Translation FE** bridges inter-entity communication via ROS2/Wi-Fi networks, ensuring data alignment and unit consistency."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin spans **three lifecycle stages**: **Design Phase** (simulation and validation of ACC logic using MATLAB/Simulink and ROS2), **Manufacturing Phase** (retrofitting the 1/10th-scale autonomous vehicle with sensors and hardware), and **Operational Phase** (real-time monitoring, remote management, and computation offloading during vehicle testing). The DT covers the **as-operated** representation phase, focusing on runtime performance and safety validation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured through **real-time data streams** (LiDAR, cameras) and **high-precision sensor calibration** (e.g., DBSCAN/Kalman filtering for object tracking). Validation mechanisms include: **1) Latency Testing** (≤100 ms end-to-end for control commands); **2) Safety Validation** (ISO 15622 compliance for ACC performance class I); **3) Uncertainty Handling** (data translation FE mitigates unit inconsistencies); **4) Verification** (ROS2 node lifecycle management ensures robustness). The DT’s validity is confirmed via public demonstrations (YouTube video) and open-source artifacts (GitHub repository)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin connects to the physical twin via **ROS2-based intra-entity communication** (onboard) and **Wi-Fi UDP communication** (inter-entity). **Network Protocols**: ROS2 topics for data exchange, Wi-Fi for remote control commands. **Latency Requirements**: ≤100 ms end-to-end latency (3GPP V2V standard). **Clock Synchronization**: NTP-like mechanisms ensure ±100 ms accuracy across distributed devices. **Data Serialization**: The **Data Translation FE** standardizes message formats (e.g., ROS2 topics) and performs unit conversions (e.g., LiDAR coordinates to vehicle-local frames)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is deployed in a **hybrid architecture**: **Physical Twin Entity** components run on-board (Jetson Orin Nano) for real-time processing, while **Digital Twin Entity** and **User Entity** components are hosted externally (cloud/off-board) for computation offloading. **Hosting Technologies**: ROS2 middleware for intra-system communication, Wi-Fi for inter-entity connectivity. **Storage**: SQL databases store historical data externally to the vehicle."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The digital twin integrates with external systems via Wi-Fi for inter-entity communication. While the case study focuses on the ACC system, the architecture supports future expansion to other ADAS subsystems or external DTs via standardized protocols (e.g., ROS2). Cross-domain validation is demonstrated through adaptations of ISO 23247 for aerospace/battery systems, though no external DTs are directly integrated in this implementation."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin adheres to the following standards: **1) ISO 23247**: Reference architecture (RA) for DTs, adapted with the **Physical Twin Entity** (not defined in ISO 23247); **2) ISO 15622**: ACC performance requirements (performance class I); **3) ROS2**: Middleware for inter-component communication; **4) 3GPP 22.185**: Latency requirements for V2V communication (≤100 ms). The case study explores deviations from ISO 23247 (e.g., splitting User Interface FE) to address automotive-specific needs."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is ensured through strict latency constraints (<100 ms), clock synchronization (±100 ms), and adherence to ISO 15622 for ACC performance. Emergency braking commands are prioritized to prevent accidents. While ROS2/Wi-Fi communication may include TLS in general, this implementation does not explicitly mention security protocols. The system operates in a **Fully Autonomous Digital Twin with Human-in-the-Loop**, enabling remote management but with safeguards for critical operations."
]