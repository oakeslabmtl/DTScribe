// ----------------------------
// Sensing Components
// ----------------------------
instance LiDARHokuyoUST10LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing 2D laser point clouds on the autonomous vehicle"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance DepthCameraIntelRealSenseD435i : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D images"
    DTDFVocab:producedData DepthImageTransmitted
]

instance EgoSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Internal vehicle state sensor measuring ego speed"
    DTDFVocab:producedData EgoSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Internal vehicle state sensor measuring steering angle"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// ----------------------------
// Data Transmitted (Physical → Digital)
// ----------------------------
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARHokuyoUST10LX
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DepthCameraIntelRealSenseD435i
]

instance EgoSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ObjectTrackTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARHokuyoUST10LX
]

// ----------------------------
// Data Entities
// ----------------------------
instance PointCloudData : DTDFVocab:Data [
    base:desc "Raw point cloud data received from LiDAR"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo MATLABSimulinkProcessingEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image data from RealSense camera"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo MATLABSimulinkProcessingEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed measurement"
    DTDFVocab:fromData EgoSpeedTransmitted
    DTDFVocab:inputTo NVIDIAJetpack5SDKEnabler
]

instance VehicleSteeringData : DTDFVocab:Data [
    base:desc "Steering angle measurement of ego vehicle"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo NVIDIAJetpack5SDKEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Object track information derived from LiDAR clustering and tracking"
    DTDFVocab:fromData ObjectTrackTransmitted
    DTDFVocab:inputTo NVIDIAJetpack5SDKEnabler
]

// ----------------------------
// Models
// ----------------------------
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering model implemented in MATLAB/Simulink"
    DTDFVocab:inputTo MATLABSimulinkProcessingEnabler
]

instance KalmanFilterTrackerModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based multi‑object tracker implemented in MATLAB/Simulink"
    DTDFVocab:inputTo MATLABSimulinkProcessingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm compliant with ISO 15622 performance class I, running on NVIDIA Jetson Orin‑Nano"
    DTDFVocab:inputTo NVIDIAJetpack5SDKEnabler
]

// ----------------------------
// Enablers
// ----------------------------
instance ROS2DDSMiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 DDS middleware facilitating real‑time message exchange over Wi‑Fi"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance MATLABSimulinkProcessingEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment used for DBSCAN clustering and Kalman filter processing"
    DTDFVocab:enables DataMonitoringService
]

instance NVIDIAJetpack5SDKEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK providing GPU‑accelerated execution of ACC control and data handling"
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService
]

// ----------------------------
// Services
// ----------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI service displaying real‑time speed, steering angle, object tracks, projected path and generating reports"
    DTDFVocab:provides VehicleStateInsight, ObjectTracksInsight, ProjectedPathInsight, AnalyticalReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC control algorithm in the Digital Twin and returns control commands to the Physical Twin"
    DTDFVocab:provides ACCControlAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, adjust desired speed, and trigger emergency braking via UI"
    DTDFVocab:provides ACCEnableDisableAction, DesiredSpeedAdjustmentAction, EmergencyBrakingAction
]

// ----------------------------
// Insights
// ----------------------------
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Visual insight of current vehicle speed and steering angle"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Visualization of detected object tracks around the vehicle"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected future path of the ego vehicle based on ACC decisions and object proximity"
]

instance AnalyticalReportInsight : DTDFVocab:Insight [
    base:desc "Analytical report summarizing vehicle performance and environment interactions"
]

// ----------------------------
// Actions
// ----------------------------
instance ACCControlAction : DTDFVocab:Action [
    base:desc "Automatic ACC command (throttle/brake) generated by the control model"
    DTDFVocab:IsAutomatic true
]

instance ACCEnableDisableAction : DTDFVocab:Action [
    base:desc "Operator command to enable or disable the ACC function"
    DTDFVocab:IsAutomatic false
]

instance DesiredSpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Operator adjustment of the desired speed setpoint for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator‑initiated emergency braking command that overrides motor actuation"
    DTDFVocab:IsAutomatic false
]

// ----------------------------
// Acting Components
// ----------------------------
instance ElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder electronic speed controller receiving voltage commands for motor drive"
]

instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Servo motor controlling vehicle steering angle"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends desired speed set‑points, ACC enable/disable commands, speed‑modification commands, and emergency‑brake signals back to the Physical Twin Entity over Wi‑Fi; the Actuation FE converts these into motor voltage or servo commands for execution on the vehicle."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is designed for real‑time operation with a maximum end‑to‑end network latency of 100 ms and clock synchronization accuracy of 100 ms across all DTS components, matching the 3GPP 22.185 latency requirement for V2V services."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 reference model with a Physical Twin Entity, Digital Twin Entity, User Entity and a Cross‑System Data Translation FE; components are implemented as ROS 2 packages, communicating intra‑vehicle via ROS 2 and inter‑entity via Wi‑Fi, providing modularity and loose coupling."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity sensor data (LiDAR point clouds, depth images) are processed in real time; clock synchronization (≤100 ms) and latency limits ensure temporal fidelity; ACC behavior conforms to ISO 15622 specifications, providing functional validity for the 1/10‑scale test vehicle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Intra‑vehicle communication uses ROS 2 over DDS; inter‑entity communication uses a Wi‑Fi network with standardized interfaces (R1) for data translation and command exchange. No specific application‑layer protocol beyond ROS 2 messages is described."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the on‑board Jetson Orin Nano; the Digital Twin Entity (including ACC computation, data storage, and reporting) runs on an external compute platform (e.g., a PC or cloud server); the User Entity UI runs on a developer/operator workstation."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adheres to ISO 23247 (Digital Twin Manufacturing Framework) for architectural structuring, ISO 15622 for ACC functional requirements, and references ISO/IEC 30173 for digital‑twin terminology; optional OPC UA can be used for data translation but is not required in this implementation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by limiting network latency to 100 ms, ensuring clock sync within 100 ms, and including an emergency‑brake command; the DT is classified as a Fully Autonomous Digital Twin with Human‑in‑the‑Loop, highlighting the need for operator oversight in safety‑critical actions. Specific cybersecurity measures are not detailed in the document."
]