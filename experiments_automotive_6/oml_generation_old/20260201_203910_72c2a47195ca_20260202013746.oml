// C3: Physical sensing components
instance HokuyoUST110LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-110LX 2‑D LiDAR providing real‑time point‑clouds of the surrounding environment"
    DTDFVocab:producedData LiDARDataTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering RGB‑D frames for ego perception"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor suite reporting vehicle speed (m/s) and steering angle (rad) in real time"
    DTDFVocab:producedData EgoStateDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST110LXLiDAR
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

instance EgoStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// C5: Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑clouds (x,y,z) streamed at 10 Hz"
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo PointCloudClusteringTrackingModel
]

instance DepthCameraFrameData : DTDFVocab:Data [
    base:desc "Depth image frames (640×480) with associated RGB data at 30 Hz"
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo PointCloudClusteringTrackingModel
]

instance EgoVehicleStateData : DTDFVocab:Data [
    base:desc "Ego speed and steering angle values (m/s, rad) at 50 Hz"
    DTDFVocab:fromData EgoStateDataTransmitted
    DTDFVocab:inputTo ACCControlModel
]

// C10: Models/Data (Processing models)
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR/Depth point‑clouds followed by a Kalman filter to produce tracked object trajectories"
    DTDFVocab:inputTo ROS2DDSMiddlewareEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm (ISO 15622) that identifies the lead vehicle and computes a safe following speed"
    DTDFVocab:inputTo MATLABSimulinkACCEnabler
]

// C11: Enablers (software/tooling)
instance ROS2DDSMiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware with DDS transport used for real‑time data exchange and visualization pipelines"
    DTDFVocab:enables DataMonitoringService
]

instance MATLABSimulinkACCEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink runtime executing the ACC control model and exposing speed‑command services"
    DTDFVocab:enables ComputationOffloadingService
]

instance PythonRemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Python‑based UI layer handling operator commands (enable/disable ACC, adjust speed, emergency brake)"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service that visualizes real‑time vehicle state, projected path and tracked objects on the operator UI"
    DTDFVocab:provides RealTimeVisualizationInsight, PostRunReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service that runs the ACC algorithm off‑board and returns desired speed commands to the vehicle"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakeAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service allowing operators to remotely enable/disable ACC, set a desired speed, or trigger emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Operators receive real‑time visualizations and reports of vehicle state and object tracks"
]

instance PostRunReportInsight : DTDFVocab:Insight [
    base:desc "Generated time‑series reports of vehicle state and object tracks for post‑run analysis"
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to activate Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to deactivate Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets a new desired cruising speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers immediate vehicle stop via emergency braking"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT, including the ACC‑computed desired speed, enable/disable ACC signals, and emergency‑brake commands, which are applied by the Actuation FE to the motor and steering actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT is required to maintain an end‑to‑end communication latency of ≤100 ms from vehicle to DT and to keep clocks synchronized within 100 ms accuracy, enabling real‑time off‑loading of the ACC function."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall DT is orchestrated as a set of ROS 2 packages representing Functional Entities (Data Collection FE, Presentation FE, Controlling FE, Actuation FE, User Interface FE, Data Translation FE) deployed across the Physical Twin Entity, Digital Twin Entity, User Entity, and a Cross‑System Entity for data translation, communicating intra‑entity via ROS 2 and inter‑entity via Wi‑Fi."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT operates under real‑time constraints (≤100 ms latency, 100 ms clock sync) and complies with ISO 15622 ACC functional requirements; high‑fidelity perception is achieved using DBSCAN and Kalman filtering of LiDAR data, and safety is addressed by limiting the ACC to performance class I on the scaled vehicle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication between PT and DT uses a Wi‑Fi link; intra‑entity communication among functional entities uses ROS 2 over DDS, with a Data Translation FE handling serialization and unit conversion of messages."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the vehicle’s Jetson Orin Nano; the Digital Twin Entity (ACC computation, data storage, visualization preprocessing) runs on a separate edge or cloud server; the User Entity (UI) runs on a workstation; each entity is packaged as a ROS 2 node set."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT architecture follows ISO 23247 Part 2 (reference architecture) and implements the ACC function per ISO 15622; the design also references ISO/IEC 30173:2023 for digital‑twin concepts and mentions OPC UA (IEC 62541) as a possible communication standard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by adhering to the latency (≤100 ms) and clock‑sync (≤100 ms) requirements, using ISO 15622 ACC specifications, and providing an emergency‑brake command; although explicit cybersecurity mechanisms are not described, the DT assumes controlled Wi‑Fi communication and structured ROS 2 messaging to mitigate safety risks."
]