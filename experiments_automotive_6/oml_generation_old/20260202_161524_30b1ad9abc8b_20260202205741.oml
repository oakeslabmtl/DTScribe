    DTDFVocab:inputTo SensorFusionEnabler, VisualizationEnabler
]

instance DrivingPathProjectionProcessed : DTDFVocab:Data [
    base:desc "Processed driving path projection data overlaid on virtual maps or sensor feeds, used for real-time ACC visualization and path planning."
