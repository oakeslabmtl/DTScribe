    base:contains CommunicationEnabler, DataTranslationEnabler
]

instance AccControlComponent : DTDFVocab:Component [
    base:desc "Hybrid ACC control system combining on-board actuation with cloud-based computation for adaptive cruise control in urban/suburban driving scenarios."
