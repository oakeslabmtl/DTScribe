    base:desc "Structured object-centric data including spatial-temporal metadata (velocity, distance, confidence scores) derived from sensor fusion of LiDAR, radar, and camera inputs."
]

instance DrivingPathProjectionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CameraSensor
    base:desc "Projected driving path data overlaid on virtual maps or sensor feeds, generated from camera-based path projection for ACC visualization."
]

// C10: Models/Data
instance AccDigitalModel : DTDFVocab:Model [
    base:desc "PID-based or model predictive control algorithm for adaptive cruise control, executed in the Digital Twin System to calculate desired speed based on relative distance, traffic density, and user-defined speed limits."
    DTDFVocab:inputTo SensorFusionEnabler, CloudComputeEnabler
]

instance ObjectDetectionModel : DTDFVocab:Model [
    base:desc "Sensor fusion model combining LiDAR, radar, and camera data to identify and track lead vehicles, pedestrians, and obstacles with spatial-temporal metadata."
    DTDFVocab:inputTo SensorFusionEnabler, DataPreprocessingEnabler
]

instance PathProjectionModel : DTDFVocab:Model [
    base:desc "Computer vision model processing camera data to project driving paths and overlay them on virtual maps or sensor feeds for ACC visualization."
    DTDFVocab:inputTo DataPreprocessingEnabler, VisualizationEnabler
]

instance RealTimeVehicleStateData : DTDFVocab:Data [
    base:desc "Real-time vehicle state data including speed, acceleration, chassis angles, and motor/steering servo status, transmitted via Wi-Fi over UDP at 10-100Hz frequencies."
    DTDFVocab:fromData VehicleStateData
    DTDFVocab:inputTo VisualizationEnabler, ControlPanelEnabler
]

instance HistoricalVehicleData : DTDFVocab:Data [
    base:desc "Persisted raw and processed vehicle data stored in local/remote repositories for post-mortem analysis and performance metric generation."
