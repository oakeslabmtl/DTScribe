instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:contains LidarSensor, RadarSensor, CameraSensor, VehicleStateSensor, EnvironmentalSensor, VehicleAccuator, RemoteEmergencyBrakeActuator, AccControlActuator
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains SensorFusionEnabler, DataPreprocessingEnabler, CloudComputeEnabler, DataPersistenceEnabler, ReportingEnabler, VisualizationEnabler, ControlPanelEnabler, DataTranslationEnabler, CommunicationEnabler, SimulationEnabler
]

