// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "On‑board Hokuyo UST‑10LX LiDAR providing raw point‑cloud data for object detection"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering depth frames"
    DTDFVocab:producedData DepthFrameTransmitted
]

instance EgoSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Internal vehicle sensor measuring ego speed for ACC"
    DTDFVocab:producedData EgoSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Internal vehicle sensor measuring steering angle for ACC"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthFrameTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]

instance EgoSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C10: Data
instance LiDARPointCloud : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream transmitted over Wi‑Fi"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo PreProcessingEnabler
]

instance DepthCameraFrame : DTDFVocab:Data [
    base:desc "Depth camera frame used for 3‑D visualization"
    DTDFVocab:fromData DepthFrameTransmitted
    DTDFVocab:inputTo VisualizationEnabler
]

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed measurement used by ACC and reporting"
    DTDFVocab:fromData EgoSpeedTransmitted
    DTDFVocab:inputTo ACCControlEnabler, ReportingEnabler, DataStorageEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle measurement used by ACC and reporting"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo ACCControlEnabler, ReportingEnabler, DataStorageEnabler
]

// C10: Models
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering followed by Kalman filter to generate object‑track descriptors"
    DTDFVocab:inputTo PreProcessingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "ACC control model (lead‑vehicle detection and speed computation per ISO 15622)"
    DTDFVocab:inputTo ACCControlEnabler
]

instance VisualizationPreprocessingModel : DTDFVocab:Model [
    base:desc "3‑D visualization preprocessing for UI rendering of vehicle state and tracks"
    DTDFVocab:inputTo VisualizationEnabler
]

instance ReportingModel : DTDFVocab:Model [
    base:desc "Formats time‑series vehicle state and object‑track data for UI reports"
    DTDFVocab:inputTo ReportingEnabler
]

instance DataStorageModel : DTDFVocab:Model [
    base:desc "Persists tracks and vehicle state in a SQL database"
    DTDFVocab:inputTo DataStorageEnabler
]

// C11: Enablers
instance DataCollectingEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 package that collects sensor streams and forwards them via Wi‑Fi"
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 package that serializes sensor data and translates it for DT consumption"
    DTDFVocab:enables DataMonitoringService
]

instance PreProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Executes PointCloudClusteringTrackingModel to produce object‑track descriptors"
    DTDFVocab:enables DataMonitoringService
]

instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "Runs ACCControlModel and returns speed commands to the vehicle"
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Runs VisualizationPreprocessingModel for UI 3‑D rendering"
    DTDFVocab:enables DataMonitoringService
]

instance ReportingEnabler : DTDFVocab:Enabler [
    base:desc "Executes ReportingModel to generate historical analysis reports"
    DTDFVocab:enables RemoteManagementService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Executes DataStorageModel to persist vehicle state and tracks"
    DTDFVocab:enables RemoteManagementService
]

instance ActuationEnabler : DTDFVocab:Enabler [
    base:desc "Sends motor voltage and steering servo commands, and emergency‑braking signals to vehicle hardware"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualizes real‑time vehicle state, projected path and object tracks"
    DTDFVocab:provides RealTimeVehicleStateInsight, ProjectedPathInsight, ObjectTracksInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC control logic runs in the DT and returns speed commands to the vehicle"
    DTDFVocab:provides ACCDecisionInsight, AdjustACCParametersAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator UI enables/disables ACC, adjusts desired speed, and triggers emergency braking"
    DTDFVocab:provides AdjustACCParametersAction, TriggerEmergencyBrakingAction, SetMotorVoltageCommandAction
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "UI displays current ego speed and steering angle in real time"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "UI shows projected vehicle path based on ACC computation"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "UI visualizes LiDAR‑derived object tracks and their predicted trajectories"
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "ACC model decides desired speed based on lead‑vehicle detection"
]

// C17: Actions
instance AdjustACCParametersAction : DTDFVocab:Action [
    base:desc "Operator adjusts desired ACC speed or toggles ACC enable state"
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator initiates emergency braking, sending stop command to ESC"
    DTDFVocab:IsAutomatic false
]

instance SetMotorVoltageCommandAction : DTDFVocab:Action [
    base:desc "DT sends motor voltage command to ESC for vehicle actuation"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends desired speed set‑points, ACC enable/disable commands, and emergency‑braking signals to the PT via the Data Translation FE and Actuation FE, again over Wi‑Fi and ROS 2 messaging."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "End‑to‑end communication latency is limited to ≤ 100 ms (R7) and all distributed clocks are synchronized to an accuracy of 100 ms (R8), satisfying real‑time requirements for ACC off‑loading."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An ISO 23247‑based architecture realized with ROS 2 packages: Physical Twin Entity hosts sensor processing and actuation FEs, Digital Twin Entity hosts data collection, presentation, ACC control and reporting FEs, User Entity provides 3D visualization and control‑panel UI FEs, and Cross‑System Entity provides data‑translation FE; entities communicate over ROS 2 intra‑node links and Wi‑Fi inter‑entity links."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT is intended as a high‑fidelity, real‑time computational reflection of the PT; fidelity is ensured by using raw LiDAR point clouds, DBSCAN/Kalman tracking, and ACC logic per ISO 15622; validity is enforced through latency ≤ 100 ms and clock sync ≤ 100 ms to maintain safe control loops."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication between PT and DT over a Wi‑Fi LAN using ROS 2 (DDS) transport; Data Translation FE performs serialization, message‑type alignment and unit conversion for all streams."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the vehicle‑mounted Jetson Orin Nano; Digital Twin Entity and User Entity run on external compute (e.g., a workstation or cloud instance); each functional entity is packaged as a ROS 2 node."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) for entity/FE structuring, ISO 15622 for ACC functionality, ISO/IEC 30173:2023 for DT terminology, and 3GPP TS 22.185 for the ≤ 100 ms latency requirement."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical operation is addressed by adhering to ISO 15622 ACC specifications, enforcing ≤ 100 ms latency and clock sync to avoid control delays, and providing an emergency‑braking command; explicit cybersecurity measures are not described in the document."
]