// C3: Physical Sensing Components
instance LidarSensor : DTDFVocab:SensingComponent [
    base:desc "Collects raw point cloud data for vehicle environment perception using LiDAR technology with high-resolution 3D spatial mapping capabilities"
    DTDFVocab:producedData LidarPointCloudData
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors vehicle operational parameters including motor actuation, steering servo angles, and driving dynamics for real-time state tracking"
    DTDFVocab:producedData VehicleStateMetrics
]

instance ThermalManagementSensor : DTDFVocab:SensingComponent [
    base:desc "Measures battery thermal characteristics including temperature gradients and thermal stress points for SoC/SoH estimation"
    DTDFVocab:producedData BatteryThermalData
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Captures vibration signatures from rotating machinery components to enable predictive failure analysis"
    DTDFVocab:producedData MachineryVibrationData
]

instance CollisionAvoidanceSensor : DTDFVocab:SensingComponent [
    base:desc "Detects space debris and satellite trajectories for on-orbit collision avoidance using sensor payload data"
    DTDFVocab:producedData OrbitalTrajectoryData
]

instance PhysiologicalSensor : DTDFVocab:SensingComponent [
    base:desc "Collects biological signals (ECG, EEG) for cyber-biophysical system monitoring and physiological response prediction"
    DTDFVocab:producedData BiologicalSignalData
]

// C4: Physical-to-Virtual Interaction
instance LidarPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LidarSensor
]

instance VehicleStateMetrics : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance BatteryThermalData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ThermalManagementSensor
]

instance MachineryVibrationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
]

instance OrbitalTrajectoryData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CollisionAvoidanceSensor
]

instance BiologicalSignalData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysiologicalSensor
]

// C10: Models/Data
instance PointCloudProcessingModel : DTDFVocab:Model [
    base:desc "Clusters and tracks raw LiDAR point clouds into structured object tracks and driving path projections for ACC monitoring"
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance VehicleStateModel : DTDFVocab:Model [
    base:desc "Simulates vehicle dynamics including motor actuation, steering responses, and environmental interactions for real-time state prediction"
    DTDFVocab:inputTo StateAnalysisEnabler
]

instance BatteryDegradationModel : DTDFVocab:Model [
    base:desc "Combines physics-based degradation models with ML-driven aging forecasts for SoC/SoH prediction in battery systems"
    DTDFVocab:inputTo BatteryManagementEnabler
]

instance VibrationAnalysisModel : DTDFVocab:Model [
    base:desc "Analyzes vibration signatures to predict rotating machinery failures using spectral analysis and machine learning techniques"
    DTDFVocab:inputTo PredictiveMaintenanceEnabler
]

instance TrajectoryPredictionModel : DTDFVocab:Model [
    base:desc "Predicts satellite trajectories and collision risks using digital twin simulations of orbital mechanics and space debris clouds"
    DTDFVocab:inputTo CollisionAvoidanceEnabler
]

instance PhysiologicalResponseModel : DTDFVocab:Model [
    base:desc "Simulates cardiac electrophysiology and physiological responses using probabilistic models to handle biological variability"
    DTDFVocab:inputTo CyberBiophysicalEnabler
]

instance ProcessSimulationModel : DTDFVocab:Model [
    base:desc "Couples multi-physics simulations of thermal, electrical, and mechanical domains for manufacturing process optimization"
    DTDFVocab:inputTo ManufacturingSimulationEnabler
]

instance LidarData : DTDFVocab:Data [
    base:desc "Processed 3D point cloud data used for object detection, path planning, and collision avoidance in autonomous systems"
    DTDFVocab:fromData LidarPointCloudData
    DTDFVocab:inputTo PointCloudProcessingEnabler, VisualizationEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Real-time vehicle state metrics including motor actuation, steering angles, and driving dynamics for control and monitoring"
    DTDFVocab:fromData VehicleStateMetrics
    DTDFVocab:inputTo StateAnalysisEnabler, ControlEnabler
]

instance BatteryThermalDataProcessed : DTDFVocab:Data [
    base:desc "Processed thermal data including temperature gradients and stress points used for battery health prediction and thermal management"
    DTDFVocab:fromData BatteryThermalData
    DTDFVocab:inputTo BatteryManagementEnabler
]

instance VibrationDataProcessed : DTDFVocab:Data [
    base:desc "Analyzed vibration signatures used for predictive maintenance and failure prediction in rotating machinery"
    DTDFVocab:fromData MachineryVibrationData
    DTDFVocab:inputTo PredictiveMaintenanceEnabler
]

instance TrajectoryDataProcessed : DTDFVocab:Data [
    base:desc "Processed orbital trajectory data used for collision avoidance and space debris detection simulations"
    DTDFVocab:fromData OrbitalTrajectoryData
    DTDFVocab:inputTo CollisionAvoidanceEnabler
]

instance BiologicalDataProcessed : DTDFVocab:Data [
    base:desc "Processed biological signals used for physiological response prediction and cyber-biophysical system monitoring"
    DTDFVocab:fromData BiologicalSignalData
    DTDFVocab:inputTo CyberBiophysicalEnabler
]

// C11: Enablers
instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2-based data processing pipeline for clustering and tracking LiDAR point clouds with real-time object detection capabilities"
    DTDFVocab:enables ObjectDetectionService, PathProjectionService
]

instance StateAnalysisEnabler : DTDFVocab:Enabler [
    base:desc "Real-time state analysis engine using ROS2 for vehicle dynamics simulation and state prediction"
    DTDFVocab:enables VehicleStateMonitoringService, AdaptiveControlService
]

instance BatteryManagementEnabler : DTDFVocab:Enabler [
    base:desc "Battery health management system integrating thermal modeling, SoC/SoH estimation, and degradation prediction algorithms"
    DTDFVocab:enables BatteryHealthMonitoringService, ThermalManagementService
]

instance PredictiveMaintenanceEnabler : DTDFVocab:Enabler [
    base:desc "Predictive maintenance platform using vibration analysis and machine learning for failure prediction in rotating machinery"
    DTDFVocab:enables MachineryHealthMonitoringService, FailurePredictionService
]

instance CollisionAvoidanceEnabler : DTDFVocab:Enabler [
    base:desc "Satellite collision avoidance system using trajectory prediction models and real-time orbital mechanics simulations"
    DTDFVocab:enables CollisionRiskAssessmentService, TrajectoryOptimizationService
]

instance CyberBiophysicalEnabler : DTDFVocab:Enabler [
    base:desc "Cyber-biophysical system enabler integrating physiological sensors with probabilistic models for response prediction"
    DTDFVocab:enables PhysiologicalResponseService, MedicalDeviceMonitoringService
]

instance ManufacturingSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Multi-physics simulation platform for manufacturing process optimization using COMSOL Multiphysics and ANSYS"
    DTDFVocab:enables ProcessOptimizationService, QualityControlService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data serialization and translation service performing unit conversions and message alignment for cross-system data integration"
    DTDFVocab:enables DataIntegrationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D/4D visualization platform using Unreal Engine for immersive digital twin state representation"
    DTDFVocab:enables VisualizationService, ARMaintenanceService
]

instance ControlEnabler : DTDFVocab:Enabler [
    base:desc "Model Predictive Control system integrating digital twin simulations with real-time ECU updates for autonomous systems"
    DTDFVocab:enables AutonomousControlService, AdaptiveControlService
]

