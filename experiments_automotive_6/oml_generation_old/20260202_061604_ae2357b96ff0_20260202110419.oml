// C3: Physical sensing components
instance LiDARSensorHokuyoUST10LX : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor (Hokuyo UST‑10LX) delivering high‑resolution point‑clouds for object detection."
    DTDFVocab:producedData LiDARPointCloudTransmission
]

instance DepthCameraIntelD435i : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera providing RGB‑D point‑clouds for supplementary perception."
    DTDFVocab:producedData DepthCameraPointCloudTransmission
]

instance InertialOdometryEgoStateSensor : DTDFVocab:SensingComponent [
    base:desc "Inertial and odometry sensor suite yielding ego vehicle speed and steering angle."
    DTDFVocab:producedData EgoStateDataTransmission
]

// C4: Data transmitted from sensors
instance LiDARPointCloudTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensorHokuyoUST10LX
]

instance DepthCameraPointCloudTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DepthCameraIntelD435i
]

instance EgoStateDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InertialOdometryEgoStateSensor
]

// C10: Data derived from transmissions
instance RawLiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data captured at 10 Hz, unprocessed."
    DTDFVocab:fromData LiDARPointCloudTransmission
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance RawDepthCameraPointCloudData : DTDFVocab:Data [
    base:desc "Raw depth‑camera point‑cloud data captured at 30 Hz, unprocessed."
    DTDFVocab:fromData DepthCameraPointCloudTransmission
    DTDFVocab:inputTo DataTranslationEnabler
]

instance EgoStateData : DTDFVocab:Data [
    base:desc "Vehicle ego speed and steering angle data, timestamped by the on‑board controller."
    DTDFVocab:fromData EgoStateDataTransmission
    DTDFVocab:inputTo ACCComputationEnabler
]

// C10: System models
instance DBSCANModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering model for generating spatial clusters from LiDAR point‑cloud."
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance KalmanFilterModel : DTDFVocab:Model [
    base:desc "Kalman filter for tracking object clusters across successive frames."
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance ACCISO15622Model : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model compliant with ISO 15622 performance class I."
    DTDFVocab:inputTo ACCComputationEnabler
]

instance ThreeDVisualizationModel : DTDFVocab:Model [
    base:desc "3‑D visualization model that renders car state and object tracks."
    DTDFVocab:inputTo VisualizationEnabler
]

instance SQLDatabaseModel : DTDFVocab:Model [
    base:desc "SQL database schema for time‑series persistence of sensor and control data."
    DTDFVocab:inputTo PersistenceEnabler
]

instance DataTranslationModel : DTDFVocab:Model [
    base:desc "Data translation model for aligning units and message types across FE boundaries."
    DTDFVocab:inputTo DataTranslationEnabler
]

// C11: Functional Enablers
instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for clustering and tracking using DBSCAN and Kalman filter models."
    DTDFVocab:enables ClusteringTrackingService, LiDARMonitoringService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for ACC computation per ISO 15622 using lead vehicle detection and desired speed calculation."
    DTDFVocab:enables ACCComputationService, EgoStateMonitoringService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for rendering vehicle state and object tracks in a 3‑D UI."
    DTDFVocab:enables ThreeDVisualizationService
]

instance PersistenceEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for persisting sensor and control data in a SQL database."
    DTDFVocab:enables DataPersistenceService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [ 
    base:desc "Enabler for aligning data units and types across the digital twin boundary."
    DTDFVocab:enables DataTranslationService, DepthCameraMonitoringService
]

instance ActuationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for converting ACC outputs into motor voltage, steering servo, and emergency braking signals."
    DTDFVocab:enables ActuationService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for remote ACC parameter modification and emergency braking via user interface."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance LiDARMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of LiDAR data streams and detection of anomalies."
    DTDFVocab:provides LiDARMonitoringInsight
]

instance DepthCameraMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of depth‑camera data streams and detection of anomalies."
    DTDFVocab:provides DepthCameraMonitoringInsight
]

instance EgoStateMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of vehicle ego speed and steering angle."
    DTDFVocab:provides EgoStateMonitoringInsight
]

instance ClusteringTrackingService : DTDFVocab:Service [
    base:desc "Service that performs DBSCAN clustering and Kalman tracking of LiDAR point‑clouds."
    DTDFVocab:provides ObjectTrackInsight
]

instance ACCComputationService : DTDFVocab:Service [
    base:desc "Service that computes desired speed and generates ACC control signals."
    DTDFVocab:provides ACCControlAction
]

instance ThreeDVisualizationService : DTDFVocab:Service [
    base:desc "Service that renders 3‑D vehicle state, object tracks, and projected path."
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance DataPersistenceService : DTDFVocab:Service [
    base:desc "Service that writes sensor and control data to an SQL database for later analysis."
    DTDFVocab:provides PerformanceReportInsight
]

instance DataTranslationService : DTDFVocab:Service [
    base:desc "Service that aligns units and message types across FE boundaries."
    DTDFVocab:provides TranslatedDataInsight
]

instance ActuationService : DTDFVocab:Service [
    base:desc "Service that translates ACC computed desired speed into motor voltage and steering commands, and triggers emergency brake."
    DTDFVocab:provides MotorVoltageCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service that allows a user to enable/disable ACC, adjust desired speed, and issue emergency brake remotely."
    DTDFVocab:provides AdjustDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance LiDARMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight into LiDAR sensor health, point‑cloud density, and latency."
]

instance DepthCameraMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight into depth‑camera performance, image quality, and data integrity."
]

instance EgoStateMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight into vehicle speed and steering angle consistency."
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Insight into the number, position, and trajectory of detected object clusters."
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visual representation of vehicle state and object tracks."
]

instance PerformanceReportInsight : DTDFVocab:Insight [
    base:desc "Aggregated performance metrics and historical reports from persisted data."
]

instance TranslatedDataInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful unit and format alignment of transmitted data."
]

// C17: Actions
instance ACCControlAction : DTDFVocab:Action [
    base:desc "Accelerator displacement command computed by the ACC control loop."
    DTDFVocab:IsAutomatic true
]

instance MotorVoltageCommandAction : DTDFVocab:Action [
    base:desc "Motor voltage command converted from desired speed by the actuation component."
    DTDFVocab:IsAutomatic true
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "User–initiated adjustment of desired cruising speed."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Emergency braking command issued by the remote management service."
    DTDFVocab:IsAutomatic false
]

// C17: Environment
instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:contains LiDARSensorHokuyoUST10LX, DepthCameraIntelD435i, InertialOdometryEgoStateSensor
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains PointCloudProcessingEnabler, ACCComputationEnabler, VisualizationEnabler, PersistenceEnabler, DataTranslationEnabler, ActuationEnabler, RemoteManagementEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital twin generates desired speed commands, safety braking actions, and ACC enable/disable signals which are transmitted via the Actuation FE to the PT’s motor drivers and steering servos; all control messages sent over the same Wi‑Fi link using the ROS 2 middleware."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with end‑to‑end latency ≤100 ms, clock synchronization within 100 ms accuracy; ACC loop and data acquisition occur at the vehicle’s perception cycle (≈30–60 Hz) with the DT processing and publishing outputs within a few milliseconds to satisfy R7."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated by the ISO 23247 RA with added Physical Twin Entity; the DT constellation includes the PT’s hardware, the edge server running the Digital Twin Entity, the client user interface host, and the cross‑system Data Translation component facilitating message serialization; all entities interact over ROS 2 topics over a Wi‑Fi network."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Engineering cycle comprising requirement definition (R1–R8), architectural design based on ISO 23247 reference architecture, implementation via ROS 2 packages and MATLAB/Simulink, deployment onto vehicle and edge server, and operational validation/testing of real‑time ACC off‑loading; the DT covers the vehicle’s operating phase (as operated)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity real‑time data acquisition and low latency ensures the DT behaves consistently with the PT; DBSCAN clustering and Kalman filter tracking provide confidence bounds; Data Translation guarantees unit consistency; compliance with ISO 15622 validates ACC control logic; no explicit statistical validation reported."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication occurs over a Wi‑Fi network using ROS 2 transport. Within entities, ROS 2 topics deliver packets between functional‑entity ROS 2 nodes. The Data Translation FE consistently serialises and aligns messages, but no DDS or NTP details are specified in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity physically embedded on the vehicle; Digital Twin Entity deployed on an external edge/server (CPU / GPU); User Entity runs on a client workstation; the Data Storage FE uses a cloud‑hosted SQL database; all components communicate over Wi‑Fi."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not explicitly described in the document; no integration to external information systems beyond the DT’s own UI and data streams."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture provides the DT structural template; ISO 15622 specifies the ACC control algorithm; ROS 2 is used as middleware; IEEE 3GPP 22.185 defines the 100 ms latency requirement for V2V communication."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical requirements: end‑to‑end latency ≤100 ms (R7), clock synchronization ≤100 ms (R8), ACC logic compliant with ISO 15622; emergency braking command provides fail‐safe override; however, explicit cybersecurity measures (authentication, encryption) are not detailed in the document."
]