// C3: Physical sensing components
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing 2‑D point clouds sampled in real time on Jetson Orin Nano"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera providing 3‑D perception data sampled in real time on Jetson Orin Nano"
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring vehicle speed sampled in real time on Jetson Orin Nano"
    DTDFVocab:producedData SpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring steering angle sampled in real time on Jetson Orin Nano"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C10: Data (following mandatory flow)
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "2‑D point cloud data from LiDAR used for object clustering and tracking"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataCollectionFEModule
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "3‑D depth image data from depth camera used for perception"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo DataCollectionFEModule
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed measurement used by ACC control and UI monitoring"
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo ActuationFEModule, DataCollectionFEModule
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle measurement used by UI monitoring and path projection"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo ActuationFEModule, DataCollectionFEModule
]

// C10: Models (supporting the DT)
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point clouds to identify object blobs"
]

instance KalmanTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking of clustered objects to produce continuous object tracks"
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm per ISO 15622 for lead‑vehicle detection and speed set‑point computation"
]

// C11: Enablers
instance DataCollectionFEModule : DTDFVocab:Enabler [
    base:desc "Collects object tracks and vehicle state from perception models for downstream services"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance ActuationFEModule : DTDFVocab:Enabler [
    base:desc "Converts desired speed and steering commands from DT into motor voltage and servo signals"
    DTDFVocab:enables RemoteManagementService, ComputationOffloadingService
]

instance ROS2DDSMiddleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware with DDS transport enabling intra‑entity communication over Wi‑Fi"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Serialises, unit‑converts and aligns messages before delivery across twins"
    DTDFVocab:enables DataMonitoringService
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL database persisting vehicle state, object tracks and generated reports"
    DTDFVocab:enables DataMonitoringService
]

instance ReportGenerator : DTDFVocab:Enabler [
    base:desc "Generates time‑series reports for post‑run analysis and parameter tuning"
    DTDFVocab:enables DataMonitoringService
]

instance ROS2PackageFE : DTDFVocab:Enabler [
    base:desc "ROS2 packages per Functional Entity implementing communication and logic"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance Python38Runtime : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime for rapid prototyping of perception and control code"
    DTDFVocab:enables ComputationOffloadingService
]

instance CppRuntime : DTDFVocab:Enabler [
    base:desc "C++ runtime for performance‑critical code such as ACC"
    DTDFVocab:enables ComputationOffloadingService
]

instance MATLABSimulinkTool : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink used for clustering and tracking model development"
    DTDFVocab:enables DataCollectionFEModule
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualises real‑time speed, steering angle, object tracks and projected path; stores reports"
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTracksInsight, ProjectedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC algorithm on the Digital Twin instead of the vehicle ECU"
    DTDFVocab:provides ACCDecisionInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, adjust desired speed, and trigger emergency braking via UI"
    DTDFVocab:provides EmergencyBrakingAction, ACCEnableAction, SpeedSetpointAction
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time UI provides operators with vehicle speed and steering angle"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "UI visualises object tracks derived from LiDAR clustering and Kalman tracking"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "UI shows projected vehicle path based on current state and ACC decisions"
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "ACC algorithm determines speed set‑point and lead‑vehicle detection per ISO 15622"
]

// C17: Actions
instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Rapid reverse motor voltage command to stop vehicle in emergency"
    DTDFVocab:IsAutomatic false
]

instance ACCEnableAction : DTDFVocab:Action [
    base:desc "Operator command to enable or disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SpeedSetpointAction : DTDFVocab:Action [
    base:desc "Operator adjusts desired speed set‑point for ACC"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder ESC driving motor speed based on voltage commands from the Actuation FE"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Servo controlling steering angle based on commands from the Actuation FE"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Rapid reverse voltage applied to motor for emergency braking"
]

// C8: Environments (Twins)
instance PhysicalTwinEntity : DTDFVocab:Environment [
    base:contains HokuyoUST10LXLidar, IntelDeepSenseD435iDepthCamera, VehicleSpeedSensor, SteeringAngleSensor,
                MotorActuator, SteeringServoActuator, ROS2DDSMiddleware, DataCollectionFEModule
]

instance DigitalTwinEntity : DTDFVocab:Environment [
    base:contains PointCloudClusteringModel, KalmanTrackingModel, ACCControlModel,
                ActuationFEModule, DataTranslationFE, SQLDatabase, ReportGenerator, ROS2DDSMiddleware,
                ROS2PackageFE, Python38Runtime, CppRuntime, MATLABSimulinkTool
]

instance UserEntity : DTDFVocab:Environment [
    base:contains DataMonitoringService, RemoteManagementService, ComputationOffloadingService, ROS2DDSMiddleware
]

instance CrossSystemEntity : DTDFVocab:Environment [
    base:contains DataTranslationFE, DataCollectionFEModule
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends ACC control commands (desired speed) and remote‑management commands (enable/disable ACC, modify desired speed, emergency brake) back to the PT over ROS2/Wi‑Fi; Actuation FE on the Physical Twin Entity translates these commands into motor voltage and steering servo signals."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "End‑to‑end communication latency bounded to ≤100 ms (R7) with clock synchronisation accuracy of 100 ms (R8); data collection and ACC computation occur at real‑time rates sufficient for the perception‑control loop of the 1/10‑scale vehicle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated ISO 23247‑based architecture: Physical Twin Entity hosts sensors/actuators and Data Pre‑Processing/Actuation FEs; Digital Twin Entity hosts Data Collection, Presentation, Reporting, Controlling (ACC) FEs; User Entity hosts User Interface FE split into 3D visualization and control panel; Cross‑System Entity provides Data Translation FE linking the twins."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the operational stage (runtime monitoring, control and remote management) and the development/testing stage (data collection, ACC algorithm validation, UI prototyping)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity perception via LiDAR point‑cloud clustering (DBSCAN) and Kalman filtering; ACC logic adheres to ISO 15622 specifications; latency ≤100 ms and clock sync ≤100 ms ensure temporal fidelity; data stored externally to avoid on‑board storage limits; no explicit V&V procedures reported."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication over Wi‑Fi using ROS2/DDS; Data Translation FE handles message serialization and unit conversion; standardized communication interface enforced by requirement R1 (modular, loosely‑coupled ROS2 topics)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the Jetson Orin Nano on the vehicle; Digital Twin Entity runs on an external compute platform (e.g., cloud or workstation) hosting ROS2 nodes for ACC and data services; User Entity runs on a separate workstation providing the UI; each entity deployed on distinct hardware."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Implements ISO 23247 reference architecture (entities and Functional Entities), ISO 15622 for ACC behavior, ISO/IEC 30173:2023 concepts, and uses ROS2 (DDS) as a de‑facto standard for communication; optional OPC UA mentioned but not adopted."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical nature acknowledged; latency ≤100 ms and clock sync ≤100 ms required to maintain safe control; remote management commands are gated through the User Interface FE; no specific cybersecurity mechanisms (e.g., authentication, encryption) described."
]