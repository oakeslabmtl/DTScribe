// ----------------------------------------------------
// C3: Physical sensing components (derived from characteristics)
// ----------------------------------------------------
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor streaming 3‑D point‑cloud data from the physical autonomous vehicle"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting motor current, RPM and health status of the vehicle"
    DTDFVocab:producedData MotorStatusTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor providing the steering wheel angular position"
    DTDFVocab:producedData SteeringAngleTransmitted
]

instance ServoPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor exposing servo actuator positions for wheel and throttle control"
    DTDFVocab:producedData ServoPositionTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Composite sensor delivering overall vehicle state (velocity, pose, battery level, etc.)"
    DTDFVocab:producedData VehicleStateTransmitted
]

// ----------------------------------------------------
// C4: Physical-to-virtual data transmission
// ----------------------------------------------------
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance MotorStatusTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ServoPositionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ServoPositionSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// ----------------------------------------------------
// C10: Data instances (post‑translation)
// ----------------------------------------------------
instance LiDARObjectTracksData : DTDFVocab:Data [
    base:desc "Clustered object tracks derived from raw LiDAR point‑cloud after clustering & tracking"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Processed motor health and performance metrics"
    DTDFVocab:fromData MotorStatusTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Normalized steering angle values"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance ServoPositionData : DTDFVocab:Data [
    base:desc "Current positions of all servo actuators"
    DTDFVocab:fromData ServoPositionTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Aggregated vehicle state (pose, velocity, battery, etc.)"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

// ----------------------------------------------------
// C10: Model instances
// ----------------------------------------------------
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Software component that clusters raw LiDAR points into object tracks"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance ACCAlgorithmModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm (lead‑vehicle detection, distance‑based speed set‑point calculation) executed on cloud resources"
    DTDFVocab:inputTo CloudComputeEnabler
]

// ----------------------------------------------------
// C11: Enablers
// ----------------------------------------------------
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware network used for intra‑Digital‑Twin communication"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance CloudComputeEnabler : DTDFVocab:Enabler [
    base:desc "Cloud/edge compute resources used for off‑loading ACC analytics"
    DTDFVocab:enables ComputationOffloadingService
]

// ----------------------------------------------------
// C6: Services
// ----------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Continuous acquisition and 3‑D visualization of vehicle state, object tracks and driving paths for operators"
    DTDFVocab:provides OperationalStatusInsight, UserInterventionAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Execution of ACC analytics on cloud resources and feeding back desired speed to the vehicle"
    DTDFVocab:provides PredictiveDiagnosticInsight, SetTargetSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Bidirectional remote configuration and actuation (enable/disable ACC, set target speed, emergency brake) via low‑latency Wi‑Fi/UDP link"
    DTDFVocab:provides ACCEnableAction, ACCDisableAction, EmergencyBrakeAction
]

// ----------------------------------------------------
// C17: Insights & Actions
// ----------------------------------------------------
instance OperationalStatusInsight : DTDFVocab:Insight [
    base:desc "Current operational status of the autonomous vehicle presented in the UI"
]

instance PredictiveDiagnosticInsight : DTDFVocab:Insight [
    base:desc "Predictive or diagnostic outcomes from off‑loaded ACC computation (e.g., collision risk, recommended maneuvers)"
]

instance UserInterventionAction : DTDFVocab:Action [
    base:desc "Operator can manually intervene based on displayed information"
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Set a new target speed for the vehicle after ACC computation"
    DTDFVocab:IsAutomatic false
]

instance ACCEnableAction : DTDFVocab:Action [
    base:desc "Remote command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance ACCDisableAction : DTDFVocab:Action [
    base:desc "Remote command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediate emergency braking command issued by the operator"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin sends control commands back to the vehicle through the same Wi‑Fi UDP channel. Commands generated by the off‑loaded ACC service include a desired speed set‑point, an enable/disable ACC flag, and an emergency‑brake command. These commands are formatted by the Data Translation FE to match the vehicle's actuation message schema before transmission. Upon receipt, the vehicle’s control electronics execute the command (e.g., adjust motor speed or trigger braking) and provide implicit feedback via updated vehicle‑state messages; explicit acknowledgement is not described in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires a shared clock across devices with a maximum synchronization error of 100 ms, as mandated by safety‑critical vehicular standards; this accuracy is the basis for computation off‑loading between the Physical Twin Entity and Digital Twin Entity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration follows the ISO 23247 reference architecture: software components are first identified, then mapped to Functional Entities and instantiated as ROS2 packages; ROS2 topics/services provide intra‑entity communication, while deployment of each entity on distinct compute platforms enables resource partitioning. The overall constellation coordinates the Physical Twin Entity (sensors, actuators, point‑cloud clustering), the Digital Twin Entity (data management, control logic), and the User Entity (3D visualization, control panel) through ROS2 middleware, satisfying the entity‑based coordination pattern defined by the standard."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT system relies on two layers of networking. Internally, all software components communicate over a ROS 2 publish‑subscribe network. For communication between the physical twin and the Digital Twin Entity, a Wi‑Fi network using UDP at the transport layer is employed. The architecture is designed for low end‑to‑end latency to satisfy safety‑critical ACC requirements, though exact bandwidth or latency figures are not given. No specific redundancy, reliability mechanisms, or security protocols (e.g., encryption, authentication) are mentioned."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The documents only state that the ACC service can be off‑loaded to “better‑suited equipment, e.g., in the cloud,” implying a cloud‑based hosting option, but they provide no details on the concrete hosting platform, compute or storage sizing, scalability mechanisms, deployment models, or availability guarantees."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "ISO 23247 does not prescribe specific communication protocols, allowing the DT to integrate with external systems using standards of choice. The document cites OPC Unified Architecture (OPC UA) as an example that can be employed for the Data Translation Functional Entity, indicating that the DT can expose or consume data via OPC UA to interoperate with enterprise IT, other Digital Twins, or external manufacturing execution systems. No additional integration patterns or external dependencies are described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system follows the ISO 23247 Digital Twin framework for manufacturing (2021). It adheres to Part 2 (Reference Architecture) which defines an entity‑based model comprising Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity, and User Entity, each built from Functional Entities. Information exchange conforms to the ISO 23247 Part 4 specifications. The implementation may employ OPC Unified Architecture (OPC UA) for communication between the Data Collection and Device Control Entity and the OME, ensuring interoperability with industrial automation standards."
]