// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2‑D LiDAR providing raw point‑cloud data"
    DTDFVocab:producedData VehicleTelemetryAndLiDARTransmitted
]

instance IntelRealSenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering depth images"
    DTDFVocab:producedData VehicleTelemetryAndLiDARTransmitted
]

instance JetsonSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of vehicle speed from the Jetson‑based controller"
    DTDFVocab:producedData VehicleTelemetryAndLiDARTransmitted
]

instance JetsonSteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of steering angle from the Jetson‑based controller"
    DTDFVocab:producedData VehicleTelemetryAndLiDARTransmitted
]

// C4: Physical‑to‑virtual interaction (Data Transmitted)
instance VehicleTelemetryAndLiDARTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR, IntelRealSenseDepthCamera, JetsonSpeedSensor, JetsonSteeringAngleSensor
]

// C5: Data instances
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Point‑cloud data generated by the Hokuyo LiDAR"
    DTDFVocab:fromData VehicleTelemetryAndLiDARTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image generated by the Intel RealSense camera"
    DTDFVocab:fromData VehicleTelemetryAndLiDARTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed value streamed from the Jetson controller"
    DTDFVocab:fromData VehicleTelemetryAndLiDARTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle value streamed from the Jetson controller"
    DTDFVocab:fromData VehicleTelemetryAndLiDARTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

// C10: Models / Algorithms
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm for point‑cloud segmentation"
    DTDFVocab:inputTo ROS2Middleware
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter for object tracking"
    DTDFVocab:inputTo ROS2Middleware
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) algorithm compliant with ISO 15622 performance class I"
    DTDFVocab:inputTo NVIDIAJetsonComputeEnabler
]

// C11: Enablers (tools & platforms)
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware handling message passing over Wi‑Fi"
    DTDFVocab:enables DataMonitoringService, VisualizationService, RemoteManagementService, DataStorageService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Persistent SQL database storing collected data and generated reports"
    DTDFVocab:enables ReportGenerationService, DataStorageService
]

instance NVIDIAJetsonComputeEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetson Orin Nano compute resource executing the ACC control algorithm"
    DTDFVocab:enables ComputationOffloadingService
]

instance PythonApplicationEnabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 application code orchestrating higher‑level services"
    DTDFVocab:enables RemoteManagementService
]

instance CPlusPlusApplicationEnabler : DTDFVocab:Enabler [
    base:desc "C++ modules for high‑performance processing of sensor streams"
    DTDFVocab:enables DataMonitoringService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI display of speed, steering angle, object tracks and projected path"
    DTDFVocab:provides RealTimeVisualInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC algorithm in the DT and returns desired speed"
    DTDFVocab:provides DesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI allows operators to enable/disable ACC, adjust speed, issue emergency brake"
    DTDFVocab:provides EnableACCAction, DisableACCAction, EmergencyBrakeAction, AdjustSpeedSetpointAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3‑D rendering of vehicle and environment"
    DTDFVocab:provides RealTimeVisualInsight
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Time‑series reports of vehicle state and object tracks"
    DTDFVocab:provides ACCParameterTuningInsight, SystemDebuggingInsight
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Persistent storage of collected data in SQL database"
    DTDFVocab:provides DataRetentionInsight
]

// C17: Insights
instance RealTimeVisualInsight : DTDFVocab:Insight [
    base:desc "Operators see live speed, steering angle, object tracks and projected path"
]

instance ACCParameterTuningInsight : DTDFVocab:Insight [
    base:desc "Insights for tuning ACC parameters based on generated reports"
]

instance SystemDebuggingInsight : DTDFVocab:Insight [
    base:desc "Diagnostic information supporting system debugging"
]

instance DataRetentionInsight : DTDFVocab:Insight [
    base:desc "Assurance that collected data is persistently stored in the SQL database"
]

// C17: Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issue emergency brake command"
    DTDFVocab:IsAutomatic false
]

instance DesiredSpeedAction : DTDFVocab:Action [
    base:desc "Apply desired speed output from ACC algorithm to motor command"
    DTDFVocab:IsAutomatic true
]

instance AdjustSpeedSetpointAction : DTDFVocab:Action [
    base:desc "Adjust ACC speed set‑point"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin sends control commands back to the Physical Twin over the same Wi‑Fi/ROS 2 link: ACC enable/disable, desired speed set‑points, emergency‑brake commands, and actuation commands (motor voltage, steering angle) generated by the Controlling FE and Actuation FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates with a maximum end‑to‑end latency of 100 ms from vehicle to DT (R7) and requires clocks synchronised within 100 ms accuracy (R8). Data collection and ACC computation occur at the perception‑cycle rate (typically tens of Hz)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT system (DTS) comprises the Physical Twin Entity (sensors, actuators, point‑cloud processing), the Digital Twin Entity (data collection, ACC, visualization, reporting, storage), the User Entity (3‑D UI and control panel), and a Cross‑System Data Translation Entity. Communication between entities uses ROS 2 intra‑node messages and Wi‑Fi inter‑entity links."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is used during design/development (cyber‑physical experimentation), testing (validation of ACC behavior), and operational phases (monitoring, remote management and health‑monitoring) as described in the case study."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by using high‑frequency sensor data, latency ≤100 ms, clock synchronisation ≤100 ms, and validated tracking algorithms (DBSCAN + Kalman). The ACC algorithm follows ISO 15622, and safety‑critical constraints are respected during off‑loading and remote command execution."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication uses a Wi‑Fi network; intra‑entity communication uses ROS 2 topics/services; data is serialised and unit‑converted by the Data Translation FE. No specific protocol such as OPC UA is employed in the implementation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the on‑board NVIDIA Jetson Orin Nano; Digital Twin Entity is hosted on external compute (cloud or workstation) reachable via Wi‑Fi; User Entity runs on an operator workstation providing the UI."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture is based on ISO 23247 (Digital Twin Manufacturing Framework) reference architecture; the ACC control logic follows ISO 15622; ISO/IEC 30173:2023 concepts are acknowledged."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT respects the safety‑critical nature of ACC by enforcing a ≤100 ms latency, clock synchronisation, and providing remote emergency‑brake capability. No explicit security mechanisms (e.g., authentication, encryption) are described in the document."
]