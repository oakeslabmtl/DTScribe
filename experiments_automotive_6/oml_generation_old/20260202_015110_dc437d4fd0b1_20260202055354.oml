instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor capturing point cloud data for object detection"
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor collecting vehicle state data including speed, position, and orientation"
]

instance MotorActuationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring motor actuation parameters"
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring steering servo input angles"
]

instance RawLiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance MotorActuationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorActuationSensor
]

instance SteeringServoDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
]

instance ObjectTracksDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance ProjectedDrivingPathDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor, LiDARPointCloudSensor
]

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data for object detection"
    DTDFVocab:fromData RawLiDARPointCloudDataTransmitted
    DTDFVocab:inputTo Python3_8
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state data including speed, position, and orientation"
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo Python3_8, Cpp
]

instance MotorActuationData : DTDFVocab:Data [
    base:desc "Motor actuation parameter data"
    DTDFVocab:fromData MotorActuationDataTransmitted
    DTDFVocab:inputTo Cpp
]

instance SteeringServoData : DTDFVocab:Data [
    base:desc "Steering servo input angle data"
    DTDFVocab:fromData SteeringServoDataTransmitted
    DTDFVocab:inputTo Cpp
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Detected object tracks from point cloud clustering"
    DTDFVocab:fromData ObjectTracksDataTransmitted
    DTDFVocab:inputTo Python3_8
]

instance ProjectedDrivingPathData : DTDFVocab:Data [
    base:desc "Projected driving path for Adaptive Cruise Control"
    DTDFVocab:fromData ProjectedDrivingPathDataTransmitted
    DTDFVocab:inputTo Python3_8
]

instance GeometricModel : DTDFVocab:Model [
    base:desc "Geometric model for object representation in 3D space"
    DTDFVocab:inputTo ROS2Middleware
]

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering model for raw LiDAR point clouds"
    DTDFVocab:inputTo Python3_8
]

instance KalmanFilterModel : DTDFVocab:Model [
    base:desc "Analytical Kalman filter for trajectory tracking"
    DTDFVocab:inputTo Python3_8, Cpp
]

instance NVIDIAJetpack5_0SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for software development"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "Robot Operating System 2 (ROS2) middleware for inter-component communication"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance Python3_8 : DTDFVocab:Enabler [
    base:desc "Python 3.8 programming language for data processing scripts"
    DTDFVocab:enables ComputationOffloadingService, DataMonitoringService
]

instance Cpp : DTDFVocab:Enabler [
    base:desc "C++ programming language for performance-critical components"
    DTDFVocab:enables ComputationOffloadingService
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL database for structured data storage and reporting"
    DTDFVocab:enables DataMonitoringService
]

instance WiFiInfrastructure : DTDFVocab:Enabler [
    base:desc "Wi-Fi network infrastructure for low-latency communication"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring service providing real-time vehicle state, projected paths, and object tracks visualization with report generation capabilities"
    DTDFVocab:provides RealTimeVehicleStateInsight, ProjectedPathVisualizationInsight, ObjectTrackDisplayInsight, ReportGenerationAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation Offloading service for external processing of ACC lead vehicle detection, speed computation, and actuation commands"
    DTDFVocab:provides LeadVehicleDetectionInsight, SafeSpeedCalculationInsight, ActuationCommandInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service enabling operators to control ACC settings and send emergency commands"
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, EmergencyBrakingAction
]

instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real-time display of vehicle speed, position, and orientation"
]

instance ProjectedPathVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of the projected driving path for ACC"
]

instance ObjectTrackDisplayInsight : DTDFVocab:Insight [
    base:desc "Display of detected object tracks from LiDAR data"
]

instance ReportGenerationAction : DTDFVocab:Action [
    base:desc "Action to save and generate reports from monitored data"
    DTDFVocab:IsAutomatic false
]

instance LeadVehicleDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight on detected lead vehicle for ACC"
]

instance SafeSpeedCalculationInsight : DTDFVocab:Insight [
    base:desc "Calculated safe speed based on distance to lead vehicle"
]

instance ActuationCommandInsight : DTDFVocab:Insight [
    base:desc "Computed actuation commands for ACC system"
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable or disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to set the desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Action to trigger emergency braking command"
    DTDFVocab:IsAutomatic false
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User Entity hosting 3D Visualization and Control Panel ROS2 nodes"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital Twin Entity managing data processing and control mechanisms"
]

instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical Twin Entity handling sensor data pre-processing, actuation, and automotive functions including Point Cloud Clustering & Tracking"
]

instance ThreeDVisualizationNode : DTDFVocab:Component [
    base:desc "ROS2 node for 3D visualization of vehicle data"
]

instance ControlPanelNode : DTDFVocab:Component [
    base:desc "ROS2 node for user control interface"
]

instance UserEnvironment : DTDFVocab:Environment [
    base:contains UserEntity, ThreeDVisualizationNode, ControlPanelNode
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains DigitalTwinEntity
]

instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands such as emergency braking and desired speed adjustments are generated by the Controlling FE and sent to the Actuation component, which converts desired speed into motor voltage commands. The Control Panel User Interface FE enables remote management of ACC, with data translation ensuring proper command formatting for physical actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires 100 ms clock synchronization accuracy for computation offloading between devices, as mandated by safety-critical vehicular application standards, though hardware limitations prevent stricter synchronization than this threshold."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin architecture follows ISO 23247 RA with entity-based structuring, mapping software components to Functional Entities implemented as ROS2 packages. Each entity (User, Digital Twin, Physical Twin) is deployed on separate hardware, with the Physical Twin Entity extending beyond ISO 23247's OME to host general automotive functionality like Point Cloud Clustering & Tracking. The User Interface FE is split into 3D Visualization and Control Panel components, while Data Storage lacks a direct FE alignment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Internal software components communicate via ROS2, while inter-entity communication uses Wi-Fi. Requirement R7 mandates a maximum network latency of 100 ms. No details on bandwidth, security protocols, or redundancy mechanisms are specified in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247:2021 standard defines the Digital Twin framework for manufacturing, with four parts: Overview and general principles, Reference architecture (Part 2), Digital representation of physical manufacturing elements, and Information exchange. Part 2 specifies the reference architecture entities including Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity, and User Entity. Functional Entities handle specific tasks like data transformation, with OPC Unified Architecture cited as an implementation example for interoperability."
]