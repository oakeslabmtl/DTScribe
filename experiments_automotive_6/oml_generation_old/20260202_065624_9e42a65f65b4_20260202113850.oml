// C3: Physical sensing components
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR producing dense point clouds"
    DTDFVocab:producedData LidarPointCloudTopic
]

instance IntelRealsenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera feeding depth images"
    DTDFVocab:producedData DepthImageTopic
]

instance VehicleEgoSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle embedded speed sensor reporting ego vehicle speed"
    DTDFVocab:producedData SpeedDataTopic
]

instance VehicleEgoSteeringSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle embedded steering sensor reporting ego steering angle"
    DTDFVocab:producedData SteeringAngleDataTopic
]

// C4: Physical-to-virtual interaction – Data transmitted
instance LidarPointCloudTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthImageTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealsenseD435iCamera
]

instance SpeedDataTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleEgoSpeedSensor
]

instance SteeringAngleDataTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleEgoSteeringSensor
]

// C10: Models/Data – Data objects
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Dense point cloud data streamed from Hokuyo UST-10LX LiDAR"
    DTDFVocab:fromData LidarPointCloudTopic
    DTDFVocab:inputTo ROS2MiddlewareEnabler, JetsonComputationEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image data streamed from Intel RealSense D435i camera"
    DTDFVocab:fromData DepthImageTopic
    DTDFVocab:inputTo ROS2MiddlewareEnabler, JetsonComputationEnabler
]

instance SpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed measurement"
    DTDFVocab:fromData SpeedDataTopic
    DTDFVocab:inputTo ROS2MiddlewareEnabler, JetsonComputationEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Ego vehicle steering angle measurement"
    DTDFVocab:fromData SteeringAngleDataTopic
    DTDFVocab:inputTo ROS2MiddlewareEnabler, JetsonComputationEnabler
]

// C10: Models
instance ACCControllerModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control controller (performance class I per ISO 15622)"
    DTDFVocab:inputTo JetsonComputationEnabler
]

instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Point‑cloud clustering using DBSCAN for object detection"
    DTDFVocab:inputTo JetsonComputationEnabler
]

instance KalmanFilterModel : DTDFVocab:Model [
    base:desc "Kalman filter for tracking detected objects over time"
    DTDFVocab:inputTo JetsonComputationEnabler
]

instance DataTranslationModel : DTDFVocab:Model [
    base:desc "Unit conversion and serialization of raw sensor data for DT processing"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance ThreeDVisualizationModel : DTDFVocab:Model [
    base:desc "3D rendering model for vehicle and environment visualization"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance ReportingModel : DTDFVocab:Model [
    base:desc "Export and storage model for time‑series logs into SQL database"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

// C11: Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware (DDS) facilitating communication between sensors and virtual entities"
    DTDFVocab:enables DataMonitoringService, VisualizationService, ReportingService
]

instance JetsonComputationEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetson Orin Nano providing high‑performance compute for ACC controller and perception models"
    DTDFVocab:enables ComputationOffloadingService
]

instance ActuationEnabler : DTDFVocab:Enabler [
    base:desc "Control layer enabling access to vehicle actuators such as motor controller, steering servo and emergency braking system"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Live display of vehicle speed, steering angle, and tracked objects for operator situational awareness"
    DTDFVocab:provides RealTimeVehicleStateInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm executed on the Jetson compute node, computing desired speed and trajectory"
    DTDFVocab:provides ACCDesiredSpeedInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote command interface for operators to enable/disable ACC, adjust target speed, and trigger emergency braking"
    DTDFVocab:provides AdjustACCAction, EnableACCAction, EmergencyBrakeAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D rendering of vehicle and surrounding environment for operator visualization"
    DTDFVocab:provides ThreeDVisualizationInsight
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Exports time‑series logs to SQL database and allows external data export"
    DTDFVocab:provides ExportTimeSeriesAction, StoreSQLDataAction
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time vehicle speed, steering angle, and tracked object display"
]

instance ACCDesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Desired speed computed by the ACC controller based on perception data"
]

instance ThreeDVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visual representation of vehicle trajectory and surrounding object tracks"
]

// C17: Actions
instance AdjustACCAction : DTDFVocab:Action [
    base:desc "Operator command to adjust the desired ACC speed"
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable or disable the ACC system"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Command to trigger an emergency brake via the ACC-generated brake‑apply signal"
    DTDFVocab:IsAutomatic false
]

instance ExportTimeSeriesAction : DTDFVocab:Action [
    base:desc "Automatically export time‑series logs to external storage"
    DTDFVocab:IsAutomatic true
]

instance StoreSQLDataAction : DTDFVocab:Action [
    base:desc "Automatically store telemetry data into the SQL database"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Computed control actions (desired speed, steering commands, emergency brake) are emitted by the Control FE of the Digital Twin Entity, serialized by the Data Translation FE, and sent over the Wi‑Fi network via ROS2 topics to the Physical Twin Entity which translates the commands into motor‑voltage and steering‑servo actuation on the vehicle."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All DT services operate in real‑time; data is streamed at each perception cycle with an end‑to‑end latency requirement of ≤100 ms. Clock synchronization across devices is maintained to within 100 ms to guarantee event ordering and command safety."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The distributed twin constellation orchestrates ROS2 nodes across four entities: Physical Twin (sensors/actuators), Digital Twin (data collection, control, storage), User Entity (3‑D visualization, control panel), Cross‑System Entity (Data Translation). Communication flows via ROS2 topics over Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "1) Requirement elicitation (R1–R8) 2) Architectural design (mapping ISO 23247 RA to software components) 3) Implementation (ROS2 nodes in Python/C++/MATLAB) 4) Testing and verification (latency, unit conversions) 5) Deployment (embedded Jetson, Wi‑Fi network, UI client) 6) Evaluation – assessing ISO 23247 fitness for automotive DTs."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time constraint enforcement (≤100 ms latency, ≤100 ms clock sync), use of DBSCAN + Kalman filter for accurate tracking, ACC validation against ISO 15622 specifications, Data Translation FE providing unit conversion and message integrity, SQL storage ensuring precise time‑series data fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication is conducted over a Wi‑Fi network; internal component messaging uses ROS 2 (DDS‑based). The Data Translation FE performs serialization and unit conversion for all networked data. No explicit WAN or external protocols are employed."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin compute runs primarily on the NVIDIA Jetson Orin Nano mounted on the vehicle for on‑board services, with optional offloading of ACC logic to a local edge server or cloud node; all components are packaged as ROS 2 nodes running on Linux. The User Entity operates on a remote workstation with the same ROS 2 stack for interface rendering."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to ISO 23247 reference architecture for DT, ISO 15622 for ACC algorithms, ROS2 middleware standards, NVIDIA JetPack 5.0 firmware, and standard ROS2 distribution packages."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by maintaining ≤ 100 ms end‑to‑end latency, achieving ± 100 ms clock synchronization, and implementing ACC in compliance with ISO 15622 safety class I. No specific cybersecurity safeguards (encryption, authentication) are indicated in the document."
]