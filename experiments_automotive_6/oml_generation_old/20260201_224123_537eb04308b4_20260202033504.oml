// -------------------------------------------------------------------
// Sensing Components and their Data Transmissions
// -------------------------------------------------------------------

// LiDAR sensor
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing 2‑D point clouds over ROS2."
    DTDFVocab:producedData LiDARDataTransmitted
]

instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 2‑D LiDAR point‑cloud data transmitted from the physical twin."
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, DBSCANClusteringModel
]

// Depth camera
instance RealSenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera providing 3‑D point clouds over ROS2."
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RealSenseDepthCamera
]

instance DepthPointCloudData : DTDFVocab:Data [
    base:desc "Raw 3‑D point‑cloud data from the RealSense depth camera."
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

// Vehicle speed sensor
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board wheel‑encoder/IMU providing vehicle speed measurements over ROS2."
    DTDFVocab:producedData SpeedDataTransmitted
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SpeedTimestampData : DTDFVocab:Data [
    base:desc "Timestamped vehicle speed values transmitted from the physical twin."
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, RemoteControlEnabler
]

// Steering angle sensor
instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board steering encoder providing steering‑angle measurements over ROS2."
    DTDFVocab:producedData SteeringDataTransmitted
]

instance SteeringDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance SteeringAngleTimestampData : DTDFVocab:Data [
    base:desc "Timestamped steering‑angle values transmitted from the physical twin."
    DTDFVocab:fromData SteeringDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, RemoteControlEnabler
]

// -------------------------------------------------------------------
// Processed data transmission (object tracking output)
// -------------------------------------------------------------------
instance ProcessedTracksDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ObjectTrackingEnabler
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks generated by DBSCAN clustering and Kalman filtering."
    DTDFVocab:fromData ProcessedTracksDataTransmitted
    DTDFVocab:inputTo ObjectTrackingEnabler, VisualizationEnabler, ReportGenerationEnabler
]

// -------------------------------------------------------------------
// Models
// -------------------------------------------------------------------
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN algorithm clustering LiDAR point clouds into object candidates."
    DTDFVocab:inputTo ObjectTrackingEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter smoothing object clusters to produce continuous tracks."
    DTDFVocab:inputTo ObjectTrackingEnabler
]

instance ACCControllerModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control controller derived from ISO‑15622, using lead‑vehicle detection and distance‑based speed set‑point."
    DTDFVocab:inputTo ACCComputationEnabler
]

// -------------------------------------------------------------------
// Enablers
// -------------------------------------------------------------------
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ISO‑23247 Data Translation FE that serializes ROS2 messages and performs unit conversion."
    DTDFVocab:enables DataMonitoringService, ACCComputationService, ReportGenerationService, VisualizationService
]

instance ObjectTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler aggregating DBSCAN and Kalman outputs into coherent object tracks."
    DTDFVocab:enables DataMonitoringService, RemoteControlService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Cloud‑hosted element executing the ACC algorithm and providing speed set‑points."
    DTDFVocab:enables ACCComputationService, RemoteControlService
]

instance ReportGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that formats timestamped vehicle state and object tracks into time‑series reports stored in SQL."
    DTDFVocab:enables ReportGenerationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that prepares 3‑D vehicle and environment data for virtual cockpit rendering."
    DTDFVocab:enables VisualizationService
]

instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler routing operator commands (ACC enable/disable, speed set, emergency brake) to the acting component."
    DTDFVocab:enables RemoteControlService, ACCComputationService
]

// -------------------------------------------------------------------
// Services
// -------------------------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI service displaying real‑time speed, steering angle, object tracks and projected path."
    DTDFVocab:provides RealTimeVehicleInsight
]

instance ACCComputationService : DTDFVocab:Service [
    base:desc "Cloud service executing the ACC algorithm and returning desired speed set‑points."
    DTDFVocab:provides ACCDecisionInsight
]

instance RemoteControlService : DTDFVocab:Service [
    base:desc "Remote‑management service allowing operators to enable/disable ACC, set desired speed, or trigger emergency braking."
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generates human‑readable time‑series reports from stored vehicle state and object tracks."
    DTDFVocab:provides ReportInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Renders a 3‑D virtual cockpit of the vehicle and its environment."
    DTDFVocab:provides VisualizationInsight
]

// -------------------------------------------------------------------
// Insights & Actions
// -------------------------------------------------------------------
instance RealTimeVehicleInsight : DTDFVocab:Insight [
    base:desc "Operators receive live visualization of speed, steering angle, detected objects and projected trajectory."
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "ACC controller outputs desired speed set‑point based on lead‑vehicle distance."
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets a target speed for the vehicle."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking."
    DTDFVocab:IsAutomatic false
]

instance ReportInsight : DTDFVocab:Insight [
    base:desc "Automatically generated time‑series report stored in SQL for offline analysis."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "3‑D virtual cockpit visualization of vehicle state and environment."
]

// -------------------------------------------------------------------
// Acting Component
// -------------------------------------------------------------------
instance VedderESCActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder electronic speed controller driving the motor and steering servo; receives desired speed, ACC enable flag, and emergency‑brake commands from the DT."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command channel from the digital twin to the vehicle over the same Wi‑Fi/ROS2 link delivering desired speed, ACC enable/disable, emergency brake, and other remote‑management commands; the Actuation FE on the physical twin receives these commands and drives the ESC and steering servo."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sub‑second real‑time operation with a hard end‑to‑end latency bound of 100 ms between vehicle and digital twin (R7) and clock synchronization accuracy of 100 ms (R8); data collection and ACC computation occur at each perception cycle (typically tens of Hz)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A layered architecture mapping ISO 23247 entities to concrete components: Physical Twin Entity hosting sensors, actuation and point‑cloud processing; Digital Twin Entity hosting data collection, ACC control, reporting and visualization; User Entity providing 3D UI and control panel; Cross‑System Entity handling data translation. Components are packaged as independent ROS2 packages deployed across vehicle, cloud, and operator workstation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin is employed in the operational stage for real‑time monitoring, remote control and off‑loading, and also supports design‑time activities such as cyber‑physical experimentation and validation of ADAS functions."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time fidelity ensured by meeting the 100 ms latency and clock sync requirements; ACC behavior complies with ISO 15622 specifications; perception fidelity derived from DBSCAN clustering and Kalman filtering of LiDAR data; validation includes external SQL logging for post‑run analysis and adherence to safety‑critical constraints."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Wi‑Fi network linking the vehicle’s Jetson to the cloud‑hosted DT and operator workstation; ROS2 as the communication middleware; standardized interfaces for all components (R1) realized through ROS2 topics/services; data payloads serialized by the Data Translation functional entity."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the Jetson Orin Nano inside the vehicle; Digital Twin Entity components (ACC computation, data collection, visualization) run on a cloud or edge server; User Entity UI runs on an operator PC; the SQL database and reporting services are hosted on an external server accessible via the network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 reference architecture, uses ISO 15622 for ACC functionality, and adheres to ISO/IEC 30173:2023 concepts for digital twins; ROS2 provides a standards‑based middleware layer."
]