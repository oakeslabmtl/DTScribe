// Sensing components
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Real‑time vehicle speed sensor onboard the PT"
    DTDFVocab:producedData VehicleSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Real‑time steering angle sensor onboard the PT"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

instance HokuyoUST10LXPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST10LX LiDAR generating raw point cloud data"
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance IntelD435iDepthImageSensor : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera providing depth images"
    DTDFVocab:producedData DepthImageDataTransmitted
]

// Data Transmitted instances
instance VehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXPointCloudSensor
]

instance DepthImageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthImageSensor
]

// Data instances
instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Real‑time vehicle speed measurement forwarded from PT"
    DTDFVocab:inputTo DigitalTwinFE
    DTDFVocab:fromData VehicleSpeedDataTransmitted
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Real‑time steering angle measurement forwarded from PT"
    DTDFVocab:inputTo DigitalTwinFE
    DTDFVocab:fromData SteeringAngleDataTransmitted
]

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud from Hokuyo UST10LX"
    DTDFVocab:inputTo DigitalTwinFE
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image from Intel D435i camera"
    DTDFVocab:inputTo DigitalTwinFE
    DTDFVocab:fromData DepthImageDataTransmitted
]

instance DBSCANClusteredTracksData : DTDFVocab:Data [
    base:desc "DBSCAN clustered object tracks derived from LiDAR point cloud"
    DTDFVocab:inputTo DigitalTwinFE
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
]

instance KalmanFilteredTracksData : DTDFVocab:Data [
    base:desc "Kalman‑filtered object tracks for lead vehicle detection"
    DTDFVocab:inputTo DigitalTwinFE
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
]

instance ReportSnapshotData : DTDFVocab:Data [
    base:desc "Time‑series snapshot report generated by the DT for operator display"
    DTDFVocab:inputTo DigitalTwinFE
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
]

instance DesiredSpeedCommandData : DTDFVocab:Data [
    base:desc "Desired speed command issued to the PT by the ACC algorithm"
    DTDFVocab:inputTo DigitalTwinFE
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
]

// Enabler
instance DigitalTwinFE : DTDFVocab:Enabler [
    base:desc "Data Translation FE: serialises, unit‑converts, clusters, and forwards PT data to the DT"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time data monitoring with displays and human‑readable reporting"
    DTDFVocab:provides RealTimeReportInsight, AnomalyDetectionInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation offloading of the ACC control algorithm onto cloud hosts"
    DTDFVocab:provides AdjustDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management of the ACC subsystem: enable/disable, desired speed adjustment, emergency braking"
    DTDFVocab:provides EnableACCAction, EmergencyBrakeAction
]

// Insights
instance RealTimeReportInsight : DTDFVocab:Insight [
    base:desc "Insight: Real‑time reports of vehicle state and trajectory enable operators to detect anomalies and assess performance"
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight: Anomaly detection in vehicle state allows operators to adjust speed and tune the control algorithm"
]

// Actions
instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action: Adjust desired speed settings in the ACC algorithm"
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action: Enable or disable the ACC subsystem"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action: Trigger emergency braking for safety"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "ACC outputs (desired speed, emergency braking commands) are serialised by the Data Translation FE, transmitted to PT, and handled by the Physical Twin Entity Actuation FE, which translates them into motor voltage commands for the speed controller and steering commands for the servo. Remote‐management UI commands (enable/disable ACC, set desired speed) follow the same routing path."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with a maximum end‑to‑end latency of 100 ms from vehicle to DT as specified by R7; all system clocks are synchronized to an accuracy of 100 ms per R8; data is streamed continuously, with no predefined sampling frequency but meeting the real‑time requirement."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation is organised as Physical Twin Entity (vehicle), Digital Twin Entity (cloud), and User Entity (3D visualization + control panel). Inter‑entity communication is realised over a Wi‑Fi network using ROS 2 topics transmitted via UDP, with the Data Translation FE orchestrating message framing, unit conversion, and timestamping."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT operates in the Operated lifecycle stage, gathering real‑time operational data, executing ACC control, and providing monitoring and remote‑management services. It does not model the Design or Manufacturing stages of the vehicle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time data collection and 100 ms latency requirement ensure timely feedback; clock synchronization to 100 ms maintains data integrity; ACC algorithm follows ISO 15622 safety standards; data storage in a database and reporting provide traceability; however, no explicit V&V methodology is described beyond adherence to ISO requirements."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "PT and DT communicate over a Wi‑Fi link using ROS 2 topics carried over UDP. The Data Translation FE serialises and frames messages; Data Collection SE publishes vehicle state and object tracks with timestamps accurate to within 100 ms, conforming to the ISO 23247 Data Translation Format."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity is deployed on a public cloud host; the Physical Twin Entity resides on the Jetson Orin Nano within the vehicle; the User Entity operates on an operator workstation or laptop, accessing the DT via the Data Translation and visualization components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) as the reference architecture, implements ISO 15622 for ACC control, and uses ROS 2 as open‑source middleware. OPC UA is referenced as a potential Data Translation method but not employed."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical nature emphasized by latency requirement (≤100 ms) and clock synchronization (≤100 ms); compliance with ISO 15622 ensures ACC safety; the DT operates within a controlled Wi‑Fi network, but explicit cybersecurity measures are not detailed in the document."
]