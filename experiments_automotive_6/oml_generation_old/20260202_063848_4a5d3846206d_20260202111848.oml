// Environment // Return code: 1 | Stderr:
instance AUTOTWINEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity, DigitalTwinEntity, UserEntity
]

// Components
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical twin entity running on vehicle hardware"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital twin entity hosting simulation and ACC logic on remote server"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User entity operator interface on separate workstation"
]

// Sensing Components
instance HokuyoLiDAR10LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST10LX LiDAR providing raw point clouds"
    DTDFVocab:producedData LiDARRawPointCloudDataTransmitted
]

instance DeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera delivering depth images"
    DTDFVocab:producedData DepthImageDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor encoded in motor controller, reports ego speed"
    DTDFVocab:producedData EgoSpeedTelemetryTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor recording vehicle steering angle"
    DTDFVocab:producedData SteeringAngleTelemetryTransmitted
]

// Data Transmitted
instance LiDARRawPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR10LX
]

instance DepthImageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DeepsenseD435iDepthCamera
]

instance EgoSpeedTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Data
instance LiDARRawPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data collected from Hokuyo UST10LX"
    DTDFVocab:fromData LiDARRawPointCloudDataTransmitted
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image data from Intel D435i depth camera"
    DTDFVocab:fromData DepthImageDataTransmitted
]

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Real‑time ego speed telemetry"
    DTDFVocab:fromData EgoSpeedTelemetryTransmitted
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Real‑time steering angle telemetry"
    DTDFVocab:fromData SteeringAngleTelemetryTransmitted
]

// Acting Components
instance MotorActuationModule : DTDFVocab:ActingComponent [
    base:desc "Motor actuation module converting desired speed to motor voltage, located on vehicle hardware"
]

instance SteeringServoActuationVedder : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuation via Vedder Electronic Speed Controller and steering servo on vehicle"
]

// Models
instance DBSCANPointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of point clouds for object detection"
    DTDFVocab:inputTo DataTranslationService
]

instance KalmanFilterObjectTrackingModel : DTDFVocab:Model [
    base:desc "Kalman-filter-based tracking of objects detected in point cloud clusters"
    DTDFVocab:inputTo DataTranslationService
]

instance ACCControllerISO15622Model : DTDFVocab:Model [
    base:desc "ACC controller implementing ISO15622 standard for performance class I ACC"
    DTDFVocab:inputTo ComputationOffloadingService
]

instance ReportingModel : DTDFVocab:Model [
    base:desc "Reporting model that aggregates vehicle state and object tracks into a SQL database"
    DTDFVocab:inputTo DataMonitoringService
]

// Enablers
instance DataCollectionFE : DTDFVocab:Enabler [
    base:desc "Collects real-time telemetry from vehicle sensors and forwards via ROS2 nodes over WiFi"
    DTDFVocab:enables DataTranslationService
]

instance DataTranslationService : DTDFVocab:Service [
    base:desc "Handles unit conversions and message alignment before virtual processing"
    DTDFVocab:provides DataAlignmentInsight
]

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for intra-system communication"
    DTDFVocab:enables ROS2CommunicationService
]

instance JetPackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK for Jetson Orin Nano"
    DTDFVocab:enables JetPackCapabilityService
]

instance MATLABSimulinkTool : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink used for point‑cloud processing"
    DTDFVocab:enables MATLABSimulinkProcessingService
]

instance Python3Runtime : DTDFVocab:Enabler [
    base:desc "Python 3.8 used for rapid prototyping"
    DTDFVocab:enables PythonRuntimeService
]

instance CppNodeLifecycle : DTDFVocab:Enabler [
    base:desc "C++ used for ROS2 node lifecycle management"
    DTDFVocab:enables NodeLifecycleService
]

instance ISO23247ReferenceArchitecture : DTDFVocab:Enabler [
    base:desc "ISO 23247 reference architecture guiding system design"
    DTDFVocab:enables ISOIntegrationService
]

instance GitHubRepo : DTDFVocab:Enabler [
    base:desc "GitHub used for source code hosting"
    DTDFVocab:enables CodeHostingService
]

// Services
instance ROS2CommunicationService : DTDFVocab:Service [
    base:desc "Provides ROS2 communication capabilities across entities"
    DTDFVocab:provides CommunicationInsight
]

instance JetPackCapabilityService : DTDFVocab:Service [
    base:desc "Enables powered hardware features via JetPack SDK"
    DTDFVocab:provides JetPackCapabilityInsight
]

instance MATLABSimulinkProcessingService : DTDFVocab:Service [
    base:desc "Provides MATLAB/Simulink processing for point cloud data"
    DTDFVocab:provides MATLABSimulinkInsight
]

instance PythonRuntimeService : DTDFVocab:Service [
    base:desc "Provides Python runtime environment for rapid prototyping"
    DTDFVocab:provides PythonRuntimeInsight
]

instance NodeLifecycleService : DTDFVocab:Service [
    base:desc "Manages lifecycle of ROS2 nodes"
    DTDFVocab:provides NodeLifecycleInsight
]

instance ISOIntegrationService : DTDFVocab:Service [
    base:desc "Aligns system components with ISO23247 reference architecture"
    DTDFVocab:provides ISOIntegrationInsight
]

instance CodeHostingService : DTDFVocab:Service [
    base:desc "Handles source code hosting and version control"
    DTDFVocab:provides CodeHostingInsight
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time display, saving and generating reports of vehicle state and object tracks"
    DTDFVocab:provides TimeSeriesReportsInsight, DrivingPathProjectionsInsight, RealTimeVisualizationInsight, DiagnosticDataInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation offloading: ACC algorithm runs on Digital Twin, computes desired speed and sends results back to vehicle"
    DTDFVocab:provides ACCDecisionInsight
]

// ACC Decision Insight
instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating ACC decision result sent to vehicle"
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI allowing operators to enable/disable ACC, change desired speed, and issue emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, InitiateEmergencyBrakingAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D visualization FE rendering vehicle, environment, projected path, and tracks"
    DTDFVocab:provides RealTimeVisualizationInsight
]

// Insights
instance TimeSeriesReportsInsight : DTDFVocab:Insight [
    base:desc "Human‑readable time‑series reports of vehicle state and object tracks"
]

instance DrivingPathProjectionsInsight : DTDFVocab:Insight [
    base:desc "Projected future driving paths based on ACC decisions"
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time 3D visualization for operator awareness"
]

instance DiagnosticDataInsight : DTDFVocab:Insight [
    base:desc "Diagnostic data for developers to troubleshoot algorithms"
]

instance DataAlignmentInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful unit conversion and message alignment"
]

instance CommunicationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating ROS2 communication is operational"
]

instance JetPackCapabilityInsight : DTDFVocab:Insight [
    base:desc "Insight indicating JetPack SDK capabilities are enabled"
]

instance MATLABSimulinkInsight : DTDFVocab:Insight [
    base:desc "Insight indicating MATLAB/Simulink processing is active"
]

instance PythonRuntimeInsight : DTDFVocab:Insight [
    base:desc "Insight indicating Python runtime is operational"
]

instance NodeLifecycleInsight : DTDFVocab:Insight [
    base:desc "Insight indicating ROS2 node lifecycle is managed"
]

instance ISOIntegrationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating alignment with ISO23247 reference architecture"
]

instance CodeHostingInsight : DTDFVocab:Insight [
    base:desc "Insight indicating source code hosting is active"
]

// Actions
instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Adjusts desired vehicle speed during operation"
    DTDFVocab:IsAutomatic false
]

instance InitiateEmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Triggers emergency braking"
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables Adaptive Cruise Control on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disables Adaptive Cruise Control on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The ACC Controlling FE computes a desired speed based on lead vehicle detection and sends this command to the vehicle over Wi‑Fi; the Physical Twin Entity’s Actuation FE converts the desired speed into motor voltage commands to drive the ESC and steering servo. Remote management commands (enable/disable ACC, modify desired speed, emergency braking) are entered in the User Interface FE (3D Visualization and Control Panel), routed to the DT, and transmitted to the vehicle as control signals via Wi‑Fi."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates in real‑time with mandatory end‑to‑end latency no greater than 100 ms from vehicle to Digital Twin (Requirement R7), and clock synchronization accuracy within 100 ms (Requirement R8). Data acquisition and ACC computation are performed at each perception cycle (typically at ~10 Hz, though the exact frequency is not specified)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated by mapping each ISO 23247 functional entity to a ROS 2 package: the Data Collection FE, Data Translation FE, Actuation FE, ACC FE, User Interface FE, Visualization FE, etc. These packages communicate over ROS 2 topics, while cross‑entity messaging (PT↔DT) is performed over Wi‑Fi using the Data Translation FE. The overall system is distributed across the vehicle, a remote server, and the operator workstation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (definition of architectural RA, mapping of software components to ISO 23247 FEs), Manufacture (retrofitting of the 1/10‑scale vehicle with Jetson hardware and sensors), Operation (runtime execution of DT services, real‑time data flow and remote command handling). The Digital Twin covers the ‘operated’ representation of the physical twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time operation enforces a strict 100 ms latency ceiling (R7) and 100 ms clock‑synchronization tolerance (R8), ensuring data integrity for safety‑critical ACC decisions. Verification is implicit in adherence to ISO 23247 and ISO 15622, with the Data Translation FE guaranteeing unit consistency and the SQL database providing persistent records for post‑mortem validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical twin and digital twin communicate over a Wi‑Fi network; ROS 2 topics exchange ROS messages between internal components on the vehicle, while inter‑entity messages (e.g., desired speed command) are serialized by the Data Translation FE and transmitted over UDP/TCP (not explicitly specified). The Data Translation FE uses standard ROS serialization mechanisms and unit conversion routines."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin system is deployed on a remote edge/cloud server, while the Physical Twin Entity resides on the vehicle’s NVIDIA Jetson Orin Nano. The User Entity operates on a separate workstation or operator terminal. The overall deployment is thus a multi‑node distributed architecture bridging on‑board compute and cloud resources."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture for digital twin design, ISO 15622 specification for ACC control, ROS 2 middleware, NVIDIA JetPack 5.0 SDK, optionally OPC UA for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The system is safety‑critical, with strict latency and clock‑synchronization requirements defined by ISO 15622 and ISO 23247. All vehicle‑to‑DT communication occurs over Wi‑Fi and must satisfy secure transmission protocols, though the specific encryption or authentication mechanisms are not detailed in the document. The design adheres to safety standards, but explicit cybersecurity measures are beyond the scope of the provided text."
]