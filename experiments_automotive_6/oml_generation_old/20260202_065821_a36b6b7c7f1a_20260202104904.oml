// C4: Components
instance LowerChassisComponent : DTDFVocab:Component [
    base:desc "Lower chassis of the 1/10-scale robotic vehicle, providing structural support."
]

instance UpperChassisComponent : DTDFVocab:Component [
    base:desc "Upper chassis part, housing the autonomous payload and sensor suite."
]

instance AdaptiveCruiseControlComponent : DTDFVocab:Component [
    base:desc "Adaptive Cruise Control (ACC) controller responsible for lead‑vehicle detection and speed regulation."
]

instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder ESC driven by high‑frequency PWM from the low‑level control FE to throttle the vehicle."
]

// C3: Physical sensing components
instance HokuyoUST110LXLidarSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑110LX LiDAR scanner providing 3D point‑cloud data."
    DTDFVocab:producedData LidarPointCloudRawData
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera delivering RGB‑D streams."
    DTDFVocab:producedData DepthCameraRGBDRawData
]

instance VehicleStateMonitoringSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state monitors generating telemetry such as speed, acceleration, and wheel angles."
    DTDFVocab:producedData VehicleStateTelemetryRawData
]

// C4: Data Transmitted
instance LidarPointCloudRawData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST110LXLidarSensor
]

instance DepthCameraRGBDRawData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

instance VehicleStateTelemetryRawData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateMonitoringSensor
]

// C10: Data
instance ProcessedLidarPointCloudData : DTDFVocab:Data [
    base:desc "Unit‑converted, serialized LiDAR point cloud ready for clustering."
    DTDFVocab:inputTo DataTranslation, PointCloudClusteringAndTrackingComponent
    DTDFVocab:fromData LidarPointCloudRawData
]

instance ProcessedDepthCameraRGBDData : DTDFVocab:Data [
    base:desc "Pre‑processed RGB‑D data after unit standardisation."
    DTDFVocab:inputTo DataTranslation
    DTDFVocab:fromData DepthCameraRGBDRawData
]

instance ProcessedVehicleStateTelemetryData : DTDFVocab:Data [
    base:desc "Kalman‑filtered vehicle state telemetry providing consistent units."
    DTDFVocab:inputTo DataTranslation
    DTDFVocab:fromData VehicleStateTelemetryRawData
]

// C11: Enablers
instance DataTranslation : DTDFVocab:Enabler [
    base:desc "Serialises streams, standardises message types, and performs unit conversions."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance PointCloudClusteringAndTrackingComponent : DTDFVocab:Enabler [
    base:desc "DBSCAN clustering followed by Kalman‑filter tracking applied to LiDAR data."
    DTDFVocab:enables DataMonitoringService
]

instance DataPreprocessingFE : DTDFVocab:Enabler [
    base:desc "Data fusion FE that applies Kalman filter to fuse raw sensor measurements."
    DTDFVocab:enables RemoteManagementService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Stores historical event logs for analytical queries."
    DTDFVocab:enables DataMonitoringService
]

// C10: Models
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering followed by Kalman‑filter tracking model for object detection."
    DTDFVocab:inputTo PointCloudClusteringAndTrackingComponent
]

instance BehavioralACCModel : DTDFVocab:Model [
    base:desc "ACC behavioral model governing vehicle dynamics."
    DTDFVocab:inputTo DataPreprocessingFE
]

instance HistoricalEventLogStorageModel : DTDFVocab:Model [
    base:desc "Analytical model for historic event log storage."
    DTDFVocab:inputTo DataStorageEnabler
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Visualises real‑time vehicle state, projected driving path, and detected object tracks."
    DTDFVocab:provides ACCPerformanceInsight, VisualizeDataAction, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Transfers ACC decision logic from the on‑board ECU to cloud or edge compute nodes."
    DTDFVocab:provides OffloadACCLogicAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Real‑time remote control of ACC, including enable/disable, speed configuration, and emergency braking."
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance ACCPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight into ACC performance derived from vehicle state and tracking data."
]

// C17: Actions
instance VisualizeDataAction : DTDFVocab:Action [
    base:desc "Opens the 3D visualization interface to display vehicle state and tracking information."
    DTDFVocab:IsAutomatic false
]

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Generates detailed reports on vehicle operation and sensor data."
    DTDFVocab:IsAutomatic false
]

instance OffloadACCLogicAction : DTDFVocab:Action [
    base:desc "Offloads ACC decision logic to external compute resources."
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables the Adaptive Cruise Control system remotely."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disables the Adaptive Cruise Control system remotely."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets the desired cruise speed for the ACC system."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Triggers emergency braking through remote command."
    DTDFVocab:IsAutomatic false
]

// C17: Environment
instance ACCControlledTestTrackEnvironment : DTDFVocab:Environment [
    base:contains LowerChassisComponent, UpperChassisComponent, AdaptiveCruiseControlComponent,
    VedderElectronicSpeedController, HokuyoUST110LXLidarSensor, IntelD435iDepthCamera,
    VehicleStateMonitoringSensor, DataTranslation, PointCloudClusteringAndTrackingComponent,
    DataPreprocessingFE, DataStorageEnabler, DataMonitoringService,
    ComputationOffloadingService, RemoteManagementService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands from the DT (e.g., steering or motor actuation requests produced by the Control Panel FE) are dispatched through the Controlling FE. Commands are serialized into messages matching the vehicle’s actuator interface (likely a ROS2 topic over UDP via Wi‑Fi). The document does not detail explicit command formats, authentication, or validation mechanisms. Feedback is provided by periodically updated vehicle state signals (e.g., wheel speed, steering angle) that are re‑integrated into the DT. Conflict resolution and execution confirmation procedures are not described in the provided excerpts."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin operates with a 100 ms clock‑synchronization accuracy imposed by hardware limitations; devices use this shared time base to coordinate computation off‑loading. Network latency between the physical and digital twins is constrained to a maximum of 100 ms to satisfy the required real‑time performance. No finer temporal granularity or higher‑frequency synchronization is specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system adheres to an ISO 23247‑based reference architecture, structuring its software around three primary entities: User, Digital Twin, and Physical Twin. Each functional element is encapsulated as a ROS 2 package containing one or more ROS 2 nodes; this mapping aligns with the entity‑based hierarchy of ISO 23247. The User Entity hosts the User Interface FE, which is split into distinct 3D Visualization and Control Panel components. The Digital Twin Entity aggregates components responsible for data management and control mechanisms, such as data storage, while the Physical Twin Entity handles resource‑specific functionalities, including sensor/actuator interfaces and autonomous processing tasks like point‑cloud clustering and tracking. Deployment occurs across multiple hardware nodes, so ownership of each functional entity’s implementation may differ from the standard ISO 23247 definition, leading to deviations that affect engineering practices but preserve the overall architectural integrity. No additional data storage entity is listed; the component lacks a natural Functional Entity mapping but remains part of the Digital Twin Entity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT’s internal software network is built on ROS 2, providing message‑passing between SW components. For communication between the Physical Twin Entity and the Digital Twin Entity, a Wi‑Fi connection that carries UDP packets is employed. The document does not specify further details such as bandwidth, latency, reliability, redundancy, or security protocols for this network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system follows the ISO 23247‑2021 digital twin framework for manufacturing, implementing the prescribed reference architecture with entities for the Observable Manufacturing Element (OME), Data Collection and Device Control, Digital Twin, and User interfaces.  Each entity is composed of Functional Entities (FEs) that execute specific tasks such as OME actuation, data transformation into human‑interpretable forms, and user interaction.  Communication between FEs and the OME may be realized using OPC Unified Architecture (OPC UA) or similar interoperable industrial protocols, as exemplified by the reference implementation on GitHub (https://github.com/McSCert/Automotive-Digital-Twin) and its public demonstration video.  The approach aligns with ISO 23247’s interoperability and information‑exchange guidelines but does not prescribe specific tooling beyond the mentioned OPC UA usage."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin aligns its safety architecture with ISO 15622, which specifies the performance requirements and test procedures for Adaptive Cruise Control systems.  Per ISO 15622, the system must demonstrate compliance with the functional‑safety lifecycle defined in ISO 26262‑1, including hazard identification, risk assessment, and verification of safety mechanisms.  The twin also adheres to the end‑to‑end latency constraints set out in 3GPP TS 22.185 for V2X services, ensuring that safety‑critical data is transmitted within the required delay budget (on the order of 10–15 ms) to support real‑time control decisions.  Safety‑critical measures encompass built‑in fail‑safe modes, redundancy of critical data streams, and formal safety validation procedures as mandated by ISO 26262.  These combined references guarantee that the system’s operation remains within the bounds of acceptable safety risk while meeting industry‑standard communication performance."
]