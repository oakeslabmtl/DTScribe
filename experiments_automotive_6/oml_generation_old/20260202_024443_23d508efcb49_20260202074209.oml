// Sensors (Physical Sensing Components)
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST 10LX LiDAR sensor for object detection and range measurement"
    DTDFVocab:producedData RawLiDARPointCloud
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera providing visual depth images"
    DTDFVocab:producedData DepthImage
]

instance ESCspeedSensor : DTDFVocab:SensingComponent [
    base:desc "Electronic speed controller speed sensor for measuring vehicle speed"
    DTDFVocab:producedData VehicleSpeed
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering servo encoder sensor for measuring steering angle"
    DTDFVocab:producedData SteeringAngle
]

// Data Transmitted (Physical to Virtual Interaction)
instance RawLiDARPointCloud : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthImage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

instance VehicleSpeed : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ESCspeedSensor
]

instance SteeringAngle : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ObjectTracks : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

// Data (Digital Twin Data)
instance TelemetryTimeseriesData : DTDFVocab:Data [
    base:desc "Persisted timeseries telemetry data of vehicle speed, steering angle, and sensor streams"
    DTDFVocab:fromData RawLiDARPointCloud, DepthImage, VehicleSpeed, SteeringAngle, ObjectTracks
    DTDFVocab:inputTo ROS2MiddlewareEnabler, DatabaseStorageEnabler
]

// Acting Components (Physical Acting Components)
instance VedderESCActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder ESC converting desired speed commands into motor voltage"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator driven by ESC/Jetson for yaw control"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency braking actuator commanded via ESC"
]

// Models (Functional Models)
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering on raw LiDAR point clouds to detect obstacles"
    DTDFVocab:inputTo SimulinkMatlabEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking of object tracks from LiDAR data"
    DTDFVocab:inputTo SimulinkMatlabEnabler
]

instance ACCControllerModel : DTDFVocab:Model [
    base:desc "ISO 15622 Adaptive Cruise Control controller model"
    DTDFVocab:inputTo NVIDIAJetpackEnabler
]

instance VisualizationModel : DTDFVocab:Model [
    base:desc "3D visualization rendering of vehicle state"
    DTDFVocab:inputTo RoboRacerFrameworkEnabler
]

// Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware (Python 3.8 & C++) facilitating real-time message passing"
    DTDFVocab:enables TelemetryMonitoringService, ACCComputationOffloadingService, ACCRemoteManagementService
]

instance DatabaseStorageEnabler : DTDFVocab:Enabler [
    base:desc "External SQL database enabler for persisting telemetry timeseries"
    DTDFVocab:enables DataStorageService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data translation front‑end converting raw streams to ROS 2 DDS messages over Wi‑Fi"
    DTDFVocab:enables TelemetryMonitoringService
]

instance SimulinkMatlabEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink runtime for clustering, tracking, and report generation"
    DTDFVocab:enables ReportGenerationService
]

instance NVIDIAJetpackEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK enabling accelerated computation on Jetson Orin Nano"
    DTDFVocab:enables ACCComputationOffloadingService
]

instance RoboRacerFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source RoboRacer framework for autonomous driving"
    DTDFVocab:enables ACCVisualizationService
]

instance OPCUAEnabler : DTDFVocab:Enabler [
    base:desc "OPC UA based data translation optional enabler for industrial interoperability"
    DTDFVocab:enables ACCRemoteManagementService
]

instance WiFiNetworkingEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi networking enabler for wireless communication between PT and DT"
    DTDFVocab:enables TelemetryMonitoringService
]

// Services
instance TelemetryMonitoringService : DTDFVocab:Service [
    base:desc "Data monitoring and real‑time telemetry UI for vehicle performance"
    DTDFVocab:provides VehicleTelemetryInsight
]

instance ACCComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation offloading for Adaptive Cruise Control algorithm"
    DTDFVocab:provides ACCOffloadInsight, ACCOffloadAction
]

instance ACCRemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management of ACC (enable/disable, set target speed, emergency brake)"
    DTDFVocab:provides ACCRemoteManagementInsight, EnableACCAction, SetTargetSpeedAction, EmergencyBrakeAction
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Data storage to an external SQL database for historical telemetry"
    DTDFVocab:provides DataStorageInsight
]

instance ACCVisualizationService : DTDFVocab:Service [
    base:desc "Adaptive‑cruise‑control simulation and visualization"
    DTDFVocab:provides ACCVisualizationInsight
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Report generation of human‑readable time‑series for performance analysis"
    DTDFVocab:provides ReportInsight
]

// Insights
instance VehicleTelemetryInsight : DTDFVocab:Insight [
    base:desc "Real‑time vehicle telemetry insight for performance monitoring"
]

instance ACCOffloadInsight : DTDFVocab:Insight [
    base:desc "Insight into ACC computation offloading status and latency"
]

instance ACCRemoteManagementInsight : DTDFVocab:Insight [
    base:desc "Insight on remote ACC management actions and status"
]

instance DataStorageInsight : DTDFVocab:Insight [
    base:desc "Database storage insight showing persisted telemetry availability"
]

instance ACCVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization insight of ACC simulation and vehicle state"
]

instance ReportInsight : DTDFVocab:Insight [
    base:desc "Human‑readable time‑series report for performance analysis"
]

// Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable or disable ACC remotely"
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Set target speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Trigger emergency brake via ESC"
    DTDFVocab:IsAutomatic false
]

instance ACCOffloadAction : DTDFVocab:Action [
    base:desc "Automatically offload ACC computation to cloud"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT emits desired‑speed commands, emergency‑brake triggers, enable/disable ACC signals, and steering adjustments; all are sent over Wi‑Fi as ROS 2 DDS messages, received by the Physical Twin Entity and forwarded to ESC/sensors."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All end‑to‑end communication and control loops are bounded by ≤100 ms latency (3GPP 3rd GPP v3.3‑162). Clock synchronization across all components is maintained to within 100 ms accuracy; data rates for LiDAR features nominally 10–20 Hz, with ROS 2 QoS configured for real‑time delivery."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation follows ISO 23247 RA: Physical Twin Entity encapsulates vehicle hardware, Digital Twin Entity executes simulation/ACC logic, User Entity provides dual FE for 3‑D visualization and control panel; inter‑entity communication is handled by the Data Translation cross‑system FE. All entities collaborate over ROS 2 DDS on a single Wi‑Fi broadcast domain."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the *operated* stage of the vehicle lifecycle, providing real‑time operational monitoring and remote control; the same platform can also be reused for design validation and post‑manufacturing analysis, but the case study focuses on the operation phase."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity ensured by applying DBSCAN for raw LiDAR clustering and Kalman filtering for track estimation, ISO 15622 compliance for ACC logic, clock sync tolerance of 100 ms, and ROS 2 QoS settings for guaranteed‑delivery of telemetry; uncertainty in perception and actuator command latency is explicitly bounded by the 100 ms requirement."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical and Digital twins are connected over IEEE 802.11 (Wi‑Fi) using ROS 2 DDS for inter‑entity messaging; the Data Translation FE serializes data packets and translates between physics and digital representations; all network traffic is encapsulated in standard ROS 2 middleware messages."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital Twin Entity is hosted on a remote cloud server (public cloud or local data‑center) with high‑performance compute; Physical Twin Entity resides on the vehicle’s NVIDIA Jetson Orin Nano; the User Entity runs on operator workstations; all layers communicate via Wi‑Fi."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture (Part 2 RA), ISO 15622 ACC specification, ROS 2 middleware (DDS standard), IEEE 802.11 Wi‑Fi network, OPC UA optional for data translation"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "System operates under strict safety‑critical constraints with 100 ms latency requirement; ACC logic complies with ISO 15622, and control commands are transmitted over ROS 2 DDS, but explicit encryption/authentication mechanisms are not described; safety‑related fail‑safe behavior is implied by adherence to ACC safety standards."
]