// ==================== Sensing Components ====================
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing 2D point‑cloud measurements for obstacle detection."
    DTDFVocab:producedData LidarPointCloudStream
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering aligned RGB‑D images for perception."
    DTDFVocab:producedData DepthImageStream
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board wheel‑speed sensor reporting vehicle longitudinal speed."
    DTDFVocab:producedData VehicleSpeedStream
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle encoder measuring front‑wheel steering position."
    DTDFVocab:producedData SteeringAngleStream
]

// ==================== Data Transmitted ====================
instance LidarPointCloudStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthImageStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
]

instance VehicleSpeedStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// ==================== Raw Data ====================
instance LidarPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream used for clustering."
    DTDFVocab:fromData LidarPointCloudStream
    DTDFVocab:inputTo DataProcessingEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Raw depth image stream used for scene understanding."
    DTDFVocab:fromData DepthImageStream
    DTDFVocab:inputTo DataProcessingEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Real‑time vehicle speed measurement."
    DTDFVocab:fromData VehicleSpeedStream
    DTDFVocab:inputTo DataProcessingEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Real‑time steering angle measurement."
    DTDFVocab:fromData SteeringAngleStream
    DTDFVocab:inputTo DataProcessingEnabler
]

// ==================== Acting Components ====================
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Converts desired speed from DT into motor voltage commands for the Vedder ESC."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Drives the steering servo to adjust steering angle based on DT commands."
]

// ==================== Models ====================
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point clouds to segment obstacle clusters."
    DTDFVocab:inputTo DataProcessingEnabler
]

instance KalmanTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking of clustered objects across frames."
    DTDFVocab:inputTo DataProcessingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control logic conforming to ISO‑15622 performance class I."
    DTDFVocab:inputTo ACCComputationEnabler
]

// ==================== Enablers (Processing & Tooling) ====================
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processes raw sensor streams (LiDAR, depth, speed, steering) using DBSCAN clustering and Kalman tracking to generate object tracks and projected paths."
    DTDFVocab:enables DataMonitoringService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Executes ACC algorithm, receiving desired speed from operator and producing acceleration/braking commands."
    DTDFVocab:enables ComputationOffloadingService
]

instance ReportingEnabler : DTDFVocab:Enabler [
    base:desc "Aggregates vehicle state and object‑track data into a SQL database and generates post‑run analytical reports."
    DTDFVocab:enables ReportingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Handles remote‑management commands (enable/disable ACC, adjust speed, emergency brake) over Wi‑Fi and OPC‑UA."
    DTDFVocab:enables RemoteManagementService
]

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware providing DDS communication between functional entities and hardware partitions."
]

instance NVIDIAJetPackEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK enabling GPU‑accelerated perception and compute on Jetson NX/Orin‑Nano."
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink toolchain used for developing DBSCAN and Kalman tracking algorithms."
]

instance WiFiLinkEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi link facilitating PT‑DT communication and remote‑management traffic."
]

instance OPCUAEnabler : DTDFVocab:Enabler [
    base:desc "OPC‑UA (IEC 62541) stack for standardized data translation between entities."
]

// ==================== Services ====================
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI display of vehicle speed, steering angle, object tracks, and projected path."
    DTDFVocab:provides RealTimeSpeedInsight, RealTimeSteeringAngleInsight, ObjectTracksInsight, ProjectedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC computation to the Digital Twin and returns control commands to the Physical Twin."
    DTDFVocab:provides ACCComputationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operator to enable/disable ACC, adjust desired speed, and trigger emergency braking remotely."
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakingAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Generates post‑run analytical reports for performance analysis and parameter tuning."
    DTDFVocab:provides PostRunReportInsight
]

// ==================== Insights ====================
instance RealTimeSpeedInsight : DTDFVocab:Insight [
    base:desc "Displays current vehicle speed to the operator in real time."
]

instance RealTimeSteeringAngleInsight : DTDFVocab:Insight [
    base:desc "Shows current steering angle to the operator in real time."
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Presents tracked object trajectories derived from LiDAR clustering and Kalman filtering."
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Visualizes the projected future path of the ego‑vehicle based on current state and ACC output."
]

instance PostRunReportInsight : DTDFVocab:Insight [
    base:desc "Provides a summary report of vehicle state, object tracks, and ACC performance after each run."
]

// ==================== Actions ====================
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables Adaptive Cruise Control on the physical vehicle."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disables Adaptive Cruise Control on the physical vehicle."
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Adjusts the desired speed setpoint for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Triggers immediate emergency braking by reducing motor voltage."
    DTDFVocab:IsAutomatic false
]

instance ACCComputationAction : DTDFVocab:Action [
    base:desc "Computes ACC control output (throttle/brake) automatically."
    DTDFVocab:IsAutomatic true
]

// ==================== Entity Environments ====================
instance PhysicalTwinEntity : DTDFVocab:Environment [
    base:contains HokuyoUST10LXLidar, IntelRealSenseD435iDepthCamera, VehicleSpeedSensor, SteeringAngleSensor, MotorVoltageActuator, SteeringServoActuator
]

instance DigitalTwinEntity : DTDFVocab:Environment [
    base:contains DataProcessingEnabler, ACCComputationEnabler, ReportingEnabler, RemoteManagementEnabler, DBSCANClusteringModel, KalmanTrackingModel, ACCControlModel, DataMonitoringService, ComputationOffloadingService, RemoteManagementService, ReportingService
]

instance UserEntity : DTDFVocab:Environment [
    base:contains DataMonitoringService, RemoteManagementService, ReportingService
]

instance CrossSystemEntity : DTDFVocab:Environment [
    base:contains ROS2MiddlewareEnabler, WiFiLinkEnabler, OPCUAEnabler, NVIDIAJetPackEnabler, MATLABSimulinkEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends motor voltage commands and steering‑servo setpoints generated by the Controlling FE (ACC) and Actuation FE, as well as remote‑management commands (enable/disable ACC, set desired speed, emergency brake) issued through the User Interface FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sub‑second real‑time operation with a hard end‑to‑end latency limit of 100 ms between PT and DT; component clocks are synchronized to within 100 ms accuracy."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The PT runs the Physical Twin Entity on its Jetson hardware, exposing sensor data over ROS 2; the Digital Twin Entity runs on separate compute (e.g., cloud/PC) and receives data via Wi‑Fi, performs ACC, reporting, and visualization preprocessing; the User Entity provides a 3D visualization and control panel UI; all entities inter‑communicate through ROS 2 topics and a Cross‑System Data Translation FE that serializes and converts units."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity sensor processing (DBSCAN, Kalman filter) ensures accurate object tracks; ACC follows ISO 15622 specifications; latency ≤100 ms and clock sync ≤100 ms guarantee timely and ordered data for safety‑critical operation; external SQL storage keeps a complete timeseries for validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bi‑directional Wi‑Fi link between PT and DT; ROS 2 publish/subscribe transports intra‑entity messages; Data Translation FE serializes data, aligns message types and performs unit conversions; optional OPC‑UA transport is mentioned as a possible implementation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity components execute on the vehicle’s Jetson Orin Nano; Digital Twin Entity components (data collection, ACC, reporting, visualization preprocessing) run on an external computing platform (e.g., cloud or workstation) accessed via Wi‑Fi; each FE is packaged as an independent ROS 2 node for modular deployment."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (reference architecture and functional entities), uses ISO 15622 for ACC functional specifications, references IEC 62541 OPC‑UA as a possible communication standard, and adopts 3GPP 22.185 latency requirements; ROS 2 and NVIDIA JetPack provide de‑facto industrial tooling standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The system is designed for safety‑critical operation with strict latency (≤100 ms) and clock‑sync (≤100 ms) constraints; remote management includes an emergency braking command; although explicit security mechanisms are not described, the architecture assumes safe operation of remote commands on a physical twin."
]