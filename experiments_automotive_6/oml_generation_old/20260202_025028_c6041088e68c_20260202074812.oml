// Sensing Components
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing raw point clouds"
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera capturing RGB-D frames"
    DTDFVocab:producedData DepthImageDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor via wheel encoder or CAN bus"
    DTDFVocab:producedData SpeedMeasurementDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring vehicle heading"
    DTDFVocab:producedData SteeringAngleMeasurementDataTransmitted
]

// Data Transmitted
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthImageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

instance SpeedMeasurementDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleMeasurementDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Data
instance LiDARPointCloudPacket : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud packet"
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
]

instance DepthImagePacket : DTDFVocab:Data [
    base:desc "Depth image packet from Intel D435i"
    DTDFVocab:fromData DepthImageDataTransmitted
]

instance SpeedDataPacket : DTDFVocab:Data [
    base:desc "Vehicle speed data packet"
    DTDFVocab:fromData SpeedMeasurementDataTransmitted
]

instance SteeringAngleDataPacket : DTDFVocab:Data [
    base:desc "Vehicle steering angle data packet"
    DTDFVocab:fromData SteeringAngleMeasurementDataTransmitted
]

// Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point clouds for object detection"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking of clustered objects"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ISO15622_ACCModel : DTDFVocab:Model [
    base:desc "ACC logic per ISO 15622 Class I for lead vehicle detection and speed calculation"
    DTDFVocab:inputTo ComputationEnabler
]

instance DataTranslationModel : DTDFVocab:Model [
    base:desc "Translates and serialises raw data, aligning message types and performing unit conversions"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance SQLDatabaseModel : DTDFVocab:Model [
    base:desc "Persisting object track and vehicle state data into a SQL database"
    DTDFVocab:inputTo ReportingEnabler
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3D rendering model for vehicle trajectory, object tracks, and projected path"
    DTDFVocab:inputTo VisualizationEnabler
]

// Enablers
instance ROS2CommunicationEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware enabling inter-component communication"
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data translation via serialisation and unit conversion"
    DTDFVocab:enables DataTranslationService
]

instance ComputationEnabler : DTDFVocab:Enabler [
    base:desc "Execution platform for ACC computation on NVIDIA Jetson Orin Nano"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Operator interface enabling ACC enable/disable, speed adjustment, and emergency brakes"
    DTDFVocab:enables RemoteManagementService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Feeds 3D visualization FE with rendered data"
    DTDFVocab:enables VisualizationService
]

instance ReportingEnabler : DTDFVocab:Enabler [
    base:desc "Generates time-series reports from persisted data in the SQL database"
    DTDFVocab:enables ReportingService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time UI for viewing, saving, and reporting vehicle state and object tracks"
    DTDFVocab:provides VehicleStateInsight, ObjectTrackInsight
]

instance DataTranslationService : DTDFVocab:Service [
    base:desc "Serialises and aligns data from heterogeneous sensors"
    DTDFVocab:provides TranslatedDataInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC logic executed in the DT; calculates desired speed and issues remote actuation"
    DTDFVocab:provides ACCDecisionInsight
    DTDFVocab:provides RemoteActuationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator interface to enable/disable ACC, adjust desired speed, and issue emergency brakes"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakeAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D rendering of vehicle trajectory, object tracks, and projected path"
    DTDFVocab:provides RenderTrajectoryInsight
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Generates time-series reports of vehicle and perception data stored in a SQL database"
    DTDFVocab:provides TimeSeriesReportInsight
]

// Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current vehicle speed and steering angle states"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Insight into tracked object positions and velocities"
]

instance TranslatedDataInsight : DTDFVocab:Insight [
    base:desc "Insight into serialized and unit-converted data streams"
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "Calculated desired speed and ACC decisions based on lead vehicle detection"
]

instance RenderTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Rendered 3D path of vehicle and projected trajectory"
]

instance TimeSeriesReportInsight : DTDFVocab:Insight [
    base:desc "Time-series report of vehicle and perception data"
]

// Actions
instance RemoteActuationAction : DTDFVocab:Action [
    base:desc "Actuation command sent to vehicle actuators for adjusted speed and steering"
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Remote command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Remote command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Remote command to set desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Remote command to issue emergency braking"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DTS publishes desired speed commands, ACC enable/disable, desired speed modification, and emergency braking signals back to the PT via ROS2 topics/services; the Actuation FE packages these commands as motor voltage and steering voltage signals sent to the PT’s ESC and steering servo; the interaction occurs over the vehicle’s Wi‑Fi link with a 100 ms latency budget."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with an overall vehicle‑to‑DT latency budget of ≤100 ms and synchronized clocks across PT and DT with an accuracy of 100 ms; perception data is sampled at each ROS2 cycle (typically 10–20 Hz in practice, but not explicitly quantified in the document)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "ISO 23247‑based entity decomposition: Physical Twin Entity (hardware and sensor/actuator handling), Digital Twin Entity (data collection, processing, and ACC logic), User Entity (UI and remote control), and Cross‑System Entity (Data Translation); deployment spans onboard Jetson, external server, and client UI, with ROS2 topics and services coordinating all interactions."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT operates primarily in the 'operated' life‑cycle stage of the physical twin, providing real‑time monitoring and control; the development and testing stages are also implied by the case study’s requirement definition, architectural design, and implementation phases, but explicit design/ideal modeling is minimal in the provided text."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time constraints (≤100 ms latency, 100 ms clock sync) ensure temporal fidelity; DBSCAN clustering and Kalman filtering provide accuracy in object tracking; the SQL database stores raw and processed data for validation; compliance with ISO 15622 for ACC ensures functional correctness, though explicit V&V procedures are not described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical twin communicates with the DT over a Wi‑Fi network using ROS2, which implements the DDS (Data Distribution Service) protocol; the Data Translation FE handles serialization; all messages are exchanged via ROS2 topics and services across distributed nodes."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity runs on an external computing platform (cloud or dedicated server) connected via Wi‑Fi; ROS2 nodes for the Physical Twin Entity execute on the NVIDIA Jetson Orin Nano within the vehicle; the User Interface runs on a separate client workstation; all components are orchestrated via ROS2 life‑cycle management."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Architecture follows ISO 23247 (Digital Twin Manufacturing Framework Reference Architecture); control logic aligns with ISO 15622 for ACC; ROS2 and NVIDIA JetPack adhere to open‑source and industry standards; data translation uses conventional serialization techniques."
]