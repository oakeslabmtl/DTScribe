// Sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor capturing raw point cloud data represented as individual points on a 2D plane"
    DTDFVocab:producedData LiDARRawDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing vehicle state information transmitted from the vehicle"
    DTDFVocab:producedData VehicleStateDataTransmitted
]

instance MotorActuationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing motor actuation state information from the vehicle"
    DTDFVocab:producedData MotorActuationDataTransmitted
]

instance SteeringServoStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing steering servo state information from the vehicle"
    DTDFVocab:producedData SteeringServoStateDataTransmitted
]

// Data transmitted instances
instance LiDARRawDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance MotorActuationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorActuationSensor
]

instance SteeringServoStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoStateSensor
]

// Data instances
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "LiDAR point cloud data after serialization and unit conversion"
    DTDFVocab:inputTo DataMonitoringEnabler
    DTDFVocab:fromData LiDARRawDataTransmitted
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state information after transformation into a human-interpretable format"
    DTDFVocab:inputTo DataMonitoringEnabler
    DTDFVocab:inputTo ACCProcessingEnabler
    DTDFVocab:fromData VehicleStateDataTransmitted
]

instance MotorActuationData : DTDFVocab:Data [
    base:desc "Motor actuation state data after transformation"
    DTDFVocab:inputTo ACCProcessingEnabler
    DTDFVocab:fromData MotorActuationDataTransmitted
]

instance SteeringServoStateData : DTDFVocab:Data [
    base:desc "Steering servo state data after transformation"
    DTDFVocab:fromData SteeringServoStateDataTransmitted
]

// Enablers
instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Component that processes vehicle state and LiDAR point cloud data for real-time monitoring"
    DTDFVocab:enables DataMonitoringService
]

instance ACCProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Component that receives vehicle state data, computes desired speed for ACC, and sends command back to the vehicle"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Component that allows remote operators to enable/disable ACC, set desired speed, and issue emergency braking commands"
    DTDFVocab:enables RemoteManagementService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data monitoring UI with real-time vehicle state, projected driving path, detected object tracks, and report generation"
    DTDFVocab:provides VehicleStateInsight, ObjectTrackingInsight, DrivingPathInsight, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service that offloads ACC computation from the vehicle and returns the desired speed command"
    DTDFVocab:provides SendDesiredSpeedCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service that enables remote control of ACC, desired speed, and emergency braking"
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of vehicle state information"
]

instance ObjectTrackingInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of detected and tracked objects from LiDAR data"
]

instance DrivingPathInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of the projected driving path"
]

// Actions
instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Generate and save a report of vehicle telemetry"
    DTDFVocab:IsAutomatic false
]

instance SendDesiredSpeedCommandAction : DTDFVocab:Action [
    base:desc "Send the computed desired speed command to the vehicle"
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable or disable the Adaptive Cruise Control (ACC) system"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set a desired speed for the vehicle"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issue an emergency braking command to the vehicle"
    DTDFVocab:IsAutomatic false
]

// Environment
instance VehicleEnvironment : DTDFVocab:Environment [
    base:contains LiDARSensor, VehicleStateSensor, MotorActuationSensor, SteeringServoStateSensor,
            DataMonitoringEnabler, ACCProcessingEnabler, RemoteManagementEnabler
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system aligns all digital twin entities to a common time base with a synchronization accuracy requirement of 100 ms. Components exchange timestamps via the underlying ROS 2 middleware. No specific synchronization frequency is declared, but every update cycle that drives the physical twin must respect the 100 ms latency bound imposed by the hardware limits of safety‑critical vehicular applications."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 reference architecture, organizing software into three logical entities—Physical Twin, Digital Twin, and User. Each functional element (FE) is implemented as a ROS 2 package containing one or more ROS 2 nodes. The Physical Twin Entity hosts resource‑specific services such as point‑cloud clustering and tracking; the Digital Twin Entity manages data processing, storage, and control logic; and the User Entity exposes the 3‑D visualization and control‑panel interfaces. This entity‑centric design enables clear ownership of functionality, facilitates deployment across heterogeneous hardware, and supports orchestration via standard ROS 2 topics and services."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin employs a ROS2-based middleware for intra‑software component communication, leveraging DDS over UDP for message passing. Inter‑entity communication between the Physical Twin Entity and Digital Twin Entity occurs over a Wi‑Fi network utilizing UDP. The architecture emphasizes a real‑time data pipeline, with the Data Translation component ensuring consistent data formats and units across all streams. No explicit bandwidth, latency, or reliability metrics are documented, but the design implies a requirement for continuous, low‑latency UDP transmission to support live visualization and control."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin system complies with ISO 23247 – Digital twin framework for manufacturing, adopting its entity‑based reference architecture that defines separate entities for data collection, digital representation, and user interaction. The standard further permits the use of OPC Unified Architecture (OPC UA) for implementing functional entities, thereby ensuring interoperability with standardized industrial automation protocols."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety provisions for the digital twin adhere to ISO 26262 functional safety guidelines. The safety lifecycle executes hazard analysis and risk assessment, deriving safety goals that map to safety classes A–D. Safety integrity levels (SIL) are specified and implemented through redundant sensing, fault‑tolerant software architecture, and fail‑safe mechanisms. Verification and validation of safety functions rely on simulation, fault injection, and formal proof aligned with ISO 26262 Part 6. The system also employs 3GPP TS 22.185–derived V2X security measures: mutual authentication via asymmetric PKI, integrity protection with MAC, confidentiality with AES‑GCM, and message authentication to prevent spoofing. These protocols enforce access control, secure key management, and logging to meet the communication security requirements for vehicle‑to‑everything services."
]