// =============================
// C3: Physical sensing components
// =============================

instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor delivering point‑cloud data from the physical vehicle"
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance CameraSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board camera used for visualisation in the digital twin"
    DTDFVocab:producedData CameraImageDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑state speed sensor providing current speed"
    DTDFVocab:producedData SpeedDataTransmitted
]

instance VehiclePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑state position sensor providing GPS/pose information"
    DTDFVocab:producedData PositionDataTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting motor status (rpm, torque) for preprocessing"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

instance SteeringStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting steering servo angle and health"
    DTDFVocab:producedData SteeringStatusDataTransmitted
]

instance ServoStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting auxiliary servo status used by the data‑pre‑processing FE"
    DTDFVocab:producedData ServoStatusDataTransmitted
]

// =============================
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// =============================

instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance CameraImageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CameraSensor
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehiclePositionSensor
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance SteeringStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringStatusSensor
]

instance ServoStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ServoStatusSensor
]

// =============================
// C10: Models / Data
// =============================

instance ProcessedPointCloudData : DTDFVocab:Data [
    base:desc "Clustered and tracked point‑cloud objects after DBSCAN + Kalman filtering"
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
    DTDFVocab:inputTo DataPreProcessingEnabler , DataTranslationEnabler
]

instance NormalizedVehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle speed, position, motor and steering status after unit conversion"
    DTDFVocab:fromData SpeedDataTransmitted , PositionDataTransmitted , MotorStatusDataTransmitted , SteeringStatusDataTransmitted , ServoStatusDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ACCDesiredSpeedData : DTDFVocab:Data [
    base:desc "Desired speed computed by the ACC control model"
    DTDFVocab:fromData NormalizedVehicleStateData
    DTDFVocab:inputTo ControllingEnabler
]

instance ActuationCommandData : DTDFVocab:Data [
    base:desc "Motor and steering commands issued to the physical actuators"
    DTDFVocab:fromData ACCDesiredSpeedData
    DTDFVocab:inputTo ActuationEnabler
]

instance PointCloudClusteringAndTrackingModel : DTDFVocab:Model [
    base:desc "Geometric processing of LiDAR point clouds (DBSCAN clustering and Kalman tracking)"
    DTDFVocab:inputTo DataPreProcessingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm that detects lead vehicle and computes desired speed"
    DTDFVocab:inputTo ControllingEnabler
]

instance DataTranslationModel : DTDFVocab:Model [
    base:desc "Serialisation, message‑type alignment and unit conversion for all streams"
    DTDFVocab:inputTo DataTranslationEnabler
]

// =============================
// C11: Enablers
// =============================

instance DataPreProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity that preprocesses raw sensor data (clustering, tracking, status aggregation)"
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity that normalises and translates data for downstream consumption"
    DTDFVocab:enables DataMonitoringService , ComputationOffloadingService
]

instance ControllingEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity that runs the ACC model and issues speed commands"
    DTDFVocab:enables ComputationOffloadingService , RemoteManagementService
]

instance ActuationEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity that forwards motor and steering commands to physical actuators"
    DTDFVocab:enables RemoteManagementService
]

// =============================
// C6: Services
// =============================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time UI visualisation of vehicle state, projected path and object tracks"
    DTDFVocab:provides SituationalAwarenessInsight , DecisionSupportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC control algorithm in the digital twin and returns desired speed to the vehicle"
    DTDFVocab:provides ACCDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, and issue emergency‑brake commands via the UI"
    DTDFVocab:provides EnableACCAction , SetDesiredSpeedAction , EmergencyBrakeAction
]

// =============================
// C17: Insights / Actions
// =============================

instance SituationalAwarenessInsight : DTDFVocab:Insight [
    base:desc "Real‑time awareness of vehicle state, point‑cloud clustering and tracking results"
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Human‑in‑the‑loop decision support through visualisation and control primitives"
]

instance ACCDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Transmit ACC computed desired speed to the motor controller"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable the Adaptive Cruise Control function"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets a target speed for the vehicle via the control panel"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator issues an immediate brake command to stop the vehicle"
    DTDFVocab:IsAutomatic false
]

// =============================
// C17: Additional Component (Actuating)
// =============================

instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Motor FE that controls vehicle propulsion based on speed commands"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo FE that adjusts steering angle based on command inputs"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity generates control commands via the ACC Controlling FE (lead‑vehicle detection and desired‑speed computation) and the User Interface FE (remote‑management commands such as enable/disable ACC, set desired speed, and emergency brake). Commands are transmitted over the ROS 2 network to the Actuation FE deployed on the Physical Twin Entity, where the Actuation component converts the desired speed into motor voltage commands and drives the steering servo. The actuation FE executes the commands on the vehicle; confirmation feedback is implied by the real‑time update of vehicle state data displayed in the UI, although explicit acknowledgement messages are not described."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DTS requires a clock synchronization accuracy of 100 ms between the vehicle’s on‑board sensors/actuators and the digital twin, as mandated by safety‑critical vehicular standards and limited by the hardware; all services (data monitoring, computation off‑loading and remote management) operate in real‑time with low end‑to‑end latency over a Wi‑Fi UDP link, and ROS2 intra‑entity messaging is assumed to be bounded within the same 100 ms window."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration follows the ISO 23247 reference architecture: software components (functional entities) are mapped to ROS2 nodes (FE) and packaged per entity; inter‑entity communication uses a UDP transport over Wi‑Fi, while intra‑entity messaging uses ROS2 DDS topics. The Data Translation FE serialises, aligns message types and performs unit conversions for every data stream, enabling the three services (data monitoring, off‑loading of the ACC algorithm, and remote management) to be composed from the underlying FEs. Resource management is achieved by off‑loading the ACC computation to an external compute node (cloud/edge) while actuation remains on the Physical Twin Entity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS relies on a hybrid network architecture: internal component communication uses ROS 2 packages (publish/subscribe pattern) and inter‑entity communication uses Wi‑Fi with UDP transport. The system requires clock synchronisation within 100 ms accuracy for safety‑critical off‑loading (as mandated by standards for vehicular applications). While specific bandwidth or latency figures are not listed, the requirement for low end‑to‑end latency is emphasised for remote management. No explicit reliability, redundancy, or security protocols (e.g., TLS) are described in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT offloads the ACC computation to a remote platform, which may be cloud‑based, but the documents do not specify the exact hosting environment, computational resources, storage architecture beyond an external SQL database, scalability mechanisms, or availability guarantees. Therefore, concrete hosting and deployment details are not provided."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DTS integrates external standards via the IEC 62541 OPC‑UA specification for the Data Translation FE (optional) and follows the ISO 23247 information‑exchange model. Data streams are exchanged over ROS2 DDS and UDP/Wi‑Fi, enabling interoperability with cloud or edge platforms for computation off‑loading. The architecture also allows optional integration with other enterprise systems through standard OPC‑UA or other middleware, as suggested by the mention of OPC‑UA as an implementation choice for FEs."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built to comply with the ISO 23247 Digital Twin Manufacturing Framework (parts 1‑4), which provides the overall development framework, reference architecture, digital representation of physical elements, and information‑exchange guidelines. Safety considerations are highlighted by recommending alignment with the automotive functional‑safety standard ISO 26262. The implementation also references AUTOSAR as a hardware‑agnostic software architecture model, and suggests the optional use of OPC Unified Architecture (IEC 62541) for the Data Translation FE. By adhering to these standards, the twin aims for interoperability with existing automotive tooling and certification processes, while leveraging the domain‑independent nature of ISO 23247 to integrate domain‑specific technologies such as ROS 2."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The documents address safety considerations for the automotive digital twin system: ISO 26262 functional safety standard is recommended to be promoted to a first‑class citizen for safety‑critical automotive DTs (Document 2), and the ACC functionality is implemented according to ISO 15622 performance class I requirements (Document 5, R6). No specific cybersecurity protocols, access control mechanisms, authentication systems, or threat mitigation strategies are described in the provided documents."
]