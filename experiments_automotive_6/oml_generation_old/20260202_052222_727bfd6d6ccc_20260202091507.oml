// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor providing raw 3D point clouds sampled at 10–30 Hz"
    DTDFVocab:producedData LiDARBinaryTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor capturing speed, steering angle, throttle, and brake pressure"
    DTDFVocab:producedData VehicleStateBinaryTransmitted
]

instance ObjectTrackingSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard Object Tracking algorithm generating object‑track and projected‑path messages"
    DTDFVocab:producedData ObjectTrackBinaryTransmitted
]

// C4: Physical-to-virtual interaction
instance LiDARBinaryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateBinaryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance ObjectTrackBinaryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ObjectTrackingSensor
]

// C10: Models/Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "LiDAR point cloud data after deserialization and unit conversion"
    DTDFVocab:fromData LiDARBinaryTransmitted
    DTDFVocab:inputTo Ros2DDSBridgeEnabler, CloudComputeEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state metrics data after filtering and normalization"
    DTDFVocab:fromData VehicleStateBinaryTransmitted
    DTDFVocab:inputTo Ros2DDSBridgeEnabler, CloudComputeEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Object track data after clustering and tracking"
    DTDFVocab:fromData ObjectTrackBinaryTransmitted
    DTDFVocab:inputTo Ros2DDSBridgeEnabler, CloudComputeEnabler
]

// C11: Enablers
instance Ros2DDSBridgeEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 DDS bridge enabling communication over industrial Wi‑Fi with 100 ms latency"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance CloudComputeEnabler : DTDFVocab:Enabler [
    base:desc "Cloud compute enabler (PostgreSQL, NVIDIA JetPack) executing ACC control algorithm"
    DTDFVocab:enables ComputationOffloadingService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring service for real‑time visualisation, snapshot, and report generation"
    DTDFVocab:provides LiveStreamInsight, SnapshotSaveInsight, ReportGenerationInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service providing ACC enabling/disabling, speed/distance setting, and emergency brake trigger"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetTargetSpeedAction, SetTargetDistanceAction, TriggerEmergencyBrakeAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation Offloading service executing ACC algorithm on cloud and returning desired speed"
    DTDFVocab:provides ReturnDesiredSpeedAction
]

// C17: Insights/Actions
instance LiveStreamInsight : DTDFVocab:Insight [
    base:desc "Live stream insight displaying real‑time LiDAR and depth camera data"
]

instance SnapshotSaveInsight : DTDFVocab:Insight [
    base:desc "Snapshot save insight for capturing and storing sensor snapshots"
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Report generation insight producing textual or graphical traffic context reports"
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Command to enable Adaptive Cruise Control system"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Command to disable Adaptive Cruise Control system"
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Command to set target ACC speed"
    DTDFVocab:IsAutomatic false
]

instance SetTargetDistanceAction : DTDFVocab:Action [
    base:desc "Command to set target ACC distance"
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Command to trigger emergency braking routine"
    DTDFVocab:IsAutomatic false
]

instance ReturnDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to return computed desired speed from cloud to vehicle"
    DTDFVocab:IsAutomatic false
]

// Additional physical architecture components
instance LowerLevelChassis : DTDFVocab:Component [
    base:desc "Lower‑level chassis of the 1/10-scale vehicle"
]

instance UpperLevelChassis : DTDFVocab:Component [
    base:desc "Upper‑level chassis providing structural support"
]

instance AdaptiveCruiseControlSystem : DTDFVocab:Component [
    base:desc "Integrated Adaptive Cruise Control system"
]

instance PhysicalVehicle : DTDFVocab:Environment [
    base:contains LowerLevelChassis, UpperLevelChassis, AdaptiveCruiseControlSystem
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin enforces a shared notion of time across all computation devices, requiring clock synchronization accuracy better than 100 ms; this 100 ms time‑stamping granularity is imposed on data exchanged between physical and digital layers to satisfy safety‑critical vehicular standards."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Architecture is derived from ISO 23247 Reference Architecture, mapping software components to functional entities and deploying each entity on separate hardware. Functional entities are organized into ROS 2 packages, with each package containing ROS 2 nodes implementing the FE’s responsibilities. The Digital Twin Entity aggregates data management and control modules, while the Physical Twin Entity encapsulates vehicle resources and general automotive functions such as point‑cloud clustering/tracking. The User Entity contains visualization and control panel sub‑components. System‑wide coordination is achieved via ROS 2 middleware, enabling inter‑entity messaging, shared data topics, and service calls."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All software components of the Digital Twin Service (DTS) are connected over an internal ROS 2 network that uses the Data Distribution Service (DDS) as transport layer, enabling low‑latency intra‑computer communication. Cross‑entity communication, i.e., between the vehicle’s physical twin and the DTS running on the cloud/edge cluster, is performed over Wi‑Fi using UDP sockets, as specified for the inter‑entity link in ISO 23247. The Data Translation FE serialises messages and executes unit conversion before the packets are sent over UDP. The network topology thus consists of (i) a micro‑service mesh of ROS 2 nodes on the edge computer, (ii) a Wi‑Fi gateway that bridges to the DTS central node, and (iii) optionally a redundant second wireless link for reliability. Bandwidth requirements are dictated by the LiDAR stream: transmitting high‑resolution point‑clouds (≈ 30 MB/s at 20 Hz) and vehicle state updates (≈ 200 kbps). Latency tolerance for real‑time monitoring is ≤ 50 ms, while control commands from the virtual twin are required to be delivered within 10 ms. Reliability is enhanced by UDP checksum verification, packet sequence numbers, and automatic retransmission requests for critical control messages."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Complies with ISO 23247 – Digital Twin Framework for Manufacturing (parts 1‑4). Employs the entity‑based reference architecture comprising the Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity and User Entity. Functional Entities (FEs) are defined for specific tasks such as actuating the OME, data transformation and user interaction. Communication between FEs may be implemented using OPC Unified Architecture (OPC UA) as an explicit example, thereby ensuring interoperability with industrial automation systems."
]