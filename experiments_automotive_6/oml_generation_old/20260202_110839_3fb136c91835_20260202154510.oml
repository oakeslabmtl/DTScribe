// C3: Physical sensing components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing point cloud data for object detection and tracking in the autonomous vehicle environment."
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelDeepsenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i Depth Camera capturing depth and visual data for environmental perception and object detection."
    DTDFVocab:producedData CameraDepthData
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor collecting real-time ego vehicle speed data for ACC control and monitoring."
    DTDFVocab:producedData VehicleSpeedData
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor collecting real-time steering angle data for ACC control and path planning."
    DTDFVocab:producedData SteeringAngleData
]

// C4: Physical-to-virtual interaction
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance CameraDepthData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iCamera
]

instance VehicleSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ObjectTrackData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR, IntelDeepsenseD435iCamera
]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Uses DBSCAN algorithm for clustering raw LiDAR point cloud data into object clusters."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter implementation for tracking object states based on clustered point cloud data."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Implements ISO 15622 for performance class I ACC with speed control based on lead vehicle distance."
    DTDFVocab:inputTo ROS2Middleware
]

instance EgoVehicleStateData : DTDFVocab:Data [
    base:desc "Stores ego vehicle state data including speed, steering angle, and object tracks in SQL database format."
    DTDFVocab:fromData VehicleSpeedData, SteeringAngleData, ObjectTrackData
    DTDFVocab:inputTo SQLDatabaseEnabler
]

instance ProjectedDrivingPathData : DTDFVocab:Data [
    base:desc "3D representation of the vehicle's projected driving path based on current state and object tracks."
    DTDFVocab:fromData EgoVehicleStateData, ObjectTrackData
    DTDFVocab:inputTo ROS2Middleware
]

instance TimeSeriesReportData : DTDFVocab:Data [
    base:desc "Human-readable time-series reports of object tracks and vehicle state data for analysis."
    DTDFVocab:fromData EgoVehicleStateData
    DTDFVocab:inputTo PythonEnabler
]

// C11: Enablers
instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for complex systems like point cloud processing and model implementation."
    DTDFVocab:enables PointCloudProcessingService, ObjectTrackingService
]

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "Robot Operating System 2 for integrating application modules and managing ROS2 node lifecycles."
    DTDFVocab:enables ACCComputationService, DataMonitoringService, RemoteManagementService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database system for storing ego vehicle state data and historical records."
    DTDFVocab:enables DataStorageService, ReportGenerationService
]

instance PythonEnabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 environment for rapid prototyping and report generation."
    DTDFVocab:enables ReportGenerationService
]

instance OPCUAEnabler : DTDFVocab:Enabler [
    base:desc "OPC Unified Architecture for data translation between physical and virtual components."
    DTDFVocab:enables DataMonitoringService
]

instance WiFiCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "Wi-Fi protocol for inter-entity communication between vehicle, cloud, and user interface."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of vehicle state data, object tracks, and projected driving path."
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance ACCComputationService : DTDFVocab:Service [
    base:desc "Offloading ACC computations from vehicle to digital twin to reduce onboard hardware burden."
    DTDFVocab:provides ACCControlAction, ComputationOffloadingInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enabling/disabling ACC, setting desired speed, and sending emergency braking commands remotely."
    DTDFVocab:provides RemoteACCSettingAction, EmergencyBrakingAction
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generating human-readable reports of object tracks and vehicle state data as time-series data."
    DTDFVocab:provides TimeSeriesReportInsight
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Storing ego vehicle state data on external device for long-term monitoring and analysis."
    DTDFVocab:provides HistoricalDataInsight
]

// C17: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of ego vehicle state, object tracks, and projected driving path to assess ACC behavior."
]

instance ACCControlAction : DTDFVocab:Action [
    base:desc "Automatic control of vehicle speed based on lead vehicle distance according to ISO 15622."
    DTDFVocab:IsAutomatic true
]

instance ComputationOffloadingInsight : DTDFVocab:Insight [
    base:desc "Reduction of onboard computational load by offloading ACC computations to digital twin."
]

instance RemoteACCSettingAction : DTDFVocab:Action [
    base:desc "Remote adjustment of desired speed and ACC enable/disable commands."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Remote emergency braking command for immediate vehicle deceleration."
    DTDFVocab:IsAutomatic false
]

instance TimeSeriesReportInsight : DTDFVocab:Insight [
    base:desc "Human-readable time-series reports of object tracks and vehicle state data for analysis."
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Historical data enabling analysis of fuel economy and driving performance trends."
]

instance PerformanceMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time assessment of ACC behavior through visualization of ego vehicle state and object tracks."
]

instance ParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Remote adjustment capabilities for desired speed and ACC enable/disable states."
]

// C2: Acting Components
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Converts desired speed into motor voltage commands for vehicle propulsion."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Controls the steering angle of the vehicle based on path planning and ACC commands."
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Executes remote emergency braking commands for immediate vehicle deceleration."
]

// C10: Additional Data Processing
instance ProcessedObjectTracksData : DTDFVocab:Data [
    base:desc "Processed object tracks derived from raw LiDAR data using DBSCAN clustering and Kalman filtering."
    DTDFVocab:fromData LiDARPointCloudData
    DTDFVocab:inputTo KalmanFilterTrackingModel, ACCControlModel
]

// C11: Additional Enablers
instance NVIDIAJetpackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for programming the Jetson Orin Nano microcomputer."
    DTDFVocab:enables PointCloudProcessingService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming environment for ROS2 node lifecycle management."
    DTDFVocab:enables ACCComputationService, DataMonitoringService
]

// C6: Additional Services
instance PointCloudProcessingService : DTDFVocab:Service [
    base:desc "Processing raw LiDAR point cloud data into object clusters using DBSCAN algorithm."
    DTDFVocab:provides ProcessedObjectTracksData
]

instance ObjectTrackingService : DTDFVocab:Service [
    base:desc "Tracking object states using Kalman filter based on clustered point cloud data."
    DTDFVocab:provides ProcessedObjectTracksData
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The interactions from the virtual world to the physical world include:
  - **Desired speed commands**: Computed by the ACC system in the Digital Twin Entity and sent back to the vehicle for actuation.
  - **Remote management commands**: Enable/disable ACC, modify desired speed, and send emergency braking commands.
  - **Actuation commands**: Sent to the motor and steering servo to control the vehicle's movement."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in real-time with a synchronization requirement of:
  - **Network latency**: ≤ 100 ms from the vehicle to the DT Entity.
  - **Clock synchronization**: Devices must be synchronized to an accuracy of 100 ms to ensure event ordering and data integrity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated as follows:
  - **Physical Twin Entity**: Deployed on the vehicle, handling data preprocessing, actuation, and sensor data collection.
  - **Digital Twin Entity**: Deployed on external hardware (e.g., cloud), managing data storage, ACC computation, and reporting.
  - **User Entity**: Deployed on user devices, providing visualization and remote management interfaces.
  The system follows an entity-based architecture inspired by ISO 23247, with deviations such as the addition of the Physical Twin Entity and splitting of the User Interface FE into visualization and control panel components."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin is primarily used during the **design, development, and operational phases** of the ACC system. **(1) Design Phase**: Serves as a **cyber-physical experimentation facility** for validating ACC algorithms (e.g., ISO 15622 compliance) and simulating edge cases; **(2) Development Phase**: Enables **remote troubleshooting** via data monitoring and real-time visualization; **(3) Operational Phase**: Supports **real-time optimization** (e.g., fuel economy adjustments) and **health monitoring** of the ACC subsystem. The DT does not explicitly cover the **as-manufactured** phase but focuses on **as-operated** behavior, leveraging **3D CAD-like visualizations** for decision support."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through: **(1) **Perception Accuracy**: **DBSCAN** and **Kalman filter** for robust object tracking; **(2) **Control Validity**: **ISO 15622** compliance for ACC logic; **(3) **Latency Constraints**: **100 ms end-to-end latency** (3GPP 22.185) and **100 ms clock synchronization** for real-time coordination; **(4) **Data Integrity**: **Data Translation FE** handles serialization and unit conversions; **(5) **Validation Methods**: Cross-checking of **LiDAR and camera data** (fusion) and **real-world testing** with the 1/10th-scale vehicle. The system does not explicitly mention **uncertainty quantification** or **cross-validation metrics** beyond the described algorithms."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection details include:
  - **Network Protocols**: Wi-Fi for inter-entity communication, ROS2 for intra-system communication.
  - **Data Translation**: Implemented via the Data Translation Functional Entity (FE), handling serialization, message alignment, and unit conversions.
  - **Latency Requirements**: End-to-end latency ≤ 100 ms, as per 3GPP V2V communication standards."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted and deployed across:
  - **Onboard Hardware**: NVIDIA Jetson Orin Nano and Jetson NX antenna for real-time data processing and actuation.
  - **External Hardware**: Cloud or server for data storage, ACC computation, and reporting.
  - **User Devices**: Laptops or workstations for visualization and remote management via a 3D UI."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration is limited to the following within the digital twin system: **(1) **Standardized Communication Interface** (R1) ensures modularity and loose coupling between components; **(2) **ROS2 Middleware** enables interoperability between **Python**, **C++**, and **MATLAB/Simulink** modules; **(3) **Data Translation FE** standardizes message formats across entities. The document does not mention integration with **external systems** (e.g., vehicle manufacturer databases, fleet management tools) or **other digital twins** beyond the described constellation. **Digital threads** and **product lifecycle management** are referenced in the background but not implemented in this case study."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership and privacy considerations are not explicitly detailed in the document. However, the DT collects and stores sensitive vehicle data, implying the need for:
  - **Data Ownership**: Likely owned by the vehicle owner or operator, with the DT service provider acting as a custodian.
  - **Privacy Measures**: Not explicitly described, but implied through secure communication protocols and access controls."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT follows the following standards:
  - **ISO 23247**: Reference architecture for Digital Twin Manufacturing Framework, adapted for automotive use.
  - **ISO 15622**: Standard for Adaptive Cruise Control (ACC) systems.
  - **3GPP Technical Specification 22.185**: Service requirements for Vehicle-to-Vehicle (V2V) communication, including latency constraints.
  - **ROS2**: Middleware standard for robotics and autonomous systems."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The digital twin incorporates the following safety and security measures: **(1) **Safety-Critical Nature**: The system is designed for **real-time operation** with **≤100 ms latency** and **100 ms clock synchronization** to ensure safe ACC functionality; **(2) **Standardized Communication**: **ROS2** and **Wi-Fi** protocols are used, with **data translation** ensuring message integrity; **(3) **Remote Management**: Emergency braking commands are part of the **User Entity**, requiring **operator authorization**; **(4) **Hardware Limitations**: **100 ms clock synchronization** is mandated due to hardware constraints (e.g., Jetson Orin Nano). The document does not detail **cybersecurity measures** (e.g., encryption, access controls) or **fail-safe mechanisms** for remote operations, though it acknowledges the **safety-critical** nature of the system."
]