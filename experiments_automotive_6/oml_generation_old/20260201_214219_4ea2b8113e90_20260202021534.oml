// =============================
// C3: Physical sensing components
// =============================

// LiDAR sensor
instance LiDARHokuyoUST10LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR providing 2‑D laser scans for obstacle detection"
    DTDFVocab:producedData LiDARPointCloudData
]

// Depth camera
instance DepthCameraIntelDeepsenseD435i : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera supplying RGB‑D images"
    DTDFVocab:producedData DepthImageData
]

// Vehicle speed sensor
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel‑based speed sensor delivering vehicle longitudinal speed"
    DTDFVocab:producedData VehicleSpeedData
]

// Steering angle sensor
instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering shaft encoder providing steering wheel angle"
    DTDFVocab:producedData SteeringAngleData
]

// =============================
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// =============================

instance LiDARDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARHokuyoUST10LX
]

instance DepthCameraTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DepthCameraIntelDeepsenseD435i
]

instance VehicleSpeedTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// =============================
// C10: Data definitions
// =============================

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 3‑D point cloud generated by the Hokuyo LiDAR"
    DTDFVocab:fromData LiDARDataTransmission
    DTDFVocab:inputTo PointCloudClusteringTrackingFE
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image (RGB‑D) from the Intel D435i camera"
    DTDFVocab:fromData DepthCameraTransmission
    DTDFVocab:inputTo DataTranslationFE
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Instantaneous vehicle longitudinal speed"
    DTDFVocab:fromData VehicleSpeedTransmission
    DTDFVocab:inputTo DataTranslationFE
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering wheel angle"
    DTDFVocab:fromData SteeringAngleTransmission
    DTDFVocab:inputTo DataTranslationFE
]

// =============================
// C11: Enablers (Functional Entities, Tooling)
// =============================

// Data translation functional entity
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Data Translation FE serialises incoming sensor payloads, aligns them to ISO‑23247 types and performs unit conversion"
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:enables ComputationOffloadingService
]

// Point‑cloud clustering & tracking functional entity (pre‑processing)
instance PointCloudClusteringTrackingFE : DTDFVocab:Enabler [
    base:desc "Component that applies DBSCAN clustering to LiDAR point clouds and tracks resulting object clusters with a Kalman filter"
    DTDFVocab:enables ComputationOffloadingService
]

// Adaptive Cruise Control functional entity (decision logic)
instance AdaptiveCruiseControlFE : DTDFVocab:Enabler [
    base:desc "ACC FE implements lead‑vehicle detection, distance‑based speed calculation and outputs a desired speed set‑point"
    DTDFVocab:enables ComputationOffloadingService
]

// Visualization functional entity (3‑D UI)
instance VisualizationFE : DTDFVocab:Enabler [
    base:desc "3‑D Visualization FE renders real‑time vehicle state, projected path and object tracks"
    DTDFVocab:enables DataMonitoringService
]

// Remote management functional entity
instance RemoteManagementFE : DTDFVocab:Enabler [
    base:desc "Provides UI controls to enable/disable ACC, set desired speed and issue emergency‑brake commands"
    DTDFVocab:enables RemoteManagementService
]

// Middleware tooling
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS 2 DDS‑based middleware for low‑latency messaging between twin and vehicle"
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:enables ComputationOffloadingService
    DTDFVocab:enables RemoteManagementService
]

// GPU acceleration tooling
instance JetPackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack SDK enabling GPU‑accelerated perception and model execution"
    DTDFVocab:enables ComputationOffloadingService
]

// Model development & code generation tooling
instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink used to develop and auto‑code‑generate the ACC controller"
    DTDFVocab:enables ComputationOffloadingService
]

// Containerisation tooling
instance DockerContainer : DTDFVocab:Enabler [
    base:desc "Docker containers provide reproducible deployment of the twin components"
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:enables ComputationOffloadingService
    DTDFVocab:enables RemoteManagementService
]

// UI framework tooling
instance QtUIFramework : DTDFVocab:Enabler [
    base:desc "Qt is used to build the graphical user interface displayed to the operator"
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:enables RemoteManagementService
]

// =============================
// C10: Models / Data processing
// =============================

// Geometric model – raw LiDAR point cloud
instance LiDARPointCloudGeometricModel : DTDFVocab:Model [
    base:desc "Geometric representation of the raw LiDAR point cloud"
    DTDFVocab:inputTo DBSCANClusteringModel
]

// DBSCAN clustering model
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "Density‑based spatial clustering algorithm applied to LiDAR points"
    DTDFVocab:inputTo KalmanFilterTrackingModel
]

// Kalman filter tracking model
instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter that tracks clustered objects across frames"
    DTDFVocab:inputTo AdaptiveCruiseControlFE
]

// ACC behavioral model
instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "Behavioral ACC model that determines lead vehicle, computes following speed set‑point"
    DTDFVocab:inputTo AdaptiveCruiseControlFE
]

// =============================
// C6: Services
// =============================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Displays real‑time vehicle state, projected driving path and nearby object tracks; allows users to view, save and generate ACC‑relevant reports"
    DTDFVocab:provides VehicleStateInsight
    DTDFVocab:provides ObjectTrackInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes the ACC algorithm in the twin (cloud/edge) and returns the desired speed command to the vehicle for actuation"
    DTDFVocab:provides ACCDecisionInsight
    DTDFVocab:provides SetSpeedSetpointAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to enable/disable ACC, set desired speed and issue emergency‑brake commands remotely"
    DTDFVocab:provides EnableACCAction
    DTDFVocab:provides DisableACCAction
    DTDFVocab:provides EmergencyBrakeAction
]

// =============================
// C17: Insights & Actions
// =============================

instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current vehicle speed, steering angle and overall state for operator awareness"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Insight presenting clustered object tracks derived from LiDAR processing"
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "Insight delivering ACC‑computed following speed set‑point based on lead‑vehicle detection"
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Action to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to issue an immediate brake command to the vehicle"
    DTDFVocab:IsAutomatic false
]

instance SetSpeedSetpointAction : DTDFVocab:Action [
    base:desc "Action that applies the ACC‑computed speed set‑point to the vehicle actuator"
    DTDFVocab:IsAutomatic true
]

// =============================
// C1: Environment (physical twin)
// =============================

instance LabScaleTestEnvironment : DTDFVocab:Environment [
    base:contains LiDARHokuyoUST10LX, DepthCameraIntelDeepsenseD435i, VehicleSpeedSensor, SteeringAngleSensor
]

// =============================
// C2: Component (physical twin)
// =============================

instance ScaleVehicleTwin : DTDFVocab:Component [
    base:desc "1/10‑scale teleoperated autonomous vehicle equipped with LiDAR, depth camera, speed and steering sensors; resource‑constrained ECUs off‑load ACC computation to the digital twin"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the Controlling FE (ACC) within the Digital Twin. Desired actuation values (e.g., target speed, steering angle) are formatted by the Data Translation FE, which serializes the command and applies required unit conversions. The command messages are transmitted over the same Wi‑Fi/UDP link to the Physical Twin where the Actuation FE receives them and converts the high‑level commands into low‑level actuator signals such as motor voltage commands or servo position commands. The document does not describe explicit validation, authentication, conflict‑resolution mechanisms, or acknowledgement messages; feedback on execution is implicit in the subsequent sensor measurements that are sent back to the Digital Twin."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires that all devices share a common notion of time to support computation offloading. Clock synchronization must achieve at least 100 ms accuracy (the chosen limit due to hardware constraints), although many safety‑critical vehicular standards mandate tighter bounds. This synchronization interval applies to the coordination between the Physical Twin Entity (sensors/actuators) and the Digital Twin Entity (data management and control)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows the ISO 23247 reference architecture (RA). Software components are first identified and then grouped into three ISO‑based entities: User Entity (User Interface FE), Digital Twin Entity (data management, control), and Physical Twin Entity (sensor/actuator preprocessing and device communication). Each functional element (FE) is implemented as an individual ROS 2 package containing one or more ROS 2 nodes, and each entity is deployed on separate hardware resources, enabling distributed execution. The overall orchestration relies on ROS 2 DDS for inter‑package communication and on the entity‑based hierarchy defined by ISO 23247 to coordinate services across the constellation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Internal communication among software components uses a ROS 2 middleware network (publish‑/subscribe model). Inter‑entity communication (Physical Twin Entity ↔ Digital Twin Entity ↔ User Entity) occurs over a Wi‑Fi network employing UDP at the transport layer. The Data Translation FE mediates all data streams, handling message type alignment and unit conversion. No bandwidth, latency, reliability, redundancy, or security protocol details are provided in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system follows ISO 23247 (Digital twin framework for manufacturing), particularly Part 2 which defines the entity‑based reference architecture (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity). Implementations may use OPC Unified Architecture as a communication protocol to achieve interoperability."
]