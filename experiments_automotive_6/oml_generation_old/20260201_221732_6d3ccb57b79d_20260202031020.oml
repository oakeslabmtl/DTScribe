// ======================================================
// C3: Physical sensing components
// ======================================================

instance HokuyoLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing 2‑D laser scans of the environment"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelRealSenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D images and point clouds"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor derived from chassis encoder"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring the steering wheel position"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// ======================================================
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// ======================================================

instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARSensor
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseDepthCamera
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// ======================================================
// C10: Data definitions
// ======================================================

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "2‑D LiDAR point cloud generated by Hokuyo UST‑10LX"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance DepthCameraPointCloudData : DTDFVocab:Data [
    base:desc "Depth camera point cloud derived from Intel RealSense D435i"
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Real‑time vehicle longitudinal speed"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Real‑time steering wheel angle"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

// ======================================================
// C11: Enablers (tools, middleware, functional entities)
// ======================================================

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation functional entity that serializes, aligns ROS2 messages and performs unit conversions over Wi‑Fi (latency ≤100 ms)"
    DTDFVocab:enables DataMonitoringService,
                       ComputationOffloadingService,
                       RemoteManagementService,
                       Visualization3DService,
                       ReportingService
]

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware enabling DDS‑based topic exchange across distributed hardware"
    DTDFVocab:enables DataMonitoringService,
                       ComputationOffloadingService,
                       RemoteManagementService,
                       Visualization3DService,
                       ReportingService
]

instance NvidiaJetPackSDKEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK providing GPU acceleration and driver support on Jetson platforms"
    DTDFVocab:enables ComputationOffloadingService,
                       Visualization3DService
]

instance Python38Enabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime used for ROS2 nodes and data‑processing scripts"
    DTDFVocab:enables ComputationOffloadingService,
                       DataMonitoringService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ toolchain for high‑performance ROS2 components"
    DTDFVocab:enables ComputationOffloadingService,
                       DataMonitoringService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for model‑based design of the ACC controller"
    DTDFVocab:enables ComputationOffloadingService
]

instance WiFiNetworkingEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi networking stack used for wireless transmission of sensor streams"
    DTDFVocab:enables DataMonitoringService,
                       RemoteManagementService
]

// ======================================================
// C6: Services
// ======================================================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI visualisation of speed, steering angle, object tracks and projected path; also generates operational reports"
    DTDFVocab:provides InsightRealTimeSpeed,
                       InsightRealTimeSteeringAngle,
                       InsightObjectTracks,
                       InsightProjectedPath,
                       InsightGenerationReport
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Off‑loads intensive ACC algorithm and point‑cloud processing to edge/cloud compute"
    DTDFVocab:provides InsightACCComputationResult,
                       Insight3DVisualization
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operator to enable/disable ACC, adjust desired speed, or trigger emergency braking"
    DTDFVocab:provides ActionEnableACC,
                       ActionDisableACC,
                       ActionAdjustDesiredSpeed,
                       ActionTriggerEmergencyBrake
]

instance Visualization3DService : DTDFVocab:Service [
    base:desc "3‑D visualisation of the vehicle and its surrounding environment"
    DTDFVocab:provides Insight3DVisualization
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Generates diagnostic and performance reports from stored timeseries data"
    DTDFVocab:provides InsightGenerationReport
]

// ======================================================
// C17: Insights
// ======================================================

instance InsightRealTimeSpeed : DTDFVocab:Insight [
    base:desc "Real‑time vehicle speed displayed on operator UI"
]

instance InsightRealTimeSteeringAngle : DTDFVocab:Insight [
    base:desc "Real‑time steering angle displayed on operator UI"
]

instance InsightObjectTracks : DTDFVocab:Insight [
    base:desc "Detected and tracked objects visualised as tracks on the UI"
]

instance InsightProjectedPath : DTDFVocab:Insight [
    base:desc "Projected vehicle trajectory visualised on the UI"
]

instance InsightACCComputationResult : DTDFVocab:Insight [
    base:desc "ACC algorithm output – desired speed set‑point for adaptive cruise control"
]

instance Insight3DVisualization : DTDFVocab:Insight [
    base:desc "3‑D rendered scene of vehicle and environment for situational awareness"
]

instance InsightGenerationReport : DTDFVocab:Insight [
    base:desc "Automated performance and diagnostics report generated for operators"
]

// ======================================================
// C17: Actions
// ======================================================

instance ActionEnableACC : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance ActionDisableACC : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance ActionAdjustDesiredSpeed : DTDFVocab:Action [
    base:desc "Adjust the desired speed set‑point for ACC"
    DTDFVocab:IsAutomatic false
]

instance ActionTriggerEmergencyBrake : DTDFVocab:Action [
    base:desc "Trigger emergency braking command"
    DTDFVocab:IsAutomatic false
]

// ======================================================
// C10: Models / Data Stores
// ======================================================

instance ACCControlModel : DTDFVocab:Model [
    base:desc "ACC control model (lead‑vehicle detection and speed set‑point computation per ISO 15622)"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering model for object segmentation"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter based object tracking model"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model rendering vehicle and environment"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance SQLTimeseriesDatabaseModel : DTDFVocab:Model [
    base:desc "SQL database storing timeseries of vehicle state and object tracks"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance ReportGenerationModel : DTDFVocab:Model [
    base:desc "Model that assembles diagnostic and performance data into operator reports"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends desired speed set‑points, ACC enable/disable commands, desired speed adjustments, and emergency‑brake commands to the PT; an Actuation functional entity converts these into motor voltage or servo commands transmitted over the same Wi‑Fi/ROS2 link."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with an end‑to‑end communication latency requirement of ≤ 100 ms and clock‑synchronization accuracy of 100 ms; sensor data are captured at the perception‑cycle rate of the autonomous vehicle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Entity‑based architecture derived from ISO 23247 consisting of a Physical Twin Entity (sensors and actuators), a Digital Twin Entity (data collection, ACC, reporting, visualization pre‑processing), a User Entity (3D visualization and control panel UI), and a cross‑system Data Translation entity; inter‑entity communication occurs over Wi‑Fi using ROS2."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Development (requirements capture R1‑R8, ROS2 package implementation), deployment, and operational runtime (monitoring, remote management) of the DT, supporting the operational stage of the physical twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity sensor data (LiDAR, depth camera) mirrored in the DT; temporal fidelity ensured by ≤ 100 ms latency and clock sync; ACC algorithm conforms to ISO 15622; no explicit V&V methodology described beyond these constraints."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Wi‑Fi network carrying ROS2 messages; Data Translation functional entity handles serialization, message type alignment and unit conversion; a standardized communication interface is mandated (R1); OPC UA is noted as a possible alternative but not employed."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the Jetson Orin Nano mounted on the vehicle; Digital Twin Entity components are hosted on external edge or cloud compute reachable via Wi‑Fi; User Entity UI runs on a workstation; each functional entity is packaged as a ROS2 node."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture, ISO 15622 functional specification for ACC, ISO/IEC 30173 digital‑twin terminology, IEC 62541 OPC UA (mentioned as optional), ROS2 as an open‑source middleware standard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical ACC implemented per ISO 15622; latency ≤ 100 ms and clock sync ≤ 100 ms enforced to maintain safe operation; remote commands (ACC enable/disable, emergency brake) designed with a human‑in‑the‑loop; no explicit cybersecurity mechanisms detailed."
]