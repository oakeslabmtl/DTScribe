// Sensing Components
instance HokuyoUST10LXLidarSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR sensor mounted on the Jetson Orin Nano chassis."
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance IntelD435iDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera providing RGB‑D images for object perception."
    DTDFVocab:producedData DepthImageDataTransmitted
]

instance WheelEncoderSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Wafer‑level wheel encoder providing real‑time vehicle speed telemetry."
    DTDFVocab:producedData EgoSpeedDataTransmitted
]

instance SteeringEncoderSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Steering angle encoder measuring pilot or autonomous steering positions."
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// Acting Components
instance VedderESCActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller receiving motor voltage commands from DT."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Servo motor actuating steering based on DT control output."
]

// Data Transmitted
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidarSensor
]

instance DepthImageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCameraSensor
]

instance EgoSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelEncoderSensingComponent
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringEncoderSensingComponent
]

// Processed Data
instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Real‑time ego vehicle speed extracted from wheel encoder telemetry."
    DTDFVocab:inputTo DataMonitoringEnabler, ComputationOffloadingEnabler
    DTDFVocab:fromData EgoSpeedDataTransmitted
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Real‑time steering angle derived from steering encoder telemetry."
    DTDFVocab:inputTo DataMonitoringEnabler
    DTDFVocab:fromData SteeringAngleDataTransmitted
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image stream from Intel D435i depth camera."
    DTDFVocab:inputTo DataMonitoringEnabler
    DTDFVocab:fromData DepthImageDataTransmitted
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "DBSCAN‑clustered and Kalman‑filtered object tracks derived from LiDAR point cloud."
    DTDFVocab:inputTo DataMonitoringEnabler, ComputationOffloadingEnabler
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
]

instance VelocityVectorsData : DTDFVocab:Data [
    base:desc "Velocity vectors of detected objects computed from Kalman filter predictions."
    DTDFVocab:inputTo ComputationOffloadingEnabler
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
]

// Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point cloud for object detection."
    DTDFVocab:inputTo DataMonitoringEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking of detected objects for velocity estimation."
    DTDFVocab:inputTo DataMonitoringEnabler
]

instance ISO15622ACCControllerModel : DTDFVocab:Model [
    base:desc "ISO 15622 compliant Adaptive Cruise Control controller computing desired speed."
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

// Enablers
instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware and SQL database based enabler powering real‑time monitoring and reporting."
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware based enabler handling offloaded ACC decision logic."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware based enabler providing remote UI for enable/disable ACC, set speed, and emergency braking."
    DTDFVocab:enables RemoteManagementService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Live UI displays speed, steering, tracks, logs and generates time‑series reports."
    DTDFVocab:provides VehicleTelemetryInsight, GenerateTimeSeriesReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC decision logic computed on the Digital Twin, sending control output to the Physical Twin."
    DTDFVocab:provides ACCDecisionInsight, SetControlOutputAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI enabling operator to enable/disable ACC, set desired speed, or trigger emergency braking."
    DTDFVocab:provides RemoteManagementControlInsight, EnableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// Insights
instance VehicleTelemetryInsight : DTDFVocab:Insight [
    base:desc "Aggregated vehicle state and object tracks insight for operator assessment."
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "ACC decision insight derived from ISO 15622 controller logic."
]

instance RemoteManagementControlInsight : DTDFVocab:Insight [
    base:desc "Insight into remote management options for ACC control."
]

// Actions
instance GenerateTimeSeriesReportAction : DTDFVocab:Action [
    base:desc "Generates time‑series reports of vehicle state and object tracks."
    DTDFVocab:IsAutomatic false
]

instance SetControlOutputAction : DTDFVocab:Action [
    base:desc "Sends computed speed control output to the Physical Twin."
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables or disables Adaptive Cruise Control on demand."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets the desired speed parameter for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Triggers emergency braking command via the Physical Twin."
    DTDFVocab:IsAutomatic false
]

// Environment
instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:contains HokuyoUST10LXLidarSensor, IntelD435iDepthCameraSensor,
                 WheelEncoderSensingComponent, SteeringEncoderSensingComponent,
                 VedderESCActuator, SteeringServoActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control messages (desired speed, ACC enable/disable, emergency‑brake) to the PT; an Actuation FE translates these into motor voltage and servo PWM commands sent over Wi‑Fi to the Jetson island, which drives the ESC and steering servo to realize desired vehicle motion."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All data streams and control actions are processed in real‑time with end‑to‑end latency capped at 100 ms and clock synchronization accuracy of 100 ms, ensuring the DT can mirror the PT’s dynamics within a 100 ms timescale."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated ensemble of ROS 2 nodes: Data Collection FE, Data Translation FE, ACC FE, Actuation FE, User Interface FE (3D visualization + control panel), and Physical Twin Entity FEs. Components communicate over Wi‑Fi using DDS, while the cloud server hosts the ACC FE; the Jetson island hosts data collection and actuation FEs."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin represents the PT in the operated stage; it captures real‑time run‑time data, offloads ACC computation, and provides remote control – i.e., it is an operational digital twin rather than a design or manufacturing model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT is described as a real‑time, high‑fidelity computational reflection of the physical twin; it satisfies the ISO 15622 control specification for ACC and meets the 100 ms latency and clock‑synchronization thresholds, ensuring timing fidelity for safety‑critical behavior."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Hardware interconnection is a Wi‑Fi link between the vehicle (Jetson) and the cloud server; ROS2 over DDS radio protocols is used for inter‑entity communication. The Data Translation FE serializes data, aligning message types for ROS2 topics. Clocks are synchronized within 100 ms accuracy across components."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hybrid edge‑cloud deployment: on‑board NVIDIA Jetson Orin Nano runs Data Collection, Data Translation, Actuation, and some Data Pre‑Processing FEs; cloud server hosts the ACC FE; a separate SQL server stores persistent telemetry; the operator’s workstation hosts the UI FE. All components communicate over ROS2 topics over Wi‑Fi."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Implemented per ISO 23247 reference architecture (Part 2) with a custom Physical Twin Entity; ACC logic conforms to ISO 15622; ROS 2 for middleware, adhering to industry micro‑service communication standards, and NVIDIA JetPack SDK for embedded Linux."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety requirements include a maximum 100 ms end‑to‑end latency, 100 ms clock synchronization, and adherence to ISO 15622 for ACC. Remote commands are carried over the standardized ROS2 interface; no explicit authentication or encryption details are given, but the DT operates within the safety‑critical constraints specified by the automotive ACC standard."
]