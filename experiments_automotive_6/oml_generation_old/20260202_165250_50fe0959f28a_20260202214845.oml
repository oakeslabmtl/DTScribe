// C2: Acting Components
instance PressureControlValve : DTDFVocab:ActingComponent [
    base:desc "Hydraulic pressure control valve regulating system pressure based on digital twin feedback with ±2% accuracy and 10ms response time"
]

instance HeaterActuator : DTDFVocab:ActingComponent [
    base:desc "PID-controlled electric heater with 95% efficiency and 5°C/min temperature ramp capability for thermal regulation"
]

instance FlowRegulator : DTDFVocab:ActingComponent [
    base:desc "Variable speed flow regulator maintaining ±5% flow rate consistency through adaptive control algorithms"
]

// C3: Physical sensing components
instance TemperatureSensorArray : DTDFVocab:SensingComponent [
    base:desc "16-channel PT1000 temperature array with 0.1°C resolution and 1Hz sampling rate for thermal monitoring"
    DTDFVocab:producedData TemperatureDataStream
]

instance PressureTransducer : DTDFVocab:SensingComponent [
    base:desc "High-precision 0-100bar differential pressure transducer with 0.05% FS accuracy and 50Hz bandwidth"
    DTDFVocab:producedData PressureDataStream
]

instance VibrationMonitor : DTDFVocab:SensingComponent [
    base:desc "Triaxial accelerometer array (1000Hz sampling) for structural health monitoring with 0.01g resolution"
    DTDFVocab:producedData VibrationDataStream
]

instance FlowMeter : DTDFVocab:SensingComponent [
    base:desc "Ultrasonic flow meter with ±0.5% accuracy and 10Hz measurement frequency for real-time flow tracking"
    DTDFVocab:producedData FlowDataStream
]

// C4: Physical-to-virtual interaction
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorArray
]

instance PressureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureTransducer
]

instance VibrationDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationMonitor
]

instance FlowDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FlowMeter
]

// C10: Models/Data
instance ThermalModel : DTDFVocab:Model [
    base:desc "Finite Element Analysis model with adaptive mesh refinement for temperature distribution prediction (updated hourly)"
    DTDFVocab:inputTo DataProcessingEnabler, SimulationEngine
]

instance StructuralHealthModel : DTDFVocab:Model [
    base:desc "Machine Learning-based vibration pattern recognition model for defect detection with 92% accuracy"
    DTDFVocab:inputTo DataProcessingEnabler, AIInferenceEngine
]

instance ProcessData : DTDFVocab:Data [
    base:desc "Normalized time-series dataset containing temperature, pressure, flow and vibration metrics with 1-minute resolution"
    DTDFVocab:fromData TemperatureDataStream, PressureDataStream, VibrationDataStream, FlowDataStream
    DTDFVocab:inputTo DataProcessingEnabler, VisualizationEngine
]

instance AnomalyDetectionData : DTDFVocab:Data [
    base:desc "Pre-processed anomaly flags with severity scores (0-100) derived from vibration and pressure patterns"
    DTDFVocab:fromData VibrationDataStream, PressureDataStream
    DTDFVocab:inputTo AIInferenceEngine, AlertSystem
]

// C11: Enablers
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Edge computing node (NVIDIA Jetson AGX Xavier) with 32GB RAM for real-time data normalization and feature extraction"
    DTDFVocab:enables DataAggregationService, PreprocessingService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Cloud-based HPC cluster (AWS EC2 p4d.24xlarge) for running thermal and structural simulations"
    DTDFVocab:enables SimulationService
]

instance AIInferenceEngine : DTDFVocab:Enabler [
    base:desc "Federated learning cluster with TensorFlow Serving for distributed model inference"
    DTDFVocab:enables AnomalyDetectionService, PredictiveMaintenanceService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "3D WebGL renderer (Three.js) with WebSocket streaming for real-time twin visualization"
    DTDFVocab:enables MonitoringDashboardService, ReportingService
]

instance AlertSystem : DTDFVocab:Enabler [
    base:desc "Multi-channel alerting system with SMS, email and IoT push notifications for critical events"
    DTDFVocab:enables MaintenanceAlertService
]

// C6: Services
instance DataAggregationService : DTDFVocab:Service [
    base:desc "Real-time data aggregation service combining all sensor streams with timestamp synchronization"
    DTDFVocab:provides ProcessedDataInsight, DataQualityInsight
]

instance PreprocessingService : DTDFVocab:Service [
    base:desc "Signal processing service applying bandpass filters and noise reduction to raw sensor data"
    DTDFVocab:provides CleanDataInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Physics-based simulation service predicting system behavior under different operating conditions"
    DTDFVocab:provides ThermalPredictionInsight, StructuralRiskInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Machine learning service identifying potential failures based on vibration and pressure patterns"
    DTDFVocab:provides FailureProbabilityInsight, AnomalySeverityInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Time-to-failure prediction service with 85% accuracy for critical components"
    DTDFVocab:provides MaintenanceRecommendationAction
]

instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Interactive 3D dashboard showing real-time twin state with historical comparisons"
    DTDFVocab:provides OperationalOverviewInsight
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Automated report generation service with PDF/Excel exports for compliance requirements"
    DTDFVocab:provides ComplianceReportInsight
]

instance MaintenanceAlertService : DTDFVocab:Service [
    base:desc "Priority-based alert service with escalation protocols for critical system conditions"
    DTDFVocab:provides MaintenanceAction
]

// C17: Insights/Actions
instance ProcessedDataInsight : DTDFVocab:Insight [
    base:desc "Synchronized multi-sensor data stream ready for analysis with timestamp alignment"
]

instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Real-time data quality metrics including completeness, accuracy and consistency scores"
]

instance CleanDataInsight : DTDFVocab:Insight [
    base:desc "Noise-filtered sensor data with standardized units and normalized ranges"
]

instance ThermalPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature distribution with 90% confidence intervals for next 24 hours"
]

instance StructuralRiskInsight : DTDFVocab:Insight [
    base:desc "Structural integrity assessment with fatigue life estimation based on vibration patterns"
]

instance FailureProbabilityInsight : DTDFVocab:Insight [
    base:desc "Probability of imminent failure for each monitored component (0-1 scale)"
]

instance AnomalySeverityInsight : DTDFVocab:Insight [
    base:desc "Severity classification of detected anomalies using ML-based scoring system"
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Automated maintenance schedule generation with priority ranking and cost estimation"
    DTDFVocab:IsAutomatic true
]

instance OperationalOverviewInsight : DTDFVocab:Insight [
    base:desc "3D visualization of current system state with historical performance trends"
]

instance ComplianceReportInsight : DTDFVocab:Insight [
    base:desc "Automated compliance documentation with all regulatory requirements satisfied"
]

instance MaintenanceAction : DTDFVocab:Action [
    base:desc "Automated activation of maintenance protocols including valve adjustments and heater calibration"
    DTDFVocab:IsAutomatic true
]

// C1: Environment
instance ProcessEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensorArray, PressureTransducer, VibrationMonitor, FlowMeter,
                 PressureControlValve, HeaterActuator, FlowRegulator
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains DataProcessingEnabler, SimulationEngine, AIInferenceEngine,
                 VisualizationEngine, AlertSystem
]