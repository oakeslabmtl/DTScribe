// C2: Acting Components
instance ActuatingControlSystem : DTDFVocab:ActuatingComponent [
    base:desc "Actuates vehicle steering and motor systems via ROS2 control signals for real-time adjustments"
]

instance MotorActuator : DTDFVocab:ActuatingComponent [
    base:desc "Controls vehicle motor systems based on Digital Twin Entity commands for dynamic performance optimization"
]

instance SteeringActuator : DTDFVocab:ActuatingComponent [
    base:desc "Manages vehicle steering commands synchronized with Digital Twin Entity trajectory predictions"
]

// C3: Physical sensing components
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "Collects raw point cloud data from LiDAR systems for object detection and tracking"
    DTDFVocab:producedData LiDARPointCloudDataStream
]

instance MotorStateSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors motor performance metrics (speed, torque) via embedded sensors"
    DTDFVocab:producedData MotorPerformanceMetricsStream
]

instance SteeringStateSensor : DTDFVocab:SensingComponent [
    base:desc "Tracks steering angle and servo position for vehicle dynamics analysis"
    DTDFVocab:producedData SteeringPositionMetricsStream
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Records core vehicle metrics (speed, position, acceleration) for real-time monitoring"
    DTDFVocab:producedData VehicleTelemetryDataStream
]

instance DataTranslationProcessor : DTDFVocab:SensingComponent [
    base:desc "Standardizes sensor data formats (ROS2 topics) and unit conversions for interoperability"
    DTDFVocab:producedData StandardizedDataFormatStream
]

// C4: Physical-to-virtual interaction
instance LiDARPointCloudDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance MotorPerformanceMetricsStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStateSensor
]

instance SteeringPositionMetricsStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringStateSensor
]

instance VehicleTelemetryDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance StandardizedDataFormatStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DataTranslationProcessor
]

// C10: Models/Data
instance VehicleDynamicModel : DTDFVocab:Model [
    base:desc "Physics-based model simulating vehicle dynamics incorporating LiDAR object detection and trajectory prediction"
    DTDFVocab:inputTo LiDARProcessingEnabler, ROS2CommunicationEnabler
]

instance ProcessOptimizationModel : DTDFVocab:Model [
    base:desc "Predictive model for manufacturing process optimization using discrete-event simulation"
    DTDFVocab:inputTo ManufacturingAnalyticsEnabler
]

instance BatteryHealthModel : DTDFVocab:Model [
    base:desc "AI-driven degradation forecasting model for automotive battery systems"
    DTDFVocab:inputTo AIAnalyticsEnabler
]

instance ObjectTrackingModel : DTDFVocab:Model [
    base:desc "Clustering and tracking model for LiDAR point clouds in 3D visualization"
    DTDFVocab:inputTo VisualizationEnabler
]

instance DataStorageRepository : DTDFVocab:Data [
    base:desc "Distributed database storing raw/processed telemetry data for historical analysis"
    DTDFVocab:fromData LiDARPointCloudDataStream, MotorPerformanceMetricsStream,
                      SteeringPositionMetricsStream, VehicleTelemetryDataStream,
                      StandardizedDataFormatStream
    DTDFVocab:inputTo TimeSeriesDatabaseEnabler, GraphDatabaseEnabler
]

instance RealTimeMetricsDashboard : DTDFVocab:Data [
    base:desc "Current state visualization data for monitoring dashboards"
    DTDFVocab:fromData StandardizedDataFormatStream
    DTDFVocab:inputTo VisualizationEnabler
]

// C11: Enablers
instance ROS2CommunicationEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 network infrastructure enabling real-time message passing with UDP transport for low-latency requirements"
    DTDFVocab:enables DataPreProcessingEnabler, AdaptiveControlService
]

instance LiDARProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Clustering and tracking pipeline for LiDAR point clouds with noise filtering"
    DTDFVocab:enables ObjectTrackingModel, VisualizationEnabler
]

instance DataPreProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Pre-processing modules for sensor data standardization and validation"
    DTDFVocab:enables StandardizedDataFormatStream, DataStorageRepository
]

instance ManufacturingAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Framework for process optimization analytics using discrete-event simulation"
    DTDFVocab:enables ProcessOptimizationModel
]

instance AIAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "AI-driven analytics platform for predictive modeling (battery degradation, failure forecasting)"
    DTDFVocab:enables BatteryHealthModel
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D visualization framework for interactive dashboards and immersive modeling"
    DTDFVocab:enables RealTimeMetricsDashboard, ScenarioSimulationService
]

instance TimeSeriesDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database solution for high-frequency data logging and historical analysis"
    DTDFVocab:enables DataStorageRepository
]

instance GraphDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Graph database for modeling relationships between physical and digital entities"
    DTDFVocab:enables DataStorageRepository
]

instance EdgeComputingPlatform : DTDFVocab:Enabler [
    base:desc "Edge computing infrastructure for low-latency processing of industrial IoT data"
    DTDFVocab:enables AdaptiveControlService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of physical states (battery voltage, vehicle metrics) via real-time telemetry"
    DTDFVocab:provides EquipmentHealthInsight, AnomalyDetectionInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "AI-driven anomaly detection in cyber-physical systems (space debris, equipment faults)"
    DTDFVocab:provides FaultPredictionInsight, DataFusionInsight
]

instance ProcessOptimizationService : DTDFVocab:Service [
    base:desc "Dynamic optimization of manufacturing processes and automotive energy systems"
    DTDFVocab:provides ResourceAllocationAction, EnergyEfficiencyAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Proactive optimization to prevent equipment failures using predictive analytics"
    DTDFVocab:provides FailureForecastingInsight, FaultMitigationAction
]

instance AdaptiveControlService : DTDFVocab:Service [
    base:desc "Real-time adjustment of physical systems based on Digital Twin predictions"
    DTDFVocab:provides DynamicReconfigurationAction, ActuatorCoordinationAction
]

instance ScenarioSimulationService : DTDFVocab:Service [
    base:desc "Virtual testing of collision avoidance and manufacturing process variations"
    DTDFVocab:provides CollisionAvoidanceSimulation, ProcessVariationSimulation
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Real-time visualization of vehicle states and manufacturing processes via dashboards"
    DTDFVocab:provides 3DVisualizationInsight, DashboardInsight
]

