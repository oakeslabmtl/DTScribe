// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "3D perception LiDAR sensor for autonomous vehicle spatial mapping and obstacle detection, providing high-resolution point cloud data with sub-centimeter precision in structured environments. Operates at real-time frequencies for vehicle state and environmental tracking."
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelRealsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "3D environmental perception depth camera providing high-resolution stereo imaging for autonomous navigation and process monitoring. Integrated with vehicle systems for spatial awareness and obstacle detection."
    DTDFVocab:producedData DepthCameraData
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor suite capturing real-time vehicle dynamics including motor actuation, steering servo actuation, speed, and trajectory data for autonomous control systems."
    DTDFVocab:producedData VehicleStateData
]

// C4: Physical-to-Virtual Data Transmission
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    base:desc "Raw 3D point cloud data from Hokuyo UST-10LX LiDAR processed through Point Cloud Clustering & Tracking SW component to generate structured object tracks and vehicle state information."
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraData : DTDFVocab:DataTransmitted [
    base:desc "3D environmental perception data from Intel Realsense D435i Depth Camera, processed for spatial mapping and obstacle detection in autonomous systems."
    DTDFVocab:producedFrom IntelRealsenseD435iDepthCamera
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    base:desc "Real-time vehicle dynamics data including motor actuation, steering servo actuation, speed, and trajectory metrics for autonomous control systems."
    DTDFVocab:producedFrom VehicleStateSensor
]

instance ObjectTracksData : DTDFVocab:DataTransmitted [
    base:desc "Processed LiDAR data identifying environmental objects (obstacles, pedestrians) with spatial-temporal attributes for situational awareness."
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance ProjectedDrivingPathData : DTDFVocab:DataTransmitted [
    base:desc "Computed autonomous vehicle trajectories derived from sensor inputs and vehicle state data for real-time control and navigation."
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR, VehicleStateSensor
]

// C10: Models/Data
instance VehicleStateModel : DTDFVocab:Model [
    base:desc "High-fidelity geometric and behavioral model of autonomous vehicle state including dynamic properties, sensor fusion outputs, and control system parameters."
    DTDFVocab:inputTo DataPreProcessingEnabler, PointCloudTrackingEnabler
]

instance ObjectTrackingModel : DTDFVocab:Model [
    base:desc "Spatial-temporal tracking model for environmental objects derived from LiDAR point clouds, enabling real-time obstacle detection and classification."
    DTDFVocab:inputTo PointCloudTrackingEnabler, DataTranslationEnabler
]

instance DrivingPathProjectionModel : DTDFVocab:Model [
    base:desc "Trajectory prediction model computing autonomous vehicle paths based on sensor inputs and vehicle dynamics for real-time navigation."
    DTDFVocab:inputTo PathProjectionEnabler, DataPreProcessingEnabler
]

instance LiDARPointCloudDataProcessed : DTDFVocab:Data [
    base:desc "Structured 3D point cloud data derived from raw LiDAR inputs, processed for object tracking and environmental mapping."
    DTDFVocab:fromData LiDARPointCloudData
    DTDFVocab:inputTo PointCloudTrackingEnabler, DataVisualizationEnabler
]

instance VehicleStateDataProcessed : DTDFVocab:Data [
    base:desc "Standardized vehicle dynamics data including motor actuation, steering inputs, and trajectory metrics for control system processing."
    DTDFVocab:fromData VehicleStateData
    DTDFVocab:inputTo DataPreProcessingEnabler, ControlSystemEnabler
]

instance ObjectTracksProcessed : DTDFVocab:Data [
    base:desc "Processed environmental object tracks with spatial-temporal attributes for real-time situational awareness and collision avoidance."
    DTDFVocab:fromData ObjectTracksData
    DTDFVocab:inputTo DataVisualizationEnabler, DecisionSupportService
]

instance DrivingPathProjectionData : DTDFVocab:Data [
    base:desc "Computed vehicle trajectories and navigation paths for autonomous control systems, derived from sensor inputs and vehicle state."
    DTDFVocab:fromData ProjectedDrivingPathData
    DTDFVocab:inputTo PathProjectionEnabler, ControlSystemEnabler
]

// C11: Enablers
instance ROS2DataAcquisitionEnabler : DTDFVocab:Enabler [
    base:desc "ROS2-based framework for real-time data acquisition, sensor fusion, and control in autonomous systems, enabling inter-node communication between software components."
    DTDFVocab:enables DataCollectionService, ControlSystemService
]

instance DataPreProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Software component standardizing and aligning sensor data (LiDAR, motor, steering) for downstream processing, including unit conversions and data validation."
    DTDFVocab:enables DataMonitoringService, DecisionSupportService
]

instance PointCloudTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Point Cloud Clustering & Tracking SW component converting raw LiDAR point clouds into structured object tracks and vehicle state data for situational awareness."
    DTDFVocab:enables ObjectDetectionService, VisualizationService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data serialization and message type alignment component ensuring consistent data formats across all data streams for interoperability."
    DTDFVocab:enables DataStorageService, RemoteManagementService
]

instance PathProjectionEnabler : DTDFVocab:Enabler [
    base:desc "Trajectory prediction engine computing autonomous vehicle paths based on sensor inputs and vehicle dynamics for real-time navigation."
    DTDFVocab:enables NavigationService, ControlSystemService
]

instance DataVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D visualization framework rendering processed data (vehicle state, object tracks, driving paths) for user interaction and monitoring."
    DTDFVocab:enables VisualizationService, DecisionSupportService
]

instance ControlSystemEnabler : DTDFVocab:Enabler [
    base:desc "Real-time control system implementing autonomous vehicle actuation based on processed sensor data and trajectory projections."
    DTDFVocab:enables AutonomousControlService, RemoteManagementService
]

instance JetsonOrinNanoEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetson Orin Nano microcomputer enabling edge AI and real-time processing of sensor data for autonomous systems, supporting high-performance computing at the edge."
    DTDFVocab:enables DataPreProcessingEnabler, PointCloudTrackingEnabler, PathProjectionEnabler
]

instance GazeboSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation environment for modeling, testing, and validating autonomous vehicle behaviors and control systems in virtual environments."
    DTDFVocab:enables SimulationService, TrainingService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "Modeling, simulation, and control system design platform for AI-driven simulations and autonomous system optimization."
    DTDFVocab:enables SimulationService, OptimizationService
]

// C6: Services
