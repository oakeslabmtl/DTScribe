// =========================== // Return code: 1 | Stderr:
// C3: Physical sensing components
// ===========================

instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor providing raw point‑cloud data for object detection and tracking on the 1/10‑scale autonomous vehicle."
    DTDFVocab:producedData LiDARRawPointCloud
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensors (e.g., wheel encoders, IMU) supplying vehicle‑state telemetry such as speed, heading and acceleration."
    DTDFVocab:producedData VehicleStateTelemetry
]

instance ProjectedPathSensor : DTDFVocab:SensingComponent [
    base:desc "Localisation/perception component delivering projected driving‑path information used by the ACC algorithm."
    DTDFVocab:producedData ProjectedPathTelemetry
]

// ===========================
// C4: Physical‑to‑Virtual interaction (DataTransmitted)
// ===========================

instance LiDARRawPointCloud : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance VehicleStateTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance ProjectedPathTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProjectedPathSensor
]

// ===========================
// C10: Data
// ===========================

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object‑track information generated by point‑cloud clustering & tracking from raw LiDAR points."
    DTDFVocab:fromData LiDARRawPointCloud
    DTDFVocab:inputTo ACCComputationEnabler, DataMonitoringEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Processed vehicle‑state information (speed, heading, acceleration) derived from telemetry."
    DTDFVocab:fromData VehicleStateTelemetry
    DTDFVocab:inputTo ACCComputationEnabler, DataMonitoringEnabler
]

instance ProjectedPathData : DTDFVocab:Data [
    base:desc "Processed projected driving‑path data used for ACC planning."
    DTDFVocab:fromData ProjectedPathTelemetry
    DTDFVocab:inputTo ACCComputationEnabler, DataMonitoringEnabler
]

// ===========================
// C11: Enablers
// ===========================

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that forwards vehicle‑state, projected‑path and object‑track data to the cloud‑based ACC model."
    DTDFVocab:enables ComputationOffloadingService
]

instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that supplies processed telemetry to the real‑time monitoring UI."
    DTDFVocab:enables DataMonitoringService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that receives operator commands (enable/disable ACC, set speed, emergency brake) and forwards them to actuators."
    DTDFVocab:enables RemoteManagementService
]

// ===========================
// C6: Services
// ===========================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Graphical UI displays real‑time vehicle state, projected path, detected object tracks and allows view, save, and report generation of logged data."
    DTDFVocab:provides InsightVehicleState, ActionGenerateReport
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Cloud‑based ACC algorithm runs off‑board the computed desired speed is sent back to the vehicle for actuation."
    DTDFVocab:provides ActionSetDesiredSpeed
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI lets operators enable/disable ACC, set a target speed, and issue emergency‑brake commands."
    DTDFVocab:provides ActionEnableACC, ActionSetTargetSpeed, ActionEmergencyBrake
]

// ===========================
// C17: Insights / Actions
// ===========================

instance InsightVehicleState : DTDFVocab:Insight [
    base:desc "Insight about current vehicle dynamics derived from telemetry, supporting operator situational awareness."
]

instance ActionGenerateReport : DTDFVocab:Action [
    base:desc "Operator‑initiated generation of a PDF/CSV report containing logged vehicle, path and object‑track data."
    DTDFVocab:IsAutomatic false
]

instance ActionSetDesiredSpeed : DTDFVocab:Action [
    base:desc "Automatic command generated by the ACC model that sets the desired vehicle speed on the physical twin."
    DTDFVocab:IsAutomatic true
]

instance ActionEnableACC : DTDFVocab:Action [
    base:desc "Operator command to enable the Adaptive Cruise Control functionality."
    DTDFVocab:IsAutomatic false
]

instance ActionSetTargetSpeed : DTDFVocab:Action [
    base:desc "Operator command to set a target cruising speed for the ACC algorithm."
    DTDFVocab:IsAutomatic false
]

instance ActionEmergencyBrake : DTDFVocab:Action [
    base:desc "Operator command that triggers an emergency brake on the vehicle with ≤100 ms timing accuracy."
    DTDFVocab:IsAutomatic false
]

// ===========================
// C2: Acting components (actuators)
// ===========================

instance ThrottleActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator that receives the desired speed command and adjusts vehicle throttle accordingly."
]

instance BrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Brake actuator that executes emergency‑brake commands with ≤100 ms timing accuracy."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin Entity are sent back to the Physical Twin over the same Wi‑Fi/UDP link. The ACC service, executed in the DT (potentially in the cloud), computes a desired speed based on the lead‑vehicle distance and transmits this speed command to the vehicle where the Actuation FE (motor and steering servo) executes it. Remote‑management UI actions (enable/disable ACC, set desired speed, emergency brake) are also issued as control messages via the same channel. The documents do not detail message formats, authentication, validation, or explicit acknowledgement mechanisms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires that all devices share a common notion of time. Clock synchronization must achieve at least 100 ms accuracy, which is the limit imposed by the hardware; safety‑critical vehicular standards typically demand tighter bounds, but the implementation targets 100 ms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 reference architecture and is organized into three top‑level entities – User Entity, Digital Twin Entity, and Physical Twin Entity. Software components identified in the design phase are mapped to Functional Entities (FEs) and each FE is implemented as an individual ROS 2 package containing one or more ROS 2 nodes. The packages are deployed on separate hardware platforms (e.g., compute unit, sensor unit, actuator unit), resulting in a distributed constellation where the Physical Twin Entity hosts resource‑specific functionality (e.g., point‑cloud clustering and tracking), the Digital Twin Entity provides data‑management and control, and the User Entity offers a 3‑D visualization and control‑panel interface."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The documentation highlights the safety‑critical nature of the ACC DT and mandates end‑to‑end latency below 100 ms, but does not describe explicit model fidelity requirements, validation and verification methods, uncertainty quantification, error‑correction mechanisms, or quality‑assurance processes for the models or the collected data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS uses a ROS2‑based intra‑entity communication fabric (DDS) for all software components. Inter‑entity communication between the Physical Twin Entity, Digital Twin Entity and User Entity is carried out over a Wi‑Fi network using UDP at the transport layer. The system must support low end‑to‑end latency, with a required time‑synchronisation accuracy of 100 ms for safety‑critical operations. No specific bandwidth, reliability, redundancy, or security protocol (e.g., TLS) details are provided in the source material."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The ACC functionality is offloaded from the vehicle to the Digital Twin, which can run on external compute resources such as cloud platforms, providing the necessary processing power for the ACC algorithm and data storage. The documents do not specify concrete hosting infrastructure, scalability mechanisms, deployment models, or availability guarantees."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The ISO 23247 standard cited in Document 2 indicates that data exchange with external systems may be realized through standards such as OPC Unified Architecture, but the described automotive digital twin does not explicitly specify any external integration protocol or dependence."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built in compliance with ISO 23247 (Digital Twin Framework for Manufacturing), specifically leveraging Part 2 (Reference Architecture) to define entities (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity) and Functional Entities. Communication and device control may employ OPC Unified Architecture, as suggested by the standard. Automotive‑specific standards are considered: the architecture promotes the Physical Twin Entity as a first‑class entity to align with automotive resource‑rich platforms, and references AUTOSAR for hardware‑agnostic software component definition. Safety considerations invoke ISO 26262 for functional safety in automotive DTs. Additionally, the implementation respects vehicular clock‑synchronisation requirements stricter than 100 ms, as mandated by various automotive safety standards."
]