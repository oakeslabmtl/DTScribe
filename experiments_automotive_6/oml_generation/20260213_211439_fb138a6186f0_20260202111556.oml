// Digital Twin Entity
instance DigitalTwinEntity : DTDFVocab:DigitalTwin [
    base:desc "Cloud‑hosted digital twin entity managing autonomous vehicle services"
]

// Sensing Components
instance RealSenseD435IDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera mounted on the upper chassis for visual depth estimation"
    DTDFVocab:producedData DepthImageTransmission
]

instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR installed on the upper chassis for 3‑D point cloud acquisition"
    DTDFVocab:producedData LiDARPointCloudTransmission
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑attached speed sensor providing throttle position data"
    DTDFVocab:producedData SpeedMeasurementTransmission
]

instance VehicleSteeringSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑attached steering angle sensor measuring servo position"
    DTDFVocab:producedData SteeringAngleMeasurementTransmission
]

// Acting Components
instance VedderESC : DTDFVocab:ActingComponent [
    base:desc "Vedder electronic speed controller converting desired speed commands into motor voltage signals"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator translating steering voltage commands into wheel steering angles"
]

// Data Transmitted
instance LiDARPointCloudTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthImageTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RealSenseD435IDepthCamera
]

instance SpeedMeasurementTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleMeasurementTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSteeringSensor
]

// Raw Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw point cloud data from Hokuyo UST‑10LX LiDAR"
    DTDFVocab:fromData LiDARPointCloudTransmission
    DTDFVocab:inputTo LiDARClusteringEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Raw depth image from Intel RealSense D435i"
    DTDFVocab:fromData DepthImageTransmission
    DTDFVocab:inputTo SceneRenderingEnabler
]

instance SpeedMeasurementData : DTDFVocab:Data [
    base:desc "Raw speed measurement from vehicle throttle sensor"
    DTDFVocab:fromData SpeedMeasurementTransmission
    DTDFVocab:inputTo RemoteManagementEnabler
]

instance SteeringAngleMeasurementData : DTDFVocab:Data [
    base:desc "Raw steering angle measurement from vehicle steering sensor"
    DTDFVocab:fromData SteeringAngleMeasurementTransmission
    DTDFVocab:inputTo RemoteManagementEnabler
]

// Processed Data
instance ClusteredPointCloudData : DTDFVocab:Data [
    base:desc "Point cloud clustered by DBSCAN into objects"
    DTDFVocab:inputTo KalmanFilterEnabler
]

instance TrackedObjectsData : DTDFVocab:Data [
    base:desc "Object tracks produced by Kalman filter tracking model"
    DTDFVocab:inputTo ACCControlEnabler
]

instance EgoVehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle speed, steering angle, and position state derived from sensors"
    DTDFVocab:inputTo RemoteManagementEnabler, DataMonitoringReportingEnabler
]

instance SceneRenderingData : DTDFVocab:Data [
    base:desc "3‑D scene rendering for visualization, comprising point cloud and tracked objects"
    DTDFVocab:inputTo SceneRenderingEnabler
]

instance SQLRecordData : DTDFVocab:Data [
    base:desc "Time‑stamped state and tracks stored in external SQL database"
    DTDFVocab:inputTo DataStorageEnabler
]

// Models
instance DBSCANPointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering model applied to raw LiDAR point cloud to detect obstacles"
    DTDFVocab:inputTo LiDARClusteringEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking model used to estimate object trajectories from clustered data"
    DTDFVocab:inputTo KalmanFilterEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "ACC control model per ISO 15622 computing desired speed from current state and object tracks"
    DTDFVocab:inputTo ACCControlEnabler
]

instance SceneRenderingModel : DTDFVocab:Model [
    base:desc "3‑D scene rendering model for visualizing vehicle environment and projected path"
    DTDFVocab:inputTo SceneRenderingEnabler
]

// Enablers and Services

// Actuation Enabler
instance ActuationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler handling motor voltage signals and steering voltage commands"
    DTDFVocab:enables ActuationService
]

instance ActuationService : DTDFVocab:Service [
    base:desc "Service converting desired speed commands into ESC signals and steering voltage commands"
    DTDFVocab:provides ActuationInsight
]

instance ActuationInsight : DTDFVocab:Insight [
    base:desc "Implementation details of actuation control logic"
]

// LiDAR Clustering Enabler
instance LiDARClusteringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler executing DBSCAN clustering on LiDAR point cloud"
    DTDFVocab:enables LiDARClusteringService
]

instance LiDARClusteringService : DTDFVocab:Service [
    base:desc "DBSCAN clustering service producing clustered point cloud insight"
    DTDFVocab:provides ClusteredPointCloudInsight
]

instance ClusteredPointCloudInsight : DTDFVocab:Insight [
    base:desc "Insight into objects detected by DBSCAN clustering"
]

// Kalman Filter Enabler
instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Enabler executing Kalman filter tracking on clustered point cloud"
    DTDFVocab:enables KalmanFilterService
]

instance KalmanFilterService : DTDFVocab:Service [
    base:desc "Kalman filter tracking service generating object track insight"
    DTDFVocab:provides TrackedObjectsInsight
]

instance TrackedObjectsInsight : DTDFVocab:Insight [
    base:desc "Insight into tracked object trajectories"
]

// ACC Control Enabler
instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler executing ACC algorithm based on ISO 15622"
    DTDFVocab:enables ACCControlService
]

instance ACCControlService : DTDFVocab:Service [
    base:desc "ACC control service computing desired speed adjustment actions"
    DTDFVocab:provides AdjustDesiredSpeedAction
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Automatic desired speed adjustment command for the vehicle"
    DTDFVocab:IsAutomatic true
]

// Scene Rendering Enabler
instance SceneRenderingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler performing 3‑D scene rendering for visualization"
    DTDFVocab:enables SceneRenderingService
]

instance SceneRenderingService : DTDFVocab:Service [
    base:desc "Scene rendering service generating scene visualization insight"
    DTDFVocab:provides SceneVisualizationInsight
]

instance SceneVisualizationInsight : DTDFVocab:Insight [
    base:desc "Rendered view of vehicle environment and predicted path"
]

// Data Monitoring & Reporting Enabler
instance DataMonitoringReportingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler generating real‑time CSV reports of object tracks and vehicle state"
    DTDFVocab:enables DataMonitoringReportingService
]

instance DataMonitoringReportingService : DTDFVocab:Service [
    base:desc "Service producing real‑time monitoring data reports"
    DTDFVocab:provides PerformanceReportInsight
]

instance PerformanceReportInsight : DTDFVocab:Insight [
    base:desc "Time‑series CSV report of object tracks and vehicle state"
]

// Remote Management Enabler
instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler handling remote operator commands for ACC and emergency actions"
    DTDFVocab:enables RemoteManagementService
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service providing remote control actions"
    DTDFVocab:provides ToggleACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

instance ToggleACCAction : DTDFVocab:Action [
    base:desc "Remote action to enable or disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Remote action to set a desired speed for the vehicle"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Emergency braking command issued remotely to halt vehicle"
    DTDFVocab:IsAutomatic false
]

// Data Storage Enabler
instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Enabler storing time‑stamped state and track data into external SQL database"
    DTDFVocab:enables DataStorageService
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Service providing storage of post‑mission analysis data"
    DTDFVocab:provides StoredDataInsight
]

instance StoredDataInsight : DTDFVocab:Insight [
    base:desc "Insight into stored database records for post‑mission analysis"
]

// Additional Insights
instance DiagnosticReportInsight : DTDFVocab:Insight [
    base:desc "Diagnostic report generated by the digital twin to evaluate vehicle performance"
]

instance PerformanceTuningInsight : DTDFVocab:Insight [
    base:desc "Performance tuning suggestions for Adaptive Cruise Control algorithms"
]

instance SafetyCriticalEventInsight : DTDFVocab:Insight [
    base:desc "Insight into detected safety‑critical events and operator interventions"
]

// Environments
instance MobileVehicleEnvironment : DTDFVocab:Environment [
    base:desc "Physical vehicle environment containing sensors and actuators"
    base:contains RealSenseD435IDepthCamera, HokuyoUST10LXLidar, VehicleSpeedSensor, VehicleSteeringSensor
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:desc "Digital twin environment containing enablers and services"
    base:contains VedderESC, SteeringServoActuator, ActuationEnabler, LiDARClusteringEnabler, KalmanFilterEnabler, ACCControlEnabler, SceneRenderingEnabler, DataMonitoringReportingEnabler, RemoteManagementEnabler, DataStorageEnabler, ActuationService, LiDARClusteringService, KalmanFilterService, ACCControlService, SceneRenderingService, DataMonitoringReportingService, RemoteManagementService, DataStorageService
]

// Component
instance DigitalTwinComponent : DTDFVocab:Component [
    base:desc "Cloud‑hosted digital twin running ROS2 nodes for monitoring, visualization, and computation offloading"
    base:isContainedIn DigitalTwinEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity’s ACC‑controlling Functional Entity computes a desired speed from the lead vehicle distance and forwards command messages via the Data Translation Functional Entity to the Data Collection Functional Entity on the vehicle, where the Actuation FE converts the desired speed into motor voltage commands and steering commands, effectively actuating the physical vehicle."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All DT services run at real‑time rates compatible with the vehicle’s perception cycle (≈ 10 Hz). End‑to‑end communication latency is bounded at 100 ms, and all participating nodes maintain clock synchronization accuracy within 100 ms, satisfying the network performance constraints required for real‑time ACC operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation follows ISO 23247’s entity‑based architecture: observable manufacturing elements (OEME) are mapped to a Physical Twin Entity (mounted on the vehicle), while the Digital Twin Entity processes data and performs ACC computation. The User Entity hosts a 3‑D visualization and a control panel, and a Cross‑System Entity provides data translation. Each entity comprises multiple Functional Entities packaged as ROS 2 packages and deployed across vehicle and cloud nodes."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle includes (1) Design and requirement definition (R1–R8), (2) Architecture mapping to ISO 23247 entities, (3) Implementation of FEs as ROS 2 packages, (4) Evaluation via a real‑world adaptive cruise control case study, and (5) Deployment in a remote‑management scenario where the DT operates in real time alongside the vehicle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT asserts real‑time, high‑fidelity reflections: data is collected and processed with network latency <100 ms, clocks are synchronized within 100 ms to preserve event ordering, and ACC logic follows ISO 15622 specifications to ensure safety‑critical correctness; data integrity is maintained through the Data‑Translation FE which normalises units and message types across the system."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the vehicle and the cloud uses a Wi‑Fi (802.11ac) link carrying ROS 2 (DDS) messages; the Data Translation Functional Entity handles serialization and unit conversion. Inter‑entity messages within the Digital Twin Entity are also exchanged via ROS 2 topics."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity is deployed on cloud‑based infrastructure (e.g., a virtual machine with sufficient GPU/CPU resources) and connects to the vehicle over Wi‑Fi. User interfaces run on client browsers or desktops, leveraging the 3‑D visualization FE, while the physical Twin runs on the NVIDIA Jetson Orin Nano node at the vehicle."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 (Digital Twin Manufacturing Framework reference architecture) is used to structure the twin; ISO 15622 (ACC standard) defines the control algorithm; ROS 2 is the communication middleware; OPC UA and other standard protocols were considered but not adopted."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety requirements enforce 100 ms end‑to‑end latency, 100 ms clock synchronization, and ISO 15622 compliance for ACC. Emergency braking can be commanded remotely, highlighting the need for runtime safety. No explicit cybersecurity measures are described in the document."
]