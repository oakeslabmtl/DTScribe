// Sensing Components
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR point cloud sensor mounted on the vehicle's chassis"
    DTDFVocab:producedData LiDARPointCloudDataReceived
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera for 3‑D perception"
    DTDFVocab:producedData DepthCameraFrameReceived
]

instance TachometerSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle tachometer sensor measuring wheel speed"
    DTDFVocab:producedData VehicleSpeedTelemetryReceived
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring vehicle steering position"
    DTDFVocab:producedData VehicleSteeringTelemetryReceived
]

// Data Transmitted
instance LiDARPointCloudDataReceived : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthCameraFrameReceived : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

instance VehicleSpeedTelemetryReceived : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TachometerSpeedSensor
]

instance VehicleSteeringTelemetryReceived : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Data transmitted via the cluster enabler
instance ClusteredPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    /* No properties needed */
]

// Data
instance LiDARPointCloudReceived : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data streamed at ~10Hz"
    DTDFVocab:inputTo LiDARClusteringEnabler
    DTDFVocab:fromData LiDARPointCloudDataReceived
]

instance DepthCameraFrameData : DTDFVocab:Data [
    base:desc "RGB‑D frames from Intel D435i captured at the vehicle's sensor rate"
    DTDFVocab:inputTo VisualizationEnabler
    DTDFVocab:fromData DepthCameraFrameReceived
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed telemetry data transmitted by the tachometer"
    DTDFVocab:inputTo DataMonitoringEnabler
    DTDFVocab:fromData VehicleSpeedTelemetryReceived
]

instance VehicleSteeringData : DTDFVocab:Data [
    base:desc "Vehicle steering telemetry data transmitted by the steering angle sensor"
    DTDFVocab:inputTo DataMonitoringEnabler
    DTDFVocab:fromData VehicleSteeringTelemetryReceived
]

instance ClusteredPointCloudData : DTDFVocab:Data [
    base:desc "Clustered LiDAR point clouds produced by DBSCAN"
    DTDFVocab:inputTo LiDARClusteringEnabler
    DTDFVocab:fromData LiDARPointCloudDataReceived
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Kalman‑filtered object tracks derived from clustered LiDAR data"
    DTDFVocab:inputTo TrackingEnabler
    DTDFVocab:fromData ClusteredPointCloudDataTransmitted
]

instance ACCDecisionData : DTDFVocab:Data [
    base:desc "ACC decision data containing desired speed and acceleration commands"
    DTDFVocab:inputTo ACCProcessingEnabler
    /* DTDFVocab:fromData removed because ACCDecisionData derives from ObjectTrackData which is of type Data */
]

// Physical Acting Components
instance MotorActuationComponent : DTDFVocab:ActingComponent [
    base:desc "Actuator FE converting desired speed into motor voltage commands for the Vedder Electronic Speed Controller"
]

instance SteeringActuationComponent : DTDFVocab:ActingComponent [
    base:desc "Actuator FE controlling steering servo based on steering commands"
]

instance EmergencyBrakingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator FE issuing emergency braking commands to vehicle drive system"
]

// Models
instance LiDARClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering model applied to raw LiDAR point cloud data"
    DTDFVocab:inputTo LiDARClusteringEnabler
]

instance KalmanTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking model used to produce object tracks from clustered LiDAR data"
    DTDFVocab:inputTo TrackingEnabler
]

instance ACCAlgorithmModel : DTDFVocab:Model [
    base:desc "ACC algorithm following ISO15622 class I to compute speed and braking actions"
    DTDFVocab:inputTo ACCProcessingEnabler
]

// Enablers
instance LiDARClusteringEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 node that clusters LiDAR point clouds using DBSCAN"
    DTDFVocab:enables LiDARClusteringService
]

instance TrackingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 node that performs Kalman filter tracking on clustered LiDAR data"
    DTDFVocab:enables TrackingService
]

instance ACCProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Cloud/edge offloaded ROS2 node implementing the ACC algorithm"
    DTDFVocab:enables ACCService
]

instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 node collecting vehicle telemetry streams for monitoring and reporting"
    DTDFVocab:enables DataMonitoringService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 node rendering 3‑D visualization of LiDAR clusters, object tracks, and vehicle state"
    DTDFVocab:enables Visualization3DService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 node exposing UI for remote operators to manage ACC, adjust desired speed, or issue emergency braking"
    DTDFVocab:enables RemoteManagementService
]

instance ReportGenerationEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 node generating historical telemetry reports and storing them in an SQL database"
    DTDFVocab:enables ReportGenerationService
]

// Services
instance LiDARClusteringService : DTDFVocab:Service [
    base:desc "Service providing clustered LiDAR point cloud visualization"
    DTDFVocab:provides ClusteredPointCloudInsight
]

instance TrackingService : DTDFVocab:Service [
    base:desc "Service providing time‑series of object tracks from tracked objects"
    DTDFVocab:provides ObjectTrackInsight
]

instance ACCService : DTDFVocab:Service [
    base:desc "Service providing ACC decisions and corresponding control actions"
    DTDFVocab:provides ACCDecisionInsight, ACCCommandAction
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real‑time vehicle performance insights and health status"
    DTDFVocab:provides VehicleHealthInsight, TelemetryInsight
]

instance Visualization3DService : DTDFVocab:Service [
    base:desc "Service rendering real‑time 3‑D visualization of vehicle state and detected objects"
    DTDFVocab:provides ThreeDVisualizationInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service allowing remote operators to enable/disable ACC, adjust desired speed, and issue emergency braking"
    DTDFVocab:provides RemoteOperatorAdjustmentInsight, RemoteOperatorAdjustmentAction
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Service generating historical telemetry reports as time‑series"
    DTDFVocab:provides HistoricalTelemetryInsight
]

// Insights
instance ClusteredPointCloudInsight : DTDFVocab:Insight [
    base:desc "Insight of clustered LiDAR point cloud data"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Insight of object tracks and their trajectories"
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "Insight of ACC decision outputs relative to vehicle state"
]

instance VehicleHealthInsight : DTDFVocab:Insight [
    base:desc "Insight showing vehicle health status and warnings"
]

instance TelemetryInsight : DTDFVocab:Insight [
    base:desc "Insight presenting current vehicle telemetry (speed, steering) in real‑time"
]

instance ThreeDVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time 3‑D visualization of object tracks, vehicle state, and projected path"
]

instance RemoteOperatorAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Insight showing current ACC status and remote operator commands"
]

instance HistoricalTelemetryInsight : DTDFVocab:Insight [
    base:desc "Historical telemetry report showing vehicle performance over time"
]

// Actions
instance ACCCommandAction : DTDFVocab:Action [
    base:desc "Command commanding desired speed and acceleration to motor controller"
    DTDFVocab:IsAutomatic true
]

instance RemoteOperatorAdjustmentAction : DTDFVocab:Action [
    base:desc "Action enabling or disabling ACC, modifying desired speed, and issuing emergency braking commands"
    DTDFVocab:IsAutomatic false
]

// Environment
instance VehicleEnvironment : DTDFVocab:Environment [
    base:contains HokuyoUST10LXLidar, IntelD435iDepthCamera, TachometerSpeedSensor, SteeringAngleSensor, MotorActuationComponent, SteeringActuationComponent, EmergencyBrakingActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "ACC computation performed in the DT generates a desired speed command, which is transmitted back to the PT over Wi‑Fi via ROS2 messages and applied through the Motor Actuation FE. Remote management commands (enable/disable ACC, override speed, emergency brake) are also sent from the DT’s User Entity to the PT’s Physical Twin Entity’s Actuation FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data acquisition and command dissemination with an end‑to‑end latency requirement of ≤100 ms (≈10 Hz). Clock synchronization across DT components maintained within 100 ms to ensure consistency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Three entities (Physical Twin, Digital Twin, User) interconnected via ROS2 DDS over Wi‑Fi. The Physical Twin Entity hosts actual sensors and actuators; the Digital Twin Entity comprises functional entities (Data Collection, Data Storage, Reporting, ACC Control, Data Translation); the User Entity renders a 3‑D visualization and a control panel. The constellation is orchestrated by Data Translation FE that serializes and unit‑converts data across entities."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (conceptual architecture), Manufacturing (physical vehicle built and retrofitted), and Operation (runtime usage for monitoring, remote management, and behavior analysis). The DT captures the vehicle’s behavior during the Operational stage and is updated during development."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time fidelity ensured by the 100 ms latency limit and 100 ms clock synchronization. DBSCAN clustering accuracy for object detection, Kalman filter for tracking; ACC algorithm validated against ISO 15622. Data translation FE ensures unit consistency, and SQL storage preserves historical integrity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication uses a Wi‑Fi network (IEEE 802.11) with ROS2 DDS (RTPS) for message transport. The DT entity and Physical Twin communicate over 802.11 Wi‑Fi; data serialized via DDS."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital Twin Entity hosted on a cloud/edge server; Physical Twin’s ROS2 nodes run on the vehicle’s Jetson Orin Nano; User Entity runs on the operator’s workstation or a remote desktop. All components communicate over the vehicle’s Wi‑Fi network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture, ISO 15622 for ACC control, ROS2 middleware (DDS), optional OPC UA for data translation per ISO 23247."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Compliance with safety‑critical requirements: end‑to‑end latency ≤100 ms, 100 ms clock sync, remote command execution controlled via UI to avoid unsafe states. The DT is designed following ISO 23247 to support safety‑critical behavior but specific cybersecurity mechanisms such as encryption or authentication are not detailed in the document."
]