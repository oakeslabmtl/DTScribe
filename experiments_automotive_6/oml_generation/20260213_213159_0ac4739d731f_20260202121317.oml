// C2: Acting Components
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Converts desired speed commands into motor voltage commands via the Vedder Electronic Speed Controller. Integrated into the lower-level chassis and interfaced via ROS2 nodes for real-time control."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Controls the vehicle's steering angle based on commands from the Digital Twin Entity (DTE). Integrated into the lower-level chassis and interfaced via ROS2 nodes for real-time control."
]

// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Provides high-resolution 3D point cloud data for object detection and tracking. Feeds raw data into the PointCloudClusteringAndTracking module."
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelDeepsenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Captures RGB-D data for environmental perception. Provides contextual information alongside LiDAR data."
    DTDFVocab:producedData CameraRGBDData
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Provides real-time data on ego vehicle speed for ACC logic and visualization."
    DTDFVocab:producedData VehicleSpeedData
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Provides real-time data on steering angle for ACC logic and visualization."
    DTDFVocab:producedData SteeringAngleData
]

// C4: Physical-to-Virtual Interaction
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    base:desc "Raw 3D point cloud data streamed from Hokuyo UST-10LX LiDAR via ROS2 topics to the DataCollectionFE in the Digital Twin Entity (DTE)."
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance CameraRGBDData : DTDFVocab:DataTransmitted [
    base:desc "RGB-D data streamed from Intel Deepsense D435i camera via ROS2 topics to the DataCollectionFE in the Digital Twin Entity (DTE)."
    DTDFVocab:producedFrom IntelDeepsenseD435iCamera
]

instance VehicleSpeedData : DTDFVocab:DataTransmitted [
    base:desc "Real-time ego vehicle speed data streamed via ROS2 topics to the DataCollectionFE in the Digital Twin Entity (DTE)."
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleData : DTDFVocab:DataTransmitted [
    base:desc "Real-time steering angle data streamed via ROS2 topics to the DataCollectionFE in the Digital Twin Entity (DTE)."
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ProcessedObjectTracks : DTDFVocab:DataTransmitted [
    base:desc "Processed object tracks generated via DBSCAN clustering and Kalman filtering in the PointCloudClusteringAndTracking module, forwarded to the DTE for visualization and control logic."
    DTDFVocab:producedFrom PointCloudClusteringAndTrackingModule
]

// C10: Models/Data
instance PointCloudClusteringAndTrackingModule : DTDFVocab:Model [
    base:desc "Implements DBSCAN clustering and Kalman filtering for object detection and tracking from LiDAR point clouds. Operates on the Physical Twin Entity (PT)."
    DTDFVocab:inputTo DataPreProcessingEnabler
]

instance ACCLogicModel : DTDFVocab:Model [
    base:desc "Implements ISO 15622 performance class I (basic speed control without road curvature) for Adaptive Cruise Control (ACC). Executes in the Digital Twin Entity (DTE)."
    DTDFVocab:inputTo ACCControllingEnabler
]

instance LiDARPointCloudDataProcessed : DTDFVocab:Data [
    base:desc "Processed LiDAR point cloud data after DBSCAN clustering and Kalman filtering, used for object tracking and visualization."
    DTDFVocab:fromData LiDARPointCloudData
    DTDFVocab:inputTo DataPreProcessingEnabler, VisualizationEnabler
]

instance CameraRGBDDataProcessed : DTDFVocab:Data [
    base:desc "Processed RGB-D data from Intel Deepsense D435i, used for environmental context visualization."
    DTDFVocab:fromData CameraRGBDData
    DTDFVocab:inputTo VisualizationEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Combined ego vehicle state data (speed, steering angle) for real-time monitoring and reporting."
    DTDFVocab:fromData VehicleSpeedData, SteeringAngleData
    DTDFVocab:inputTo DataStorageEnabler, VisualizationEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Timeseries data of object tracks processed via DBSCAN clustering and Kalman filtering, stored for reporting and analysis."
    DTDFVocab:fromData ProcessedObjectTracks
    DTDFVocab:inputTo DataStorageEnabler, ReportingEnabler
]

instance TimeseriesReports : DTDFVocab:Data [
    base:desc "Human-readable timeseries reports of object tracks and vehicle state generated for post-analysis."
    DTDFVocab:fromData VehicleStateData, ObjectTrackData
    DTDFVocab:inputTo ReportingEnabler
]

// C11: Enablers
instance DataPreProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Handles data serialization, translation, and alignment between Physical Twin Entity (PT) and Digital Twin Entity (DTE). Converts LiDAR point clouds to trackable objects."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance ACCControllingEnabler : DTDFVocab:Enabler [
    base:desc "Executes ACC logic (ISO 15622 performance class I) in the Digital Twin Entity (DTE) to reduce computational load on the PT."
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Renders 3D CAD-like representations of vehicle state, object tracks, and projected driving paths in real-time via the 3D Visualization User Interface FE."
    DTDFVocab:enables DataMonitoringService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Stores ego vehicle state and object track data in an external SQL database via the Data Storage component."
    DTDFVocab:enables ReportGenerationService
]

instance ReportingEnabler : DTDFVocab:Enabler [
    base:desc "Generates human-readable timeseries reports of object tracks and vehicle state for post-analysis."
    DTDFVocab:enables ReportGenerationService
]

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "Modular communication middleware for intra-entity and inter-entity data exchange between ROS2 nodes across PT and DTE."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance WiFiCommunicationProtocol : DTDFVocab:Enabler [
    base:desc "Inter-entity communication protocol between Physical Twin Entity (PT) and Digital Twin Entity (DTE) with ≤100 ms latency (3GPP TS 22.185 compliant)."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of ego vehicle state (speed, steering angle), object tracks, and projected driving path via the 3D Visualization User Interface FE."
    DTDFVocab:provides VehicleStateInsight, ObjectTrackInsight, DrivingPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC logic in the DTE (cloud/edge) to reduce computational load on the PT's NVIDIA Jetson Orin Nano, with only actuation commands sent back to the PT."
    DTDFVocab:provides ACCLogicAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables enable/disable ACC, desired speed adjustment, and emergency braking via the Control Panel User Interface FE."
    DTDFVocab:provides ACCEnableDisableAction, DesiredSpeedAdjustmentAction, EmergencyBrakingAction
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generates human-readable timeseries reports of object tracks and vehicle state via the Reporting FE for post-analysis."
    DTDFVocab:provides TimeseriesReportInsight
]

// C17: Insights/Actions
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of ego vehicle speed and steering angle to inform ACC adjustments."
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of object tracks processed via DBSCAN clustering and Kalman filtering."
]

instance DrivingPathInsight : DTDFVocab:Insight [
    base:desc "Projection of the vehicle's driving path based on current state and object tracks."
]

instance TimeseriesReportInsight : DTDFVocab:Insight [
    base:desc "Post-analysis reports of object tracks and vehicle state for performance evaluation."
]

instance ACCLogicAction : DTDFVocab:Action [
    base:desc "Execution of ACC logic (ISO 15622 performance class I) in the Digital Twin Entity (DTE)."
    DTDFVocab:IsAutomatic true
]

instance ACCEnableDisableAction : DTDFVocab:Action [
    base:desc "Remote enable/disable of Adaptive Cruise Control (ACC) functionality."
    DTDFVocab:IsAutomatic false
]

instance DesiredSpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjustment of desired speed for ACC via the Control Panel User Interface FE."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Initiation of emergency braking via the Control Panel User Interface FE."
    DTDFVocab:IsAutomatic false
]

// C1: Entities (Centralized yet Modular Architecture)
instance PhysicalTwinEntityEnvironment : DTDFVocab:Environment [
    base:desc "Hosts sensor data processing (Point Cloud Clustering & Tracking) and actuation. Implemented on NVIDIA Jetson Orin Nano with ROS2 middleware."
    base:contains DataCollectionFE, DataPreProcessingFE, DataTranslationFE, HokuyoUST10LXLiDAR, IntelDeepsenseD435iCamera, VehicleSpeedSensor, SteeringAngleSensor, MotorActuator, SteeringServoActuator, PointCloudClusteringAndTrackingModule
]

instance DigitalTwinEntityEnvironment : DTDFVocab:Environment [
    base:desc "Centralizes ACC logic, data collection, and visualization. Deployed on external cloud/edge infrastructure."
    base:contains ACCControllingFE, DataPreProcessingEnabler, ACCControllingEnabler, DataStorageEnabler, VisualizationEnabler, ReportingEnabler, DataStorageComponent
]

instance UserEntityEnvironment : DTDFVocab:Environment [
    base:desc "Combines 3D Visualization and Control Panel into a unified interface for real-time monitoring and remote management."
    base:contains VisualizationFE, ControlPanelFE
]

// C5: Components (Functional Entities)
instance DataCollectionFE : DTDFVocab:Component [
    base:desc "Collects real-time data from Physical Twin Entity (PT) via ROS2 topics and forwards it to the Digital Twin Entity (DTE)."
    base:isContainedIn PhysicalTwinEntityEnvironment
]

instance DataPreProcessingFE : DTDFVocab:Component [
    base:desc "Processes raw sensor data (LiDAR point clouds, camera feeds) into structured object tracks using DBSCAN clustering and Kalman filtering."
    base:isContainedIn PhysicalTwinEntityEnvironment
    DTDFVocab:inputTo DataPreProcessingEnabler
]

instance ACCControllingFE : DTDFVocab:Component [
    base:desc "Executes ACC logic (ISO 15622 performance class I) and sends actuation commands back to the Physical Twin Entity (PT)."
    base:isContainedIn DigitalTwinEntityEnvironment
    DTDFVocab:inputTo ACCControllingEnabler
]

instance VisualizationFE : DTDFVocab:Component [
    base:desc "Renders 3D CAD-like representations of vehicle state, object tracks, and projected paths in real-time."
    base:isContainedIn UserEntityEnvironment
    DTDFVocab:inputTo VisualizationEnabler
]

instance ControlPanelFE : DTDFVocab:Component [
    base:desc "Provides remote management capabilities (enable/disable ACC, desired speed adjustment, emergency braking)."
    base:isContainedIn UserEntityEnvironment
    DTDFVocab:inputTo RemoteManagementService
]

instance ReportingFE : DTDFVocab:Component [
    base:desc "Generates human-readable timeseries reports of object tracks and vehicle state for post-analysis."
    base:isContainedIn DigitalTwinEntityEnvironment
    DTDFVocab:inputTo ReportingEnabler
]

instance DataStorageComponent : DTDFVocab:Component [
    base:desc "Stores ego vehicle state and object track data in an external SQL database."
    base:isContainedIn DigitalTwinEntityEnvironment
    DTDFVocab:inputTo DataStorageEnabler
]

instance DataTranslationFE : DTDFVocab:Component [
    base:desc "Ensures interoperability between entities by performing data serialization, unit conversion, and alignment."
    base:isContainedIn PhysicalTwinEntityEnvironment
    DTDFVocab:inputTo DataPreProcessingEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The interactions from the virtual twin (DT) to the physical twin (PT) include:
    - **Desired speed commands**: Computed by the **ACC Controlling FE** in the DTE and transmitted back to the PT for motor actuation.
    - **Remote management commands**: Sent via the **Control Panel User Interface FE** to enable/disable ACC, modify desired speed, or trigger emergency braking.
    - **Actuation commands**: Executed by the **Actuation FE** in the Physical Twin Entity, converting virtual control signals into physical motor/steering actions."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates on a **real-time time scale** with the following constraints:
    - **End-to-end latency**: ≤100 ms (from PT to DTE and vice versa), adhering to **3GPP TS 22.185** for V2V communication.
    - **Clock synchronization**: Devices must be synchronized to **±100 ms accuracy** to ensure event ordering and data integrity in distributed operations.
    - **Perception cycle**: Object tracks and vehicle state are updated at the frequency of sensor data acquisition (e.g., LiDAR and camera feeds)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation follows the **ISO 23247 reference architecture** with the following orchestration:
    - **Entities**:
        1. **Physical Twin Entity (PT)**: Custom entity (not in ISO 23247) hosting **sensor data processing (Data Pre-Processing FE)**, **actuation (Actuation FE)**, and **point cloud clustering/tracking**.
        2. **Digital Twin Entity (DTE)**: Centralizes **data collection (Data Collecting FE)**, **ACC control (Controlling FE)**, **reporting (Reporting FE)**, and **visualization preprocessing (Presentation FE)**.
        3. **User Entity**: Combines **3D Visualization** and **Control Panel** into a single **User Interface FE** (split from monolithic UI in ISO 23247).
    - **Functional Entities (FEs)**:
        - Mapped to ROS2 packages for modularity (e.g., **Data Translation FE** handles all data serialization).
    - **Deployment**:
        - PT components run on the **Jetson Orin Nano** (onboard).
        - DTE components may execute on **external cloud/edge** for computation offloading.
    - **Data Flow**:
        - Sensor data → **Data Pre-Processing FE** → **Data Collecting FE** → **ACC Controlling FE** → **Actuation FE** (PT).
        - User commands → **Control Panel FE** → **Controlling FE** → **Actuation FE** (PT)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the following lifecycle stages of the physical counterpart:
    - **Design/Development**: Used as a **cyber-physical experimentation facility** for validating ACC logic and sensor fusion algorithms (e.g., **DBSCAN + Kalman filtering**).
    - **Operation**: Enables **real-time monitoring, remote management, and predictive maintenance** (e.g., brake system prognosis via simulators like **CREO Simulate**).
    - **Lifecycle Management**: Supports **digital threads** for end-to-end information flow (e.g., storing vehicle state data in an **SQL database** for post-mortem analysis). The DT represents the PT **as operated**, not as designed or manufactured."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
    - **Real-Time Constraints**:
        - **≤100 ms end-to-end latency** (3GPP TS 22.185) for real-time ACC operation.
        - **±100 ms clock synchronization** for event ordering and data integrity.
    - **Validation Mechanisms**:
        - **ISO 15622 compliance**: ACC logic adheres to **performance class I** standards.
        - **Sensor Fusion**: **DBSCAN + Kalman filtering** for accurate object tracking.
        - **Simulation Integration**: **CREO Simulate** for predictive maintenance validation.
    - **Uncertainty Management**:
        - **Data Translation FE** handles unit conversions and message alignment to mitigate errors.
        - **External SQL storage** ensures data integrity for post-analysis.
    - **Verification**:
        - **ROS2 middleware** provides modular testing of individual FEs.
        - **Public demonstration** validates real-world applicability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection between PT and DT includes:
    - **Network Protocol**: **Wi-Fi** for inter-entity communication with **≤100 ms latency** (as per 3GPP TS 22.185).
    - **Intra-Entity Communication**: **ROS2 topics** for message-passing between software components (nodes) within entities.
    - **Data Translation**: Custom **Data Translation FE** serializes data, aligns message types, and performs unit conversions (e.g., LiDAR point clouds to trackable objects).
    - **Clock Synchronization**: Devices synchronized to **±100 ms accuracy** to ensure coordinated operations."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted and deployed as follows:
    - **Physical Twin (PT)**:
        - **Hardware**: **NVIDIA Jetson Orin Nano** (onboard) with **ROS2** and **Jetpack 5.0 SDK**.
        - **Software**: **Python 3.8, C++, MATLAB/Simulink** for implementing FEs (e.g., **Point Cloud Clustering & Tracking**).
    - **Digital Twin Entity (DTE)**:
        - **Potential Deployment**: Cloud/edge for computation offloading (e.g., ACC logic).
        - **Software**: ROS2 packages for **Data Collecting FE**, **Controlling FE**, and **Reporting FE**.
    - **User Entity**:
        - **Hosted on external workstation** for remote management and visualization.
        - **3D Visualization** and **Control Panel** integrated into a unified UI."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration involves:
    - **External Data Systems**: Potential integration with **vehicle lifecycle management tools** for end-to-end digital threads.
    - **Standardized Interfaces**: **ROS2** and **ISO 23247-compliant FEs** enable interoperability with other DTs or IoT systems.
    - **Data Exchange**: **SQL database** stores timeseries data for cross-system analysis (e.g., fleet coordination)."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT adheres to the following standards:
    - **ISO 23247**: Reference architecture for DT development, adapted for automotive use (e.g., **entity-based structure**, **Functional Entities**).
    - **ISO 15622**: ACC logic complies with **performance class I** requirements (basic speed control).
    - **3GPP TS 22.185**: **≤100 ms latency** for V2V communication.
    - **ROS2**: Middleware standard for modular software integration.
    - **NVIDIA Jetpack 5.0**: SDK for Jetson hardware development."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety considerations include:
    - **Real-Time Constraints**: **≤100 ms latency** and **±100 ms clock synchronization** ensure timely and coordinated operations.
    - **Remote Operation Safety**:
        - **Emergency braking** command is directly executable via the **Control Panel FE**.
        - **Human-in-the-Loop (HITL)**: Operators can override automated actions (e.g., disabling ACC).
    - **Data Integrity**: **Data Translation FE** and **SQL storage** ensure accurate and tamper-proof data.
    - **Safety-Critical Validation**: ACC logic is validated against **ISO 15622** standards.
    - **Potential Risks**: Remote operations could introduce cybersecurity vulnerabilities (e.g., unauthorized command injection), but no specific mitigation strategies are detailed in the document."
]