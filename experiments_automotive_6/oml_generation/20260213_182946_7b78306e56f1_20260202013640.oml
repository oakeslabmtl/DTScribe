// =============================
// C1: System Under Study
// =============================
instance AutonomousScaleVehicle : DTDFVocab:Component [
    base:desc "1/10‑scale autonomous vehicle retrofitted from a Traxxas Slash 4x4 platform, equipped with lower chassis (steering/speed control), upper chassis hosting NVIDIA Jetson NX antenna, Jetson Orin Nano, Hokuyo UST‑10LX LiDAR, Intel RealSense D435i depth camera, and Vedder ESC."
]

// =============================
// C2: Acting Components
// =============================
// Motor drive actuator
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder ESC that actuates vehicle speed by modulating motor voltage."
]

// Steering actuator
instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Servo motor that actuates the steering angle of the 1/10‑scale vehicle."
]

// Emergency brake actuator (via motor voltage = 0)
instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Acts as an emergency brake by setting motor voltage to zero through the Vedder ESC."
]

// =============================
// C3: Physical Sensing Components
// =============================
// LiDAR sensor
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2‑D LiDAR providing real‑time point‑cloud data.",
    producedData LiDARPointCloudDataTransmitted
]

// Depth camera sensor
instance IntelRealSenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D frames.",
    producedData CameraDepthDataTransmitted
]

// Vehicle speed sensor (ego speed)
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board wheel‑speed sensor delivering the ego‑vehicle speed.",
    producedData SpeedDataTransmitted
]

// Steering‑angle sensor
instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the current steering angle of the vehicle.",
    producedData SteeringAngleDataTransmitted
]

// =============================
// C4: Data Transmitted (ROS2 Topics)
// =============================
// LiDAR point‑cloud topic
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

// Depth‑image topic
instance CameraDepthDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iCamera
]

// Speed topic
instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

// Steering angle topic
instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// =============================
// C17: Insights & Actions
// =============================
// Insight – Vehicle state report
instance VehicleStateReportInsight : DTDFVocab:Insight [
    base:desc "Human‑readable time‑series report of vehicle speed, steering angle, and detected object tracks."
]

// Insight – Projected path visualization
instance ProjectedPathVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of current vehicle trajectory and predicted paths of surrounding objects."
]

// Insight – ACC command output
instance ACCCommandInsight : DTDFVocab:Insight [
    base:desc "Computed ACC speed set‑point presented to the operator for verification."
]

// Action – Adjust ACC settings
instance AdjustACCSettingsAction : DTDFVocab:Action [
    base:desc "Operator changes ACC target speed or following distance via the UI.",
    DTDFVocab:IsAutomatic false
]

// Action – Emergency brake
instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency stop Digital Twin commands motor voltage = 0 via EmergencyBrakeActuator.",
    DTDFVocab:IsAutomatic false
]

// =============================
// C6: Services
// =============================
// Service 1 – Data Monitoring
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualizes real‑time vehicle state, projected paths, and object tracks, stores data and generates reports.",
    provides VehicleStateReportInsight, ProjectedPathVisualizationInsight
]

// Service 2 – Computation Offloading
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC algorithm off‑board, reducing load on the vehicle ECU.",
    provides ACCCommandInsight, AdjustACCSettingsAction
]

// Service 3 – Remote Management
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows remote enable/disable of ACC, speed set‑point changes, and emergency braking.",
    provides EmergencyBrakeAction, AdjustACCSettingsAction
]

// =============================
// C11: Enablers (Tooling & Infrastructure)
// =============================
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 (DDS) middleware for real‑time topic transport.",
    enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance JetPackSDKEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK providing CUDA‑accelerated compute on Jetson Orin Nano.",
    enables ComputationOffloadingService
]

instance Python38Enabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime used by the ACCControlModel and data‑translation scripts.",
    enables ComputationOffloadingService
]

instance CppRos2NodeEnabler : DTDFVocab:Enabler [
    base:desc "C++ ROS 2 nodes implementing sensor interfacing and service APIs.",
    enables DataMonitoringService, RemoteManagementService
]

instance MatlabSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for advanced perception processing.",
    enables DataMonitoringService
]

instance DBSCANAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Implementation of the DBSCAN clustering algorithm.",
    enables DataMonitoringService
]

instance KalmanFilterAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Implementation of the Kalman‑filter tracking algorithm.",
    enables DataMonitoringService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Relational SQL database engine used for persistent storage of time‑series data.",
    enables DataMonitoringService
]

instance Visualization3DModelEnabler : DTDFVocab:Enabler [
    base:desc "Graphics engine (e.g., OpenGL/Qt) that renders 3‑D visualization data for the UI.",
    enables DataMonitoringService
]

instance WiFiNetworkingEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi networking stack enabling remote UI connectivity to the vehicle.",
    enables RemoteManagementService
]

instance DataTranslationFEEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation Functional Entity responsible for serialization, unit conversion, and ROS 2 message mapping.",
    enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

// =============================
// C10: Models
// =============================
// ACC control model (ISO 15622)
instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model compliant with ISO 15622, computes speed set‑point from vehicle state and surrounding objects.",
    inputTo JetPackSDKEnabler
]

// DBSCAN clustering model
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN algorithm clusters LiDAR point‑clouds into object candidates.",
    inputTo DBSCANAlgorithmEnabler
]

// Kalman filter tracking model
instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter refines object clusters into tracked trajectories.",
    inputTo KalmanFilterAlgorithmEnabler
]

// 3‑D visualization model
instance Visualization3DModel : DTDFVocab:Model [
    base:desc "Generates 3‑D scene data for UI from tracked objects and vehicle pose.",
    inputTo Visualization3DModelEnabler
]

// =============================
// C10: Data (processed / stored)
// =============================
// Vehicle speed data
instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of ego‑vehicle speed received from SpeedDataTransmitted.",
    fromData SpeedDataTransmitted,
    inputTo ROS2MiddlewareEnabler
]

// Steering angle data
instance VehicleSteeringAngleData : DTDFVocab:Data [
    base:desc "Time‑series of steering angle received from SteeringAngleDataTransmitted.",
    fromData SteeringAngleDataTransmitted,
    inputTo ROS2MiddlewareEnabler
]

// LiDAR point‑cloud data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw point‑cloud frames streamed from LiDARPointCloudDataTransmitted.",
    fromData LiDARPointCloudDataTransmitted,
    inputTo DBSCANAlgorithmEnabler
]

// Depth camera data
instance CameraDepthData : DTDFVocab:Data [
    base:desc "Depth image frames streamed from CameraDepthDataTransmitted.",
    fromData CameraDepthDataTransmitted,
    inputTo MatlabSimulinkEnabler
]

// Object tracks data (output of Kalman filter)
instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Structured time‑series of tracked objects (position, velocity) generated by KalmanFilterTrackingModel.",
    fromData LiDARPointCloudDataTransmitted,
    inputTo KalmanFilterAlgorithmEnabler
]

// ACC command data (output of ACC model)
instance ACCCommandData : DTDFVocab:Data [
    base:desc "Desired speed set‑point issued by ACCControlModel for computation offloading.",
    fromData VehicleSpeedData,
    inputTo JetPackSDKEnabler
]

// Visualization data (3‑D scene for UI)
instance Visualization3DData : DTDFVocab:Data [
    base:desc "3‑D visual representation of vehicle, environment, and projected paths for UI rendering.",
    fromData ObjectTracksData,
    inputTo Visualization3DModelEnabler
]

// Time‑series storage in relational SQL DB
instance TimeSeriesSQLDatabase : DTDFVocab:Data [
    base:desc "SQL relational database storing VehicleSpeedData, SteeringAngleData, and ObjectTracksData for reporting.",
    fromData VehicleSpeedData,
    inputTo SQLDatabaseEnabler
]

// =============================
// C17: Additional Twin Entities (Multiplicities)
// =============================
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "On‑vehicle twin hosted on Jetson Orin Nano, directly interfacing sensors and actuators."
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Off‑board twin running on remote compute, providing ACC computation and UI services."
]

instance UserEntity : DTDFVocab:Component [
    base:desc "Remote user interface component accessed via Wi‑Fi for monitoring and control."
]

instance CrossSystemDataTranslationEntity : DTDFVocab:Component [
    base:desc "Functional entity that links PhysicalTwin, DigitalTwin, and UserEntity, handling serialization and unit conversion."
]

// =============================
// C17: Environment (Physical Vehicle)
// =============================
instance ScaleVehicleEnvironment : DTDFVocab:Environment [
    base:contains AutonomousScaleVehicle,
                 VedderElectronicSpeedController,
                 SteeringServo,
                 EmergencyBrakeActuator,
                 HokuyoUST10LXLidar,
                 IntelRealSenseD435iCamera,
                 VehicleSpeedSensor,
                 SteeringAngleSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin sends desired speed commands, ACC enable/disable signals, desired speed adjustments, and emergency‑brake commands back to the vehicle over the ROS 2/Wi‑Fi link; an Actuation Functional Entity converts these commands into motor voltage and steering‑servo control signals."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "End‑to‑end communication latency bounded at ≤100 ms (R7) and component clocks synchronized within 100 ms accuracy (R8). Data collection and control operate at the perception‑cycle rate (tens of Hz), supporting real‑time interaction."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Entity‑based architecture derived from ISO 23247: Physical Twin Entity hosts Data Pre‑Processing and Actuation FEs; Digital Twin Entity hosts Data Collection, Reporting, Controlling, and Presentation FEs; User Entity hosts Visualization and Control‑Panel UI FEs; Cross‑System Data Translation FE mediates inter‑entity communication over ROS 2 within entities and Wi‑Fi between entities."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during design/testing (simulation of ACC), during manufacturing validation, and throughout operation for monitoring, remote management and performance reporting."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Safety‑critical operation enforced by latency ≤100 ms and clock sync ≤100 ms. ACC logic follows ISO 15622 specifications. Sensor data is processed with proven DBSCAN clustering and Kalman filtering, and results are stored in a SQL database for traceability. Real‑time performance was validated on the physical testbed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Intra‑entity communication via ROS 2 DDS on the same host; inter‑entity communication over a Wi‑Fi network using ROS 2 topics. A Data Translation Functional Entity performs message serialization, type alignment and unit conversion for all exchanged data."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the vehicle‑mounted NVIDIA Jetson Orin Nano; Digital Twin Entity runs on an external compute platform (e.g., cloud or workstation) that hosts the ACC algorithm and data services; the User Entity UI runs on a remote workstation accessed over the Wi‑Fi link."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 (Digital Twin Manufacturing Framework) for architecture, ISO 15622 for ACC functionality, ISO/IEC 30173 for DT terminology, OPC UA (IEC 62541) mentioned as optional data translation protocol, and 3GPP TS 22.185 referenced for latency requirements."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed through real‑time latency limits (≤100 ms), clock synchronization (≤100 ms), and remote command validation for emergency braking. No explicit security mechanisms (e.g., authentication, encryption) are described in the document."
]