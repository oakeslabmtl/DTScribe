// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor providing raw point cloud data for the vehicle."
    DTDFVocab:producedData RawLiDARData
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor providing speed, acceleration, and heading data."
    DTDFVocab:producedData RawVehicleStateData
]

instance RemoteOperatorDevice : DTDFVocab:SensingComponent [
    base:desc "Remote operator device transmitting ACC control commands."
    DTDFVocab:producedData RemoteCommandDataTransmitted
]

// C4: Physical-to-virtual interaction – Data transmitted
instance RawLiDARData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance RawVehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance RemoteCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RemoteOperatorDevice
]

// C5: Data instances
instance ProcessedLiDARData : DTDFVocab:Data [
    base:desc "Processed LiDAR data after ISO 23247 Data Translation FE, including unit conversions."
    DTDFVocab:fromData RawLiDARData
    DTDFVocab:inputTo ObjectTrackingEnabler
]

instance ProcessedVehicleStateData : DTDFVocab:Data [
    base:desc "Processed vehicle state data after data translation."
    DTDFVocab:fromData RawVehicleStateData
    DTDFVocab:inputTo DataMonitoringEnabler
]

instance LeadVehicleDistanceData : DTDFVocab:Data [
    base:desc "Lead-vehicle distance derived from processed LiDAR point cloud clustering."
    DTDFVocab:fromData ProcessedLiDARData
    DTDFVocab:inputTo ComputationEnabler
]

instance RemoteCommandData : DTDFVocab:Data [
    base:desc "Remote control command data after processing."
    DTDFVocab:fromData RemoteCommandDataTransmitted
    DTDFVocab:inputTo RemoteCommandEnabler
]

// C11: Enablers
instance ObjectTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that processes LiDAR data to produce object tracks."
    DTDFVocab:enables ObjectTrackingService
]

instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that aggregates vehicle state and object track data for monitoring."
    DTDFVocab:enables DataMonitoringService
]

instance ComputationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that offloads ACC speed computation to cloud infrastructure."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteCommandEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that routes remote commands to the remote management service."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance ObjectTrackingService : DTDFVocab:Service [
    base:desc "Clusters and tracks objects from processed LiDAR data, producing proximity tracks."
    DTDFVocab:provides ObjectTrackInsight
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Aggregates vehicle state, object tracks, and projected driving paths for visualization."
    DTDFVocab:provides VehicleStateInsight, ObjectTrackVisualizationInsight, DrivingPathProjectionInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computes vehicle speed based on lead-vehicle distance using cloud resources."
    DTDFVocab:provides ACCSpeedComputationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, and issue emergency braking."
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Provides real‑time object track and proximity information."
]

instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Shows current vehicle state including speed, acceleration, and heading."
]

instance ObjectTrackVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of tracked objects in the simulation."
]

instance DrivingPathProjectionInsight : DTDFVocab:Insight [
    base:desc "Projected driving path based on current trajectory."
]

// C17: Actions
instance ACCSpeedComputationAction : DTDFVocab:Action [
    base:desc "Computes the vehicle’s travel speed from lead‑vehicle distance."
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables the Adaptive Cruise Control subsystem."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets the desired vehicle speed."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issues an emergency braking command."
    DTDFVocab:IsAutomatic false
]

// C10: Environment containing all components
instance VehicleTwinEnvironment : DTDFVocab:Environment [
    base:contains LiDARSensor, VehicleStateSensor, RemoteOperatorDevice,
        RawLiDARData, RawVehicleStateData, RemoteCommandDataTransmitted,
        ProcessedLiDARData, ProcessedVehicleStateData, LeadVehicleDistanceData, RemoteCommandData,
        ObjectTrackingEnabler, DataMonitoringEnabler, ComputationEnabler, RemoteCommandEnabler,
        ObjectTrackingService, DataMonitoringService, ComputationOffloadingService, RemoteManagementService,
        ObjectTrackInsight, VehicleStateInsight, ObjectTrackVisualizationInsight, DrivingPathProjectionInsight,
        ACCSpeedComputationAction, EnableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin requires all devices to share a common notion of time with a minimum synchronization accuracy of 100 ms to support computation offloading, in accordance with standards that mandate tighter clock alignment for safety‑critical vehicular applications. This 100 ms wall‑clock tolerance is enforced across the distributed vehicle components, ensuring that ROS2 packages executing on separate ECUs can coordinate real‑time data exchanges while respecting the required temporal granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system implements the ISO 23247 Reference Architecture by partitioning the Digital Twin System (DTS) into three core entities: Digital Twin, Physical Twin, and User entities. Each Functional Element (FE) is encapsulated in an individual ROS2 package containing one or more ROS2 nodes, enabling deployment across diverse hardware modules of the vehicle. The Digital Twin Entity hosts data‑management and control subsystems, the Physical Twin Entity handles sensor data preprocessing, actuation logic, and device communication (including general automotive functions such as point‑cloud clustering and tracking), while the User Entity provides a 3‑D visualization and control panel. The orchestration follows a hierarchical, component‑based pattern where inter‑entity interactions are mediated via ROS2 topics, services, and actions, ensuring coherent coordination between distributed subsystems."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between software components inside the Digital Twin is performed over a ROS 2 network using the ROS 2 publish/subscribe middleware. Inter‑entity communication between the physical device (vehicle) and the Digital Twin occurs over a Wi‑Fi network and uses UDP as the transport layer. The document does not specify the network topology (e.g., star, ring), bandwidth or latency requirements, or redundancy and reliability mechanisms. Furthermore, security protocols for network communication are not described in the provided text."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin adheres to ISO 23247 – Digital Twin Framework for Manufacturing. Its implementation follows the entity‑based reference architecture defined in Part 2, which specifies Observable Manufacturing Elements (OMEs), Data Collection and Device Control Entities, Digital Twin Entities, and User Entities. Functional Entities (FEs) are the granularity of the implementation. While ISO 23247 does not prescribe specific encoding or transport protocols, it allows the use of standards such as OPC Unified Architecture for device communication. The reference architecture also mandates compliance with Parts 1, 3, and 4 concerning general principles, digital representation of physical manufacturing elements, and information exchange, respectively."
]