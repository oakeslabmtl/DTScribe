// -------------------------------------------------
// Physical Sensing Components
// -------------------------------------------------
instance SpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Ego‑vehicle speed measurement from the Vedder electronic speed controller."
    DTDFVocab:producedData VehicleTelemetry
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle measurement from the vehicle’s steering mechanism."
    DTDFVocab:producedData VehicleTelemetry
]

instance HokuyoLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2‑D LiDAR providing laser scans for object detection."
    DTDFVocab:producedData LiDARPointCloud
]

instance IntelDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D frames."
    DTDFVocab:producedData DepthCameraFrames
]

// -------------------------------------------------
// Physical‑to‑Virtual Data Transmission
// -------------------------------------------------
instance VehicleTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SpeedSensor, SteeringAngleSensor
]

instance LiDARPointCloud : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARSensor
]

instance DepthCameraFrames : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCameraSensor
]

// -------------------------------------------------
// Digital Twin Data Objects
// -------------------------------------------------
instance VehicleStateData : DTDFVocab:Data [
    base:desc "Combined speed and steering‑angle state used by the ACC algorithm."
    DTDFVocab:fromData VehicleTelemetry
    DTDFVocab:inputTo DataCollectionEnabler
]

instance RawLiDARData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data before clustering."
    DTDFVocab:fromData LiDARPointCloud
    DTDFVocab:inputTo DBSCANClusteringModel
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames used for perception and ACC decision making."
    DTDFVocab:fromData DepthCameraFrames
    DTDFVocab:inputTo ACCAlgorithmEnabler
]

// -------------------------------------------------
// Models / Algorithms
// -------------------------------------------------
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point clouds to generate initial object clusters."
    DTDFVocab:inputTo ACCAlgorithmEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter applied to object clusters for multi‑frame tracking."
    DTDFVocab:inputTo ACCAlgorithmEnabler
]

instance ACCIso15622Model : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm implementing lead‑vehicle selection and speed‑set‑point as defined in ISO 15622."
    DTDFVocab:inputTo ACCAlgorithmEnabler
]

instance PersistentSQLDatabaseModel : DTDFVocab:Model [
    base:desc "SQL schema for persisting time‑series vehicle state and object‑track data."
    DTDFVocab:inputTo DBEnabler
]

// -------------------------------------------------
// Enablers (Functional Entities & Tooling)
// -------------------------------------------------
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware (ROS 2, Wi‑Fi) used for all inter‑entity communication."
    DTDFVocab:enables DataCollectionEnabler, DataTranslationEnabler, ACCAlgorithmEnabler, UIVisualizationEnabler, RemoteManagementEnabler
]

instance DataCollectionEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247 Data Collection FE gathering telemetry and perception streams."
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247 Data Translation FE serializing and performing unit conversion."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadService, RemoteManagementService
]

instance ACCAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Execution environment for the ACC control algorithm (off‑loaded to the digital twin)."
    DTDFVocab:enables ComputationOffloadService
]

instance UIVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "User‑interface FE rendering real‑time speed, steering, object tracks, and projected path."
    DTDFVocab:enables DataMonitoringService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Remote‑management FE allowing operators to enable/disable ACC, set speed, and trigger emergency brake."
    DTDFVocab:enables RemoteManagementService
]

instance DBEnabler : DTDFVocab:Enabler [
    base:desc "SQL database service persisting vehicle state and object‑track time series."
    DTDFVocab:enables ComputationOffloadService, DataMonitoringService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment used for clustering and tracking algorithm development."
    DTDFVocab:enables DBSCANClusteringModel, KalmanFilterTrackingModel
]

instance NVIDIAJetpack5Enabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK providing GPU acceleration on Jetson devices."
    DTDFVocab:enables ACCAlgorithmEnabler
]

instance Python38Enabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime for rapid prototyping of ROS 2 nodes."
    DTDFVocab:enables DataCollectionEnabler, DataTranslationEnabler
]

instance CppROS2LifecycleEnabler : DTDFVocab:Enabler [
    base:desc "C++ ROS 2 node lifecycle management for high‑performance components."
    DTDFVocab:enables ACCAlgorithmEnabler, UIVisualizationEnabler
]

// -------------------------------------------------
// Services
// -------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI shows real‑time speed, steering angle, object tracks, projected path and can generate saved reports."
    DTDFVocab:provides RealTimeSpeedInsight, RealTimeSteeringInsight, RealTimeObjectTracksInsight, ProjectedPathInsight, PostRunReportInsight
]

instance ComputationOffloadService : DTDFVocab:Service [
    base:desc "ACC control algorithm runs in the digital twin, reducing load on the vehicle ECU."
    DTDFVocab:provides ACCDecisionInsight, ACCDecisionAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, set desired speed, and issue emergency‑brake commands from the UI."
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// -------------------------------------------------
// Insights
// -------------------------------------------------
instance RealTimeSpeedInsight : DTDFVocab:Insight [
    base:desc "Real‑time display of vehicle speed on the operator UI."
]

instance RealTimeSteeringInsight : DTDFVocab:Insight [
    base:desc "Real‑time display of steering‑angle on the operator UI."
]

instance RealTimeObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Visualization of detected object tracks derived from LiDAR clustering."
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected trajectory of the ego‑vehicle based on current speed and steering."
]

instance PostRunReportInsight : DTDFVocab:Insight [
    base:desc "Generated post‑run analysis report summarizing speed, steering, and object‑track statistics."
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "ACC decision (desired speed, enable/disable) derived from the DT’s ISO 15622 model."
]

// -------------------------------------------------
// Actions
// -------------------------------------------------
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Command to enable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Command to disable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set the target speed for the ACC controller."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediate cut of motor power to execute an emergency brake."
    DTDFVocab:IsAutomatic true
]

instance ACCDecisionAction : DTDFVocab:Action [
    base:desc "Adjust ACC parameters (desired speed, enable/disable) based on developer tuning."
    DTDFVocab:IsAutomatic false
]

// -------------------------------------------------
// Acting Components (Actuators)
// -------------------------------------------------
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Voltage command sent to the Vedder electronic speed controller to regulate vehicle speed."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "PWM command sent to the steering servo for directional control."
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Command that instantly cuts motor power to enact an emergency stop."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Controlling FE in the Digital Twin Entity computes the desired speed according to the ACC algorithm and sends speed set‑points, ACC enable/disable commands, desired‑speed adjustments, and emergency‑braking signals back to the PT via the Actuation FE over the same ROS 2/Wi‑Fi channel."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates in real‑time with a maximum end‑to‑end network latency of 100 ms (per 3GPP TS 22.185) and clock synchronization accuracy of 100 ms across all DT components, enabling tight coupling between PT and DT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 reference model: a Physical Twin Entity (sensors, actuation), a Digital Twin Entity (data collection, ACC logic, reporting, visualization preprocessing), a User Entity (3D visualization UI and control panel), and a Cross‑System Data Translation FE that mediates all inter‑entity message formats. Communication within the DT uses ROS 2/DDS; PT‑DT communication uses Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is used during the operational stage for monitoring, remote control, and performance analysis, and also during development/debugging phases where developers exploit the monitoring and data‑collection capabilities."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity is achieved by using raw LiDAR point clouds and real‑time vehicle telemetry; validity is ensured by adhering to ISO 15622 ACC functional requirements, meeting the 100 ms latency bound, and synchronising clocks within 100 ms. The tracking model is validated through DBSCAN clustering followed by Kalman filtering to maintain accurate object tracks."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange between PT and DT occurs over a Wi‑Fi network using ROS 2 messages (DDS transport). Within the DT, components communicate via ROS 2 topics and services. The Data Translation FE serialises, aligns message types, and performs unit conversion to ensure interoperability."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the vehicle’s Jetson Orin Nano; the Digital Twin Entity runs on a separate compute platform (e.g., a laptop or cloud instance) hosting the ACC logic and database; the User Entity runs on an operator workstation displaying the 3D visualization and control panel. Each entity is packaged as a ROS 2 node set."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT architecture is based on ISO 23247 (Digital Twin Manufacturing Framework) and uses ISO 15622 for ACC functionality. Communication latency follows 3GPP TS 22.185 specifications, and ISO/IEC 30173:2023 is referenced for twin terminology. Optional OPC UA (IEC 62541) is mentioned as a possible data‑translation layer."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed as a safety‑critical system with a hard latency bound of 100 ms, clock synchronization of 100 ms, and compliance with ISO 15622 ACC safety requirements. Remote management commands (enable/disable ACC, emergency brake) are executed only after validation by the Controlling FE, but no specific cybersecurity mechanisms are described in the document."
]