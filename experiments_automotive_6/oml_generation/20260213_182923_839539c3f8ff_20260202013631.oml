import DTDFVocab

// =============================
// Physical Sensing Components
// =============================

instance HokuyoUST110LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑110LX LiDAR providing raw point clouds",
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera delivering depth images",
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of ego vehicle speed from the vehicle’s embedded sensors",
    DTDFVocab:producedData SpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of steering angle obtained from the vehicle’s embedded sensors",
    DTDFVocab:producedData SteeringAngleTransmitted
]

// =========================
// Data Transmitted (PT → DT)
// =========================

instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST110LXLidar
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ObjectTracksTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST110LXLidar
]

// =====================
// Data (Virtual Twin)
// =====================

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data",
    DTDFVocab:fromData LiDARPointCloudTransmitted,
    DTDFVocab:inputTo ObjectTrackingEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image stream from the D435i camera",
    DTDFVocab:fromData DepthImageTransmitted,
    DTDFVocab:inputTo ObjectTrackingEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed (m/s) measured on the physical vehicle",
    DTDFVocab:fromData SpeedDataTransmitted,
    DTDFVocab:inputTo ACCControlEnabler,
    DTDFVocab:inputTo MonitoringEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle (rad) measured on the physical vehicle",
    DTDFVocab:fromData SteeringAngleTransmitted,
    DTDFVocab:inputTo ACCControlEnabler,
    DTDFVocab:inputTo MonitoringEnabler
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Derived object tracks generated from LiDAR point clouds (DBSCAN + Kalman)",
    DTDFVocab:fromData ObjectTracksTransmitted,
    DTDFVocab:inputTo VisualizationEnabler
]

// =====================
// Acting Components (PT)
// =====================

instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage actuation for speed control (implemented by the Actuation Functional Entity)"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuation for direction control"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency braking command that overrides normal actuation"
]

// =====================
// Enablers (DT)
// =====================

instance ROS2DDSEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware using DDS for intra‑ and inter‑entity communication",
    DTDFVocab:enables DataMonitoringService,
    DTDFVocab:enables ComputationOffloadingService,
    DTDFVocab:enables RemoteManagementService
]

instance DataCollectingFEEnabler : DTDFVocab:Enabler [
    base:desc "Data Collecting Functional Entity gathers sensor streams over ROS2"
]

instance DataTranslationFEEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation FE serialises, performs unit conversion, and forwards data to the Digital Twin"
]

instance ObjectTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Executes object tracking model (DBSCAN clustering + Kalman filter)"
]

instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "Runs ACC control model implementing ISO 15622 lead‑vehicle following logic",
    DTDFVocab:enables ComputationOffloadingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D visualization model renders tracks and projected path",
    DTDFVocab:enables DataMonitoringService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Aggregates vehicle state data for UI monitoring",
    DTDFVocab:enables DataMonitoringService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Handles operator commands for ACC enable/disable, speed adjustment and emergency braking",
    DTDFVocab:enables RemoteManagementService
]

instance DatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database persisting time‑series vehicle state and generated reports",
    DTDFVocab:enables RemoteManagementService
]

// =====================
// Models (DT)
// =====================

instance DBSCANKalmanObjectTrackingModel : DTDFVocab:Model [
    base:desc "Object tracking model using DBSCAN clustering of LiDAR points and a Kalman filter for trajectory estimation",
    DTDFVocab:inputTo ObjectTrackingEnabler
]

instance ISO15622ACCControlModel : DTDFVocab:Model [
    base:desc "ACC control model implementing ISO 15622 logic for lead‑vehicle following",
    DTDFVocab:inputTo ACCControlEnabler
]

instance ThreeDVisualizationModel : DTDFVocab:Model [
    base:desc "3D visualization model for rendering object tracks and projected path",
    DTDFVocab:inputTo VisualizationEnabler
]

instance VehicleStateSQLDatabaseModel : DTDFVocab:Model [
    base:desc "SQL database schema for persisting vehicle state, reports and ACC logs",
    DTDFVocab:inputTo DatabaseEnabler
]

// =====================
// Services (DT)
// =====================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualises real‑time speed, steering angle, object tracks and projected path, and generates reports",
    DTDFVocab:provides LiveVehicleStateInsight,
    DTDFVocab:provides ObjectTracksVisualizationInsight,
    DTDFVocab:provides ProjectedPathInsight,
    DTDFVocab:provides GeneratedReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm (lead‑vehicle detection and speed computation per ISO 15622) runs in the DT and returns control set‑points",
    DTDFVocab:provides ACCDecisionInsight,
    DTDFVocab:provides SetSpeedSetpointAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI enables operators to enable/disable ACC, adjust desired speed, and issue emergency braking",
    DTDFVocab:provides ACCEnableDisableAction,
    DTDFVocab:provides ACCParameterAdjustmentAction,
    DTDFVocab:provides EmergencyBrakeAction
]

// =====================
// Insights & Actions
// =====================

instance LiveVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Provides operators with live vehicle speed and steering angle"
]

instance ObjectTracksVisualizationInsight : DTDFVocab:Insight [
    base:desc "Displays tracked objects derived from LiDAR data"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Shows projected vehicle path based on ACC decisions"
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "ACC module computes desired speed set‑point for the vehicle"
]

instance GeneratedReportInsight : DTDFVocab:Insight [
    base:desc "Reports summarising vehicle state and ACC performance for developer diagnostics"
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator‑initiated emergency braking command that overrides normal actuation",
    DTDFVocab:IsAutomatic false
]

instance ACCEnableDisableAction : DTDFVocab:Action [
    base:desc "Operator command to enable or disable the ACC function",
    DTDFVocab:IsAutomatic false
]

instance ACCParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Operator adjusts desired speed set‑point for the ACC controller",
    DTDFVocab:IsAutomatic false
]

instance SetSpeedSetpointAction : DTDFVocab:Action [
    base:desc "Automatic action sending computed speed set‑point from ACC model to the vehicle actuators",
    DTDFVocab:IsAutomatic true
]

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Automatic generation of diagnostic reports stored in the SQL database",
    DTDFVocab:IsAutomatic true
]

// =====================
// Twin Entities (Multiplicity)
// =====================

instance PhysicalTwinEntity : DTDFVocab:Environment [
    base:contains HokuyoUST110LXLidar, IntelDeepsenseD435iDepthCamera, VehicleSpeedSensor, SteeringAngleSensor,
               MotorVoltageActuator, SteeringServoActuator, EmergencyBrakeActuator
]

instance DigitalTwinEntity : DTDFVocab:Environment [
    base:contains ROS2DDSEnabler, DataCollectingFEEnabler, DataTranslationFEEnabler,
               ObjectTrackingEnabler, ACCControlEnabler, VisualizationEnabler, MonitoringEnabler,
               RemoteManagementEnabler, DatabaseEnabler,
               DBSCANKalmanObjectTrackingModel, ISO15622ACCControlModel, ThreeDVisualizationModel,
               VehicleStateSQLDatabaseModel,
               DataMonitoringService, ComputationOffloadingService, RemoteManagementService,
               LiDARPointCloudData, DepthImageData, VehicleSpeedData, SteeringAngleData, ObjectTracksData
]

instance UserEntity : DTDFVocab:Environment [
    base:contains DataMonitoringService, RemoteManagementService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends desired speed commands, ACC enable/disable signals, modified speed set‑points, and emergency braking commands back to the PT over the same ROS2/Wi‑Fi link. The Actuation FE converts the desired speed into motor voltage and the steering FE (if used) into servo positions, which are applied on the vehicle."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates in real time with a maximum end‑to‑end communication latency of 100 ms (per 3GPP 22.185) and clock synchronisation accuracy of 100 ms across all DT components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Adapted ISO 23247 architecture with four entities: Physical Twin Entity (sensing, actuation, point‑cloud clustering), Digital Twin Entity (data collection, ACC, reporting, visualization pre‑processing), User Entity (3D UI and control panel), and Cross‑System Entity (Data Translation). Entities are distributed across vehicle‑side hardware and external compute, communicating over ROS2 and Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT supports the operational stage (real‑time monitoring, remote control, and off‑loaded ACC computation) and the development stage (data collection, debugging, and reporting for developers). It is also used as a cyber‑physical experimentation platform during design."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity representation achieved by processing raw LiDAR data with DBSCAN and Kalman filtering, ACC behavior conforms to ISO 15622, latency and clock‑sync constraints (≤100 ms) ensure timely interaction for safety‑critical operation, and external storage allows post‑run validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication between PT and DT over a Wi‑Fi network using ROS2 messages; Data Translation FE serialises, type‑aligns and converts units; optional OPC UA noted but not employed; ROS2 packages encapsulate each FE."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital Twin Entity components run on external compute (e.g., a PC or cloud host) separate from the vehicle, while the Physical Twin Entity (sensors, point‑cloud clustering) runs on the vehicle’s Jetson Orin Nano. Each Functional Entity is deployed as a ROS2 package on its respective hardware."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The design follows ISO 23247 (Digital Twin Manufacturing Framework) reference architecture, ISO 15622 (ACC functional requirements), ISO/IEC 30173 (conceptual DT terminology), and 3GPP 22.185 (latency requirement). ROS2 (DDS) and OPC UA are referenced as standard middleware options."
]