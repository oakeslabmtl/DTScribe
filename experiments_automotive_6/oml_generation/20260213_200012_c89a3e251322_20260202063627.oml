import "https://example.com/DTDFVocab" as DTDFVocab
instance HokuyoLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR for point cloud data",
    DTDFVocab:producedData HokuyoLidarPointCloudDataTransmitted
]
instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i Depth Camera for depth perception",
    DTDFVocab:producedData IntelDepthCameraDepthDataTransmitted
]
instance VedderSpeedController : DTDFVocab:SensingComponent [
    base:desc "Vedder Electronic Speed Controller for motor speed feedback",
    DTDFVocab:producedData VedderSpeedControllerFeedbackTransmitted
]
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Motor actuator for vehicle speed control"
]
instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator for steering control"
]
instance HokuyoLidarPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLidar
]
instance IntelDepthCameraDepthDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]
instance VedderSpeedControllerFeedbackTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VedderSpeedController
]
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data",
    DTDFVocab:fromData HokuyoLidarPointCloudDataTransmitted,
    DTDFVocab:inputTo Python38
]
instance DepthCameraImageData : DTDFVocab:Data [
    base:desc "Depth camera image data for perception",
    DTDFVocab:fromData IntelDepthCameraDepthDataTransmitted,
    DTDFVocab:inputTo Python38
]
instance SpeedFeedbackData : DTDFVocab:Data [
    base:desc "Motor speed feedback from Vedder ESC",
    DTDFVocab:fromData VedderSpeedControllerFeedbackTransmitted,
    DTDFVocab:inputTo Python38
]
instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Processed object tracks from DBSCAN and Kalman filter",
    DTDFVocab:inputTo Python38
]
instance VehicleStateData : DTDFVocab:Data [
    base:desc "Timeseries vehicle state data for storage",
    DTDFVocab:inputTo SQLDatabaseEnabler
]
instance DBSCANModel : DTDFVocab:Model [
    base:desc "DBSCAN-based point cloud clustering",
    DTDFVocab:inputTo Python38
]
instance KalmanFilterModel : DTDFVocab:Model [
    base:desc "Kalman filter for object tracking",
    DTDFVocab:inputTo Python38
]
instance ACCControlLogicModel : DTDFVocab:Model [
    base:desc "ACC control logic per ISO 15622",
    DTDFVocab:inputTo MATLABSimulink
]
instance NVIDIAJetpackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for development environment",
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for communication",
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]
instance Python38 : DTDFVocab:Enabler [
    base:desc "Python 3.8 for rapid prototyping",
    DTDFVocab:enables ComputationOffloadingService, DataMonitoringService
]
instance CPlusPlusForROS2 : DTDFVocab:Enabler [
    base:desc "C++ for ROS2 node lifecycle management",
    DTDFVocab:enables DataMonitoringService
]
instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for complex systems modeling",
    DTDFVocab:enables ComputationOffloadingService
]
instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database for data storage",
    DTDFVocab:enables DataMonitoringService
]
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of vehicle state and object tracks",
    DTDFVocab:provides VehicleStateVisualization, ObjectTrackReport, PerformanceAnalytics
]
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC system executed on DT to reduce on-board computation",
    DTDFVocab:provides ACCControl
]
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enable/disable ACC, set desired speed, emergency braking via UI",
    DTDFVocab:provides EnableACC, DisableACC, SetDesiredSpeed, EmergencyBraking
]
instance VehicleStateVisualization : DTDFVocab:Insight [
    base:desc "Real-time vehicle state visualization for operators"
]
instance ObjectTrackReport : DTDFVocab:Insight [
    base:desc "Object track reports for developers"
]
instance PerformanceAnalytics : DTDFVocab:Insight [
    base:desc "Performance analytics for troubleshooting ACC system"
]
instance ACCControl : DTDFVocab:Action [
    base:desc "ACC control logic execution",
    DTDFVocab:IsAutomatic true
]
instance EnableACC : DTDFVocab:Action [
    base:desc "Enable ACC system via UI",
    DTDFVocab:IsAutomatic false
]
instance DisableACC : DTDFVocab:Action [
    base:desc "Disable ACC system via UI",
    DTDFVocab:IsAutomatic false
]
instance SetDesiredSpeed : DTDFVocab:Action [
    base:desc "Set desired speed via UI",
    DTDFVocab:IsAutomatic false
]
instance EmergencyBraking : DTDFVocab:Action [
    base:desc "Emergency braking activation via UI",
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Motor voltage commands for speed control and emergency braking commands sent to the vehicle's actuation system; steering angle commands are not part of the DT's output as per the documented ACC implementation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "End-to-end latency of at most 100 ms between vehicle and DT Entity, with clocks synchronized to 100 ms accuracy as per 3GPP Technical Specification 22.185 for safety-critical vehicular applications."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Distributed system with Physical Twin Entity on vehicle hardware (Jetson Orin Nano), Digital Twin Entity for computation offloading (cloud-based), User Entity (UI on separate device), and Cross-System Entity (Data Translation), communicating via ROS2 intra-component and Wi-Fi inter-entity."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Used during design phase for cyber-physical experimentation, validation of requirements compliance, and operational phase for optimization and health monitoring, as described in automotive DT surveys by Deng et al. and Schwarz and Wang."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "ROS2 for intra-component communication; Wi-Fi for inter-entity communication with 100 ms latency constraint; Data Translation component serializes data, aligns message types, and performs unit conversions."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity deployed on NVIDIA Jetson Orin Nano on the vehicle; Digital Twin Entity and Data Storage on cloud; User Entity on separate device."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture for DT structure; ISO 15622 for ACC control strategy implementation."
]