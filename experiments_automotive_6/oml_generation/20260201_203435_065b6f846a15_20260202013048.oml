// ---------------------------------------------------------------------------
// 1. Sensing Components
// ---------------------------------------------------------------------------
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor capturing 3D point clouds of the environment for the scaled autonomous vehicle."
    DTDFVocab:producedData LiDARRawPointCloudTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Drive‑motor status sensor providing RPM and torque feedback."
    DTDFVocab:producedData MotorStatusTransmitted
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑servo sensor delivering command and feedback signals."
    DTDFVocab:producedData SteeringServoTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑state sensor (IMU, wheel encoders) reporting position, velocity and orientation."
    DTDFVocab:producedData VehicleStateTransmitted
]

// ---------------------------------------------------------------------------
// 2. Data Transmitted (Physical → Virtual)
// ---------------------------------------------------------------------------
instance LiDARRawPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance MotorStatusTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance SteeringServoTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// ---------------------------------------------------------------------------
// 3. Data (after acquisition)
// ---------------------------------------------------------------------------
instance RawLiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data as received from the physical twin."
    DTDFVocab:fromData LiDARRawPointCloudTransmitted
    DTDFVocab:inputTo PointCloudClusteringTrackingEnabler
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Motor status information (RPM, torque) extracted from the motor sensor."
    DTDFVocab:fromData MotorStatusTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance SteeringServoData : DTDFVocab:Data [
    base:desc "Steering‑servo command and feedback values."
    DTDFVocab:fromData SteeringServoTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Combined vehicle state (position, velocity, orientation)."
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks generated by clustering and tracking of LiDAR point clouds."
    DTDFVocab:fromData LiDARRawPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

// ---------------------------------------------------------------------------
// 4. Enablers (Functional Entities)
// ---------------------------------------------------------------------------
instance PointCloudClusteringTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Functional Entity that clusters LiDAR point clouds and tracks objects in real time."
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247 Data Translation FE that serializes messages, aligns types and performs unit conversions."
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService, DataMonitoringService
]

instance WiFiUDPTransportEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi UDP transport layer that forwards processed streams from the Physical Twin Entity to the Digital Twin Entity."
    DTDFVocab:enables DataMonitoringService
]

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware network used for intra‑component communication inside the Digital Twin Entity."
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService, DataMonitoringService
]

instance CloudACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Cloud‑based compute resource that runs the Adaptive Cruise Control algorithm and returns speed commands."
    DTDFVocab:enables ComputationOffloadingService
]

instance UIEnabler : DTDFVocab:Enabler [
    base:desc "Custom UI component that visualizes vehicle state, object tracks and enables operator command issuance."
    DTDFVocab:enables RemoteManagementService, DataMonitoringService
]

// ---------------------------------------------------------------------------
// 5. Services
// ---------------------------------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Streams real‑time vehicle state, projected path and detected object tracks; allows saving and reporting of ACC‑relevant data."
    DTDFVocab:provides VehicleStateInsight, ObjectTracksInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes the ACC algorithm on cloud resources and transmits the resulting speed command back to the vehicle."
    DTDFVocab:provides GenerateSpeedCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to enable/disable ACC, set desired speed, and issue emergency‑brake commands; also supports developer debugging."
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction, DebugDataAction
]

// ---------------------------------------------------------------------------
// 6. Insights
// ---------------------------------------------------------------------------
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current vehicle motion parameters useful for ACC performance assessment."
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Insight about surrounding objects and their predicted trajectories derived from LiDAR clustering."
]

// ---------------------------------------------------------------------------
// 7. Actions
// ---------------------------------------------------------------------------
instance GenerateSpeedCommandAction : DTDFVocab:Action [
    base:desc "Generates a speed command for the vehicle based on ACC lead‑vehicle detection and desired‑speed calculation."
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Command to enable the Adaptive Cruise Control function."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Command to disable the Adaptive Cruise Control function."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets the operator‑specified desired cruising speed for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issues an emergency braking command to stop the vehicle immediately."
    DTDFVocab:IsAutomatic false
]

instance DebugDataAction : DTDFVocab:Action [
    base:desc "Allows developers to request raw sensor logs and internal state for debugging."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin Entity—such as ACC enable/disable, desired speed set‑points, and emergency‑brake requests—are formatted by the Data Translation FE and sent over the same Wi‑Fi UDP link to the Physical Twin Entity. Upon receipt, the Actuation FE forwards the commands to the vehicle actuators (motor, steering servo) to realize the requested behavior. The documents do not describe validation, authentication, or acknowledgement mechanisms for these commands."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Device coordination for computation offloading requires a shared notion of time; the system mandates clock synchronization accuracy of 100 ms, which is the maximum allowed latency between the physical and digital components. This requirement follows safety‑critical vehicular standards and defines the temporal granularity for all time‑stamped sensor and actuator data exchanged between the Physical Twin Entity and the Digital Twin Entity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system adopts the ISO 23247 reference architecture and implements every Functional Entity as an individual ROS 2 package; each package contains one or more ROS 2 nodes that realize the functionality of the corresponding FE. The three top‑level entities (Physical Twin, Digital Twin, User) are orchestrated through ROS 2 middleware, enabling inter‑process communication across the heterogeneous hardware components. This ROS 2‑based integration embodies the resource‑centric orchestration prescribed by the standard while allowing entity‑level ownership of functionality."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS employs a hybrid network architecture. Internal software components communicate via the ROS 2 middleware (publish/subscribe) on each hardware node. Communication between the three ISO 23247 entities (Physical Twin, Digital Twin, User) is carried out over a Wi‑Fi LAN using UDP as the transport protocol. The system requires low end‑to‑end latency to support safety‑critical ACC functions and targets a clock synchronisation accuracy of 100 ms across devices. No explicit bandwidth, reliability, redundancy, or security protocol details are provided in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The standard allows implementation of Functional Entities with protocols such as OPC Unified Architecture; although the present system does not detail a concrete external‑system linkage, it is compatible with OPC UA and with the ISO 23247‑4 information‑exchange specifications for data sharing with other enterprise systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built to comply with ISO 23247 – Digital Twin Framework for Manufacturing, specifically Part 2 (Reference Architecture). Entities and Functional Entities such as the Data Collection and Device Control Entity, Digital Twin Entity, User Entity, and Observable Manufacturing Element are adopted as defined by the standard. The implementation may use OPC Unified Architecture for data exchange, as suggested by the standard, although the choice of protocol is left to the implementer."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The case study notes that the ISO 23247 reference architecture (RA) is insufficient for safety‑critical automotive applications and recommends promoting safety to a first‑class citizen by incorporating existing automotive functional‑safety standards, specifically ISO 26262. No cybersecurity protocols, access‑control mechanisms, authentication systems, or threat‑mitigation strategies are described in the documents."
]