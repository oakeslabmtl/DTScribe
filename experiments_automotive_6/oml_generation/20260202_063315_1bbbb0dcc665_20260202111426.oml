// Sensing Components
instance HokuyoLiDAR10LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR for 3D point‑cloud acquisition on 1/10‑scale vehicle"
    DTDFVocab:producedData LiDARPointCloudStream
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera providing stereo imaging for vehicle perception"
    DTDFVocab:producedData DepthImageStream
]

instance WheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel speed sensor for vehicle velocity measurement"
    DTDFVocab:producedData SpeedMeasurementStream
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor for vehicle heading feedback"
    DTDFVocab:producedData SteeringAngleStream
]

// Physical-Transmitted Data
instance LiDARPointCloudStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR10LX
]

instance DepthImageStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

instance SpeedMeasurementStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedSensor
]

instance SteeringAngleStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Data instances
instance LiDARPointCloud : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud used for DBSCAN clustering"
    DTDFVocab:fromData LiDARPointCloudStream
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance DepthImage : DTDFVocab:Data [
    base:desc "Depth image from Intel D435i used for environmental understanding"
    DTDFVocab:fromData DepthImageStream
    DTDFVocab:inputTo CppRuntimeEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed measurement for ACC computation"
    DTDFVocab:fromData SpeedMeasurementStream
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance VehicleSteeringData : DTDFVocab:Data [
    base:desc "Vehicle steering angle measurement for ACC computation"
    DTDFVocab:fromData SteeringAngleStream
    DTDFVocab:inputTo PythonRuntimeEnabler
]

// Models / Data
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN‑based clustering model for LiDAR point‑cloud segmentation"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter tracking model for object state estimation"
    DTDFVocab:inputTo CppRuntimeEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Feed‑forward ACC control model mapping lead vehicle distance to desired speed"
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance SQLDatabaseSchema : DTDFVocab:Model [
    base:desc "SQL database schema for persisting vehicle state and object tracks"
    DTDFVocab:inputTo DatabaseEnabler
]

instance Rendering3DModel : DTDFVocab:Model [
    base:desc "3D rendering model for visualizing vehicle motion and environment"
    DTDFVocab:inputTo RenderingEnabler
]

// Insights
instance DiagnosticsReport : DTDFVocab:Insight [
    base:desc "Diagnostic report including vehicle speed, steering angle, projected path, and detected object tracks."
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "ACC control decision mapping lead vehicle distance to desired speed."
]

instance DataPersistenceInsight : DTDFVocab:Insight [
    base:desc "Insight into data persistence operations."
]

instance RenderingInsight : DTDFVocab:Insight [
    base:desc "Insight into rendering performance."
]

// Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Initiate emergency braking"
    DTDFVocab:IsAutomatic false
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI that displays real‑time vehicle state, projected trajectory, and detected object tracks, with logging options"
    DTDFVocab:provides DiagnosticsReport
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC algorithm computation to DT, reducing on‑board ECU load"
    DTDFVocab:provides ACCDecisionInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, modify desired speed, and issue emergency braking via UI"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakeAction
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Service for data persistence to the SQL database"
    DTDFVocab:provides DataPersistenceInsight
]

instance RenderingService : DTDFVocab:Service [
    base:desc "Service for 3D rendering runtime"
    DTDFVocab:provides RenderingInsight
]

// Enablers
instance Ros2DDSEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware (DDS) for real‑time topic communication"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService, ComputationOffloadingService
]

instance PythonRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime for ROS2 nodes and algorithm execution"
    DTDFVocab:enables ComputationOffloadingService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for DBSCAN clustering of LiDAR point‑clouds"
    DTDFVocab:enables ComputationOffloadingService
]

instance CppRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "C++ compiled ROS2 packages for low‑level control and tracking"
    DTDFVocab:enables ComputationOffloadingService
]

instance DatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database runtime for data persistence"
    DTDFVocab:enables DataStorageService
]

instance RenderingEnabler : DTDFVocab:Enabler [
    base:desc "OpenGL/Vulkan rendering runtime for 3D visualization"
    DTDFVocab:enables RenderingService
]

// Physical-Acting Components
instance ElectronicSpeedController : DTDFVocab:Component [
    base:desc "Vedder electronic speed controller handling motor voltage commands"
]

instance SteeringServo : DTDFVocab:Component [
    base:desc "Steering servo actuating vehicle direction"
]

instance JetsonOrin : DTDFVocab:Component [
    base:desc "NVIDIA Jetson Orin Nano microcomputer running ROS2"
]

instance JetsonNX : DTDFVocab:Component [
    base:desc "NVIDIA Jetson NX antenna for network communication"
]

// Environment
instance VehicleEnvironment : DTDFVocab:Environment [
    base:desc "Physical twin environment comprising sensors, actuators, and computing units on the 1/10‑scale vehicle"
    base:contains HokuyoLiDAR10LX, IntelD435iDepthCamera, WheelSpeedSensor, SteeringAngleSensor, ElectronicSpeedController, SteeringServo, JetsonOrin, JetsonNX
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT outputs are sent back to the vehicle via Wi‑Fi ROS 2 topics and the Data Translation entity. Control commands include desired speed voltage for the motor controller and steering‑servo position, as well as emergency‑brake instructions and ACC enable/disable signals. The Physical Twin Entity executes these actuation commands through the motor and steering hardware."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT must maintain end‑to‑end latency of ≤ 100 ms (R7) and keep all clocks synchronized to an accuracy of 100 ms (R8); the ACC algorithm runs in real time on the DT with these latency constraints."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation follows ISO 23247’s entity‑based architecture: the Physical Twin Entity hosts sensor acquisition and actuation FEs, the Digital Twin Entity contains data collection, reporting, and ACC control FEs, and the User Entitiy contains visualization and control panel FEs. Inter‑entity communication is orchestrated over a ROS 2 network, with a Data Translation FE mediating serialization and unit conversion. Physical and virtual components run on distributed hardware connected over Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Requirement specification (R1–R8), architectural design mapping to ISO 23247 entities, software implementation of FE packages, integration and testing of the DT, and public release of source code and documentation; this iterative case‑study process reflects the life cycle from design to deployment."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity real‑time simulation of vehicle dynamics, strict latency (≤ 100 ms) constraints, real‑time data capture from sensors, and safety‑critical ACC execution; validity is ensured by aligning with ISO 15622 specifications and operating within the defined latency bounds."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Wireless communication over Wi‑Fi (IEEE 802.11) links the physical twin and the digital twin; within the DT, ROS 2 nodes communicate via DDS; the Data Translation FE mediates serialization, unit conversion, and timestamp alignment across the network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Distributed hosting: the vehicle’s Jetson Orin/NX runs the Physical Twin Entity; the Digital Twin Entity runs on a separate compute box or in the cloud executing ROS 2 packages; the User Entity runs on an operator workstation with 3D visualization; all nodes are packaged and deployed using ROS 2 launch files."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture for DT is adopted and adapted, mapping its Functional Entities to code packages. ACC logic follows ISO 15622 for adaptive cruise control specifications. ROS 2 and NVIDIA Jetpack serve as platform standards, and open‑source ROS packages are used for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety-critical requirements include maintaining ≤ 100 ms latency, enabling emergency braking, and ensuring the system’s real‑time control loop; no explicit cybersecurity measures are described in the document."
]