// C2: Acting Components
instance VedderESCActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller (ESC) receiving velocity set‑points and outputting PWM voltage to drive‑motors"
]
instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo receiving angle set‑points to actuate the steering link"
]

// C3: Physical sensing components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "360° Hokuyo UST‑10LX LiDAR delivering 10 Hz raw point‑cloud data (ISO 23247 compliant)"
    DTDFVocab:producedData HokuyoUST10LXPointCloudData
]
instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera providing RGB‑D imagery at 30 fps for vehicle‑dynamic estimation"
    DTDFVocab:producedData IntelDeepsenseD435IDepthImageData
]
instance VedderESC : DTDFVocab:SensingComponent [
    base:desc "Vedder ESC reporting wheel speed and electrical current (10 Hz sample rate)"
    DTDFVocab:producedData VedderESCWheelSpeedData, VedderESCCurrentData
]
instance VehicleStateComponent : DTDFVocab:SensingComponent [
    base:desc "Component aggregating vehicle speed, heading and steering state"
    DTDFVocab:producedData VehicleStateData
]

// C4: Physical‑to‑virtual interaction
instance HokuyoUST10LXPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]
instance IntelDeepsenseD435IDepthImageData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]
instance VedderESCWheelSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VedderESC
]
instance VedderESCCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VedderESC
]
instance VehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateComponent
]

// C10: Models/Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud aligned with ISO 23247 units"
    DTDFVocab:fromData HokuyoUST10LXPointCloudData
    DTDFVocab:inputTo DataMonitoringEnabler, ComputationOffloadingEnabler
]
instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image from Intel D435i used for vehicle‑dynamic estimation"
    DTDFVocab:fromData IntelDeepsenseD435IDepthImageData
    DTDFVocab:inputTo DataMonitoringEnabler, ComputationOffloadingEnabler
]
instance WheelSpeedData : DTDFVocab:Data [
    base:desc "Wheel speed measurement from Vedder ESC at 10 Hz"
    DTDFVocab:fromData VedderESCWheelSpeedData
    DTDFVocab:inputTo DataMonitoringEnabler, ComputationOffloadingEnabler
]
instance CurrentData : DTDFVocab:Data [
    base:desc "Electrical current draw from Vedder ESC sensor data"
    DTDFVocab:fromData VedderESCCurrentData
    DTDFVocab:inputTo DataMonitoringEnabler, ComputationOffloadingEnabler
]
instance VehicleStateDataRecord : DTDFVocab:Data [
    base:desc "Vehicle speed, heading, and steering state records"
    DTDFVocab:fromData VehicleStateData
    DTDFVocab:inputTo DataMonitoringEnabler
]
instance PointCloudClusteringAndTrackingModel : DTDFVocab:Model [
    base:desc "Real‑time clustering & tracking of LiDAR point‑clouds for object detection"
    DTDFVocab:inputTo DataMonitoringEnabler
]
instance ACCBehavioralModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control behaviour model processing depth‑image data to compute desired speed"
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

// C11: Enablers
instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for Data Monitoring service, handling real‑time telemetry via Wi‑Fi UDP and ROS2 topics"
    DTDFVocab:enables DataMonitoringService
]
instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for Computation Offloading, sending raw sensors to cloud via Wi‑Fi UDP"
    DTDFVocab:enables ComputationOffloadingService
]
instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for Remote Management, issuing control commands over short‑latency Wi‑Fi UDP"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service visualizing real‑time vehicle state, projected path and detected objects"
    DTDFVocab:provides DataVisualizationInsight
]
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service executing ACC routine in the cloud and returning velocity set‑points"
    DTDFVocab:provides ACCCommandAction
]
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service enabling operators to enable/disable ACC, set desired speed and issue emergency braking"
    DTDFVocab:provides EnableAccAction, SetSpeedAction, EmergencyBrakeAction
]

// C17: Insights/Actions
instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of real‑time vehicle telemetry and object bounding boxes"
]
instance ACCCommandAction : DTDFVocab:Action [
    base:desc "Compute desired vehicle speed based on lead‑vehicle distance in ACC routine"
    DTDFVocab:IsAutomatic true
]
instance EnableAccAction : DTDFVocab:Action [
    base:desc "Enable or disable Adaptive Cruise Control via remote command"
    DTDFVocab:IsAutomatic false
]
instance SetSpeedAction : DTDFVocab:Action [
    base:desc "Set desired vehicle speed manually from remote management interface"
    DTDFVocab:IsAutomatic false
]
instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issue emergency braking command immediately"
    DTDFVocab:IsAutomatic false
]

// C17: Environment
instance AutonomousVehicleEnvironment : DTDFVocab:Environment [
]

// Additional System Under Study
instance AutonomousVehicleSystemUnderStudy : DTDFVocab:SystemUnderStudy [
    DTDFVocab:hasEnvironment AutonomousVehicleEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the Control Panel user interface front‑end and are transmitted via the ROS 2 network to the Actuation front‑end. The Actuation component converts the desired speed, motor voltage commands, and steering assist signals into low‑level actuator signals that drive the motor actuation and steering servo actuation hardware. The Data Translation component is again employed to serialize and align the command messages. No explicit authentication, validation, feedback or conflict resolution mechanisms are described in the document."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system enforces a global clock synchronization that guarantees a maximum skew of 100 ms between any device involved in computation offloading and data acquisition. This 100 ms bound satisfies the most stringent requirements of safety‑critical vehicular standards (many of which mandate stricter synchronisation), while remaining achievable given the hardware limitations of the 1/10‑scale vehicle platform. All inter‑component communication is therefore time‑stamped against a unified reference clock with a precision of 100 ms; no finer granularity is specified or required by the documented design."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Architecture follows the ISO 23247 reference architecture for digital twins, with functional entities (FEs) mapped to individual ROS 2 packages. Each package contains one or more ROS 2 nodes that expose specific services such as data preprocessing, point‑cloud clustering, tracking, and actuator control. Entities are logically grouped into: (1) **User Entity** – hosts the singular User Interface FE that is split into a 3D visualization node and a control‑panel node; (2) **Digital Twin Entity** – provides data management, storage, and control logic; (3) **Physical Twin Entity** – implements data pre‑processing, device communication, and automotive‑specific functions (e.g., point‑cloud clustering, tracking). Each entity is deployed on separate hardware components (compute nodes, sensor platforms, actuator controllers), forming a distributed microservices constellation. Coordination between entities is executed via ROS 2 topic, service, and action communication, with time‑synchronization established through shared clock information. Resource management is performed at the node level, with each FE encapsulating compute, sensor, and actuator resources necessary for its role. This constellation ensures that the digital twin services mirror the physical asset, maintain temporal consistency, and support computation offloading across the distributed hardware stack."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin is defined as real‑time and high‑fidelity.  Network latency across the DT components is strictly bounded to a maximum of 100 ms, and all clocks are synchronised to an accuracy of 100 ms (e.g., via GPS or IEEE 1588 Time‑Protocol).  Validation and verification of models are performed by cross‑comparing model predictions with live sensor streams, with any discrepancy triggering error‑detection, correction routines, and uncertainty quantification.  Quality assurance processes include periodic sensor calibration, audit trails for data provenance, and rigorous testing of data‑storage reliability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system’s internal software components communicate through a ROS 2 middleware stack, which routes message packets between sensors, processing modules, and user interfaces. External communication between the vehicle and off‑board systems is carried over a Wi‑Fi network using UDP as the protocol at the transport layer. The document does not specify bandwidth, latency, reliability, or security requirements for these links."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Vehicle‑side (edge) compute hosts the on‑board sensors, the Point Cloud Clustering & Tracking component, the Actuation front‑end, and the on‑board Data Monitoring UI. External storage and reporting are performed by a device outside the vehicle, which receives data from the Vehicle via the Wi‑Fi link and persists them using a SQL database as indicated. The architecture is therefore a hybrid edge‑to‑cloud deployment, with real‑time processing on the vehicle and aggregated data logging and reporting off‑board, but the document does not detail cloud‑specific hosting or scalability provisions."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system conforms to ISO 23247 – Digital Twin Framework for Manufacturing, specifically Part 2 (Reference Architecture). ISO 23247 outlines the expected entities and functional entities required, providing a compliance framework for digital twin realization. Additionally, the reference to OPC Unified Architecture indicates adherence to the OPC UA standard for secure and interoperable data exchange between the Digital Twin Entity, Data Collection/Device Control Entity, and User Entity. No further certification or interoperability standards are explicitly mentioned."
]