// ---------------------------------------------------------------
// Sensing Components
// ---------------------------------------------------------------
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2‑D LiDAR providing range point clouds for perception"
    DTDFVocab:producedData LiDARDataTransmitted
]

instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D images"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance WheelEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel encoder providing vehicle speed and odometry data"
    DTDFVocab:producedData WheelEncoderDataTransmitted
]

instance IMUSensor : DTDFVocab:SensingComponent [
    base:desc "Inertial Measurement Unit supplying orientation and acceleration"
    DTDFVocab:producedData IMUDataTransmitted
]

// ---------------------------------------------------------------
// Data Transmitted (Physical → Virtual)
// ---------------------------------------------------------------
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]

instance WheelEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelEncoderSensor
]

instance IMUDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IMUSensor
]

// ---------------------------------------------------------------
// Raw Data Products (Virtual)
// ---------------------------------------------------------------
instance LiDARRawPointCloudData : DTDFVocab:Data [
    base:desc "Raw point‑cloud stream from the LiDAR (UDP, ROS2 topic /lidar/points)"
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames from the Intel D435i (ROS2 topic /camera/depth)"
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance VehicleSpeedOdometryData : DTDFVocab:Data [
    base:desc "Vehicle speed and odometry derived from wheel encoders"
    DTDFVocab:fromData WheelEncoderDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance InertialMeasurementData : DTDFVocab:Data [
    base:desc "Orientation, angular velocity and linear acceleration from the IMU"
    DTDFVocab:fromData IMUDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

// ---------------------------------------------------------------
// Computational Models
// ---------------------------------------------------------------
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering + Kalman‑filter tracking pipeline for LiDAR point clouds"
    DTDFVocab:inputTo DataStorageEnabler
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "ACC behavioural model consuming vehicle state and object tracks to compute desired speed"
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

// ---------------------------------------------------------------
// Enablers (Middleware & Services)
// ---------------------------------------------------------------
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS‑2 DDS middleware handling real‑time message passing between sensors, models and storage"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Persistent data storage component persisting raw measurements, processed tracks and reports"
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Cloud‑offloading engine executing the ACC model and returning control commands"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementUIEnabler : DTDFVocab:Enabler [
    base:desc "3‑D visualization and control‑panel UI providing operator interaction with the DT"
    DTDFVocab:enables RemoteManagementService
]

// ---------------------------------------------------------------
// Services
// ---------------------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Displays real‑time vehicle state, projected path and detected object tracks allows saving and reporting historic data"
    DTDFVocab:provides RealTimeVehicleStateInsight, SaveHistoricReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes the ACC algorithm on the digital twin (cloud) and returns desired speed for actuation"
    DTDFVocab:provides EnableACCAction, SetTargetSpeedAction, EmergencyBrakeAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set target speed and issue emergency braking via the UI"
    DTDFVocab:provides EnableACCAction, SetTargetSpeedAction, EmergencyBrakeAction
]

// ---------------------------------------------------------------
// Insights & Actions
// ---------------------------------------------------------------
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current vehicle dynamics and environment derived from sensor fusion"
]

instance SaveHistoricReportAction : DTDFVocab:Action [
    base:desc "Action to generate, save and export a historic report of vehicle state and ACC performance"
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable the Adaptive Cruise Control function remotely"
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Action to set a desired cruising speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to trigger an immediate emergency braking command"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the digital twin are issued to the physical twin through the Actuation functional entity (FE). The ACC Controlling FE computes a desired speed based on lead‑vehicle detection and sends a speed command, while remote‑management functions (enable/disable ACC, set desired speed, emergency‑brake) are also transmitted. Commands are serialized by the Data Translation FE and transmitted over the same Wi‑Fi UDP channel used for sensor data. Upon receipt, the Actuation FE drives the motor and steering‑servo to realise the commanded actions. Explicit acknowledgement or confirmation of command execution is not detailed in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin requires a shared notion of time across devices; synchronization accuracy of 100 ms is mandated (hardware‑limited) and complies with safety‑critical vehicular standards that often demand tighter (<100 ms) sync. This 100 ms bound governs the coordination needed for computation off‑loading between the physical and digital components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration is built on the ISO 23247 reference architecture; software components are mapped to Functional Entities and each FE is packaged as an individual ROS 2 package containing one or more ROS 2 nodes. Communication and coordination among the three entities occur via ROS 2 middleware, allowing distributed execution across heterogeneous compute resources."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The architecture requires that all devices share a common notion of time with a synchronization accuracy of 100 ms, as stated: many standards mandate stricter clock synchronization than 100 ms for safety‑critical vehicular applications, but the system limits to 100 ms accuracy due to hardware limitations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS employs a two‑layer network architecture. Internally, software components exchange messages on a ROS2 (DDS) network, providing publish‑subscribe communication within the digital environment. Communication between the physical twin and the digital twin occurs over a Wi‑Fi network using UDP at the transport layer. The system is required to support low end‑to‑end latency to satisfy safety‑critical ACC operation, although specific latency or bandwidth figures are not provided. No explicit reliability, redundancy, or security protocols are described in the supplied material."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "ACC computation is offloaded from the vehicle’s resource‑constrained ECU to the Digital Twin, which can run on cloud resources as indicated by the statement that computation is allocated to 'better‑suited equipment, e.g., in the cloud.' No further details on the hosting platform, computational or storage capacity, scalability mechanisms, deployment models, or availability guarantees are given in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability follows ISO 23247 part 2 and may employ standards such as OPC Unified Architecture for data exchange, although the present implementation uses ROS 2 topics/services. The design therefore supports integration with external enterprise systems or other digital twins through OPC UA or ROS 2 bridges, aligning with the standard’s information‑exchange guidelines."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system is built on the ISO 23247 Digital Twin framework for manufacturing. Specifically, Part 2 of ISO 23247, which defines the entity‑based reference architecture (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity) is used as the primary design basis. The implementation follows the ISO‑defined entities but introduces a Physical Twin Entity that extends the standard’s OME concept. Functional Entities are instantiated as ROS 2 packages, aligning with the standard’s allowance for arbitrary FE implementation (e.g., OPC UA, ROS 2). The design acknowledges deviations from the ISO model and notes their impact on ownership and engineering processes."
]