// C3: Physical sensing components
instance HokuyoUst10LxLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing 2‑D point‑cloud scans at up to 40 Hz"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering RGB‑D frames via ROS2"
    DTDFVocab:producedData DepthImageTransmitted
]

instance ChassisEgoSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of vehicle forward speed from chassis electronics"
    DTDFVocab:producedData EgoSpeedTransmitted
]

instance ChassisSteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of steering wheel angle from chassis electronics"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUst10LxLiDAR
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

instance EgoSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChassisEgoSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChassisSteeringAngleSensor
]

// C10: Data instances
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw point‑cloud data stream from the LiDAR"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataCollectionFunctionalEntity
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames from the Intel D435i camera"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo DataCollectionFunctionalEntity
]

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed in m/s"
    DTDFVocab:fromData EgoSpeedTransmitted
    DTDFVocab:inputTo DataCollectionFunctionalEntity
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering wheel angle in degrees"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo DataCollectionFunctionalEntity
]

// C11: Enablers (Functional Entities)
instance DataCollectionFunctionalEntity : DTDFVocab:Enabler [
    base:desc "Aggregates incoming sensor streams, performs unit conversion, and forwards to processing FEs"
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationFunctionalEntity : DTDFVocab:Enabler [
    base:desc "Serializes and performs unit conversion for ROS2 messages"
    DTDFVocab:enables DataMonitoringService
]

instance ObjectClusteringModelEnabler : DTDFVocab:Enabler [
    base:desc "Executes DBSCAN clustering on LiDAR point clouds"
    DTDFVocab:enables ComputationOffloadingService
]

instance ObjectTrackingModelEnabler : DTDFVocab:Enabler [
    base:desc "Runs Kalman‑filter based multi‑object tracking on clustered points"
    DTDFVocab:enables ComputationOffloadingService
]

instance ACCComputationFunctionalEntity : DTDFVocab:Enabler [
    base:desc "Computes Adaptive Cruise Control speed set‑point following ISO‑15622 logic"
    DTDFVocab:enables ComputationOffloadingService
]

instance ActuationFunctionalEntity : DTDFVocab:Enabler [
    base:desc "Translates speed and steering decisions into voltage/angle commands for actuators"
    DTDFVocab:enables RemoteManagementService
]

instance UIVisualizationFunctionalEntity : DTDFVocab:Enabler [
    base:desc "Generates real‑time 3‑D visualizations and UI dashboards for operators"
    DTDFVocab:enables DataMonitoringService
]

instance ReportingFunctionalEntity : DTDFVocab:Enabler [
    base:desc "Stores vehicle state, tracks, and ACC decisions in a SQL database for post‑mission analysis"
    DTDFVocab:enables DataMonitoringService
]

// C10: Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering module for object hypothesis generation"
    DTDFVocab:inputTo ObjectClusteringModelEnabler
]

instance KalmanFilterTrackerModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based object tracker yielding trajectory estimates"
    DTDFVocab:inputTo ObjectTrackingModelEnabler
]

instance ACCControlModelISO15622 : DTDFVocab:Model [
    base:desc "ACC control model implementing ISO 15622 longitudinal control logic"
    DTDFVocab:inputTo ACCComputationFunctionalEntity
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model rendering vehicle state, object tracks, and projected path"
    DTDFVocab:inputTo UIVisualizationFunctionalEntity
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI visualization, reporting and storage of vehicle state"
    DTDFVocab:provides RealTimeVehicleStateInsight
    DTDFVocab:provides ACCDecisionInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes the ACC algorithm on external compute and returns the computed speed"
    DTDFVocab:provides ComputeSpeedDecisionAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Provides UI controls to enable/disable ACC, adjust set‑point speed, and issue emergency brake"
    DTDFVocab:provides EnableACCAction
    DTDFVocab:provides AdjustSetPointSpeedAction
    DTDFVocab:provides EmergencyBrakeAction
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Operator view of live speed, steering angle, object tracks and projected path"
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "Desired speed decision produced by the ACC algorithm"
]

// C17: Actions
instance ComputeSpeedDecisionAction : DTDFVocab:Action [
    base:desc "Automatic computation of target speed based on ACC logic"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance AdjustSetPointSpeedAction : DTDFVocab:Action [
    base:desc "Operator adjusts the ACC set‑point speed"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers immediate vehicle stop"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller receiving voltage commands to regulate vehicle speed"
]

instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Steering servo receiving angle commands for wheel direction control"
]

// C1: Environment (physical vehicle)
instance AutonomousVehicleEnvironment : DTDFVocab:Environment [
    base:contains HokuyoUst10LxLiDAR, IntelDeepSenseD435iDepthCamera,
               ChassisEgoSpeedSensor, ChassisSteeringAngleSensor,
               VedderElectronicSpeedController, SteeringServo
]

// C0: Component (physical chassis)
instance TraxxasSlashChassis : DTDFVocab:Component [
    base:desc "1/10‑scale Traxxas Slash 4x4 chassis retrofitted with NVIDIA Jetson NX antenna, Jetson Orin Nano MCU, and the listed sensors/actuators"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends desired speed commands, ACC enable/disable signals, modified speed set-points, and emergency braking commands back to the PT through the Actuation FE, which translates them into motor voltage and steering servo signals."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All DT-PT interactions are bounded by a maximum end-to-end latency of 100 ms and the distributed components maintain clock synchronization within 100 ms, satisfying real-time requirements for ACC."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates the Physical Twin Entity (sensors, actuators), the Digital Twin Entity (data collection, ACC, reporting, visualization) and the User Entity (UI panels), communicating intra-entity via ROS 2 and inter-entity over Wi-Fi using the standardized interface defined in requirement R1."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during design (cyber-physical experimentation), testing, deployment, and runtime operation for monitoring, validation and remote control of the ACC function."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High-fidelity interaction is ensured by maintaining ≤100 ms latency, synchronized clocks, real-time sensor sampling, and adherence to ISO 15622 ACC specifications; the DT stores raw and processed data for offline validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication uses ROS 2 topics for intra-entity data exchange and Wi‑Fi (IP-based) for inter-entity links; a standardized communication interface (R1) and the Data Translation FE perform serialization, type alignment and unit conversion."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity and User Entity run on external compute (e.g., a workstation or cloud server) separate from the on-board Jetson devices that host the Physical Twin Entity; each Functional Entity is packaged as an independent ROS 2 node."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system follows ISO 23247 reference architecture, utilizes ISO/IEC 30173 terminology, implements ACC logic per ISO 15622, and aligns latency requirements with 3GPP TS 22.185 (V2V) specifications."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations include the 100 ms latency bound, 100 ms clock synchronization, and adherence to ISO 15622 ACC safety class I; remote commands are mediated through the User Interface FE to prevent unsafe actuation, but explicit security mechanisms are not described."
]