// C1: Acting Components
instance MotorActuationFeature : DTDFVocab:ActingComponent [
    base:desc "Converts desired speed into motor voltage commands via Vedder Electronic Speed Controller, deployed on NVIDIA Jetson Orin Nano"
]

instance SteeringServo : DTDFVocab:Actuator [
    base:desc "Adjusts steering angle for autonomous vehicle control, implemented on NVIDIA Jetson Orin Nano"
]

instance AdaptiveCruiseControlFeature : DTDFVocab:ActingComponent [
    base:desc "Implements ISO 15622-based performance-class I adaptive cruise control logic for distance-based speed adjustments, running on NVIDIA Jetson Orin Nano"
]

// C2: Physical Sensing Components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing point cloud data for object detection in 3D environment"
]

instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i Depth Camera supporting 3D perception with stereo vision capabilities"
]

instance OnboardSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor measuring ego vehicle speed for real-time state monitoring"
]

instance OnboardSteeringSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor tracking ego vehicle steering angle for control feedback"
]

// C3: Produced Data from Sensing Components
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthCameraData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]

instance EgoSpeedTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OnboardSpeedSensor
]

instance SteeringAngleTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OnboardSteeringSensor
]

// C4: Data Storage and Processing
instance PointCloudClusteringData : DTDFVocab:Data [
    base:desc "Processed point cloud data from LiDAR using DBSCAN clustering for object detection"
    DTDFVocab:fromData LiDARPointCloudData
    DTDFVocab:inputTo DataCollectionService
]

instance KalmanFilteredTracks : DTDFVocab:Data [
    base:desc "Object tracks generated via Kalman filter processing of point cloud data"
    DTDFVocab:fromData PointCloudClusteringData
    DTDFVocab:inputTo DataCollectionService
]

instance EgoVehicleStateData : DTDFVocab:Data [
    base:desc "Real-time ego vehicle state combining speed and steering angle telemetry"
    DTDFVocab:fromData EgoSpeedTelemetry, SteeringAngleTelemetry
    DTDFVocab:inputTo DataCollectionService
]

instance HistoricalDataArchive : DTDFVocab:Data [
    base:desc "SQL database storing historical ego vehicle state and object track data for analysis"
    DTDFVocab:inputTo ReportingService
]

// C5: Models
instance Vehicle3DCADModel : DTDFVocab:Model [
    base:desc "3D CAD-based visualization of autonomous vehicle chassis and environment for real-time rendering"
    DTDFVocab:inputTo VisualizationService
]

instance LiDARPointCloudModel : DTDFVocab:Model [
    base:desc "Sensor model implementing DBSCAN clustering and Kalman filter for object detection from LiDAR data"
    DTDFVocab:inputTo DataCollectionService
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "ISO 15622-based performance-class I adaptive cruise control logic implementation"
    DTDFVocab:inputTo ControlProcessingEnabler
]

// C6: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "Robot Operating System 2 middleware enabling real-time inter-component communication via topics/topics"
    DTDFVocab:enables DataCollectionService, VisualizationService
]

instance NVIDIAJetpackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for software development on NVIDIA Jetson Orin Nano platform"
    DTDFVocab:enables ControlProcessingEnabler, DataCollectionService
]

instance PythonPrototyping : DTDFVocab:Enabler [
    base:desc "Python 3.8 environment for rapid prototyping of ROS2 nodes and data processing"
    DTDFVocab:enables DataCollectionService
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for complex systems modeling including point cloud processing"
    DTDFVocab:enables LiDARPointCloudModel
]

instance ROS2Visualization : DTDFVocab:Enabler [
    base:desc "ROS2-based 3D visualization framework for real-time rendering of vehicle and environment"
    DTDFVocab:inputTo Vehicle3DCADModel
    DTDFVocab:enables VisualizationService
]

instance WiFiDataTransmission : DTDFVocab:Enabler [
    base:desc "Wi-Fi network infrastructure for transmitting real-time data streams (100ms latency) between physical twin and digital twin entity"
    DTDFVocab:inputTo DataCollectionService
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "External SQL database for storing historical data (ego vehicle state and object tracks) for reporting and analysis"
    DTDFVocab:inputTo ReportingService
]

// C7: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of ego vehicle speed, steering angle, object tracks, and projected driving path via 3D visualization"
    DTDFVocab:provides RealTimeVisualizationInsight, HistoricalAnalysisInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC control logic from vehicle ECU to digital twin entity for real-time processing on NVIDIA Jetson Orin Nano"
    DTDFVocab:provides ControlLogicExecutionAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to enable/disable ACC, set desired speed, and trigger emergency braking via control panel UI"
    DTDFVocab:provides UserControlAction
]

instance DataCollectionService : DTDFVocab:Service [
    base:desc "Collects real-time telemetry data from physical twin via ROS2 middleware for digital twin processing"
    DTDFVocab:provides SensorDataStreamingAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides 3D visualization interface for real-time rendering of vehicle and environment"
    DTDFVocab:provides InteractiveVisualizationAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Generates historical reports from stored data for performance analysis and predictive maintenance"
    DTDFVocab:provides PerformanceReportAction
]

// C8: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time 3D visualization of ego vehicle speed, steering angle, object tracks, and projected driving path"
]

instance HistoricalAnalysisInsight : DTDFVocab:Insight [
    base:desc "Historical data analysis for brake system and motor health monitoring via SQL database reports"
]

instance ControlLogicExecutionAction : DTDFVocab:Action [
    base:desc "Executes ISO 15622-based ACC control logic on NVIDIA Jetson Orin Nano for adaptive speed adjustments"
    DTDFVocab:IsAutomatic true
]

instance UserControlAction : DTDFVocab:Action [
    base:desc "Allows operators to enable/disable ACC, set desired speed, or trigger emergency braking via control panel UI"
    DTDFVocab:IsAutomatic false
]

instance SensorDataStreamingAction : DTDFVocab:Action [
    base:desc "Transmits real-time sensor data (100ms latency) from physical twin to digital twin entity via ROS2 middleware"
    DTDFVocab:IsAutomatic true
]

instance InteractiveVisualizationAction : DTDFVocab:Action [
    base:desc "Enables interactive 3D visualization of autonomous vehicle environment and state"
    DTDFVocab:IsAutomatic false
]

instance PerformanceReportAction : DTDFVocab:Action [
    base:desc "Generates performance reports from historical data for predictive maintenance and troubleshooting"
    DTDFVocab:IsAutomatic false
]

// C9: Physical Twin Entity Components
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Customized entity for automotive systems containing Data Pre-Processing FE, Actuation FE, and Point Cloud Clustering & Tracking FE"
    base:contains MotorActuationFeature, SteeringServo, AdaptiveCruiseControlFeature,
        HokuyoLiDAR, IntelDepthCamera, OnboardSpeedSensor, OnboardSteeringSensor,
        LiDARPointCloudData, DepthCameraData, EgoSpeedTelemetry, SteeringAngleTelemetry,
        PointCloudClusteringData, KalmanFilteredTracks, EgoVehicleStateData
]

// C10: Digital Twin Entity Components
instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Primary Digital Twin Entity hosting Data Collection FE, Reporting FE, and Presentation FE"
    base:contains DataCollectionService, ReportingService, VisualizationService,
        ROS2Middleware, NVIDIAJetpackSDK, PythonPrototyping, MATLABSimulink,
        WiFiDataTransmission, SQLDatabase
]

// C11: User Entity Components
instance UserEntity : DTDFVocab:Component [
    base:desc "Handles user interactions including 3D Visualization and Control Panel"
    base:contains ROS2Visualization, RemoteManagementService
]

// C12: Environment
instance ControlProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for control processing logic enabling ACC control execution"
    DTDFVocab:enables ComputationOffloadingService
]

instance AutonomousVehicleEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity, DigitalTwinEntity, UserEntity,
        Vehicle3DCADModel, LiDARPointCloudModel, AdaptiveCruiseControlModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The virtual-to-physical interaction occurs through the **ACC Controlling FE** and **Actuation FE**, implementing ISO 15622-based control logic. The DT computes desired speed based on lead vehicle distance and transmits commands via ROS2 topics to the NVIDIA Jetson Orin Nano, which forwards motor voltage commands to the **Vedder Electronic Speed Controller** and steering servo. Emergency braking commands are sent directly to the vehicle’s actuators. Synchronization ensures <100 ms end-to-end latency."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates on a **real-time time-scale** with strict synchronization requirements: **end-to-end latency ≤ 100 ms** (compliant with 3GPP V2V communication standards), and **clock synchronization accuracy ≤ 100 ms** (due to hardware constraints). Data collection and processing rates are aligned with perception cycles (e.g., LiDAR object tracking updates at ~10–20 Hz), ensuring temporal coherence between physical and virtual states."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is organized as a **multi-layered entity-based architecture** inspired by ISO 23247 but adapted for automotive systems. Key components include: **Physical Twin Entity** (hosts sensor/actuator-specific logic), **Digital Twin Entity** (manages data collection, reporting, and visualization), and **User Entity** (splitted into **3D Visualization** and **Control Panel**). The **Data Translation FE** ensures inter-entity communication via standardized ROS2 message types. The DTS is deployed across **onboard hardware (Jetson Orin Nano)** and **cloud-based storage** for remote management."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans **three lifecycle stages**: **1) Design Phase** (simulator-based prototyping using MATLAB/Simulink for complex systems like point cloud clustering), **2) Manufacturing Phase** (hardware retrofitting of a 1/10th-scale autonomous vehicle with autonomy components), and **3) Operational Phase** (real-time monitoring, remote management, and predictive maintenance via DT services). The DT covers the **as-operated** representation phase of the physical twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured through: **1) Sensor Calibration**: LiDAR and depth camera data are pre-processed via DBSCAN/Kalman filter to mitigate noise. **2) Real-Time Synchronization**: Clock synchronization (±100 ms) via NTP or ROS2 time synchronization. **3) Validation Mechanisms**: ISO 15622-based ACC compliance testing, real-time latency validation (<100 ms), and remote management demonstrations. Uncertainty is managed via **Data Translation FE** for unit conversions and **Reporting FE** for historical analysis. Verification includes ROS2 node lifecycle testing and edge computing constraints."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT employs **Wi-Fi-based communication** (UDP/ROS2 topics) for inter-entity communication between the vehicle (ROS2 network) and the DT Entity (cloud-based). **Network Protocols**: ROS2 (for intra-vehicle communication) and Wi-Fi (for inter-entity communication). **Latency Requirements**: <100 ms end-to-end latency (3GPP V2V compliance). **Security**: No explicit security protocols mentioned; assumes ROS2-based trust models for automotive safety-critical systems."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed across **two hardware layers**: **1) Onboard Hardware**: NVIDIA Jetson Orin Nano (hosts Physical Twin Entity, Data Pre-Processing FE, Actuation FE). **2) Cloud-Based Hosting**: External SQL database for data storage and **Data Collection FE** (offloads ACC computation). The **User Entity** (3D Visualization/Control Panel) is accessible via web interfaces or ROS2-based dashboards. Deployment follows ROS2 package-based modularity for maintainability."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT integrates horizontally with **external systems** via ROS2 middleware for inter-vehicle communication (e.g., V2V coordination). It also connects to **3D CAD design tools** (e.g., MATLAB/Simulink) for simulation-based development. No explicit mention of integration with external DTs or enterprise systems (e.g., PLM tools) is provided."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership is **shared**: The **physical twin owner** controls sensor data (LiDAR, cameras), while the **DT service provider** manages processed data (e.g., object tracks, reports) stored in an external SQL database. Privacy considerations are implicit: real-time data streams are secured via ROS2-based trust models, but no explicit encryption (e.g., TLS) or access controls are described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT adheres to the following standards: **1) ISO 23247**: Reference architecture (entity-based design, Data Translation FE). **2) ISO 15622**: ACC control logic specification (performance-class I). **3) ROS2**: Middleware for inter-component communication. **4) 3GPP 22.185**: Latency requirements for V2V communication (<100 ms). Custom adaptations include the **Physical Twin Entity** (not defined in ISO 23247) and ROS2-based deployment."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety are addressed via: **1) Safety-Critical Requirements**: <100 ms latency (3GPP compliance), clock synchronization (±100 ms), and ISO 15622-based ACC validation. **2) Trust Models**: ROS2-based communication assumes secure inter-vehicle trust (no explicit encryption). **3) Remote Operations**: Emergency braking commands are sent directly to actuators, ensuring human-in-the-loop safety. **4) Data Integrity**: Data Translation FE ensures unit conversions and message alignment to prevent malformed commands. No mention of cybersecurity frameworks (e.g., ISO 27001) or intrusion detection."
]