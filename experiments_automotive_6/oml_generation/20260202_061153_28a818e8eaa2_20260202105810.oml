// C3: Physical Sensing Components
instance EgoSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Speed sensor integrated with the ESC providing ego-vehicle speed telemetry."
    DTDFVocab:producedData EgoSpeedTS
]

instance EgoSteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor capturing the vehicle's steering input."
    DTDFVocab:producedData EgoSteeringAngleTS
]

instance HokuyoLidarSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR generating 3D point clouds for environmental perception."
    DTDFVocab:producedData LiDARPointCloudTS
]

instance IntelDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera supplying RGB‑D frames for point cloud generation."
    DTDFVocab:producedData DepthCameraFrameTS
]

instance ObjectTrackSensor : DTDFVocab:SensingComponent [
    base:desc "Object track processor generating size, position, and velocity tracks from LiDAR and depth data."
    DTDFVocab:producedData ObjectTrackTS
]

// C4: Physical‑to‑Virtual Interaction – Data Transmitted
instance EgoSpeedTS : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoSpeedSensor
]

instance EgoSteeringAngleTS : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoSteeringAngleSensor
]

instance LiDARPointCloudTS : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLidarSensor
]

instance DepthCameraFrameTS : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCameraSensor
]

instance ObjectTrackTS : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ObjectTrackSensor
]

// C4: Virtual Data
instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Ego-vehicle speed data as a numerical value."
    DTDFVocab:fromData EgoSpeedTS
    DTDFVocab:inputTo ROS2Middleware
]

instance EgoSteeringAngleData : DTDFVocab:Data [
    base:desc "Ego steering angle data as a numerical value."
    DTDFVocab:fromData EgoSteeringAngleTS
    DTDFVocab:inputTo ROS2Middleware
]

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "3D LiDAR point cloud data."
    DTDFVocab:fromData LiDARPointCloudTS
    DTDFVocab:inputTo MATLABSimulink
]

instance DepthCameraFrameData : DTDFVocab:Data [
    base:desc "RGB‑D frame from depth camera."
    DTDFVocab:fromData DepthCameraFrameTS
    DTDFVocab:inputTo MATLABSimulink
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Object track data including size, position, velocity."
    DTDFVocab:fromData ObjectTrackTS
    DTDFVocab:inputTo ROS2Middleware
]

// C10: Models / Data
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm applied on LiDAR point cloud data to detect objects."
    DTDFVocab:inputTo MATLABSimulink
]

instance KalmanFilterModel : DTDFVocab:Model [
    base:desc "Kalman filter used for estimating object tracks from processed point cloud."
    DTDFVocab:inputTo MATLABSimulink
]

instance VisualizationModel : DTDFVocab:Model [
    base:desc "3D rendering engine generating visualizations of vehicle and tracks."
    DTDFVocab:inputTo UI3DEngine
]

instance SQLPersistenceModel : DTDFVocab:Model [
    base:desc "SQL database persistence model storing ego state and object tracks."
    DTDFVocab:inputTo SQLDatabase
]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware facilitating communication between on‑board PT assembly and cloud DT services."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, VisualizationService, ReportGenerationService
]

instance NVIDIAJetPack5 : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK providing system libraries on Jetson Orin Nano."
]

instance PythonCPPNode : DTDFVocab:Enabler [
    base:desc "Python 3.8/C++ ROS2 nodes implementing data handling and computation."
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink platform used for complex processing such as clustering and tracking."
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL database for persistent storage of telemetry and track data."
]

instance UI3DEngine : DTDFVocab:Enabler [
    base:desc "3D engine used to render vehicle and environment for the UI."
]

instance RemoteManagementUI : DTDFVocab:Enabler [
    base:desc "UI enabling operators to adjust ACC settings and issue emergency brake."
    DTDFVocab:enables RemoteManagementService
]

// C2: Acting Components
instance SpeedActuatorComponent : DTDFVocab:ActingComponent [
    base:desc "Actuation FE converting DT desired speed into motor voltage commands directed to the ESC for throttle control."
]

instance SteeringActuatorComponent : DTDFVocab:ActingComponent [
    base:desc "Actuation FE translating DT steering angle commands into physical steering actuator signals."
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service that displays real‑time vehicle state, projected path, and detected tracks, saves data, and generates time‑series reports."
    DTDFVocab:provides VehicleStateReportingInsight, ObjectTrackReportingInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service that offloads ACC control logic to the DT, computing lead vehicle, desired speed, and sending commands back."
    DTDFVocab:provides ACCControlAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service allowing operators to enable/disable ACC, adjust desired speed, and issue emergency braking via the UI."
    DTDFVocab:provides AdjustDesiredSpeedAction, ToggleACCAction, EmergencyBrakeAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that renders 3D visualization of vehicle and surrounding object tracks."
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Service that generates human-readable reports of tracks and state."
    DTDFVocab:provides ReportGenerationInsight
]

// C17: Insights
instance VehicleStateReportingInsight : DTDFVocab:Insight [
    base:desc "Insight providing continuous reporting of vehicle state."
]

instance ObjectTrackReportingInsight : DTDFVocab:Insight [
    base:desc "Insight providing continuous reporting of detected object tracks."
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight delivering human-readable reports of tracks and state."
]

// C17: Actions
instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action enabling operators to remotely adjust desired speed on the ACC system."
    DTDFVocab:IsAutomatic false
]

instance ToggleACCAction : DTDFVocab:Action [
    base:desc "Action enabling operators to enable or disable the ACC feature."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action enabling operators to issue an emergency braking command via the UI."
    DTDFVocab:IsAutomatic false
]

instance ACCControlAction : DTDFVocab:Action [
    base:desc "Action representing ACC computed desired speed and steering commands sent back from DT to vehicle."
    DTDFVocab:IsAutomatic true
]

// Environment tying all components together
instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains EgoSpeedSensor, EgoSteeringAngleSensor, HokuyoLidarSensor, IntelDepthCameraSensor, ObjectTrackSensor,
    EgoSpeedTS, EgoSteeringAngleTS, LiDARPointCloudTS, DepthCameraFrameTS, ObjectTrackTS,
    EgoSpeedData, EgoSteeringAngleData, LiDARPointCloudData, DepthCameraFrameData, ObjectTrackData,
    DBSCANClusteringModel, KalmanFilterModel, VisualizationModel, SQLPersistenceModel,
    ROS2Middleware, NVIDIAJetPack5, PythonCPPNode, MATLABSimulink, SQLDatabase, UI3DEngine, RemoteManagementUI,
    SpeedActuatorComponent, SteeringActuatorComponent,
    DataMonitoringService, ComputationOffloadingService, RemoteManagementService, VisualizationService, ReportGenerationService,
    VehicleStateReportingInsight, ObjectTrackReportingInsight, ReportGenerationInsight,
    AdjustDesiredSpeedAction, ToggleACCAction, EmergencyBrakeAction, ACCControlAction
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT outputs include desired speed commands and emergency braking instructions dispatched to the physical vehicle. The Physical Twin Entity contains the Actuation FE that converts these commands into motor voltage and steering servo signals sent back to the PT over the same Wi‑Fi / ROS 2 link, allowing remote acceleration, deceleration, or braking of the ego vehicle."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with a maximum permissible end‑to‑end latency of 100 ms between PT and DT, and clock synchronization accuracy of 100 ms across devices. LiDAR processing and ACC inference operate at the sensor’s native update rate (≈10–20 Hz), ensuring timely decision making."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "ISO 23247 entity‑based architecture instantiated with a Physical Twin Entity, Digital Twin Entity, and User Entity. The Physical Twin Entity hosts sensor interfaces and actuation FEs; the Digital Twin Entity contains data collection, processing, and ACC control FEs; the User Entity provides UI FEs (3D visualization and control panel). Data Translation FE bridges formats across entities. Communication occurs over Wi‑Fi using ROS 2 topics and services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design – vehicle retrofitting, component selection; Development – requirement definition, architecture mapping to ISO 23247, implementation of FE packages; Deployment – publishing ROS 2 services on vehicle and cloud; Operability – real‑time operation of ACC, remote management, data monitoring; Maintenance – periodic updates to FE logic, sensor calibration, and UI enhancements."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time, high‑fidelity operation; safety‑critical compliance with ISO 15622 ACC specification (performance class I); end‑to‑end latency ≤ 100 ms; clock synchronization to ± 100 ms for event ordering; verification via adherence to the ISO 23247 RA and runtime checks during ACC execution."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical and virtual tiers connected via a Wi‑Fi network leveraging ROS 2’s DDS‑over‑IP communication. The Data Translation FE serializes messages and performs unit conversions before transmission. End‑to‑end latency measured at ≤100 ms, satisfying 3GPP V2V TS 22.185 requirements."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "On‑board deployment of sensor interfaces, data collection, and actuation FE on NVIDIA Jetson Orin Nano; cloud/edge compute hosts the Digital Twin Entity FEs (ACC logic, data storage, visualization) running on Docker containers or native processes; operator UI hosted locally (desktop or web) or remotely. Deployment follows ISO 23247 layered architecture with each interface encapsulated in ROS 2 packages."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture adopted as the core design; ACC implementation aligned with ISO 15622; data translation relies on standard ROS 2 and potential OPC UA; sensors follow industry specifications (Hokuyo, Intel D435i)."
]