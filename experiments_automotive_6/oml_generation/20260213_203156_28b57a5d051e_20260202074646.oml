// Sensors
instance LiDARUST10LXSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR sensor mounted on vehicle capturing point clouds"
    DTDFVocab:producedData LiDARPointCloudTransmission
]

instance DepthCameraD435iSensor : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera mounted for environment perception"
    DTDFVocab:producedData DepthImageTransmission
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor measuring real-time speed"
    DTDFVocab:producedData VehicleSpeedTransmission
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor providing real-time steering angle data"
    DTDFVocab:producedData SteeringAngleTransmission
]

// Data transmitted
instance LiDARPointCloudTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARUST10LXSensor
]

instance DepthImageTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DepthCameraD435iSensor
]

instance VehicleSpeedTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Point cloud data captured by LiDAR sensor"
    DTDFVocab:fromData LiDARPointCloudTransmission
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image data captured by Intel D435i camera"
    DTDFVocab:fromData DepthImageTransmission
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed data sampled from speed sensor"
    DTDFVocab:fromData VehicleSpeedTransmission
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle data sampled from steering angle sensor"
    DTDFVocab:fromData SteeringAngleTransmission
    DTDFVocab:inputTo PythonRuntimeEnabler
]

// Models
instance DBSCANPointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point cloud clustering for object segmentation"
    DTDFVocab:inputTo PythonRuntimeEnabler, JetPackSDKEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking of detected objects"
    DTDFVocab:inputTo PythonRuntimeEnabler, MATLABSimulinkRuntimeEnabler
]

instance ACCControlAlgorithmModel : DTDFVocab:Model [
    base:desc "ACC control algorithm providing cruise control commands"
    DTDFVocab:inputTo ROS2MiddlewareEnabler, PythonRuntimeEnabler
]

// Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware enabling communication between vehicle and cloud components"
    DTDFVocab:enables DataMonitoringAndReportingService, ACCComputationOffloadService, ACCRemoteManagementService, Vehicle3DVisualizationService
]

instance JetsonHardwareEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetson NX/Orin hardware hosting on vehicle for computing"
    DTDFVocab:enables DataMonitoringAndReportingService, ACCComputationOffloadService, ACCRemoteManagementService, Vehicle3DVisualizationService
]

instance JetPackSDKEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack SDK providing drivers and libraries for Jetson"
    DTDFVocab:enables DataMonitoringAndReportingService, ACCComputationOffloadService, ACCRemoteManagementService, Vehicle3DVisualizationService
]

instance PythonRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime environment for data processing and model execution"
    DTDFVocab:enables DataMonitoringAndReportingService, ACCComputationOffloadService, ACCRemoteManagementService, Vehicle3DVisualizationService
]

instance CppRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "C++ runtime environment for performance-critical modules"
    DTDFVocab:enables DataMonitoringAndReportingService, ACCComputationOffloadService, ACCRemoteManagementService, Vehicle3DVisualizationService
]

instance MATLABSimulinkRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink runtime environment for model-based design"
    DTDFVocab:enables DataMonitoringAndReportingService, ACCComputationOffloadService, ACCRemoteManagementService, Vehicle3DVisualizationService
] // TODO: Fix the error on this line using the following error message: 'Couldn't resolve reference to NamedInstance 'V'.' | TODO: Fix the error on this line using the following error message: 'Couldn't resolve reference to SemanticProperty 'cial3DVisualizationService'.'

instance OPCUAEnabler : DTDFVocab:Enabler [
    base:desc "OPC UA protocol for data exchange (optional)"
    DTDFVocab:enables DataMonitoringAndReportingService, ACCComputationOffloadService, ACCRemoteManagementService, Vehicle3DVisualizationService
]

instance DataTranslationFEEnabler : DTDFVocab:Enabler [
    base:desc "Custom Data Translation Front-End converting ROS messages to SQL database format"
    DTDFVocab:enables DataMonitoringAndReportingService, ACCComputationOffloadService, ACCRemoteManagementService, Vehicle3DVisualizationService
]

// Services
instance DataMonitoringAndReportingService : DTDFVocab:Service [
    base:desc "Service providing real-time monitoring and reporting of vehicle telemetry"
    DTDFVocab:provides DataMonitoringInsight
]

instance ACCComputationOffloadService : DTDFVocab:Service [
    base:desc "Service offloading ACC algorithm computation to remote server"
    DTDFVocab:provides ACCStatusInsight
]

instance ACCRemoteManagementService : DTDFVocab:Service [
    base:desc "Service enabling remote management of ACC settings"
    DTDFVocab:provides EnableACCAction, AdjustDesiredSpeedAction, InitiateEmergencyBrakeAction
]

instance Vehicle3DVisualizationService : DTDFVocab:Service [
    base:desc "Service rendering 3D visualization of vehicle and environment"
    DTDFVocab:provides VehicleVisualizationInsight
]

// Insights
instance DataMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight for real-time monitoring of vehicle telemetry and environmental data"
]

instance ACCStatusInsight : DTDFVocab:Insight [
    base:desc "Insight into ACC status enabling enable/disable decisions"
]

instance VehicleVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight visualizing vehicle position and surroundings in 3D"
]

// Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable or disable Adaptive Cruise Control system"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to adjust desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance InitiateEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to initiate emergency braking command"
    DTDFVocab:IsAutomatic false
]

// Components
instance PhysicalTwinComponent : DTDFVocab:Component [
    base:desc "Physical twin embedded on Traxxas 1/10 scale vehicle running autonomy components"
]

instance DigitalTwinComponent : DTDFVocab:Component [
    base:desc "Digital twin deployed on remote server handling computation and visualization"
]

instance UserInterfaceComponent : DTDFVocab:Component [
    base:desc "User interface allowing drivers and developers to monitor and configure the vehicle"
]

// Environment
instance VehicleTwinEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinComponent, DigitalTwinComponent, UserInterfaceComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Desired speed setpoints sent to motor, steering commands, ACC enable/disable, and emergency braking command sent to the vehicle"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time operation with end-to-end latency ≤100 ms and clock synchronization accuracy of 100 ms"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "ISO 23247‑based constellation with Physical Twin Entity, Digital Twin Entity, and User Entity interconnected via Data Translation FE over Wi-Fi; each entity deployed on its respective hardware"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated stage (monitoring and remote management during vehicle operation)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real-time fidelity ensured by ≤100 ms latency and clock synchronization; data integrity maintained through unit conversions and serialization in Data Translation FE; validation performed through live operation and reporting"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Wi-Fi network between vehicle and remote DT, ROS 2 DDS over UDP for intra-entity communication, and Data Translation FE handling serialization between ROS and TCP/IP"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital Twin Entity hosted on a remote cloud server, data storage in an SQL database, and User Interface running on the operator's device or local workstation"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 (Digital Twin Manufacturing Framework), ISO/IEC 30173 (Digital Twin concepts), and ROS 2 middleware"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety-critical operations addressed via low-latency requirement (≤100 ms) and clock synchronization; however, detailed cybersecurity and safety analysis for remote execution is not specified"
]