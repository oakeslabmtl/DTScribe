    DTDFVocab:fromData MotorActuationFeedback, SteeringActuationFeedback, ServoActuationFeedback
    DTDFVocab:inputTo DataPreProcessingEnabler
]

// C11: Enablers
instance DataPreProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Aligns and formats sensor data (LiDAR, motor, steering, servo) for downstream processing, ensuring serialization and unit conversion."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance VisualizationPreProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Prepares data for 3D visualization including vehicle state, object tracks, and projected driving paths."
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Central hub for serializing data, aligning message types, and performing unit conversions to ensure interoperability between physical and digital entities."
    DTDFVocab:enables DataMonitoringService
]

instance LowLatencyCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "Ensures real-time data synchronization between physical twin and Digital Twin System using Wi-Fi (UDP transport layer)."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance CloudComputeAllocationEnabler : DTDFVocab:Enabler [
    base:desc "Cloud-based compute allocation for handling high-fidelity ACC computations, reducing on-board processing load."
    DTDFVocab:enables ComputationOffloadingService
]

instance ROS2NetworkEnabler : DTDFVocab:Enabler [
    base:desc "Facilitates modular and interoperable data exchange between software components using ROS2 network."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides real-time visualization of live vehicle state data including projected driving path, detected object tracks, and system performance metrics."
    DTDFVocab:provides RealTimeVisualizationInsight, DataLoggingAndReportingAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads entire ACC system logic (lead vehicle detection, desired speed computation, distance-based control) from on-board ECUs to cloud-based Digital Twin."
    DTDFVocab:provides ACCLogicExecutionInsight, ActuationFeedbackAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to remotely enable/disable ACC, set desired speeds, and issue emergency braking commands with low-latency constraints."
    DTDFVocab:provides RemoteACCControlInsight, EmergencyBrakingAction
]

// C17: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live visualization of vehicle state data including projected driving path, detected object tracks (e.g., lead vehicle, obstacles), and system performance metrics."
]

instance DataLoggingAndReportingAction : DTDFVocab:Action [
    base:desc "Allows users to save, retrieve, and generate reports of historical vehicle state data for post-analysis."
    DTDFVocab:IsAutomatic false
]

instance ACCLogicExecutionInsight : DTDFVocab:Insight [
    base:desc "Computation of desired speed and distance-based control algorithms executed in the cloud-based Digital Twin."
]

instance ActuationFeedbackAction : DTDFVocab:Action [
    base:desc "Transmits computed desired speed back to physical vehicle for real-time actuation (e.g., throttle, braking)."
    DTDFVocab:IsAutomatic true
]

instance RemoteACCControlInsight : DTDFVocab:Insight [
    base:desc "Remote control interface for enabling/disabling ACC, setting desired speeds, and issuing emergency braking commands."
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Issues emergency braking commands remotely with enforced low-latency constraints (100ms)."
    DTDFVocab:IsAutomatic false
]

// C1: Acting Components
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Motor actuator receiving actuation commands from the Digital Twin for throttle control in adaptive cruise control."
]

instance BrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Brake actuator receiving actuation commands from the Digital Twin for braking control in adaptive cruise control."
]

instance SteeringActuator : DTDFVocab:ActingComponent [
    base:desc "Steering actuator receiving actuation commands from the Digital Twin for steering adjustments in adaptive cruise control."
]

// C10: Additional Models/Data
instance ACCControlModel : DTDFVocab:Model [
    base:desc "Computational model for adaptive cruise control logic including lead vehicle detection, desired speed computation, and distance-based control algorithms."
    DTDFVocab:inputTo CloudComputeAllocationEnabler
]

instance DrivingPathProjectionModel : DTDFVocab:Model [
    base:desc "Model projecting the vehicle's driving path based on current state and detected obstacles."
    DTDFVocab:inputTo VisualizationPreProcessingEnabler
]

instance SystemPerformanceMetricsModel : DTDFVocab:Model [
    base:desc "Model tracking and computing system performance metrics for real-time monitoring."
    DTDFVocab:inputTo DataPreProcessingEnabler
]

// C11: Additional Enablers
instance UserInterfacePlatformEnabler : DTDFVocab:Enabler [
    base:desc "Web-based framework (e.g., React, Angular) for real-time visualization of vehicle state data, driving paths, and object tracks."
