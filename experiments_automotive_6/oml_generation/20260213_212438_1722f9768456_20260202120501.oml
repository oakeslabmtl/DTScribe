// C3: Physical Sensing Components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor providing raw point cloud data for environmental perception and object detection in the autonomous vehicle system."
    DTDFVocab:producedData LiDARPointCloudData
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor suite collecting real-time telemetry including motor, steering, and servo actuation states for vehicle state monitoring."
    DTDFVocab:producedData VehicleStateData
]

instance MotorActuationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring motor actuation states for feedback in the adaptive cruise control system."
    DTDFVocab:producedData MotorActuationFeedback
]

instance SteeringActuationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring steering actuation states for feedback in the adaptive cruise control system."
    DTDFVocab:producedData SteeringActuationFeedback
]

instance ServoActuationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring servo actuation states for feedback in the adaptive cruise control system."
    DTDFVocab:producedData ServoActuationFeedback
]

// C4: Physical-to-Virtual Interaction
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    base:desc "Raw point cloud data from LiDAR sensors processed via Point Cloud Clustering & Tracking software component."
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    base:desc "Real-time telemetry from the vehicle including motor, steering, and servo actuation states."
    DTDFVocab:producedFrom VehicleStateSensor
]

instance MotorActuationFeedback : DTDFVocab:DataTransmitted [
    base:desc "Data from motor actuation systems processed by Actuation FE component."
    DTDFVocab:producedFrom MotorActuationSensor
]

instance SteeringActuationFeedback : DTDFVocab:DataTransmitted [
    base:desc "Data from steering actuation systems processed by Actuation FE component."
    DTDFVocab:producedFrom SteeringActuationSensor
]

instance ServoActuationFeedback : DTDFVocab:DataTransmitted [
    base:desc "Data from servo actuation systems processed by Actuation FE component."
    DTDFVocab:producedFrom ServoActuationSensor
]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Converts raw LiDAR points into structured object tracks and environmental maps for adaptive cruise control."
    DTDFVocab:inputTo DataPreProcessingEnabler
]

instance VehicleStateModel : DTDFVocab:Model [
    base:desc "Digital representation of vehicle state including motor, steering, and servo actuation states for real-time monitoring."
    DTDFVocab:inputTo DataPreProcessingEnabler
]

instance ObjectTrackModel : DTDFVocab:Model [
    base:desc "Structured object tracks generated from processed LiDAR point clouds for obstacle detection and lead vehicle tracking."
    DTDFVocab:inputTo DataPreProcessingEnabler
]

instance LiDARPointCloudDataProcessed : DTDFVocab:Data [
    base:desc "Processed LiDAR point cloud data after clustering and tracking, ready for visualization and control logic."
    DTDFVocab:fromData LiDARPointCloudData
    DTDFVocab:inputTo DataPreProcessingEnabler
]

instance VehicleStateDataProcessed : DTDFVocab:Data [
    base:desc "Processed vehicle state data including motor, steering, and servo actuation states for real-time monitoring and control."
    DTDFVocab:fromData VehicleStateData
    DTDFVocab:inputTo DataPreProcessingEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Structured object tracks and environmental representations derived from processed LiDAR data."
