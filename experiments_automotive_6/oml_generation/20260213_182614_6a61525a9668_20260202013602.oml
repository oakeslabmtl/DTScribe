// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing up to 10 m range 2‑D point clouds"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelRealSenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D frames"
    DTDFVocab:producedData DepthCameraFramesTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board speed sensor reporting ego‑vehicle velocity"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor measuring current wheel orientation"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthCameraFramesTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseDepthCamera
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ObjectTracksTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR, IntelRealSenseDepthCamera
]

// C10: Data instances
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud frames"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance DepthCameraFramesData : DTDFVocab:Data [
    base:desc "Raw depth‑camera RGB‑D frames"
    DTDFVocab:fromData DepthCameraFramesTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego‑vehicle speed values (m/s)"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle measurements (degrees)"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Derived object tracks after clustering and filtering"
    DTDFVocab:fromData ObjectTracksTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

// C10: Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN algorithm clustering LiDAR point clouds into obstacle groups"
    DTDFVocab:inputTo ROS2Middleware
]

instance KalmanFilterTrackerModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking model smoothing object trajectories"
    DTDFVocab:inputTo ROS2Middleware
]

instance ACCControllerModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control controller per ISO 15622 computing speed command"
    DTDFVocab:inputTo ROS2Middleware
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model rendering vehicle state and object tracks"
    DTDFVocab:inputTo ROS2Middleware
]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware transporting data over Wi‑Fi using ROS 2 topics"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance NvidiaJetPackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK providing GPU‑accelerated processing on Jetson Orin Nano"
    DTDFVocab:enables ComputationOffloadingService
]

instance OPCUATranslationTool : DTDFVocab:Enabler [
    base:desc "OPC‑UA based data translation and unit conversion service"
    DTDFVocab:enables DataMonitoringService
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL database persisting time‑series vehicle states and object tracks"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualizes real‑time vehicle state, object tracks, projected paths and generates reports"
    DTDFVocab:provides ObjectTracksReportInsight, SystemHealthIndicatorInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm runs on the digital twin and returns the computed speed command"
    DTDFVocab:provides FollowingSpeedInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, modify desired speed, and trigger emergency braking"
    DTDFVocab:provides AdjustDesiredSpeedAction, TriggerEmergencyBrakeAction, EnableACCAction, DisableACCAction
]

// C17: Insights
instance ObjectTracksReportInsight : DTDFVocab:Insight [
    base:desc "Visual report of detected object tracks derived from sensor data"
]

instance SystemHealthIndicatorInsight : DTDFVocab:Insight [
    base:desc "System health indicators such as sensor status and processing load"
]

instance FollowingSpeedInsight : DTDFVocab:Insight [
    base:desc "Computed following speed produced by the ACC controller"
]

// C17: Actions
instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator adjusts the desired speed setpoint for ACC"
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers an emergency brake command"
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator enables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator disables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance VehicleSpeedActuator : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller (Vedder ESC) accepting voltage commands to set vehicle speed"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo providing angular position control for vehicle steering"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency brake interface to instantly stop the vehicle"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT via the Actuation functional entity over Wi‑Fi/ROS 2, including desired speed values, ACC enable/disable flags, emergency‑brake signals, and steering adjustments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in real time with a maximum end‑to‑end network latency of 100 ms (per 3GPP TS 22.185) and requires clock synchronization across components to within 100 ms accuracy."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation orchestrates the Physical Twin Entity (sensing, actuation), Digital Twin Entity (data collection, ACC, reporting, visualization preprocessing), User Entity (3‑D visualization and control panel UI), and Cross‑System Entity (data translation); intra‑entity communication uses ROS 2, inter‑entity communication uses Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during the design/development stage for cyber‑physical experimentation and also during the operational stage for real‑time monitoring, control, and maintenance of the autonomous vehicle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity representation is achieved by running the ACC algorithm on the DT and using real sensor data; model validity is supported by adherence to ISO 15622, real‑time latency ≤ 100 ms, and clock sync ≤ 100 ms to ensure temporal fidelity for safety‑critical control."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual data are exchanged over a Wi‑Fi link (IEEE 802.11) using ROS 2 topics; data are serialized by the Data Translation FE; latency is bounded to 100 ms as per 3GPP TS 22.185; ROS 2 provides DDS‑based publish/subscribe communication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Each functional entity is packaged as a ROS 2 node and deployed on dedicated hardware: the Physical Twin Entity runs on the vehicle’s Jetson Orin Nano, the Digital Twin Entity runs on an external workstation or cloud server, and the User Entity runs on a user workstation; entities communicate over Wi‑Fi."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 Part 2 reference architecture, uses ISO 15622 for ACC functionality, references ISO/IEC 30173:2023 for DT terminology, and aligns communication latency requirements with 3GPP TS 22.185; OPC UA (IEC 62541) is mentioned as a possible implementation option."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations include strict real‑time latency (≤ 100 ms), clock synchronization (≤ 100 ms), and adherence to ISO 15622 for ACC behavior; explicit cybersecurity mechanisms are not described in the document."
]