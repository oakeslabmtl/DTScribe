// ---------------------------------------------------
// Acting Components
// ---------------------------------------------------
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage actuator for vehicle speed control and emergency braking on the Physical Twin"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator for steering angle control on the Physical Twin"
]

// ---------------------------------------------------
// Physical Sensing Components
// ---------------------------------------------------
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR providing 2‑D point‑cloud streams via ROS2"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D images via ROS2"
    DTDFVocab:producedData DepthImageTransmitted
]

instance EgoSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring ego vehicle speed, published over ROS2"
    DTDFVocab:producedData VehicleStateTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring steering wheel angle, published over ROS2"
    DTDFVocab:producedData VehicleStateTransmitted
]

// ---------------------------------------------------
// Data Transmitted (Physical→Virtual)
// ---------------------------------------------------
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoSpeedSensor, SteeringAngleSensor
]

// ---------------------------------------------------
// Raw Data Instances
// ---------------------------------------------------
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo SQLDatabaseEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Raw depth image stream"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo SQLDatabaseEnabler
]

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed measurement"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo SQLDatabaseEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Ego steering angle measurement"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo SQLDatabaseEnabler
]

// ---------------------------------------------------
// Models
// ---------------------------------------------------
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm for object detection on LiDAR data"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter for smoothing object tracks derived from DBSCAN clusters"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model following ISO‑15622 for lead‑vehicle detection and speed computation"
    DTDFVocab:inputTo ROS2PackageACC
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualisation model rendering vehicle state and object tracks"
    DTDFVocab:inputTo VisualizationEngineEnabler
]

// ---------------------------------------------------
// Processed Data from Models
// ---------------------------------------------------
instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks generated by DBSCAN and Kalman filtering"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo SQLDatabaseEnabler, VisualizationEngineEnabler
]

instance DesiredSpeedData : DTDFVocab:Data [
    base:desc "Desired speed computed by ACC control model"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo ROS2PackageACC
]

instance VisualizationData : DTDFVocab:Data [
    base:desc "3‑D visualisation data consumed by the UI"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo VisualizationEngineEnabler
]

// ---------------------------------------------------
// Enablers (Tooling & Infrastructure)
// ---------------------------------------------------
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware enabling intra‑entity topic communication"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance WiFi80211Enabler : DTDFVocab:Enabler [
    base:desc "IEEE 802.11 Wi‑Fi link for inter‑entity communication between PT, DT and UI"
    DTDFVocab:enables RemoteManagementService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database persisting sensor readings, object tracks and computed speeds"
    DTDFVocab:enables DataMonitoringService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment used for DBSCAN, Kalman filtering and ACC algorithm development"
    DTDFVocab:enables ComputationOffloadingService
]

instance ROS2PackageACC : DTDFVocab:Enabler [
    base:desc "ROS2 package implementing the ACC control algorithm"
    DTDFVocab:enables ComputationOffloadingService
]

instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "3‑D visualization engine powering the UI rendering"
    DTDFVocab:enables DataMonitoringService
]

// ---------------------------------------------------
// Services
// ---------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualises real‑time speed, steering angle, object tracks and projected path; generates time‑series reports"
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTracksInsight, ProjectedPathInsight, PostRunReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm runs in the Digital Twin, receives sensor data and returns desired speed"
    DTDFVocab:provides DesiredSpeedInsight, AdjustDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, modify desired speed, and trigger emergency braking via UI"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakeAction
]

// ---------------------------------------------------
// Insights
// ---------------------------------------------------
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time visual insight into vehicle speed and steering angle"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Insight into detected surrounding objects and their trajectories"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected future path of the autonomous vehicle based on ACC output"
]

instance PostRunReportInsight : DTDFVocab:Insight [
    base:desc "Time‑series report of vehicle state and sensor data for post‑run analysis"
]

instance DesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Computed desired speed for maintaining safe distance to lead vehicle"
]

// ---------------------------------------------------
// Actions
// ---------------------------------------------------
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Modify target speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Trigger emergency braking via motor actuator"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends computed desired speed commands, enable/disable ACC flags, emergency braking signals, and optional steering adjustments back to the PT over a Wi‑Fi link; the Actuation FE translates these commands into motor voltage and servo signals for execution on the vehicle."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is designed for sub‑second operation: network latency is bounded to ≤100 ms (per 3GPP TS‑22.185) and clocks on all DTS components are synchronised to an accuracy of 100 ms, enabling real‑time data collection and control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A layered architecture following ISO 23247: Physical Twin Entity (sensors and actuators), Digital Twin Entity (data collection, ACC, reporting, visualization), User Entity (3D visualization and control panel UI), and Cross‑System Entity (data translation); each functional entity is implemented as an independent ROS2 package and deployed on distinct hardware platforms."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during development (developers use data collection and monitoring to troubleshoot) and during operation (operators monitor and remotely manage ACC), thus covering both the design/testing and runtime stages of the vehicle lifecycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity sensor data (LiDAR point clouds) are processed in real time; synchronization to 100 ms ensures temporal coherence; ACC behaviour conforms to ISO 15622 performance class I; latency and clock‑sync constraints are enforced to maintain safety‑critical operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication over a Wi‑Fi network linking the vehicle’s Jetson board to the off‑board DT host; ROS2 topics carry sensor streams and control commands; the Data Translation FE handles serialization, message‑type alignment, and unit conversion."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the on‑board NVIDIA Jetson Orin Nano; Digital Twin Entity and User Entity run on an external compute platform (e.g., a PC or cloud instance); each functional entity is packaged as a separate ROS2 node set for independent deployment."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) reference architecture, leverages ISO 15622 for ACC functionality, and aligns with ISO/IEC 30173 conceptual definitions of digital twins."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by enforcing a maximum 100 ms end‑to‑end latency and clock synchronization to 100 ms, complying with ISO 15622 ACC performance class; however, explicit security mechanisms (authentication, encryption) are not described in the document."
]