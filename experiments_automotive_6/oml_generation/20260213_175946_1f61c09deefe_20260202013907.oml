// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "High‑performance LiDAR capturing raw point clouds of the surrounding environment"
    DTDFVocab:producedData LiDARPointCloudRawTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor units measuring the vehicle’s speed and steering angle for state estimation"
    DTDFVocab:producedData VehicleStateRawTransmitted
]

// C4: Physical-to-virtual interaction - Data transmitted
instance LiDARPointCloudRawTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateRawTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// C10: Models/Data - Raw data
instance LiDARPointCloudRawData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud received from the LiDAR sensor"
    DTDFVocab:fromData LiDARPointCloudRawTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehicleStateRawData : DTDFVocab:Data [
    base:desc "Raw vehicle state data (speed, steering angle) received from the vehicle state sensor"
    DTDFVocab:fromData VehicleStateRawTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

// C10: Models/Datas - Processed data
instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks automatically generated from LiDAR point clouds by the clustering and tracking algorithm"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance DesiredSpeedData : DTDFVocab:Data [
    base:desc "Desired vehicle speed computed by the ACC algorithm executed in the cloud"
    DTDFVocab:inputTo DataTranslationEnabler
]

// C10: Models - Functional Entity executing perception
instance PointCloudClusteringTrackerModel : DTDFVocab:Model [
    base:desc "Performs 3D point cloud clustering and temporal tracking to produce object tracks"
    DTDFVocab:inputTo DataTranslationEnabler
]

// C11: Enablers - Data translation and serialization
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Translates raw and processed data into serialized messages, aligns types, performs unit conversions and forwards them to services"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Graphical user interface service that visualizes real‑time vehicle state, projected path and detected object tracks; allows collecting and reporting ACC‐relevant data"
    DTDFVocab:provides ACCMonitoringInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC control computations (lead vehicle detection, speed setpoint calculation) to the cloud and publishes the resulting desired speed back to the vehicle"
    DTDFVocab:provides DesiredSpeedSetpointAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to remotely enable/disable ACC, set desired speed, and issue emergency braking commands through the UI"
    DTDFVocab:provides EmergencyBrakeCommandAction, ACCEnableToggleAction
]

// C17: Insights
instance ACCMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time status of the Adaptive Cruise Control system including current speed, desired speed, and object tracking information"
]

// C17: Actions
instance DesiredSpeedSetpointAction : DTDFVocab:Action [
    base:desc "Set the desired vehicle speed that the ACC algorithm recommends"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeCommandAction : DTDFVocab:Action [
    base:desc "Immediate emergency braking command issued by an operator through the UI"
    DTDFVocab:IsAutomatic false
]

instance ACCEnableToggleAction : DTDFVocab:Action [
    base:desc "Toggle the Adaptive Cruise Control system on or off remotely"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin Entity are sent back to the vehicle over the same Wi‑Fi/UDP link. The commands include ACC enable/disable, a desired speed set‑point, and an emergency‑brake request. These commands are received by the Actuation FE in the Physical Twin Entity, which converts the desired speed into the appropriate motor voltage/actuation signal for the vehicle. The system operates in real time to meet low end‑to‑end latency requirements, but the documents do not describe explicit validation, authentication, or acknowledgement mechanisms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires clock synchronization between devices with an accuracy of 100 ms, as dictated by hardware limitations; this defines the maximum permissible time drift for computation offloading and coordination between the Physical Twin Entity and Digital Twin Entity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration follows the ISO 23247 reference architecture: software components are first identified, then mapped to Functional Entities that are implemented as individual ROS‑2 packages (each containing ROS‑2 nodes). The Physical Twin Entity hosts sensor, actuator and compute resources; the Digital Twin Entity provides data management and control logic; the User Entity offers a 3D visualization and control panel UI. Coordination between entities relies on ROS‑2 communication primitives and the shared 100 ms time base."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS uses a hybrid network architecture. Inside each entity, software components communicate via a ROS 2 middleware network (publish/subscribe and services). Between entities, a Wi‑Fi network transports UDP packets for both sensor data (physical→virtual) and control commands (virtual→physical). Clock synchronisation across devices is required to within 100 ms accuracy to satisfy safety‑critical timing constraints. No explicit bandwidth or redundancy mechanisms are described, and security protocols are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the vehicle’s on‑board compute hardware, hosting sensor drivers and the Data Pre‑Processing and Actuation FEs as ROS 2 packages. The Digital Twin Entity is deployed on external compute resources that may reside in the cloud or at the edge, providing sufficient CPU, memory and storage to run the Data Translation, Data Collection, Reporting and 3D Visualization services. The architecture supports off‑loading of the ACC algorithm to this remote platform, enabling scalable compute and storage while maintaining low end‑to‑end latency for control loops."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built to conform to the ISO 23247 Digital Twin framework for manufacturing, specifically leveraging Part 2 (Reference Architecture) to define an entity‑based structure (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity) and to allocate functionality to Functional Entities. Communication and device coordination may employ OPC Unified Architecture (OPC UA) as suggested by the standard, though the implementation described uses ROS 2 as the middleware. The design also respects industry‑specified time‑synchronization limits (≤100 ms) for safety‑critical vehicular applications, aligning with standards that mandate stricter clock synchronization. No additional certification or compliance frameworks are mentioned."
]