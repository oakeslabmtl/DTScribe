instance PointCloudProcessingFE : DTDFVocab:FunctionalEntity [
    base:desc "Point Cloud Clustering & Tracking FE that processes raw LiDAR point clouds into structured 3D representations"
    DTDFVocab:inputTo LiDARPointCloudData
    DTDFVocab:enables AnomalyDetectionService
]

