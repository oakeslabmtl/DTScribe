]

instance SatelliteTrackingData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CollisionAvoidanceSensor
    DTDFVocab:communicationProtocol CoAP
]

instance SteeringCommandData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSteeringActuator
    DTDFVocab:communicationProtocol ROS2Network
]

instance MotorControlCommands : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorActuator
    DTDFVocab:communicationProtocol OPCUA
]

instance BatteryManagementCommands : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BatteryPackActuator
    DTDFVocab:communicationProtocol MQTT
]

