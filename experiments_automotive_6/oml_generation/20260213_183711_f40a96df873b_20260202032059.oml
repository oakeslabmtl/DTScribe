// -----------------------------------------------------------
// Physical Sensing Components
// -----------------------------------------------------------

instance HokuyoUst10LxLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2‑D LiDAR providing 270° scans of the environment, streamed as raw point clouds over Wi‑Fi."
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering RGB‑D frames for perception."
    DTDFVocab:producedData DepthCameraFramesTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring vehicle longitudinal speed."
    DTDFVocab:producedData SpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring wheel steering angle."
    DTDFVocab:producedData SteeringDataTransmitted
]

instance JetsonOrinNanoComputeMonitor : DTDFVocab:SensingComponent [
    base:desc "Internal monitor of Jetson Orin Nano compute resources (CPU/GPU utilization, temperature)."
    DTDFVocab:producedData ComputeMetricsTransmitted
]

// -----------------------------------------------------------
// Data Transmitted (raw sensor streams)
// -----------------------------------------------------------

instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUst10LxLiDAR
]

instance DepthCameraFramesTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ComputeMetricsTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JetsonOrinNanoComputeMonitor
]

// -----------------------------------------------------------
// Data (raw) 
// -----------------------------------------------------------

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data captured at up to 40 Hz."
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DBSCANProcessingEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames from the Intel D435i camera."
    DTDFVocab:fromData DepthCameraFramesTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance SpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed in m/s."
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, ACCProcessingEnabler
]

instance SteeringData : DTDFVocab:Data [
    base:desc "Steering angle in degrees."
    DTDFVocab:fromData SteeringDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ComputeMetricsData : DTDFVocab:Data [
    base:desc "CPU/GPU utilization percentages and temperature readings."
    DTDFVocab:fromData ComputeMetricsTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

// -----------------------------------------------------------
// Processed Data Transmitted (model outputs)
// -----------------------------------------------------------

instance ClusteredLiDARTransmitted : DTDFVocab:DataTransmitted [
]

instance ObjectTracksTransmitted : DTDFVocab:DataTransmitted [
]

instance ACCSetpointTransmitted : DTDFVocab:DataTransmitted [
]

// -----------------------------------------------------------
// Data (processed)
// -----------------------------------------------------------

instance ClusteredLiDARData : DTDFVocab:Data [
    base:desc "Segmented LiDAR clusters representing detected obstacles."
    DTDFVocab:fromData ClusteredLiDARTransmitted
    DTDFVocab:inputTo KalmanTrackerProcessingEnabler
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks with position, velocity, and ID generated by Kalman filter."
    DTDFVocab:fromData ObjectTracksTransmitted
    DTDFVocab:inputTo ACCProcessingEnabler, ROS2CommunicationEnabler
]

instance ACCSetpointData : DTDFVocab:Data [
    base:desc "Desired speed set‑point computed by the ACC model, sent to the motor controller."
    DTDFVocab:fromData ACCSetpointTransmitted
    DTDFVocab:inputTo ROS2CommunicationEnabler
]

// -----------------------------------------------------------
// Models
// -----------------------------------------------------------

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm segmenting LiDAR point clouds to identify obstacles."
    DTDFVocab:inputTo DBSCANProcessingEnabler
]

instance KalmanFilterTrackerModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based tracker generating object tracks from clustered LiDAR data."
    DTDFVocab:inputTo KalmanTrackerProcessingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) model compliant with ISO 15622 performance class I, calculating speed set‑point from lead‑vehicle distance."
    DTDFVocab:inputTo ACCProcessingEnabler
]

// -----------------------------------------------------------
// Enablers
// -----------------------------------------------------------

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 node that serializes sensor streams and performs unit conversion (e.g., m/s → km/h)."
    DTDFVocab:enables DataMonitoringService
]

instance DBSCANProcessingEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink component executing DBSCAN clustering on LiDAR point clouds."
    DTDFVocab:enables DataMonitoringService
]

instance KalmanTrackerProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Python node implementing a Kalman filter to produce object tracks."
    DTDFVocab:enables DataMonitoringService
]

instance ACCProcessingEnabler : DTDFVocab:Enabler [
    base:desc "C++ ROS2 node running the ISO 15622‑compliant ACC algorithm."
    DTDFVocab:enables ComputationOffloadingService
]

instance ROS2CommunicationEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware facilitating inter‑entity communication between PT, DT, and User entities."
    DTDFVocab:enables RemoteManagementService, DataMonitoringService, ComputationOffloadingService
]

// -----------------------------------------------------------
// Services
// -----------------------------------------------------------

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualizes real‑time speed, steering angle, object tracks, projected path, and generates time‑series reports."
    DTDFVocab:provides RealTimeSpeedInsight, RealTimeSteeringInsight, ObjectTracksInsight, ProjectedPathInsight, TimeSeriesReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC algorithm in the Digital Twin, determines lead‑vehicle distance and returns speed set‑point."
    DTDFVocab:provides ACCRecommendationInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI allows operators to enable/disable ACC, modify desired speed, and trigger emergency braking."
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustSpeedSetpointAction, EmergencyBrakeAction
]

// -----------------------------------------------------------
// Insights
// -----------------------------------------------------------

instance RealTimeSpeedInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of vehicle speed streamed from the Physical Twin."
]

instance RealTimeSteeringInsight : DTDFVocab:Insight [
    base:desc "Real‑time display of steering angle."
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Live object tracks obtained from LiDAR clustering and Kalman filter."
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected vehicle trajectory based on current speed and steering."
]

instance TimeSeriesReportInsight : DTDFVocab:Insight [
    base:desc "Generated time‑series reports of speed, steering, and tracks for post‑analysis."
]

instance ACCRecommendationInsight : DTDFVocab:Insight [
    base:desc "ACC computed speed set‑point recommendation based on lead‑vehicle distance."
]

// -----------------------------------------------------------
// Actions
// -----------------------------------------------------------

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance AdjustSpeedSetpointAction : DTDFVocab:Action [
    base:desc "Operator adjusts the desired speed set‑point for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking, commanding motor to stop immediately."
    DTDFVocab:IsAutomatic false
]

// -----------------------------------------------------------
// Acting Components
// -----------------------------------------------------------

instance MotorDriverActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder electronic speed controller driving the vehicle motor, receives voltage command for desired speed."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Servo controlling wheel steering angle based on command from the Digital Twin."
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency brake actuation that forces the motor driver to zero voltage, halting the vehicle."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT: desired speed set‑points for the motor controller, steering angle commands for the servo, enable/disable signals for the ACC subsystem, speed‑setting commands, and an emergency‑brake command. These are transmitted over the same Wi‑Fi link using the Data Translation FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is designed for real‑time operation with an end‑to‑end latency budget of ≤100 ms between PT and DT and clock synchronization accuracy of 100 ms across all components, matching the 3GPP TS 22.185 requirement for V2V communication."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 reference model with a Physical Twin Entity (sensing/actuation), a Digital Twin Entity (data collection, ACC control, reporting, visualization pre‑processing), a User Entity (3D visualization UI and control panel), and a Cross‑System Data Translation Entity. Entities are deployed on separate hardware and communicate via ROS2 topics internally and Wi‑Fi externally."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The case study focuses on the operational stage of the twin, using the DT for run‑time monitoring, control offloading, and remote management of the already manufactured 1/10‑scale vehicle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity perception is achieved by processing raw LiDAR point clouds with DBSCAN and Kalman filtering. The ACC algorithm adheres to ISO 15622 performance‑class I specifications, ensuring functional validity. Real‑time latency (≤100 ms) and clock sync (100 ms) are enforced to maintain safety‑critical timing guarantees."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication uses a Wi‑Fi network (IEEE 802.11) with ROS2 as the transport layer. Data streams are serialized by the Data Translation Functional Entity. The system follows a standardized communication interface (R1) to ensure modularity and loose coupling."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the vehicle‑mounted Jetson Orin Nano, the Digital Twin Entity executes on an external compute platform (e.g., cloud server or workstation), and the User Entity is hosted on an operator workstation. Each entity is packaged as a ROS2 node set and deployed independently."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture conforms to ISO 23247 (Digital Twin Manufacturing Framework) reference architecture, uses the ACC functional specification from ISO 15622, references ISO/IEC 30173 for digital‑twin terminology, and employs ROS2 as an open‑source middleware standard. OPC UA is mentioned as a possible transport but not implemented."
]