// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR unit providing 2‑D range measurements for object detection"
    DTDFVocab:producedData LiDARDataTransmitted
]

instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera supplying 3‑D point clouds for clustering and tracking"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor extracting motor speed and health status from the drive Motor"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reading angular position of the Steering Servo"
    DTDFVocab:producedData SteeringServoDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Aggregator providing overall vehicle state (speed, heading, battery) from the physical twin"
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance SteeringServoDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// C10: Data definitions
instance LiDARRangeData : DTDFVocab:Data [
    base:desc "2‑D range measurements streamed from the LiDAR"
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance DepthPointCloudData : DTDFVocab:Data [
    base:desc "Raw 3‑D point‑cloud stream from the depth camera"
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Current speed and health metrics of the drive Motor"
    DTDFVocab:fromData MotorStatusDataTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance SteeringServoPositionData : DTDFVocab:Data [
    base:desc "Angular position feedback of the Steering Servo"
    DTDFVocab:fromData SteeringServoDataTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Composite vehicle state required for ACC and UI visualisation"
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks produced by the Point Cloud Clustering & Tracking model"
    DTDFVocab:inputTo DataTranslationFE
]

// C10: Model definition
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Applies DBSCAN clustering on incoming point‑cloud data followed by a Kalman filter to maintain object tracks"
    DTDFVocab:inputTo DataTranslationFE
]

// C11: Enablers
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "ISO 23247 Data Translation functional entity serialising messages, aligning models and performing unit conversions over ROS‑2"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware facilitating low‑latency communication between DT software components"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance ACCAlgorithmFE : DTDFVocab:Enabler [
    base:desc "Computation offloading functional entity executing the ACC algorithm (lead‑vehicle detection, speed‑setpoint calculation) in the cloud"
    DTDFVocab:enables ComputationOffloadingService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI visualising vehicle state, projected driving path and detected object tracks; supports viewing, saving and reporting logged data"
    DTDFVocab:provides VehicleStateVisualizationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs the ACC algorithm in the twin and returns the desired speed set‑point to the vehicle for actuation"
    DTDFVocab:provides DesiredSpeedSetpointAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI enables operators to enable/disable ACC, manually set speed, and issue an emergency‑brake command"
    DTDFVocab:provides EmergencyBrakeAction, ManualSpeedSetAction
]

// C17: Insights / Actions
instance VehicleStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight delivering live visualisation of vehicle state and surrounding object tracks for operators"
]

instance DesiredSpeedSetpointAction : DTDFVocab:Action [
    base:desc "Action delivering the ACC‑computed desired speed set‑point to the vehicle"
    DTDFVocab:IsAutomatic true
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediate stop command satisfying Requirement R5 (emergency braking) sent to the drive Motor and ESC"
    DTDFVocab:IsAutomatic false
]

instance ManualSpeedSetAction : DTDFVocab:Action [
    base:desc "Operator‑initiated command to manually set vehicle speed satisfying Requirement R6"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are sent from the Digital Twin back to the vehicle over the same Wi‑Fi UDP channel. Commands include enabling/disabling ACC, setting a desired speed, and an emergency‑brake command; these are issued by the remote‑management UI and by the off‑loaded ACC computation (which calculates a desired speed based on lead‑vehicle distance). The commands are serialized and unit‑converted by the Data Translation FE before transmission. The UI displays confirmation of command execution, but the documents do not describe specific validation, authentication, acknowledgement, or conflict‑resolution mechanisms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Clock synchronization between the physical vehicle and its digital twin must achieve an accuracy of 100 ms, as required for safety‑critical vehicular applications and limited by the hardware; this shared notion of time enables computation offloading across devices."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration follows the ISO 23247 reference architecture instantiated with ROS 2: each Functional Entity is packaged as an individual ROS 2 package containing one or more ROS 2 nodes; communication between entities occurs via ROS 2 topics/services, enabling coordination across the separate hardware platforms. The mapping of software components to entities provides resource‑level segregation and ownership."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The ISO 23247 framework structures the Digital Twin lifecycle into four sequential parts: (1) Overview and General Principles – defines the conceptual stage and high‑level goals; (2) Reference Architecture – establishes the entity‑based architectural stage where the Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity and User Entity are defined; (3) Digital Representation of Physical Manufacturing Elements – implements the Digital Twin Entity using functional entities that model the OME; (4) Information Exchange – integrates the DT with external systems and supports the transition to operational use. Governance of the lifecycle is expressed through adherence to the ISO 23247 standard, which prescribes the entities, functional entities and their responsibilities, but does not detail transition mechanisms."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑component communication within the digital twin system is built on ROS 2. Communication between the physical twin and the digital twin occurs over a Wi‑Fi network using UDP transport. The system is required to provide low end‑to‑end latency for safety‑critical ACC functionality, but the documents do not give quantitative bandwidth or latency targets, nor do they describe redundancy, reliability mechanisms, or specific security protocols for the network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT services are executed on external compute resources that can be “better‑suited equipment, e.g., in the cloud”, enabling off‑loading of the ACC algorithm. No details are given about the precise hosting platform (cloud provider, edge or on‑premise), required computational or storage capacities, scalability mechanisms, supported deployment models, or availability/reliability guarantees."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system complies with ISO 23247 (four‑part Digital Twin framework) and adopts its entity‑based reference architecture. Additional standards cited in the broader document include ISO 15622 for Adaptive Cruise Control (ACC) implementation and 3GPP Technical Specification 22.185 for network latency requirements. Interoperability is supported through the optional use of OPC UA, aligning the DT with common industrial communication standards."
]