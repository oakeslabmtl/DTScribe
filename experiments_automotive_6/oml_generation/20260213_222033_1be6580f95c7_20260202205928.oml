    DTDFVocab:enables ManufacturingProcessMonitoringService, PredictiveMaintenanceService
]

instance CyberBiophysicalEnabler : DTDFVocab:Enabler [
    base:desc "Modelica-based simulation environment for cyber-biophysical systems integrating physical and computational components with real-time data integration"
    DTDFVocab:enables CyberBiophysicalSystemMonitoringService, DynamicReconfigurationService
]

instance DataTranslationFE : DTDFVocab:Enabler [
