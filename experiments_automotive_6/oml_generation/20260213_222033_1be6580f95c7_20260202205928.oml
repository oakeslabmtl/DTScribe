    base:desc "High-fidelity sensor system measuring state-of-charge (SoC), state-of-health (SoH), and electrochemical parameters for battery systems in automotive applications"
    DTDFVocab:producedData BatteryHealthDataTransmitted
]

instance OrbitalDebrisSensor : DTDFVocab:SensingComponent [
    base:desc "Space-based sensor system detecting orbital debris and tracking spacecraft trajectories for collision avoidance in aerospace applications"
    DTDFVocab:producedData OrbitalDebrisDataTransmitted
]

instance ManufacturingProcessSensor : DTDFVocab:SensingComponent [
    base:desc "Industrial IoT sensor network capturing vibration, temperature, and pressure data from manufacturing equipment for condition monitoring"
    DTDFVocab:producedData ManufacturingProcessDataTransmitted
