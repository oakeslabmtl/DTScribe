    DTDFVocab:producedFrom VehicleStateSensor
]

instance BatteryHealthDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BatteryHealthMonitor
]

instance OrbitalDebrisDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OrbitalDebrisSensor
]

instance ManufacturingProcessDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ManufacturingProcessSensor
]

instance CyberBiophysicalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IoTSensorNetwork
]

