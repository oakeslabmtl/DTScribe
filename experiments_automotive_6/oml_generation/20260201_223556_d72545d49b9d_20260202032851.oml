// C3: Physical sensing components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing 2D laser scans for object detection"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering RGB‑D images"
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard wheel‑encoder sensor measuring vehicle speed"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring servo position"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// C4: Physical‑to‑virtual interaction (Data transmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C5: Data items
instance RawLiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 2D point cloud from LiDAR"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ROS2DataProcessingEnabler
]

instance RawDepthImageData : DTDFVocab:Data [
    base:desc "Raw depth image from depth camera"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo ROS2DataProcessingEnabler
]

instance EgoVehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed in meters per second"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo ROS2DataProcessingEnabler
]

instance EgoSteeringAngleData : DTDFVocab:Data [
    base:desc "Ego steering angle in degrees"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo ROS2DataProcessingEnabler
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Tracked object positions obtained via DBSCAN clustering and Kalman filtering"
    DTDFVocab:fromData RawLiDARPointCloudData
    DTDFVocab:inputTo ACCAlgorithmEnabler
]

instance ACCCommandData : DTDFVocab:Data [
    base:desc "ACC control command (desired speed set‑point) generated by the ISO 15622 model"
    DTDFVocab:fromData ObjectTracksData
    DTDFVocab:inputTo ACCAlgorithmEnabler
]

// C10: Models / Algorithms
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm for segmenting LiDAR point clouds"
    DTDFVocab:inputTo ROS2DataProcessingEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter for smoothing object tracks across frames"
    DTDFVocab:inputTo ROS2DataProcessingEnabler
]

instance ACCControlModelISO15622 : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model defined by ISO 15622 for lead‑vehicle detection and speed set‑point calculation"
    DTDFVocab:inputTo ACCAlgorithmEnabler
]

// C11: Enablers
instance ROS2DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 node chain performing DBSCAN clustering and Kalman filtering on sensor streams"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance ACCAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Off‑vehicle computation node executing the ISO 15622 ACC algorithm"
    DTDFVocab:enables RemoteManagementService, ReportingService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI visualizing vehicle speed, steering angle, projected path, and object tracks"
    DTDFVocab:provides VehicleStateInsight, ObjectTracksInsight, ProjectedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC computation to the digital twin for higher‑performance processing"
    DTDFVocab:provides ACCResultInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI permits enabling/disabling ACC, adjusting desired speed, and issuing emergency‑brake commands"
    DTDFVocab:provides DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakeAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Automated generation of time‑series reports stored in an SQL database"
    DTDFVocab:provides ReportGenerationAction
]

// C17: Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Live visualization of ego vehicle speed, steering angle, and projected trajectory"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Visualization of detected and tracked surrounding objects"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected path of ego vehicle based on current motion and ACC set‑point"
]

instance ACCResultInsight : DTDFVocab:Insight [
    base:desc "Display of ACC‑computed desired speed set‑point"
]

// C17: Actions
instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator adjusts the desired cruising speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers an emergency brake command to stop the vehicle"
    DTDFVocab:IsAutomatic false
]

instance ReportGenerationAction : DTDFVocab:Action [
    base:desc "Automated generation and storage of time‑series performance reports"
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller receiving motor voltage commands for propulsion"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator receiving angle commands to steer the vehicle"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT via ROS2 over Wi‑Fi, including desired speed set‑points, ACC enable/disable flags, emergency‑brake triggers, and motor/steering actuation commands; these are processed by the Actuation FE on the Physical Twin Entity."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in real‑time with an end‑to‑end network latency budget of ≤100 ms and clock synchronization accuracy of 100 ms across all components, satisfying the 3GPP 22.185 latency requirement for V2V‑type services."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates a Physical Twin Entity (sensors/actuators), a Digital Twin Entity (data collection, ACC computation, visualization, reporting), a User Entity (3D visualization and control‑panel UI), and a Cross‑System Entity (Data Translation FE) communicating over ROS2 and Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during the design and development phase (simulation, cyber‑physical experimentation) and during operational use for monitoring, remote management, and performance reporting of the running vehicle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time fidelity is ensured by the ≤100 ms latency and clock sync constraints; safety validity is addressed by adhering to ISO 15622 ACC specifications and by limiting the control to performance‑class I (no road‑curvature handling). Tracking fidelity relies on DBSCAN clustering and Kalman filtering validated against sensor data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication between PT and DT uses a Wi‑Fi network carrying ROS2 messages; the Data Translation FE serializes and aligns data types. The standardized communication interface (R1) enforces modular, loosely‑coupled message exchange."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the vehicle’s NVIDIA Jetson Orin Nano; Digital Twin Entity components are hosted on an external computing platform (e.g., cloud workstation) with separate ROS2 processes; the User Entity UI runs on an operator workstation connected via the same Wi‑Fi network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) for entity/functional decomposition, uses ISO 15622 for ACC functional requirements, and complies with the standardized communication principle (R1); ROS2 provides a de‑facto standard middleware stack."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by meeting ISO 15622 ACC requirements, enforcing ≤100 ms latency and clock sync, and providing emergency‑brake capability; explicit cybersecurity mechanisms are not described in the document."
]