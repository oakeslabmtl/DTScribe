// Sensing Components
instance LidarSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle’s on‑board LiDAR sensor generating raw point cloud streams for environment perception."
    DTDFVocab:producedData LidarRawPointCloudUDP
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle ECU sensor providing periodic vehicle state updates (pose, velocity, wheel speeds) over ROS2 topics."
    DTDFVocab:producedData VehicleStateTopic
]

// Physical-to-virtual interaction – Data Transmitted
instance LidarRawPointCloudUDP : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LidarSensor
    base:desc "UDP transmission over vehicle’s Wi‑Fi interface of raw LiDAR point cloud streams to the Data Translation FE."
]

instance LidarSerializedPointCloudDDS : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LidarRawPointCloudUDP
    base:desc "DDS‑compatible binary format of LiDAR point cloud serialized and aligned with ISO 23247 message types."
]

instance VehicleStateTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
    base:desc "ROS2 topic publishing periodic vehicle status data (pose, velocity, wheel speeds) from the ECU."
]

instance PointCloudClusteredData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LidarSerializedPointCloudDDS
    base:desc "Clustered point‑cloud data produced by the Point Cloud Clustering & Tracking component, containing detected object tracks and predicted driving path."
]

// Virtual data (processed or looked‑up) – Data
instance RawPointCloudData : DTDFVocab:Data [
    base:desc "DDS‑compatible binary point‑cloud data aligned with ISO 23247 message types."
    DTDFVocab:fromData LidarSerializedPointCloudDDS
    DTDFVocab:inputTo DataMonitoringEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Normalized vehicle state data including pose, velocity, and wheel speeds; used for ACC monitoring and computation."
    DTDFVocab:fromData VehicleStateTopic
    DTDFVocab:inputTo DataMonitoringEnabler, ComputationOffloadingEnabler, RemoteManagementEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Detected object tracks and predicted driving path derived from Euclidean clustering."
    DTDFVocab:fromData PointCloudClusteredData
    DTDFVocab:inputTo DataMonitoringEnabler, ComputationOffloadingEnabler
]

// Enablers
instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for real‑time acquisition and visualization of ACC‑relevant vehicle state data via a user interface."
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that offloads ACC computation from the vehicle’s ECU to an external cloud or edge server."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler allowing operators to manually enable/disable ACC, set desired speed, and issue emergency braking commands."
    DTDFVocab:enables RemoteManagementService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real‑time insights into vehicle state and object tracks for ACC monitoring."
    DTDFVocab:provides VehicleStateInsight, ObjectTrackInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service that receives vehicle state and object track data to compute the desired speed, then sends ACC command to the vehicle."
    DTDFVocab:provides SendACCCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service enabling remote management actions such as toggling ACC, setting desired speed, and initiating emergency braking."
    DTDFVocab:provides ToggleACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into the vehicle’s current pose, velocity, and wheel speeds during ACC operation."
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Insight into detected object tracks and predicted driving path."
]

// Actions
instance SendACCCommandAction : DTDFVocab:Action [
    base:desc "Action to send the desired speed command computed by the cloud/edge server to the vehicle ECU for accelerating or decelerating."
    DTDFVocab:IsAutomatic false
]

instance ToggleACCAction : DTDFVocab:Action [
    base:desc "Action to enable or disable the ACC system remotely."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to set a desired speed for the ACC system."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to issue an emergency braking command."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires precise temporal alignment across all components, enforcing a shared clock with an accuracy tighter than 100 ms due to hardware constraints. Each computational node, sensor, and actuator must operate with this 100 ms synchronization granularity to meet safety‑critical vehicular service latency requirements, particularly for computation‑offloading tasks where devices exchange time‑stamped data. No higher‑frequency time buses are specified beyond this bound."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The orchestration follows the ISO 23247 Reference Architecture, mapping each software component (FEs) to a dedicated ROS 2 package containing one or more ROS 2 nodes. The Physical Twin Entity hosts general vehicle functions such as Point Cloud Clustering & Tracking, while the Digital Twin Entity manages data storage, pre‑processing, and control mechanisms. The User Entity contains the User Interface FE split into 3D Visualization and Control Panel sub‑components. Deployment on separate hardware facilitates dedicated resource management per entity, with ROS 2’s data‑distribution service handling inter‑entity messaging and synchronization."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All intra‑DTS software components communicate over a ROS2 network, which utilizes DDS for publish/subscribe messaging. Inter‑entity communication (between the Physical Twin Entity and the Digital Twin Entity) is conducted over a Wi‑Fi network using UDP at the transport layer, as illustrated in Fig. 2. The Data Translation FE serves as the serialization hub, synchronizing and converting sensor streams to comply with ISO 23247. The architecture forms a bus‑like topology within the vehicle, with all processing units exchanging data via DDS topics routed over the vehicle’s internal Wi‑Fi."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Standardization: The Digital Twin implementation aligns with the ISO 23247 – Digital Twin Framework for Manufacturing, following its reference architecture (Part 2). The architecture defines four entity roles: Data Collection and Device Control Entity, Digital Twin Entity, User Entity, and Functional Entities. It adheres to ISO‑ed guidelines for modeling Observable Manufacturing Elements (OMEs). For concrete device communication, the system uses OPC Unified Architecture (OPC UA) as an example implementation, enabling interoperability with industrial devices. The open-source reference implementation is available on GitHub (https://github.com/McSCert/Automotive-Digital-Twin). No other certification or compliance frameworks are explicitly mentioned."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "3GPP TS 22.185 specifies a V2X security architecture that requires mutual authentication between vehicle and roadside units (RSUs) using an application‑level Public Key Infrastructure (PKI) based on the V2X Authentication/Authorization (VAA) profile. Cryptographic protection of V2X messages is enforced by Message Authentication Codes (MACs) calculated with AES‑128‑GCM and channel encryption is provided by AES‑CCM‑16‑128. Vehicle identifiers are pseudonymised with short‑lived pseudonyms (typically refreshed every 15–30 s), and certificate revocation is performed via the X.509 Certificate Revocation List (CRL) and Online Certificate Status Protocol (OCSP) mechanisms. ISO 26262 mandates a functional‑safety lifecycle that includes a safety concept, hazard analysis and risk assessment (H‑ARA), safety goals, and safety requirements. Level ASIL D systems must implement fault‑tolerant architectures, such as dual‑ or triple‑modular redundancy, isolated components, and watchdog‑based fail‑safe mechanisms. Safety‑critical system considerations include the need for rigorous software and hardware verification, MISRA‑C compliance for safety‑related code, and continuous monitoring of safety‑related events through safety monitors and basic safety functions. The safety lifecycle also requires the establishment of safety margins, concurrent fault detection, and safe‑state transitions in the event of faults to prevent hazardous states. "
]