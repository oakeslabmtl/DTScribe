// Acting Components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller receives throttle commands via CAN (ID 0x200) and outputs PWM duty cycle to regulate brushless DC motor, limited to 150 Nm motor torque."
]
instance HighTorqueServoMotor : DTDFVocab:ActingComponent [
    base:desc "High torque Servo motor interfaces via calibrated PWM (CAN ID 0x201) translating steering angle commands into differential wheel positioning, limited to ±30°."
]

// Physical Sensing Components
instance HokuyoUST10LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 1D LiDAR (range 0.04–8 m, 10° FoV, 15 Hz, 1 k points per sweep) transmits data at 5 Hz via 100 Mbps Ethernet."
    DTDFVocab:producedData LiDARPointCloudFrame
]
instance IntelDeepSenseD435i : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i RGB‑D camera (1280×720 RGB + depth, 30 fps) streams depth and color data, aggregated with LiDAR via PPS synchronization (10 µs precision)."
    DTDFVocab:producedData DepthImageFrame
]

// Data Transmitted (Physical → Virtual)
instance LiDARPointCloudFrame : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LX
]
instance DepthImageFrame : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435i
]

// Enabler: Data Translation FE
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Data Translation front‑end serializes UDP LiDAR frames, performs unit conversion (m → cm), and publishes as ROS 2 topics following ISO 23247."
    DTDFVocab:enables DataTranslationService
]
instance DataTranslationService : DTDFVocab:Service [
    base:desc "Converts LiDAR UDP frames to ROS 2 topic providing standardized point‑cloud stream."
]

// Data Transmitted after conversion
instance LiDARPointCloudROS : DTDFVocab:DataTransmitted [
]
instance DepthImageROS : DTDFVocab:DataTransmitted [
]

// Point‑cloud clustering
instance PointCloudClusteringComponent : DTDFVocab:Enabler [
    base:desc "DBSCAN clustering on LiDARPointCloudROS topic."
    DTDFVocab:enables ClusteringService
]
instance ClusteringService : DTDFVocab:Service [
    base:desc "Clusters point cloud into object footprints."
]
instance ClusterTopic : DTDFVocab:DataTransmitted [
]

// Tracking & path projection
instance PointCloudTrackingComponent : DTDFVocab:Enabler [
    base:desc "Tracks clustered points into object tracks and projects driving path."
    DTDFVocab:enables TrackingService
]
instance TrackingService : DTDFVocab:Service [
    base:desc "Tracks objects from cluster topic, outputs ObjectTrack data."
]
instance ObjectTrackTopic : DTDFVocab:DataTransmitted [
]

instance PathProjectionComponent : DTDFVocab:Enabler [
    base:desc "Projects driving path from tracked objects."
    DTDFVocab:enables PathProjectionService
]
instance PathProjectionService : DTDFVocab:Service [
    base:desc "Computes projected path trajectory."
]
instance PathProjectionTopic : DTDFVocab:DataTransmitted [
]

// Vehicle state & actuation status
instance VehicleStateFE : DTDFVocab:Enabler [
    base:desc "Collects vehicle state (speed, gear, torque) and actuation status for transmission."
    DTDFVocab:enables VehicleStateService
]
instance VehicleStateService : DTDFVocab:Service [
    base:desc "Publishes vehicle state ROS topic."
]
instance VehicleStateTopic : DTDFVocab:DataTransmitted [
]

instance ActuationStatusFE : DTDFVocab:Enabler [
    base:desc "Monitors CAN diagnostics from ESC and Servo."
    DTDFVocab:enables ActuationStatusService
]
instance ActuationStatusService : DTDFVocab:Service [
    base:desc "Publishes actuation status ROS topic."
]
instance ActuationStatusTopic : DTDFVocab:DataTransmitted [
]

// Data Instances (Virtual → Persistence)
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Serialized LiDAR point cloud received on ROS topic (converted to cm)."
    DTDFVocab:inputTo DataTranslationFE
    DTDFVocab:fromData LiDARPointCloudROS
]
instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image from Intel D435i archived in database."
    DTDFVocab:inputTo DataTranslationFE
    DTDFVocab:fromData DepthImageROS
]
instance ClusterData : DTDFVocab:Data [
    base:desc "Clustered point cloud footprint data derived from ClusterTopic."
    DTDFVocab:inputTo PointCloudClusteringComponent
    DTDFVocab:fromData ClusterTopic
]
instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Object tracks with UUID, position, velocity derived from ObjectTrackTopic."
    DTDFVocab:inputTo PointCloudTrackingComponent
    DTDFVocab:fromData ObjectTrackTopic
]
instance PathProjectionData : DTDFVocab:Data [
    base:desc "Projected driving path trajectory derived from PathProjectionTopic."
    DTDFVocab:inputTo PathProjectionComponent
    DTDFVocab:fromData PathProjectionTopic
]
instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state (speed, gear, torque) derived from VehicleStateTopic."
    DTDFVocab:inputTo VehicleStateFE
    DTDFVocab:fromData VehicleStateTopic
]
instance ActuationStatusData : DTDFVocab:Data [
    base:desc "Actuator status (ESC torque, Servo angle) derived from ActuationStatusTopic."
    DTDFVocab:inputTo ActuationStatusFE
    DTDFVocab:fromData ActuationStatusTopic
]

// Acc Computation Offloading
instance AccComputationOffloadingFE : DTDFVocab:Enabler [
    base:desc "Offloads ACC logic to cloud compute, receiving vehicle state and tracking data."
    DTDFVocab:enables AccComputationService
]
instance AccComputationService : DTDFVocab:Service [
    base:desc "Performs lead vehicle detection and desired speed calculation."
]
instance AccLogicModel : DTDFVocab:Model [
    base:desc "ACC logic model implementing state‑machine for adaptive cruise control."
    DTDFVocab:inputTo AccComputationOffloadingFE
]
instance AccDesiredSpeedData : DTDFVocab:Data [
    base:desc "Computed desired speed sent to vehicle actuators."
    DTDFVocab:fromData AccDesiredSpeedTopic
]

instance AccDesiredSpeedTopic : DTDFVocab:DataTransmitted [
]

// Digital Twin Services
instance DataMonitoringFE : DTDFVocab:Enabler [
    base:desc "Provides real‑time telemetry to User via web dashboard."
    DTDFVocab:enables DataMonitoringService
]
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Streams vehicle telemetry, projected path, and object tracks."
    DTDFVocab:provides VehicleTelemetryInsight, ObjectTrackInsight, PathProjectionInsight, SpeedLimitAlert, BrakeForceAnomalyAlert
]

instance RemoteManagementFE : DTDFVocab:Enabler [
    base:desc "Enables remote control of ACC, emergency braking, and target speed."
    DTDFVocab:enables RemoteManagementService
]
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Handles operator control commands."
    DTDFVocab:provides RemoteEnableACC, RemoteDisableACC, EmergencyBrakeCommand, SetDesiredSpeed
]

// Insights
instance VehicleTelemetryInsight : DTDFVocab:Insight [
    base:desc "Provides real‑time vehicle speed, heading, and distance to lead vehicle."
]
instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Shows object tracks with UUID, position, velocity."
]
instance PathProjectionInsight : DTDFVocab:Insight [
    base:desc "Displays projected path trajectory."
]
instance AccDesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Displays computed desired speed for ACC."
]
instance SpeedLimitAlert : DTDFVocab:Insight [
    base:desc "Alert when vehicle speed exceeds speed limit."
]
instance BrakeForceAnomalyAlert : DTDFVocab:Insight [
    base:desc "Alert on brake force anomalies."
]

// Actions
instance RemoteEnableACC : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]
instance RemoteDisableACC : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]
instance EmergencyBrakeCommand : DTDFVocab:Action [
    base:desc "Operator command to initiate emergency braking."
    DTDFVocab:IsAutomatic false
]
instance SetDesiredSpeed : DTDFVocab:Action [
    base:desc "Operator sets desired speed for ACC."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Panel User Interface FE serves as the human‑ops console from which remote management commands are dispatched. Commands are routed through the ROS 2 middleware to the actuation peripherals (Motor Actuation, Steering Servo Actuation), which are connected to the vehicle’s control bus. While the document specifies that control messages flow from the UI to the actuators, it does not provide explicit details regarding command format, authentication, conflict resolution, or feedback mechanisms; consequently, no guarantees on confirmation of command execution are documented."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system enforces a strict temporal synchronisation requirement where the digital twin representation must be updated and accessed with an accuracy of no worse than 100 ms relative to the physical twin. This 100 ms bound is imposed by hardware limitations inherent to the vehicular computing platform, and it directly governs the acceptable end‑to‑end latency for data‑exchange, computation off‑loading, and control actuation between the ROS 2 nodes operating in the Digital Twin Entity, the Physical Twin Entity, and the User Entity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Following ISO 23247 Reference Architecture, each functional element (FE) is mapped to a dedicated ROS 2 package comprising one or more ROS 2 nodes. The overall system adopts an entity‑based hierarchy with three top‑level entities, each mapped to distinct compute platforms. Inter‑entity communication relies on ROS 2 DDS publish/subscribe patterns, enabling real‑time data exchange and coordinated control. The Digital Twin Entity implements data management, analytics, and state‑management services; the Physical Twin Entity hosts sensor/actuator interfaces and processing workloads; and the User Entity provides visualization and control panels. Resource allocation adheres to ISO entity roles, with each the physical compute node hosting the FE packages assigned to its entity, distributing computational load and preserving real‑time constraints. The architecture extends ISO 23247 by introducing a Physical Twin Entity to capture the inherent resources of the automotive platform, thereby affecting ownership and engineering workflows."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS employs a two‑tier communication architecture. Internally, all software components intercommunicate via a ROS 2 network, which uses a publish‑subscribe pattern over shared memory or sockets to deliver low‑latency messages. Externally, the physical sensors and vehicle interfaces are bridged to the Digital Twin through a Wi‑Fi network, with data carried over UDP for efficiency. The design targets an end‑to‑end sensor‑to‑visualization latency below 100 ms; no additional bandwidth, redundancy, or security provisions are outlined in the text."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Each functional entity has been instantiated on a dedicated edge platform. The vehicle‑side Digital Twin runs on an NVIDIA Jetson Orin Nano micro‑computer, providing high‑performance compute for point‑cloud processing and state aggregation. Data storage and reporting services reside on an external device located outside the vehicle, ensuring that persistent logs are kept separate from the on‑board compute. No cluster or cloud deployment models are described, and the architecture assumes a purely on‑device deployment with local persistence."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system conforms to ISO 23247 – Digital Twin Framework for manufacturing (Part 2: Reference Architecture).  It adopts the entity‑based reference architecture defined in the standard, comprising: 1) Observable Manufacturing Element (OME) representing the physical asset or process; 2) Data Collection and Device Control Entity for acquiring sensor data and issuing control commands; 3) Digital Twin Entity that provides the virtual representation; and 4) User Entity that exposes interfaces for monitoring and control.  Each entity is further decomposed into Functional Entities (FEs) responsible for discrete tasks such as data transformation, human‑readable rendering, or actuator interfacing.  While the standard does not prescribe specific implementations, the example demonstrates the use of OPC Unified Architecture (OPC UA) as a communication protocol for device control and data exchange.  The implementation is publicly available on GitHub (https://github.com/McSCert/Automotive-Digital-Twin) and includes a demonstration video (https://youtu.be/Rv-sJJQc3WU), illustrating compliance with the interoperability and data exchange guidelines of ISO 23247."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Compliance with ISO 15622 mandates that the ACC Digital Twin meets specified safety‑critical performance criteria, including failure mode identification through functional safety analysis. In addition, ISO 26262‑1:2018 governs the road vehicle functional safety lifecycle; the ACC system architecture is developed under an ISO 26262 safety case, with hazards classified to ASIL D where required, and a comprehensive risk assessment, fault tree analysis, and FMEA guided by the standard. The V2X communication layer follows 3GPP TS 22.185, which prescribes a security framework based on X.509 certificates for mutual authentication, HMAC‑SHA‑256 for message integrity, and optional payload encryption with AES‑128‑GCM. A secure element holds the private keys, and role‑based access control limits key usage to authorized V2X entities. Fail‑safe mechanisms such as watchdog timers, redundant sensor fusion, and a default braking mode ensure safe operation when aberrant conditions are detected. Threat mitigation strategies include continuous monitoring of message integrity, certificate revocation lists, and segregation of safety‑critical from non‑critical functions to adhere to safety‑critical system considerations."
]