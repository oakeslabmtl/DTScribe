// C3: Physical sensing components
instance LiDAR_Sensor : DTDFVocab:SensingComponent [
    base:desc "High-resolution LiDAR sensor providing raw point‑clouds for environment perception."
]

instance MotorSensor : DTDFVocab:SensingComponent [
    base:desc "Torque sensor measuring motor output."
]

instance SteeringSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor measuring steering angle."
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Speed sensor measuring vehicle velocity."
]

// C4: Physical‑to‑virtual interaction
instance LidarPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDAR_Sensor
]

instance MotorSignalTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSensor
]

instance SteeringSignalTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringSensor
]

instance SpeedSignalTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

// C10: Models/Data
instance ACCAlgorithmModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm computing optimal following speed and braking commands."
    DTDFVocab:inputTo ComputationOffloadingFE
]

instance LidarPointCloudData : DTDFVocab:Data [
    base:desc "Serialized LiDAR point‑cloud data processed by DataTranslationFE into ROS2 message."
    DTDFVocab:fromData LidarPointCloudTransmitted
    DTDFVocab:inputTo DataMonitoringFE
]

instance MotorSignalData : DTDFVocab:Data [
    base:desc "Processed motor sensor data with unit conversion, forwarded by DataTranslationFE."
    DTDFVocab:fromData MotorSignalTransmitted
    DTDFVocab:inputTo DataMonitoringFE, ComputationOffloadingFE
]

instance SteeringSignalData : DTDFVocab:Data [
    base:desc "Processed steering sensor data with unit conversion."
    DTDFVocab:fromData SteeringSignalTransmitted
    DTDFVocab:inputTo DataMonitoringFE, ComputationOffloadingFE
]

instance SpeedSignalData : DTDFVocab:Data [
    base:desc "Processed vehicle speed data."
    DTDFVocab:fromData SpeedSignalTransmitted
    DTDFVocab:inputTo DataMonitoringFE, ComputationOffloadingFE
]

// C11: Enablers
instance DataMonitoringFE : DTDFVocab:Enabler [
    base:desc "FE that streams translated sensor data via ROS2 topics for monitoring."
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingFE : DTDFVocab:Enabler [
    base:desc "FE that offloads ACC algorithm to cloud compute, computing optimal following speed and braking commands."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementFE : DTDFVocab:Enabler [
    base:desc "FE that exposes web‑based UI over Wi‑Fi for remote ACC management."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time vehicle state display, including speed, distance to lead vehicle, and headway; allows view, save, and report generation."
    DTDFVocab:provides VehicleStateInsight, AnomalyDetectionInsight, SaveVehicleDataAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computes optimal following speed and braking profiles in real time, returning commands to ACC controller."
    DTDFVocab:provides OptimalFollowingSpeedInsight, BrakingProfileInsight, ACCCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables remote enabling/disabling of ACC, set desired speed, and emergency braking from a different location."
    DTDFVocab:provides PerformanceMetricsInsight, LogAnalyticsInsight, ACCEnableAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights/Actions
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Live dashboard showing vehicle speed, distance to lead vehicle, and headway measurements."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects anomalous vehicle state using moving averages and 3σ thresholds."
]

instance SaveVehicleDataAction : DTDFVocab:Action [
    base:desc "Saves current vehicle state data for later review and reporting."
    DTDFVocab:IsAutomatic false
]

instance OptimalFollowingSpeedInsight : DTDFVocab:Insight [
    base:desc "Real‑time optimal following speed output from ACC decision algorithm."
]

instance BrakingProfileInsight : DTDFVocab:Insight [
    base:desc "Recommended braking profile based on inter‑vehicle distance."
]

instance ACCCommandAction : DTDFVocab:Action [
    base:desc "ROS2 message carrying commanded speed to ACC controller."
    DTDFVocab:IsAutomatic true
]

instance PerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Aggregated performance metrics and logs for remote monitoring."
]

instance LogAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Analytical view of system logs and anomaly alerts."
]

instance ACCEnableAction : DTDFVocab:Action [
    base:desc "Command to enable or disable ACC system remotely."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets the desired cruising speed for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issues emergency braking command to vehicle."
    DTDFVocab:IsAutomatic false
]

// C17: Environment
instance PhysicalVehicleEnvironment : DTDFVocab:Environment [
    base:contains LiDAR_Sensor, MotorSensor, SteeringSensor, VehicleSpeedSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin emits control commands to the physical vehicle actuators via the Actuation FE hierarchy: Motor Actuation FE and Steering Servo Actuation FE. Commands originate from the Control Panel User Interface FE, are formatted according to ISO 23247 command message conventions (exact field layout not specified), and are transmitted over the ROS 2 network to the actuation controllers that interface with the vehicle’s hardware. Direct confirmation of actuator state or command acknowledgement is not described in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system achieves clock synchronization within a 100 ms window, a requirement driven by hardware limitations and stringent vehicular safety standards. This granularity underpins computation‑offloading and ensures that all physical and digital components share a synchronized notion of time, thereby mitigating latency artifacts in data exchange and control loops."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The orchestration aligns with ISO 23247 Reference Architecture, mapping each software component to a Feature Entity (FE) and implementing these FEs as individual ROS2 packages. Within each package, one or more ROS2 nodes realize specific functionalities. This design defines a clear resource management scheme: the User Entity hosts the User Interface FE (split into visualization and control panel sub-components), the Digital Twin Entity manages data handling and control logic, and the Physical Twin Entity encapsulates device-level processing such as point‑cloud clustering and tracking. The overall system leverages ROS2 middleware for node discovery, topic publication/subscription, and service invocation, thereby coordinating the execution flow across the distributed hardware platform."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system’s software layer uses ROS 2 for intra‑entity communication, which encapsulates messages over UDP when local; inter‑entity communication (Physical Twin ↔ Digital Twin, Digital Twin ↔ User) is performed over a Wi‑Fi network using UDP as the transport protocol. The documents do not provide explicit bandwidth, latency limits, reliability, redundancy, or security protocol (e.g., authentication, encryption) specifications."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Figure 2 and the accompanying text provide a conceptual deployment diagram separating the Physical Twin, Digital Twin, and User entities, but the documents do not detail whether the Digital Twin components run on cloud, edge, or on‑premise hardware, nor do they specify computational or storage resources, scalability strategies, deployment models, or availability guarantees."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system conforms to ISO 23247‑2 (Reference Architecture), employing the mandated entity‑based decomposition: Data Collection and Device Control, Digital Twin, and User entities, each realized as sets of Functional Entities. Communication between entities is implemented over ROS 2 DDS on an Ethernet/Wi‑Fi network; however, the ISO standard itself imposes no specific protocol, merely requiring adherence to its data model and reference APIs. The DT’s data interfaces are expressed through ROS 2 messages based on a common data schema derived from ISO 23247, ensuring interoperability with other ISO‑compliant twins. Compliance is maintained by traceability between the ISO requirement tree and implemented FEs, and by executing a testing plan aligned with ISO 23247 Part 4 (Information Exchange)."
]