// C3: Physical sensing components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "2D laser scanner providing high-resolution environmental mapping with 360° field of view, operating at 10Hz for obstacle detection, localization, and path planning."
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelRealSenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "RGB-D sensor capturing color and depth data (up to 90° FOV) at 30 FPS for 3D reconstruction and spatial awareness using structured light or stereo vision."
    DTDFVocab:producedData CameraDepthData
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor interface collecting real-time vehicle metrics including speed, steering angle, and motor status for system monitoring and control."
    DTDFVocab:producedData VehicleStateData
]

// C4: Physical-to-virtual interaction
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
    base:desc "Raw point cloud data from LiDAR pre-processed into structured object tracks for obstacle detection and environmental mapping."
]

instance CameraDepthData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iCamera
    base:desc "RGB-D data stream capturing color and depth information for 3D spatial awareness and object reconstruction."
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
    base:desc "Real-time vehicle metrics including speed, steering angle, and motor status transmitted for system monitoring and control."
]

instance ProcessedObjectTracks : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR, IntelRealSenseD435iCamera
    base:desc "Structured object tracks derived from fused LiDAR and camera data for real-time obstacle detection and path planning."
]

// C10: Models/Data
instance PointCloudClusteringAndTrackingModel : DTDFVocab:Model [
    base:desc "Software component converting raw LiDAR point clouds into structured object tracks and environmental maps for perception tasks."
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance VehicleStateDataModel : DTDFVocab:Data [
    base:desc "Structured representation of real-time vehicle state metrics (speed, acceleration, steering angle) for monitoring and control."
    DTDFVocab:fromData VehicleStateData
    DTDFVocab:inputTo VehicleStateMonitoringEnabler, ComputationOffloadingEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Processed object tracks and environmental maps derived from fused sensor data for real-time visualization and decision-making."
    DTDFVocab:fromData ProcessedObjectTracks
    DTDFVocab:inputTo DataMonitoringService
]

instance ComputationOffloadingOutputData : DTDFVocab:Data [
    base:desc "Output data from computation offloading service containing ACC commands and system state."
    DTDFVocab:fromData VehicleStateDataModel, ObjectTrackData
    DTDFVocab:inputTo ACCCommandData
]

instance ACCCommandData : DTDFVocab:Data [
    base:desc "Computed Adaptive Cruise Control commands including desired speed and emergency braking instructions for vehicle actuation."
    DTDFVocab:fromData ComputationOffloadingOutputData
    DTDFVocab:inputTo ActuationCommandEnabler
]

// C11: Enablers
instance NVIDIAJetpack50SDK : DTDFVocab:Enabler [
    base:desc "Software Development Kit for autonomy stack development with CUDA-accelerated perception algorithms (object detection, path planning)."
]

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "Modular communication framework supporting real-time data publishing/subscription, service-based remote management, and cross-platform compatibility."
]

instance InfluxDBTimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time-series database for logging vehicle state, sensor data, and ACC commands with sub-millisecond precision."
]

instance GazeboSimulationEnvironment : DTDFVocab:Enabler [
    base:desc "Simulation platform for offline testing of ACC algorithms before deployment on physical twin."
]

instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for processing LiDAR point clouds into structured object tracks and environmental maps."
]

instance VehicleStateMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for real-time vehicle state data collection, processing, and visualization."
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for cloud-based computational delegation of resource-intensive ACC tasks from vehicle ECUs."
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for teleoperation and remote control of ACC functions with safety-critical protocols."
]

instance ActuationCommandEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for translating high-level ACC commands into low-level motor voltage commands for vehicle actuation."
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for serializing and aligning message types, performing unit conversions, and ensuring data consistency across components."
]

instance DataPersistenceEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for storing and retrieving historical vehicle data and sensor information."
]

instance ACCAlgorithmTestingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for testing and validating ACC algorithms in simulated environments."
]

instance WebBasedDashboardEnabler : DTDFVocab:Enabler [
    base:desc "JavaScript/React-based web interface for real-time visualization and operator control of the Digital Twin system."
]

instance ROS2WebToolsEnabler : DTDFVocab:Enabler [
    base:desc "Middleware tools for integrating ROS2 services with web-based user interfaces for real-time data visualization."
]

instance ROS2DDSProtocol : DTDFVocab:Enabler [
    base:desc "Low-latency communication protocol for deterministic messaging between ROS2 nodes in safety-critical applications."
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time state data visualization, reporting, and data logging for operators and developers with low-latency communication."
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Cloud-based delegation of ACC system from vehicle ECUs including lead vehicle detection, desired speed calculation, and actuation command transmission."
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Teleoperation and control of ACC functions with remote enabling/disabling, parameter tuning, and safety-critical command validation."
]

instance DataPersistenceService : DTDFVocab:Service [
    base:desc "Service for saving and generating reports of vehicle state data with sub-millisecond precision logging."
]

instance ACCAlgorithmTestingService : DTDFVocab:Service [
    base:desc "Service for offline testing and validation of ACC algorithms in simulated environments before physical deployment."
]

// C17: Insights/Actions
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of vehicle state data including speed, acceleration, and motor status for operator oversight."
]

instance DrivingPathInsight : DTDFVocab:Insight [
    base:desc "Projection of vehicle driving path based on current state and environmental data for trajectory prediction."
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Real-time display of detected object tracks in proximity for obstacle awareness and collision avoidance."
]

instance ACCCommandAction : DTDFVocab:Action [
    base:desc "Transmission of computed desired speed commands back to vehicle ECUs for execution."
    DTDFVocab:IsAutomatic true
]

instance SafetyCriticalResponseAction : DTDFVocab:Action [
    base:desc "Execution of low-latency safety interventions (e.g., emergency braking) based on real-time sensor data."
    DTDFVocab:IsAutomatic true
]

instance ACCControlAction : DTDFVocab:Action [
    base:desc "Remote enabling/disabling of ACC system via user interface."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Remote triggering of emergency braking commands with safety confirmation protocols."
    DTDFVocab:IsAutomatic false
]

instance ParameterTuningAction : DTDFVocab:Action [
    base:desc "Remote adjustment of ACC parameters including desired speed and safety margins."
    DTDFVocab:IsAutomatic false
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Post-analysis reports of vehicle state and sensor data for troubleshooting and performance evaluation."
]

instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Validation metrics and test results from ACC algorithm testing in simulated environments."
]

// C2: Acting Components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Dedicated hardware module for real-time speed regulation of motorized components with closed-loop control mechanisms."
]

instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator receiving voltage commands for propulsion and directional control with dynamic response tuning."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator receiving voltage commands for steering control with safety interlocks and overcurrent protection."
]

// C10: Additional Models/Data
instance ACCAlgorithmModel : DTDFVocab:Model [
    base:desc "Rule-based or model-driven decision logic for lead vehicle detection and desired speed calculation in ACC systems."
]

instance SimulationEnvironmentModel : DTDFVocab:Model [
    base:desc "Virtual representation of physical environment for offline testing of ACC algorithms in Gazebo or NVIDIA Isaac Sim."
]

// C10: Additional Data
instance HistoricalVehicleData : DTDFVocab:Data [
    base:desc "Archived vehicle state and sensor data for post-analysis and troubleshooting."
    DTDFVocab:fromData VehicleStateData
]

instance SimulationTestData : DTDFVocab:Data [
    base:desc "Test results and performance metrics from offline ACC algorithm testing in simulation environment."
    DTDFVocab:fromData SimulationEnvironmentModel
]

// Relationships between Enablers and Services
GazeboSimulationEnvironment DTDFVocab:enables ACCAlgorithmTestingEnabler
NVIDIAJetpack50SDK DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
ROS2Middleware DTDFVocab:enables VehicleStateMonitoringEnabler, RemoteManagementEnabler, DataTranslationEnabler
InfluxDBTimeSeriesDatabase DTDFVocab:enables DataPersistenceEnabler
PointCloudProcessingEnabler DTDFVocab:enables DataMonitoringService
VehicleStateMonitoringEnabler DTDFVocab:enables DataMonitoringService
ComputationOffloadingEnabler DTDFVocab:enables ComputationOffloadingService
RemoteManagementEnabler DTDFVocab:enables RemoteManagementService
ActuationCommandEnabler DTDFVocab:enables RemoteManagementService
DataTranslationEnabler DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
DataPersistenceEnabler DTDFVocab:enables DataPersistenceService
ACCAlgorithmTestingEnabler DTDFVocab:enables ACCAlgorithmTestingService
WebBasedDashboardEnabler DTDFVocab:enables DataMonitoringService, RemoteManagementService
ROS2WebToolsEnabler DTDFVocab:enables DataMonitoringService
ROS2DDSProtocol DTDFVocab:enables VehicleStateMonitoringEnabler, RemoteManagementEnabler

// Relationships between Services and Insights/Actions
DataMonitoringService DTDFVocab:provides VehicleStateInsight, DrivingPathInsight, ObjectTrackInsight
ComputationOffloadingService DTDFVocab:provides ACCCommandAction, SafetyCriticalResponseAction
RemoteManagementService DTDFVocab:provides ACCControlAction, EmergencyBrakeAction, ParameterTuningAction
DataPersistenceService DTDFVocab:provides HistoricalDataInsight
ACCAlgorithmTestingService DTDFVocab:provides SimulationValidationInsight

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The **Virtual-to-Physical Interaction** in this DTS involves control commands generated by the **Digital Twin Entity** and executed on the **Physical Twin Entity** (vehicle). Key components and flows include:
  1. **Control Commands**:
     - **ACC (Adaptive Cruise Control) Commands**: Generated by the **Controlling FE** (e.g., enable/disable ACC, modify desired speed, emergency braking).
     - **Motor Voltage Commands**: Direct actuation signals sent to the motor (e.g., torque adjustments via voltage modulation).
     - **Steering Commands**: Derived from user inputs or autonomous control logic, forwarded to the **Steering Servo Actuation FE**.
  2. **Command Formats**:
     - Commands are serialized and translated by the **Data Translation FE**, ensuring compatibility between software components and physical actuators.
  3. **Validation and Authentication**: **Not in Document** – No explicit mechanisms (e.g., digital signatures, checksums, or access control) are described for validating or authenticating control commands.
  4. **Feedback Systems**:
     - **Vehicle State Collection**: Post-execution feedback (e.g., actual speed, steering angle) is collected by the **Vehicle State** sensors and transmitted back to the Digital Twin for closed-loop control.
     - **Actuation FE**: While the **Actuation FE** (Motor, Steering Servo) executes commands, no explicit feedback loop from actuators to the Digital Twin is documented beyond the **Vehicle State** data.
  5. **Conflict Resolution**: **Not in Document** – No mechanisms (e.g., priority arbitration, deadlock detection) are specified for resolving conflicts between concurrent control commands.
  6. **Command Execution Confirmation**: **Not in Document** – No acknowledgment or confirmation protocols (e.g., handshakes, status flags) are described for verifying successful execution of commands on physical actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin System (DTS) enforces a **100 ms time synchronization accuracy** between physical and digital components to enable computation offloading and coordination, adhering to hardware limitations. This temporal granularity is critical for safety-critical vehicular applications, where stricter clock synchronization (e.g., sub-100 ms) is mandated by standards but not achievable due to hardware constraints. The system leverages **time synchronization protocols** (unspecified but implied to be ROS2-compatible) to align distributed components, ensuring deterministic behavior for real-time services such as sensor fusion, actuation, and device communication. Latency requirements are implicitly tied to the **100 ms synchronization window**, dictating the maximum acceptable delay for data propagation between the Physical Twin Entity (sensors/actuators) and Digital Twin Entity (data management/control)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DTS follows an **entity-based orchestration pattern** rooted in ISO 23247 RA, with **substantial customizations** to accommodate hardware constraints and functional requirements:
  - **Component Integration**: Software components are mapped to **Functional Entities (FEs)** and deployed as **ROS2 packages**, each containing one or more ROS2 nodes. This modular design enables **loose coupling** between entities (Physical Twin, Digital Twin, User) while enforcing **strict ownership boundaries** for functionalities (e.g., *Data Storage* lacked a natural FE alignment, requiring ad-hoc integration).
  - **Resource Management**: The Physical Twin Entity uniquely hosts **general automotive functionalities** (e.g., *Point Cloud Clustering & Tracking*) alongside resource-specific operations, deviating from ISO 23247’s OME model. This centralization of compute/sensor/actuator resources under one entity **simplifies coordination** but may introduce **engineering complexity** due to cross-entity dependencies.
  - **System-Wide Coordination**: Synchronization is managed via **ROS2’s distributed communication framework**, where nodes across entities exchange data with **100 ms temporal bounds**. The architecture avoids a centralized controller, instead relying on **entity-specific FEs** to handle localized coordination (e.g., the Digital Twin Entity manages control mechanisms, while the Physical Twin Entity handles real-time sensor/actuator tasks)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The document does not provide explicit details on **model fidelity requirements**, **validation and verification (V&V) methods**, **uncertainty quantification**, or **error correction mechanisms**. While the introduction references Digital Twins as 'high-fidelity computational reflections,' the **ISO 23247 Part 2 standard** focuses solely on defining an **entity-based reference architecture** (OME, DTE, Data Collection Entity, User Entity) and does not address fidelity, validation, or quality assurance processes. The standard also notes that **implementation guidelines for Functional Entities (FEs)** are not specified, leaving fidelity considerations undefined."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **Technical Network Infrastructure** of this DTS is designed for real-time communication between entities and software components, with the following specifications:
  1. **Communication Protocols**:
     - **Intra-Entity (ROS2)**: Software components within the Digital Twin Entity communicate via **ROS2**, a middleware framework optimized for real-time data exchange, publish-subscribe messaging, and modularity.
     - **Inter-Entity (Wi-Fi)**: Communication between the **Physical Twin Entity** and **Digital Twin Entity** occurs over a **Wi-Fi network** (protocol unspecified beyond 'using U', but implied to be **UDP** due to real-time constraints and lack of TCP overhead).
  2. **Network Topology and Architecture**:
     - **Decentralized**: The system lacks a centralized controller; instead, components communicate peer-to-peer via ROS2 topics and Wi-Fi broadcasts.
     - **Hierarchical**: The **Data Translation FE** acts as a central translator for all data streams, ensuring format consistency.
  3. **Bandwidth and Latency Requirements**:
     - **Latency**: End-to-end latency must be **at most 100 ms** to support real-time monitoring and control (implied by the need for ACC and visualization updates).
     - **Bandwidth**: **Not explicitly quantified**, but high-bandwidth requirements are inferred for LiDAR point cloud transmission and 3D visualization updates.
  4. **Reliability and Redundancy Mechanisms**: **Not in Document** – No explicit redundancy (e.g., failover nodes, duplicate data paths) or reliability protocols (e.g., QoS guarantees in ROS2) are described.
  5. **Security Protocols**: **Not in Document** – No encryption, authentication, or intrusion detection mechanisms are mentioned for network communication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **Hosting and Deployment Infrastructure** of this DTS is constrained by real-time requirements and hardware limitations, with the following specifics:
  1. **Hosting Platforms**:
     - **Edge Computing**: The system is deployed on **edge devices** (e.g., the vehicle’s onboard computer) to minimize latency. The **NVIDIA Jetson Orin Nano** is explicitly mentioned as hardware for processing LiDAR data and running ROS2 components.
     - **On-Premise**: Data storage and reporting generation occur on a **device external to the vehicle**, likely a local server or workstation for visualization and analysis.
     - **Cloud**: **Not in Document** – No mention of cloud hosting (e.g., AWS, Azure) for storage or computation.
  2. **Computational and Storage Requirements**:
     - **Computational**: High-performance edge devices (e.g., Jetson Orin Nano) handle real-time processing of LiDAR data, point cloud clustering, and control logic.
     - **Storage**: Raw and processed data (e.g., point clouds, reports) are stored on an external device, with no explicit mention of distributed storage or cloud integration.
  3. **Scalability Mechanisms**: **Not in Document** – No dynamic scaling (e.g., container orchestration, load balancing) or modular deployment strategies are described.
  4. **Deployment Models Supported**:
     - **Monolithic**: Components are tightly coupled within the vehicle’s onboard system, with minimal external dependencies.
     - **Containerized**: **Not explicitly mentioned**, but ROS2 supports containerization for component isolation.
  5. **Availability and Reliability Assurance**:
     - **Hardware Redundancy**: **Not in Document** – No redundant Wi-Fi adapters, power supplies, or backup edge devices are mentioned.
     - **Data Replication**: **Not in Document** – No mechanisms for replicating critical data (e.g., LiDAR scans, control logs) across nodes.
     - **Fault Tolerance**: **Not in Document** – ROS2’s inherent fault tolerance (e.g., topic reconnection) is implied but not explicitly configured or tested for this system."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to the **ISO 23247 – Digital twin framework for manufacturing**, specifically **Part 2: Reference Architecture**, which defines:
  - An **entity-based architecture** with standardized roles (OME, Data Collection/Control Entity, Digital Twin Entity, User Entity) to ensure **modularity** and **interoperability**.
  - **Industry-specific compliance** for manufacturing use cases, aligning with **physical-digital integration** principles.
  - **Information exchange guidelines** (e.g., structured data formats, protocol recommendations like **OPC UA** for industrial communication).
  - **No explicit certification requirements** are mentioned, but adherence to ISO 23247 implies **compliance with manufacturing digital twin best practices**.
  The standard does not specify **third-party certification frameworks** (e.g., ISO 9001, IEC 62443) but enforces **interoperability** through its **entity-based modular design** and **data exchange principles**."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system for Adaptive Cruise Control (ACC) adheres to **ISO 15622:2018**, which specifies performance requirements and test procedures for ACC systems, including safety-critical operational constraints. The system integrates **V2X (Vehicle-to-Everything) services** as outlined in **3GPP TS 22.185 (Release 15)**, ensuring low-latency communication (<100 ms) for real-time safety-critical interactions. While the documents do not explicitly detail cybersecurity protocols (e.g., TLS/DTLS, MACs) or fail-safe mechanisms (e.g., redundancy, watchdog timers), they emphasize **functional safety** through standardized test procedures and performance validation. The Digital Twin architecture leverages **ISO 23247 Reference Architecture (RA)** for Digital Twin Systems, which mandates **safety-critical system considerations** in its **Digital Twin System (DTS) requirements**, though specific threat mitigation strategies or access control mechanisms are not elaborated."
]