// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing real‑time point‑cloud streams from the physical twin"
    DTDFVocab:producedData LiDARPointCloudStream
]

instance IntelRealSenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering depth images over Wi‑Fi ROS2 topics"
    DTDFVocab:producedData DepthImageStream
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of vehicle speed (m/s) transmitted via ROS2"
    DTDFVocab:producedData SpeedTelemetryStream
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor reporting steering angle (degrees) over ROS2"
    DTDFVocab:producedData SteeringTelemetryStream
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance LiDARPointCloudStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthImageStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseDepthCamera
]

instance SpeedTelemetryStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringTelemetryStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C10: Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw point‑cloud data from LiDAR used for clustering and tracking"
    DTDFVocab:fromData LiDARPointCloudStream
    DTDFVocab:inputTo MonitoringEnabler, ComputationOffloadingEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames used for environment perception and visualization"
    DTDFVocab:fromData DepthImageStream
    DTDFVocab:inputTo MonitoringEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Timestamped vehicle speed readings required by ACC and UI insights"
    DTDFVocab:fromData SpeedTelemetryStream
    DTDFVocab:inputTo MonitoringEnabler, ComputationOffloadingEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Timestamped steering angle values required by ACC and UI insights"
    DTDFVocab:fromData SteeringTelemetryStream
    DTDFVocab:inputTo MonitoringEnabler, ComputationOffloadingEnabler
]

// C10: Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering algorithm (MATLAB/Simulink) for object segmentation"
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

instance KalmanFilterTrackerModel : DTDFVocab:Model [
    base:desc "Kalman‑filter tracker that fuses clustered points into stable object tracks"
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

instance ACCControllerModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ISO 15622) controller implementing lead‑vehicle detection and speed computation"
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model rendering vehicle state, projected path and object tracks"
    DTDFVocab:inputTo MonitoringEnabler
]

// C11: Enablers
instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 Data Collection Front‑End that aggregates sensor streams for real‑time monitoring"
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 Computation Offloading Front‑End that executes ACC, clustering and tracking models on the external Digital Twin"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "User Interface Front‑End enabling operators to command ACC parameters and emergency braking"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time UI visualisation of vehicle state, projected path, object tracks and generates time‑series reports"
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTracksInsight, ProjectedPathInsight, AnalyticalReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC algorithm (lead‑vehicle detection, speed computation per ISO 15622) in the Digital Twin"
    DTDFVocab:provides ACCComputationInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, adjust desired speed, and trigger emergency braking via UI"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakingAction
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Live visual insight of current vehicle speed and steering angle"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Visualization of detected object tracks from clustering and tracking pipeline"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected trajectory of the autonomous vehicle based on current speed and steering"
]

instance AnalyticalReportInsight : DTDFVocab:Insight [
    base:desc "Time‑series report summarising vehicle performance and detected objects"
]

instance ACCComputationInsight : DTDFVocab:Insight [
    base:desc "Result of ACC computation (desired speed, gap distance, actuation command)"
]

// C17: Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator adjusts the ACC target speed set‑point"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking; sent to ESC"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage command interface controlling vehicle speed via ESC"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator that sets wheel angle"
]

instance EmergencyBrakingActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency braking command sent to the onboard electronic speed controller"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity sends the computed desired speed (ACC output) and remote‑management commands (enable/disable ACC, set desired speed, emergency brake) back to the PT over the same Wi‑Fi/ROS2 channel, where the Actuation FE converts them into motor voltage and servo commands."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is designed for sub‑100 ms end‑to‑end network latency and clock synchronization accuracy of 100 ms, enabling real‑time ACC control loops at the perception‑cycle rate."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 reference model: Physical Twin Entity hosts data pre‑processing and actuation FEs; Digital Twin Entity hosts Data Collecting, Reporting, Presentation, and Controlling FEs; User Entity hosts separate Visualization and Control‑Panel UI FEs; all entities communicate via ROS2 intra‑node messaging and Wi‑Fi inter‑entity links."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is used during the operated (run‑time) stage for monitoring, off‑loading, and remote management, and also supports development‑time troubleshooting of the ACC subsystem."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Sensor data are processed in real time with DBSCAN clustering and Kalman filtering to ensure accurate object tracking; the ACC algorithm adheres to ISO 15622 specifications; latency ≤100 ms and clock sync ≤100 ms are enforced to maintain safety‑critical performance; reporting UI provides verification of system behavior."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The PT communicates with the DT over a Wi‑Fi network using ROS2/DDS as the standardized communication interface (R1); Data Translation FE performs serialization, message‑type alignment, and unit conversion for all exchanged data streams."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the NVIDIA Jetson Orin Nano mounted on the vehicle; Digital Twin Entity is hosted on external compute resources (e.g., cloud or edge server) to provide off‑loaded computation; User Entity runs on a desktop workstation; each entity is packaged as a ROS2 node set."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The design follows ISO 23247 (Digital Twin Manufacturing Framework) for entity and functional decomposition, ISO 15622 for ACC functionality, and uses ROS2 (DDS) as a standardized communication middleware; R1 mandates a standardized interface between all components."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by limiting network latency to ≤100 ms, enforcing clock synchronization within 100 ms, and implementing ACC per ISO 15622; remote management commands are executed through controlled UI interfaces, and the system design acknowledges the safety‑critical nature of off‑loading computation and actuation."
]