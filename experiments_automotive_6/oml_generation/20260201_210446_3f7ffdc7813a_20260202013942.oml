// C3: Physical sensing components
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor on the physical twin providing 3D point‑cloud data of the environment."
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "CAN‑bus vehicle state sensor delivering speed, odometry and heading information."
    DTDFVocab:producedData VehicleStateTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Motor status sensor reporting voltage and current of the speed controller."
    DTDFVocab:producedData MotorStatusTransmitted
]

instance SteeringServoStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Steering servo status sensor delivering current steering angle feedback."
    DTDFVocab:producedData SteeringServoStatusTransmitted
]

// C4: Physical‑to‑virtual data transmission
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance MotorStatusTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance SteeringServoStatusTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoStatusSensor
]

// C10: Raw data instances
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream sampled from the physical twin."
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo PointCloudProcessingNodeEnabler, DataTranslationNodeEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state data (speed, pose, odometry) extracted from CAN bus."
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo DataTranslationNodeEnabler, VisualizationNodeEnabler, ControlPanelNodeEnabler
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Motor voltage and current status originating from the speed controller."
    DTDFVocab:fromData MotorStatusTransmitted
    DTDFVocab:inputTo DataTranslationNodeEnabler, RemoteManagementNodeEnabler
]

instance SteeringServoStatusData : DTDFVocab:Data [
    base:desc "Current steering angle reported by the servo feedback sensor."
    DTDFVocab:fromData SteeringServoStatusTransmitted
    DTDFVocab:inputTo DataTranslationNodeEnabler, RemoteManagementNodeEnabler
]

// C10: Models
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering and Kalman‑filter tracking model that converts raw LiDAR points into object tracks."
    DTDFVocab:inputTo PointCloudProcessingNodeEnabler
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "ACC algorithm executed off‑board that determines lead vehicle and computes a safe following speed."
    DTDFVocab:inputTo ACCComputationNodeEnabler
]

// C4: Model‑output data transmission
instance ObjectTracksTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PointCloudProcessingNodeEnabler
]

instance DesiredSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ACCComputationNodeEnabler
]

// C10: Processed data instances
instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Tracked objects (position, velocity) generated by the clustering & tracking model."
    DTDFVocab:fromData ObjectTracksTransmitted
    DTDFVocab:inputTo VisualizationNodeEnabler, DataStorageNodeEnabler
]

instance DesiredSpeedData : DTDFVocab:Data [
    base:desc "Desired vehicle speed command computed by the ACC model."
    DTDFVocab:fromData DesiredSpeedTransmitted
    DTDFVocab:inputTo ControlPanelNodeEnabler, RemoteManagementNodeEnabler, DataStorageNodeEnabler
]

// C11: Enablers (ROS2 nodes & services)
instance PointCloudProcessingNodeEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 node encapsulating the point‑cloud clustering & tracking model."
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationNodeEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 node that serialises, aligns and converts units of all incoming sensor streams."
    DTDFVocab:enables DataMonitoringService
]

instance ACCComputationNodeEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 node running the off‑board ACC algorithm in the cloud."
    DTDFVocab:enables ComputationOffloadingService
]

instance DataStorageNodeEnabler : DTDFVocab:Enabler [
    base:desc "SQL database component persisting object tracks, vehicle state and speed commands."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance VisualizationNodeEnabler : DTDFVocab:Enabler [
    base:desc "3D visualization component rendering vehicle state and object tracks for the UI."
    DTDFVocab:enables DataMonitoringService
]

instance ControlPanelNodeEnabler : DTDFVocab:Enabler [
    base:desc "Control‑panel UI allowing operators to view data and issue ACC configuration commands."
    DTDFVocab:enables RemoteManagementService
]

instance RemoteManagementNodeEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 service interface exposing enable/disable ACC, set speed, and emergency‑brake commands."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring service displaying real‑time vehicle state, projected path and object tracks, and supporting report generation."
    DTDFVocab:provides RealTimeVehicleStateInsight, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation Offloading service executing the ACC algorithm off‑board and returning a speed command."
    DTDFVocab:provides ComputeDesiredSpeedAction, ACCStatusInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service enabling operators to toggle ACC, set desired speed, and issue emergency braking."
    DTDFVocab:provides ToggleACCAction, EmergencyBrakeAction
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight providing operators with up‑to‑date vehicle pose, speed and heading."
]

instance ACCStatusInsight : DTDFVocab:Insight [
    base:desc "Insight indicating current ACC state (enabled, following distance, target speed)."
]

// C17: Actions
instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Action to generate and export a PDF/CSV report of the collected session data."
    DTDFVocab:IsAutomatic false
]

instance ComputeDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Automatic action that computes the safe following speed based on lead‑vehicle detection."
    DTDFVocab:IsAutomatic true
]

instance ToggleACCAction : DTDFVocab:Action [
    base:desc "Operator‑initiated action to enable or disable the Adaptive Cruise Control function."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Safety‑critical action that commands immediate zero‑velocity to the vehicle."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin computes Adaptive Cruise Control decisions (lead‑vehicle identification, desired speed) and sends control commands back to the vehicle over the same Wi‑Fi UDP link. Commands are packaged by the Data Translation FE into the vehicle’s actuation message format (e.g., desired speed set‑point, ACC enable/disable, emergency brake). The vehicle’s control unit receives the command, validates it, executes the corresponding actuation on motor and steering hardware, and provides implicit acknowledgment through subsequent state updates."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires clock synchronization between devices with an accuracy of 100 ms, which is the maximum tolerance imposed by hardware limitations; this synchronisation frequency is used to enable safe computation off‑loading in the vehicular context."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration follows the ISO 23247 reference architecture, mapping each Functional Entity to a ROS 2 package; each package contains one or more ROS 2 nodes that implement the entity’s functionality. Communication between the Physical Twin Entity (hosting compute, sensors, actuators and services such as Point Cloud Clustering & Tracking), the Digital Twin Entity (handling data pre‑processing, storage and control), and the User Entity (providing 3D visualization and control panels) is realised through ROS 2 publish/subscribe and service mechanisms, enabling component integration and resource management across the distributed hardware."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The architecture requires that all distributed components maintain a common notion of time with a synchronization accuracy of at most 100 ms, as dictated by hardware constraints and safety‑critical timing requirements. Consequently, the communication infrastructure must guarantee clock alignment within this bound, and any computation off‑loading between devices is designed to respect the 100 ms latency ceiling. Temporal fidelity is therefore a primary validation criterion for the twin’s operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Intra‑digital‑twin communication between software components uses ROS 2 (DDS) middleware. Communication between the physical twin and the digital twin occurs over a Wi‑Fi network with UDP as the transport protocol. The topology is a logical client‑server exchange where the vehicle streams sensor data to the DT and receives control messages in return. The system is required to sustain low end‑to‑end latency for safety‑critical ACC operation, but the documents do not give quantitative latency, bandwidth, reliability, redundancy or security protocol details."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The ACC functionality is off‑loaded from the resource‑constrained ECU to the Digital Twin, which can be executed on cloud‑based compute resources or any platform capable of running ROS 2 services. The DT requires sufficient processing power for point‑cloud clustering, tracking, and ACC decision logic, as well as storage for collected vehicle state data and generated reports. The system is designed to maintain low end‑to‑end latency for remote management, though specific hardware, scalability mechanisms, and availability guarantees are not detailed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built on the ISO 23247 Digital Twin framework (parts 1–4), explicitly adopting its entity‑based reference architecture (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity). It acknowledges vehicular safety‑critical clock‑synchronization standards that mandate ≤100 ms accuracy, and mentions the possibility of using OPC Unified Architecture for device communication. The implementation uses ROS2 packages (leveraging DDS) to meet interoperability requirements."
]