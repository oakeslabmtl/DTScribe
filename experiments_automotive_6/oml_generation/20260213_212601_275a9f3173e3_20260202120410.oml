]

instance ACCLogicExecutionEnabler : DTDFVocab:Enabler [
    base:desc "Cloud/edge computing infrastructure executing ACC logic including lead vehicle detection and desired speed computation."
    DTDFVocab:enables ACCControlService
]

instance PathPlanningEnabler : DTDFVocab:Enabler [
    base:desc "Trajectory optimization module using Model Predictive Control (MPC) for driving path planning."
