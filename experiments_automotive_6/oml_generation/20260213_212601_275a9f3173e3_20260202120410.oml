    base:desc "Advanced LiDAR sensor providing raw point cloud data for environmental perception and object detection in autonomous driving applications."
    DTDFVocab:producedData LiDARPointCloudData
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Collection of sensors monitoring vehicle dynamics including motor state, steering angle, servo actuation, and vehicle state for ACC applications."
    DTDFVocab:producedData VehicleStateData
]

instance MotorActuationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring motor actuation commands and states for real-time vehicle dynamics control."
    DTDFVocab:producedData MotorActuationData
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor tracking steering servo commands and angles for precise vehicle trajectory control."
    DTDFVocab:producedData SteeringServoData
]

instance ObjectDetectionCamera : DTDFVocab:SensingComponent [
    base:desc "Camera system providing visual data for supplementary object detection and environmental awareness."
    DTDFVocab:producedData CameraVisualData
]

instance RadarSensor : DTDFVocab:SensingComponent [
    base:desc "Radar sensor providing distance and velocity measurements for lead vehicle detection and adaptive speed control."
    DTDFVocab:producedData RadarMeasurementData
]

// C4: Physical-to-virtual interaction
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    base:desc "Raw and clustered LiDAR point cloud data transmitted from the Physical Twin to Digital Twin via UDP at high frequency (≥10Hz)."
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    base:desc "Comprehensive vehicle state information including motor actuation, steering angle, servo commands, and vehicle dynamics transmitted at high frequency (≥100Hz)."
    DTDFVocab:producedFrom VehicleStateSensor
]

instance MotorActuationData : DTDFVocab:DataTransmitted [
    base:desc "Motor actuation commands and states transmitted from the Physical Twin to Digital Twin for real-time vehicle dynamics control."
    DTDFVocab:producedFrom MotorActuationSensor
]

instance SteeringServoData : DTDFVocab:DataTransmitted [
    base:desc "Steering servo commands and angles transmitted from the Physical Twin to Digital Twin for precise vehicle trajectory control."
    DTDFVocab:producedFrom SteeringServoSensor
]

instance CameraVisualData : DTDFVocab:DataTransmitted [
    base:desc "Visual data from cameras used for supplementary object detection and environmental mapping."
    DTDFVocab:producedFrom ObjectDetectionCamera
]

instance RadarMeasurementData : DTDFVocab:DataTransmitted [
    base:desc "Radar-based distance and velocity measurements for lead vehicle detection and adaptive speed control."
    DTDFVocab:producedFrom RadarSensor
]

instance ObjectTracksData : DTDFVocab:DataTransmitted [
    base:desc "Processed object tracks derived from LiDAR point cloud clustering and tracking for environmental awareness."
    DTDFVocab:producedFrom LiDARSensor
]

instance ProjectedDrivingPathData : DTDFVocab:DataTransmitted [
    base:desc "Derived driving path information based on vehicle state and sensor fusion for trajectory planning."
    DTDFVocab:producedFrom VehicleStateSensor, LiDARSensor, RadarSensor
]

// C10: Models/Data
instance LiDARPointCloudModel : DTDFVocab:Model [
