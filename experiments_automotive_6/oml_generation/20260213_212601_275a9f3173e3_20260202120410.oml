    DTDFVocab:inputTo LiDARPointCloudPreprocessingEnabler
]

instance VehicleStateModel : DTDFVocab:Model [
    base:desc "Behavioral model capturing vehicle dynamics including speed, acceleration, and steering states for real-time control."
    DTDFVocab:inputTo VehicleStateDataTranslationEnabler
]

instance ObjectDetectionModel : DTDFVocab:Model [
    base:desc "Perception model for object detection and tracking using LiDAR and camera data."
