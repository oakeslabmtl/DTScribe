    base:desc "Base hardware layer including actuation systems (throttle, braking) and low-level control units for basic vehicle dynamics."
]

instance UpperLevelChassisComponent : DTDFVocab:Component [
    base:desc "Autonomy layer hosting perception modules (object detection, tracking) and decision-making logic for ACC."
]

