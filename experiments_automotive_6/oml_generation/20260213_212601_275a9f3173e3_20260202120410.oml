    base:desc "Structured LiDAR point cloud data after preprocessing including clustering and tracking for object detection."
    DTDFVocab:fromData LiDARPointCloudData
    DTDFVocab:inputTo LiDARPointCloudPreprocessingEnabler, ObjectTrackingEnabler
]

instance ProcessedVehicleStateData : DTDFVocab:Data [
    base:desc "Standardized vehicle state data with unit conversions and message type alignment for real-time monitoring."
    DTDFVocab:fromData VehicleStateData
    DTDFVocab:inputTo VehicleStateDataTranslationEnabler
]

instance ObjectTracks : DTDFVocab:Data [
    base:desc "Structured object tracks derived from LiDAR point cloud clustering for environmental awareness."
