// ----------------------------------------------------
// C3: Physical sensing components
// ----------------------------------------------------
instance HokuyoLidarSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing raw point clouds over ROS2 topics via Wi‑Fi"
    DTDFVocab:producedData HokuyoLidarDataTransmitted
]

instance IntelDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera providing depth images over ROS2 topics via Wi‑Fi"
    DTDFVocab:producedData IntelDepthCameraDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board vehicle speed sensor publishing speed measurements via ROS2"
    DTDFVocab:producedData VehicleSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor publishing steering angle via ROS2"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// ----------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// ----------------------------------------------------
instance HokuyoLidarDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLidarSensor
]

instance IntelDepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCameraSensor
]

instance VehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// ----------------------------------------------------
// C5: Data objects
// ----------------------------------------------------
instance HokuyoLidarPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data streamed from the vehicle"
    DTDFVocab:fromData HokuyoLidarDataTransmitted
    DTDFVocab:inputTo DataCollectionEnabler
]

instance IntelDepthImageData : DTDFVocab:Data [
    base:desc "Depth image data from Intel D435i camera"
    DTDFVocab:fromData IntelDepthCameraDataTransmitted
    DTDFVocab:inputTo DataCollectionEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed measurement"
    DTDFVocab:fromData VehicleSpeedDataTransmitted
    DTDFVocab:inputTo DataCollectionEnabler, ComputationOffloaderEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle measurement"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo DataCollectionEnabler
]

// ----------------------------------------------------
// C10: Models / Algorithms
// ----------------------------------------------------
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering algorithm used to identify objects"
    DTDFVocab:inputTo DataCollectionEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based tracker for maintaining object tracks"
    DTDFVocab:inputTo DataCollectionEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm compliant with ISO 15222 performance class I"
    DTDFVocab:inputTo ComputationOffloaderEnabler
]

instance ISO15222PerformanceModel : DTDFVocab:Model [
    base:desc "ISO 15222 performance‑class I compliance model for ACC"
    DTDFVocab:inputTo ComputationOffloaderEnabler
]

// ----------------------------------------------------
// C11: Enablers (Functional Entities)
// ----------------------------------------------------
instance DataCollectionEnabler : DTDFVocab:Enabler [
    base:desc "Data Collection FE gathers object tracks and ego‑state, performs serialization, unit conversion and alignment"
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloaderEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that offloads ACC computation to the Digital Twin and returns desired speed"
    DTDFVocab:enables ComputationOffloadingService
]

instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler delivering real‑time UI monitoring of vehicle state, perception and projected path"
    DTDFVocab:enables DataMonitoringService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that lets operators enable/disable ACC, set target speed, trigger emergency brake and generate reports"
    DTDFVocab:enables RemoteManagementService
]

// ----------------------------------------------------
// C6: Services
// ----------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring service displaying speed, steering angle, object tracks and projected path on the UI"
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTracksInsight, ProjectedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation Offloading service runs the ACC algorithm in the DT and returns the desired speed"
    DTDFVocab:provides DesiredSpeedInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service enables operators to control ACC, set target speed, trigger emergency braking and generate mission reports"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetTargetSpeedAction, EmergencyBrakeAction, ReportGenerationInsight
]

// ----------------------------------------------------
// C17: Insights
// ----------------------------------------------------
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Operator view of current vehicle speed and steering angle"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Visual representation of tracked objects around the vehicle"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected future path of the vehicle based on current state and ACC output"
]

instance DesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Desired speed computed by the ACC algorithm"
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Generated mission report stored in the SQL database for post‑mission analysis"
]

// ----------------------------------------------------
// C17: Actions
// ----------------------------------------------------
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets the target speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT, including desired speed values, ACC enable/disable, emergency‑brake signals, and steering adjustments; these are received by the Actuation FE which converts them to motor voltage and servo commands."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is required to maintain end‑to‑end network latency ≤ 100 ms and clock synchronisation accuracy of 100 ms, enabling sub‑100 ms update cycles for sensor acquisition, ACC computation and actuation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall architecture follows the ISO 23247 reference architecture with a Physical Twin Entity (sensors/actuators), Digital Twin Entity (data collection, ACC, reporting, storage), User Entity (visualisation and control UI) and a Cross‑System Data Translation component linking them via ROS2 intra‑entity and Wi‑Fi inter‑entity links."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is used during design‑time for cyber‑physical experimentation, during testing for validation of ACC behaviour, and during operation for real‑time monitoring, remote management and data logging."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Safety‑critical operation is ensured by meeting the ≤ 100 ms latency and clock sync constraints, adhering to ISO 15622 ACC specifications, and using validated perception algorithms (DBSCAN, Kalman filter). Real‑time testing validates model fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses a Wi‑Fi network transporting ROS 2 messages; the Data Translation FE serialises data and performs unit conversion, fulfilling requirement R1 for a standardized communication interface."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the on‑board Jetson Orin Nano, the Digital Twin Entity (ACC, data collection, storage, reporting) runs on a cloud/edge server, and the User Entity UI runs on a separate workstation or laptop. All components are packaged as ROS 2 nodes."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) reference architecture, uses ISO 15622 for ACC behavior, and references ISO/IEC 30173:2023 for digital‑twin terminology; optional OPC UA is mentioned as a possible protocol for Data Translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations include strict latency (≤ 100 ms) and clock synchronisation (≤ 100 ms), compliance with ISO 15622 ACC performance class I, and remote management commands that can affect vehicle motion; no explicit security mechanisms (e.g., authentication) are described in the document."
]