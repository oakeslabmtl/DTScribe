    base:desc "Issues alerts for predicted component failures (engine wear, battery degradation)"
    DTDFVocab:IsAutomatic true
]

instance DemandForecasting : DTDFVocab:Insight [
    base:desc "Predicts energy consumption/demand patterns (traffic, storage systems)"
]

