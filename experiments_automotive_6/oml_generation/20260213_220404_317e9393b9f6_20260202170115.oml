// C2: Acting Components
instance VehicleSteeringActuator : DTDFVocab:ActingComponent [
    base:desc "Physical motor/steering servo commands logged as command events (e.g., actuation thresholds, servo position updates)"
]

instance BatteryChargingRegulator : DTDFVocab:ActingComponent [
    base:desc "Regulates battery charging/discharging cycles for energy storage systems in real-time"
]

instance AutonomousEmergencyBrakingSystem : DTDFVocab:ActingComponent [
    base:desc "Executes real-time decision-making for emergency braking in autonomous vehicles"
]

// C3: Physical Sensing Components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Raw point cloud data capture for 2D/3D spatial coordinates of vehicle states and environmental objects"
    DTDFVocab:producedData LiDARPointCloudData
]

instance VehicleTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Continuous telemetry (motor actuation, steering servo signals, feedback) transmitted as time-series data"
    DTDFVocab:producedData VehicleStateTelemetry
]

instance ActuationFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Logs physical motor/steering servo command events (position updates, thresholds)"
    DTDFVocab:producedData ActuationCommandEvents
]

instance EnvironmentalSensorCluster : DTDFVocab:SensingComponent [
    base:desc "Cross-referenced sensor fusion (LiDAR + camera feeds) for noise mitigation in point cloud clustering"
    DTDFVocab:producedData FusedEnvironmentalData
]

// C4: Data Transmission
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleTelemetrySensor
]

instance ActuationCommandEvents : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ActuationFeedbackSensor
]

instance FusedEnvironmentalData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensorCluster
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous real-time data collection from sensors (e.g., automotive telematics, IIoT) with anomaly detection and fault diagnosis"
    DTDFVocab:provides RealTimeAnomalyDetection, PredictiveMaintenanceAlerts, PerformanceHeatmapVisualization
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Parameter tuning for performance (fuel efficiency, battery lifespan) and resource allocation optimization"
    DTDFVocab:provides PerformanceParameterTuning, EnergyDistributionOptimization, ScenarioBasedTesting
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Failure prediction (engine wear, battery degradation) and demand forecasting (traffic patterns, energy consumption)"
    DTDFVocab:provides FailurePredictionAlerts, DemandForecasting, RiskAssessment
]

instance ControlService : DTDFVocab:Service [
    base:desc "Closed-loop control (adaptive cruise control, battery charging regulation) with real-time decision-making"
    DTDFVocab:provides ClosedLoopControl, EmergencyBraking, FaultIsolation
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D/4D modeling (virtual twins of vehicles, manufacturing plants) with interactive dashboards"
    DTDFVocab:provides VirtualTwinVisualization, RealTimePerformanceMetrics, CollaborativeDashboard
]

// C11: Enablers
instance ROS2Network : DTDFVocab:Enabler [
    base:desc "Intra-entity communication protocol for digital twin components (real-time data processing)"
    DTDFVocab:enables MonitoringService, OptimizationService, ControlService
]

instance WiFiUDPProtocol : DTDFVocab:Enabler [
    base:desc "Inter-entity communication protocol (physical/digital) with 10Hz motor state updates"
    DTDFVocab:enables MonitoringService, VisualizationService
]

instance DataPreProcessingFE : DTDFVocab:Enabler [
    base:desc "Aligns raw LiDAR point clouds into structured tracks via clustering and noise filtering"
    DTDFVocab:inputTo LiDARPointCloudData, FusedEnvironmentalData
]

instance DataCollectionFE : DTDFVocab:Enabler [
    base:desc "Aggregates raw sensor data into standardized formats for translation (e.g., motor/steering logs)"
    DTDFVocab:inputTo VehicleStateTelemetry, ActuationCommandEvents
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Serializes/deserializes data (ROS2 message types), aligns schemas, and performs unit conversions (LiDAR mm→meters)"
    DTDFVocab:inputTo LiDARPointCloudData, VehicleStateTelemetry
]

instance PointCloudClusteringFE : DTDFVocab:Enabler [
    base:desc "Converts LiDAR point clouds into structured object tracks (vehicle states, environmental objects)"
    DTDFVocab:inputTo LiDARPointCloudData
]

instance SimulationEngineANSYS : DTDFVocab:Enabler [
    base:desc "Models physical behavior for digital twins (fluid dynamics, structural analysis)"
    DTDFVocab:inputTo OptimizationService, PredictionService
]

instance AIFrameworkTensorFlow : DTDFVocab:Enabler [
    base:desc "Enables predictive analytics and adaptive learning for real-time control"
    DTDFVocab:inputTo PredictionService, ControlService
]

instance OPCUAProtocol : DTDFVocab:Enabler [
    base:desc "Standardized data exchange and control interface for physical-digital synchronization"
    DTDFVocab:inputTo MonitoringService, VisualizationService
]

instance GraphDatabaseNeo4j : DTDFVocab:Enabler [
    base:desc "Models relationships between entities in cyber-physical systems for fault propagation analysis"
    DTDFVocab:inputTo OptimizationService, ControlService
]

// C10: Models/Data
instance Vehicle3DModel : DTDFVocab:Model [
    base:desc "3D digital representation of vehicle geometry for virtual cockpit visualization"
    DTDFVocab:inputTo SimulationEngineANSYS, VisualizationService
]

instance DrivingPathSimulation : DTDFVocab:Model [
    base:desc "Scenario-based testing model for crash simulations and traffic flow optimization"
    DTDFVocab:inputTo SimulationEngineANSYS, OptimizationService
]

instance BatteryLifecycleModel : DTDFVocab:Model [
    base:desc "Lifecycle analysis model for battery degradation prediction"
    DTDFVocab:inputTo AIFrameworkTensorFlow, PredictionService
]

instance PerformanceKPIModel : DTDFVocab:Model [
    base:desc "Real-time performance metrics model for KPI tracking and heatmaps"
    DTDFVocab:inputTo SimulationEngineANSYS, VisualizationService
]

instance VehicleStateModel : DTDFVocab:Model [
    base:desc "Digital twin of vehicle state tracking for telemetry and actuation feedback"
    DTDFVocab:inputTo DataCollectionFE, ControlService
]

instance EnvironmentalConditionModel : DTDFVocab:Model [
    base:desc "Environmental data model for cross-referenced sensor fusion"
    DTDFVocab:inputTo PointCloudClusteringFE, VisualizationService
]

// C17: Insights/Actions
instance RealTimeAnomalyDetection : DTDFVocab:Insight [
    base:desc "Detects anomalies in sensor data streams for predictive maintenance alerts"
]

