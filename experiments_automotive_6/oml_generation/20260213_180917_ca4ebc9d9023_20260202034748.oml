// C6: Digital Twin Entity Components
instance DigitalTwinController : DTDFVocab:Component [
    base:desc "Central controller managing data processing, computation offloading, and control mechanisms for the Digital Twin"
]

instance ACCSystemOffloader : DTDFVocab:Component [
    base:desc "Component responsible for offloading ACC system computations from constrained ECUs to Digital Twin for enhanced performance"
]

instance RemoteManagementConsole : DTDFVocab:Component [
    base:desc "Remote management interface allowing operators to control ACC system parameters and emergency actions"
]

// C7: Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation component handling serialization, message type alignment, and unit conversions for standardized data transmission"
    DTDFVocab:inputTo MonitoringDashboardService
]

instance WiFiUDPEnabler : DTDFVocab:Enabler [
    base:desc "Wi-Fi UDP communication enabler facilitating real-time data transmission between physical and virtual entities"
    DTDFVocab:inputTo MonitoringDashboardService
]

instance MonitoringDashboardEnabler : DTDFVocab:Enabler [
    base:desc "User interface enabler providing real-time visualization of vehicle state, projected paths, and object tracks"
    DTDFVocab:inputTo MonitoringDashboardService
]

instance ACCOffloadingServiceEnabler : DTDFVocab:Enabler [
    base:desc "Service enabler for ACC computation offloading functionality"
    DTDFVocab:inputTo ACCOffloadingService
]

instance EmergencyBrakeActionEnabler : DTDFVocab:Enabler [
    base:desc "Emergency action enabler for triggering braking commands"
    DTDFVocab:inputTo EmergencyBrakeTriggerAction
]

// C8: Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real-time monitoring service providing user interface for displaying vehicle state data, projected driving paths, and detected object tracks with report generation capabilities"
    DTDFVocab:provides VehicleStateInsight, PathProjectionInsight, ObjectTrackingInsight, ReportGenerationAction
]

instance ACCOffloadingService : DTDFVocab:Service [
    base:desc "Computation offloading service transferring ACC system operations from constrained vehicle ECUs to Digital Twin for enhanced performance"
    DTDFVocab:provides ACCSpeedCalculationAction, ACCActuationCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management service allowing operators to enable/disable ACC, set desired speeds, and trigger emergency braking commands"
    DTDFVocab:provides ACCControlAction, EmergencyBrakeTriggerAction
]

// C9: Insights/Actions
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real-time insight into vehicle state metrics (speed, position, orientation) displayed in the monitoring dashboard"
]

instance PathProjectionInsight : DTDFVocab:Insight [
    base:desc "Visualization of projected driving paths based on sensor data for collision avoidance and route planning"
]

instance ObjectTrackingInsight : DTDFVocab:Insight [
    base:desc "Real-time tracking of detected objects with position, velocity, and trajectory information displayed in the monitoring dashboard"
]

instance ReportGenerationAction : DTDFVocab:Action [
    base:desc "Action allowing users to save and generate performance reports from collected monitoring data"
    DTDFVocab:IsAutomatic false
]

instance ACCSpeedCalculationAction : DTDFVocab:Action [
    base:desc "Action performed by Digital Twin to calculate speed adjustments based on distance to lead vehicle using ACC system algorithms"
    DTDFVocab:IsAutomatic true
]

instance ACCActuationCommandAction : DTDFVocab:Action [
    base:desc "Action executing motor and steering commands based on calculated speed adjustments for adaptive cruise control"
    DTDFVocab:IsAutomatic true
]

instance ACCControlAction : DTDFVocab:Action [
    base:desc "Remote control action enabling/disabling ACC system and setting desired cruise speed parameters"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeTriggerAction : DTDFVocab:Action [
    base:desc "Emergency action triggering immediate braking commands via vehicle actuators for safety interventions"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (e.g., ACC-related signals) from the ACC Controlling FE are transmitted to Motor and Steering Servo actuators via Wi-Fi UDP. The Data Translation component handles serialization and unit conversions for control messages."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires 100 ms clock synchronization accuracy for computation offloading due to hardware limitations, which is less stringent than safety-critical vehicular standards mandating stricter synchronization (<100 ms)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows ISO 23247 RA standards, implemented via ROS2 where each Functional Entity (FE) is encapsulated as an individual ROS2 package containing one or more ROS2 nodes. The Physical Twin Entity, a deviation from ISO 23247's OME, hosts general automotive functionality such as Point Cloud Clustering & Tracking, with all entities deployed on distinct hardware and coordinated through ROS2 communication channels."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Intra-component communication uses ROS2, while inter-entity communication (Physical, Digital, User) occurs over Wi-Fi with UDP transport layer."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247-2:2021 defines a reference architecture with Observable Manufacturing Elements (OME), Data Collection and Device Control Entity, Digital Twin Entity, and User Entity. Functional Entities (FEs) perform tasks such as actuating OME, data transformation, and user interfacing; implementation details are not specified by the standard, with OPC Unified Architecture cited as a potential technology choice."
]