// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor providing raw point cloud data for obstacle detection"
    DTDFVocab:producedData LiDARRawPointCloud
]

instance MotorStateSensor : DTDFVocab:SensingComponent [
    base:desc "Motor state sensor delivering speed and torque information"
    DTDFVocab:producedData MotorStateRawData
]

instance SteeringStateSensor : DTDFVocab:SensingComponent [
    base:desc "Steering state sensor delivering steering angle data"
    DTDFVocab:producedData SteeringStateRawData
]

instance ServoStateSensor : DTDFVocab:SensingComponent [
    base:desc "Servo motor state sensor delivering actuator status data"
    DTDFVocab:producedData ServoStateRawData
]

instance ActuatorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Actuator status sensor streaming real‑time actuator commands"
    DTDFVocab:producedData ActuatorStatusRawData
]

// C4: Physical-to-virtual interaction (Data transmitted from sensors)
instance LiDARRawPointCloud : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance MotorStateRawData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStateSensor
]

instance SteeringStateRawData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringStateSensor
]

instance ServoStateRawData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ServoStateSensor
]

instance ActuatorStatusRawData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ActuatorStatusSensor
]

// C10: Models/Data (processed data after ISO 23247 translation)
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "LiDAR point cloud data after serialization, type alignment, and unit conversion"
    DTDFVocab:fromData LiDARRawPointCloud
    DTDFVocab:inputTo DataTranslationEnabler
]

instance MotorStateData : DTDFVocab:Data [
    base:desc "Motor state data after serialization, type alignment, and unit conversion"
    DTDFVocab:fromData MotorStateRawData
    DTDFVocab:inputTo DataTranslationEnabler
]

instance SteeringStateData : DTDFVocab:Data [
    base:desc "Steering state data after serialization, type alignment, and unit conversion"
    DTDFVocab:fromData SteeringStateRawData
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ServoStateData : DTDFVocab:Data [
    base:desc "Servo state data after serialization, type alignment, and unit conversion"
    DTDFVocab:fromData ServoStateRawData
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ActuatorStatusData : DTDFVocab:Data [
    base:desc "Actuator status data after serialization, type alignment, and unit conversion"
    DTDFVocab:fromData ActuatorStatusRawData
    DTDFVocab:inputTo DataTranslationEnabler
]

// C11: Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Serializes, type‑aligns, and unit‑converts raw sensor data per ISO 23247"
    DTDFVocab:enables ObjectTrackingService, VisionVisualizationService, ACCComputationService, RemoteManagementService, DataCollectionService
]

// C6: Services
instance ObjectTrackingService : DTDFVocab:Service [
    base:desc "Processes LiDAR point cloud into detected object tracks and projected driving path"
    DTDFVocab:provides ObjectTracksInsight
]

instance VisionVisualizationService : DTDFVocab:Service [
    base:desc "Displays real‑time vehicle state, projected path, and detected object tracks in 3D UI"
    DTDFVocab:provides VehicleStateInsight, DrivingPathInsight
]

instance ACCComputationService : DTDFVocab:Service [
    base:desc "Runs ACC algorithm in the cloud and forwards the computed speed command to the vehicle"
    DTDFVocab:provides SpeedCommandAction, ACCPerformanceInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, and issue emergency braking"
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

instance DataCollectionService : DTDFVocab:Service [
    base:desc "Collects telemetry data and generates performance reports for developers"
    DTDFVocab:provides DataCollectionInsight
]

// C17: Insights / Actions
instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Tracks of detected objects derived from LiDAR clustering"
]

instance DrivingPathInsight : DTDFVocab:Insight [
    base:desc "Projected driving path computed from tracking data"
]

instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time vehicle state information such as speed and steering angle"
]

instance ACCPerformanceInsight : DTDFVocab:Insight [
    base:desc "Metrics on ACC algorithm performance and latency"
]

instance DataCollectionInsight : DTDFVocab:Insight [
    base:desc "Aggregated telemetry data for developer reporting"
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Opens or closes the Adaptive Cruise Control system"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets the desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issues an emergency braking command to the vehicle"
    DTDFVocab:IsAutomatic false
]

instance SpeedCommandAction : DTDFVocab:Action [
    base:desc "Sends the computed speed command to vehicle actuators"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Clock synchronization accuracy of 100 ms is required across devices to enable computation offloading in the vehicle. No tighter synchronization is feasible due to hardware limitations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin orchestration follows the ISO 23247 Reference Architecture, mapping each functional element (FE) to a ROS2 package that runs as a node on the vehicle. The architecture separates concerns across three entities: Physical Twin Entity (managing sensors, actuators, and general automotive functions such as point‑cloud clustering & tracking), Digital Twin Entity (housing data management, control mechanisms, and higher‑level modeling), and User Entity (providing a 3D visualization and control‑panel interface). System resources (compute, sensors, actuators) are distributed across these entities, and common ROS2 topics/services enable integration, while the shared high‑precision clock ensures temporal alignment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical communication fabric consists of two layers: an inter‑entity layer that transports high‑rate sensor and actuator data over Wi‑Fi using the UDP protocol, and an intra‑entity layer where ROS 2 nodes publish and subscribe to serialized, unit‑aligned messages on a local ROS 2 network. The architecture does not specify stricter network topologies, bandwidth/latency requirements, reliability, redundancy, or security protocols."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to the ISO 23247 “Digital twin framework for manufacturing” which defines a reference architecture and information exchange model.  It implements the Data Collection and Device Control, Digital Twin, and User entities as specified, and uses OPC Unified Architecture (OPC UA) as a data‑exchange protocol to achieve interoperability with legacy manufacturing equipment and enterprise systems."
]