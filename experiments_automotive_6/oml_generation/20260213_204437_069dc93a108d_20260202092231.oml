// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent, DTDFVocab:Component [
    base:desc "LiDAR sensor mounted on the vehicle, provides raw point‑cloud data for object detection and trajectory projection"
    DTDFVocab:producedData LiDARRawPointCloudDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent, DTDFVocab:Component [
    base:desc "Vehicle state sensor supplying speed, position, and orientation information for real‑time monitoring"
    DTDFVocab:producedData VehicleStateDataTransmitted
]

instance ACCStateSensor : DTDFVocab:SensingComponent, DTDFVocab:Component [
    base:desc "ACC state sensor that reports the current status of the Adaptive Cruise Control system"
    DTDFVocab:producedData ACCCommandDataTransmitted
]

instance SteeringSignalSensor : DTDFVocab:SensingComponent, DTDFVocab:Component [
    base:desc "Steering signal sensor capturing steering wheel angle and command inputs"
    DTDFVocab:producedData SteeringSignalDataTransmitted
]

instance MotorSignalSensor : DTDFVocab:SensingComponent, DTDFVocab:Component [
    base:desc "Motor signal sensor capturing motor command signals"
    DTDFVocab:producedData MotorSignalDataTransmitted
]

// C4: Physical-to-virtual interaction
instance LiDARRawPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Raw LiDAR point‑cloud data transmitted from the vehicle"
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Vehicle state data transmitted from the vehicle"
    DTDFVocab:producedFrom VehicleStateSensor
]

instance ACCCommandDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "ACC command data transmitted from the vehicle"
    DTDFVocab:producedFrom ACCStateSensor
]

instance SteeringSignalDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Steering signal data transmitted from the vehicle"
    DTDFVocab:producedFrom SteeringSignalSensor
]

instance MotorSignalDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Motor signal data transmitted from the vehicle"
    DTDFVocab:producedFrom MotorSignalSensor
]

// C10: Data
instance LiDARRawPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data received from the vehicle"
    DTDFVocab:fromData LiDARRawPointCloudDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state data received from the vehicle"
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
    DTDFVocab:inputTo ACCComputationEnabler
]

instance ACCCommandData : DTDFVocab:Data [
    base:desc "ACC command data received from the vehicle"
    DTDFVocab:fromData ACCCommandDataTransmitted
    DTDFVocab:inputTo RemoteCommandEnabler
]

instance SteeringSignalData : DTDFVocab:Data [
    base:desc "Steering signal data received from the vehicle"
    DTDFVocab:fromData SteeringSignalDataTransmitted
    DTDFVocab:inputTo RemoteCommandEnabler
]

instance MotorSignalData : DTDFVocab:Data [
    base:desc "Motor signal data received from the vehicle"
    DTDFVocab:fromData MotorSignalDataTransmitted
    DTDFVocab:inputTo RemoteCommandEnabler
]

// C10: Models
instance LiDARClusterTrackingModel : DTDFVocab:Model [
    base:desc "Model for clustering raw LiDAR point clouds into object tracks and projected driving paths"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ACCComputationModel : DTDFVocab:Model [
    base:desc "Model implementing ACC algorithm for lead vehicle detection, speed calculation, and desired speed command generation"
    DTDFVocab:inputTo ACCComputationEnabler
]

instance RemoteCommandModel : DTDFVocab:Model [
    base:desc "Model facilitating remote enable/disable of ACC, desired speed adjustment, and emergency braking within safety‑critical latency thresholds"
    DTDFVocab:inputTo RemoteCommandEnabler
]

// C11: Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that serialises, aligns, unit‑converts, and merges LiDAR, vehicle state, and signal streams for downstream services"
    DTDFVocab:enables DataMonitoringService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for ACC algorithm computation carried out on cloud or edge hardware"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteCommandEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for remote enable/disable of ACC, desired speed adjustment, and emergency braking commands"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Web‑based UI that displays real‑time vehicle state, projected trajectory, and detected object tracks, supports capturing and generating structured reports"
    DTDFVocab:provides VehicleStateInsight, ObjectTrackInsight, TrajectoryInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm executed on cloud or edge hardware that returns desired speed commands to the vehicle"
    DTDFVocab:provides GenerateDesiredSpeedCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator interface for remotely enabling/disabling ACC, adjusting desired speed, and issuing emergency braking commands within safety‑critical latency thresholds"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into live vehicle state data displayed on the monitoring dashboard"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Insight on detected object tracks identified via LiDAR processing"
]

instance TrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight on the projected driving trajectory computed from vehicle state and object tracks"
]

// C17: Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable the Adaptive Cruise Control system"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Action to disable the Adaptive Cruise Control system"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to adjust the desired speed setpoint for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to issue an emergency braking command to the vehicle"
    DTDFVocab:IsAutomatic false
]

instance GenerateDesiredSpeedCommandAction : DTDFVocab:Action [
    base:desc "Action generating the desired speed command from the ACC algorithm"
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance ACCActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator responsible for commanding the vehicle’s acceleration/deceleration as dictated by the ACC algorithm output"
]

// Environment and Components
instance VehicleChassis : DTDFVocab:Component [
    base:desc "Lower and upper chassis comprising the vehicle structure"
]

instance AutonomyStack : DTDFVocab:Component [
    base:desc "Autonomy stack including the Adaptive Cruise Control system"
]

instance AutonomousVehicleEnvironment : DTDFVocab:Environment [
    base:contains VehicleChassis, AutonomyStack, LiDARSensor, VehicleStateSensor, ACCStateSensor, SteeringSignalSensor, MotorSignalSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin—such as acceleration set‑points, emergency braking requests, and ACC enable/disable toggles—are transmitted to the Physical Twin over the same Wi‑Fi/UDP link. These commands are serialized and unit‑converted by the ISO 23247 Data Translation FE before being published to the physical twin Fe components. The vehicle’s on‑board actuators execute the commands and echo the resulting actuator state back through the monitoring channel. Conflict resolution is performed by the vehicle’s real‑time control stack, which discards out‑of‑sequence commands and prioritises safety‑critical actions. The DT receives feedback confirming command execution and updates its state accordingly."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin synchronizes its internal clock with the physical twin’s clock using a strict 100 ms accuracy requirement, which translates to a minimum synchronization frequency of 10 Hz. All sensor and actuator timestamps are bound to this 100 ms granularity, and any computation off‑loading between the twin and the vehicle must respect this bound to maintain safety‑critical timing constraints."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system adopts the ISO 23247 Reference Architecture, mapping each Functional Element (FE) to an individual ROS 2 package that contains one or more ROS 2 nodes. Three main entities organize the architecture: the User Entity hosting a split User Interface FE into a 3 D Visualization FE and a Control‑Panel FE; the Digital Twin Entity that aggregates data‑management and control‑FE components; and the Physical Twin Entity that bundles data‑pre‑processing, Point‑Cloud Clustering & Tracking, actuation, and device‑communication FE functions. Each FE is deployed on dedicated hardware, reflecting a decentralized deployment. Component integration relies on ROS 2 topics, services, and actions for inter‑entity communication, while ROS 2 lifecycle management ensures coordinated activation and shutdown. Resource contention is handled by assigning hardware‑specific ROS 2 nodes to the appropriate FE, thereby maintaining functional ownership and enabling on‑board orchestration of the twin’s computational workflow."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The ISO 23247 standard does not prescribe model fidelity requirements, validation or verification methods, uncertainty quantification, or quality assurance processes. These aspects are left to be addressed by the developers within the context of their specific application or by referencing other industry or organization‑specific standards."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin software uses ROS 2 as its middleware for intra‑vehicle component communication, providing real‑time publish/subscribe semantics. Inter‑entity communication between the Physical Twin and Digital Twin is carried out over a Wi‑Fi network with UDP at the transport layer. The link is constrained by a latency requirement of at most 100 ms for latency‑sensitive control and monitoring messages. Reliability is ensured by the Data Translation FE’s checksum detection and retransmission logic; network security relies on standard Wi‑Fi authentication mechanisms without additional application‑layer encryption."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity is deployed on an NVIDIA Jetson Orin Nano microcomputer situated on the vehicle. The board hosts the ROS 2 runtime and runs the data‑translation, monitoring, and control services. Computation and storage are handled locally on the vehicle, providing low‑latency data flow and eliminating WAN dependencies. The deployment is exclusively edge‑based, enabling rapid response to sensor inputs and actuator outputs while preserving the required real‑time constraints."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin adopts ISO 23247 – Digital twin framework for manufacturing, specifically its Part 2 reference architecture that prescribes an entity‑based decomposition into Observable Manufacturing Element (OME), Data Collection & Device Control, Digital Twin and User entities. The architecture supports interoperability through reference to industrial protocols such as OPC Unified Architecture (OPC UA), which is recommended for device communication and data exchange. This compliance ensures alignment with the ISO standard’s guidelines for information exchange and digital representation of physical manufacturing elements."
]