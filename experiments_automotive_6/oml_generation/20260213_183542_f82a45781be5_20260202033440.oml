// C3: Physical sensing components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2D LiDAR mounted on the autonomous vehicle"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera providing RGB‑D images"
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle internal speed measurement from chassis electronics"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle measurement from chassis electronics"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ObjectDetectionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR, IntelRealSenseD435iDepthCamera
]

// C10: Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Point‑cloud data generated by the LiDAR"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image data generated by the RealSense camera"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Current vehicle speed value"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering angle value"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance ObjectDetectionData : DTDFVocab:Data [
    base:desc "Detected and tracked objects (clusters and tracks) from LiDAR & camera"
    DTDFVocab:fromData ObjectDetectionTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

// C10: Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN‑based point‑cloud clustering module"
    DTDFVocab:inputTo DataProcessingEnabler
]

instance KalmanFilterTrackerModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based multi‑object tracker"
    DTDFVocab:inputTo DataProcessingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) model compliant with ISO 15622"
    DTDFVocab:inputTo ComputationOffloadEnabler
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model for vehicle state and projected path"
    DTDFVocab:inputTo DataProcessingEnabler
]

// C11: Enablers
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware + NVIDIA JetPack SDK for on‑board data processing"
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadEnabler : DTDFVocab:Enabler [
    base:desc "Remote cloud compute (NVIDIA Jetson Orin) for ACC algorithm execution"
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi networking and ROS 2 services for operator command handling"
    DTDFVocab:enables RemoteManagementService
]

instance ReportingEnabler : DTDFVocab:Enabler [
    base:desc "SQL database storage and report generation engine"
    DTDFVocab:enables ReportGenerationService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring UI visualising vehicle state, object tracks and projected path"
    DTDFVocab:provides VehicleStateInsight, ObjectTracksInsight, ProjectedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation Offloading – executes the ACC algorithm remotely and returns desired speed"
    DTDFVocab:provides ComputeDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management enabling operators to enable/disable ACC, set speed, trigger emergency brake"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Report Generation of time‑series vehicle data stored in a SQL database"
    DTDFVocab:provides ReportInsight
]

// C17: Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight of vehicle speed and steering angle"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Visualization of detected and tracked objects with IDs and trajectories"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected vehicle path based on current dynamics and ACC plan"
]

instance ReportInsight : DTDFVocab:Insight [
    base:desc "Aggregated time‑series report of vehicle telemetry for post‑mission analysis"
]

// C17: Actions
instance ComputeDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Compute desired speed based on ACC model output"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set operator‑requested desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Trigger emergency braking command"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components (Physical acting components)
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator that converts desired speed into motor voltage commands sent to the ESC"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Servo actuator controlling vehicle steering angle"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator that engages emergency braking command from the DT"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT, including desired speed values for the motor, enable/disable ACC signals, emergency‑braking commands, and steering adjustments, all routed through the Actuation FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All DT services operate in real‑time with an end‑to‑end network latency requirement of ≤100 ms (R7) and clock synchronization accuracy of 100 ms (R8)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation comprises a Physical Twin Entity (data pre‑processing and actuation FEs), a Digital Twin Entity (data collection, reporting, ACC controlling, and presentation FEs), a User Entity (3D visualization and control‑panel UI FEs), and a Cross‑System Data Translation FE; components are deployed on the vehicle, a remote server, and operator workstations."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed primarily in the operational stage to monitor, control, and analyse the running vehicle, while also supporting design‑time experimentation through high‑fidelity simulation components."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT maintains sub‑100 ms latency and clock sync to ensure temporal fidelity; tracking accuracy relies on DBSCAN clustering and Kalman filtering, and ACC behavior follows ISO 15622 specifications, providing a validated functional fidelity for safety‑critical operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑digital communication uses a Wi‑Fi network with data serialized by the Data Translation FE; intra‑entity messaging uses ROS2 topics/services, and optional OPC UA is mentioned as a possible implementation for the Data Translation FE."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity components run on the NVIDIA Jetson Orin Nano aboard the vehicle; the Digital Twin Entity (including ACC computation and database) runs on a remote cloud/edge server; the User Entity UI runs on a workstation connected via the same Wi‑Fi network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Reference Architecture, Functional Entities), uses ISO 15622 for ACC functional requirements, and references ISO/IEC 30173 for digital‑twin terminology."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed for a safety‑critical ACC function with latency and synchronization constraints (≤100 ms); remote management commands (including emergency braking) are supported, but specific security mechanisms (e.g., authentication, encryption) are not described in the document."
]