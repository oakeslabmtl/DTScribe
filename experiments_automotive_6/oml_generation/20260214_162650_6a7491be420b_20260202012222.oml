// ---------- C3: Physical sensing components ----------
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor delivering point‑cloud data from the 1/10‑scale autonomous vehicle"
    DTDFVocab:producedData LiDARPointCloudTransmission
]

instance CameraVisualizationSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board camera used for 3D visualization of the vehicle environment"
    DTDFVocab:producedData CameraFrameTransmission
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑state sensor providing instantaneous speed signals"
    DTDFVocab:producedData VehicleSpeedTransmission
]

instance VehiclePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑state sensor providing position (localisation) data"
    DTDFVocab:producedData VehiclePositionTransmission
]

// ---------- C4: Physical‑to‑virtual interaction ----------
instance LiDARPointCloudTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance CameraFrameTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CameraVisualizationSensor
]

instance VehicleSpeedTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance VehiclePositionTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehiclePositionSensor
]

// ---------- C5: Data objects ----------
instance RawLiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw point‑cloud data as emitted by the LiDAR sensor"
    DTDFVocab:fromData LiDARPointCloudTransmission
    DTDFVocab:inputTo DataProcessingEnabler
]

instance RawCameraFrameData : DTDFVocab:Data [
    base:desc "Raw image frames captured by the on‑board camera"
    DTDFVocab:fromData CameraFrameTransmission
    DTDFVocab:inputTo DataProcessingEnabler
]

instance RawVehicleSpeedData : DTDFVocab:Data [
    base:desc "Unprocessed vehicle speed value"
    DTDFVocab:fromData VehicleSpeedTransmission
    DTDFVocab:inputTo DataProcessingEnabler
]

instance RawVehiclePositionData : DTDFVocab:Data [
    base:desc "Unprocessed vehicle position (localisation) value"
    DTDFVocab:fromData VehiclePositionTransmission
    DTDFVocab:inputTo DataProcessingEnabler
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks derived from LiDAR point‑cloud clustering & Kalman‑filter tracking"
    DTDFVocab:inputTo VisualizationEnabler
]

instance DesiredSpeedData : DTDFVocab:Data [
    base:desc "Desired speed computed by the ACC control model (automatic)"
    DTDFVocab:inputTo ACCComputationEnabler
]

instance NormalizedVehicleData : DTDFVocab:Data [
    base:desc "Unified, unit‑converted vehicle state data after Data Translation"
    DTDFVocab:inputTo RemoteControlEnabler
]

// ---------- C10: Models / analytical components ----------
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering followed by Kalman‑filter tracking on LiDAR point clouds"
    DTDFVocab:inputTo DataProcessingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm: lead‑vehicle detection, inter‑vehicle distance evaluation, desired‑speed computation"
    DTDFVocab:inputTo ACCComputationEnabler
]

instance DataTranslationModel : DTDFVocab:Model [
    base:desc "Serialisation, message‑type alignment and unit conversion for all data streams"
    DTDFVocab:inputTo DataTranslationEnabler
]

// ---------- C11: Enablers ----------
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that runs preprocessing (clustering, tracking, ACC, translation) on incoming raw data"
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:enables ComputationOffloadingService
    DTDFVocab:enables RemoteManagementService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that performs data translation (serialization, unit conversion) for normalized data exchange"
    DTDFVocab:enables RemoteManagementService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that executes the ACC control model to compute desired speed"
    DTDFVocab:enables ComputationOffloadingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that prepares object‑track and vehicle‑state data for UI visualisation"
    DTDFVocab:enables DataMonitoringService
]

instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that forwards operator commands (enable ACC, emergency brake) to the physical actuators"
    DTDFVocab:enables RemoteManagementService
]

// ---------- C6: Services ----------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI service showing vehicle state, projected path, and object tracks; supports data saving and report generation"
    DTDFVocab:provides RealTimeVehicleStateInsight
    DTDFVocab:provides ObjectTrackingInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC algorithm in the digital twin and returns desired speed for actuation"
    DTDFVocab:provides DesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator interface to enable/disable ACC, set desired speed, and issue emergency‑brake commands over low‑latency UDP"
    DTDFVocab:provides EnableACCAction
    DTDFVocab:provides EmergencyBrakeAction
]

// ---------- C17: Insights ----------
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight providing current vehicle speed, position and heading to the operator"
]

instance ObjectTrackingInsight : DTDFVocab:Insight [
    base:desc "Insight displaying live object tracks generated from LiDAR clustering & tracking"
]

// ---------- C17: Actions ----------
instance DesiredSpeedAction : DTDFVocab:Action [
    base:desc "Automatic command to set the vehicle propulsion motor to the desired speed computed by ACC"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Manual operator command to enable the Adaptive Cruise Control function"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Manual operator command to immediately stop the vehicle (emergency brake)"
    DTDFVocab:IsAutomatic false
]

// ---------- C2: Acting components ----------
instance MotorActuatorFE : DTDFVocab:ActingComponent [
    base:desc "Motor actuator that controls vehicle propulsion based on speed commands"
]

instance SteeringServoActuatorFE : DTDFVocab:ActingComponent [
    base:desc "Steering servo that adjusts the vehicle's steering angle based on command inputs"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity generates control commands via the ACC Controlling FE (lead‑vehicle detection and desired‑speed computation) and the User Interface FE (remote‑management commands such as enable/disable ACC, set desired speed, and emergency brake). Commands are transmitted over the ROS 2 network to the Actuation FE deployed on the Physical Twin Entity, where the Actuation component converts the desired speed into motor voltage commands and drives the steering servo. The actuation FE executes the commands on the vehicle; confirmation feedback is implied by the real‑time update of vehicle state data displayed in the UI, although explicit acknowledgement messages are not described."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DTS requires a clock synchronization accuracy of 100 ms between the vehicle’s on‑board sensors/actuators and the digital twin, as mandated by safety‑critical vehicular standards and limited by the hardware; all services (data monitoring, computation off‑loading and remote management) operate in real‑time with low end‑to‑end latency over a Wi‑Fi UDP link, and ROS2 intra‑entity messaging is assumed to be bounded within the same 100 ms window."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration follows the ISO 23247 reference architecture: software components (functional entities) are mapped to ROS2 nodes (FE) and packaged per entity; inter‑entity communication uses a UDP transport over Wi‑Fi, while intra‑entity messaging uses ROS2 DDS topics. The Data Translation FE serialises, aligns message types and performs unit conversions for every data stream, enabling the three services (data monitoring, off‑loading of the ACC algorithm, and remote management) to be composed from the underlying FEs. Resource management is achieved by off‑loading the ACC computation to an external compute node (cloud/edge) while actuation remains on the Physical Twin Entity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS relies on a hybrid network architecture: internal component communication uses ROS 2 packages (publish/subscribe pattern) and inter‑entity communication uses Wi‑Fi with UDP transport. The system requires clock synchronisation within 100 ms accuracy for safety‑critical off‑loading (as mandated by standards for vehicular applications). While specific bandwidth or latency figures are not listed, the requirement for low end‑to‑end latency is emphasised for remote management. No explicit reliability, redundancy, or security protocols (e.g., TLS) are described in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT offloads the ACC computation to a remote platform, which may be cloud‑based, but the documents do not specify the exact hosting environment, computational resources, storage architecture beyond an external SQL database, scalability mechanisms, or availability guarantees. Therefore, concrete hosting and deployment details are not provided."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DTS integrates external standards via the IEC 62541 OPC‑UA specification for the Data Translation FE (optional) and follows the ISO 23247 information‑exchange model. Data streams are exchanged over ROS2 DDS and UDP/Wi‑Fi, enabling interoperability with cloud or edge platforms for computation off‑loading. The architecture also allows optional integration with other enterprise systems through standard OPC‑UA or other middleware, as suggested by the mention of OPC‑UA as an implementation choice for FEs."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built to comply with the ISO 23247 Digital Twin Manufacturing Framework (parts 1‑4), which provides the overall development framework, reference architecture, digital representation of physical elements, and information‑exchange guidelines. Safety considerations are highlighted by recommending alignment with the automotive functional‑safety standard ISO 26262. The implementation also references AUTOSAR as a hardware‑agnostic software architecture model, and suggests the optional use of OPC Unified Architecture (IEC 62541) for the Data Translation FE. By adhering to these standards, the twin aims for interoperability with existing automotive tooling and certification processes, while leveraging the domain‑independent nature of ISO 23247 to integrate domain‑specific technologies such as ROS 2."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The documents address safety considerations for the automotive digital twin system: ISO 26262 functional safety standard is recommended to be promoted to a first‑class citizen for safety‑critical automotive DTs (Document 2), and the ACC functionality is implemented according to ISO 15622 performance class I requirements (Document 5, R6). No specific cybersecurity protocols, access control mechanisms, authentication systems, or threat mitigation strategies are described in the provided documents."
]