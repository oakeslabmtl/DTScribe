// C17: Insights/Actions
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Provides operators with a real‑time visualization of vehicle state and sensor‑derived object tracks"
]

instance DataReportAction : DTDFVocab:Action [
    base:desc "Allows users to generate and save reports of observed vehicle data",
    DTDFVocab:IsAutomatic false
]

instance SpeedCommandInsight : DTDFVocab:Insight [
    base:desc "Shows the computed speed command from the ACC algorithm to be applied to vehicle actuators"
]

instance ACCComputationAction : DTDFVocab:Action [
    base:desc "Executes ACC lead‑vehicle detection and desired‑speed computation in the cloud",
    DTDFVocab:IsAutomatic true
]

instance ACCControlInsight : DTDFVocab:Insight [
    base:desc "Allows operators to enable/disable ACC and set the desired cruising speed via the UI"
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issues an emergency braking command to the vehicle",
    DTDFVocab:IsAutomatic false
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring service displays real‑time vehicle state, projected path, and nearby object tracks allows users to view, save, and generate reports of vehicle data",
    DTDFVocab:provides VehicleStateInsight, DataReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation Offloading service executes the ACC algorithm in the cloud and sends the resulting speed command back to the vehicle for actuation",
    DTDFVocab:provides SpeedCommandInsight, ACCComputationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service enables operators to enable/disable ACC, set desired speed, and issue an emergency‑braking command via the UI",
    DTDFVocab:provides ACCControlInsight, EmergencyBrakeAction
]

// C11: Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware provides real‑time data exchange over ROS2 topics",
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance WiFiUDPEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi UDP link transports sensor data between Physical Twin Entity and Digital Twin Entity",
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance NvidiaJetpackEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK accelerates perception and control algorithms in the cloud",
    DTDFVocab:enables ComputationOffloadingService
]

instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processes LiDAR point clouds (clustering & tracking) for use by visualization and ACC services",
    DTDFVocab:enables DataMonitoringService
]

instance DepthDataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processes depth camera RGB‑D data for 3‑D visualization",
    DTDFVocab:enables DataMonitoringService
]

instance MotorStateProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processes motor state feedback for control and status monitoring",
    DTDFVocab:enables RemoteManagementService
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]

instance MotorStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VedderESC
]

// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing distance measurements as point clouds",
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera providing RGB-D data",
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance VedderESC : DTDFVocab:SensingComponent [
    base:desc "Vedder Electronic Speed Controller reporting motor state feedback",
    DTDFVocab:producedData MotorStateTransmitted
]

// C2: Acting Components
instance VehicleMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Physical motor actuator realized as ROS2 nodes issuing control commands to vehicle motors"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator realized as ROS2 nodes issuing control commands to the steering mechanism"
]

// C5: Data (processed)
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Processed LiDAR point cloud after preprocessing and unit conversion",
    DTDFVocab:fromData LiDARPointCloudTransmitted,
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance DepthCameraRGBDData : DTDFVocab:Data [
    base:desc "Processed RGB‑D data from depth camera after translation",
    DTDFVocab:fromData DepthCameraDataTransmitted,
    DTDFVocab:inputTo DepthDataProcessingEnabler
]

instance MotorStateData : DTDFVocab:Data [
    base:desc "Processed motor state feedback data",
    DTDFVocab:fromData MotorStateTransmitted,
    DTDFVocab:inputTo MotorStateProcessingEnabler
]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Point‑cloud clustering and tracking algorithm used to interpret 3D sensor data for visualization and ACC monitoring",
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance ACCAlgorithmModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm performing lead‑vehicle detection and desired‑speed computation",
    DTDFVocab:inputTo NvidiaJetpackEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin—such as the computed desired speed for the ACC algorithm, ACC enable/disable commands, and emergency‑brake requests—are transmitted back to the physical twin over the same Wi‑Fi UDP link. The commands are consumed by the Actuation FE on the physical side, which translates the desired speed into motor voltage commands and triggers actuation of steering or braking. The documents do not specify explicit validation, authentication, or acknowledgment mechanisms for these command messages."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates with a shared time reference required for computation offloading, enforcing a clock synchronization accuracy of 100 ms across devices; although safety‑critical vehicular standards mandate stricter synchronization, the system limits to 100 ms because of hardware constraints."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall constellation follows the ISO 23247 reference architecture, mapping each functional entity to a ROS2 package that runs on the designated hardware, thereby aligning the Physical Twin Entity (sensor/actuator and preprocessing services), the Digital Twin Entity (data management and control services), and the User Entity (3D visualization and control‑panel services) within an entity‑based modular structure."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS internal software components communicate via a ROS 2 network (publish/subscribe model). Communication between the Physical Twin Entity and the Digital Twin Entity occurs over a Wi‑Fi network using UDP at the transport layer. The documents do not provide quantitative latency, bandwidth, reliability, redundancy, or security specifications."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The computational part of the DT that runs the ACC algorithm is off‑loaded from the resource‑constrained ECU to external compute resources described as “in the cloud”. The DT therefore is deployed on cloud infrastructure that provides sufficient processing and storage for data collection, reporting and remote management. Details on edge or on‑premise deployment, scalability mechanisms or availability guarantees are not provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is explicitly based on the ISO 23247 standard for manufacturing digital twins. ISO 23247 defines four parts: (1) overview and general principles, (2) reference architecture (adopted in the design), (3) digital representation of physical manufacturing elements, and (4) information exchange. The architecture adopts the ISO 23247 entity model—Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, and User Entity—while introducing a Physical Twin Entity to host compute, sensor, and actuator resources. Communication and interoperability are implemented using ROS 2 packages and nodes, not the OPC UA example mentioned in the background. Timing synchronization for distributed computation off‑loading requires a clock accuracy of 100 ms, stated as a hardware limitation, even though many safety‑critical vehicular standards demand tighter synchronization. No additional certification or industry‑specific compliance frameworks are reported in the documents."
]