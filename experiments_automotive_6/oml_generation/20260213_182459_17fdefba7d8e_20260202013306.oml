// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing real‑time point‑cloud data for ego‑vehicle perception"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering depth images of the environment"
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Internal vehicle speed sensor delivering instantaneous ego‑vehicle speed"
    DTDFVocab:producedData SpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor providing the current wheel steering angle"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
    base:desc "Serialized LiDAR point‑cloud transmitted over Wi‑Fi via ROS2 topics"
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
    base:desc "Depth image payload sent over ROS2 topics"
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
    base:desc "Vehicle speed value streamed to the Digital Twin"
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
    base:desc "Steering angle value streamed to the Digital Twin"
]

// C10: Data instances
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud received from the sensor"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationFE, DataCollectingFE, ClusteringTrackingEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image received from the camera"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo DataTranslationFE, DataCollectingFE
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego‑vehicle speed value"
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo DataTranslationFE, DataCollectingFE, ACCControlEnabler, RemoteManagementEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering angle of the vehicle"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo DataTranslationFE, DataCollectingFE, RemoteManagementEnabler
]

// C11: Enablers (Functional Entities)
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "ROS2 node that serializes, unit‑converts and routes sensor streams over Wi‑Fi"
    DTDFVocab:enables DataMonitoringService
]

instance DataCollectingFE : DTDFVocab:Enabler [
    base:desc "ROS2 node that subscribes to sensor topics and aggregates data for downstream modules"
    DTDFVocab:enables DataMonitoringService
]

instance ClusteringTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Processes LiDAR point clouds using DBSCAN clustering and Kalman filter tracking"
    DTDFVocab:enables DataMonitoringService
]

instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "Executes ISO 15622 ACC algorithm to compute desired speed from lead‑vehicle data"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "UI component allowing operators to enable/disable ACC, adjust setpoint, or trigger emergency braking"
    DTDFVocab:enables RemoteManagementService
]

instance ReportingEnabler : DTDFVocab:Enabler [
    base:desc "Generates time‑series reports and stores them in an SQL database"
    DTDFVocab:enables ReportingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Renders speed, steering angle, object tracks and projected path on the operator UI"
    DTDFVocab:enables DataMonitoringService
]

// C10: Models
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering combined with Kalman filter tracking for object detection"
    DTDFVocab:inputTo ClusteringTrackingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "ACC control model conforming to ISO 15622 for lead‑vehicle detection and speed computation"
    DTDFVocab:inputTo ACCControlEnabler
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualization of speed, steering angle, object tracks and projected path"
    DTDFVocab:provides RealTimeVehicleInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC algorithm in the Digital Twin and returns desired speed to the Physical Twin"
    DTDFVocab:provides DesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator UI to enable/disable ACC, modify setpoint, or trigger emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakingAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Generates time‑series reports stored in a SQL database"
    DTDFVocab:provides TimeSeriesReportInsight
]

// C17: Insights / Actions
instance RealTimeVehicleInsight : DTDFVocab:Insight [
    base:desc "Real‑time visual insight of vehicle speed, steering, tracked objects and projected trajectory"
]

instance DesiredSpeedAction : DTDFVocab:Action [
    base:desc "Desired speed command computed by the ACC algorithm"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator enables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator disables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator adjusts the ACC desired speed setpoint"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking"
    DTDFVocab:IsAutomatic false
]

instance TimeSeriesReportInsight : DTDFVocab:Insight [
    base:desc "Time‑series report of vehicle telemetry stored in the SQL database for post‑run analysis"
]

// C2: Acting Components
instance MotorDriveActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller driving propulsion motor, receives voltage commands for desired speed and emergency braking"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Servo motor controlling wheel steering based on steering‑angle commands"
]

instance ActuationFEActuator : DTDFVocab:ActingComponent [
    base:desc "Function element converting desired speed into motor voltage and applying emergency‑braking commands"
]

// C5: Environment
instance VehicleEnvironment : DTDFVocab:Environment [
    base:contains HokuyoLiDAR, IntelDepthCamera, VehicleSpeedSensor, SteeringAngleSensor,
                MotorDriveActuator, SteeringServoActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT sends ACC control commands (desired speed, enable/disable ACC, emergency‑brake) and actuation voltage set‑points back to the PT over the same Wi‑Fi link; commands are issued by the Controlling FE (ACC) and Actuation FE and executed by the motor/steering actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with end‑to‑end network latency bounded to ≤100 ms (per 3GPP TS 22.185) and clock synchronization accuracy of 100 ms across all DT components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A coordinated constellation where the Physical Twin Entity provides sensor data and actuation, the Digital Twin Entity hosts the ACC algorithm, data collection, storage and visualization, and the User Entity offers a 3D visualization and control‑panel UI; all entities communicate via standardized ROS2 interfaces and a Wi‑Fi link."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT supports the design/verification stage (simulation‑based testing), development stage (troubleshooting with data collection), and operational stage (runtime monitoring, control and remote management of the ACC system)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity sensor data (LiDAR point clouds) processed with DBSCAN/Kalman filter; ACC algorithm conforms to ISO 15622; latency ≤100 ms and clock sync ≤100 ms ensure temporal fidelity; safety‑critical nature imposes real‑time constraints and validation through on‑board testing."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional Wi‑Fi link between PT and DT; intra‑entity communication via ROS2 (publish/subscribe) using the Data Translation FE for serialization and unit conversion; optional OPC UA mentioned as a possible transport but not used."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the on‑board NVIDIA Jetson Orin Nano; Digital Twin Entity runs on an external compute platform (cloud or workstation) hosting ROS2 nodes for ACC, data collection, storage and visualization; User Entity UI runs on a workstation connected to the DT via the same network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Architecture follows ISO 23247 (Digital Twin Manufacturing Framework) entity model; ACC functionality complies with ISO 15622; communication latency benchmark follows 3GPP TS 22.185; ROS2 provides an open‑source middleware standard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical operation mandates latency ≤100 ms and clock sync ≤100 ms; remote commands include emergency braking; however, specific cybersecurity mechanisms (e.g., authentication, encryption) are not described in the document."
]