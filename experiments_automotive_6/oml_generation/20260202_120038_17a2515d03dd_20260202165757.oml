// C2: Acting Components
instance VehicleSteeringActuator : DTDFVocab:ActingComponent [
    base:desc "Motor/steering actuation signals processed via Data Pre-Processing FE modules for vehicle control"
]

instance VehicleMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Actuation commands for vehicle motors processed through ROS2-based software components"
]

// C3: Physical sensing components
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "High-fidelity LiDAR sensors capturing 2D plane data for vehicle environment mapping"
    DTDFVocab:producedData VehicleLiDARPointCloudData
]

instance MotorPerformanceSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors monitoring motor performance metrics for predictive analytics"
    DTDFVocab:producedData MotorPerformanceMetricsData
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensors providing real-time input for adaptive control systems"
    DTDFVocab:producedData SteeringAngleData
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors capturing vehicle state metrics (position, speed) for real-time monitoring"
    DTDFVocab:producedData VehicleStateMetricsData
]

instance DataCollectionDevice : DTDFVocab:SensingComponent [
    base:desc "Data Collection FE handling aggregated logs (e.g., ACC-related controls, SW logs)"
    DTDFVocab:producedData SystemLogData
]

instance PreProcessingDataSensor : DTDFVocab:SensingComponent [
    base:desc "Data Pre-Processing FE modules filtering noise and normalizing data streams"
    DTDFVocab:producedData ProcessedDataStream
]

// C4: Physical-to-virtual interaction
instance VehicleLiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance MotorPerformanceMetricsData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPerformanceSensor
]

instance SteeringAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance VehicleStateMetricsData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance SystemLogData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DataCollectionDevice
]

instance ProcessedDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PreProcessingDataSensor
]

// C10: Models/Data
instance VehicleStateModel : DTDFVocab:Model [
    base:desc "Geometric and behavioral model representing vehicle state derived from operational data"
    DTDFVocab:inputTo PointCloudProcessingEnabler, DataTranslationEnabler
]

instance ObjectTrackingModel : DTDFVocab:Model [
    base:desc "Model generating structured object tracks from raw LiDAR point clouds"
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance VehiclePerformanceModel : DTDFVocab:Model [
    base:desc "Behavioral model simulating vehicle performance metrics for predictive analytics"
    DTDFVocab:inputTo MotorPerformanceEnabler
]

instance LiDARCoordinateModel : DTDFVocab:Model [
    base:desc "Model converting LiDAR coordinates to digital twin coordinates via data translation"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ProcessedDataStorage : DTDFVocab:Data [
    base:desc "Aggregated processed data for storage and historical analysis"
    DTDFVocab:fromData ProcessedDataStream
    DTDFVocab:inputTo DataStorageEnabler
]

instance RawSensorData : DTDFVocab:Data [
    base:desc "Raw sensor data collected from vehicle components"
    DTDFVocab:fromData VehicleLiDARPointCloudData, MotorPerformanceMetricsData,
                        SteeringAngleData, VehicleStateMetricsData, SystemLogData
    DTDFVocab:inputTo DataCollectionEnabler
]

// C11: Enablers
instance ROS2CommunicationEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 (Robot Operating System 2) framework enabling real-time message passing between components"
    DTDFVocab:enables RealTimeDataProcessingService
]

instance WiFiTransportEnabler : DTDFVocab:Enabler [
    base:desc "Wi-Fi (UDP transport layer) for inter-entity communication between Digital Twin and User Entity"
    DTDFVocab:enables UserInterfaceService
]

instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Software component processing LiDAR point clouds into structured object tracks and vehicle state representations"
    DTDFVocab:enables ObjectTrackingService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation FE serializing, aligning message types, and performing unit conversions (e.g., LiDAR coordinates)"
    DTDFVocab:enables ModelAlignmentService
]

instance DataPreProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Pre-processing FE modules filtering noise and normalizing data streams (e.g., clustering raw LiDAR points)"
    DTDFVocab:enables DataQualityService
]

instance DataCollectionEnabler : DTDFVocab:Enabler [
    base:desc "Data Collection FE handling aggregated logs (e.g., ACC-related controls, SW logs) for storage"
    DTDFVocab:enables LogManagementService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "System for persistent storage of raw and processed data"
    DTDFVocab:enables HistoricalAnalysisService
]

instance OPCUACommunicationEnabler : DTDFVocab:Enabler [
    base:desc "OPC Unified Architecture for FE implementation enabling seamless integration with industrial devices"
    DTDFVocab:enables PredictiveAnalyticsService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D Visualization FE integrating processed data into virtual cockpit for real-time monitoring"
    DTDFVocab:enables InteractiveDashboardService
]

// C6: Services
instance RealTimeDataProcessingService : DTDFVocab:Service [
    base:desc "Real-time processing of sensor data via FE-driven predictive analytics using OPC UA data streams"
    DTDFVocab:provides VehiclePerformanceInsight, AnomalyDetectionInsight
]

instance ObjectTrackingService : DTDFVocab:Service [
    base:desc "Generating structured object tracks from LiDAR point clouds for vehicle state representation"
    DTDFVocab:provides ObjectDetectionAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "FE-driven predictive analytics for failure prediction using low-latency OPC UA data streams"
    DTDFVocab:provides FailurePredictionInsight
]

instance ModelAlignmentService : DTDFVocab:Service [
    base:desc "Ensuring real-time alignment between Physical Twin Entity and Digital Twin Entity via data translation"
    DTDFVocab:provides DataConsistencyAction
]

instance DataQualityService : DTDFVocab:Service [
    base:desc "Ensuring data quality through noise filtering and normalization in pre-processing FE modules"
    DTDFVocab:provides DataValidationInsight
]

instance LogManagementService : DTDFVocab:Service [
    base:desc "Handling aggregated logs for storage and presentation via Reporting FE"
    DTDFVocab:provides LogReportAction
]

instance HistoricalAnalysisService : DTDFVocab:Service [
    base:desc "Providing historical data analysis capabilities for long-term system monitoring"
    DTDFVocab:provides TrendAnalysisInsight
]

instance InteractiveDashboardService : DTDFVocab:Service [
    base:desc "3D visualization interface presenting real-time metrics in virtual cockpit"
    DTDFVocab:provides DashboardVisualizationAction
]

instance UserInterfaceService : DTDFVocab:Service [
    base:desc "Standardized interfaces (web/mobile) controlled by User Entities presenting FE-generated insights"
    DTDFVocab:provides UserFeedbackAction
]

