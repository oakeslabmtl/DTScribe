    base:desc "Action triggering object detection and tracking from LiDAR point clouds for state representation"
    DTDFVocab:IsAutomatic true
]

instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics results indicating potential equipment failures based on operational data"
]

instance DataConsistencyAction : DTDFVocab:Action [
    base:desc "Action ensuring real-time alignment between physical and digital twin entities through data translation"
    DTDFVocab:IsAutomatic true
]

instance DataValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results confirming data quality through noise filtering and normalization processes"
]

instance LogReportAction : DTDFVocab:Action [
    base:desc "Action generating and storing aggregated log reports for system monitoring"
    DTDFVocab:IsAutomatic true
]

