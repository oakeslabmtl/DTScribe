instance VehiclePerformanceInsight : DTDFVocab:Insight [
    base:desc "Real-time operational insights on vehicle performance metrics generated by FE visualization components"
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Processed insights identifying operational anomalies in vehicle systems via predictive analytics"
]

