// C2: Acting Components
instance PhysicalTwinActuationController : DTDFVocab:ActingComponent [
    base:desc "Manages data pre-processing, actuation commands, and device communication for the Physical Twin Entity in the decentralized architecture, handling real-time control operations for the teleoperated autonomous vehicle's ACC system."
]

instance DigitalTwinControlManager : DTDFVocab:ActingComponent [
    base:desc "Handles computation offloading for ACC system components (lead vehicle detection, speed computation, actuation commands) by offloading from vehicle ECUs to cloud infrastructure, enabling remote management capabilities."
]

// C3: Physical Sensing Components
instance LiDARDataCollector : DTDFVocab:SensingComponent [
    base:desc "Collects raw LiDAR sensor data from the physical vehicle chassis components for object detection and tracking in the Adaptive Cruise Control (ACC) system."
    DTDFVocab:producedData RawLiDARPointCloudData
]

instance MotorStateSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors real-time motor state parameters (speed, torque) from the vehicle's lower chassis layer for ACC system feedback."
    DTDFVocab:producedData MotorStateParameters
]

instance SteeringServoMonitor : DTDFVocab:SensingComponent [
    base:desc "Tracks steering servo position and control signals from the vehicle's upper chassis layer for autonomous steering coordination."
    DTDFVocab:producedData SteeringControlData
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Collects comprehensive vehicle state data (position, velocity, acceleration) from resource-constrained ECUs for real-time ACC system operation."
    DTDFVocab:producedData VehicleStateMetrics
]

// C4: Data Transmission Components
instance RawLiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARDataCollector
]

instance MotorStateParameters : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStateSensor
]

instance SteeringControlData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoMonitor
]

instance VehicleStateMetrics : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance ProjectedDrivingPathData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DataTranslationService
]

instance ObjectTrackData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PointCloudClusteringService
]

// C10: Models/Data
instance VehicleStateDatabase : DTDFVocab:Model [
    base:desc "Stores historical vehicle state data for post-processing analysis and trend detection in the ACC system."
    DTDFVocab:inputTo DataTranslationService
]

instance ObjectTrackingModel : DTDFVocab:Model [
    base:desc "Processes raw LiDAR point clouds into clustered and tracked object data for ACC system object detection and avoidance."
    DTDFVocab:inputTo PointCloudClusteringService
]

instance ProjectedPathModel : DTDFVocab:Model [
    base:desc "Generates projected driving paths based on current vehicle state and environmental conditions for ACC system guidance."
    DTDFVocab:inputTo DataTranslationService
]

instance MotorControlParameters : DTDFVocab:Data [
    base:desc "Processed motor control parameters derived from raw sensor data for real-time actuation commands in the ACC system."
    DTDFVocab:fromData MotorStateParameters
    DTDFVocab:inputTo PhysicalTwinActuationController
]

instance SteeringCommandData : DTDFVocab:Data [
    base:desc "Processed steering commands derived from sensor feedback for autonomous vehicle steering coordination."
    DTDFVocab:fromData SteeringControlData
    DTDFVocab:inputTo PhysicalTwinActuationController
]

instance RealTimeVehicleState : DTDFVocab:Data [
    base:desc "Current real-time vehicle state metrics (position, velocity, acceleration) for ACC system operation."
    DTDFVocab:fromData VehicleStateMetrics
    DTDFVocab:inputTo DigitalTwinControlManager
]

instance DetectedObjectTrajectories : DTDFVocab:Data [
    base:desc "Tracked object trajectories derived from LiDAR point cloud processing for ACC system awareness."
    DTDFVocab:fromData ObjectTrackData
    DTDFVocab:inputTo DigitalTwinControlManager
]

instance VisualizationDataBundle : DTDFVocab:Data [
    base:desc "Comprehensive data bundle for real-time visualization including vehicle state, projected paths, and object tracks."
    DTDFVocab:fromData ProjectedDrivingPathData, ObjectTrackData, VehicleStateMetrics
]

// C11: Enablers
instance DataTranslationService : DTDFVocab:Enabler [
    base:desc "Performs data serialization, message type alignment, and unit conversions between physical vehicle data formats and digital twin standards."
]

instance PointCloudClusteringService : DTDFVocab:Enabler [
    base:desc "Processes raw LiDAR point clouds into clustered and tracked object data for ACC system awareness."
]

instance ROS2CommunicationBridge : DTDFVocab:Enabler [
    base:desc "Manages internal communication between software components using ROS2 messaging framework."
]

instance WiFiUDPTransport : DTDFVocab:Enabler [
    base:desc "Handles inter-entity communication between Physical Twin and Digital Twin entities using Wi-Fi UDP transport layer."
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides real-time visualization of vehicle state data, projected driving paths, detected object tracks, and reporting capabilities for operators and developers."
    DTDFVocab:enables DataTranslationService, ROS2CommunicationBridge
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC system components (lead vehicle detection, speed computation, actuation commands) from vehicle ECUs to cloud infrastructure."
    DTDFVocab:enables DataTranslationService, PointCloudClusteringService
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to enable/disable ACC, set desired speed, and send emergency braking commands via UI for Human-in-the-Loop operation."
    DTDFVocab:enables ROS2CommunicationBridge
]

// C17: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides real-time 3D visualization of vehicle state, projected driving paths, and detected objects for ACC system monitoring."
    DTDFVocab:provides DataMonitoringService
]

instance OperationalReportingAction : DTDFVocab:Action [
    base:desc "Generates and sends operational reports containing vehicle state metrics, object detection results, and system performance data."
    DTDFVocab:IsAutomatic true
    DTDFVocab:provides DataMonitoringService
]

instance LeadVehicleDetection : DTDFVocab:Insight [
    base:desc "Detects lead vehicle in the driving lane using LiDAR and object tracking algorithms for ACC system coordination."
    DTDFVocab:provides ComputationOffloadingService
]

instance SpeedComputationAction : DTDFVocab:Action [
    base:desc "Computes safe following speed based on distance to lead vehicle and vehicle capabilities for ACC system operation."
    DTDFVocab:IsAutomatic true
    DTDFVocab:provides ComputationOffloadingService
]

// C17: Environment Components
instance UserEntityEnvironment : DTDFVocab:Environment [
    base:contains 3DVisualizationInterface, ControlPanelInterface
    DTDFVocab:hasEnvironment DecentralizedDigitalTwinSystem
]

instance DigitalTwinEntityEnvironment : DTDFVocab:Environment [
    base:contains DataTranslationService, PointCloudClusteringService, ROS2CommunicationBridge, WiFiUDPTransport
    base:isContainedIn DecentralizedDigitalTwinSystem
]

instance PhysicalTwinEntityEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinActuationController, MotorStateSensor, SteeringServoMonitor, LiDARDataCollector, VehicleStateSensor
    base:isContainedIn DecentralizedDigitalTwinSystem
]

instance DecentralizedDigitalTwinSystem : DTDFVocab:Environment [
    base:contains UserEntityEnvironment, DigitalTwinEntityEnvironment, PhysicalTwinEntityEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (e.g., motor actuation, steering servo) are generated by the Controlling FE, translated via the Data Translation component, and transmitted over Wi-Fi UDP to the Actuation FE. ROS2 handles internal software component communication within the Digital Twin system."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires 100 ms clock synchronization accuracy for computation offloading in safety-critical vehicular applications, as mandated by industry standards and constrained by hardware limitations, ensuring temporal consistency between physical and digital components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Architected using ISO 23247 Reference Architecture (RA), software components are mapped to Functional Entities (FEs) implemented as ROS2 packages. Each FE is realized as ROS2 nodes organized into three entities: User Entity (with 3D Visualization and Control Panel), Digital Twin Entity (data management and control), and Physical Twin Entity (data pre-processing, actuation, and Point Cloud Clustering & Tracking), with the Physical Twin Entity representing a deviation from ISO 23247 by hosting general automotive functionality."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Internal communication between software components uses ROS2; inter-entity communication (e.g., between Physical Twin and Digital Twin entities) occurs over Wi-Fi using UDP transport layer. No details on bandwidth, latency, network topology, redundancy, or security protocols are specified."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with ISO 23247 standard, which includes four parts: Overview and general principles, Reference architecture, Digital representation of physical manufacturing elements, and Information exchange. Interoperability standards such as OPC Unified Architecture (OPC UA) are referenced for data collection and device control entity implementations."
]