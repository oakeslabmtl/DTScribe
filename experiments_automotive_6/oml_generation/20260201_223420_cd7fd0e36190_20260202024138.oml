// -------------------------------
// 1. Physical Sensing Components
// -------------------------------
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR range‑finding sensor generating point‑cloud data used by the clustering and tracking model."
    DTDFVocab:producedData LiDARDataTransmitted
]

instance DepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Depth‑camera sensor providing point‑cloud measurements for object detection."
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance MotorSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor rotational speed of the 1/10‑scale autonomous vehicle."
    DTDFVocab:producedData MotorSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting the steering wheel angle of the vehicle."
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

instance ServoStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor indicating the status (on/off, fault) of vehicle servos."
    DTDFVocab:producedData ServoStatusDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Aggregator sensor exposing vehicle state information (pose, velocity, battery)."
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// ---------------------------------
// 2. Data Transmitted (Physical→Virtual)
// ---------------------------------
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "LiDAR point‑cloud stream serialized, aligned and unit‑converted by the Data Translation element, delivered via Wi‑Fi UDP."
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Depth‑camera point‑cloud stream processed through the Data Translation pipeline."
    DTDFVocab:producedFrom DepthCameraSensor
]

instance MotorSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Motor speed measurements transmitted after UDP transport and unit conversion."
    DTDFVocab:producedFrom MotorSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Steering angle values transmitted over the low‑latency Wi‑Fi link."
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ServoStatusDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Servo status bits transmitted via the UDP channel."
    DTDFVocab:producedFrom ServoStatusSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Vehicle state bundle (pose, speed, battery) delivered to the digital twin."
    DTDFVocab:producedFrom VehicleStateSensor
]

// -------------------------------
// 3. Data (Digital Twin side)
// -------------------------------
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data after reception and conversion."
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo DataPreProcessingFE, VisualizationFE
]

instance DepthCameraPointCloudData : DTDFVocab:Data [
    base:desc "Depth‑camera point‑cloud data after conversion."
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo DataPreProcessingFE, VisualizationFE
]

instance MotorSpeedData : DTDFVocab:Data [
    base:desc "Motor speed value ready for use by control logic."
    DTDFVocab:fromData MotorSpeedDataTransmitted
    DTDFVocab:inputTo DataPreProcessingFE, ControlPanelFE
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle measurement ready for downstream processing."
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo DataPreProcessingFE, ControlPanelFE
]

instance ServoStatusData : DTDFVocab:Data [
    base:desc "Current servo status flags."
    DTDFVocab:fromData ServoStatusDataTransmitted
    DTDFVocab:inputTo DataPreProcessingFE, ControlPanelFE
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Aggregated vehicle state (pose, velocity, battery) after translation."
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo DataPreProcessingFE, ControlPanelFE, VisualizationFE
]

// -------------------------------
// 4. Models / Computational Elements
// -------------------------------
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Behavioral analytical model that clusters raw point clouds and produces object tracks."
    DTDFVocab:inputTo DataPreProcessingFE
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "Analytical model computing desired speed and lead‑vehicle detection for Adaptive Cruise Control."
    DTDFVocab:inputTo AdaptiveCruiseControlFE
]

// -------------------------------
// 5. Enablers (Functional Entities)
// -------------------------------
instance DataPreProcessingFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that performs sensor pre‑processing, clustering, and tracking."
    DTDFVocab:enables DataMonitoringService
]

instance AdaptiveCruiseControlFE : DTDFVocab:Enabler [
    base:desc "Functional Entity hosting the Adaptive Cruise Control algorithm."
    DTDFVocab:enables ComputationOffloadingService
]

instance ControlPanelFE : DTDFVocab:Enabler [
    base:desc "User‑interface functional entity offering remote control actions."
    DTDFVocab:enables RemoteManagementService
]

instance VisualizationFE : DTDFVocab:Enabler [
    base:desc "3‑D visualisation functional entity rendering vehicle state and object tracks."
    DTDFVocab:enables DataMonitoringService
]

// -------------------------------
// 6. Services
// -------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "User interface service displaying real‑time vehicle state, projected path, and object tracks; supports data saving and report generation."
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTracksInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes the Adaptive Cruise Control algorithm off‑board and returns speed commands to the physical vehicle."
    DTDFVocab:provides SpeedCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, and issue emergency braking remotely."
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, EmergencyBrakingAction
]

// -------------------------------
// 7. Insights & Actions
// -------------------------------
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Provides operators with up‑to‑date vehicle pose, velocity, and sensor status."
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Shows positions and trajectories of detected objects derived from clustering and tracking."
]

instance SpeedCommandAction : DTDFVocab:Action [
    base:desc "Speed command generated by the ACC model and sent to the vehicle actuators."
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable or disable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets the target cruise speed for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator triggers an emergency braking command to the vehicle."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin runs the ACC algorithm, determines the lead vehicle, computes a desired speed and transmits this command back to the vehicle over the same Wi‑Fi UDP link. Additional commands—ACC enable/disable, set desired speed, emergency‑brake—are issued from the user‑interface and routed through the Data Translation FE to the Actuation FE on the physical twin, which drives the motor, steering and servo actuators. Execution is confirmed by the updated vehicle‑state feedback that is sent back to the DT and displayed in the UI."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin requires that physical devices and digital components share a common notion of time with a synchronization accuracy of 100 ms; many standards mandate stricter (<100 ms) synchronization for safety‑critical vehicular applications, but the implementation is limited to 100 ms due to hardware constraints. This defines the latency budget for computation off‑loading and ensures that data exchanged between the Physical Twin Entity and the Digital Twin Entity is timestamped within that tolerance."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration follows the ISO 23247 reference architecture; functional entities are mapped onto ROS2 packages, providing middleware‑based communication between the Physical Twin Entity (sensor/actuator resources and point‑cloud clustering), the Digital Twin Entity (data management and control logic), and the User Entity (3D visualization and control panel). ROS2 serves as the system‑wide coordination mechanism, handling resource allocation and message passing across the distributed hardware."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is constrained by the requirement that all distributed components share a common notion of time with a maximum deviation of 100 ms, as imposed by vehicular safety standards and hardware limitations. This timing bound is used to guarantee coherent data fusion between sensor streams and actuation commands. Validation of the clustering/tracking algorithms and the 3‑D visualization is implied by the ISO 23247 reference architecture, but explicit verification methods, uncertainty quantification, or error‑correction mechanisms are not described in the documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑component communication inside the digital twin uses the ROS 2 middleware, while communication between the physical twin and the digital twin occurs over a Wi‑Fi network employing UDP at the transport layer. The architecture follows a client‑server model with the vehicle publishing sensor streams and the DT publishing control messages. The system is designed for low end‑to‑end latency to satisfy the safety‑critical ACC use case; however, specific bandwidth or latency figures are not provided. Reliability is handled by ROS 2 QoS settings and the use of UDP, and no security protocols are described in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The ACC functionality is off‑loaded from the vehicle to a remote compute platform (referred to as the digital twin system), implying a cloud or edge deployment that can host the ACC algorithm and associated services. No detailed specifications of computational or storage resources, scalability mechanisms, deployment models, or availability guarantees are given in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External integration is not explicitly detailed in the documents. The ISO 23247 standard notes that OPC Unified Architecture (OPC UA) can be employed for the Data Translation Functional Entity to enable interoperability with other enterprise systems. In the presented implementation, intra‑DT communication relies on ROS 2; no concrete use of OPC UA or other external protocols is mentioned, indicating that integration with external systems is left to optional extensions rather than being a currently realized feature."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system complies with the ISO 23247 Digital Twin framework for manufacturing (parts 1‑4), which defines an entity‑based reference architecture, digital representation of physical elements, and information exchange. While ISO 23247 does not prescribe specific implementation technologies, the design notes that one may choose OPC Unified Architecture for communication. Additionally, the vehicle domain requires clock synchronization accuracy of 100 ms across devices to support safety‑critical operations. No other industry certifications or interoperability standards are mentioned."
]