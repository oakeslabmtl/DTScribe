// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor providing pointcloud data of the environment for object tracking."
]
instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor suite measuring speed, acceleration, and steering angle."
]
instance ActuationSensor : DTDFVocab:SensingComponent [
    base:desc "Actuator-state sensor measuring motor and servo actuation signals."
]

// C2: Acting Components (none for this DT)

// C4: Data Transmitted
instance LiDARRawDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]
instance VehicleStateRawDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]
instance ActuationRawDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ActuationSensor
]

// C5: Data
instance LiDARData : DTDFVocab:Data [
    base:desc "Processed LiDAR data after ISO23247-based translation, containing discrete object tracks projected onto a 2D plane."
    DTDFVocab:fromData LiDARRawDataStream
    DTDFVocab:inputTo DataTranslationFeature
]
instance VehicleStateData : DTDFVocab:Data [
    base:desc "Processed vehicle state data with unit conversion applied, used for trajectory computation and real-time monitoring."
    DTDFVocab:fromData VehicleStateRawDataStream
    DTDFVocab:inputTo DataTranslationFeature
]
instance ActuationData : DTDFVocab:Data [
    base:desc "Processed actuation data representing motor commands for control."
    DTDFVocab:fromData ActuationRawDataStream
    DTDFVocab:inputTo DataTranslationFeature
]

// C11: Enablers
instance DataTranslationFeature : DTDFVocab:Enabler [
    base:desc "ISO23247-based data translation feature that serialises ROS2 messages, aligns data types, and performs unit conversions."
    DTDFVocab:enables DataMonitoringService
]
instance ACCOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Cloud-based compute node enabling ACC logic offloading for lead-vehicle detection and desired-speed computation."
    DTDFVocab:enables ComputationOffloadingService
]
instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Remote control enabler allowing low-latency operator interaction via WiFi/UDP for ACC enable/disable, speed setting, and emergency braking."
    DTDFVocab:enables RemoteManagementService
]
instance SQLStorageEnabler : DTDFVocab:Enabler [
    base:desc "SQL database enabler storing historical vehicle state for reporting and analytics."
    DTDFVocab:enables DataArchivalService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real-time vehicle state display, projected trajectory, and object tracks monitoring via user interface."
    DTDFVocab:provides VehicleStateInsight,
                   TrajectoryVisualizationInsight,
                   ObjectTrackInsight
]
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service providing ACC computation results from cloud nodes, returning desired-speed command to vehicle."
    DTDFVocab:provides DesiredSpeedCommandAction
]
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service enabling operators to remotely control ACC, set desired-speed, and issue emergency-brake commands."
    DTDFVocab:provides EnableACCAction,
                   DisableACCAction,
                   SetDesiredSpeedCommandAction,
                   EmergencyBrakeAction
]
instance DataArchivalService : DTDFVocab:Service [
    base:desc "Service responsible for persisting historical vehicle state data to SQL database."
    DTDFVocab:provides PersistHistoricalDataAction
]

// C17: Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight visualizing current vehicle speed, acceleration, and steering angle."
]
instance TrajectoryVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight displaying projected trajectory based on vehicle state and environmental data."
]
instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Insight showing detected object tracks and projected positions."
]

// C17: Actions
instance DesiredSpeedCommandAction : DTDFVocab:Action [
    base:desc "Action sending desired speed command from offloaded ACC logic to vehicle."
    DTDFVocab:IsAutomatic false
]
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action enabling Adaptive Cruise Control on the vehicle."
    DTDFVocab:IsAutomatic false
]
instance DisableACCAction : DTDFVocab:Action [
    base:desc "Action disabling Adaptive Cruise Control on the vehicle."
    DTDFVocab:IsAutomatic false
]
instance SetDesiredSpeedCommandAction : DTDFVocab:Action [
    base:desc "Action allowing operator to set a desired speed for ACC."
    DTDFVocab:IsAutomatic false
]
instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action commanding emergency braking."
    DTDFVocab:IsAutomatic false
]
instance PersistHistoricalDataAction : DTDFVocab:Action [
    base:desc "Action archiving historical vehicle state data to the SQL database."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin employs a rigorous clock synchronization scheme, requiring all participating device compute nodes to align their operating time within a precision of 100 ms—this constraint is dictated by hardware limitations and aligned with safety‑critical vehicular standards that demand sub‑100‑ms synchronization. Synchronization is enforced across the ROS2‑based device network, ensuring that data exchange between physical and virtual components adheres to this temporal granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration follows the ISO 23247 “Digital Twin framework for manufacturing” by arranging the system into entity‑based Functional Entities (FEs). Key software components are first identified, then mapped onto FEs and implemented as ROS 2 packages containing ROS 2 nodes. The User Entity groups user‑facing FEs—specifically an interface FE split into visualization and control panel. The Digital Twin Entity aggregates data‑management and control FEs, while the Physical Twin Entity, distinct from the ISO 23247 Physical Twin concept, hosts resource‑specific and general automotive FEs such as point‑cloud clustering and tracking. Deployment occurs across separate hardware, ensuring decentralized execution. Coordination mechanisms include 100 ms clock synchronization, network latency limits, and inter‑FE messaging via ROS 2 topics/services, thereby providing coherent real‑time interaction across all entities.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Software components communicate over a ROS2 networking stack, exchanging data via DDS topics. Inter‑entity communication between the physical twin and the digital twin occurs over Wi‑Fi using the UDP transport protocol. The document does not specify bandwidth, latency, reliability, redundancy or security mechanisms beyond the use of ROS2 QoS policies and Wi‑Fi UDP."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 Part 2 defines an entity‑based reference architecture with four core entities—Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity, and User Entity.  Inter‑entity interfaces are specified as collections of Functional Entities (FEs) that can be implemented with any technology stack; for example, the standard cites OPC Unified Architecture (OPC UA) as a possible communication layer."
]