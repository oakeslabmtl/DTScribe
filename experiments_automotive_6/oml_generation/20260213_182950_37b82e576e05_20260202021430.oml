// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2-D LiDAR, max range 10 m, 40 Hz scan rate publishing planar range scans"
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance IntelRealSenseD435i : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera, RGB‑D up to 30 Hz, publishing dense 3‑D point clouds"
    DTDFVocab:producedData DepthCameraPointCloudDataTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board motor status monitor providing RPM and voltage feedback"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Steering servo position feedback sensor reporting angle"
    DTDFVocab:producedData SteeringServoSignalDataTransmitted
]

// C4: Physical‑to‑virtual interaction (Data transmitted)
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthCameraPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435i
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance SteeringServoSignalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
]

// C10: Data instances (raw)
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream"
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance DepthCameraPointCloudData : DTDFVocab:Data [
    base:desc "Raw depth‑camera dense point‑cloud stream"
    DTDFVocab:fromData DepthCameraPointCloudDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Current motor RPM and voltage"
    DTDFVocab:fromData MotorStatusDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance SteeringServoSignalData : DTDFVocab:Data [
    base:desc "Current steering‑servo angle"
    DTDFVocab:fromData SteeringServoSignalDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

// C10: Data instances (processed / model output)
instance ProcessedObjectTracksData : DTDFVocab:Data [
    base:desc "Clustered object tracks with Kalman‑filter state and confidence"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance EgoVehicleStateData : DTDFVocab:Data [
    base:desc "Estimated vehicle pose, speed and heading"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance DesiredSpeedCommandData : DTDFVocab:Data [
    base:desc "Desired speed output from ACC model for actuation"
    DTDFVocab:inputTo ActuationInterfaceEnabler
]

instance DesiredSteeringCommandData : DTDFVocab:Data [
    base:desc "Desired steering angle output from ACC model for actuation"
    DTDFVocab:inputTo ActuationInterfaceEnabler
]

// C10: Models
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering followed by Kalman‑filter tracking of LiDAR and depth‑camera point clouds"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "ACC control logic consuming object tracks and ego state to compute desired speed and spacing"
    DTDFVocab:inputTo CloudACCComputeEnabler
]

// C11: Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Serialises, aligns and converts units of incoming sensor streams over Wi‑Fi UDP"
    DTDFVocab:enables DataMonitoringService
]

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware distributes processed data within the Digital Twin"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance CloudACCComputeEnabler : DTDFVocab:Enabler [
    base:desc "GPU‑accelerated cloud compute runs the ACC model and returns speed commands"
    DTDFVocab:enables ComputationOffloadingService
]

instance ActuationInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Converts high‑level speed/steering setpoints to motor voltage and servo PWM, sends over CAN via ROS 2"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI displays real‑time vehicle state, projected path and nearby object tracks; users can view, save and generate reports"
    DTDFVocab:provides VehicleStateVisualizationInsight, DataReportGenerationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Migrates ACC algorithm to the Digital Twin, processes data in the cloud and returns desired speed for actuation"
    DTDFVocab:provides DesiredSpeedComputationInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI enables operators to enable/disable ACC, set target speed and issue emergency‑braking over low‑latency link"
    DTDFVocab:provides ACCEnableAction, ACCDisableAction, SetTargetSpeedAction, EmergencyBrakingAction
]

// C17: Insights
instance VehicleStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualisation of vehicle pose, speed and sensor point clouds"
]

instance DataReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Generation of historical data reports for analysis and post‑mission review"
]

instance DesiredSpeedComputationInsight : DTDFVocab:Insight [
    base:desc "Computed desired speed and spacing from ACC model, presented with confidence metric"
]

// C17: Actions
instance ACCEnableAction : DTDFVocab:Action [
    base:desc "Operator command to start Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance ACCDisableAction : DTDFVocab:Action [
    base:desc "Operator command to stop Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets a target cruising speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator issues immediate emergency braking"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin (desired speed for ACC, ACC enable/disable signals, and emergency‑brake requests) are packaged by the Data Translation component, transmitted over the Wi‑Fi UDP link to the Physical Twin, and received by the vehicle’s actuation front‑ends (motor, steering servo). The DT does not specify additional validation, authentication, or acknowledgment mechanisms; command execution is implied by the actuation front‑ends applying the received values."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system mandates that all participating devices share a common notion of time for computation offloading, requiring clock synchronization accuracy of 100 ms (the limit imposed by hardware). This synchronization level is set to satisfy safety‑critical vehicular application standards that often require stricter than 100 ms alignment."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 reference model: the Physical Twin Entity hosts sensors, actuators and low‑level processing; the Digital Twin Entity provides the digital representation and control logic; the User Entity supplies visualization and control‑panel interfaces. Each Functional Entity is realized as an individual ROS 2 package containing one or more ROS 2 nodes, and the packages are distributed across distinct compute nodes, using ROS 2 middleware for inter‑entity communication and overall system orchestration."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT development follows the ISO 23247 framework, beginning with an architectural design phase where key software components are identified and their relationships to sensors/actuators are defined (Fig. 2, Tab. I). The identified components are then mapped onto Functional Entities (FEs) and each FE is realized as an individual ROS 2 package containing one or more ROS 2 nodes. After implementation, the packages are deployed on separate hardware units that correspond to the three ISO entities (User Entity, Digital Twin Entity, Physical Twin Entity). The lifecycle therefore consists of design → FE mapping → ROS 2 package implementation → distributed deployment, without explicit governance or transition management steps described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The physical‑digital twin link uses a Wi‑Fi network with UDP transport. Internal communication among digital‑twin software components is handled by a ROS 2 network. The system is required to support low end‑to‑end latency communication, but specific bandwidth, latency thresholds, reliability, redundancy or security mechanisms are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The ACC algorithm is offloaded from the on‑board ECU to external computational resources constituting the digital twin (referred to as the DT system). The documents mention that the offloading can be to “better‑suited equipment, e.g., in the cloud,” implying a cloud or remote edge deployment, but they do not specify exact hosting platforms, storage capacities, scalability or availability mechanisms."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The ISO 23247 standard mentions that integration with external systems can be achieved via protocols such as OPC Unified Architecture (OPC UA). While the present implementation does not specify a concrete external‑system link, the possibility of employing OPC UA for data exchange and interoperability is noted."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is explicitly designed to comply with the ISO 23247 Digital Twin framework for manufacturing, adopting the Part 2 reference architecture with its Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, and User Entity. The implementation respects industry timing standards for safety‑critical vehicular applications that mandate clock synchronization tighter than 100 ms, and the design enforces a 100 ms synchronization accuracy due to hardware constraints. No additional certification or interoperability standards are mentioned."
]