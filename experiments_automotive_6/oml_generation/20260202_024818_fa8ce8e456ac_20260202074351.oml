// Sensing Components
instance HokuyoUST10LXLidarSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR providing raw point clouds"
    DTDFVocab:producedData LiDARRawPointCloudTransmitted
]

instance IntelD435iDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera feeding visual data into the DT"
    DTDFVocab:producedData DepthCameraImageTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensors capturing speed and steering angle"
    DTDFVocab:producedData VehicleStateTelemetryTransmitted
]

// DataTransmitted Instances
instance LiDARRawPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidarSensor
]

instance DepthCameraImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCameraSensor
]

instance VehicleStateTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance DesiredSpeedCommandTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ControlPanelFE
]

// Data Instances
instance LiDARPointCloud : DTDFVocab:Data [
    base:desc "Pre‑processed LiDAR point cloud for clustering"
    DTDFVocab:fromData LiDARRawPointCloudTransmitted
    DTDFVocab:inputTo DataPreProcessingFE
]

instance DepthImage : DTDFVocab:Data [
    base:desc "Depth image after type alignment and unit conversion"
    DTDFVocab:fromData DepthCameraImageTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Telemetry of speed and steering angle"
    DTDFVocab:fromData VehicleStateTelemetryTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance DesiredSpeedCommand : DTDFVocab:Data [
    base:desc "Desired speed command issued by the operator"
    DTDFVocab:fromData DesiredSpeedCommandTransmitted
    DTDFVocab:inputTo ACCFE
]

// Models
instance BasicACCModel : DTDFVocab:Model [
    base:desc "ISO 15622 basic ACC logic for cruise control"
    DTDFVocab:inputTo ACCFE
]

instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point clouds to identify objects"
    DTDFVocab:inputTo DataPreProcessingFE
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking of clustered objects over time"
    DTDFVocab:inputTo DataPreProcessingFE
]

// Enablers (Functional Entities)
instance DataCollectionFE : DTDFVocab:Enabler [
    base:desc "Collects data streams from physical sensors"
    DTDFVocab:enables DataMonitoringService
]

instance ReportingFE : DTDFVocab:Enabler [
    base:desc "Generates time‑series reports of vehicle state and object tracks"
    DTDFVocab:enables ReportGenerationService
]

instance ACCFE : DTDFVocab:Enabler [
    base:desc "Accelerator Control FE executing ACC logic"
    DTDFVocab:enables RemoteManagementService
]

instance DataStorageFE : DTDFVocab:Enabler [
    base:desc "External SQL database storage of vehicle state and point clouds"
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Serializes, type‑aligns, and unit‑converts incoming data"
    DTDFVocab:enables DataMonitoringService
]

instance DataPreProcessingFE : DTDFVocab:Enabler [
    base:desc "Clusters point clouds and tracks objects for perception"
    DTDFVocab:enables DataMonitoringService
]

instance ControlPanelFE : DTDFVocab:Enabler [
    base:desc "Operator UI FE enabling ACC adjustments and speed commands"
    DTDFVocab:enables RemoteManagementService
]

instance VehicleActuationFE : DTDFVocab:Enabler [
    base:desc "Transmits desired speed and steering commands to actuators"
    DTDFVocab:enables RemoteManagementService
]

instance 3DVisualizationFE : DTDFVocab:Enabler [
    base:desc "Renders 3‑D view of vehicle and environment in the UI"
    DTDFVocab:enables VisualizationService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI displays speed, steering, tracks, and projected path"
    DTDFVocab:provides VehiclePerformanceInsight, ObjectTrackInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC algorithm execution off‑board and streams results back"
    DTDFVocab:provides AdjustAccParametersAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operator to enable/disable ACC, set desired speed, trigger emergency braking"
    DTDFVocab:provides AdjustAccParametersAction, SetDesiredSpeedAction, TriggerEmergencyBrakingAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3‑D visualization of vehicle and tracked objects"
    DTDFVocab:provides VehiclePerformanceInsight
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generates post‑drive analysis reports"
    DTDFVocab:provides PostDriveAnalysisInsight
]

// Insights
instance VehiclePerformanceInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring provides insights into vehicle performance"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Object tracks derived from clustering and tracking models"
]

instance PostDriveAnalysisInsight : DTDFVocab:Insight [
    base:desc "Post‑drive analysis through generated reports"
]

// Actions
instance AdjustAccParametersAction : DTDFVocab:Action [
    base:desc "Operator can adjust ACC parameters remotely"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets the desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking"
    DTDFVocab:IsAutomatic false
]

// Acting Components
instance VehicleMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Motor actuator driven by vehicle voltage commands"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo controlled by steering angle commands"
]

// Components and Environment
instance VehicleActuationComponent : DTDFVocab:Component [
    base:desc "Combines motor and steering actuators for vehicle actuation"
    base:contains VehicleMotorActuator, SteeringServoActuator
]

instance TrackedEnvironment : DTDFVocab:Environment [
    base:contains VehicleActuationComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Outputs from the Digital Twin—including desired speed commands, steering adjustments, and emergency braking signals—are sent through the Device Control Entity to the PT’s actuators; the Motor Actuation FE converts desired speed into voltage commands, while the user‑controlled Control Panel FE can remotely enable/disable ACC or send emergency braking."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time interaction with a maximum end‑to‑end latency requirement of 100 ms from PT to DT, with clock synchronization accuracy of 100 ms; ACC computations and control decisions are performed within each perception cycle (≈10 ms resolution), and all data serialization aligns with ROS2 message publishing rates."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An entity‑based constellation following ISO 23247: Physical Twin Entity (sensor/actuator layer), Digital Twin Entity (simulation, data management, ACC logic), User Entity (UI/visualization), and Cross‑System Entity (data translation). Communication flows are coordinated over ROS2 on vehicle, Wi‑Fi to cloud, and dedicated UI layers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design and validation phase (simulation and requirement check), Development and deployment (ISO 23247 RA mapping, ROS2 implementation), Operational phase (live vehicle–DT interaction, remote management), and Maintenance/upgrade phase (incremental feature additions such as new FEs or updated algorithms)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity achieved through direct real‑time sensor streams, low‑latency (≤100 ms) data transfer, and precise clock synchronization (≤100 ms). Validity enforced by ISO 15622 ACC specification compliance, simulation‑based verification of clustering/tracking, and on‑board data logging against physical twin behavior."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "PT‑DT linkage via Wi‑Fi network using ROS2 publish/subscribe; cross‑entity communication handled by Data Translation FE; signals are serialized using ROS2 message types with optional unit conversion; network security not explicitly described."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital Twin services deployed on a cloud computing platform accessible over Wi‑Fi; ROS2 nodes on the vehicle handle Data Collection and Actuation; Computation offloading performed on remote cloud nodes; UI hosted locally on operator’s workstation."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 Delivery Architecture reference (Part 2) applied to DT design; ACC logic follows ISO 15622; communication messages use ROS2 conventions; optional OPC UA could be used though not implemented."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Designed for safety‑critical automotive context; latency and clock synchronization constraints (≤100 ms) address real‑time safety; ACC system implemented according to ISO 15622; however explicit cybersecurity mechanisms (encryption, authentication) are not detailed in the document."
]