// Sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Raw LiDAR point cloud sensor capturing 3‑D point clouds at 10 Hz over Wi‑Fi (UDP)"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor measuring speed, acceleration, and yaw rate, transmitted over Wi‑Fi (UDP)"
    DTDFVocab:producedData VehicleStateTransmitted
]

instance DrivingPathSensor : DTDFVocab:SensingComponent [
    base:desc "Projected driving path sensor providing planned trajectory via path planner, transmitted over Wi‑Fi (UDP)"
    DTDFVocab:producedData DrivingPathTransmitted
]

// Data transmitted to the DT
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance DrivingPathTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DrivingPathSensor
]

// Core data derived in the DT
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "LiDAR point cloud data in meters, unit‑converted to centimeters within the DT"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo PointCloudClusteringEnabler, DataTranslationEnabler, ComputationOffloadingEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state data including speed, acceleration, and yaw, unit‑converted for DT consistency"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo ComputationOffloadingEnabler, RemoteManagementEnabler
]

instance DrivingPathData : DTDFVocab:Data [
    base:desc "Projected driving path data containing waypoints, unit‑converted for DT integration"
    DTDFVocab:fromData DrivingPathTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, DataStorageEnabler, VisualizationFrontEndEnabler
]

// Enablers for processing and storage
instance PointCloudClusteringEnabler : DTDFVocab:Enabler [
    base:desc "Clusters raw LiDAR point clouds and tracks objects to extract object tracks"
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Serializes data streams, aligns message types, and performs unit conversions (meters ↔ centimeters)"
    DTDFVocab:enables DataMonitoringService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Persists processed data streams in PostgreSQL for future analysis"
    DTDFVocab:enables DataMonitoringService
]

instance VisualizationFrontEndEnabler : DTDFVocab:Enabler [
    base:desc "Renders 3‑D visualization of vehicle state, trajectory, and detected object tracks in real time"
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Hosts ACC control logic in the cloud for computationally intensive ACC computation"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Provides remote enable/disable ACC, set desired speed, and trigger emergency braking with low‑latency communication"
    DTDFVocab:enables RemoteManagementService
]

// Services offered by the DT
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Streams real‑time vehicle state, projected trajectory, and object tracks to users; supports data saving and report generation"
    DTDFVocab:provides VehicleStateInsight, ACCControlInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computes desired speed from lead vehicle distance in the cloud and returns ACC command to the vehicle"
    DTDFVocab:provides ACCControlInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to remotely enable/disable ACC, set desired speed, and trigger emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, TriggerEmergencyBrakeAction
]

// Actions that can be invoked
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables the Adaptive Cruise Control (ACC) module on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disables the Adaptive Cruise Control (ACC) module on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets the desired speed parameter for the ACC module"
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Triggers an emergency braking command on the vehicle"
    DTDFVocab:IsAutomatic true
]

// Insights presented to users
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Displays real‑time vehicle state overlay on visualization"
]

instance ACCControlInsight : DTDFVocab:Insight [
    base:desc "Shows desired speed computed by ACC based on lead vehicle distance"
]

// Physical chassis components
instance LowerLevelChassis : DTDFVocab:Component [
    base:desc "Lower‑level chassis including suspension and wheel modules"
]

instance UpperLevelChassis : DTDFVocab:Component [
    base:desc "Upper‑level chassis including body and steering modules"
]

instance ACCModule : DTDFVocab:Component [
    base:desc "Dedicated ACC module handling acceleration and braking control"
]

// Middleware component
instance ROS2Middleware : DTDFVocab:Component [
    base:desc "ROS 2 middleware (DDS‑based) distributing data to functional units within the DT"
]

// User interfaces
instance OperatorConsole : DTDFVocab:Component [
    base:desc "Operator interface for monitoring and controlling ACC"
]

instance DeveloperConsole : DTDFVocab:Component [
    base:desc "Developer console for troubleshooting and refining ACC logic"
]

// Environments grouping components
instance VehicleEnvironment : DTDFVocab:Environment [
    base:contains LowerLevelChassis, UpperLevelChassis, ACCModule, LiDARSensor, VehicleStateSensor, DrivingPathSensor
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains ROS2Middleware, PointCloudClusteringEnabler, DataTranslationEnabler, DataStorageEnabler, VisualizationFrontEndEnabler, ComputationOffloadingEnabler, RemoteManagementEnabler, DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance UserEnvironment : DTDFVocab:Environment [
    base:contains OperatorConsole, DeveloperConsole
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Temporal synchronization is achieved through a shared clock across the Digital Twin system, with a required accuracy of 100 ms to satisfy safety‑critical vehicular application standards. Devices perform computation offloading only when their local clocks are synchronized within this bound. ROS2 packages utilize DDS time sources, and the system execution aims to maintain a maximum 100 ms latency between physical sensor events and their digital twin representations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows the ISO 23247 Reference Architecture (RA) by mapping each Feature Element to a ROS2 package containing one or more ROS2 nodes. The Digital Twin Entity aggregates data‑management, control, and processing components; the Physical Twin Entity captures hardware‑specific functionality such as sensor and actuator interfacing, including general automotive logic like point‑cloud clustering and tracking; and the User Entity delivers 3D visualization and control panel interfaces. Resource management is embedded within the OME‑like Physical Twin Entity, which abstracts compute, sensor and actuator resources. System‑wide coordination is realized via DDS middleware that propagates events and services across the distributed entities, ensuring coherent state among the twin and physical layers."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between software components is handled within a ROS 2 network (leveraging DDS), while inter‑entity communication uses a Wi‑Fi network over UDP at the transport layer. The document does not specify bandwidth, latency, reliability, redundancy mechanisms, or security protocols for these communications."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system is built in accordance with ISO 23247 – Digital twin framework for manufacturing, adopting the entity‑based reference architecture detailed in Part 2. It implements an Observable Manufacturing Element (OME), a Data Collection and Device Control Entity, a Digital Twin Entity, and a User Entity, each composed of functional entities for tasks such as data acquisition, device actuation, and user interaction. For communication and data exchange, the system uses OPC Unified Architecture (OPC UA), a widely accepted industry‑standard protocol for device connectivity and data interoperability. The architecture and component implementation are therefore compliant with ISO 23247 and leverage OPC UA to satisfy interoperability and integration requirements within industrial manufacturing environments."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "According to ISO 26262‑1:2018 the digital twin’s safety aspects are governed by a formal functional‑safety lifecycle that mandates hazard analysis, risk assessment (e.g., FMEA), safety‑goal definition, and a safety concept verified through rigorous testing and analysis. Critical ECUs are designed with fail‑safe mechanisms such as redundant sensor fusion, watchdog timers, and adherence to automotive Safety Integrity Levels (ASIL C/D). The V2X security architecture defined in 3GPP TS 22.185 introduces a public‑key infrastructure (PKI) that uses X.509 certificates issued by trusted Certificate Authorities for mutual authentication between vehicles and roadside units. Data integrity is protected using cryptographic message‑authentication codes (e.g., HMAC‑SHA256) and confidentiality is ensured with AES‑128 in GCM mode. Certificate revocation is handled via Certificate Revocation Lists (CRLs) distributed throughout the V2X network. Threat‑mitigation strategies include secure boot processes, runtime integrity checks, protection against replay attacks through nonces and sequence numbers, and secure key exchange protocols. Safety‑critical system requirements specify that all safety‑critical functions must fail in a safe state, supported by hardware redundancy, fault‑tolerant communication protocols, and exhaustive verification/testing.”}"
]