// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor providing point cloud data for perception."
    DTDFVocab:producedData LiDARDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor providing vehicle state information such as speed, acceleration, and wheel steering."
    DTDFVocab:producedData VehicleStateDataTransmitted
]

instance MotorSteeringSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing motor and steering output signals."
    DTDFVocab:producedData MotorSteeringDataTransmitted
]

// C4: Physical-to-virtual interaction - data transmission
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance MotorSteeringDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSteeringSensor
]

// C10: Models/Data - processed data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Serialized and aligned LiDAR point cloud data after ISO 23247 Data Translation."
    DTDFVocab:inputTo MonitoringDataProcessingEnabler, OffloadingDataProcessingEnabler
    DTDFVocab:fromData LiDARDataTransmitted
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state data including speed, acceleration, and steering angle after unit conversion."
    DTDFVocab:inputTo MonitoringDataProcessingEnabler, OffloadingDataProcessingEnabler
    DTDFVocab:fromData VehicleStateDataTransmitted
]

instance MotorSteeringData : DTDFVocab:Data [
    base:desc "Motor and steering sensor outputs after serialization and alignment."
    DTDFVocab:inputTo MonitoringDataProcessingEnabler, OffloadingDataProcessingEnabler
    DTDFVocab:fromData MotorSteeringDataTransmitted
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Processed object tracks derived from LiDAR point cloud and vehicle state via clustering and tracking."
    DTDFVocab:inputTo MonitoringDataProcessingEnabler
    DTDFVocab:fromData LiDARDataTransmitted
]

instance ProjectedDrivingPathData : DTDFVocab:Data [
    base:desc "Projected driving trajectory computed from vehicle state and object tracks."
    DTDFVocab:inputTo MonitoringDataProcessingEnabler
    DTDFVocab:fromData VehicleStateDataTransmitted
]

// C11: Enablers
instance MonitoringDataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247 Data Translation FE and ROS2 intra‑process network enabling real‑time 3D visualization."
    DTDFVocab:enables DataMonitoringService
]

instance OffloadingDataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Component enabling computation offloading of the ACC algorithm to the cloud."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler providing low‑latency remote control of ACC and vehicle actions."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time visualization of vehicle state, projected trajectory, and object tracks, with UI to save data and generate reports."
    DTDFVocab:provides DrivingStateVisualizationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Selective relocation of the ACC algorithm from the vehicle ECU to the DT’s compute cloud, processing lead‑vehicle detection and speed calculations."
    DTDFVocab:provides DesiredSpeedCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Low‑latency remote control capabilities: enable/disable ACC, set desired speed, issue emergency brakes."
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights/Actions
instance DrivingStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of vehicle state, projected trajectory, and object tracks on a 3D UI."
]

instance DesiredSpeedCommandAction : DTDFVocab:Action [
    base:desc "Desired speed command output by the ACC algorithm running on the cloud."
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Manual enable or disable of Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "The operator can set a desired speed for the vehicle."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Manual emergency brake command to halt vehicle."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are issued from the Digital Twin via the Actuation FE components (Motor Actuation, Steering Servo Actuation FE). These commands are serialized and unit‑converted by the Data Translation FE, then transmitted over UDP/Wi‑Fi to the corresponding physical actuators. Feedback signals (e.g., actuator state) are routed through the same Data Translation FE and the ROS 2 network back to the Digital Twin for real‑time status monitoring and confirmation of command execution."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires the physical vehicles and the digital twin to share a consistent notion of time, achieving synchronization accuracy of 100 ms. Data and command exchanges between sensors, processors and actuators are conducted via ROS 2 messages timestamped with a unified clock, ensuring that any latency between sensor acquisition, data preprocessing, and actuation does not exceed the 100 ms bound mandated for safety‑critical vehicular applications."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows ISO 23247 Reference Architecture, implementing each Functional Entity (FE) as an individual ROS 2 package containing one or more ROS 2 nodes. The Physical Twin Entity hosts the hardware resources (compute, sensors, actuators) and implements lower‑level automotive functions such as point‑cloud clustering and tracking. The Digital Twin Entity gathers data‑management and control‑mechanism services, while the User Entity contains the User Interface FE, subdivided into 3D Visualization and Control Panel sub‑components. Each FE is deployed on a distinct hardware node, yielding a decentralized deployment model. Coordination is achieved through ROS 2 topics and services, adhering to the ISO 23247 entity‑based structure and ensuring clear ownership and modular communication across the twin’s functional layers."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between software components occurs within a ROS 2 network; inter‑entity communication (between physical and digital Twins) uses Wi‑Fi with UDP on the transport layer. The documents do not provide explicit bandwidth, latency, reliability, redundancy, or security requirements."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "No information on hosting platforms (cloud/edge/on‑premise), computational/storage requirements, scalability mechanisms, deployment models, or availability/reliability assurance is provided in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system conforms to ISO 23247 (Digital Twin Framework for Manufacturing), adopting the reference architecture described in Part 2 of the standard.  It implements an entity‑based architecture comprising: 1) the Observable Manufacturing Element (OME) representing physical assets such as equipment, processes, or products; 2) the Data Collection and Device Control entity that gathers sensor data from and sends control commands to the OME; 3) the Digital Twin entity that digitally models the OME; and 4) the User entity that provides monitoring and control interfaces.  Functional Entities (FEs) within each entity perform specialized tasks such as actuating the OME, transforming raw data into human‑interpretable formats, or interfacing with end‑users.  Although ISO 23247 does not prescribe any particular implementation technology, the system may employ OPC Unified Architecture (OPC UA) as the protocol for data exchange and device control, ensuring interoperability with industry automation equipment.  No further certification requirements or additional compliance frameworks are documented. "
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety concerns for the digital‑twin solution are derived from ISO 26262‑1:2018, ISO 15622:2018 and the 3GPP TS 22.185 v15.0.0 Release 15. The system follows the ISO 26262 functional‑safety life‑cycle: hazard analysis and risk assessment (HARA) identify safety hazards associated with the ACC module; safety goals and functional safety concepts are documented, and safety integrity levels (SIL 1–SIL 4) are assigned. For example, the longitudinal control loop of the adaptive cruise control is specified at SIL 3, with a dedicated safety continuity function that forces the vehicle into a pre‑defined “safe‑brake” state when a fault or sensor failure is detected. Testing follows ISO 15622’s test procedures, including acceleration‑deceleration profiling, fault‑injection experiments and performance data logging at 10 Hz. Cybersecurity is addressed per the 3GPP V2X security architecture defined in TS 22.185 (with references to TS 33.160). The twin uses a public‑key infrastructure (V2X‑PKI) for mutual authentication of V2X messages; certificates are provisioned via the V2X‑PKI, message integrity is provided by HMAC‑SHA‑256 and confidentiality by AES‑128/256 in GCM mode. Access to the twin’s data is controlled via role‑based access control (RBAC) with OAuth 2.0 tokens, and all authentication events are logged. Threat‑mitigation strategies include continuous monitoring for anomalous V2X traffic, replay‑attack protection via sequence numbers and timestamps, and rate‑limiting to defend against denial‑of‑service attacks. Safety‑critical modules share sensor data over a secure CAN‑FD bus with message encryption and redundancy; diagnostic tests and watchdog timers ensure fault detection and recovery. The overall safety case, which satisfies ISO 26262 requirement A.15.5.5, is reviewed by an independent safety auditor and updates are tracked through the system’s configuration management process."
]