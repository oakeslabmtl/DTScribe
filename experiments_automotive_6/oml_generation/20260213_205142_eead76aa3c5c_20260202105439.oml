// Physical sensing components
instance HokuyoUst110LxLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-110LX LiDAR producing 3D point clouds at 10 Hz"
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera providing RGB‑D images at 30 fps"
    DTDFVocab:producedData DepthImageDataTransmitted
]

instance WheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel‑speed sensor feeding ego vehicle speed to the DT"
    DTDFVocab:producedData WheelSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor providing real‑time steering feedback"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

instance AuxiliaryVehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Auxiliary sensor providing additional vehicle state information"
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// Data transmitted from physical sensors
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUst110LxLidar
]

instance DepthImageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

instance WheelSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AuxiliaryVehicleStateSensor
]

// Physical data for processing and visualization
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "3D point cloud collected by Hokuyo UST-110LX LiDAR"
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
    DTDFVocab:inputTo UIFrameworkEnabler, CloudNodeEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image from Intel D435i depth camera"
    DTDFVocab:fromData DepthImageDataTransmitted
    DTDFVocab:inputTo UIFrameworkEnabler, CloudNodeEnabler
]

instance WheelSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed derived from wheel‑speed sensor"
    DTDFVocab:fromData WheelSpeedDataTransmitted
    DTDFVocab:inputTo UIFrameworkEnabler, CloudNodeEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle from steering‑angle sensor"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo UIFrameworkEnabler, CloudNodeEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Consolidated vehicle state data from auxiliary sensors"
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo UIFrameworkEnabler, CloudNodeEnabler
]

// Model instances
instance DataTranslationModel : DTDFVocab:Model [
    base:desc "Data Translation FE aligning ROS2 data types for the DT"
    DTDFVocab:inputTo CloudNodeEnabler
]

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering for object grouping"
    DTDFVocab:inputTo CloudNodeEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking of detected object positions"
    DTDFVocab:inputTo CloudNodeEnabler
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "ISO‑15622 compliant ACC logic computing speed commands"
    DTDFVocab:inputTo CloudNodeEnabler
]

// Derived data after processing
instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Tracked object positions after DBSCAN and Kalman filter"
    DTDFVocab:inputTo RenderingEnabler, CloudNodeEnabler
]

instance ACCCommandData : DTDFVocab:Data [
    base:desc "Speed command generated by the ACC model"
    DTDFVocab:inputTo RemoteControlEnabler, CloudNodeEnabler
]

instance SQLLogData : DTDFVocab:Data [
    base:desc "Time‑series logs stored in external SQL database"
    DTDFVocab:inputTo SQLDatabaseEnabler
]

// Enabler instances
instance UIFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "UI framework enabling real‑time monitoring of vehicle state"
    DTDFVocab:enables DataMonitoringService
]

instance CloudNodeEnabler : DTDFVocab:Enabler [
    base:desc "Cloud node enabler hosting adaptive cruise control and processing models"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Interface for remote management actions from operator workstation"
    DTDFVocab:enables RemoteManagementService
]

instance RenderingEnabler : DTDFVocab:Enabler [
    base:desc "3D rendering enabler visualizing vehicle and environment"
    DTDFVocab:enables VisualizationService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database enabler storing DT logs and reports"
    DTDFVocab:enables DataReportingService
]

// Service instances
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI displaying speed, steering, object tracks, projected path, and generating reports"
    DTDFVocab:provides VehiclePerformanceInsight, ACCEffectivenessInsight, SystemHealthInsight, DriverBehaviorInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC logic executed on cloud node, returning speed commands and diagnostics"
    DTDFVocab:provides ACCControlInsight, ACCExecutionAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator remote control: enable/disable ACC, modify desired speed, trigger emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, ModifyDesiredSpeedAction, TriggerEmergencyBrakingAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D rendering of vehicle state and detected objects"
    DTDFVocab:provides ObjectTracking3DInsight
]

instance DataReportingService : DTDFVocab:Service [
    base:desc "Stores time‑series logs in SQL database for subsequent analysis"
    DTDFVocab:provides DataStorageInsight, SQLReportAction
]

// Insight instances
instance VehiclePerformanceInsight : DTDFVocab:Insight [
    base:desc "Insights into vehicle speed, steering dynamics, and trajectory adherence"
]

instance ACCEffectivenessInsight : DTDFVocab:Insight [
    base:desc "Assessment of ACC performance versus target speed and spacing"
]

instance SystemHealthInsight : DTDFVocab:Insight [
    base:desc "Real‑time health metrics of the autonomous system and hardware"
]

instance DriverBehaviorInsight : DTDFVocab:Insight [
    base:desc "Analysis of operator interventions and latency in control commands"
]

instance ACCControlInsight : DTDFVocab:Insight [
    base:desc "Diagnostics of ACC control loop and decision logic"
]

instance ObjectTracking3DInsight : DTDFVocab:Insight [
    base:desc "3D visualization insight of tracked objects around the vehicle"
]

instance DataStorageInsight : DTDFVocab:Insight [
    base:desc "Visibility of persisted DT logs and archival metrics"
]

// Action instances
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable the Adaptive Cruise Control function on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable the Adaptive Cruise Control function"
    DTDFVocab:IsAutomatic false
]

instance ModifyDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set a new desired speed for ACC operation"
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Trigger emergency braking in response to unsafe conditions"
    DTDFVocab:IsAutomatic false
]

instance ACCExecutionAction : DTDFVocab:Action [
    base:desc "Execute ACC computed speed command on the vehicle"
    DTDFVocab:IsAutomatic true
]

instance SQLReportAction : DTDFVocab:Action [
    base:desc "Generate and store SQL report of DT activity"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Desired speed and steering commands generated by the ACC controller (ISO15622 compliant) are converted by the Actuation FE into motor voltage commands and steering servo signals sent via ROS2 messages over Wi‑Fi to the vehicle; remote enable/disable and emergency braking commands are also transmitted to the Physical Twin Entity for actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with an end‑to‑end network latency requirement of ≤100 ms, clock synchronization accuracy also ≤100 ms; data acquisition and command cycles are performed in real‑time to sustain the ACC control loop."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An ISO23247 entity‑based architecture: Physical Twin Entity (on‑board hardware), Digital Twin Entity (cloud/edge node), User Entity (operator console) – each composed of Functional Entities (Data Translation, Data Collection, Presentation, Reporting, Acceleration Control, Actuation, Visualization, etc.) orchestrated via ROS2 topics/messages over a Wi‑Fi network."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated (run‑time) stage— the DT is active during vehicle operation, collecting and processing data, executing control logic, and providing remote management; no explicit design or manufacturing stages are covered in this study."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Critical latency must stay below 100 ms and all device clocks must be synchronized within 100 ms, ensuring real‑time data integrity. The DT operates on a 1/10‑scale vehicle, making the fidelity of sensor data and control signals relative to a full‑size vehicle. Validation is implicit through real‑time monitoring and reporting; the architecture adheres to ISO 23247 and ISO 15622 safety guidelines."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical twin and Digital Twin Entity exchange data over a Wi‑Fi network using ROS 2, which relies on DDS for message transportation. The Data Translation FE serializes and unifies message types; internal component communication also occurs over ROS2 topics. No explicit mention of lower‑level protocols beyond Wi‑Fi and DDS."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Distributed deployment: Physical Twin Entity on NVIDIA Jetson NX/Nano (on‑board), Digital Twin Entity on a cloud/edge server, User Entity on operator workstation; all connected over Wi‑Fi; ROS2 nodes run on respective hardware platforms."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Architecture guided by ISO 23247 reference architecture; ACC control follows ISO 15622 specification; middleware (ROS2) and optional OPC UA conform to open standards; NVIDIA Jetpack SDK follows NVIDIA platform standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Acknowledged safety-critical nature with low‑latency requirement (≤100 ms); use of ISO standards for control logic; no explicit cybersecurity mechanisms described, but remote operation imposes risk awareness; safety emphasized through compliance with ISO 15622 and real‑time constraints."
]