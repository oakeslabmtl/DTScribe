// C3: Physical sensing components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2-D LiDAR providing raw point‑cloud scans for environment perception."
    DTDFVocab:producedData LiDARPointCloudTx
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D frames for perception."
    DTDFVocab:producedData DepthCameraFramesTx
]

instance OnboardOdometry : DTDFVocab:SensingComponent [
    base:desc "On‑board odometry subsystem measuring ego‑vehicle speed and steering‑angle."
    DTDFVocab:producedData OdometryTx
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance LiDARPointCloudTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraFramesTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
]

instance OdometryTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OnboardOdometry
]

// C5: Data produced from sensors
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Point‑cloud data stream emitted by the LiDAR sensor."
    DTDFVocab:fromData LiDARPointCloudTx
    DTDFVocab:inputTo TrackingFE
]

instance DepthCameraFrameData : DTDFVocab:Data [
    base:desc "Depth‑camera RGB‑D frame stream."
    DTDFVocab:fromData DepthCameraFramesTx
    DTDFVocab:inputTo TrackingFE
]

instance EgoVehicleStateData : DTDFVocab:Data [
    base:desc "Ego vehicle speed and steering‑angle measurements from odometry."
    DTDFVocab:fromData OdometryTx
    DTDFVocab:inputTo ACCControlFE
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "3‑D object tracks generated by clustering and Kalman‑filter pipeline."
    DTDFVocab:inputTo ACCControlFE
]

instance ACCCommandData : DTDFVocab:Data [
    base:desc "Desired speed and steering commands computed by the ACC control model."
    DTDFVocab:inputTo ActuationFE
]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering followed by a Kalman filter pipeline for object‑track generation."
    DTDFVocab:inputTo TrackingFE
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm (ISO 15622) for lead‑vehicle identification and speed set‑point calculation."
    DTDFVocab:inputTo ACCControlFE
]

// C11: Enablers (Functional Entities)
instance DataCollectionFE : DTDFVocab:Enabler [
    base:desc "ROS 2 package aggregating raw sensor streams and publishing them on DDS topics."
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Serialises sensor data, performs unit conversion, and aligns message types before ROS 2 publication."
    DTDFVocab:enables DataMonitoringService
]

instance TrackingFE : DTDFVocab:Enabler [
    base:desc "Executes the point‑cloud clustering and tracking model on incoming sensor data."
    DTDFVocab:enables ComputationOffloadingService
]

instance ACCControlFE : DTDFVocab:Enabler [
    base:desc "Runs the ACC control model on the Digital Twin, providing speed and steering set‑points."
    DTDFVocab:enables ComputationOffloadingService
]

instance VisualizationFE : DTDFVocab:Enabler [
    base:desc "Generates UI visualisations and time‑series reports for operators."
    DTDFVocab:enables DataMonitoringService
]

instance RemoteManagementFE : DTDFVocab:Enabler [
    base:desc "Enables operators to enable/disable ACC, adjust desired speed, and issue emergency‑brake commands."
    DTDFVocab:enables RemoteManagementService
]

instance ActuationFE : DTDFVocab:Enabler [
    base:desc "Sends desired speed and steering commands to vehicle actuators and handles emergency‑brake actuation."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualises real‑time vehicle state, projected path, and object tracks; generates time‑series reports."
    DTDFVocab:provides RealTimeVisualInsight, TimeSeriesReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs the ACC algorithm on the Digital Twin instead of the on‑board ECU."
    DTDFVocab:provides ACCComputationInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI allows operators to enable/disable ACC, adjust desired speed, and issue emergency‑brake commands."
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance RealTimeVisualInsight : DTDFVocab:Insight [
    base:desc "3‑D object tracks and projected vehicle path displayed in real time."
]

instance TimeSeriesReportInsight : DTDFVocab:Insight [
    base:desc "Time‑series report of vehicle state (speed, steering angle) over mission duration."
]

instance ACCComputationInsight : DTDFVocab:Insight [
    base:desc "Indicates successful off‑loading of ACC computation to the Digital Twin."
]

// C17: Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator adjusts the desired speed set‑point for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator issues an emergency brake command, triggering immediate actuation."
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller (motor voltage command) driven by the Actuation Functional Entity."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo driven by the Actuation Functional Entity."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity sends control commands back to the PT through the Actuation FE: (1) desired speed values that are converted to motor voltage commands, (2) enable/disable ACC flags, (3) modified speed set‑points, and (4) emergency‑brake commands. These messages travel over a Wi‑Fi link and are applied by the vehicle’s electronic speed controller and steering servo."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in real time with stringent timing: network latency between PT and DT must not exceed 100 ms (R7) and clocks on all components are synchronised to within 100 ms (R8). This ensures that off‑loaded ACC computations and control commands are delivered within a sub‑100 ms window."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation follows the ISO 23247 reference architecture: the Physical Twin Entity hosts sensor acquisition and actuation FEs; the Digital Twin Entity contains Data Collection, Presentation, Reporting, and Controlling FEs; the User Entity provides the 3D Visualization and Control Panel UI FEs; and a Cross‑System Data Translation FE mediates data exchange. Intra‑entity communication uses ROS 2 topics, while inter‑entity links use Wi‑Fi and the Data Translation layer."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is used across multiple lifecycle stages: (i) design and testing – as a cyber‑physical experimentation platform with high‑fidelity simulation, (ii) production/validation – to verify compliance with ISO 15622 ACC specifications, and (iii) operation – for real‑time monitoring, remote management, and performance analytics of the running vehicle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity is achieved by using raw sensor streams (LiDAR, camera) and real‑time clustering/tracking. Model validity is ensured by adhering to ISO 15622 for ACC behavior and by meeting the 100 ms latency and clock‑sync requirements, which are verified experimentally. The DBSCAN‑Kalman pipeline provides quantitative tracking accuracy, and the SQL‑based data storage enables post‑run validation against ground truth."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication between PT and DT occurs over a Wi‑Fi network using ROS 2 messages (DDS underneath). The Data Translation FE serialises messages, performs unit conversion, and ensures type compatibility across the ROS 2 middleware. No additional application‑layer protocol is specified beyond ROS 2."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the on‑board NVIDIA Jetson Orin Nano (Linux); the Digital Twin Entity (ACC computation, data processing, reporting) is deployed on a cloud or edge server accessible via Wi‑Fi; the User Entity UI runs on a separate workstation or laptop. All components are packaged as ROS 2 nodes and launched via ROS 2 launch files."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture and development follow ISO 23247 (Digital Twin Manufacturing Framework) as the primary reference architecture, ISO 15622 for ACC functional requirements, and cite ISO/IEC 30173 for digital‑twin terminology. OPC UA (IEC 62541) is mentioned as a possible implementation for the Data Translation FE, though not used in the case study."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed through real‑time latency (≤100 ms) and clock synchronization (≤100 ms) to guarantee timely control actions, compliance with ISO 15622 ACC specifications, and the inclusion of an emergency‑brake command that can be issued remotely. No explicit cybersecurity mechanisms (e.g., authentication, encryption) are described in the document."
]