// ===========================
// Physical Sensing Components
// ===========================

instance HokuyoLiDARUST10LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing 2‑D point‑cloud scans of the environment"
    DTDFVocab:producedData LiDARDataTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering RGB‑D frames for perception"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor reporting ego vehicle linear speed (m/s)"
    DTDFVocab:producedData SpeedStateDataTransmitted
]

instance VehicleSteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering encoder delivering current steering angle (rad)"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// ===========================
// Physical‑to‑Virtual Interaction
// ===========================

instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARUST10LX
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

instance SpeedStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSteeringAngleSensor
]

// ===========================
// Data Items (from Transmission)
// ===========================

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw point‑cloud scan from the Hokuyo LiDAR"
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo ROS2DDS
]

instance DepthCameraFrameData : DTDFVocab:Data [
    base:desc "RGB‑D frame from the Intel DeepSense camera"
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo ROS2DDS
]

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed value (m/s) sampled from the speed sensor"
    DTDFVocab:fromData SpeedStateDataTransmitted
    DTDFVocab:inputTo ROS2DDS
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering angle (rad) sampled from the steering encoder"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo ROS2DDS
]

// ===========================
// Models & Data Stores
// ===========================

instance PointCloudTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering followed by Kalman filter for object track generation"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm (ISO 15622) that computes following speed"
    DTDFVocab:inputTo Python38Runtime
]

instance SQLTimeSeriesDatabase : DTDFVocab:Model [
    base:desc "SQL database persisting time‑series vehicle state and object‑track data"
    DTDFVocab:inputTo OPCUADatasetTranslation
]

// Data produced by models (optional linking)
instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Tracked object list generated by PointCloudTrackingModel"
    DTDFVocab:inputTo ROS2DDS
]

instance ACCSpeedCommandData : DTDFVocab:Data [
    base:desc "Speed command (m/s) output by ACCControlModel for motor actuation"
    DTDFVocab:inputTo ROS2DDS
]

// ===========================
// Enablers (Software / Middleware)
// ===========================

instance ROS2DDS : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware using DDS for decentralized communication among PT, DT, and UI"
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:enables ComputationOffloadingService
    DTDFVocab:enables RemoteManagementService
]

instance Python38Runtime : DTDFVocab:Enabler [
    base:desc "Python 3.8 execution environment for ACC algorithm implementation"
    DTDFVocab:enables ComputationOffloadingService
]

instance CppLifecycleManager : DTDFVocab:Enabler [
    base:desc "C++ based node lifecycle management for ROS 2 packages"
    DTDFVocab:enables RemoteManagementService
]

instance MatlabSimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink runtime for complex perception algorithms (clustering, Kalman filter)"
    DTDFVocab:enables DataMonitoringService
]

instance NVIDIAJetPack5SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK providing GPU acceleration on Jetson devices"
    DTDFVocab:enables DataMonitoringService
]

instance OPCUADatasetTranslation : DTDFVocab:Enabler [
    base:desc "Optional OPC‑UA based data translation (serialization, unit conversion)"
    DTDFVocab:enables RemoteManagementService
]

// ===========================
// Services (DT Core Services)
// ===========================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualizes real‑time vehicle state, projected path, and object tracks"
    DTDFVocab:provides RealTimeVehicleStateVisualizationInsight
    DTDFVocab:provides ObjectTracksVisualizationInsight
    DTDFVocab:provides TimeSeriesReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm runs in the DT and returns speed commands to the PT"
    DTDFVocab:provides ACCSpeedCommandInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators enable/disable ACC, set desired speed, and trigger emergency braking via UI"
    DTDFVocab:provides EnableACCAction
    DTDFVocab:provides DisableACCAction
    DTDFVocab:provides SetDesiredSpeedAction
    DTDFVocab:provides EmergencyBrakeAction
]

// ===========================
// Insights
// ===========================

instance RealTimeVehicleStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live visualization of ego vehicle speed, steering angle, and trajectory"
]

instance ObjectTracksVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live rendering of detected object tracks from LiDAR and camera data"
]

instance TimeSeriesReportInsight : DTDFVocab:Insight [
    base:desc "Generated time‑series report of vehicle state and object tracks for post‑run analysis"
]

instance ACCSpeedCommandInsight : DTDFVocab:Insight [
    base:desc "Speed command produced by ACCControlModel presented to operator"
]

// ===========================
// Actions (Operator‑initiated)
// ===========================

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator enables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator disables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets the desired cruising speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers immediate brake to stop the vehicle"
    DTDFVocab:IsAutomatic false
]

// ===========================
// Acting Components (Physical Actuators)
// ===========================

instance MotorDriveActuator : DTDFVocab:ActingComponent [
    base:desc "Vehicle motor drive controlled via Vedder electronic speed controller"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo driven by the control FE to achieve commanded steering angle"
]

// ===========================
// Environment / Hardware Platform
// ===========================

instance JetsonNXOrinNanoPlatform : DTDFVocab:Environment [
    base:contains HokuyoLiDARUST10LX
    base:contains IntelDeepSenseD435iDepthCamera
    base:contains VehicleSpeedSensor
    base:contains VehicleSteeringAngleSensor
    base:contains MotorDriveActuator
    base:contains SteeringServoActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT, including the ACC‑computed desired speed, enable/disable ACC signals, and emergency‑brake commands, which are applied by the Actuation FE to the motor and steering actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT is required to maintain an end‑to‑end communication latency of ≤100 ms from vehicle to DT and to keep clocks synchronized within 100 ms accuracy, enabling real‑time off‑loading of the ACC function."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall DT is orchestrated as a set of ROS 2 packages representing Functional Entities (Data Collection FE, Presentation FE, Controlling FE, Actuation FE, User Interface FE, Data Translation FE) deployed across the Physical Twin Entity, Digital Twin Entity, User Entity, and a Cross‑System Entity for data translation, communicating intra‑entity via ROS 2 and inter‑entity via Wi‑Fi."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT operates under real‑time constraints (≤100 ms latency, 100 ms clock sync) and complies with ISO 15622 ACC functional requirements; high‑fidelity perception is achieved using DBSCAN and Kalman filtering of LiDAR data, and safety is addressed by limiting the ACC to performance class I on the scaled vehicle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication between PT and DT uses a Wi‑Fi link; intra‑entity communication among functional entities uses ROS 2 over DDS, with a Data Translation FE handling serialization and unit conversion of messages."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the vehicle’s Jetson Orin Nano; the Digital Twin Entity (ACC computation, data storage, visualization preprocessing) runs on a separate edge or cloud server; the User Entity (UI) runs on a workstation; each entity is packaged as a ROS 2 node set."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT architecture follows ISO 23247 Part 2 (reference architecture) and implements the ACC function per ISO 15622; the design also references ISO/IEC 30173:2023 for digital‑twin concepts and mentions OPC UA (IEC 62541) as a possible communication standard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by adhering to the latency (≤100 ms) and clock‑sync (≤100 ms) requirements, using ISO 15622 ACC specifications, and providing an emergency‑brake command; although explicit cybersecurity mechanisms are not described, the DT assumes controlled Wi‑Fi communication and structured ROS 2 messaging to mitigate safety risks."
]