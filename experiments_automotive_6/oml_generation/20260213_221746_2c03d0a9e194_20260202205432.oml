    base:desc "Real-time location and identification data from RFID tags for asset tracking in manufacturing environments."
    DTDFVocab:fromData RFIDAssetLocationData
    DTDFVocab:inputTo Neo4j
]

// C11: Enablers
instance AWSIoTGreengrass : DTDFVocab:Enabler [
    base:desc "AWS IoT Greengrass edge computing platform enabling local data processing and device management for automotive and industrial digital twins."
    DTDFVocab:enables RealTimeVehicleMonitoringService, PredictiveMaintenanceService, EdgeControlService
]

instance AzureDigitalTwins : DTDFVocab:Enabler [
    base:desc "Microsoft Azure Digital Twins platform providing cloud-based digital twin services with real-time data synchronization and visualization capabilities."
    DTDFVocab:enables RealTimeManufacturingMonitoringService, CyberBiophysicalHealthMonitoringService, OptimizationService
]

instance InfluxDB : DTDFVocab:Enabler [
    base:desc "Time-series database optimized for high-write throughput and real-time analytics, supporting industrial IoT and manufacturing digital twin applications."
    DTDFVocab:enables ProcessOptimizationService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "PostgreSQL extension for time-series data storage with SQL interface, enabling scalable analytics for manufacturing process monitoring."
    DTDFVocab:enables ProcessOptimizationService
]

instance Neo4j : DTDFVocab:Enabler [
    base:desc "Graph database for relationship modeling and traversal, enabling digital thread implementation for asset tracking and manufacturing processes."
    DTDFVocab:enables AssetTrackingService
]

instance ANSYSSimulation : DTDFVocab:Enabler [
    base:desc "ANSYS multiphysics simulation software for finite element analysis, computational fluid dynamics, and structural analysis in manufacturing digital twins."
    DTDFVocab:enables ProcessSimulationService
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for modeling, simulation, and real-time control of automotive and industrial systems in digital twin applications."
    DTDFVocab:enables VehicleDynamicsSimulationService
]

instance COMSOLMultiphysics : DTDFVocab:Enabler [
    base:desc "COMSOL Multiphysics simulation software for multi-physics modeling including electrochemical, fluid dynamics, and structural analysis in cyber-biophysical systems."
    DTDFVocab:enables HealthSimulationService
]

instance TensorFlow : DTDFVocab:Enabler [
    base:desc "Deep learning framework for building and training neural networks for anomaly detection, failure prediction, and control optimization in digital twins."
    DTDFVocab:enables AnomalyDetectionService
]

instance OPCUAProtocol : DTDFVocab:Enabler [
    base:desc "OPC Unified Architecture protocol enabling standardized interoperability between industrial devices, sensors, and digital twin platforms."
    DTDFVocab:enables RealTimeDataIntegrationService
]

instance MQTTProtocol : DTDFVocab:Enabler [
    base:desc "MQTT lightweight messaging protocol for IoT device communication, enabling efficient data transmission in digital twin applications."
    DTDFVocab:enables IoTDataIntegrationService
]

instance ROS2Framework : DTDFVocab:Enabler [
    base:desc "Robot Operating System 2 framework for industrial robotics enabling real-time data processing, control, and interoperability in manufacturing digital twins."
    DTDFVocab:enables RoboticsControlService
]

instance UnrealEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine game engine adapted for digital twin visualization providing high-fidelity 3D/4D visualization and immersive experiences."
