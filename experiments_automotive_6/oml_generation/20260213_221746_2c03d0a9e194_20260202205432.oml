]

instance RealTimeTelemetryData : DTDFVocab:Data [
    base:desc "Aggregated real-time telemetry data from automotive sensors including LiDAR, radar, IMU, and battery management system data for vehicle monitoring."
    DTDFVocab:fromData LiDARPointCloudData, RadarObjectDetectionData, IMUAttitudeData, BatteryManagementData
    DTDFVocab:inputTo AWSIoTGreengrass, AzureDigitalTwins
]

instance ManufacturingProcessData : DTDFVocab:Data [
    base:desc "Time-series data from industrial sensors including vibration, temperature, and force measurements for manufacturing process monitoring and optimization."
