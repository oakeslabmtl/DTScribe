// C2: Acting Components //
instance VehicleActuatorSystem : DTDFVocab:ActingComponent [
    base:desc "Embedded control units (ECUs) in automotive vehicles responsible for executing commands like braking, steering, and battery management based on real-time data from the digital twin."
]

instance SatellitePropulsionSystem : DTDFVocab:ActingComponent [
    base:desc "On-orbit propulsion systems for satellites enabling collision avoidance maneuvers and debris monitoring operations through digital twin-generated trajectory data."
]

instance ManufacturingActuatorNetwork : DTDFVocab:ActingComponent [
    base:desc "ISO 23247-compliant actuator networks in manufacturing plants controlling assembly line operations, energy distribution, and process parameters via digital twin feedback."
]

// C3: Physical Sensing Components
instance AutomotiveLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "High-resolution LiDAR sensors mounted on vehicles for real-time 3D environment mapping and object detection, providing raw point cloud data for digital twin visualization."
    DTDFVocab:producedData AutomotiveLiDARPointCloudData
]

instance VehicleStateSensorCluster : DTDFVocab:SensingComponent [
    base:desc "Cluster of sensors (motor, steering servo, vehicle dynamics) providing real-time telemetry data including actuation states, vehicle position, and operational parameters."
    DTDFVocab:producedData VehicleStateTelemetryData
]

instance AerospaceRadarSensor : DTDFVocab:SensingComponent [
    base:desc "Space-based radar systems for satellite debris detection and collision avoidance, transmitting real-time orbital tracking data to the digital twin."
    DTDFVocab:producedData SpaceDebrisTrackingData
]

instance ManufacturingIoTSensorNetwork : DTDFVocab:SensingComponent [
    base:desc "ISO 23247-compliant IoT sensor network monitoring manufacturing equipment health, environmental conditions, and process variables in real-time."
    DTDFVocab:producedData ManufacturingProcessTelemetryData
]

instance CyberBiophysicalMedicalSensor : DTDFVocab:SensingComponent [
    base:desc "Interdisciplinary sensors integrating biological (e.g., ECG, glucose monitoring) and physical parameters for cyber-biophysical system monitoring."
    DTDFVocab:producedData CyberBiophysicalHealthData
]

// C4: Physical-to-Virtual Interaction
instance AutomotiveLiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AutomotiveLiDARSensor
]

instance VehicleStateTelemetryData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensorCluster
]

instance SpaceDebrisTrackingData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AerospaceRadarSensor
]

instance ManufacturingProcessTelemetryData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ManufacturingIoTSensorNetwork
]

instance CyberBiophysicalHealthData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CyberBiophysicalMedicalSensor
]

// C10: Models/Data
instance AutomotiveVehicleDigitalModel : DTDFVocab:Model [
    base:desc "High-fidelity multi-body dynamics (MBD) model of automotive vehicles integrating physics-based simulations for collision avoidance, battery thermal management, and autonomous driving scenarios."
    DTDFVocab:inputTo AutomotiveSimulationEnabler
]

instance AerospaceSatelliteOrbitalModel : DTDFVocab:Model [
    base:desc "NASA STK-based orbital mechanics model for satellite trajectory prediction, collision avoidance algorithms, and space debris monitoring simulations."
    DTDFVocab:inputTo AerospaceSimulationEnabler
]

instance ManufacturingProcessSimulationModel : DTDFVocab:Model [
    base:desc "ISO 23247-compliant finite element analysis (FEA) and computational fluid dynamics (CFD) model for manufacturing process optimization and energy efficiency analysis."
    DTDFVocab:inputTo ManufacturingSimulationEnabler
]

instance CyberBiophysicalHealthModel : DTDFVocab:Model [
    base:desc "Multi-disciplinary model combining physics-based simulations with biological data for adaptive control in cyber-biophysical systems like medical devices and smart infrastructure."
    DTDFVocab:inputTo CyberBiophysicalSimulationEnabler
]

instance AutomotiveLiDARProcessedData : DTDFVocab:Data [
    base:desc "Structured object tracks derived from raw LiDAR point clouds via clustering and tracking algorithms, enabling real-time 3D visualization and collision detection."
    DTDFVocab:fromData AutomotiveLiDARPointCloudData
    DTDFVocab:inputTo VisualizationEnabler
]

instance VehicleStateStandardizedData : DTDFVocab:Data [
    base:desc "Aggregated and standardized vehicle state data including motor actuation, steering servo angles, and operational parameters converted via ISO 23247 Data Translation FE."
    DTDFVocab:fromData VehicleStateTelemetryData
    DTDFVocab:inputTo ControlEnabler
]

instance SpaceDebrisOrbitalData : DTDFVocab:Data [
    base:desc "Processed space debris tracking data including orbital parameters, collision risk assessments, and avoidance maneuver recommendations."
    DTDFVocab:fromData SpaceDebrisTrackingData
    DTDFVocab:inputTo AerospaceControlEnabler
]

instance ManufacturingProcessMetrics : DTDFVocab:Data [
    base:desc "Real-time process metrics including performance indicators, health status, and environmental conditions for manufacturing optimization."
    DTDFVocab:fromData ManufacturingProcessTelemetryData
    DTDFVocab:inputTo OptimizationEnabler
]

instance CyberBiophysicalFeedbackData : DTDFVocab:Data [
    base:desc "Bi-directional feedback data combining physical sensor inputs with digital control outputs for adaptive cyber-biophysical system regulation."
    DTDFVocab:fromData CyberBiophysicalHealthData
    DTDFVocab:inputTo AdaptiveControlEnabler
]

// C11: Enablers
instance AutomotiveSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Siemens Simcenter-based simulation engine enabling multi-body dynamics (MBD) and finite element analysis (FEA) for automotive component testing and failure prediction."
    DTDFVocab:enables AutomotiveMonitoringService, AutomotiveOptimizationService, AutomotivePredictionService, AutomotiveControlService
]

instance AerospaceSimulationEnabler : DTDFVocab:Enabler [
    base:desc "NASA STK and ANSYS Fluent integration for orbital mechanics simulations, collision avoidance algorithms, and space debris trajectory modeling."
    DTDFVocab:enables AerospaceMonitoringService, AerospaceOptimizationService, AerospaceControlService
]

instance ManufacturingSimulationEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247-compliant simulation platform combining ANSYS FEA and Siemens MindSphere for manufacturing process optimization and energy efficiency analysis."
    DTDFVocab:enables ManufacturingMonitoringService, ManufacturingOptimizationService, ManufacturingSimulationService
]

instance CyberBiophysicalSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Multi-disciplinary simulation framework integrating physics-based models with biological data for adaptive control in cyber-biophysical systems."
    DTDFVocab:enables CyberBiophysicalMonitoringService, CyberBiophysicalPredictionService, CyberBiophysicalControlService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unity/Unreal Engine-based 3D/4D visualization platform with AR/VR integration for real-time digital twin rendering and interactive diagnostics."
    DTDFVocab:enables AutomotiveVisualizationService, AerospaceVisualizationService, ManufacturingVisualizationService
]

instance ControlEnabler : DTDFVocab:Enabler [
    base:desc "ROS2-based real-time control system enabling closed-loop feedback for autonomous braking, collision avoidance, and adaptive manufacturing process control."
    DTDFVocab:enables AutomotiveControlService, AerospaceControlService, ManufacturingControlService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "AI-driven optimization engine using reinforcement learning for trajectory optimization, resource allocation, and process parameter tuning."
    DTDFVocab:enables AutomotiveOptimizationService, AerospaceOptimizationService, ManufacturingOptimizationService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247 Data Translation Functional Entity performing unit conversions, message type alignment, and data serialization for interoperability."
    DTDFVocab:enables DataProcessingService
]

instance EdgeComputingEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA EGX-based edge computing cluster for decentralized processing of real-time data streams with low-latency communication via 5G/URLLC."
    DTDFVocab:enables EdgeProcessingService
]

instance AIModelTrainingEnabler : DTDFVocab:Enabler [
    base:desc "TensorFlow Federated framework for distributed AI model training across digital twins using federated learning principles."
    DTDFVocab:enables PredictiveAnalyticsService
]

