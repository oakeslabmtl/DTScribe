// ------------------------------------------------------------
// 1. Physical Sensing Components
// ------------------------------------------------------------
instance HokuyoLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-110LX 2‑D LiDAR providing raw point‑cloud data"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelRealSenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering depth images"
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle telemetry extracting ego speed and steering angle from chassis electronics"
    DTDFVocab:producedData VehicleStateTransmitted
]

// ------------------------------------------------------------
// 2. Data Transmitted (Physical → Virtual)
// ------------------------------------------------------------
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARSensor
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseDepthCamera
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleTelemetrySensor
]

// ------------------------------------------------------------
// 3. Data (Virtual)
// ------------------------------------------------------------
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Point‑cloud data received from the Hokuyo LiDAR"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image received from the Intel RealSense camera"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Ego vehicle speed and steering angle telemetry"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

// ------------------------------------------------------------
// 4. Models / Algorithms
// ------------------------------------------------------------
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm applied to LiDAR point‑clouds"
    DTDFVocab:inputTo DataTranslationFE
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter that tracks objects using clustered points"
    DTDFVocab:inputTo DataTranslationFE
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) model compliant with ISO‑15622 performance class I"
    DTDFVocab:inputTo DataTranslationFE
]

// ------------------------------------------------------------
// 5. Enablers (Data Processing & Middleware)
// ------------------------------------------------------------
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Data Translation functional entity serialises ROS2 messages, performs unit conversion and aligns message types before delivery to the Digital Twin"
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:enables ComputationOffloadingService
    DTDFVocab:enables RemoteManagementService
]

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware used for Wi‑Fi communication between Physical Twin, Digital Twin and User entities"
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:enables ComputationOffloadingService
    DTDFVocab:enables RemoteManagementService
]

// ------------------------------------------------------------
// 6. Services
// ------------------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualises real‑time speed, steering angle, object tracks, projected path and generates downloadable reports"
    DTDFVocab:provides RealTimeVisualizationInsight
    DTDFVocab:provides GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs the ACC algorithm in the Digital Twin, off‑loading lead‑vehicle detection and speed computation from the onboard ECU"
    DTDFVocab:provides ACCControlInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, adjust desired speed and issue emergency brake commands via the UI"
    DTDFVocab:provides EnableACCAction
    DTDFVocab:provides DisableACCAction
    DTDFVocab:provides AdjustDesiredSpeedAction
    DTDFVocab:provides EmergencyBrakeAction
]

// ------------------------------------------------------------
// 7. Insights & Actions
// ------------------------------------------------------------
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides operators with live visualisation for informed decision‑making"
]

instance ACCControlInsight : DTDFVocab:Insight [
    base:desc "Displays ACC status, performance metrics and predicted vehicle trajectories"
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Adjust the desired speed set‑point for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issue an emergency brake command to the vehicle"
    DTDFVocab:IsAutomatic false
]

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Generate and download a report containing vehicle state and tracking history"
    DTDFVocab:IsAutomatic true
]

// ------------------------------------------------------------
// 8. Acting Components (Physical Actuators)
// ------------------------------------------------------------
instance VedderESCActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder electronic speed controller (ESC) receiving motor voltage commands to control vehicle speed"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo receiving angle commands to steer the vehicle"
]

// ------------------------------------------------------------
// 9. Digital Twin Entities (Constellation)
// ------------------------------------------------------------
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical twin running on the vehicle’s NVIDIA Jetson Orin‑Nano"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital twin executed on external cloud compute"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "Operator workstation hosting the UI"
]

// ------------------------------------------------------------
// 10. Environment (Logical Grouping)
// ------------------------------------------------------------
instance DTConstellationEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity, DigitalTwinEntity, UserEntity
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity computes ACC decisions (lead‑vehicle detection, desired speed) and sends control commands back to the PT over the same Wi‑Fi/ROS 2 channel. Commands include desired speed set‑points, ACC enable/disable flags, and emergency brake triggers, which are interpreted by the Actuation FE on the PT to drive the ESC and steering servo."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is designed for sub‑second operation with a maximum end‑to‑end latency of 100 ms from PT to DT (requirement R7) and clock synchronisation accuracy of 100 ms across components (requirement R8). Data collection, control and UI updates therefore occur at a 10 Hz‑plus rate."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates the Physical Twin Entity (sensors, actuators, Data Pre‑Processing FE), the Digital Twin Entity (Data Collection, Reporting, Controlling, Presentation FEs) and the User Entity (3D Visualization and Control Panel UI FEs). Interaction is mediated by ROS 2 topics across a Wi‑Fi network, with each FE implemented as an independent ROS 2 package."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during the operational stage for real‑time monitoring, remote management and off‑loaded ACC computation, and also supports development/testing activities (e.g., data collection for debugging) as described in the case‑study methodology."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT maintains high fidelity through real‑time sensor fusion (LiDAR + depth camera), validated tracking using DBSCAN and Kalman filtering, and ACC logic compliant with ISO 15622. Latency <100 ms and clock sync ≤100 ms ensure temporal fidelity; safety‑critical nature mandates deterministic communication via ROS 2 over Wi‑Fi."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses a Wi‑Fi network with ROS 2 as the middleware protocol. Data messages are serialized and translated by the Data Translation FE. The system also requires a standardized communication interface (requirement R1)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the on‑board NVIDIA Jetson Orin Nano; Digital Twin Entity executes on external compute resources (potentially cloud or edge server); User Entity UI runs on a workstation accessed by operators. Each entity is packaged as ROS 2 nodes and deployed on separate hardware."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture conforms to ISO 23247 (Digital Twin Manufacturing Framework) reference architecture and uses ISO 15622 for ACC functionality. ISO/IEC 30173:2023 is referenced as a generic DT terminology standard. OPC UA is mentioned as a possible communication technology."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed for safety‑critical operation, enforcing a maximum 100 ms latency and synchronized clocks to avoid timing errors. Remote commands (enable/disable ACC, emergency brake) are mediated through the User Entity UI. While explicit security mechanisms are not detailed, the use of standardized interfaces and controlled command pathways addresses basic safety concerns."
]