// =============================
// Data Transmitted (Physical → Virtual)
// =============================

// Raw LiDAR point cloud stream
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST110LXLiDAR
]

// Raw depth‑camera point cloud stream
instance DepthCameraPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
]

// Vehicle speed stream
instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

// Steering angle stream
instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Derived object tracks (after clustering & tracking)
instance ObjectTracksTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST110LXLiDAR, IntelRealSenseD435iDepthCamera
]

// =============================
// Physical Sensing Components
// =============================

// Hokuyo UST‑110LX LiDAR
instance HokuyoUST110LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑110LX 2D LiDAR providing real‑time point clouds of the surrounding environment"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

// Intel RealSense D435i Depth Camera
instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D images and point clouds"
    DTDFVocab:producedData DepthCameraPointCloudTransmitted
]

// Vehicle Speed Sensor (wheel encoder)
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel‑encoder based speed sensor measuring the ego vehicle forward speed"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

// Steering Angle Sensor
instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor reporting real‑time steering wheel position of the vehicle"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// =============================
// Insights & Actions
// =============================

instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of ego vehicle speed, steering angle, and trajectory"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Live display of detected and tracked objects with positions and velocities"
]

instance ACCStatusInsight : DTDFVocab:Insight [
    base:desc "Current ACC state (enabled/disabled) and computed target speed"
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator adjusts the desired cruise speed value"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator issues an emergency braking command to the physical twin"
    DTDFVocab:IsAutomatic false
]

// =============================
// Services
// =============================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualizes real‑time vehicle state, projected path, and object tracks generates saved reports"
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTracksInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm runs in the digital twin, computing lead‑vehicle detection and desired speed"
    DTDFVocab:provides ACCStatusInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI allows operators to enable/disable ACC, adjust desired speed, and issue emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakeAction
]

// =============================
// Enablers (Tools / Functional Entities)
// =============================

instance DBSCANClusteringEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 node implementing DBSCAN clustering in Python"
    DTDFVocab:enables DataMonitoringService
]

instance KalmanTrackingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 node running Kalman filter tracking in C++"
    DTDFVocab:enables DataMonitoringService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "ACC control module executed on NVIDIA Jetson Orin Nano (C++/MATLAB)"
    DTDFVocab:enables ComputationOffloadingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3‑D rendering engine (e.g., Unity/OGRE) driven by Python for UI visualization"
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Data Translation Functional Entity performing ROS2 message serialization and unit conversion"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance ROS2CommEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware handling Wi‑Fi topics between physical and digital twins"
    DTDFVocab:enables RemoteManagementService, DataMonitoringService
]

instance SQLPersistenceEnabler : DTDFVocab:Enabler [
    base:desc "SQL database storing object‑track logs and vehicle‑state datasets"
    DTDFVocab:enables DataMonitoringService
]

// =============================
// Models
// =============================

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm (lead‑vehicle detection & desired speed) compliant with ISO 15622"
    DTDFVocab:inputTo ACCComputationEnabler
]

instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering applied to LiDAR/Depth point clouds for obstacle segmentation"
    DTDFVocab:inputTo DBSCANClusteringEnabler
]

instance ObjectTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based tracker producing continuous object tracks"
    DTDFVocab:inputTo KalmanTrackingEnabler
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model generating real‑time graphics of vehicle state and object tracks"
    DTDFVocab:inputTo VisualizationEnabler
]

// =============================
// Data (Digital Twin)
// =============================

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "LiDAR point‑cloud data received from the physical twin"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DBSCANClusteringEnabler
]

instance DepthCameraPointCloudData : DTDFVocab:Data [
    base:desc "Depth‑camera point‑cloud data received from the physical twin"
    DTDFVocab:fromData DepthCameraPointCloudTransmitted
    DTDFVocab:inputTo DBSCANClusteringEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Forward speed value (m/s) of the ego vehicle"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo ACCComputationEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering angle (degrees) of the ego vehicle"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo ACCComputationEnabler
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Detected and tracked objects (position, velocity) derived from sensor fusion"
    DTDFVocab:fromData ObjectTracksTransmitted
    DTDFVocab:inputTo VisualizationEnabler
]

// =============================
// Acting Components
// =============================

instance MotorVoltageCommandActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage command generated by the Vedder ESC for speed actuation"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering‑servo actuation implemented by the Actuation Functional Entity"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Transmission of ACC commands (desired speed), remote‑management commands (enable/disable ACC, set speed, emergency‑brake) from the digital twin to the physical twin over Wi‑Fi via ROS 2, received by the Actuation Functional Entity and applied to the motor/steering hardware."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sub‑second, with a maximum end‑to‑end network latency of 100 ms and clock synchronization accuracy of 100 ms across all DTS components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A distributed architecture mapping the ISO 23247 reference architecture: Physical Twin Entity ↔ Digital Twin Entity ↔ User Entity, connected via ROS 2 intra‑entity links and Wi‑Fi inter‑entity links, with Cross‑System Entity handling data translation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the operational stage (real‑time monitoring and control) and supports development/testing phases through cyber‑physical experimentation, as described in the case study."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time fidelity ensured by ≤100 ms latency and synchronized clocks; ACC functionality conforms to ISO 15622; point‑cloud processing validated through DBSCAN clustering and Kalman filtering; data integrity maintained via standardized ROS 2 messaging and unit conversion."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Wi‑Fi network between the vehicle and external compute; ROS 2 topics for intra‑entity communication; Data Translation FE performs serialization, type alignment, and unit conversion."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the vehicle’s Jetson Orin Nano; Digital Twin Entity runs on an external PC or cloud server hosting ROS 2 nodes; User Entity (UI) runs on a workstation; cross‑system services run on the same host as the Digital Twin Entity; SQL database hosted externally."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system follows ISO 23247 (Digital Twin Manufacturing Framework) for architectural mapping, ISO 15622 for ACC functionality, and uses ROS 2 as a standardized middleware; OPC UA is mentioned as an optional protocol but not employed."
]