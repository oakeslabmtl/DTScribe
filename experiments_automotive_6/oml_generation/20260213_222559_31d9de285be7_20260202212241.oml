// C1: Entities
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "ROS2 package containing Software Function Entities responsible for data pre-processing, point cloud clustering, and tracking in autonomous vehicle systems"
    base:contains PhysicalTwinActuator, LidarPointCloudSensor, VehicleStateSensor, ObjectTrackingSensor, DataPreProcessingEnabler, PointCloudClusteringEnabler
    base:isContainedIn CyberBiophysicalEnvironment
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "ROS2 package containing Digital Twin Models and Enablers for simulation, optimization, and control of cyber-biophysical and automotive systems"
    base:contains CyberBiophysicalModel, AutomotiveSimulationModel, AerospaceOrbitalModel, BatteryDegradationModel, SimulationEnabler, OptimizationEnabler, ControlEnabler, PredictionEnabler
    base:isContainedIn CyberBiophysicalEnvironment
]

instance UserEntity : DTDFVocab:Component [
    base:desc "ROS2 package providing user interfaces for monitoring, visualization, and control of Digital Twin systems through interactive dashboards and AR/VR platforms"
    base:contains VisualizationEnabler, ReportingEnabler, VisualizationService, MonitoringService, ControlService
    base:isContainedIn CyberBiophysicalEnvironment
]

