// C2: Acting Components
instance VedderESCActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller managing the PT’s motor speed via command messages to the Jetson Orin Nano"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo motor translating steering angle commands into PWM signals"
]

// C3: Physical sensing components
instance HokuyoUST10LXLidarSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR generating full‑density point clouds transferred by ROS2 topics over Wi‑Fi (802.11)"
    DTDFVocab:producedData LidarPointCloudTopic
]

instance IntelD435IDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera providing RGB‑D frames via ROS2 topics"
    DTDFVocab:producedData DepthFrameTopic
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Built‑in vehicle speed sensor (tacho) publishing vehicle speed data over ROS2"
    DTDFVocab:producedData SpeedTopic
]

instance VehicleSteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle steering angle sensor publishing steering angle over ROS2"
    DTDFVocab:producedData SteeringAngleTopic
]

// C4: Physical‑to‑virtual interaction
instance LidarPointCloudTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidarSensor
]

instance DepthFrameTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435IDepthCameraSensor
]

instance SpeedTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSteeringAngleSensor
]

// C5: Data instances from sensor topics
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data received from the Hokuyo UST‑10LX LiDAR"
    DTDFVocab:fromData LidarPointCloudTopic
    DTDFVocab:inputTo DataTranslationEnabler
]

instance DepthFrameData : DTDFVocab:Data [
    base:desc "RGB‑D frames captured by the Intel D435i depth camera"
    DTDFVocab:fromData DepthFrameTopic
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed value published by the built‑in speed sensor"
    DTDFVocab:fromData SpeedTopic
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehicleSteeringData : DTDFVocab:Data [
    base:desc "Vehicle steering angle value published by the built‑in steering sensor"
    DTDFVocab:fromData SteeringAngleTopic
    DTDFVocab:inputTo DataTranslationEnabler
]

// C10: Models/Data
// 1. DBSCAN clustering of LiDAR
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN‑based point cloud clustering FE processing LiDAR data for object segmentation"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ClusteredPointCloudData : DTDFVocab:Data [
    base:desc "Clustered LiDAR point clouds output from the DBSCAN model"
    DTDFVocab:inputTo DataTranslationEnabler
]

// 2. Kalman filter tracking of objects
instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter tracking FE providing tracked object paths"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Tracked object positions and velocities from the Kalman filter"
    DTDFVocab:inputTo DataTranslationEnabler
]

// 3. ACC control FE (ISO 15622)
instance ACCControlModel : DTDFVocab:Model [
    base:desc "ACC controlling FE implementing ISO 15622 acceleration‑by‑distance logic"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ACCDecisionData : DTDFVocab:Data [
    base:desc "Desired speed command output by the ACC control model"
    DTDFVocab:inputTo DataTranslationEnabler
]

// 4. Data collection FE
instance DataCollectionModel : DTDFVocab:Model [
    base:desc "Data collection FE harvesting vehicle state and track data for telemetry and logging"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehicleStateLogData : DTDFVocab:Data [
    base:desc "Time‑series vehicle state snapshots logged by the data collection FE"
    DTDFVocab:inputTo DataTranslationEnabler
]

// 5. Reporting FE
instance ReportingModel : DTDFVocab:Model [
    base:desc "Reporting FE generating CSV/SQL logs of vehicle state and telemetry"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance AutomatedReportData : DTDFVocab:Data [
    base:desc "Automated report output for post‑hoc analysis"
    DTDFVocab:inputTo DataTranslationEnabler
]

// 6. Visualization FE
instance VisualizationModel : DTDFVocab:Model [
    base:desc "Visualization FE rendering 3D scenes of vehicle and surrounding objects via ROS2"
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VisualizationSceneData : DTDFVocab:Data [
    base:desc "3D scene representation ready for rendering"
    DTDFVocab:inputTo DataTranslationEnabler
]

// C11: Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data translation FE serializing, unit‑converting, and dispatching all incoming data streams to downstream services"
    DTDFVocab:enables DataMonitoringService,
                    ComputationOffloadingService,
                    RemoteManagementService,
                    VisualizationService,
                    ReportingService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of vehicle state, object tracks, projected driving path, and data logging"
    DTDFVocab:provides ACCPerformanceMetricsInsight,
                    ForceFieldProjectionInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm executed in the cloud (offloading) with desired speed commands sent back to the vehicle"
    DTDFVocab:provides ACCDecisionData
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI‑driven enable/disable ACC, alter desired speed, trigger emergency braking"
    DTDFVocab:provides EnableACCAction,
                    AlterDesiredSpeedAction,
                    TriggerEmergencyBrakingAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D rendering of vehicle and surrounding objects"
    DTDFVocab:provides VisualizationSceneData
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Generation of time‑series vehicle state snapshots stored in SQL"
    DTDFVocab:provides AutomatedReportGenerationInsight
]

// C17: Insights/Actions
instance ACCPerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Real‑time Adaptive Cruise Control performance metrics (e.g., gap maintenance, speed error)"
]

instance ForceFieldProjectionInsight : DTDFVocab:Insight [
    base:desc "force‑field projections of vehicle dynamics for operator decision support"
]

instance AutomatedReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Automated report generation capturing vehicle state data for post‑hoc analysis"
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable the Adaptive Cruise Control feature on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance AlterDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator command to alter the desired cruise speed"
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator command to trigger emergency braking"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT outputs ACC‑generated desired speed and steering commands via ROS2 topics that are consumed by the Physical Twin Entity’s Actuation FE, which writes voltage commands to the Vedder Electronic Speed Controller and PWM signals to the steering servo; additionally, remote‑management commands such as ACC enable/disable, desired speed setpoint, and emergency‑brake tokens are conveyed in the same manner."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates in real‑time with a maximum end‑to‑end latency of 100 ms (as per ISO 22407 V2, 3GPP 22.185) and clock synchronization accuracy of 100 ms across all participating nodes, ensuring that encounter data and commands are processed within sub‑100 ms cycles typical of ACC perception‑control loops."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT orchestrates its functional entities across a layered RA: the Physical Twin Entity handles sensor acquisition and actuation; the Digital Twin Entity processes data, runs ACC logic and generates reports; the User Entity exposes a 3D visualization and control panel; the Cross‑System Data Translation FE synchronizes message formats; all are distributed as ROS 2 packages over Wi‑Fi and run on a hybrid edge‑to‑cloud topology."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "This Digital Twin behaves as an operational twin during live vehicle runs, providing real‑time monitoring and control. It also supports a developmental phase where data is collected for validation and debugging, as the system is initially prototyped in a 1/10‑scale testbed."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time LiDAR data are processed by DBSCAN and Kalman filtering (validated against ground‑truth tracks in the 1/10‑scale vehicle), the ACC controller follows ISO 15622 specifications for safe deceleration, and end‑to‑end latency is bounded at 100 ms; however, the paper does not detail formal verification, testing procedures, or statistical error bounds for the models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication occurs over Wi‑Fi (IEEE 802.11) using ROS 2’s DDS implementation; the Data Translation FE serializes ROS messages, converts units, and forwards them across the network; timestamps are aligned via NTP with 100 ms accuracy."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Compute is partitioned between the on‑board Jetson Orin Nano (handling sensor acquisition and low‑level actuation) and a remote cloud node that hosts the Digital Twin Entity for ACC processing and data logging; the User Entity runs on a desktop or mobile device with cloud connectivity; all nodes are orchestrated through ROS 2 launch files."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture (with ISO 23247 parts 1‑4) provides the EA, ISO 15622 specifies the ACC control logic, ROS 2 follows the DDS standard (IEEE 1680?); additionally, OPC UA (IEC 62541) is referenced though not used directly; the PT’s sensors comply with industry standards for LiDAR and depth camera."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed for a safety‑critical automotive context, enforcing a maximum 100 ms end‑to‑end latency, synchronizing clocks to 100 ms, and integrating a human‑in‑the‑loop; however, explicit cybersecurity mechanisms (authentication, encryption) are not described in the document."
]