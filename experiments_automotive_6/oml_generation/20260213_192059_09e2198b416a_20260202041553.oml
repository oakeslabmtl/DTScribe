instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR for point cloud data"
    DTDFVocab:producedData LiDARPointCloudsTransmitted
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i Depth Camera for depth perception"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance EgoVehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor measuring ego vehicle speed"
    DTDFVocab:producedData EgoVehicleSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor measuring steering angle"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

instance MotorVoltageCommandActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage command actuation for speed control"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuation for vehicle direction"
]

instance LiDARPointCloudsTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]

instance EgoVehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoVehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance LiDARPointCloudsData : DTDFVocab:Data [
    base:desc "LiDAR point cloud data"
    DTDFVocab:fromData LiDARPointCloudsTransmitted
    DTDFVocab:inputTo PointCloudClusteringEnabler
]

instance DepthCameraData : DTDFVocab:Data [
    base:desc "Depth camera data for perception"
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo PointCloudClusteringEnabler
]

instance EgoVehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed data"
    DTDFVocab:fromData EgoVehicleSpeedDataTransmitted
    DTDFVocab:inputTo ACCEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle data"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo ACCEnabler
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks data from DBSCAN clustering and Kalman filtering"
    DTDFVocab:fromData LiDARPointCloudsTransmitted, DepthCameraDataTransmitted
    DTDFVocab:inputTo ACCEnabler
]

instance VehicleStateTimeseriesData : DTDFVocab:Data [
    base:desc "Vehicle state timeseries data"
    DTDFVocab:fromData EgoVehicleSpeedDataTransmitted, SteeringAngleDataTransmitted
    DTDFVocab:inputTo DataMonitoringService
]

instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Point Cloud Clustering & Tracking model using DBSCAN and Kalman filter"
    DTDFVocab:inputTo PointCloudClusteringEnabler
]

instance ACCModel : DTDFVocab:Model [
    base:desc "ACC model compliant with ISO 15622"
    DTDFVocab:inputTo ACCEnabler
]

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for inter-node communication"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance NVIDIAJetpack50SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for hardware acceleration"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance Python38 : DTDFVocab:Enabler [
    base:desc "Python 3.8 for ROS2 node implementation"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance Cpp : DTDFVocab:Enabler [
    base:desc "C++ for performance-critical ROS2 nodes"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for point cloud processing"
    DTDFVocab:enables DataMonitoringService
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL database for data storage"
    DTDFVocab:enables DataMonitoringService
]

instance PointCloudClusteringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for point cloud clustering and tracking"
    DTDFVocab:enables DataMonitoringService
]

instance ACCEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for ACC system execution"
    DTDFVocab:enables ComputationOffloadingService
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring service for real-time visualization, data saving, and report generation"
    DTDFVocab:provides DataVisualizationInsight, DataSavingAction, ReportGenerationAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation Offloading service for ACC system execution on digital twin"
    DTDFVocab:provides ACCDecisionInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service for enable/disable ACC, set desired speed, emergency braking via UI"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakingAction
]

instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of object tracks, driving path, and vehicle state"
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "ACC computes desired speed based on lead vehicle to inform driver or autonomous control decisions"
]

instance DataSavingAction : DTDFVocab:Action [
    base:desc "Data saving to SQL database"
    DTDFVocab:IsAutomatic true
]

instance ReportGenerationAction : DTDFVocab:Action [
    base:desc "Report generation from stored data"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable ACC via UI"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable ACC via UI"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set desired speed via UI"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Emergency braking via UI"
    DTDFVocab:IsAutomatic false
]

instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical Twin Entity as per ISO 23247"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital Twin Entity as per ISO 23247"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User Entity as per ISO 23247"
]

instance CrossSystemEntity : DTDFVocab:Component [
    base:desc "Cross-System Entity as per ISO 23247"
]

instance DataCollectionFE : DTDFVocab:Component [
    base:desc "Data Collection Functional Entity"
]

instance ActuationFE : DTDFVocab:Component [
    base:desc "Actuation Functional Entity"
]

instance AutonomousVehicle : DTDFVocab:Component [
    base:desc "1/10-scale autonomous vehicle retrofitted from Traxxas Slash 4x4 Premium with autonomy components"
]

instance JetsonNXAntenna : DTDFVocab:Component [
    base:desc "NVIDIA Jetson NX antenna for communication"
]

instance JetsonOrinNano : DTDFVocab:Component [
    base:desc "NVIDIA Jetson Orin Nano microcomputer"
]

instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller for motor voltage command actuation"
]

instance AutomotiveDigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity, DigitalTwinEntity, UserEntity, CrossSystemEntity, DataCollectionFE, ActuationFE, HokuyoUST10LXLiDAR, IntelDeepsenseD435iDepthCamera, EgoVehicleSpeedSensor, SteeringAngleSensor, MotorVoltageCommandActuator, SteeringServoActuator, ROS2Middleware, NVIDIAJetpack50SDK, Python38, Cpp, MATLABSimulink, SQLDatabase, PointCloudClusteringModel, ACCModel, DataMonitoringService, ComputationOffloadingService, RemoteManagementService, AutonomousVehicle, JetsonNXAntenna, JetsonOrinNano, VedderElectronicSpeedController
    base:desc "Automotive context implementation of ISO 23247 RA with case-based generalization for requirements"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Transmission of ACC control commands (desired speed, emergency braking) and steering commands from the digital twin to the physical twin's motor and steering actuators, with end-to-end latency <= 100 ms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with end-to-end latency of at most 100 ms and clock synchronization accuracy of 100 ms between components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated entities: Physical Twin Entity (on vehicle hardware), Digital Twin Entity (on vehicle/cloud), User Entity (remote UI), Cross-System Entity (Data Translation); components communicate via ROS2 internally and Wi-Fi between entities."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Primarily in the design and development phase for ACC system validation, with operational use for monitoring and remote management; represents the physical twin as operated."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "ROS2 network for internal communication, Wi-Fi for inter-entity communication; Data Translation FE for serialization, message alignment, and unit conversion; latency <=100 ms as per 3GPP TS 22.185."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity on vehicle's Jetson Orin Nano; Digital Twin Entity components deployed on vehicle and cloud; external SQL database for data storage."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture for DT framework; ACC implementation follows ISO 15622."
]