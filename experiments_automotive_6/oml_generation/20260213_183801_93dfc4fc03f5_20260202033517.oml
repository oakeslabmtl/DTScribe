// =====================
// Physical Sensing Components
// =====================

instance HokuyoUst110LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑110LX LiDAR providing raw point‑cloud data of the surrounding environment"
    DTDFVocab:producedData LiDARRawPointCloudTransmitted
]

instance IntelRealSenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera providing raw depth point‑cloud data"
    DTDFVocab:producedData DepthCameraPointCloudTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor delivering ego‑vehicle longitudinal speed"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor delivering current wheel steering angle"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// =====================
// Data Transmitted (Physical → Virtual)
// =====================

instance LiDARRawPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUst110LXLiDAR
]

instance DepthCameraPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iCamera
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// =====================
// Data Objects (Virtual)
// =====================

instance LiDARRawPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream used for clustering and tracking"
    DTDFVocab:fromData LiDARRawPointCloudTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance DepthCameraPointCloudData : DTDFVocab:Data [
    base:desc "Raw depth‑camera point‑cloud stream for environment perception"
    DTDFVocab:fromData DepthCameraPointCloudTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego‑vehicle longitudinal speed value"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering wheel angle of the ego vehicle"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance ProcessedObjectTracksData : DTDFVocab:Data [
    base:desc "Processed object tracks (position, velocity) derived from LiDAR point‑clouds"
    DTDFVocab:fromData LiDARRawPointCloudTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

// =====================
// Models / Algorithms
// =====================

instance AccDecisionModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control decision model (lead‑vehicle detection and speed computation per ISO 15622)"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point‑cloud to identify object candidates"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance TrackFilteringModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based tracking producing position and velocity of detected objects"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model for real‑time UI display"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

// =====================
// Enablers (Tooling & Middleware)
// =====================

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware (ROS2 packages per Functional Entity) handling messaging, serialization and unit conversion"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, ReportGenerationService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation Functional Entity for serialization and unit conversion between physical and virtual domains"
    DTDFVocab:enables ComputationOffloadingService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink toolchain used for clustering and tracking algorithm implementation"
    DTDFVocab:enables ComputationOffloadingService
]

// =====================
// Services (DT Capabilities)
// =====================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI service providing 3‑D visualization, live reporting and data logging"
    DTDFVocab:provides RealTimeVisualizationInsight, DataLoggingInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC algorithm execution to the Digital Twin"
    DTDFVocab:provides ACCDecisionInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables remote enable/disable of ACC, modification of set‑point speed and emergency braking"
    DTDFVocab:provides RemoteDecisionMakingInsight, AdjustACCParametersAction, EmergencyBrakeAction
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generates time‑series CSV reports and stores them in an external SQL database"
    DTDFVocab:provides PostRunReportInsight
]

// =====================
// Insights & Actions
// =====================

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Operators receive live 3‑D visualization of vehicle state and surrounding tracks"
]

instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "System continuously logs sensor streams for post‑run analysis"
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "ACC decision outcomes (target speed, spacing) are exposed for monitoring"
]

instance RemoteDecisionMakingInsight : DTDFVocab:Insight [
    base:desc "Operators can assess and modify ACC parameters during a run"
]

instance PostRunReportInsight : DTDFVocab:Insight [
    base:desc "After a mission, a CSV report summarizing vehicle state and track history is available"
]

instance AdjustACCParametersAction : DTDFVocab:Action [
    base:desc "Remote adjustment of ACC set‑point speed and following distance"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issue an emergency brake command to the physical twin"
    DTDFVocab:IsAutomatic false
]

// =====================
// Acting Components (Physical Actuators)
// =====================

instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage actuation via Vedder Electronic Speed Controller for propulsion"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuation for vehicle turning"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency braking command actuator driven by the Actuation Functional Entity"
]

// =====================
// Environments (Hosting Hardware)
// =====================

instance JetsonOrinNanoHardware : DTDFVocab:Environment [
    base:contains MotorVoltageActuator, SteeringServoActuator, EmergencyBrakeActuator,
                HokuyoUst110LXLiDAR, IntelRealSenseD435iCamera, VehicleSpeedSensor, SteeringAngleSensor
]

instance PCUserInterfaceHardware : DTDFVocab:Environment [
    base:desc "PC hosting UI services"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Transmission of desired speed set‑points, ACC enable/disable commands, emergency‑brake signals, and actuation commands (motor voltage, steering adjustments) from the Digital Twin Entity to the Physical Twin via the Actuation Functional Entity and a Wi‑Fi link."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in real‑time with an end‑to‑end network latency bounded to ≤100 ms (requirement R7) and all DTS components maintain clock synchronization within 100 ms (requirement R8), ensuring that data collection, control computation and actuation occur within a single perception cycle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An entity‑based architecture derived from ISO 23247 comprising a Physical Twin Entity (sensor/actuator layer), a Digital Twin Entity (data collection, processing, ACC control, reporting), a User Entity (UI and control panel), and a Cross‑System Data Translation Entity, interconnected via ROS 2 intra‑entity and Wi‑Fi inter‑entity links."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Safety‑critical ACC functionality follows ISO 15622 specifications; latency ≤100 ms and clock sync ≤100 ms are enforced to maintain real‑time fidelity; tracking accuracy relies on DBSCAN clustering and Kalman filtering, and physical‑to‑virtual data is timestamped for consistency."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Standardized communication interfaces realized with ROS 2 topics/services within the vehicle and Wi‑Fi (IEEE 802.11) for off‑board communication; the Data Translation FE handles message serialization and unit conversion across entities."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the on‑board NVIDIA Jetson Orin Nano; Digital Twin Entity and Data Translation Entity are hosted on an external compute platform (e.g., cloud or workstation) reachable via Wi‑Fi; User Entity UI runs on a separate PC."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adopts ISO 23247 (Digital Twin Manufacturing Framework) for architectural guidance, ISO 15622 for ACC functional requirements, ISO/IEC 30173:2023 for digital‑twin terminology, and 3GPP TS 22.185 for latency benchmarks; OPC UA is mentioned as an optional communication standard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations include adherence to ISO 15622 ACC specifications, enforced network latency ≤100 ms, and clock synchronization ≤100 ms to ensure deterministic control; explicit cybersecurity mechanisms are not described in the document."
]