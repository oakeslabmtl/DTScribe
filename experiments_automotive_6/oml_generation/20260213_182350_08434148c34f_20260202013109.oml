// ==================== Sensing Components ====================
// C3: Physical sensing components
instance HokuyoUst10LxLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR providing raw point‑cloud data from the 1/10‑scale vehicle"
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering depth point‑cloud data"
    DTDFVocab:producedData DepthCameraPointCloudDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor delivering real‑time ego‑vehicle speed"
    DTDFVocab:producedData VehicleSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor delivering real‑time steering angle"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// ==================== Acting Components ====================
// C2: Acting Components
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage command sent to the drive motor for longitudinal control"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering‑servo command for vehicle steering direction"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency brake command generated by the DT and sent to vehicle actuators"
]

// ==================== Data Transmitted ====================
// C4: Physical‑to‑virtual interaction
instance VehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUst10LxLiDARSensor
]

instance DepthCameraPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
]

// ==================== Data ====================
// C4: Data produced from transmitted streams
instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Real‑time ego‑vehicle speed transmitted over ROS2"
    DTDFVocab:fromData VehicleSpeedDataTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Real‑time steering angle transmitted over ROS2"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw point‑cloud data from Hokuyo LiDAR"
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance DepthCameraPointCloudData : DTDFVocab:Data [
    base:desc "Depth point‑cloud data from Intel RealSense D435i"
    DTDFVocab:fromData DepthCameraPointCloudDataTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

// ==================== Models / Data Stores ====================
// C10: Models/Data
instance DbscanClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering model used for object detection"
    DTDFVocab:inputTo PointCloudClusteringTrackingFE
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking model for maintaining object tracks across frames"
    DTDFVocab:inputTo PointCloudClusteringTrackingFE
]

instance AccControlModel : DTDFVocab:Model [
    base:desc "ACC control model compliant with ISO 15622 class I for longitudinal control"
    DTDFVocab:inputTo AccComputationFE
]

instance SqlDatabaseModel : DTDFVocab:Model [
    base:desc "SQL database storing persistent object tracks and vehicle state"
    DTDFVocab:inputTo DataCollectionFE
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization data structures for rendering object tracks and projected path"
    DTDFVocab:inputTo VisualizationEngineFE
]

// ==================== Enablers (Functional Entities) ====================
// C11: Enablers
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Data Translation FE serialises ROS2 messages, performs unit conversion and aligns types"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance PointCloudClusteringTrackingFE : DTDFVocab:Enabler [
    base:desc "FE running DBSCAN clustering and Kalman filter tracking on point‑cloud data"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance AccComputationFE : DTDFVocab:Enabler [
    base:desc "FE executing the ACC algorithm in the digital twin"
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService
]

instance DataCollectionFE : DTDFVocab:Enabler [
    base:desc "FE collecting processed data and persisting it to the SQL database"
    DTDFVocab:enables ReportGenerationService, DataMonitoringService
]

instance VisualizationEngineFE : DTDFVocab:Enabler [
    base:desc "FE rendering 3‑D visualisations for the UI"
    DTDFVocab:enables Visualization3DService
]

// ==================== Services ====================
// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI visualisation and reporting of vehicle state and object tracks"
    DTDFVocab:provides LiveSpeedInsight, LiveSteeringAngleInsight, ObjectTracksInsight, ProjectedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC algorithm execution to the digital twin"
    DTDFVocab:provides AccControlInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operator to enable/disable ACC, set speed set‑point, and issue emergency brake"
    DTDFVocab:provides AccEnableAction, AccDisableAction, SpeedSetpointAction, EmergencyBrakeAction
]

instance Visualization3DService : DTDFVocab:Service [
    base:desc "Provides 3‑D visualisation of object tracks and projected paths"
    DTDFVocab:provides ObjectTracks3DVisualizationInsight
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generates time‑series reports of vehicle state and object tracking data"
    DTDFVocab:provides TimeSeriesReportInsight
]

// ==================== Insights ====================
// C17: Insights
instance LiveSpeedInsight : DTDFVocab:Insight [
    base:desc "Current vehicle speed displayed in the operator UI"
]

instance LiveSteeringAngleInsight : DTDFVocab:Insight [
    base:desc "Current steering angle displayed in the operator UI"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Detected object tracks visualised on the UI"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected vehicle path based on ACC decision shown on UI"
]

instance AccControlInsight : DTDFVocab:Insight [
    base:desc "ACC algorithm output (desired acceleration) used for longitudinal control"
]

instance ObjectTracks3DVisualizationInsight : DTDFVocab:Insight [
    base:desc "3‑D rendering of object tracks and environment for operator situational awareness"
]

instance TimeSeriesReportInsight : DTDFVocab:Insight [
    base:desc "Generated report summarising time‑series vehicle state and tracking data"
]

// ==================== Actions ====================
// C17: Actions
instance AccEnableAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control via remote command"
    DTDFVocab:IsAutomatic false
]

instance AccDisableAction : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control via remote command"
    DTDFVocab:IsAutomatic false
]

instance SpeedSetpointAction : DTDFVocab:Action [
    base:desc "Set desired speed set‑point for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issue emergency brake command to vehicle actuators"
    DTDFVocab:IsAutomatic true
]

// ==================== Environment & System Components ====================
// C17: Environment
instance VehicleScaleEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity, DigitalTwinEntity, UserEntity, CrossSystemEntity
]

// System Entities
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical twin running on on‑vehicle NVIDIA Jetson NX/Orin‑Nano, hosting sensors and ROS2 middleware"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital twin executed on external cloud compute, performing ACC, data processing and visualization"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "Operator console providing UI for monitoring, remote management and report generation"
]

instance CrossSystemEntity : DTDFVocab:Component [
    base:desc "Data Translation functional entity bridging physical and digital twins over Wi‑Fi using ROS2"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity sends desired speed set‑points, ACC enable/disable commands, speed‑modification requests, and emergency‑brake signals back to the Physical Twin Entity over the same Wi‑Fi/ROS 2 channel; the Actuation FE translates these high‑level commands into motor voltage and steering‑servo signals for the vehicle."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in real‑time with a maximum end‑to‑end network latency of 100 ms (per requirement R7) and clock synchronisation accuracy of 100 ms (requirement R8), matching the perception‑cycle update rate of the physical vehicle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An entity‑based architecture derived from ISO 23247: Physical Twin Entity (sensors, actuation), Digital Twin Entity (data collection, ACC, reporting, visualization), User Entity (UI panels), and Cross‑System Data Translation FE; communication within entities uses ROS 2, while inter‑entity links use Wi‑Fi with standardized message formats."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT supports the design, testing, and operational stages of the vehicle: it is used for cyber‑physical experimentation during development, for validation of ACC requirements, and for runtime monitoring and remote control during vehicle operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time sensor data fidelity ensured by 100 ms latency and clock sync; ACC logic conforms to ISO 15622 class I; clustering and tracking validated by DBSCAN and Kalman filter on live LiDAR; limited to 1/10‑scale dynamics and no road‑curvature handling, which bounds model validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional Wi‑Fi link between vehicle and DT, employing ROS 2 messages wrapped by the Data Translation FE; optional OPC UA noted as a possible transport layer but not used in the implementation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the onboard NVIDIA Jetson Orin Nano; Digital Twin Entity runs on an external workstation or cloud server; User Entity runs on an operator PC; each functional entity is packaged as a ROS 2 node set."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Implemented according to ISO 23247 reference architecture, ISO 15622 ACC functional standard, ROS 2 communication standards, 3GPP TS 22.185 latency guideline, and leverages ISO/IEC 30173:2023 concepts; optional OPC UA (IEC 62541) mentioned for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed for safety‑critical operation with a hard latency ceiling of 100 ms and clock synchronisation of 100 ms; remote management includes an emergency‑brake command; however, specific cybersecurity mechanisms (authentication, encryption) are not described in the document."
]