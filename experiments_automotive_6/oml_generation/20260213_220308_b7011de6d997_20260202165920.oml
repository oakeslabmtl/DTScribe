    base:desc "AI-driven neural network model for failure prediction using historical and real-time sensor data"
    DTDFVocab:inputTo EdgeProcessingNode, InfluxDBDataStore
]

instance ManufacturingProcessModel : DTDFVocab:Model [
    base:desc "Discrete-event simulation model for manufacturing process optimization and predictive maintenance"
    DTDFVocab:inputTo DataLake, MQTTBroker
]

instance BatteryEnergyModel : DTDFVocab:Model [
    base:desc "Physics-based energy consumption model for battery management systems in electric vehicles"
    DTDFVocab:inputTo OPCUADataExchangeSystem, ROS2Network
]

instance CollisionAvoidanceModel : DTDFVocab:Model [
    base:desc "Real-time physics-based model for space-based asset collision avoidance systems"
    DTDFVocab:inputTo EdgeProcessingNode, 5GNetwork
]

instance RealTimeTrajectoryModel : DTDFVocab:Model [
    base:desc "Continuous physics-based model for vehicle trajectory prediction and adaptive cruise control"
    DTDFVocab:inputTo ROS2Network, OPCUADataExchangeSystem
]

instance ManufacturingDefectModel : DTDFVocab:Model [
    base:desc "Hybrid model combining physics-based and ML components for defect detection in manufacturing"
