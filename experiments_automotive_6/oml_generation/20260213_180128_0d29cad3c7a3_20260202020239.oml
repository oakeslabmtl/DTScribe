// C3: Physical sensing components
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor providing raw point cloud data stream from the vehicle."
    DTDFVocab:producedData LiDARPointCloudTransmission
]

instance MotorSignalSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle motor signal sensor providing motor state data."
    DTDFVocab:producedData MotorSignalTransmission
]

instance SteeringSignalSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle steering signal sensor providing steering state data."
    DTDFVocab:producedData SteeringSignalTransmission
]

instance ServoSignalSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle servo signal sensor providing servo state data."
    DTDFVocab:producedData ServoSignalTransmission
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor providing overall vehicle state signals."
    DTDFVocab:producedData VehicleStateTransmission
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance LiDARPointCloudTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance MotorSignalTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSignalSensor
]

instance SteeringSignalTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringSignalSensor
]

instance ServoSignalTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ServoSignalSensor
]

instance VehicleStateTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// C10: Models/Data
instance ProcessedPointCloudData : DTDFVocab:Data [
    base:desc "Clustered and tracked point cloud data ready for visualization and storage."
    DTDFVocab:fromData LiDARPointCloudTransmission
    DTDFVocab:inputTo PointCloudClusteringEnabler, DataTranslationEnabler
]

instance ProcessedVehicleStateData : DTDFVocab:Data [
    base:desc "Processed vehicle state data including motor, steering, servo and overall state."
    DTDFVocab:fromData MotorSignalTransmission, SteeringSignalTransmission, ServoSignalTransmission, VehicleStateTransmission
    DTDFVocab:inputTo DataTranslationEnabler
]

// C11: Enablers
instance PointCloudClusteringEnabler : DTDFVocab:Enabler [
    base:desc "Clusters and tracks raw LiDAR point clouds for object detection."
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Serialises, aligns message types, and performs unit conversions according to ISO 23247."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance WiFiLinkEnabler : DTDFVocab:Enabler [
    base:desc "Handles physical-to-virtual data transmission over WiFi using UDP."
]

instance ROS2NetworkEnabler : DTDFVocab:Enabler [
    base:desc "Facilitates intra-DTS component communication over ROS2 network."
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI displays real‑time vehicle state data, projected driving path, and detected object tracks; allows users to view, save, and generate reports."
    DTDFVocab:provides ViewDataAction, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm is executed on the DT (e.g., cloud resources) and the resulting desired speed is sent back to the vehicle for actuation."
    DTDFVocab:provides ReturnDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI enables operators to enable/disable ACC, set a desired speed, and issue an emergency‑braking command remotely."
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, IssueEmergencyBrakeAction
]

// C17: Insights/Actions
instance ViewDataAction : DTDFVocab:Action [
    base:desc "Allows user to view current vehicle state data."
    DTDFVocab:IsAutomatic false
]

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Creates and saves a report of vehicle data."
    DTDFVocab:IsAutomatic false
]

instance ReturnDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sends computed desired speed to vehicle for actuation."
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables Adaptive Cruise Control on the vehicle."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disables Adaptive Cruise Control on the vehicle."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets a desired speed for the vehicle."
    DTDFVocab:IsAutomatic false
]

instance IssueEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issues emergency braking command to vehicle."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DTS sends control commands back to the vehicle over the same Wi‑Fi/UDP link. Commands include ACC enable/disable, desired speed set‑point, and emergency‑brake activation. These commands are generated by the Controlling/Actuation functional entities, serialized by the Data Translation component, and transmitted to the vehicle’s actuators (motor, steering servo). The vehicle returns updated state information, which is displayed in the UI to confirm execution."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT requires that the physical twin and its digital counterpart share a common notion of time; clock synchronization must achieve at least 100 ms accuracy, which is the limit imposed by the available hardware. This synchronization constraint is required for computation off‑loading between devices; stricter sub‑100 ms bounds are mandated by external safety‑critical vehicular standards but are not imposed in this implementation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO‑23247 reference architecture with an entity‑based decomposition. Functional Entities are realized as ROS 2 packages; each package contains one or more ROS 2 nodes that implement the FE’s behavior. The three entities communicate via ROS 2 middleware, providing data management, actuation and user interaction. Resource management is achieved by mapping each entity to dedicated compute resources (e.g., separate on‑board computers). The overall orchestration relies on ROS 2’s publish/subscribe and service mechanisms to coordinate the entities."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection consists of a ROS 2 middleware backbone for internal component messaging and a Wi‑Fi network using UDP for external communication between the physical twin and the DTS. The architecture follows a client‑server style where the vehicle acts as a data source and command receiver, while the DTS provides processing and UI services. The system is required to sustain low end‑to‑end latency to meet safety‑critical needs, though exact bandwidth or latency figures are not stated. Redundancy and security mechanisms are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT services can be hosted on compute resources that may reside in the cloud, as the context mentions off‑loading compute to 'better‑suited equipment, e.g., in the cloud'. No specific details on storage size, scaling strategy, deployment models (container, VM, edge) or availability guarantees are provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin complies with ISO 23247 (2021), the 'Digital twin framework for manufacturing' standard. Compliance involves adhering to Part 2 of the standard, which defines a reference architecture based on entities such as the Observable Manufacturing Element (OME), the Data Collection and Device Control Entity, the Digital Twin Entity, and the User Entity. Each entity is composed of Functional Entities that perform specific tasks (e.g., actuation, data transformation, user interfacing). The standard does not prescribe specific implementation technologies, but the architecture may be realized with protocols such as OPC Unified Architecture. No additional certification or interoperability specifications are described in the document."
]