// =============================
// Physical Twin Entity (on‑vehicle Jetson)
// =============================
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "1/10‑scale autonomous vehicle built from a Traxxas Slash 4×4 platform, equipped with Jetson NX antenna, Jetson Orin‑Nano, Hokuyo UST‑10LX LiDAR, Intel RealSense D435i depth camera, and ROS2 middleware."
]

// =============================
// Digital Twin Entity (cloud/external compute)
// =============================
instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "External compute platform hosting the Digital Twin, executing ACC control, clustering, tracking, visualization and reporting services."
]

// =============================
// User Entity (operator console)
// =============================
instance UserEntity : DTDFVocab:Component [
    base:desc "Operator console providing real‑time UI visualisation, remote‑management controls and report access."
]

// =============================
// Cross‑System Entity (Data Translation Functional Entity)
// =============================
instance DataTranslationCrossSystemEntity : DTDFVocab:Component [
    base:desc "Functional Entity that serialises ROS2 messages, performs unit conversion and aligns message types between Physical and Digital Twins."
]

// =============================
// Sensing Components (Physical)
// =============================
instance HokuyoLidarSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2D LiDAR providing raw point‑cloud data of the surroundings."
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelRealSenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering depth images and RGB data."
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel‑based speed sensor delivering ego‑vehicle speed in m/s."
    DTDFVocab:producedData SpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle encoder providing current steering wheel angle in degrees."
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// =============================
// Data Transmitted (Physical → Virtual)
// =============================
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLidarSensor
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseDepthCamera
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// =============================
// Data (Virtual)
// =============================
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "3‑D point‑cloud generated from LiDAR scans after unit conversion."
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo PointCloudClusteringModelEnabler, DataTranslationEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image (and RGB) from RealSense camera after serialization."
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego‑vehicle longitudinal speed (m/s) after unit conversion."
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo ACCControlModelEnabler, DataTranslationEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering wheel angle (degrees) after unit conversion."
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo ACCControlModelEnabler, DataTranslationEnabler
]

// =============================
// Enablers (Tools, Models, Infrastructure)
// =============================
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware (C++/Python) for node lifecycle, topic transport and QoS."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, VisualizationService, ReportGenerationService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation Functional Entity that serialises ROS2 messages, performs unit conversion and aligns message schemas."
    DTDFVocab:enables DataMonitoringService
]

instance PointCloudClusteringModelEnabler : DTDFVocab:Enabler [
    base:desc "DBSCAN point‑cloud clustering model implemented in Python/ROS2 for object segmentation."
    DTDFVocab:enables ComputationOffloadingService
]

instance TrackingModelEnabler : DTDFVocab:Enabler [
    base:desc "Kalman‑filter based multi‑target tracking model for maintaining object tracks over time."
    DTDFVocab:enables ComputationOffloadingService
]

instance ACCControlModelEnabler : DTDFVocab:Enabler [
    base:desc "Adaptive Cruise Control (ACC) control model compliant with ISO 15622 class I, executed on the Digital Twin."
    DTDFVocab:enables RemoteManagementService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "PostgreSQL database storing persistent object tracks, vehicle state and historical time‑series."
    DTDFVocab:enables ReportGenerationService
]

instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "3‑D visualization engine (e.g., Unity/Godot) rendering vehicle pose, object tracks and projected paths."
    DTDFVocab:enables VisualizationService
]

instance ReportGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Report generation module creating PDF/HTML summaries of time‑series data and performance metrics."
    DTDFVocab:enables ReportGenerationService
]

instance MATLABSimulinkProcessingEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment used for complex signal processing and model‑based design."
    DTDFVocab:enables ComputationOffloadingService
]

instance NVIDIAJetpackSDKEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK providing GPU acceleration for perception and control algorithms."
    DTDFVocab:enables ComputationOffloadingService
]

instance WiFiNetworkingEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi link used for real‑time ROS2 topic transport between Physical and Digital Twins."
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance OPCUAServerEnabler : DTDFVocab:Enabler [
    base:desc "Optional OPC‑UA server exposing standardized interfaces for external systems."
    DTDFVocab:enables RemoteManagementService
]

// =============================
// Services
// =============================
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI visualisation and reporting of vehicle state, object tracks and sensor data."
    DTDFVocab:provides LiveSpeedInsight, LiveSteeringAngleInsight, LiveObjectTracksInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes perception (clustering, tracking) and ACC algorithms on the Digital Twin."
    DTDFVocab:provides LiveObjectTracksInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables remote commands: ACC on/off, desired speed set‑point, and emergency brake."
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3‑D visualisation of vehicle trajectory, object tracks and projected future path."
    DTDFVocab:provides ProjectedPathInsight
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generates post‑run analysis reports from persisted time‑series data."
    DTDFVocab:provides PostRunReportInsight
]

// =============================
// Insights
// =============================
instance LiveSpeedInsight : DTDFVocab:Insight [
    base:desc "Live display of ego‑vehicle longitudinal speed."
]

instance LiveSteeringAngleInsight : DTDFVocab:Insight [
    base:desc "Live display of current steering wheel angle."
]

instance LiveObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Live visualisation of detected object tracks derived from DBSCAN clustering and Kalman filtering."
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected vehicle path based on current ACC set‑point and dynamics."
]

instance PostRunReportInsight : DTDFVocab:Insight [
    base:desc "Summarised performance report containing speed, steering, and object‑track statistics."
]

// =============================
// Actions
// =============================
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Command to enable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Command to disable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set the target speed (m/s) for the ACC controller."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediate activation of emergency brake to stop the vehicle."
    DTDFVocab:IsAutomatic true
]

// =============================
// Acting Components (Physical)
// =============================
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage command interface driving the rear wheels."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Servo command interface controlling the steering mechanism."
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator that applies a mechanical brake upon EmergencyBrakeAction."
]

// =============================
// Environment Composition
// =============================
instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:contains HokuyoLidarSensor, IntelRealSenseDepthCamera, VehicleSpeedSensor, SteeringAngleSensor,
                MotorVoltageActuator, SteeringServoActuator, EmergencyBrakeActuator, WiFiNetworkingEnabler
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains ROS2MiddlewareEnabler, DataTranslationEnabler, PointCloudClusteringModelEnabler,
                TrackingModelEnabler, ACCControlModelEnabler, MATLABSimulinkProcessingEnabler,
                NVIDIAJetpackSDKEnabler, SQLDatabaseEnabler, VisualizationEngineEnabler,
                ReportGeneratorEnabler, OPCUAServerEnabler
]

instance UserConsoleEnvironment : DTDFVocab:Environment [
    base:contains DataMonitoringService, RemoteManagementService, VisualizationService,
                ReportGenerationService, UserEntity
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity sends desired speed set‑points, ACC enable/disable commands, speed‑modification requests, and emergency‑brake signals back to the Physical Twin Entity over the same Wi‑Fi/ROS 2 channel; the Actuation FE translates these high‑level commands into motor voltage and steering‑servo signals for the vehicle."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in real‑time with a maximum end‑to‑end network latency of 100 ms (per requirement R7) and clock synchronisation accuracy of 100 ms (requirement R8), matching the perception‑cycle update rate of the physical vehicle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An entity‑based architecture derived from ISO 23247: Physical Twin Entity (sensors, actuation), Digital Twin Entity (data collection, ACC, reporting, visualization), User Entity (UI panels), and Cross‑System Data Translation FE; communication within entities uses ROS 2, while inter‑entity links use Wi‑Fi with standardized message formats."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT supports the design, testing, and operational stages of the vehicle: it is used for cyber‑physical experimentation during development, for validation of ACC requirements, and for runtime monitoring and remote control during vehicle operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time sensor data fidelity ensured by 100 ms latency and clock sync; ACC logic conforms to ISO 15622 class I; clustering and tracking validated by DBSCAN and Kalman filter on live LiDAR; limited to 1/10‑scale dynamics and no road‑curvature handling, which bounds model validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional Wi‑Fi link between vehicle and DT, employing ROS 2 messages wrapped by the Data Translation FE; optional OPC UA noted as a possible transport layer but not used in the implementation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the onboard NVIDIA Jetson Orin Nano; Digital Twin Entity runs on an external workstation or cloud server; User Entity runs on an operator PC; each functional entity is packaged as a ROS 2 node set."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Implemented according to ISO 23247 reference architecture, ISO 15622 ACC functional standard, ROS 2 communication standards, 3GPP TS 22.185 latency guideline, and leverages ISO/IEC 30173:2023 concepts; optional OPC UA (IEC 62541) mentioned for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed for safety‑critical operation with a hard latency ceiling of 100 ms and clock synchronisation of 100 ms; remote management includes an emergency‑brake command; however, specific cybersecurity mechanisms (authentication, encryption) are not described in the document."
]