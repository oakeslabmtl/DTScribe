import DTDFVocab

// -----------------------------------------------------------
// 1. Physical Sensing Components
// -----------------------------------------------------------

instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing raw point clouds for perception",
    DTDFVocab:producedData LiDARRawPointCloudTransmitted
]

instance IntelRealSenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D frames",
    DTDFVocab:producedData DepthCameraRawFrameTransmitted
]

instance EgoSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring the ego‑vehicle longitudinal speed",
    DTDFVocab:producedData EgoSpeedRawTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring the steering wheel angle",
    DTDFVocab:producedData SteeringAngleRawTransmitted
]

// -----------------------------------------------------------
// 2. Acting Components (Physical Twin)
// -----------------------------------------------------------

instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder ESC driving the motor for longitudinal speed control"
]

instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Servo actuator providing lateral steering control"
]

instance EmergencyBrakeInterface : DTDFVocab:ActingComponent [
    base:desc "Command interface that accepts emergency‑brake signals"
]

// -----------------------------------------------------------
// 3. Data Transmitted (Physical → Virtual)
// -----------------------------------------------------------

instance LiDARRawPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthCameraRawFrameTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseDepthCamera
]

instance EgoSpeedRawTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoSpeedSensor
]

instance SteeringAngleRawTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// -----------------------------------------------------------
// 4. Data (Processed / Derived)
// -----------------------------------------------------------

instance LiDARClusteredObjectData : DTDFVocab:Data [
    base:desc "Object tracks derived from LiDAR point clouds after DBSCAN clustering and Kalman filtering",
    DTDFVocab:fromData LiDARRawPointCloudTransmitted,
    DTDFVocab:inputTo DataPreProcessingFE
]

instance DepthProcessedData : DTDFVocab:Data [
    base:desc "Depth information extracted from RGB‑D frames for path prediction",
    DTDFVocab:fromData DepthCameraRawFrameTransmitted,
    DTDFVocab:inputTo DataPreProcessingFE
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Filtered ego vehicle speed after Kalman smoothing",
    DTDFVocab:fromData EgoSpeedRawTransmitted,
    DTDFVocab:inputTo DataCollectionFE
]

instance VehicleSteeringAngleData : DTDFVocab:Data [
    base:desc "Filtered steering angle after Kalman smoothing",
    DTDFVocab:fromData SteeringAngleRawTransmitted,
    DTDFVocab:inputTo DataCollectionFE
]

instance ACCDesiredSpeedData : DTDFVocab:Data [
    base:desc "Desired speed computed by the ACC controller (ISO‑15622, Performance Class I)",
    DTDFVocab:fromData VehicleSpeedData,
    DTDFVocab:inputTo ControllingFE
]

// -----------------------------------------------------------
// 5. Models (Encapsulated in Functional Entities)
// -----------------------------------------------------------

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering model applied to raw LiDAR point clouds",
    DTDFVocab:inputTo DataPreProcessingFE
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based tracking model for maintaining object tracks",
    DTDFVocab:inputTo DataPreProcessingFE
]

instance ACCControlModel_ISO15622 : DTDFVocab:Model [
    base:desc "ACC control model defined by ISO‑15622 (Performance Class I)",
    DTDFVocab:inputTo ControllingFE
]

// -----------------------------------------------------------
// 6. Enablers (Functional Entities & Tooling)
// -----------------------------------------------------------

instance DataPreProcessingFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that performs perception preprocessing (clustering, tracking, depth handling)",
    DTDFVocab:enables ComputationOffloadingService
]

instance DataCollectionFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that ingests raw sensor streams and provides filtered vehicle state data",
    DTDFVocab:enables DataMonitoringService
]

instance ControllingFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that runs the ACC algorithm and publishes desired speed",
    DTDFVocab:enables RemoteManagementService
]

instance ReportingFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that prepares reports and visualisations for the UI",
    DTDFVocab:enables DataMonitoringService
]

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware used for publish/subscribe of sensor streams and FE communication",
    DTDFVocab:enables ComputationOffloadingService, DataMonitoringService, RemoteManagementService
]

instance NvidiaJetpack5Enabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK providing GPU acceleration on Jetson devices",
    DTDFVocab:enables ComputationOffloadingService
]

instance Python38RuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime used for ROS 2 nodes and ML model execution",
    DTDFVocab:enables ComputationOffloadingService, DataMonitoringService
]

instance CppNodeLifecycleEnabler : DTDFVocab:Enabler [
    base:desc "C++ support for ROS 2 node lifecycle management",
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService
]

instance MatlabSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink used for advanced algorithm development",
    DTDFVocab:enables ControllingFE
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Cross‑system Data Translation Functional Entity that maps ROS messages to DT data models",
    DTDFVocab:enables DataCollectionFE, DataPreProcessingFE
]

// -----------------------------------------------------------
// 7. Services
// -----------------------------------------------------------

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualising real‑time vehicle state, projected path and object tracks generates reports",
    DTDFVocab:provides RealTimeVehicleSpeedInsight, RealTimeSteeringAngleInsight, ObjectTrackVisualisationInsight, PredictedDrivingPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm and perception (point‑cloud clustering, tracking) on the digital twin host",
    DTDFVocab:provides ComputedDesiredSpeedInsight, ObjectTrackVisualisationInsight, PredictedDrivingPathInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "User‑initiated enable/disable of ACC, speed adjustment and emergency braking",
    DTDFVocab:provides EnableACCAction, AdjustSpeedAction, EmergencyBrakingAction
]

// -----------------------------------------------------------
// 8. Insights & Actions
// -----------------------------------------------------------

instance RealTimeVehicleSpeedInsight : DTDFVocab:Insight [
    base:desc "Real‑time vehicle speed value presented to operators"
]

instance RealTimeSteeringAngleInsight : DTDFVocab:Insight [
    base:desc "Real‑time steering angle value presented to operators"
]

instance ObjectTrackVisualisationInsight : DTDFVocab:Insight [
    base:desc "Visualisation of tracked objects derived from LiDAR and camera perception"
]

instance PredictedDrivingPathInsight : DTDFVocab:Insight [
    base:desc "Predicted driving path generated from perception and vehicle state"
]

instance ComputedDesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Desired speed output from the ACC controller (ISO‑15622)"
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable the Adaptive Cruise Control",
    DTDFVocab:IsAutomatic false
]

instance AdjustSpeedAction : DTDFVocab:Action [
    base:desc "Operator command to manually adjust the target speed",
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator command to trigger an emergency brake",
    DTDFVocab:IsAutomatic false
]

// -----------------------------------------------------------
// 9. ISO‑23247 Entities (Twin Constellation)
// -----------------------------------------------------------

instance PhysicalTwinEntity : DTDFVocab:Environment [
    base:desc "Physical Twin Entity hosting sensors, actuators and the Actuation Functional Entity",
    base:contains HokuyoLiDAR, IntelRealSenseDepthCamera, EgoSpeedSensor, SteeringAngleSensor,
                 VedderElectronicSpeedController, SteeringServo, EmergencyBrakeInterface
]

instance DigitalTwinEntity : DTDFVocab:Environment [
    base:desc "Digital Twin Entity executing functional entities, models and services",
    base:contains DataCollectionFE, DataPreProcessingFE, ControllingFE, ReportingFE,
                 DBSCANClusteringModel, KalmanFilterTrackingModel, ACCControlModel_ISO15622,
                 ROS2MiddlewareEnabler, NvidiaJetpack5Enabler, Python38RuntimeEnabler,
                 CppNodeLifecycleEnabler, MatlabSimulinkEnabler,
                 DataMonitoringService, ComputationOffloadingService, RemoteManagementService,
                 RealTimeVehicleSpeedInsight, RealTimeSteeringAngleInsight,
                 ObjectTrackVisualisationInsight, PredictedDrivingPathInsight,
                 ComputedDesiredSpeedInsight, EnableACCAction, AdjustSpeedAction, EmergencyBrakingAction
]

instance UserEntity : DTDFVocab:Environment [
    base:desc "User Entity providing UI interaction and remote management capabilities",
    base:contains DataMonitoringService, RemoteManagementService
]

instance CrossSystemDataTranslationEntity : DTDFVocab:Environment [
    base:desc "Cross‑system entity responsible for translating ROS messages between physical and digital twins",
    base:contains DataTranslationFE
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity runs the ACC control algorithm (Controlling FE) and the Remote Management UI, generating desired speed set‑points, enable/disable ACC commands, speed‑set commands and emergency‑brake signals that are transmitted back to the physical twin over the same Wi‑Fi/ROS 2 channel and executed by the Actuation FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is required to maintain a maximum end‑to‑end network latency of 100 ms (R7) and clock synchronization accuracy of 100 ms across all DTS components (R8), enabling real‑time data collection and control at the perception‑cycle rate used for object tracking."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin System (DTS) orchestrates the Physical Twin Entity (sensors, actuators, point‑cloud processing), the Digital Twin Entity (data collection, ACC, reporting, visualization), the User Entity (3D visualization and control panel UI), and a Cross‑System Data Translation entity; intra‑entity communication uses ROS 2 topics, inter‑entity communication uses Wi‑Fi with serialized messages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity perception is achieved through DBSCAN clustering and Kalman filtering of raw LiDAR data; the ACC algorithm complies with ISO 15622 performance class I; system safety is addressed by enforcing a ≤100 ms latency budget and 100 ms clock sync, providing deterministic timing for control actions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑digital communication occurs over a Wi‑Fi network using ROS 2 messages; data is serialized and unit‑converted by the Data Translation FE; the same Wi‑Fi link carries control commands from the DT back to the vehicle."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT components (Digital Twin Entity and User Entity) are deployed on external compute resources—potentially cloud‑based servers—separate from the vehicle‑mounted Jetson Orin Nano that hosts the Physical Twin Entity."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows the ISO 23247 reference architecture (Part 2), uses the ACC functional requirements from ISO 15622, and references ISO/IEC 30173 for terminology; optional OPC UA (IEC 62541) is mentioned as a possible data‑translation mechanism."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations include the 100 ms latency requirement, clock synchronization, and inclusion of an emergency‑brake command; the DT is classified as a Fully Autonomous Digital Twin with Human‑in‑the‑Loop per the liberty‑to‑act taxonomy, but explicit cybersecurity mechanisms are not described."
]