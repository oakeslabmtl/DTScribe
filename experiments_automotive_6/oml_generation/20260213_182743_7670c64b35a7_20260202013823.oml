// C3: Physical sensing components
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "Acquires raw LiDAR point‑cloud data from the 1/10‑scale autonomous vehicle"
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors motor drive status (rpm, torque) on the physical twin"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

instance SteeringServoPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Reads steering servo position feedback from the physical twin"
    DTDFVocab:producedData SteeringServoPositionDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Provides overall vehicle state (position, velocity, heading) derived from onboard sensors"
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance SteeringServoPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoPositionSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// C10: Data objects flowing into enablers
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑clouds streamed to the Digital Twin"
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Motor drive telemetry used for status monitoring and control feedback"
    DTDFVocab:fromData MotorStatusDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance SteeringServoPositionData : DTDFVocab:Data [
    base:desc "Steering servo angle measurements for vehicle maneuvering awareness"
    DTDFVocab:fromData SteeringServoPositionDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "High‑level vehicle state (pose, speed) required for monitoring and ACC computation"
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

// C10: Models/Data
instance PointCloudClusteringAndTrackingModel : DTDFVocab:Model [
    base:desc "Clusters and tracks objects from raw LiDAR point clouds"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "ACC algorithm performing lead‑vehicle identification and desired‑speed calculation"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

// C11: Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware provides bi‑directional low‑latency communication over Wi‑Fi (UDP) between Physical Twin and Digital Twin"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Streams real‑time vehicle state, projected path, and detected object tracks; UI allows view, save, and report generation"
    DTDFVocab:provides VehicleStateInsight, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes the ACC algorithm in the cloud and returns a speed command to the vehicle for actuation"
    DTDFVocab:provides ACCSpeedCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can remotely enable/disable ACC, set target speed, and issue emergency‑braking commands via the UI"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetTargetSpeedAction, EmergencyBrakingAction
]

// C17: Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current vehicle pose, velocity, and sensor detections for operator awareness"
]

// C17: Actions
instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Generates a PDF/HTML report of the monitored session"
    DTDFVocab:IsAutomatic false
]

instance ACCSpeedCommandAction : DTDFVocab:Action [
    base:desc "Issues the computed speed command from the ACC model to the vehicle actuator"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Remotely activates the Adaptive Cruise Control function"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Remotely deactivates the Adaptive Cruise Control function"
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Sets a new target cruising speed for the ACC algorithm"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Triggers an emergency braking maneuver on the physical vehicle"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin computes ACC control outputs (e.g., desired speed, enable/disable ACC, emergency‑brake command) and sends them back to the physical twin. Commands are issued from the Controlling FE / User Interface FE to the Actuation FE, which drives the vehicle actuators (motor, steering servo). The messages are transmitted over the same Wi‑Fi UDP link and are handled within the ROS 2 network of the DT. The documents do not detail the exact command message format, validation/authentication mechanisms, conflict‑resolution logic, or explicit execution acknowledgements."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT requires clock synchronization between devices with an accuracy of 100 ms, as hardware limits prevent tighter synchronization; this aligns with many safety‑critical vehicular standards that demand sub‑100 ms sync. Synchronization is needed for computation offloading and coordinated operation of the Physical Twin Entity and Digital Twin Entity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration is realized by mapping each Functional Entity to an individual ROS2 package; the packages contain one or more ROS2 nodes that communicate over DDS. The overall system follows the ISO 23247 reference architecture, with the Physical Twin Entity handling resource‑specific functions (point‑cloud clustering, tracking, actuation), the Digital Twin Entity providing data management and control, and the User Entity exposing a 3‑D visualization and control‑panel UI. Coordination across entities is achieved through ROS2 topics/services, enabling runtime resource management and component integration across the three hardware platforms."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Time synchronization is a key validity requirement for the twin; devices must share a common notion of time with an accuracy of at least 100 ms, imposed by hardware limitations. While stricter synchronization (sub‑100 ms) is mandated by safety‑critical vehicular standards, the system adopts the 100 ms bound to balance feasibility and safety. No further model fidelity, validation, or uncertainty quantification methods are described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS comprises two communication layers: (1) an intra‑system ROS2 (DDS) network that interconnects all software components (Data Translation, Point Cloud Clustering, Controlling FE, etc.) and (2) an inter‑entity Wi‑Fi link that transports data between the physical twin and the digital twin using UDP at the transport layer. No quantitative bandwidth or latency values are given; however, Document 2 notes that the system must support low end‑to‑end latency communication to satisfy safety‑critical requirements. The documents do not mention redundancy mechanisms, security protocols (e.g., encryption, authentication), or specific network topology beyond the client‑server style flow implied by UI → Controlling FE → Wi‑Fi → Physical twin."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT services (Data Monitoring, Computation Offloading, Remote Management) are intended to run on equipment that can provide higher computational resources than the on‑board ECU, with the example of offloading the ACC logic to the cloud. The documents do not specify the concrete hosting platform (cloud provider, edge node, on‑premise server), the required CPU/memory/storage capacities, scalability mechanisms, deployment models (container, VM, etc.) or availability guarantees."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system is built according to the ISO 23247 digital‑twin framework for manufacturing. It adopts the ISO 23247 reference architecture, defining entities such as the Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity and User Entity, and implements Functional Entities as ROS 2 packages. For temporal coordination the design follows safety‑critical vehicular standards that require clock synchronization tighter than 100 ms; the implementation enforces a 100 ms accuracy bound as dictated by those standards."
]