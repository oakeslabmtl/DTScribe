]

instance BioreactorYieldModel : DTDFVocab:Model [
    base:desc "Digital twin model for bioprocess yield prediction based on real-time biological parameters (Document [7])."
    DTDFVocab:inputTo MATLABSimulationEnabler, COMSOLMultiphysicsEnabler
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Continuous stream of raw sensor data from physical components including temperature, pressure, voltage, and LiDAR point clouds (Document [7], [8], [17])."
    DTDFVocab:fromData TemperatureHumidityDataTransmitted, PressureDataTransmitted, BatteryVoltageDataTransmitted, BatteryTemperatureDataTransmitted, CNCMachineDataTransmitted, RoboticArmDataTransmitted, LiDARPointCloudDataTransmitted, EnvironmentalDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, ROS2ProcessingEnabler
]

instance ProcessedSensorData : DTDFVocab:Data [
    base:desc "Preprocessed sensor data including object tracks, clustered point clouds, and feature-extracted biological parameters (Document [7], [16])."
