    DTDFVocab:inputTo 3DVisualizationEnabler, PredictiveMaintenanceEnabler
]

instance HistoricalOperationalData : DTDFVocab:Data [
    base:desc "Time-series historical data including maintenance logs, production records, and environmental conditions for trend analysis (Document [14])."
