// C10: Models/Data
instance CyberBiophysicalSimulationModel : DTDFVocab:Model [
    base:desc "Multi-scale simulation model integrating microscopic biological processes (e.g., cellular) with macroscopic system performance for cyber-biophysical systems (Document [7])."
    DTDFVocab:inputTo COMSOLMultiphysicsEnabler, MATLABSimulationEnabler
]

instance BatteryElectrochemicalModel : DTDFVocab:Model [
    base:desc "Physics-based electrochemical model for lithium-ion battery state-of-health (SoH) and state-of-charge (SoC) prediction (Document [17])."
    DTDFVocab:inputTo COMSOLMultiphysicsEnabler, ANSYSFluentEnabler
]

instance ManufacturingProcessModel : DTDFVocab:Model [
    base:desc "Discrete-event simulation model for automotive manufacturing process optimization and predictive maintenance (Document [10])."
