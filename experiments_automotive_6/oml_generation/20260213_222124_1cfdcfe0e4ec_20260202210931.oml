]

instance DigitalTwinModelData : DTDFVocab:Data [
    base:desc "Aggregated data used for digital twin simulations including geometric, behavioral, and analytical models (Document [10])."
    DTDFVocab:fromData RealTimeSensorData, ProcessedSensorData, HistoricalOperationalData
    DTDFVocab:inputTo SiemensDigitalTwinCreatorEnabler, PTCThingWorxEnabler
]

