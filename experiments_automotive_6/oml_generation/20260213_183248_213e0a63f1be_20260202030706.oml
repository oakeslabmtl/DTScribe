// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR providing 2‑D point clouds"
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance IntelRealSenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera providing RGB‑D images"
    DTDFVocab:producedData DepthImageDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring longitudinal vehicle speed"
    DTDFVocab:producedData VehicleSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring steering wheel angle / vehicle heading"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// C4: Physical‑to‑virtual interaction (Data transmitted)
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthImageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseDepthCamera
]

instance VehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C5: Data objects
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Timestamped 2‑D point‑cloud frames from LiDAR"
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
    DTDFVocab:inputTo DBSCANLibraryEnabler, KalmanFilterLibraryEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames with associated timestamps"
    DTDFVocab:fromData DepthImageDataTransmitted
    DTDFVocab:inputTo DBSCANLibraryEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Longitudinal speed values with timestamps"
    DTDFVocab:fromData VehicleSpeedDataTransmitted
    DTDFVocab:inputTo ACCControlLibraryEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle measurements with timestamps"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo ACCControlLibraryEnabler
]

// C10: Models/Data
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm for point‑cloud object detection"
    DTDFVocab:inputTo DBSCANLibraryEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter model for tracking clustered objects over time"
    DTDFVocab:inputTo KalmanFilterLibraryEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model compliant with ISO 15622 performance class I"
    DTDFVocab:inputTo ACCControlLibraryEnabler
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model for real‑time vehicle state and projected path"
    DTDFVocab:inputTo VisualizationEngineEnabler
]

// C11: Enablers (tools, libraries, runtimes)
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware for topic‑based communication over Wi‑Fi"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database storing timestamps, object tracks, speed, steering, and human‑readable reports"
    DTDFVocab:enables RemoteManagementService
]

instance Python38RuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime used for rapid prototyping of models"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance CppNodeLifecycleEnabler : DTDFVocab:Enabler [
    base:desc "C++ node lifecycle management for ROS 2 packages"
    DTDFVocab:enables ComputationOffloadingService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for developing clustering and tracking algorithms"
    DTDFVocab:enables DataMonitoringService
]

instance NVIDIAJetPack5SDKEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK enabling GPU‑accelerated computation on Jetson hardware"
    DTDFVocab:enables ComputationOffloadingService
]

instance WiFiNetworkingEnabler : DTDFVocab:Enabler [
    base:desc "Standard Wi‑Fi networking for inter‑entity data transfer"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance DBSCANLibraryEnabler : DTDFVocab:Enabler [
    base:desc "DBSCAN library used by the clustering model"
    DTDFVocab:enables DataMonitoringService
]

instance KalmanFilterLibraryEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter library used by the tracking model"
    DTDFVocab:enables DataMonitoringService
]

instance ACCControlLibraryEnabler : DTDFVocab:Enabler [
    base:desc "ACC control library implementing ISO 15622 algorithm"
    DTDFVocab:enables ComputationOffloadingService
]

instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "3‑D rendering engine powering the UI visualizations"
    DTDFVocab:enables DataMonitoringService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualizes real‑time vehicle state, object tracks, and projected path"
    DTDFVocab:provides VehicleStateInsight, PredictedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC algorithm on the Digital Twin instead of the on‑board ECU"
    DTDFVocab:provides ACCComputationInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, adjust speed set‑points, and trigger emergency braking via UI"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustSpeedSetpointAction, EmergencyBrakeAction
]

// C17: Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of vehicle speed, steering angle, and pose"
]

instance PredictedPathInsight : DTDFVocab:Insight [
    base:desc "Projected vehicle trajectory generated by the ACC model"
]

instance ACCComputationInsight : DTDFVocab:Insight [
    base:desc "Result of ACC computation (lead‑vehicle detection and speed command) performed on the Digital Twin"
]

// C18: Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance AdjustSpeedSetpointAction : DTDFVocab:Action [
    base:desc "Adjust desired speed set‑point for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Trigger emergency braking immediately"
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance MotorVoltageCommandInterface : DTDFVocab:ActingComponent [
    base:desc "Motor voltage command interface that drives vehicle speed (Actuation Functional Entity) executed on Jetson controller"
]

instance SteeringServoActuation : DTDFVocab:ActingComponent [
    base:desc "Steering‑servo actuation that controls steering angle, executed on Jetson controller"
]

// C9: Environment containing the physical twin
instance VehicleEnvironment : DTDFVocab:Environment [
    base:contains HokuyoLiDAR, IntelRealSenseDepthCamera, VehicleSpeedSensor, SteeringAngleSensor, MotorVoltageCommandInterface, SteeringServoActuation
]

// C8: Component grouping (logical entities)
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical Twin Entity running on the on‑board Jetson NX/Orin Nano"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital Twin Entity hosted on an external compute node or cloud"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "Operator workstation providing UI for monitoring and remote management"
]

instance CrossSystemEntity : DTDFVocab:Component [
    base:desc "Cross‑System Entity offering data‑translation services across PT, DT, and User entities"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT via ROS 2 over the same Wi‑Fi link. Commands include desired speed values (converted to motor voltage by the Actuation FE), ACC enable/disable signals, speed‑setpoint updates, and emergency‑brake commands issued from the User Interface FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is engineered to maintain end‑to‑end communication latency ≤ 100 ms (per 3GPP TS 22.185) and clock synchronization accuracy of 100 ms across all DT components, enabling real‑time ACC control loops synchronized with the PT perception cycle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates the Physical Twin Entity, Digital Twin Entity, User Entity, and Cross‑System Entity. Intra‑entity communication uses ROS 2 topics; inter‑entity data exchange occurs over Wi‑Fi with the Data Translation FE handling serialization and unit conversion."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during the design and testing phase as a cyber‑physical experimentation platform and throughout operation for monitoring, control, and remote management of the PT, reflecting both development‑time and run‑time life‑cycle stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by using high‑resolution LiDAR data and validated DBSCAN/Kalman tracking; ACC behavior follows ISO 15622 specifications. Latency ≤ 100 ms and clock sync ≤ 100 ms guarantee temporal fidelity, while safety‑critical constraints are respected by limiting ACC to performance class I on the scale vehicle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual and virtual‑to‑physical data exchange uses a Wi‑Fi network with ROS 2 communication. The Data Translation FE serializes messages and performs unit conversion; optional OPC UA (IEC 62541) could be used for data translation but is not required in this implementation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the Jetson Orin Nano mounted in the vehicle. The Digital Twin Entity executes on an external compute platform (e.g., cloud server or desktop PC). The User Entity resides on an operator workstation displaying the UI and control panel."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) reference architecture, uses ISO 15622 for ACC functionality, references ISO/IEC 30173:2023 for twin concepts, and mentions optional OPC UA (IEC 62541) for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by adhering to ISO 15622 ACC specifications, enforcing a maximum 100 ms latency, and requiring clock synchronization within 100 ms. Remote commands include an emergency‑brake function to mitigate hazards. No explicit cybersecurity mechanisms are described in the document."
]