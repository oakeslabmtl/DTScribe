// C2: Acting Components
instance MotorVoltageCommandInterface : DTDFVocab:ActingComponent [
    base:desc "Actuation Functional Entity that drives vehicle speed via Jetson-based controller on the Physical Twin (PT)"
]

instance SteeringServoActuation : DTDFVocab:ActingComponent [
    base:desc "Steering-servo actuation that controls steering angle, executed on PT via Jetson-based controller"
]

// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing 2D point clouds for object detection"
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelRealSenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera capturing 3D environmental data"
    DTDFVocab:producedData DepthCameraData
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On-board speed sensor measuring longitudinal vehicle speed"
    DTDFVocab:producedData VehicleSpeedData
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering-angle sensor measuring vehicle heading"
    DTDFVocab:producedData SteeringAngleData
]

// C4: Physical-to-Virtual Interaction
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iCamera
]

instance VehicleSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance RawSensorDataBundle : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR, IntelRealSenseD435iCamera, VehicleSpeedSensor, SteeringAngleSensor
    base:desc "Aggregated raw sensor data streamed from PT to DT over Wi-Fi using ROS2 topics"
]

// C10: Models/Data
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm for point-cloud object segmentation and tracking"
    DTDFVocab:inputTo Python38Enabler, MATLABSimulinkEnabler
]

instance KalmanFilterModel : DTDFVocab:Model [
    base:desc "Kalman filter for state estimation and trajectory prediction of detected objects"
    DTDFVocab:inputTo Python38Enabler, MATLABSimulinkEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) model conforming to ISO 15622 (performance class I)"
    DTDFVocab:inputTo CppEnabler, MATLABSimulinkEnabler
]

instance ThreeDVisualizationModel : DTDFVocab:Model [
    base:desc "3D visualization model for real-time path projection and environmental rendering"
    DTDFVocab:inputTo NVIDIAJetPackEnabler
]

instance TimeStampedObjectTracks : DTDFVocab:Data [
    base:desc "Time-stamped object tracks generated from processed LiDAR/Depth data"
    DTDFVocab:fromData LiDARPointCloudData, DepthCameraData
    DTDFVocab:inputTo SQLDatabaseEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Processed vehicle state including speed, steering angle, and position"
    DTDFVocab:fromData VehicleSpeedData, SteeringAngleData
    DTDFVocab:inputTo SQLDatabaseEnabler
]

instance HumanReadableReports : DTDFVocab:Data [
    base:desc "Generated human-readable reports for post-run analysis and parameter tuning"
    DTDFVocab:fromData TimeStampedObjectTracks, VehicleStateData
    DTDFVocab:inputTo SQLDatabaseEnabler
]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for real-time data streaming and inter-component communication"
]

instance Python38Enabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 for rapid prototyping of clustering and tracking algorithms"
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ for node lifecycle management and performance-critical components"
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for algorithm development and simulation"
]

instance NVIDIAJetPackEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK for hardware acceleration and GPU computing"
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database for structured storage of time-series and analytical data"
]

instance WiFiNetworkingEnabler : DTDFVocab:Enabler [
    base:desc "Standard Wi-Fi networking for inter-entity communication between PT and DT"
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of vehicle state, object tracks, and projected path via UI"
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm execution on DT (lead-vehicle detection and speed computation) instead of on-board ECU"
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator-controlled ACC enable/disable, speed set-point adjustment, and emergency braking"
]

// C17: Insights/Actions
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Continuous visualization of current vehicle speed, steering angle, and position"
]

instance ObjectTrackVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time display of detected objects with bounding boxes and trajectories"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Predicted vehicle path based on current state and environmental data"
]

instance ACCLeadVehicleDetectionAction : DTDFVocab:Action [
    base:desc "Automatic detection of lead vehicles in front of the autonomous vehicle"
    DTDFVocab:IsAutomatic true
]

instance ACCSpeedComputationAction : DTDFVocab:Action [
    base:desc "Calculation of optimal speed to maintain safe distance from lead vehicle"
    DTDFVocab:IsAutomatic true
]

instance ACCEnableDisableAction : DTDFVocab:Action [
    base:desc "Manual enable/disable of Adaptive Cruise Control functionality"
    DTDFVocab:IsAutomatic false
]

instance SpeedSetPointAdjustmentAction : DTDFVocab:Action [
    base:desc "Operator adjustment of desired speed set-point for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Triggered emergency braking to avoid collisions"
    DTDFVocab:IsAutomatic true
]

// C1: System Under Study
instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity, JetsonNXController, JetsonOrinNanoController
]

instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "1/10-scale autonomous vehicle (retrofitted Traxxas Slash 4x4 chassis) serving as the physical twin"
    base:isContainedIn PhysicalTwinEnvironment
]

instance JetsonNXController : DTDFVocab:Component [
    base:desc "NVIDIA Jetson NX antenna for wireless communication"
    base:isContainedIn PhysicalTwinEnvironment
]

instance JetsonOrinNanoController : DTDFVocab:Component [
    base:desc "NVIDIA Jetson Orin Nano micro-computer for on-board processing"
    base:isContainedIn PhysicalTwinEnvironment
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains DigitalTwinEntity
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "External compute node/cloud hosting the Digital Twin processing pipeline"
    base:isContainedIn DigitalTwinEnvironment
]

instance UserEnvironment : DTDFVocab:Environment [
    base:contains UserEntity
]

instance UserEntity : DTDFVocab:Component [
    base:desc "Operator workstation for remote monitoring and management"
    base:isContainedIn UserEnvironment
]

instance CrossSystemEnvironment : DTDFVocab:Environment [
    base:contains CrossSystemEntity
]

instance CrossSystemEntity : DTDFVocab:Component [
    base:desc "Data translation services for cross-entity communication"
    base:isContainedIn CrossSystemEnvironment
]

instance DataTranslationEnvironment : DTDFVocab:Environment [
    base:contains DataTranslationFunctionalEntity
]

instance DataTranslationFunctionalEntity : DTDFVocab:Component [
    base:desc "Unit conversion and serialization of sensor data for cross-platform compatibility"
    base:isContainedIn DataTranslationEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT via ROS 2 over the same Wi‑Fi link. Commands include desired speed values (converted to motor voltage by the Actuation FE), ACC enable/disable signals, speed‑setpoint updates, and emergency‑brake commands issued from the User Interface FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is engineered to maintain end‑to‑end communication latency ≤ 100 ms (per 3GPP TS 22.185) and clock synchronization accuracy of 100 ms across all DT components, enabling real‑time ACC control loops synchronized with the PT perception cycle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates the Physical Twin Entity, Digital Twin Entity, User Entity, and Cross‑System Entity. Intra‑entity communication uses ROS 2 topics; inter‑entity data exchange occurs over Wi‑Fi with the Data Translation FE handling serialization and unit conversion."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during the design and testing phase as a cyber‑physical experimentation platform and throughout operation for monitoring, control, and remote management of the PT, reflecting both development‑time and run‑time life‑cycle stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by using high‑resolution LiDAR data and validated DBSCAN/Kalman tracking; ACC behavior follows ISO 15622 specifications. Latency ≤ 100 ms and clock sync ≤ 100 ms guarantee temporal fidelity, while safety‑critical constraints are respected by limiting ACC to performance class I on the scale vehicle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual and virtual‑to‑physical data exchange uses a Wi‑Fi network with ROS 2 communication. The Data Translation FE serializes messages and performs unit conversion; optional OPC UA (IEC 62541) could be used for data translation but is not required in this implementation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the Jetson Orin Nano mounted in the vehicle. The Digital Twin Entity executes on an external compute platform (e.g., cloud server or desktop PC). The User Entity resides on an operator workstation displaying the UI and control panel."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) reference architecture, uses ISO 15622 for ACC functionality, references ISO/IEC 30173:2023 for twin concepts, and mentions optional OPC UA (IEC 62541) for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by adhering to ISO 15622 ACC specifications, enforcing a maximum 100 ms latency, and requiring clock synchronization within 100 ms. Remote commands include an emergency‑brake function to mitigate hazards. No explicit cybersecurity mechanisms are described in the document."
]