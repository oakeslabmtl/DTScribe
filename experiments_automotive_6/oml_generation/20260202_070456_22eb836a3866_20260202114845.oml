// C3: Physical sensing components
instance HokuyoPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR point‑cloud sensor on the physical vehicle"
    DTDFVocab:producedData HokuyoPointCloudTransmitted
]

instance IntelDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera sensing stereo and depth data"
    DTDFVocab:producedData IntelDepthCameraTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor embedded in the physical twin"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor integrated into the vehicle chassis"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// C4: Data transmitted from physical to virtual
instance HokuyoPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoPointCloudSensor
]

instance IntelDepthCameraTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCameraSensor
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C1: Physical data
instance HokuyoPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud captured by the Hokuyo UST‑10LX sensor"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
    DTDFVocab:fromData HokuyoPointCloudTransmitted
]

instance IntelDepthCameraData : DTDFVocab:Data [
    base:desc "Stereo depth images captured by the Intel D435i camera"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
    DTDFVocab:fromData IntelDepthCameraTransmitted
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Instantaneous vehicle speed read by the speed sensor"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
    DTDFVocab:fromData VehicleSpeedTransmitted
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Instantaneous steering angle measured by the steering sensor"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
    DTDFVocab:fromData SteeringAngleTransmitted
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Object tracks generated by DBSCAN clustering followed by Kalman filter"
    DTDFVocab:inputTo ACCAlgorithmRuntimeEnabler
    DTDFVocab:fromData HokuyoPointCloudTransmitted
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Aggregated vehicle state including speed, steering angle, and environment context"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
    DTDFVocab:fromData VehicleSpeedTransmitted
]

instance ACCDecisionData : DTDFVocab:Data [
    base:desc "ACC decision outputs (desired speed, unlock/lock state) computed off‑loaded from the edge server"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
    DTDFVocab:fromData VehicleStateData
]

// C10: Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm implemented in MATLAB/Simulink to segment LiDAR point clouds"
    DTDFVocab:inputTo ACCAlgorithmRuntimeEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter used to refine object state estimates after DBSCAN segmentation"
    DTDFVocab:inputTo ACCAlgorithmRuntimeEnabler
]

instance ISO15522ACCModel : DTDFVocab:Model [
    base:desc "C‑based ACC logic following ISO 15522 compliance executed on the edge server"
    DTDFVocab:inputTo ACCAlgorithmRuntimeEnabler
]

instance ThreeDVisualizationModel : DTDFVocab:Model [
    base:desc "3D rendering model for visualizing vehicle trajectory and object tracks in the UI"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance TimeSeriesReportingModel : DTDFVocab:Model [
    base:desc "Time‑series reporting module for generating vehicle state analytics"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

// C11: Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware utilizing DDS for real‑time, over‑Wi‑Fi communication"
    DTDFVocab:enables DataMonitoringService
]

instance ACCAlgorithmRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "C++/Python ROS 2 node runtime executing ACC decision algorithms per ISO 15522"
    DTDFVocab:enables ACCDecisionOffloadingService, ACCRemoteManagementService
]

instance MATLABSimulinkClusterEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink driver for DBSCAN and Kalman filter clustering"
    DTDFVocab:enables DataMonitoringService
]

instance NVIDIAJetPackEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK enabling GPU acceleration on Jetson Orin/NX"
    DTDFVocab:enables ACCDecisionOffloadingService
]

instance HIDSpeedControllerFirmwareEnabler : DTDFVocab:Enabler [
    base:desc "Firmware for Vedder Electronic Speed Controller handling voltage commands"
    DTDFVocab:enables ACCRemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI service delivering vehicle state, projected path, and object tracks"
    DTDFVocab:provides VehicleStateInsight, TrajectoryPredictionInsight
]

instance ACCDecisionOffloadingService : DTDFVocab:Service [
    base:desc "Computation offloading service executing ACC logic on the edge server"
    DTDFVocab:provides SetDesiredSpeedAction, EnableACCAction
]

instance ACCRemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management service for ACC enable/disable and emergency brake"
    DTDFVocab:provides EnableACCAction, TriggerEmergencyBrakeAction
]

// C17: Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current vehicle speed, steering angle, and dynamic state"
]

instance TrajectoryPredictionInsight : DTDFVocab:Insight [
    base:desc "Insight into projected vehicle trajectory based on current state and ACC predictions"
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Insight from offline time‑series analysis supporting predictive maintenance"
]

// C17: Actions
instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to set the desired speed for ACC control"
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable or disable the ACC system"
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to trigger an emergency brake for collision avoidance"
    DTDFVocab:IsAutomatic false
]

// C3/C4: Acting components
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Motor actuation via voltage commands to the vehicle’s drive motor"
    DTDFVocab:producedData ACCDecisionData
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuation controlled by AV’s steering commands"
    DTDFVocab:producedData ACCDecisionData
]

// C5: Components describing twin entities
instance PhysicalTwinComponent : DTDFVocab:Component [
    base:desc "Physical twin handling sensor interfaces and actuator control on the vehicle"
]

instance DigitalTwinComponent : DTDFVocab:Component [
    base:desc "Digital twin running on edge server, responsible for data processing and ACC logic"
]

instance UserComponent : DTDFVocab:Component [
    base:desc "User entity running the remote UI client for monitoring and control"
]

// C18: Environment that contains the twin entities
instance VehicleSystemEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinComponent, DigitalTwinComponent, UserComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT issues desired‑speed commands and steering‐force commands (via motor voltage and steering servo control) back to the PT, and remote control signals such as enable/disable ACC, set desired speed, and emit emergency braking via ROS2 messages."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with a maximum end‑to‑end latency of 100 ms from PT to DT, and clock synchronization accuracy of 100 ms across all devices; all DT services (ACC logic, UI updates, reporting) operate within this sub‑100 ms time scale."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An ISO 23247 entity‑based constellation where Sensor/actuator interfaces form the Physical Twin Entity, data collection, processing, ACC logic, and reporting form the Digital Twin Entity, and a 3D visualization plus control‑panel UI compose the User Entity; all FEs are deployed across vehicle hardware, edge server, and remote UI, communicating via ROS2 over Wi‑Fi, with a Cross‑System Data Translation FE bridging formats."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design and requirements definition (R1–R8), development and implementation (ROS2 packages, mapping to ISO 23247 FEs), validation and testing (low‑latency compliance, safety‑critical ACC behavior meeting ISO 15622), operation and remote management, and ongoing maintenance/upgrades (e.g., decompose User Interface FE, extend to other ADAS)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "ACC logic constrained by ISO 15622 (performance class I), real‑time latency requirement of ≤100 ms, clock synchronization within 100 ms, validation of sensor fusion accuracy, and unit‑conversion via Data Translation FE to ensure consistency, with implicit V&V implied through compliance with ISO standards."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The PT communicates with the DT over a Wi‑Fi (802.11) link; inter‑entity communication uses ROS 2 which employs DDS over UDP/TCP; the data‑translation FE serializes messages into ROS 2 topics; the DT hosts ROS 2 nodes on a remote server or local PC."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity runs on an external server/cloud platform (or local PC) connected via Wi‑Fi; ROS 2 nodes manage data collection, ACC computation, and UI; the Physical Twin Entity runs on the vehicle’s Jetson Orin Nano."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 RA (entity‑based RA for DT) and incorporates ISO 15622 for ACC control logic; software follows ROS 2 standards; use of OPC UA not implemented but possible."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "DT handles safety‑critical ACC logic with 100 ms latency; actors can remotely execute operations (ACC enable/disable) and emergency braking; safety compliance guided by ISO 15622 and ISO 23247; no explicit cybersecurity mechanisms described, but low‑latency and safety constraints emphasized."
]