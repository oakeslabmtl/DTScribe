// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR sensor providing raw point cloud data for object detection and tracking."
    DTDFVocab:producedData HokuyoLiDARPointCloudData
]

instance IntelDeepSenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera capturing depth frames for environmental perception."
    DTDFVocab:producedData IntelCameraDepthData
]

instance ChassisControlInterface : DTDFVocab:SensingComponent [
    base:desc "Lower-level chassis control interface providing vehicle state variables (speed and steering angle) as observable state."
    DTDFVocab:producedData VehicleStateData
]

// C4: Physical-to-Virtual Interaction
instance HokuyoLiDARPointCloudData : DTDFVocab:DataTransmitted [
    base:desc "Raw LiDAR point clouds transmitted in real-time via ROS2 messages over Wi-Fi from Physical Twin to Digital Twin."
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance IntelCameraDepthData : DTDFVocab:DataTransmitted [
    base:desc "Depth-camera frames transmitted in real-time via ROS2 messages over Wi-Fi from Physical Twin to Digital Twin."
    DTDFVocab:producedFrom IntelDeepSenseD435iCamera
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    base:desc "Vehicle speed and steering angle data transmitted in real-time via ROS2 messages over Wi-Fi from Physical Twin to Digital Twin."
    DTDFVocab:producedFrom ChassisControlInterface
]

instance ObjectTrackData : DTDFVocab:DataTransmitted [
    base:desc "Object-track information generated by on-board DBSCAN clustering and Kalman-filter tracking, transmitted via ROS2 messages."
    DTDFVocab:producedFrom OnBoardClusteringAndTracking
]

// C10: Models/Data
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "Point-cloud clustering pipeline using DBSCAN algorithm for object detection from raw LiDAR data."
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman-filter tracking model for maintaining object tracks after DBSCAN clustering."
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) model compliant with ISO 15622 for lead-vehicle detection and desired speed computation."
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance RawSensorData : DTDFVocab:Data [
    base:desc "Raw sensor streams including LiDAR point clouds, depth-camera frames, and vehicle state variables."
    DTDFVocab:fromData HokuyoLiDARPointCloudData, IntelCameraDepthData, VehicleStateData
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance DerivedObjectTracks : DTDFVocab:Data [
    base:desc "Processed object tracks generated by DBSCAN clustering and Kalman-filter tracking from raw sensor data."
    DTDFVocab:fromData ObjectTrackData
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance EgoVehicleState : DTDFVocab:Data [
    base:desc "Ego-vehicle speed and steering angle state derived from chassis control interface."
    DTDFVocab:fromData VehicleStateData
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance SQLDatabaseReports : DTDFVocab:Data [
    base:desc "Human-readable time-series reports stored in SQL database for post-run analysis and parameter tuning."
    DTDFVocab:inputTo SQLDatabaseEnabler
]

// C11: Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware (DDS transport) for inter-process communication between Physical Twin and Digital Twin entities."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance NVIDIAJetpackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for Jetson development and hardware acceleration."
    DTDFVocab:enables OnBoardClusteringAndTracking
]

instance Python38Enabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime for implementing ROS2 nodes and data processing pipelines."
    DTDFVocab:enables DataTranslationFunctionalEntity
]

instance CppROS2NodeLifecycle : DTDFVocab:Enabler [
    base:desc "C++ implementation with ROS2 node lifecycle management for robust functional entities."
    DTDFVocab:enables ACCControlFunctionalEntity
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for developing clustering and tracking algorithms."
    DTDFVocab:enables DBSCANClusteringModel, KalmanFilterTrackingModel
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database system for storing time-series reports and enabling reporting services."
    DTDFVocab:enables ReportingService
]

instance WiFiNetworkingEnabler : DTDFVocab:Enabler [
    base:desc "Wi-Fi networking infrastructure for real-time data transmission between Physical Twin and Digital Twin."
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time UI visualization of vehicle state, projected path, and object tracks with report generation and storage capabilities."
    DTDFVocab:provides RealTimeVehicleStateInsight, ProjectedPathInsight, ObjectTrackVisualizationInsight, GeneratedReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm execution in Digital Twin determining lead vehicle and computing desired speed."
    DTDFVocab:provides LeadVehicleDetectionAction, DesiredSpeedComputationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI interface for operators to enable/disable ACC, modify speed set-points, and trigger emergency braking."
    DTDFVocab:provides ACCEnableDisableAction, SpeedSetPointModificationAction, EmergencyBrakingAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Creation of human-readable time-series reports stored in SQL database for post-run analysis."
    DTDFVocab:provides SQLDatabaseReportsInsight
]

// C17: Insights/Actions
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of vehicle speed and steering angle for operator awareness."
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Visualization of projected driving path based on current vehicle state and object tracks."
]

instance ObjectTrackVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time display of surrounding object tracks detected by clustering and tracking models."
]

instance GeneratedReportInsight : DTDFVocab:Insight [
    base:desc "Automatically generated reports stored in SQL database for post-run analysis."
]

instance SQLDatabaseReportsInsight : DTDFVocab:Insight [
    base:desc "Access to stored time-series reports in SQL database for parameter tuning and decision support."
]

instance LeadVehicleDetectionAction : DTDFVocab:Action [
    base:desc "Automatic detection of lead vehicle using ACC control model."
    DTDFVocab:IsAutomatic true
]

instance DesiredSpeedComputationAction : DTDFVocab:Action [
    base:desc "Computation of desired speed based on lead vehicle distance and relative speed."
    DTDFVocab:IsAutomatic true
]

instance ACCEnableDisableAction : DTDFVocab:Action [
    base:desc "Operator-controlled action to enable or disable ACC functionality."
    DTDFVocab:IsAutomatic false
]

instance SpeedSetPointModificationAction : DTDFVocab:Action [
    base:desc "Operator-controlled modification of ACC speed set-points."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Remote emergency braking command issued through actuation interface."
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller converting desired speed commands into motor voltage signals."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo for controlling steering angle based on ACC commands."
]

instance EmergencyBrakingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuation interface for remote emergency braking commands."
]

// C1: Functional Entities
instance OnBoardClusteringAndTracking : DTDFVocab:Component [
    base:desc "ROS2 package implementing DBSCAN clustering and Kalman-filter tracking on Physical Twin hardware."
]

instance ACCControlFunctionalEntity : DTDFVocab:Component [
    base:desc "ROS2 package implementing ACC control model compliant with ISO 15622."
]

instance DataCollectionFunctionalEntity : DTDFVocab:Component [
    base:desc "ROS2 package gathering raw sensor streams from Physical Twin."
]

instance DataTranslationFunctionalEntity : DTDFVocab:Component [
    base:desc "Cross-system entity that serializes, performs unit conversion, and aligns message types between Physical Twin and Digital Twin."
]

// C5: Physical Twin Entity
instance PhysicalTwinEntity : DTDFVocab:Environment [
    base:desc "1/10-scale autonomous vehicle platform hosting all sensing and actuation components."
    base:contains HokuyoUST10LXLiDAR, IntelDeepSenseD435iCamera, ChassisControlInterface,
                   VedderElectronicSpeedController, SteeringServoActuator, EmergencyBrakingActuator,
                   OnBoardClusteringAndTracking, DataCollectionFunctionalEntity
]

// C7: Digital Twin Entity
instance DigitalTwinEntity : DTDFVocab:Environment [
    base:desc "Digital representation of the autonomous vehicle running ACC algorithms and providing remote management."
    base:contains ACCControlFunctionalEntity, DataTranslationFunctionalEntity,
                   DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

// C8: User Entity
instance UserEntity : DTDFVocab:Environment [
    base:desc "Operator interface for monitoring and managing the Digital Twin."
    base:contains RemoteManagementService, ReportingService
]

// C9: Cross-System Entity
instance DataTranslationCrossSystemEntity : DTDFVocab:Environment [
    base:desc "Cross-system entity handling data serialization, unit conversion, and message alignment."
    base:contains DataTranslationFunctionalEntity
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT issues ROS2 command messages over the same Wi‑Fi link to the PT. Commands include the ACC‑computed desired speed, enable/disable ACC flags, user‑requested speed set‑points, and emergency‑braking signals. The Actuation FE on the PT receives these messages and drives the motor controller and steering servo accordingly."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sub‑100 ms end‑to‑end latency is required for PT‑to‑DT communication (R7). Clock synchronization across all DTS components must be accurate to within 100 ms (R8). Data are collected and processed in real time at the perception cycle rate of the vehicle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A distributed constellation where the Physical Twin Entity (sensors, actuation, point‑cloud processing) runs on the vehicle’s Jetson Orin Nano, the Digital Twin Entity (data collection, ACC computation, visualization preprocessing, reporting) runs on external compute, and the User Entity (3D visualization UI, control‑panel UI) runs on a operator workstation. Data Translation FE provides a common data model across entities. Communication uses ROS2 topics over Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during design (as a cyber‑physical experimentation platform), development (for troubleshooting and validation), and operation (for real‑time monitoring, remote management, and performance reporting)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity perception is achieved through DBSCAN clustering of LiDAR points and Kalman‑filter tracking, providing accurate object tracks. The ACC control model follows ISO 15622 specifications for performance class I. Real‑time validation is performed by the UI reporting vehicle state and by measuring end‑to‑end latency (≤100 ms). Clock synchronization (≤100 ms) supports consistent event ordering."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication between PT and DT over a Wi‑Fi network using ROS2 (DDS) transport. Data are marshalled by the Data Translation FE, which handles serialization, message‑type alignment, and unit conversion. No OPC UA is employed in the implementation, although it is mentioned as an optional standard."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the vehicle’s NVIDIA Jetson Orin Nano (ROS2 packages). Digital Twin Entity and User Entity are hosted on external compute resources (e.g., a workstation or cloud server) also running ROS2. Each Functional Entity is encapsulated in its own ROS2 package for modular deployment."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Primary use of ISO 23247 (Digital Twin Manufacturing Framework) reference architecture; ACC functional model follows ISO 15622 (Adaptive Cruise Control). ISO/IEC 30173 is referenced for terminology but not applied. No other standards are explicitly used."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed for safety‑critical operation with a maximum 100 ms latency and synchronized clocks (±100 ms) to ensure timely actuation. Remote management commands include emergency braking. While specific cybersecurity mechanisms are not detailed, the architecture respects safety constraints by limiting latency and ensuring real‑time control as per ISO 15622."
]