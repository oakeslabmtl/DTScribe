    DTDFVocab:inputTo HealthcareMonitoringEnabler
]

instance SpaceDebrisTrajectories : DTDFVocab:Data [
    base:desc "Predicted trajectories of space debris objects for collision risk assessment"
    DTDFVocab:fromData SpaceDebrisData
    DTDFVocab:inputTo SpaceDebrisMitigationEnabler
]

// C11: Enablers
instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2-based software component performing point cloud clustering, tracking, and 3D reconstruction using PointCloudClusteringModel"
    DTDFVocab:enables RealTimeVisualizationService, AnomalyDetectionService
]

instance AutonomousControlEnabler : DTDFVocab:Enabler [
    base:desc "Edge computing framework implementing autonomous control algorithms using VehicleStateEstimationModel for real-time decision making"
    DTDFVocab:enables AutonomousControlService, CollisionAvoidanceService
]

instance BatteryManagementEnabler : DTDFVocab:Enabler [
    base:desc "Physics-based simulation engine optimizing battery thermal management and degradation prediction using BatteryDegradationModel"
    DTDFVocab:enables BatteryOptimizationService
]

instance HealthcareMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "AI/ML processing pipeline analyzing BiologicalSignalFeatures for real-time healthcare monitoring and predictive diagnostics"
    DTDFVocab:enables PatientMonitoringService, AnomalyDetectionService
]

instance SpaceDebrisMitigationEnabler : DTDFVocab:Enabler [
    base:desc "Orbital mechanics simulation platform computing collision avoidance maneuvers using OrbitalMechanicsModel"
    DTDFVocab:enables CollisionAvoidanceService, TrajectoryOptimizationService
]

instance ProcessOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Constraint-based optimization engine adjusting production schedules and resource allocation using ManufacturingProcessModel"
    DTDFVocab:enables ProcessOptimizationService, EnergyManagementService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247-compliant data translation component ensuring serialization, message alignment, and unit conversion across data streams"
    DTDFVocab:enables DataIntegrationService
]

instance EdgeComputingFramework : DTDFVocab:Enabler [
    base:desc "Kubernetes-based edge computing framework deploying digital twin services on NVIDIA Jetson and Raspberry Pi clusters for low-latency processing"
    DTDFVocab:enables EdgeOptimizationService
]

instance DigitalTwinPlatform : DTDFVocab:Enabler [
    base:desc "Cloud-based digital twin platform (e.g., Siemens MindSphere, PTC ThingWorx) providing DTaaS capabilities and role-based access control"
    DTDFVocab:enables VisualizationService, DecisionSupportService
]

