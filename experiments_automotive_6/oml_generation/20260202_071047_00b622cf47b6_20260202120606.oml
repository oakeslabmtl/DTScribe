]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Machine learning model converting raw 2D point cloud data into structured object tracks and spatial clusters for 3D visualization"
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance VehicleStateEstimationModel : DTDFVocab:Model [
    base:desc "Kalman filter-based model for real-time vehicle state estimation combining sensor fusion and predictive path planning"
    DTDFVocab:inputTo AutonomousControlEnabler
]

instance BatteryDegradationModel : DTDFVocab:Model [
    base:desc "Physics-based finite element analysis model predicting battery degradation over time using thermal and electrochemical data"
    DTDFVocab:inputTo BatteryManagementEnabler
]

instance BiologicalSignalProcessingModel : DTDFVocab:Model [
    base:desc "Neural network model for processing physiological signals and detecting anomalies in healthcare monitoring systems"
    DTDFVocab:inputTo HealthcareMonitoringEnabler
]

instance OrbitalMechanicsModel : DTDFVocab:Model [
    base:desc "Multi-body dynamics model simulating satellite trajectories and collision avoidance maneuvers for aerospace systems"
    DTDFVocab:inputTo SpaceDebrisMitigationEnabler
]

instance ManufacturingProcessModel : DTDFVocab:Model [
    base:desc "Constraint-based optimization model for production scheduling and resource allocation in cyber-physical production systems"
    DTDFVocab:inputTo ProcessOptimizationEnabler
]

