// C2: Acting Components
instance CyberBiophysicalActuator : DTDFVocab:ActingComponent [
    base:desc "Bi-directional actuator for cyber-biophysical systems integrating prosthetic controls, drug delivery systems, and wearable device interfaces with real-time feedback capabilities"
]

instance AutomotiveVehicleActuator : DTDFVocab:ActingComponent [
    base:desc "Vehicle actuator system controlling powertrain, chassis, and ADAS components with sub-millisecond latency requirements for autonomous driving applications"
]

instance ManufacturingRobotActuator : DTDFVocab:ActingComponent [
    base:desc "Industrial robot actuator for CNC machining, assembly lines, and additive manufacturing with ISO 23247 compliance for process optimization"
]

instance AerospaceSatelliteActuator : DTDFVocab:ActingComponent [
    base:desc "Satellite thruster and orientation control system for on-orbit collision avoidance with dynamic orbital mechanics adaptation"
]

instance BatteryManagementActuator : DTDFVocab:ActingComponent [
    base:desc "Battery management system actuator controlling cell balancing, thermal management, and state estimation for lithium-ion battery packs"
]

// C3: Physical sensing components
instance PhysiologicalSensor : DTDFVocab:SensingComponent [
    base:desc "Wearable ECG/EEG/pressure sensors for real-time physiological parameter tracking in cyber-biophysical systems with stochastic process integration"
    DTDFVocab:producedData PhysiologicalDataTransmitted
]

instance AutomotiveLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "High-resolution LiDAR sensor for autonomous vehicle perception with 3D point cloud generation and object tracking capabilities"
    DTDFVocab:producedData LiDARDataTransmitted
]

instance AutomotiveRadarSensor : DTDFVocab:SensingComponent [
    base:desc "Automotive radar sensor for collision detection and velocity measurement with 2D/3D environmental mapping capabilities"
    DTDFVocab:producedData RadarDataTransmitted
]

instance ManufacturingProcessSensor : DTDFVocab:SensingComponent [
    base:desc "Industrial process sensor for temperature, pressure, vibration, and flow rate monitoring in manufacturing equipment with ISO/IEC 17025 compliance"
    DTDFVocab:producedData ProcessDataTransmitted
]

instance AerospaceOrbitalSensor : DTDFVocab:SensingComponent [
    base:desc "Space-based radar and optical tracker for satellite debris detection and orbital mechanics monitoring with NASA/ESA compliance"
    DTDFVocab:producedData OrbitalDataTransmitted
]

instance BatteryElectrochemicalSensor : DTDFVocab:SensingComponent [
    base:desc "In-situ battery sensors measuring voltage, temperature, state of charge (SOC), and state of health (SOH) with electrochemical model integration"
    DTDFVocab:producedData BatteryDataTransmitted
]

instance PositionTrackingSensor : DTDFVocab:SensingComponent [
    base:desc "GPS/IMU sensor for precise position and orientation tracking in autonomous vehicles and aerospace applications"
    DTDFVocab:producedData PositionDataTransmitted
]

// C4: Physical-to-virtual interaction
instance PhysiologicalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysiologicalSensor
]

instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AutomotiveLiDARSensor
]

instance RadarDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AutomotiveRadarSensor
]

instance ProcessDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ManufacturingProcessSensor
]

instance OrbitalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AerospaceOrbitalSensor
]

instance BatteryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BatteryElectrochemicalSensor
]

instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionTrackingSensor
]

// C10: Models/Data
instance CyberBiophysicalModel : DTDFVocab:Model [
    base:desc "Multi-scale cyber-biophysical model integrating microscopic (cellular) to macroscopic (organ-level) scales with fuzzy logic for biological variability handling"
]

instance AutomotiveDigitalShadowModel : DTDFVocab:Model [
    base:desc "High-fidelity digital shadow model for automotive systems with 100ms latency synchronization between physical and digital states"
]

instance ManufacturingProcessModel : DTDFVocab:Model [
    base:desc "Multi-scale manufacturing process model from component-level tool wear to plant-level energy consumption with ISO 23247 compliance"
]

instance AerospaceOrbitalModel : DTDFVocab:Model [
    base:desc "High-fidelity orbital mechanics model for satellite systems with dynamic adaptation for variable gravitational forces and debris clouds"
]

instance BatteryElectrochemicalModel : DTDFVocab:Model [
    base:desc "P2D electrochemical model for lithium-ion battery packs with multi-physics coupling of electrochemical, thermal, and mechanical phenomena"
]

instance PhysiologicalData : DTDFVocab:Data [
    base:desc "Processed physiological data including heart rate, glucose levels, and EEG signals with uncertainty quantification using Bayesian networks"
    DTDFVocab:fromData PhysiologicalDataTransmitted
]

instance LiDARData : DTDFVocab:Data [
    base:desc "Processed 2D/3D point clouds from LiDAR sensors with object tracking and spatial alignment for autonomous vehicle perception"
    DTDFVocab:fromData LiDARDataTransmitted
]

instance RadarData : DTDFVocab:Data [
    base:desc "Processed radar data including velocity measurements and collision detection information for autonomous driving applications"
    DTDFVocab:fromData RadarDataTransmitted
]

instance ProcessData : DTDFVocab:Data [
    base:desc "Processed manufacturing data including temperature, pressure, vibration, and flow rate measurements with cross-validation for accuracy"
    DTDFVocab:fromData ProcessDataTransmitted
]

instance OrbitalData : DTDFVocab:Data [
    base:desc "Processed orbital data including satellite position, velocity, and debris detection information with NASA/ESA compliance"
    DTDFVocab:fromData OrbitalDataTransmitted
]

instance BatteryData : DTDFVocab:Data [
    base:desc "Processed battery data including voltage, temperature, SOC, and SOH measurements with electrochemical model integration"
    DTDFVocab:fromData BatteryDataTransmitted
]

instance PositionData : DTDFVocab:Data [
    base:desc "Processed position and orientation data with GPS/IMU fusion for autonomous vehicle and aerospace applications"
    DTDFVocab:fromData PositionDataTransmitted
]

