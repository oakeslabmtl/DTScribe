// C2: Acting Components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Electronic Speed Controller for OME actuation, enabling precise motor voltage commands for speed adjustments"
]

instance SteeringServo : DTDFVocab:Actuator [
    base:desc "Steering servo system for vehicle lateral control with physical actuation constraints"
    DTDFVocab:producedData SteeringCommandSignal
]

// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Onboard LiDAR sensor providing 2D plane data for spatial awareness in autonomous driving applications"
    DTDFVocab:producedData RawLiDARPointCloud
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Depth camera providing spatial distribution for environmental and motion tracking"
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Combination of IMU and vehicle dynamics sensors for position, speed, and orientation tracking"
    DTDFVocab:producedData VehicleStateData, ACCControlLog
]

// C4: Physical-to-Virtual Data Transmission
instance RawLiDARPointCloud : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
    base:desc "Raw 2D LiDAR point cloud data for initial processing and clustering"
]

instance ProcessedLiDARData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
    base:desc "Processed LiDAR data after DBSCAN clustering for object tracking and vehicle state representation"
]

instance MotorActuationSignal : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
    base:desc "Motor voltage commands generated by Actuation Functional Entity for speed adjustments"
]

instance SteeringCommandSignal : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
    base:desc "Steering servo commands for lateral control based on control logic processing"
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
    base:desc "Structured vehicle state data (position, speed, orientation) for digital twin representation"
]

instance ACCControlLog : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
    base:desc "Automatic Cruise Control related logs for diagnostics and reporting"
]

// C5: Data Components
instance LiDARClusteringOutput : DTDFVocab:Data [
    base:desc "Structured object tracks generated from LiDAR point cloud clustering for autonomous driving applications"
    DTDFVocab:fromData ProcessedLiDARData
]

instance VehicleStateRepresentation : DTDFVocab:Data [
    base:desc "Real-time vehicle state representation combining position, speed, and orientation data"
    DTDFVocab:fromData VehicleStateData
]

instance ActuationCommands : DTDFVocab:Data [
    base:desc "Digital commands for motor and steering actuators based on control logic processing"
    DTDFVocab:fromData MotorActuationSignal, SteeringCommandSignal
]

instance OperationalMetrics : DTDFVocab:Data [
    base:desc "Generated operational metrics (efficiency, reliability) for analytics and compliance reporting"
    DTDFVocab:fromData ACCControlLog
]

instance VisualizationData : DTDFVocab:Data [
    base:desc "3D interactive dashboard data for real-time vehicle state visualization"
    DTDFVocab:fromData LiDARClusteringOutput, VehicleStateRepresentation
]

instance HistoricalDataStorage : DTDFVocab:Data [
    base:desc "Stored historical data for offline analysis and compliance reporting"
    DTDFVocab:fromData OperationalMetrics
]

// C6: Models
instance PointCloudTrackingModel : DTDFVocab:Model [
    base:desc "Model implementing DBSCAN clustering and tracking algorithms for LiDAR data processing"
]

instance KalmanFilterModel : DTDFVocab:Model [
    base:desc "State estimation model using Kalman filters for vehicle tracking and uncertainty quantification"
]

instance ParticleFilterModel : DTDFVocab:Model [
    base:desc "Uncertainty quantification model using particle filters for dynamic environments"
]

instance AdaptiveControlLogic : DTDFVocab:Model [
    base:desc "Dynamic reconfiguration model for ACC control algorithms with physics-informed constraints"
]

instance PhysicsInformedNeuralNetwork : DTDFVocab:Model [
    base:desc "Hybrid model combining deep learning with PDEs for high-fidelity predictions"
]

instance TrajectoryForecastModel : DTDFVocab:Model [
    base:desc "Short-term prediction model using Kalman filtering and RNNs for autonomous vehicle path planning"
]

instance DriverIntentRecognitionModel : DTDFVocab:Model [
    base:desc "Model for recognizing driver intent using gaze tracking and voice commands"
]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "Core middleware for multi-agent coordination, message passing, and device abstraction across heterogeneous IoT devices"
    DTDFVocab:enables RealTimeDataAcquisitionService, StateEstimationService
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "Simulation engines for modeling physics-based dynamics and digital twin validation"
    DTDFVocab:inputTo VisualizationService
]

instance Python38Environment : DTDFVocab:Enabler [
    base:desc "Scripting environment for data processing, machine learning, and ontology management"
]

instance CPlusPlusPlatform : DTDFVocab:Enabler [
    base:desc "Low-level programming platform for real-time embedded systems and high-performance computing"
]

instance SQLDatabaseSystem : DTDFVocab:Enabler [
    base:desc "Structured storage system for historical data, operational metrics, and queryable DT state"
    DTDFVocab:inputTo OperationalMetrics, HistoricalDataStorage
]

instance PhysicsInformedNeuralNetworks : DTDFVocab:Enabler [
    base:desc "Hybrid modeling approach combining deep learning with PDEs for high-fidelity predictions"
    DTDFVocab:inputTo TrajectoryForecastModel
]

instance TensorFlowPyTorchFrameworks : DTDFVocab:Enabler [
    base:desc "AI simulation frameworks for end-to-end training of DT components"
    DTDFVocab:inputTo DriverIntentRecognitionModel
]

instance SemanticWebTechnologies : DTDFVocab:Enabler [
    base:desc "OWL/RDF technologies for ontology-driven reasoning to link DT data with industrial standards"
]

instance EdgeComputingFramework : DTDFVocab:Enabler [
    base:desc "ISO 23247-compliant distributed processing model for balancing latency and computational resources"
    DTDFVocab:inputTo RealTimeDataAcquisitionService
]

// C12: Services
instance RealTimeDataAcquisitionService : DTDFVocab:Service [
    base:desc "Continuous ingestion of sensor data via edge computing for low-latency processing with DBSCAN clustering for anomaly detection"
    DTDFVocab:provides LiDARClusteringOutput, ProcessedLiDARData
    DTDFVocab:enables EdgeComputingFramework
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Use of Kalman filters for tracking and particle filters for uncertainty quantification in dynamic environments"
    DTDFVocab:provides VehicleStateRepresentation
    DTDFVocab:enables KalmanFilterModel, ParticleFilterModel
]

instance AdaptiveControlService : DTDFVocab:Service [
    base:desc "Dynamic reconfiguration of control algorithms (e.g., ACC) based on real-time feedback with physics-informed constraints"
    DTDFVocab:provides ActuationCommands
    DTDFVocab:enables AdaptiveControlLogic
]

instance ResourceAllocationService : DTDFVocab:Service [
    base:desc "Offloading computationally intensive tasks to edge/cloud platforms for AI-driven simulations"
    DTDFVocab:provides PhysicsInformedNeuralNetwork
    DTDFVocab:enables TensorFlowPyTorchFrameworks, PhysicsInformedNeuralNetworks
]

instance FaultPredictionService : DTDFVocab:Service [
    base:desc "Machine learning models for proactive failure detection in automotive and industrial systems"
    DTDFVocab:provides OperationalMetrics
    DTDFVocab:enables Python38Environment
]

instance TrajectoryForecastingService : DTDFVocab:Service [
    base:desc "Short-term predictions for autonomous vehicles using Kalman filtering and RNNs for path planning"
    DTDFVocab:provides TrajectoryForecastModel
    DTDFVocab:enables KalmanFilterModel
]

instance ClosedLoopControlService : DTDFVocab:Service [
    base:desc "Direct actuation of physical systems via ROS2-based message brokers for interoperability"
    DTDFVocab:provides MotorActuationSignal, SteeringCommandSignal
    DTDFVocab:enables ROS2Middleware
]

instance HumanInTheLoopService : DTDFVocab:Service [
    base:desc "Integration of driver intent recognition (gaze tracking, voice commands) into DT for context-aware control"
    DTDFVocab:provides DriverIntentRecognitionModel
    DTDFVocab:enables Python38Environment
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D interactive dashboards for real-time vehicle state visualization using MATLAB/Simulink and ROS2 visualization tools"
    DTDFVocab:provides VisualizationData
    DTDFVocab:enables MATLABSimulink, ROS2Middleware
]

instance DataDrivenInsightsService : DTDFVocab:Service [
    base:desc "Generation of operational metrics (efficiency, reliability) via SQL databases for analytics and compliance reporting"
    DTDFVocab:provides OperationalMetrics
    DTDFVocab:enables SQLDatabaseSystem
]

instance StandardizedProtocolsService : DTDFVocab:Service [
    base:desc "Adherence to ISO/IEC 30173 for terminology consistency and ISO 23247-1 for framework alignment"
    DTDFVocab:enables SemanticWebTechnologies, EdgeComputingFramework
]

