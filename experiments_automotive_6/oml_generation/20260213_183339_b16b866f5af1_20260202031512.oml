// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR mounted on upper chassis, provides 2D range scans"
    DTDFVocab:producedData LiDARDataTransmitted
]

instance IntelRealSenseD435i : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera providing RGB‑D frames"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance EgoSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Internal vehicle state sensor measuring ego speed"
    DTDFVocab:producedData EgoSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Internal vehicle state sensor measuring steering angle"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// C4: Physical‑to‑virtual interaction (Data transmitted)
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435i
]

instance EgoSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C10: Data objects
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw point‑cloud stream from LiDAR"
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo ClusteringAndTrackingEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames from RealSense camera"
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo ClusteringAndTrackingEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego speed measurement (m/s)"
    DTDFVocab:fromData EgoSpeedDataTransmitted
    DTDFVocab:inputTo ACCAlgorithmEnabler
]

instance VehicleSteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle measurement (rad)"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo ACCAlgorithmEnabler
]

// C10: Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering implemented in MATLAB/Simulink"
    DTDFVocab:inputTo ClusteringAndTrackingEnabler
]

instance KalmanFilterTrackerModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based multi‑object tracker"
    DTDFVocab:inputTo ClusteringAndTrackingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm compliant with ISO‑15622 performance class I"
    DTDFVocab:inputTo ACCAlgorithmEnabler
]

// C11: Enablers
instance ROS2DataTranslationFE : DTDFVocab:Enabler [
    base:desc "ROS2 Feature Enabler serialising and unit‑converting sensor streams before Wi‑Fi transmission"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance ClusteringAndTrackingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 node executing DBSCAN clustering and Kalman filter tracking using MATLAB/Simulink libraries"
    DTDFVocab:enables DataMonitoringService
]

instance ACCAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 node running ACC control model on off‑board compute"
    DTDFVocab:enables ComputationOffloadingService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database storing time‑series vehicle state and object tracks"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance VisualizationPreprocessorEnabler : DTDFVocab:Enabler [
    base:desc "Preprocesses tracking and path data for 3‑D rendering in UI"
    DTDFVocab:enables DataMonitoringService
]

instance ROS2ActuationFE : DTDFVocab:Enabler [
    base:desc "ROS2 Feature Enabler translating control commands to ESC and steering servo, includes emergency brake override"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI displays real‑time speed, steering angle, object tracks and projected path; generates analytical reports"
    DTDFVocab:provides VehicleStateInsight, ObjectTracksInsight, ProjectedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Off‑board ACC algorithm computes desired speed and sends control commands to the physical twin"
    DTDFVocab:provides ACCDesiredSpeedDecision
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, adjust desired speed, and trigger emergency braking via UI"
    DTDFVocab:provides EmergencyBrakingAction, RemoteControlAction
]

// C17: Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Visual insight of current vehicle speed and steering angle"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Visualized clusters and tracked objects derived from LiDAR and depth camera data"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected vehicle trajectory based on ACC decision and current state"
]

// C17: Actions
instance ACCDesiredSpeedDecision : DTDFVocab:Action [
    base:desc "Automatically computed desired speed based on ACC logic and object proximity"
    DTDFVocab:IsAutomatic true
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Emergency braking command that overrides motor actuation"
    DTDFVocab:IsAutomatic false
]

instance RemoteControlAction : DTDFVocab:Action [
    base:desc "Operator‑issued manual speed or steering command via UI"
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance ElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder ESC that receives motor voltage commands from the Actuation FE"
]

instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Servo that actuates steering based on angle command from the Actuation FE"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator that forces motor stop for emergency braking"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends desired speed set‑points, ACC enable/disable commands, speed‑modification commands, and emergency‑brake signals back to the Physical Twin Entity over Wi‑Fi; the Actuation FE converts these into motor voltage or servo commands for execution on the vehicle."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is designed for real‑time operation with a maximum end‑to‑end network latency of 100 ms and clock synchronization accuracy of 100 ms across all DTS components, matching the 3GPP 22.185 latency requirement for V2V services."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 reference model with a Physical Twin Entity, Digital Twin Entity, User Entity and a Cross‑System Data Translation FE; components are implemented as ROS 2 packages, communicating intra‑vehicle via ROS 2 and inter‑entity via Wi‑Fi, providing modularity and loose coupling."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity sensor data (LiDAR point clouds, depth images) are processed in real time; clock synchronization (≤100 ms) and latency limits ensure temporal fidelity; ACC behavior conforms to ISO 15622 specifications, providing functional validity for the 1/10‑scale test vehicle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Intra‑vehicle communication uses ROS 2 over DDS; inter‑entity communication uses a Wi‑Fi network with standardized interfaces (R1) for data translation and command exchange. No specific application‑layer protocol beyond ROS 2 messages is described."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the on‑board Jetson Orin Nano; the Digital Twin Entity (including ACC computation, data storage, and reporting) runs on an external compute platform (e.g., a PC or cloud server); the User Entity UI runs on a developer/operator workstation."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adheres to ISO 23247 (Digital Twin Manufacturing Framework) for architectural structuring, ISO 15622 for ACC functional requirements, and references ISO/IEC 30173 for digital‑twin terminology; optional OPC UA can be used for data translation but is not required in this implementation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by limiting network latency to 100 ms, ensuring clock sync within 100 ms, and including an emergency‑brake command; the DT is classified as a Fully Autonomous Digital Twin with Human‑in‑the‑Loop, highlighting the need for operator oversight in safety‑critical actions. Specific cybersecurity measures are not detailed in the document."
]