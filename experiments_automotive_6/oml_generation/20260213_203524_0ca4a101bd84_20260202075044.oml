// Sensing Components
instance HokuyoUst10LxSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST 10LX LiDAR providing continuous 360° laser scans at 10 Hz."
    DTDFVocab:producedData PointCloudDataStream
]

instance IntelRealSenseD435iSensor : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera capturing RGB-D frames at 30 fps."
    DTDFVocab:producedData DepthImageDataStream
]

instance WheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel speed encoder feeding ego vehicle speed via CAN bus."
    DTDFVocab:producedData WheelSpeedDataStream
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring wheel angle over 300° range."
    DTDFVocab:producedData SteeringAngleDataStream
]

instance ElectronicSpeedControllerSensor : DTDFVocab:SensingComponent [
    base:desc "Vedder electronic speed controller interface exposing throttle, current, and voltage states."
    DTDFVocab:producedData VehicleStateDataStream
]

// Data Transmitted (serialised ROS2 DDS messages)
instance PointCloudDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUst10LxSensor
]

instance DepthImageDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iSensor
]

instance WheelSpeedDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedSensor
]

instance SteeringAngleDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance VehicleStateDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ElectronicSpeedControllerSensor
]

// Data (raw formats used by models)
instance PointCloudData : DTDFVocab:Data [
    base:desc "Raw lidar point cloud in XYZ format."
    DTDFVocab:fromData PointCloudDataStream
    DTDFVocab:inputTo ClusteringEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames from RealSense camera in 16-bit PNG."
    DTDFVocab:fromData DepthImageDataStream
    DTDFVocab:inputTo TrackingEnabler
]

instance WheelSpeedData : DTDFVocab:Data [
    base:desc "Vehicle wheel speed in km/h."
    DTDFVocab:fromData WheelSpeedDataStream
    DTDFVocab:inputTo TrackingEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering wheel angle in degrees."
    DTDFVocab:fromData SteeringAngleDataStream
    DTDFVocab:inputTo TrackingEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Throttle position, current, and voltage states from the electronic speed controller."
    DTDFVocab:fromData VehicleStateDataStream
    DTDFVocab:inputTo AccControllerEnabler
]

// Models
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN-based point cloud clustering algorithm implemented in Python."
    DTDFVocab:inputTo ClusteringEnabler
]

instance ObjectTrackingModel : DTDFVocab:Model [
    base:desc "Kalman-filter-based multi-object tracker processing clustered points."
    DTDFVocab:inputTo TrackingEnabler
]

instance ACCControllerModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control controller compliant with ISO 15622."
    DTDFVocab:inputTo AccControllerEnabler
]

// Enablers (Functional Entities/ROS2 Nodes)
instance ClusteringEnabler : DTDFVocab:Enabler [
    base:desc "Data Collection FE node that runs point cloud clustering."
    DTDFVocab:enables DataMonitoringService
]

instance TrackingEnabler : DTDFVocab:Enabler [
    base:desc "Object Tracking FE node that fuses depth images, speed, and steering data."
    DTDFVocab:enables DataMonitoringService
]

instance AccControllerEnabler : DTDFVocab:Enabler [
    base:desc "ACC Control FE node that executes the ACC algorithm on cloud server."
    DTDFVocab:enables ACCAlgorithmService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time viewer of vehicle speed, steering angle, and surrounding object tracks."
    DTDFVocab:provides VehicleSpeedInsight, VehicleSteeringInsight, ObjectTrackingInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI service handling ACC enable/disable, desired speed adjustments, and emergency braking."
    DTDFVocab:provides ACCEnableAction, ACCDisableAction, DesiredSpeedAdjustmentAction, EmergencyBrakingAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D rendering of vehicle, projected path, and tracked objects using a 3D Visualizer FE."
    DTDFVocab:provides VehicleVisualizationInsight, PathVisualizationInsight, ObjectVisualizationInsight
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Generates human-readable XML/CSV reports and SQL snapshot databases of vehicle data."
    DTDFVocab:provides ReportGenerationInsight
]

instance ACCAlgorithmService : DTDFVocab:Service [
    base:desc "ACC algorithm service that sends desired speed, steering, and emergency brake commands."
    DTDFVocab:provides VehicleAccelerationCommand, VehicleSteeringCommand, VehicleEmergencyBrakeCommand
]

// Insights
instance VehicleSpeedInsight : DTDFVocab:Insight [
    base:desc "Insight into current vehicle speed and desired speed over time."
]

instance VehicleSteeringInsight : DTDFVocab:Insight [
    base:desc "Insight into steering angle and lane-keeping performance."
]

instance ObjectTrackingInsight : DTDFVocab:Insight [
    base:desc "Insight into tracked object positions and lead distances for ACC."
]

instance VehicleVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight depicting vehicle pose and 3D environment view."
]

instance PathVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight showing projected path based on ACC planning."
]

instance ObjectVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight visualizing surrounding objects in 3D space."
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing report content and timeline of logged events."
]

instance ACCPerformanceDashboardInsight : DTDFVocab:Insight [
    base:desc "Dashboard insight combining speed, lead distance, and desired speed metrics."
]

// Actions
instance ACCEnableAction : DTDFVocab:Action [
    base:desc "Action to enable the Adaptive Cruise Control subsystem."
    DTDFVocab:IsAutomatic false
]

instance ACCDisableAction : DTDFVocab:Action [
    base:desc "Action to disable the Adaptive Cruise Control subsystem."
    DTDFVocab:IsAutomatic false
]

instance DesiredSpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Action to set a desired speed value for the ACC algorithm."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Action to trigger emergency braking via the vehicle’s braking system."
    DTDFVocab:IsAutomatic false
]

instance VehicleAccelerationCommand : DTDFVocab:Action [
    base:desc "Command generated by the ACC algorithm to adjust throttle velocity."
    DTDFVocab:IsAutomatic true
]

instance VehicleSteeringCommand : DTDFVocab:Action [
    base:desc "Command generated by the ACC algorithm to adjust steering servo."
    DTDFVocab:IsAutomatic true
]

instance VehicleEmergencyBrakeCommand : DTDFVocab:Action [
    base:desc "Command generated by the ACC algorithm to apply emergency braking."
    DTDFVocab:IsAutomatic true
]

// Acting Components (Physical Actuators)
instance ThrottleActuator : DTDFVocab:ActingComponent [
    base:desc "GPIO output on Jetson Orin Nano controlling electronic speed controller throttle."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "GPIO output on Jetson Orin Nano driving steering servo actuators."
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "GPIO output on Jetson Orin Nano driving emergency braking system."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Outputs from the Digital Twin, such as desired speed command, steering angle command, and ACC enable/disable signals, are published on the ROS 2 network and delivered to the PT via the Data Translation FE over Wi‑Fi. The actuator FEs on the PT convert these high‑level commands into motor voltage commands, steering servo PWM signals, or brake regulator signals, which directly control the vehicle’s hardware."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near‑real‑time operations with a maximum end‑to‑end latency of 100 ms between the PT and the Digital Twin. Data streams are sampled at the sensor frequencies (LiDAR at ~10 Hz, depth camera at ~6 Hz, vehicle‑state at 50‑100 Hz) and synchronized by the Data Translation FE with a clock accuracy of ≤ 100 ms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellation is an entity‑based architecture following ISO 23247: Physical Twin Entity hosts sensors and actuation, Digital Twin Entity hosts data collection, ACC computation, reporting; User Entity hosts 3D visualization and control panel; Cross‑System Entity implements Data Translation. ROS 2 message passing over Wi‑Fi connects these entities, forming a decentralized, real‑time orchestrated system."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the operation stage of the vehicle’s lifecycle; it monitors a manufactured 1/10‑scale PT (manufacturing stage) and provides active runtime services during operation. The system is not used during design or design validation, thus focusing on manufactured and operational stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through Kalman‑filter state‑estimation and DBSCAN clustering on raw LiDAR, which are validated against ground‑truth from manual inspection. ACC control complies with ISO 15622 safety levels, guaranteeing deterministic behavior. Data translation applies unit conversion and timestamp alignment to preserve temporal integrity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication uses ROS 2 DDS over Wi‑Fi (UDP/TCP). The PT‑DT link is a 5 GHz Wi‑Fi network; the vehicle’s Jetson publishes LiDAR and vehicle‑state topics and subscribes to actuation topics. The cloud ACC server communicates via secure MQTT or gRPC over TLS. Data Translation FE serializes messages into binary DDS payloads."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical hosting occurs on an NVIDIA Jetson Orin Nano installed in the vehicle, with additional ROS 2 nodes deployed on a cloud server (e.g., AWS EC2 GPU instance) for ACC computation. The User UI runs on an operator workstation (Windows/Linux) connected over the same Wi‑Fi LAN, or accessible via secure web interface. All nodes can be containerized with Docker or run natively on the target OS."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (RA) for entity–FE mapping, uses ISO 15622 (ACC control), ISO 30173 (concepts & terminology) for terminology, and IEC 62541 (OPC UA) where applicable. ROS 2 (DDS) adheres to MISRA‑C++ and ISO 14379. Firmware on Jetson uses NVIDIA JetPack 5.0 which complies with ISO 13849 for medical devices and ISO 26262 for automotive safety, providing baseline safety assurance."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The system is safety‑critical; operations are bound by a 100 ms latency threshold derived from 3GPP 22.185 V2V standards. The Digital Twin enforces command validation and timestamp checks to prevent stale commands and incorporates ISO 15622 safety rules for ACC. However, explicit cybersecurity measures (auth, encryption) are not detailed in the document."
]