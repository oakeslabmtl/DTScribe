// Environments
instance VehiclePhysicalTwinEnvironment : DTDFVocab:Environment [
    base:desc "Physical twin of the 1/10 scale vehicle, hosting onboard hardware and actuators."
    base:contains HokuyoLidarSensor, IntelDepthCameraSensor, VehicleSpeedSensor, SteeringAngleSensor, VedderESCActuator, SteeringServoActuator
]

// Sensing Components
instance HokuyoLidarSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST10LX LiDAR producing 3‑D point cloud data."
    DTDFVocab:producedData LiDARPointCloudTransmitted
]
instance IntelDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera capturing visual depth images."
    DTDFVocab:producedData DepthImageTransmitted
]
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board vehicle speed sensor reporting wheel velocity."
    DTDFVocab:producedData SpeedSignalTransmitted
]
instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring steering wheel angle."
    DTDFVocab:producedData SteeringAngleSignalTransmitted
]
instance DatabaseLoggerComponent : DTDFVocab:SensingComponent [
    base:desc "Internal logger producing serialized SQL database logs."
    DTDFVocab:producedData DatabaseLogsTransmitted
]

// Acting Components
instance VedderESCActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller controlling motor torque."
]
instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Integrated steering servo providing heading actuation."
]

// Data Transmitted
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLidarSensor
]
instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCameraSensor
]
instance SpeedSignalTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]
instance SteeringAngleSignalTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]
instance DatabaseLogsTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DatabaseLoggerComponent
]

// Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data received from the Hokuyo UST10LX."
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ROS2CommunicationEnabler
]
instance DepthImageData : DTDFVocab:Data [
    base:desc "Real‑time depth image from Intel D435i."
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo ROS2CommunicationEnabler
]
instance SpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed telemetry transmitted by the on‑board speed sensor."
    DTDFVocab:fromData SpeedSignalTransmitted
    DTDFVocab:inputTo ROS2CommunicationEnabler
]
instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle telemetry transmitted by the steering angle sensor."
    DTDFVocab:fromData SteeringAngleSignalTransmitted
    DTDFVocab:inputTo ROS2CommunicationEnabler
]
instance SQLDatabaseLogsData : DTDFVocab:Data [
    base:desc "Logs of vehicle data and control actions stored in the SQL database."
    DTDFVocab:fromData DatabaseLogsTransmitted
    DTDFVocab:inputTo SQLDatabaseEnabler
]

// Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering model in MATLAB/Simulink for point cloud segmentation."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]
instance KalmanFilteringTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking model in Python 3.8 for object track estimation."
    DTDFVocab:inputTo PythonPrototypingEnabler
]
instance ACCControllerModel : DTDFVocab:Model [
    base:desc "ACC controller implementing ISO 15622 performance class I logic."
    DTDFVocab:inputTo CppLifecycleEnabler
]
instance PoseStateModel : DTDFVocab:Model [
    base:desc "Vehicle pose and state dynamics model via NVIDIA Jetpack SDK."
    DTDFVocab:inputTo NVIDIAJetpackEnabler
]

// Enablers
instance ROS2CommunicationEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware facilitating real‑time data transmission over Wi‑Fi."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]
instance PythonPrototypingEnabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime used for rapid prototyping of KL filtering and remote APIs."
    DTDFVocab:enables DataMonitoringService
]
instance CppLifecycleEnabler : DTDFVocab:Enabler [
    base:desc "C++ ROS 2 node lifecycle manager for the ACC controller on the Jetson Orin."
    DTDFVocab:enables ComputationOffloadingService
]
instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink integration for point‑cloud clustering and simulation."
    DTDFVocab:enables DataMonitoringService
]
instance NVIDIAJetpackEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK enabling GPU accelerated model inference."
    DTDFVocab:enables ComputationOffloadingService
]
instance WiFiNetworkEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi network setup providing connectivity between vehicle and external host."
    DTDFVocab:enables RemoteManagementService
]
instance GitHubSourceEnabler : DTDFVocab:Enabler [
    base:desc "GitHub-hosted source repository for ROS 2 packages and deployment scripts."
]
instance RoboRacerScriptingEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source RoboRacer scripts for vehicle integration."
]
instance OPCUAEnabler : DTDFVocab:Enabler [
    base:desc "OPC UA protocol for optional data translation."
]
instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database interface for log storage and retrieval."
    DTDFVocab:enables DataStorageReportService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides UI for real‑time vehicle state visualization, projected path, and object tracks."
    DTDFVocab:provides RealTimeVisualizationInsight, ObjectTrackingInsight
]
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC logic on external GPU compute and offloads heavy computations."
    DTDFVocab:provides ACCControlInsight, PerformanceMetricsInsight
]
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows remote enable/disable ACC, set desired speed, and trigger emergency braking."
    DTDFVocab:provides RemoteControlInsight, EmergencyBrakingAction
]
instance Visualization3DService : DTDFVocab:Service [
    base:desc "Generates 3‑D visualizations of vehicle trajectory and environment."
    DTDFVocab:provides ThreeDVisualizationInsight
]
instance DataStorageReportService : DTDFVocab:Service [
    base:desc "Stores logs in SQL database and generates performance reports."
    DTDFVocab:provides PerformanceReportInsight, DiagnosticReportInsight
]

// Insights
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight into current vehicle state and projected path displayed in real time."
]
instance ObjectTrackingInsight : DTDFVocab:Insight [
    base:desc "Insight into tracked object positions derived from Kalman filtering."
]
instance ACCControlInsight : DTDFVocab:Insight [
    base:desc "Insight of ACC control decisions computed from ACC controller."
]
instance PerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Insight into performance indicators such as speed, fuel consumption, and trajectory adherence."
]
instance RemoteControlInsight : DTDFVocab:Insight [
    base:desc "Insight into remote operator adjustments for ACC parameters and vehicle speed."
]
instance ThreeDVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight into rendered 3‑D visualization of vehicle and surroundings."
]
instance PerformanceReportInsight : DTDFVocab:Insight [
    base:desc "Performance report generated from SQL database logs."
]
instance DiagnosticReportInsight : DTDFVocab:Insight [
    base:desc "Diagnostic report for predictive maintenance derived from logged data."
]
instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Action enabling immediate vehicle braking in emergency situations."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Desired speed and steering set‑points generated by the ACC controller in the Digital Twin Entity are converted to motor voltage commands by the Actuation FE and transmitted over Wi‑Fi to the Vedder ESC and steering servo; emergency braking commands and ACC enable/disable signals are also sent from the User Entity to the Physical Twin Entity."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Operations performed in real‑time with end‑to‑end latency ≤ 100 ms, clocks synchronized to within 100 ms, and vehicle state updated at each perception cycle (≈ 10 Hz)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation follows ISO 23247’s entity‑based RA: the Physical Twin Entity subsumes sensor/actuator interfaces, the Digital Twin Entity hosts simulation and control FEs, the User Entity hosts the 3‑D visualization and control panel, and the Cross‑System Entity mediates data translation; all are connected via ROS 2 topics over Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle spans the design stage (simulation and validation of ACC logic using the ROS 2/SIMULINK models), the validation stage (online evaluation of ACC performance during field trials), and the operational stage (ongoing monitoring, remote management, and data logging during vehicle operation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity ensured by real‑time data acquisition, DBSCAN + Kalman‑filter tracking, and compliance with ISO 15622 ACC rules; validity verified through field‑trial latency tests (≤ 100 ms) and ACC performance against vehicle trajectory; uncertainty managed by timestamp synchronization and 100 ms clock alignment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication occurs over a standard Wi‑Fi network using ROS 2 DDS transport; the Data Translation FE serializes messages, performs unit conversions, and aligns timestamps; the Physical Twin Entity communicates over the vehicle’s Ethernet/Serial optical network to the Jetson."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hybrid deployment: on‑board Jetson Orin Nano handles sensor data ingestion and actuation, an off‑board host (cloud or local server) runs the Digital Twin Entity FEs (ACC controller, visualization), and a SQL database server stores logs; the system runs ROS 2 nodes across vehicle and host hardware, using NVIDIA Jetpack 5.0 on the Edge device."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture and standard, ISO 15622 for ACC, ROS 2 middleware, OPC UA for data translation where applied, and NVIDIA JetPack SDK."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety compliance through ISO 15622 ACC spec and real‑time latency ≤ 100 ms; mechanical safety via actuators controlled only by Digital Twin Entity; no explicit cybersecurity mechanisms described, but all wireless communication is encapsulated in ROS 2 DDS which supports encryption if configured."
]