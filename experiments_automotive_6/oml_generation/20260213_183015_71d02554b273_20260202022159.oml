// ----------------------------------------------------------
// 1. Physical Sensing Components
// ----------------------------------------------------------

instance HokuyoLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2‑D LiDAR mounted on the vehicle roof providing up to 10 Hz range measurements."
    DTDFVocab:producedData LiDARRawDataTransmitted
]

instance IntelDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera mounted front‑facing delivering RGB‑D streams at up to 30 Hz."
    DTDFVocab:producedData DepthCameraRawDataTransmitted
]

instance MotorSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor reading the drive motor speed (ego vehicle speed)."
    DTDFVocab:producedData SpeedStatusDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle encoder attached to the steering servo."
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// ----------------------------------------------------------
// 2. Data Transmitted from Physical Sensors
// ----------------------------------------------------------

instance LiDARRawDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARSensor
]

instance DepthCameraRawDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCameraSensor
]

instance SpeedStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// ----------------------------------------------------------
// 3. Raw Data Objects (originating from DataTransmitted)
// ----------------------------------------------------------

instance RawLiDARPointCloud : DTDFVocab:Data [
    base:desc "Raw 2‑D point‑cloud captured by the Hokuyo LiDAR."
    DTDFVocab:fromData LiDARRawDataTransmitted
    DTDFVocab:inputTo ClusteringEnabler
]

instance RawDepthRGBDData : DTDFVocab:Data [
    base:desc "Raw RGB‑D frames from the Intel depth camera."
    DTDFVocab:fromData DepthCameraRawDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehicleSpeedStatusData : DTDFVocab:Data [
    base:desc "Ego vehicle speed reading from motor sensor."
    DTDFVocab:fromData SpeedStatusDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehicleSteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering angle of the vehicle."
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

// ----------------------------------------------------------
// 4. Processed Data (output of models)
// ----------------------------------------------------------

instance ClusteredObjectsData : DTDFVocab:Data [
    base:desc "Clusters of LiDAR points generated by DBSCAN."
    DTDFVocab:fromData LiDARRawDataTransmitted
    DTDFVocab:inputTo TrackingEnabler
]

instance TrackedObjectsData : DTDFVocab:Data [
    base:desc "Kalman‑filtered object tracks derived from clustered points."
    DTDFVocab:fromData LiDARRawDataTransmitted
    DTDFVocab:inputTo ACCControlEnabler
]

instance ACCDesiredSpeedData : DTDFVocab:Data [
    base:desc "Desired speed computed by the ACC algorithm for the ego vehicle."
    DTDFVocab:fromData LiDARRawDataTransmitted
    DTDFVocab:inputTo CloudACCEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Aggregated vehicle state (speed, position, heading) after data translation."
    DTDFVocab:fromData SpeedStatusDataTransmitted
    DTDFVocab:inputTo VisualizationEnabler
]

// ----------------------------------------------------------
// 5. Models
// ----------------------------------------------------------

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN algorithm clustering raw LiDAR point clouds."
    DTDFVocab:inputTo TrackingEnabler
]

instance KalmanTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking of DBSCAN clusters."
    DTDFVocab:inputTo ACCControlEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) logic that computes desired speed from tracked objects."
    DTDFVocab:inputTo CloudACCEnabler
]

// ----------------------------------------------------------
// 6. Enablers (software / middleware)
// ----------------------------------------------------------

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Component that serialises, aligns to ISO‑23247, and performs unit conversions on sensor streams."
    DTDFVocab:enables DataMonitoringService
]

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 DDS‑based intra‑process communication backbone."
    DTDFVocab:enables DataMonitoringService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Relational SQL storage for processed perception data."
    DTDFVocab:enables DataMonitoringService
]

instance CloudACCEnabler : DTDFVocab:Enabler [
    base:desc "Off‑loaded ACC computation hosted on cloud/edge resources."
    DTDFVocab:enables ComputationOffloadingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based UI visualisation layer that streams telemetry and accepts operator commands."
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:enables RemoteManagementService
]

instance ClusteringEnabler : DTDFVocab:Enabler [
    base:desc "Executes DBSCAN clustering on incoming LiDAR point clouds."
    DTDFVocab:enables DataMonitoringService
]

instance TrackingEnabler : DTDFVocab:Enabler [
    base:desc "Executes Kalman tracking on clustered objects."
    DTDFVocab:enables DataMonitoringService
]

instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "Runs the ACC control model to produce desired speed."
    DTDFVocab:enables ComputationOffloadingService
]

// ----------------------------------------------------------
// 7. Services
// ----------------------------------------------------------

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Streams real‑time vehicle state, projected path, and object tracks; allows data saving and reporting."
    DTDFVocab:provides VehicleStateInsight
    DTDFVocab:provides ProjectedPathInsight
    DTDFVocab:provides ObjectTracksInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm on external compute resources and returns desired speed."
    DTDFVocab:provides DesiredSpeedInsight
    DTDFVocab:provides EnableACCAction
    DTDFVocab:provides DisableACCAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set speed targets, and issue emergency braking via UI."
    DTDFVocab:provides EmergencyBrakeAction
]

// ----------------------------------------------------------
// 8. Insights
// ----------------------------------------------------------

instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight of ego vehicle speed, position, and heading."
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Visualization of the planned driving path generated by the perception pipeline."
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Insight into nearby object tracks identified by clustering and tracking."
]

instance DesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Computed desired speed for the ego vehicle as output of the ACC algorithm."
]

// ----------------------------------------------------------
// 9. Actions
// ----------------------------------------------------------

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Command to activate Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Command to deactivate Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediate brake command issued by the operator."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin generates control commands for the vehicle’s Adaptive Cruise Control (ACC) subsystem. Command types include enabling/disabling ACC, setting a desired speed value, and issuing an emergency braking request. These commands are formatted by the Data Translation FE (serialised, type‑aligned and unit‑converted) and transmitted to the vehicle over the same Wi‑Fi UDP link used for sensor data. Upon receipt, the Actuation functional element on the physical side decodes the messages and forwards the desired speed or brake command to the vehicle’s motor and steering actuators. The system provides execution confirmation through feedback of the updated vehicle state (e.g., actual speed), which is again processed by the Data Translation FE and sent back to the DT for monitoring. No explicit authentication or conflict‑resolution mechanisms are described in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT requires a shared notion of time across the physical and digital sides to support computation offloading; clock synchronization must achieve 100 ms accuracy (the system limits its sync to 100 ms, whereas many safety‑critical vehicular standards demand tighter bounds). This synchronization interval defines the temporal granularity for services such as sensor data acquisition, point‑cloud clustering, and actuation commands."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration relies on the ISO 23247 reference architecture: functional entities are mapped to ROS 2 packages, each containing one or more ROS 2 nodes that implement the required functionality. The Physical Twin Entity hosts resource‑specific functions (e.g., point‑cloud clustering and tracking), the Digital Twin Entity provides data‑management and control mechanisms, and the User Entity supplies the 3D visualization and control‑panel interfaces. Coordination between entities is achieved through ROS 2 communication middleware and the 100 ms clock‑synchronisation layer, ensuring consistent execution across distributed hardware."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT components communicate internally via the ROS 2 middleware, forming a publish/subscribe network on the hosting compute platform. Communication between the physical twin and the digital twin occurs over a wireless Wi‑Fi network using UDP as the transport protocol. The architecture thus comprises a local ROS 2 mesh for intra‑DT component interaction and an external Wi‑Fi link for inter‑entity exchange. Specific bandwidth, latency, reliability, redundancy, or security mechanisms (e.g., encryption, QoS) are not detailed in the provided documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin services are implemented as software components that can be deployed on compute resources external to the vehicle, such as cloud or edge platforms, enabling off‑loading of the ACC algorithm from the resource‑constrained ECU. Data collected from the vehicle are stored on an external device or storage service separate from the on‑board hardware. The modular service composition (Data Translation, Data Monitoring, Computation Offloading, Remote Management) allows scaling by adding more compute nodes as needed, but the documents do not specify concrete hosting platforms, scalability mechanisms, or availability guarantees."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system complies with ISO 23247, the International Standards Organization’s Digital Twin framework for manufacturing. It adopts Part 2 (Reference Architecture), which prescribes an entity‑based architecture comprising an Observable Manufacturing Element (OME), a Data Collection and Device Control Entity, a Digital Twin Entity, and a User Entity. Each entity is further decomposed into Functional Entities that handle specific tasks such as actuation, data transformation, and user interfacing. While ISO 23247 does not dictate concrete implementation techniques, the document notes that standards‑based communication protocols such as OPC Unified Architecture (OPC UA) can be employed for data exchange and control."
]