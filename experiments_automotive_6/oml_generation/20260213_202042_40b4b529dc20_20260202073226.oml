// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Front‑mounted LiDAR sensor used for object detection raw point‑cloud data captured in real time."
    DTDFVocab:producedData LiDARRawPointCloudDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing vehicle state telemetry (speed, acceleration, yaw rate)."
    DTDFVocab:producedData VehicleStateDataTransmitted
]

instance SteeringSensor : DTDFVocab:SensingComponent [
    base:desc "Steering sensor providing steering angle and torque data."
    DTDFVocab:producedData SteeringDataTransmitted
]

instance MotorDataSensor : DTDFVocab:SensingComponent [
    base:desc "Motor controller sensor reporting motor speed and torque."
    DTDFVocab:producedData MotorDataTransmitted
]

instance UserUIInput : DTDFVocab:SensingComponent [
    base:desc "User interface component capturing remote management commands (ACC enable/disable, target speed, emergency brake)."
    DTDFVocab:producedData UserRemoteCommandTransmitted
]

// C4: Physical-to-virtual interaction
instance LiDARRawPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance SteeringDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringSensor
]

instance MotorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorDataSensor
]

instance UserRemoteCommandTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom UserUIInput
]

// C10: Models/Data
instance LiDARProcessedObjectTrackData : DTDFVocab:Data [
    base:desc "Clustered LiDAR point‑cloud processed into individual object tracks."
    DTDFVocab:fromData LiDARRawPointCloudDataTransmitted
]

instance LiDARProjectedDrivingPathData : DTDFVocab:Data [
    base:desc "Projected driving path computed from clustering results."
    DTDFVocab:fromData LiDARRawPointCloudDataTransmitted
]

instance VehicleStateProcessedData : DTDFVocab:Data [
    base:desc "Vehicle state data aligned to ISO23247 format."
    DTDFVocab:fromData VehicleStateDataTransmitted
]

instance SteeringProcessedData : DTDFVocab:Data [
    base:desc "Steering data aligned to ISO23247 format."
    DTDFVocab:fromData SteeringDataTransmitted
]

instance MotorProcessedData : DTDFVocab:Data [
    base:desc "Motor data aligned to ISO23247 format."
    DTDFVocab:fromData MotorDataTransmitted
]

instance UserRemoteCommandData : DTDFVocab:Data [
    base:desc "User‑issued remote command serialized for cloud processing."
    DTDFVocab:fromData UserRemoteCommandTransmitted
]

// C11: Enablers
instance PointCloudClusteringEnabler : DTDFVocab:Enabler [
    base:desc "Enables point‑cloud clustering and tracking of detected objects, producing object tracks and projected path."
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:hasInput LiDARProcessedObjectTrackData, LiDARProjectedDrivingPathData
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Serializes data, aligns message types according to ISO23247, performs unit conversion, and publishes via ROS2."
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:hasInput VehicleStateProcessedData, SteeringProcessedData, MotorProcessedData
]

instance AccComputationEnabler : DTDFVocab:Enabler [
    base:desc "Hosts Adaptive Cruise Control algorithm, receives sensor streams, calculates lead‑vehicle distance and desired speed, and pushes commands to on‑board ECU."
    DTDFVocab:enables ComputationOffloadingService
    DTDFVocab:hasInput LiDARProcessedObjectTrackData, VehicleStateProcessedData
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Receives user commands via UI, forwards commands to ACC system."
    DTDFVocab:enables RemoteManagementService
    DTDFVocab:hasInput UserRemoteCommandData
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Web‑based UI streams real‑time vehicle state data, projected trajectory, and nearby object tracks provides telemetry reports."
    DTDFVocab:provides TelemetryReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computes lead vehicle distance and desired speed in cloud/edge, pushes commands back to on‑board ECU."
    DTDFVocab:provides LeadVehicleDistanceInsight, DesiredSpeedCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set target speed, or issue emergency braking via UI ensures low end‑to‑end latency."
    DTDFVocab:provides EnableACCAction, SetTargetSpeedAction, EmergencyBrakeAction
]

// C17: Insights/Actions
instance TelemetryReportInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time telemetry reports generated by the Data Monitoring service."
]

instance LeadVehicleDistanceInsight : DTDFVocab:Insight [
    base:desc "Insight indicating calculated distance to lead vehicle, produced by the Computation Offloading service."
]

instance DesiredSpeedCommandAction : DTDFVocab:Action [
    base:desc "Automatic action creating the desired speed command derived from ACC algorithm."
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Manual action enabling Adaptive Cruise Control through Remote Management service."
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Manual action setting a target speed via Remote Management service."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Manual action triggering emergency braking via Remote Management service."
    DTDFVocab:IsAutomatic false
]

// C3: Additional components representing entities
instance UserEntity : DTDFVocab:Component [
    base:desc "User entity executing remote commands via web UI, hosted on edge compute nodes."
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital Twin entity executing computation offloading and data translation services, hosted on cloud/edge."
]

instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical Twin entity residing on vehicle hardware, providing sensors and actuators."
]

// C10: Environment grouping entities
instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains DigitalTwinEntity, PhysicalTwinEntity, UserEntity
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates on a 100 ms clock synchronization accuracy, mandated by safety‑critical vehicular standards, to support computation off‑loading among devices. A temporal granularity of 100 ms is the baseline for all digital‑physical interactions, ensuring that sensor data, control commands, and model updates are exchanged within this bound. Latency requirements are implicit in maintaining this 100 ms window, with any communication or processing delays exceeding this bound considered unacceptable for real‑time vehicle control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows ISO 23247 Reference Architecture, mapping SW functional entities (FEs) onto individual ROS 2 packages that encapsulate ROS 2 nodes implementing the entity behaviours. The User Entity contains the User Interface FE split into two sub‑components (3D Visualization and Control Panel). The Digital Twin Entity hosts data‑management and control FEs, while the Physical Twin Entity incorporates data pre‑processing, actuation, and device‑communication FEs such as Point Cloud Clustering & Tracking. The orchestration is decentralized across hardware nodes, with resource management handled by ROS 2’s node lifecycle and package deployment on each hardware platform. System‑wide coordination is achieved via ROS 2 topic buses, service calls, and action servers, ensuring synchronous updates between physical devices and virtual models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin System implements a dual‑layer communication architecture. Intra‑system component interactions are handled by a ROS 2 network that uses the Data Distribution Service (DDS) middleware, providing publish‑subscribe messaging over UDP with typical multicast or unicast configurations. Inter‑entity communication between the physical twin (sensors/actuators) and the digital twin occurs over a conventional Wi‑Fi network using UDP as the transport protocol. All transmitted messages are routed through the Data Translation component, which serializes payloads, normalizes message types, and executes unit conversions to guarantee consistency across the system. The documentation does not provide explicit bandwidth, latency, reliability, redundancy, or security specifications for this network infrastructure."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adheres to ISO 23247:2021 Digital Twin Framework for Manufacturing, implementing the reference architecture defined in Part 2. This architecture enumerates four primary entities: Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity, and User Entity, each composed of Functional Entities (FEs) that handle specific tasks such as device control, data transformation, and user interface provision. Industrial communication between the twin and the physical manufacturing elements is conducted via OPC Unified Architecture (OPC UA), ensuring secure, bidirectional data exchange compatible with IEC 61131‑3 PLC stacks. The open‑source reference implementation hosted on GitHub demonstrates these components in an automotive manufacturing context, and a public YouTube demonstration confirms runtime behaviour. By following ISO 23247, the twin satisfies interoperability, security, and data‑modelling requirements for digital twins in manufacturing environments."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A comprehensive security and safety framework is implemented in the Digital Twin system, based on the requirements of ISO 15622, 3GPP TS 22.185, ISO 26262‑1 and the model‑driven architecture proposed by Dalibor et al. For cyber‑security, the system adopts a PKI‑based authentication mechanism using X.509 certificates issued to every V2X node, and establishes secure communication channels with DTLS 1.2 over UDP. All exchange of control and status data is encrypted with AES‑128‑GCM and integrity‑protected by SHA‑256 based HMAC. Access control is enforced through role‑based permissions defined in the system‑model, and data flows are logged for auditability. For functional safety, ISO 26262‑1 mandates a full Safety Lifecycle, including Hazard Analysis and Risk Assessment, to assign ASIL levels; safety‑critical functions such as adaptive cruise control deactivate in an ASIL D compliant fail‑safe mode when fault detection signals from multiple sensors (radar, lidar, camera) indicate a conflict. Redundancy in the control loop and a watchdog timer ensure timely recovery, and the Digital Twin maintains a Safety Integrity Level SIL 3 for the brake‑intervention logic. The architecture of the twin, described in the model‑driven cockpit study, explicitly models safety constraints in SysML, and the twin’s self‑diagnostic components fulfill the verification and validation actions required by ISO 26262‑1. Together these measures guarantee that the Digital Twin meets both cybersecurity and functional‑safety requirements while providing a resilient and trustworthy operation."
]