instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR for point cloud data"
    DTDFVocab:producedData HokuyoRawLiDARTransmitted
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i Depth Camera for visual data"
    DTDFVocab:producedData IntelD435iDepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor measuring speed"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring steering angle"
    DTDFVocab:producedData SteeringAngleTransmitted
]

instance HokuyoRawLiDARTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance IntelD435iDepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance HokuyoRawLiDARData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data"
    DTDFVocab:fromData HokuyoRawLiDARTransmitted
    DTDFVocab:inputTo DBSCANProcessingEnabler
]

instance IntelD435iDepthImageData : DTDFVocab:Data [
    base:desc "Depth camera imagery data"
    DTDFVocab:fromData IntelD435iDepthImageTransmitted
    DTDFVocab:inputTo ObjectDetectionEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed measurement data"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo ACCControlEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle measurement data"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo ACCControlEnabler
]

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN-based point cloud clustering model for object detection"
    DTDFVocab:inputTo DBSCANProcessingEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter for object tracking"
    DTDFVocab:inputTo ObjectTrackingEnabler
]

instance ISO15622ACCLogicModel : DTDFVocab:Model [
    base:desc "ISO 15622-compliant adaptive cruise control logic"
    DTDFVocab:inputTo ACCControlEnabler
]

instance SQLVehicleDatabase : DTDFVocab:Data [
    base:desc "SQL database for storing vehicle state and object track data"
    DTDFVocab:fromData VehicleSpeedTransmitted, SteeringAngleTransmitted
    DTDFVocab:inputTo DataStorageEnabler
]

instance NVIDIAJetpack50SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for hardware acceleration of perception tasks"
    DTDFVocab:enables PointCloudClusteringService
]

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for inter-node communication"
    DTDFVocab:enables RealTimeDataMonitoringService, RemoteManagementService, ThreeDVisualizationService
]

instance Python38 : DTDFVocab:Enabler [
    base:desc "Python 3.8 for scripting and data processing"
    DTDFVocab:enables DataCollectionService, PointCloudClusteringService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ for high-performance processing components"
    DTDFVocab:enables ACCControlService, RealTimeDataMonitoringService
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for point cloud processing and simulation"
    DTDFVocab:enables PointCloudClusteringService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database for data storage"
    DTDFVocab:enables DataStorageService
]

instance RealTimeDataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time data monitoring service for viewing, saving, and generating reports"
    DTDFVocab:provides SystemPerformanceInsight, TroubleshootingInsight
]

instance ACCComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation offloading of ACC system to external Digital Twin Entity"
    DTDFVocab:provides ACCSystemPerformanceInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management service for enabling/disabling ACC, setting desired speed, emergency braking"
    DTDFVocab:provides EnableACCCmd, DisableACCCmd, SetDesiredSpeedCmd, EmergencyBrakingCmd
]

instance ThreeDVisualizationService : DTDFVocab:Service [
    base:desc "3D visualization of object tracks and projected driving path"
    DTDFVocab:provides ObjectTracksVisualizationInsight, DrivingPathVisualizationInsight
]

instance SystemPerformanceInsight : DTDFVocab:Insight [
    base:desc "Real-time system performance monitoring insights for operators"
]

instance TroubleshootingInsight : DTDFVocab:Insight [
    base:desc "Troubleshooting insights for developers during development"
]

instance ObjectTracksVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of object tracks for situational awareness"
]

instance DrivingPathVisualizationInsight : DTDFVocab:Insight [
    base:desc "Projected driving path visualization for navigation"
]

instance ACCSystemPerformanceInsight : DTDFVocab:Insight [
    base:desc "Performance metrics for adaptive cruise control system"
]

instance EnableACCCmd : DTDFVocab:Action [
    base:desc "Enable ACC system command"
    DTDFVocab:IsAutomatic false
]

instance DisableACCCmd : DTDFVocab:Action [
    base:desc "Disable ACC system command"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedCmd : DTDFVocab:Action [
    base:desc "Set desired speed command"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingCmd : DTDFVocab:Action [
    base:desc "Emergency braking command"
    DTDFVocab:IsAutomatic false
]

instance VedderESCActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller for motor voltage command generation"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo control actuator"
]

instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:contains DataCollectionFE, ACCControllingFE, PhysicalActuationFE
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains DataProcessingFE, VisualizationFE
]

instance UserEnvironment : DTDFVocab:Environment [
    base:contains UserInterfaceFE
]

instance DataCollectionFE : DTDFVocab:Component [
    base:desc "Data Collection Functional Entity for sensor data collection and preprocessing"
]

instance ACCControllingFE : DTDFVocab:Component [
    base:desc "ACC Control Functional Entity for adaptive cruise control logic"
]

instance PhysicalActuationFE : DTDFVocab:Component [
    base:desc "Actuation Functional Entity for motor and steering control"
]

instance DataProcessingFE : DTDFVocab:Component [
    base:desc "Data Processing Functional Entity for DBSCAN and Kalman filter processing"
]

instance VisualizationFE : DTDFVocab:Component [
    base:desc "Visualization Functional Entity for 3D rendering"
]

instance UserInterfaceFE : DTDFVocab:Component [
    base:desc "User Interface Functional Entity for operator interaction"
]

instance DBSCANClusteredData : DTDFVocab:Data [
    base:desc "DBSCAN clustered point cloud data"
    DTDFVocab:fromData HokuyoRawLiDARTransmitted
    DTDFVocab:inputTo ObjectTrackingEnabler
]

instance ObjectTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter based object tracking enabler"
    DTDFVocab:enables ObjectTrackingService
]

instance ObjectTrackingService : DTDFVocab:Service [
    base:desc "Object tracking service using Kalman filter"
    DTDFVocab:provides ObjectTracksVisualizationInsight
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object track data"
    DTDFVocab:fromData HokuyoRawLiDARTransmitted
    DTDFVocab:inputTo ThreeDVisualizationEnabler
]

instance ThreeDVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D visualization enabler for object tracks"
    DTDFVocab:enables ThreeDVisualizationService
]

instance DBSCANProcessingEnabler : DTDFVocab:Enabler [
    base:desc "DBSCAN processing enabler for point cloud clustering"
    DTDFVocab:enables PointCloudClusteringService
]

instance PointCloudClusteringService : DTDFVocab:Service [
    base:desc "Point cloud clustering service using DBSCAN"
    DTDFVocab:provides ObjectDetectionInsight
]

instance ObjectDetectionInsight : DTDFVocab:Insight [
    base:desc "Object detection insights from clustered point cloud data"
]

instance ObjectDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Object detection enabler for depth camera imagery"
    DTDFVocab:enables ObjectDetectionService
]

instance ObjectDetectionService : DTDFVocab:Service [
    base:desc "Object detection service for depth camera imagery"
]

instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "ACC control enabler"
    DTDFVocab:enables ACCControlService, RemoteManagementService
]

instance ACCControlService : DTDFVocab:Service [
    base:desc "Service for adaptive cruise control"
]

instance DataCollectionService : DTDFVocab:Service [
    base:desc "Service for collecting sensor data"
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Data storage enabler"
    DTDFVocab:enables DataStorageService
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Data storage service for vehicle state and object track data"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Transmission of ACC-computed desired speed and emergency braking commands from the Digital Twin Entity to the Physical Twin Entity, converted to motor voltage commands by the Actuation FE for vehicle speed control."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time operation with end-to-end latency ≤100 ms and clock synchronization accuracy of 100 ms, as specified by 3GPP TS 22.185 for V2V communication requirements."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated entities: Physical Twin Entity (ROS2 nodes for sensor processing/actuation), Digital Twin Entity (ACC control, data collection), User Entity (visualization/control), with Data Translation FE handling ROS2 intra-entity and Wi-Fi inter-entity communication."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational phase; used for real-time monitoring, computation offloading, and remote management of the ACC system during vehicle operation, with compliance validation during development."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "ACC implementation follows ISO 15622 performance class I specifications, but no explicit verification/validation mechanisms or uncertainty analysis are documented."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "ROS2 network for intra-entity communication; Wi-Fi for inter-entity communication with ≤100 ms latency and 100 ms clock sync accuracy."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity deployed on vehicle-mounted Jetson Orin Nano; Digital Twin Entity and Data Storage on external server/cloud; User Entity on client devices."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture for DT structure; ACC system implemented per ISO 15622 standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety-critical nature acknowledged, but no specific security protocols or safety mechanisms detailed in the document."
]