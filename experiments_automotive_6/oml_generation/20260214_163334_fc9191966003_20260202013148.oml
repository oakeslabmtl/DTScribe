// C3: Physical sensing components
instance HokuyoUst10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR providing 2‑D point‑cloud data for environment perception"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera streaming RGB‑D images"
    DTDFVocab:producedData DepthCameraImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring ego‑vehicle speed (wheel encoder or similar)"
    DTDFVocab:producedData SpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering position sensor measuring the current steering angle"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUst10LXLiDAR
]

instance DepthCameraImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C10: Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 2‑D point‑cloud generated by the Hokuyo LiDAR"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationFEEnabler, ModelExecutionRuntimeEnabler
]

instance DepthCameraImageData : DTDFVocab:Data [
    base:desc "RGB‑D image stream from the Intel DeepSense camera"
    DTDFVocab:fromData DepthCameraImageTransmitted
    DTDFVocab:inputTo DataTranslationFEEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego‑vehicle speed measurement in m/s"
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo DataTranslationFEEnabler, ModelExecutionRuntimeEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering angle in degrees"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo DataTranslationFEEnabler, ModelExecutionRuntimeEnabler
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Clustered and tracked object positions and velocities derived from LiDAR point clouds"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationFEEnabler, ModelExecutionRuntimeEnabler
]

instance DesiredSpeedData : DTDFVocab:Data [
    base:desc "Speed set‑point computed by the ACC control algorithm"
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo DataTranslationFEEnabler
]

// C10: Models/Data
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm for LiDAR point‑cloud segmentation"
    DTDFVocab:inputTo ModelExecutionRuntimeEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter for multi‑target object tracking"
    DTDFVocab:inputTo ModelExecutionRuntimeEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) algorithm compliant with ISO 15622 performance class I"
    DTDFVocab:inputTo ModelExecutionRuntimeEnabler
]

// C11: Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware handling inter‑process communication over DDS"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance DataTranslationFEEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation functional entity serialize ROS messages and performs unit conversion"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance ModelExecutionRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Runtime environment (ROS 2 nodes, Python/C++ executables) that runs perception and ACC models"
    DTDFVocab:enables ComputationOffloadingService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualises real‑time vehicle state, projected path, object tracks and generates time‑series reports"
    DTDFVocab:provides EgoVehicleSpeedInsight, SteeringAngleInsight, ObjectTracksInsight, ProjectedDrivingPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes the ACC algorithm in the Digital Twin and returns desired speed to the vehicle"
    DTDFVocab:provides DesiredSpeedInsight, UpdateDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI controls to enable/disable ACC, set speed, and trigger emergency braking stores data in SQL database"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetSpeedAction, EmergencyBrakingAction
]

// C17: Insights
instance EgoVehicleSpeedInsight : DTDFVocab:Insight [
    base:desc "Real‑time display of ego‑vehicle speed"
]

instance SteeringAngleInsight : DTDFVocab:Insight [
    base:desc "Real‑time display of current steering angle"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Visualization of surrounding object tracks (position & velocity)"
]

instance ProjectedDrivingPathInsight : DTDFVocab:Insight [
    base:desc "Projected driving path computed by the ACC module"
]

instance DesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Desired speed set‑point generated by the ACC algorithm"
]

// C17: Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetSpeedAction : DTDFVocab:Action [
    base:desc "Operator command to set a target speed for the vehicle"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Emergency braking command sent to the motor controller"
    DTDFVocab:IsAutomatic false
]

instance UpdateDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Automatic command sent to the Electronic Speed Controller to achieve the ACC desired speed"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance ElectronicSpeedControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller converting desired speed commands into motor voltage"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo receiving steering‑angle commands to control wheel direction"
]

instance EmergencyBrakingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator path that cuts power to the motor controller for emergency braking"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity sends computed ACC commands (desired speed) back to the vehicle, which are translated by the Actuation FE into motor voltage signals. Remote‑management commands—including enable/disable ACC, modify desired speed, and emergency‑brake signals—are also transmitted from the User Entity to the Physical Twin Entity."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is required to maintain an end‑to‑end network latency of ≤100 ms between the vehicle and the Digital Twin Entity, and clocks across all DTS components are synchronised to an accuracy of 100 ms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DTS follows the ISO 23247 entity‑based architecture: Physical Twin Entity (sensor acquisition, data pre‑processing, actuation), Digital Twin Entity (data collection, ACC control, reporting, presentation), User Entity (3D visualization, control panel UI), and a Cross‑System Data Translation FE. Communication within the vehicle uses ROS2 topics; inter‑entity communication uses a Wi‑Fi network."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during design‑time for simulation and validation, during testing/development for data collection and debugging, and during operation for real‑time monitoring, control off‑loading and remote management of the ACC subsystem."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity modelling is achieved through real‑time LiDAR point‑cloud processing, DBSCAN clustering, Kalman filtering, and an ACC algorithm validated against ISO 15622. Latency ≤100 ms and clock synchronisation to 100 ms provide temporal fidelity. The system is designed as a safety‑critical application, with human‑in‑the‑loop supervision."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Intra‑entity communication uses ROS2 (DDS) over the vehicle’s internal network; inter‑entity communication between the vehicle and the Digital Twin uses a Wi‑Fi link with a standardized communication interface (R1). OPC UA is mentioned as an optional protocol but not employed in the implementation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the on‑board NVIDIA Jetson Orin Nano; the Digital Twin Entity is hosted on external compute hardware (e.g., a workstation or cloud instance) reachable via Wi‑Fi; the User Entity UI runs on a desktop PC. Each functional entity is packaged as a ROS2 node within its respective deployment."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture adheres to ISO 23247 (Digital Twin Manufacturing Framework) for entity and functional entity definitions, uses ISO 15622 for ACC functional requirements, and builds on ROS2 as a standardized middleware. OPC UA is referenced as a possible data‑exchange standard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The system is developed for a safety‑critical ACC application with latency and clock‑sync constraints, and includes a human‑in‑the‑loop for remote management. No explicit cybersecurity mechanisms (e.g., authentication, encryption) are described in the document."
]