// C3: Physical sensing components
instance HokuyoLidarSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR sensor capturing planar point clouds for obstacle detection"
    DTDFVocab:producedData LidarPointCloudStream
]

instance IntelD435iDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera providing RGB‑D and depth images for environment mapping"
    DTDFVocab:producedData DepthImageStream
]

instance VehicleSpeedTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed telemetry sensor collecting ego‑vehicle speed from the embedded speed controller"
    DTDFVocab:producedData SpeedTelemetryStream
]

instance VehicleSteeringTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle steering telemetry sensor collecting steering angle from the steering servo controller"
    DTDFVocab:producedData SteeringTelemetryStream
]

// C4: Physical‑to‑virtual interaction
instance LidarPointCloudStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLidarSensor
]

instance DepthImageStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCameraSensor
]

instance SpeedTelemetryStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedTelemetrySensor
]

instance SteeringTelemetryStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSteeringTelemetrySensor
]

// C10: Models/Data
instance LidarPointCloudData : DTDFVocab:Data [
    base:desc "LiDAR point cloud data serialized and transmitted to the Digital Twin via ROS2 over Wi‑Fi"
    DTDFVocab:inputTo DataProcessingEnabler
    DTDFVocab:fromData LidarPointCloudStream
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image data from the Intel D435i, serialized and transmitted via ROS2"
    DTDFVocab:inputTo DataProcessingEnabler
    DTDFVocab:fromData DepthImageStream
]

instance SpeedTelemetryData : DTDFVocab:Data [
    base:desc "Vehicle speed telemetry data sent from the speed controller to the DT via ROS2"
    DTDFVocab:inputTo DataProcessingEnabler
    DTDFVocab:fromData SpeedTelemetryStream
]

instance SteeringTelemetryData : DTDFVocab:Data [
    base:desc "Vehicle steering angle telemetry data transmitted to the DT over ROS2"
    DTDFVocab:inputTo DataProcessingEnabler
    DTDFVocab:fromData SteeringTelemetryStream
]

instance DBSCANPointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN‑based point‑cloud clustering model for segmenting obstacle points"
    DTDFVocab:inputTo DataProcessingEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking model maintaining vehicle‑centric object tracks"
    DTDFVocab:inputTo DataProcessingEnabler
]

instance ACCControlISO15622Model : DTDFVocab:Model [
    base:desc "ACC control model following ISO 15622 to compute desired speed based on lead‑vehicle detection"
    DTDFVocab:inputTo DataProcessingEnabler
]

instance SQLDatabaseModel : DTDFVocab:Model [
    base:desc "SQL database model for persistent storage of telemetry, diagnostics, and user configurations"
    DTDFVocab:inputTo DataProcessingEnabler
]

instance ThreeDVisualizationModel : DTDFVocab:Model [
    base:desc "3‑D visualization model rendering tracked objects and vehicle state within a virtual cockpit"
    DTDFVocab:inputTo DataProcessingEnabler
]

// C11: Enablers
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler orchestrating ROS2 message processing, data translation, and service execution on the vehicle edge and cloud host"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, Visualization3DService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real‑time monitoring dashboards, vehicle telemetry, and time‑series reporting"
    DTDFVocab:provides RealTimeDashboardInsight, TimeSeriesReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Cloud‑based ACC decision logic executing lead‑vehicle identification and desired speed computation"
    DTDFVocab:provides LeadVehicleIdentificationInsight, DesiredSpeedPolicyInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service enabling remote configuration of ACC parameters, desired speed adjustment, and emergency braking commands"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakeAction
]

instance Visualization3DService : DTDFVocab:Service [
    base:desc "Service rendering a 3‑D virtual cockpit with vehicle state and tracked objects"
    DTDFVocab:provides VirtualCockpit3DInsight
]

// C17: Insights
instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring dashboard displaying speed, steering, surrounding object tracks, and projected path"
]

instance TimeSeriesReportInsight : DTDFVocab:Insight [
    base:desc "Time‑series report generator for troubleshooting diagnostics and performance analysis"
]

instance LeadVehicleIdentificationInsight : DTDFVocab:Insight [
    base:desc "Lead‑vehicle detection insight derived from LiDAR and depth data clustering"
]

instance DesiredSpeedPolicyInsight : DTDFVocab:Insight [
    base:desc "Desired speed computation insight based on ACC control model following ISO 15622"
]

instance VirtualCockpit3DInsight : DTDFVocab:Insight [
    base:desc "3‑D visualization of vehicle environment and tracked objects within a virtual cockpit interface"
]

// C17: Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable adaptive cruise control (ACC) on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Action to disable adaptive cruise control (ACC) on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to adjust the desired speed parameter of the ACC model"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to issue an emergency brake command to the vehicle"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance MotorVoltageCommandGeneratorActuator : DTDFVocab:ActingComponent [
    base:desc "Generates motor voltage commands for the vehicle's speed controller"
]

instance SteeringServoControlActuator : DTDFVocab:ActingComponent [
    base:desc "Controls steering servo motor to adjust vehicle heading"
]

instance EmergencyBrakeSignalDispatcherActuator : DTDFVocab:ActingComponent [
    base:desc "Dispatches emergency brake signal to the vehicle's braking system"
]

// Environment instance linking actuators
instance VehicleEdgeEnvironment : DTDFVocab:Environment [
    base:contains MotorVoltageCommandGeneratorActuator, SteeringServoControlActuator, EmergencyBrakeSignalDispatcherActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Issuance of desired‑speed control commands, steering‑angle updates, emergency‑brake activations, and remote‑management directives from the DT’s Digital Twin Entity to the vehicle’s actuators; commands are serialized by the Data Translation FE and sent over the Wi‑Fi network to the vehicle’s Data Collection and Control Entity."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates on a real‑time time scale with end‑to‑end latency capped at 100 ms as required by 3GPP TS 22.185; the system’s clocks are synchronized to an accuracy of 100 ms, and sensor streams and decision outputs are aligned to this 100 ms tick for coordinated processing."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "All functional entities are orchestrated via a ROS2 network: the Physical Twin Entity packages (clustering, tracking, actuation) run on the vehicle; the Digital Twin Entity packages (data collection, ACC control, reporting, data storage) run on a remote host; the User Entity (3D visualization and control panel) runs on an operator workstation; cross‑system data translation bridges ROS2 topics over Wi‑Fi, forming a cohesive digital‑twin constellation that processes real‑time data, executes control logic, and presents UI to users."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Requirements definition – R1 to R8 are captured as system requirements. Architecture design – ISO 23247 RA is mapped to entities and FEs (Sec. IV‑B). Implementation – SW components packaged as ROS 2 nodes and deployed to PT and DT. Deployment – the DT services are made available to operators and developers on an operator workstation. (Further validation and maintenance stages are implied but not explicitly described.)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity sensor data (raw LiDAR, depth images) are preserved through DBSCAN clustering and Kalman filtering, yielding accurate object tracks; ACC logic follows ISO 15622 specifications; real‑time execution meets 100 ms latency; data integrity ensured via clock synchronization to 100 ms and validation checks on message timestamps; report generation offers traceability and auditability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication occurs over a Wi‑Fi network using ROS 2 publish/subscribe messaging. The Data Translation FE handles serialization, type alignment, and unit conversion. End‑to‑end latency is constrained to ≤100 ms, meeting 3GPP requirements."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the NVIDIA Jetson Orin Nano embedded in the vehicle; the Digital Twin Entity is hosted on a remote server or cloud instance; the User Entity runs on an operator workstation; the Cross‑System entity spans the network links between the PT and DT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system follows ISO 23247 reference architecture, ISO 15622 ACC control specification, ROS2 (interoperable with DDS and IEEE 802.11 networking standards), and sensor standards for Hokuyo LiDAR and Intel D435i; the coding follows NVIDIA JetPack SDK conventions; firmware and data interfaces align with open‑source RoboRacer guidelines."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed through low‑latency (<100 ms) deterministic networking, deterministic ROS2 message handling, and adherence to ISO 15622 ACC safety specifications; the acceleration and braking controls are only applied after validation of sensor data and timestamp synchronization; remote command execution is mediated via the Data Translation FE to prevent injection of malformed signals; the design acknowledges the potential for human‑in‑the‑loop accidents and enforces human‑override capability via UI emergency brake."
]