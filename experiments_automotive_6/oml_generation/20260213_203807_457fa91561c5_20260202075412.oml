// C3: Physical sensing components
instance HokuyoUSTL10LXLidarSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR sensor providing 3‑D point cloud data for obstacle detection"
    DTDFVocab:producedData LiDARPointCloudStream
]

instance IntelD435iDepthCameraSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera generating depth image streams for scene reconstruction"
    DTDFVocab:producedData DepthImageStream
]

instance VehicleStateSignalSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Vehicle state telemetry sensor capturing speed and steering angle"
    DTDFVocab:producedData VehicleTelemetryStream
]

// C4: Physical‑to‑virtual interaction
instance LiDARPointCloudStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUSTL10LXLidarSensingComponent
]

instance DepthImageStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCameraSensingComponent
]

instance VehicleTelemetryStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSignalSensingComponent
]

// C10: Models/Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data stream from the Hokuyo UST‑10LX"
    DTDFVocab:fromData LiDARPointCloudStream
    DTDFVocab:inputTo DataCollectionEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Raw depth image data from Intel D435i camera"
    DTDFVocab:fromData DepthImageStream
    DTDFVocab:inputTo DataCollectionEnabler
]

instance VehicleTelemetryData : DTDFVocab:Data [
    base:desc "Raw vehicle telemetry data, including speed and steering angle"
    DTDFVocab:fromData VehicleTelemetryStream
    DTDFVocab:inputTo DataCollectionEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Processed object tracks derived from LiDAR clustering and Kalman tracking"
    DTDFVocab:fromData LiDARPointCloudStream
    DTDFVocab:inputTo DataCollectionEnabler
]

instance PathProjectionData : DTDFVocab:Data [
    base:desc "Projected vehicle path output from ACC controller"
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

instance SQLDatabaseReportData : DTDFVocab:Data [
    base:desc "Persisted time‑series reports stored in a SQL database"
    DTDFVocab:inputTo SQLDatabaseEnabler
]

instance DBSCANClusterModel : DTDFVocab:Model [
    base:desc "Clustering of LiDAR point clouds using DBSCAN algorithm"
    DTDFVocab:inputTo DataCollectionEnabler
]

instance KalmanFilterTrackModel : DTDFVocab:Model [
    base:desc "Tracking of objects using Kalman filter"
    DTDFVocab:inputTo DataCollectionEnabler
]

instance ACCControllerModel : DTDFVocab:Model [
    base:desc "ACC controller model conforming to ISO 15622"
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

// C11: Enablers
instance DataCollectionEnabler : DTDFVocab:Enabler [
    base:desc "Data ingestion and preprocessing FE handling ROS2 streams, performing DBSCAN clustering and Kalman tracking"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for offloading ACC logic to Digital Twin computational resources"
    DTDFVocab:enables ComputationOffloadingService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database enabler for persisting time‑series reports from the monitoring service"
    DTDFVocab:enables DataMonitoringService
]

instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler facilitating remote UI interactions for remote management actions"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time data monitoring service displaying vehicle state, object tracks, and supporting persistence to SQL database"
    DTDFVocab:provides VehicleStateInsight, ObjectTrackInsight, TimeSeriesReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computational offloading service executing ACC logic on Digital Twin, reducing on‑board ECU load"
    DTDFVocab:provides ACCPerformanceInsight, PathProjectionInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management service allowing operators to control ACC state, modify desired speed, and issue emergency braking"
    DTDFVocab:provides SetACCStateAction, ModifyDesiredSpeedAction, EmergencyBrakingAction
]

// C17: Insights/Actions
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current vehicle state derived from telemetry data"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Insight into object tracks detected via LiDAR clustering and Kalman filtering"
]

instance PathProjectionInsight : DTDFVocab:Insight [
    base:desc "Insight into projected vehicle path produced by ACC controller"
]

instance TimeSeriesReportInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing persisted time‑series reports in SQL database"
]

instance ACCPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight into ACC controller performance metrics"
]

instance SetACCStateAction : DTDFVocab:Action [
    base:desc "Action to enable or disable ACC state remotely"
    DTDFVocab:IsAutomatic false
]

instance ModifyDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to modify desired speed command for vehicle"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Action to trigger emergency braking remotely"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance MotorActuationActuator : DTDFVocab:ActingComponent [
    base:desc "Physical actuation component controlling motor voltage via Motor Actuation FE"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Physical actuation component controlling steering servo via Steering Servo Actuation FE"
]

instance VelocityCommandActuator : DTDFVocab:ActingComponent [
    base:desc "Digital Twin actuation component translating speed commands into motor voltage signals"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT’s Controlling FE computes ACC decisions (desired vehicle speed) and sends actuation commands back to the vehicle’s motor and steering servo through the Data Translation FE. Remote management commands issued via the UI (enable/disable ACC, set desired speed, trigger emergency braking) are likewise transmitted to the PT and applied to the actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All DT services operate in real‑time with an end‑to‑end latency requirement of ≤100 ms between the vehicle and the Digital Twin Entity. Clock synchronization across all hardware components is maintained to within 100 ms accuracy, ensuring consistent event ordering and data integrity during computation offloading."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system’s constellation consists of three entities mapped to the ISO 23247 RA: Physical Twin Entity hosting sensors and actuators; Digital Twin Entity encapsulating data collection, processing, and control FEs; and User Entity providing a 3‑D visualization and control panel UI. Communications flow via a ROS 2 network within the vehicle and a Wi‑Fi network for remote DT interaction."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The study follows a traditional engineering lifecycle: 1) Requirement Definition (R1‑R8); 2) Architecture Design based on ISO 23247 RA; 3) Implementation of software components as ROS 2 packages; 4) Validation during operation (real‑time monitoring, latency tests); and 5) Deployment for remote management. No explicit manufacturing‑phase modeling is included, as the twin is only instantiated during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "PT–DT communication occurs over a Wi‑Fi network; data serialization and unit alignment are performed by the Data Translation FE. Inside the vehicle, inter‑entity messages are exchanged over the ROS 2 publish/subscribe network. The DT accepts serialized messages compatible with ROS 2 messages and uses standard UDP/TCP transport as per ROS 2 DDS profile."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity and associated data‑processing services are deployed on a remote server (cloud or edge) capable of providing low‑latency response. The User Entity (UI) runs on a client workstation that interfaces with the DT via Wi‑Fi. The overall deployment is thus a hybrid edge‑to‑cloud model."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) for entity and FE mapping, ISO 15622 for the ACC controller definition, and ROS 2 as the middleware. Data translation adheres to standard serialization practices (e.g., OPC UA‑like), ensuring compliance with industrial communication standards."
]