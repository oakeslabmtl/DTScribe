// C3: Physical sensing components
instance HokuyoUST10LxSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR sensor providing 3D point cloud perception on the vehicle"
    DTDFVocab:producedData PointCloudTransmission
]

instance IntelDS435iDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering RGB-D images from the vehicle"
    DTDFVocab:producedData DepthFrameTransmission
]

instance SpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Speed sensor embedded in the electronic speed controller measuring vehicle velocity"
    DTDFVocab:producedData SpeedTransmission
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor capturing vehicle heading from the steering servo"
    DTDFVocab:producedData SteeringAngleTransmission
]

// C2: Acting components
instance ElectricMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Electric motor actuator that receives motor‑voltage commands to control vehicle speed"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator that receives steering‑angle commands to control vehicle heading"
]

// C4: Data transmitted
instance PointCloudTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LxSensor
]

instance DepthFrameTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDS435iDepthCameraSensor
]

instance SpeedTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SpeedSensor
]

instance SteeringAngleTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C10: Models / Data
instance PointCloudData : DTDFVocab:Data [
    base:desc "Point cloud data captured by the Hokuyo UST‑10LX LiDAR"
    DTDFVocab:fromData PointCloudTransmission
    DTDFVocab:inputTo ROS2MiddlewareEnabler, CloudComputeEnabler
]

instance DepthFrameData : DTDFVocab:Data [
    base:desc "Depth frame data captured by the Intel DeepSense D435i depth camera"
    DTDFVocab:fromData DepthFrameTransmission
    DTDFVocab:inputTo ROS2MiddlewareEnabler, CloudComputeEnabler
]

instance SpeedData : DTDFVocab:Data [
    base:desc "Speed data captured by the speed sensor"
    DTDFVocab:fromData SpeedTransmission
    DTDFVocab:inputTo ROS2MiddlewareEnabler, CloudComputeEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle data captured by the steering angle sensor"
    DTDFVocab:fromData SteeringAngleTransmission
    DTDFVocab:inputTo ROS2MiddlewareEnabler, CloudComputeEnabler
]

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN-based point‑cloud clustering module for detecting objects from LiDAR data"
    DTDFVocab:inputTo MATLABSimulinkEnabler, ROS2MiddlewareEnabler
]

instance KalmanFilterTrackerModel : DTDFVocab:Model [
    base:desc "Kalman filter tracker model to generate object tracks from clustered points"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance ACCControllerModel : DTDFVocab:Model [
    base:desc "ACC controller based on ISO 15622 P‑class I logic mapping distance to lead vehicle to desired speed"
    DTDFVocab:inputTo CppEnabler, ROS2MiddlewareEnabler
]

instance DataLoggingComponentModel : DTDFVocab:Model [
    base:desc "Component that logs vehicle state and object track time‑series data to an external SQL database"
    DTDFVocab:inputTo CloudComputeEnabler, ROS2MiddlewareEnabler
]

// C11: Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for message passing between virtual components over Wi‑Fi"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, VisualizationService, ReportGenerationService
]

instance Python3Enabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime used for implementing ROS2 nodes"
    DTDFVocab:enables DataMonitoringService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ compiler used for high‑performance ROS2 node implementations"
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for advanced point‑cloud clustering and tracking"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance NVIDIAJetpackEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for programming Jetson Orin Nano hardware"
    DTDFVocab:enables RemoteManagementService, ComputationOffloadingService
]

instance CloudComputeEnabler : DTDFVocab:Enabler [
    base:desc "Cloud‑based compute resources for ACC offloading and data logging"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, ReportGenerationService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors and provides real‑time display, storage, and reporting of vehicle state and object tracks"
    DTDFVocab:provides ACCDecisionInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service delegating the ACC decision loop to DT hardware for computation offloading"
    DTDFVocab:provides EmergencyBrakeAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service enabling remote enable/disable of ACC, manual desired speed setting, and issuing emergency‑brake commands"
    DTDFVocab:provides ToggleACCAction, SetDesiredSpeedAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that provides 3D rendering of the vehicle, environment, and projected paths"
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Service that exports time‑series SQL data for tracked data and generates reports"
    DTDFVocab:provides HistoricalPerformanceInsight
]

// C17: Insights and Actions
instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "Insight derived from real‑time vehicle state and object track analysis to inform ACC decisions"
]

instance HistoricalPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight derived from a historical SQL time‑series analysis of vehicle operation for performance evaluation"
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to set the desired speed of the vehicle for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to trigger an emergency brake command via the vehicle's braking system"
    DTDFVocab:IsAutomatic false
]

instance ToggleACCAction : DTDFVocab:Action [
    base:desc "Action to enable or disable the Adaptive Cruise Control system remotely"
    DTDFVocab:IsAutomatic false
]

// Environment
instance VehicleEnvironment : DTDFVocab:Environment [
    base:contains HokuyoUST10LxSensor, IntelDS435iDepthCameraSensor, SpeedSensor, SteeringAngleSensor, ElectricMotorActuator, SteeringServoActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT’s Control FE computes desired speeds and emergency‑braking commands and publishes them on ROS2 topics that are received by the Vehicle Actuation FE; the FE converts these commands into motor‑voltage and steering‑angle signals that are dispatched over the same Wi‑Fi link to the vehicle’s motor driver and steering servo for actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in near‑real‑time with end‑to‑end communication latency capped at 100 ms (R7) and all system clocks synchronized within 100 ms (R8), thereby enabling timely ACC computations and control actions that honor automotive safety‑critical timing constraints."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates the Physical Twin, Digital Twin, and User entities as functional entities (FEs) mapped to specific ROS2 packages, linked via ROS2 DDS topics over Wi‑Fi; an inter‑entity Data Translation FE serializes and converts units, while the User interface is split into 3D visualization and control‑panel FEs; all components collaborate to provide monitoring, control, and reporting services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin focuses on the Operated lifecycle stage: it monitors, controls, and reports on a running vehicle; the holistic digital thread (design → manufacturing → operation) is implied, but the current implementation primarily covers the Operated phase through real‑time data acquisition and control."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured through real‑time sensor fusion, DBSCAN clustering accuracy, Kalman‑filter state estimation, and compliance with ISO 15622 ACC control logic; validation of safety‑critical timings is performed by measuring end‑to‑end latency (≤ 100 ms) and ensuring clock synchronization within 100 ms as required by R7 and R8; however, explicit formal verification procedures are not detailed in the document."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The vehicle and DT components communicate over a Wi‑Fi network using ROS 2 transport. ROS 2 nodes publish and subscribe to topics across entities; the Data Translation FE serialises the payloads. Between entities, inter‑entity communication is performed via the Wi‑Fi network, while intra‑entity micro‑services communicate locally on the same compute node."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin runs on an edge or cloud platform (e.g., local server) that processes ACC decisions and hosts the ROS2 middleware; the vehicle hosts the Physical Twin Entity on an NVIDIA Jetson Orin Nano, while the user interface runs on a separate workstation; all components are containerized or packaged as ROS2 nodes and deployed via launch files on their respective hardware."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to ISO 23247 reference architecture (entity‑based, functional‑entity mapping), ISO 15622 P‑class I ACC control logic, and ROS2 DDS middleware; optional OPC UA considered for data translation but not implemented."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The system satisfies safety requirements by enforcing a maximum 100 ms latency and 100 ms clock synchronisation, providing human‑in‑the‑loop functionality, and performing real‑time status monitoring. No specific authentication or encryption mechanisms are detailed in the provided document, but the low‑latency, time‑synchronised operations are addressed as safety critical. The DT operates on a human‑controlled vehicle, ensuring that remote commands are moderated through safe‐state transitions and emergency braking controls."
]