// C2: Acting Components
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Converts desired speed into motor voltage commands sent via ROS2 topics to the Jetson Orin Nano."
]
instance SteeringActuator : DTDFVocab:ActingComponent [
    base:desc "Sends steering torque commands to the steering servo via ROS2 topics."
]
instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Issues emergency brake command via ROS2 topics."
]

// C3: Physical sensing components
instance HokuyoUST10LXSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST10LX LiDAR that streams raw point clouds."
    DTDFVocab:producedData LiDARPointCloudTopic
]
instance IntelDS435iDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera providing depth images."
    DTDFVocab:producedData DepthImageTopic
]
instance VedderSpeedControllerSensor : DTDFVocab:SensingComponent [
    base:desc "Vedder electronic speed controller that outputs wheel speed."
    DTDFVocab:producedData WheelSpeedTopic
]
instance SteeringEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Steering encoder measuring steering angle."
    DTDFVocab:producedData SteeringAngleTopic
]

// C4: Physical-to-virtual interaction
instance LiDARPointCloudTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXSensor
]
instance DepthImageTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDS435iDepthCameraSensor
]
instance WheelSpeedTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VedderSpeedControllerSensor
]
instance SteeringAngleTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringEncoderSensor
]
instance VehicleStateTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VedderSpeedControllerSensor, SteeringEncoderSensor
]
instance ObjectTrackTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXSensor, IntelDS435iDepthCameraSensor
]
instance ReportGenerationTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DataCollectionEnabler
]

// C10: Models/Data
instance ACCControllerModel : DTDFVocab:Model [
    base:desc "Accelerated Cruise Control (ACC) controller implementing ISO 15622 Class I logic."
    DTDFVocab:inputTo AccComputationEnabler
]
instance DBSCANModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering algorithm used in clustering FE."
    DTDFVocab:inputTo PointCloudClusteringEnabler
]
instance KalmanFilterModel : DTDFVocab:Model [
    base:desc "Kalman filter for object tracking in Point‑Cloud Clustering & Tracking FE."
    DTDFVocab:inputTo PointCloudClusteringEnabler
]
instance SQLDatabaseModel : DTDFVocab:Model [
    base:desc "SQL database storing tracked objects and vehicle state for future predictive maintenance."
    DTDFVocab:inputTo DataCollectionEnabler
]

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data received from LiDARPointCloudTopic."
    DTDFVocab:fromData LiDARPointCloudTopic
    DTDFVocab:inputTo PointCloudClusteringEnabler
]
instance DepthImageData : DTDFVocab:Data [
    base:desc "Raw depth image data received from DepthImageTopic."
    DTDFVocab:fromData DepthImageTopic
    DTDFVocab:inputTo PointCloudClusteringEnabler
]
instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state data (speed and steering) received from VehicleStateTopic."
    DTDFVocab:fromData VehicleStateTopic
    DTDFVocab:inputTo DataCollectionEnabler
]
instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Object track data produced by clustering and tracking FE."
    DTDFVocab:fromData ObjectTrackTopic
    DTDFVocab:inputTo DataCollectionEnabler
]
instance ReportData : DTDFVocab:Data [
    base:desc "Generated report data containing time‑series analytics."
    DTDFVocab:fromData ReportGenerationTopic
    DTDFVocab:inputTo ReportGenerationEnabler
]

// C11: Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Serialises and unit‑converts incoming ROS2 messages for downstream processing."
    DTDFVocab:enables DataCollectionEnabler
]
instance PointCloudClusteringEnabler : DTDFVocab:Enabler [
    base:desc "Processes raw point clouds with DBSCAN and Kalman filter to produce object tracks."
    DTDFVocab:enables DataCollectionEnabler
]
instance DataCollectionEnabler : DTDFVocab:Enabler [
    base:desc "Collects and forwards data to monitoring, reporting, and visualization subsystems."
    DTDFVocab:enables DataMonitoringService, ReportGenerationService, VisualizationService
]
instance AccComputationEnabler : DTDFVocab:Enabler [
    base:desc "Executes ACC controller logic in the DT and forwards results to the vehicle."
    DTDFVocab:enables ComputationOffloadingService
]
instance ReportGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Generates time‑series reports from collected data."
    DTDFVocab:enables ReportGenerationService
]
instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Provides 3D visualization of vehicle and surrounding tracks."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time display, saving, and reporting of vehicle state and object tracks."
    DTDFVocab:provides TimeseriesAnalyticsInsight, AnomalyDetectionInsight
]
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC logic in the DT and transmits results to the vehicle."
]
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows enable/disable of ACC, set desired speed, and issue emergency brake."
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "3D visualization of the vehicle and surrounding tracks."
    DTDFVocab:provides ADASPerformanceInsight
]
instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Creates time‑series reports of object tracks and vehicle state."
    DTDFVocab:provides PredictiveMaintenanceInsight
]

// C17: Insights/Actions
instance TimeseriesAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Time‑series analytics of object tracks and vehicle state."
]
instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection in vehicle state and object tracks."
]
instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Insights for predictive maintenance derived from SQL database."
]
instance ADASPerformanceInsight : DTDFVocab:Insight [
    base:desc "ADAS performance analysis derived from visualization data."
]
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables or disables the Adaptive Cruise Control function."
    DTDFVocab:IsAutomatic false
]
instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets the desired speed for Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]
instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Triggers emergency braking."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends desired speed, ACC enable/disable flags, emergency braking commands, and steering corrections back to the PT through ROS 2 services/topics; these are consumed by the Actuation FE on the Jetson Orin Nano, which drives the motor voltage and steering servo actuators, and triggers the braking subsystem."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time vehicle state is sampled at the perception cycle (typical 30–60 Hz); end‑to‑end communication latency from vehicle to DT must not exceed 100 ms, and all clocks are synchronised to within 100 ms (as specified in R7 and R8)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation follows the ISO 23247 entity architecture: Observable Manufacturing Element analogue (Physical Twin), Digital Twin Entity, User Entity, each consisting of a set of Functional Entities (Data Translation, Data Collection, Presentation, Reporting, Controlling, Actuation). Communication flows over ROS 2 topics/services within the DT and over Wi‑Fi between PT and DT, with Data Translation serving as the cross‑system glue."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT operates in the ‘Operated’ phase of the vehicle lifecycle, providing real‑time monitoring and remote control after manufacturing; it also supports design validation via simulation during development, but the case study focuses on operational use."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is achieved through high‑fidelity sensor data processing (DBSCAN, Kalman filter), real‑time latency constraints (≤100 ms), clock synchronisation (≤100 ms accuracy), and compliance with ISO 15622 control logic. Validation involves comparing real‑time vehicle state against DT reports, ensuring that AC commands produced by the DT match expected behavior under varying lead vehicle distances."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication uses ROS 2 DDS over Wi‑Fi; within the DT, ROS 2 nodes communicate via DDS topics; between PT and DT, data is transmitted over UDP/TCP (ROS 2 transport) over a Wi‑Fi network, with a dedicated Data Translation FE handling serialization."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The PT runs the Physical Twin Entity on an NVIDIA Jetson Orin Nano; the Digital Twin Entity and User Entity are hosted on a local workstation or cloud edge node (not explicitly specified) and are packaged as ROS 2 containers or executables. The system is orchestrated via ROS 2 launch files that spin up each entity on its respective hardware."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 Part 2 (Reference Architecture) is the primary guideline; ISO 15622 defines ACC control logic; ROS 2 follows DDS communication standard; OPC UA mentioned but not used. All software follows open‑source licensing under the project repository."
]