    base:desc "Adaptive cruise control maintaining safe following distance using projected driving paths."
    DTDFVocab:IsAutomatic true
]

instance CollisionFreeTrajectoryAction : DTDFVocab:Action [
    base:desc "Optimal trajectory adjustment to avoid collisions in aerospace applications."
    DTDFVocab:IsAutomatic true
]

