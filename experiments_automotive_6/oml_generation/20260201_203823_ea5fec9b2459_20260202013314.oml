// -----------------------------------------------------------------------------
// C3: Physical sensing components
// -----------------------------------------------------------------------------
instance HokuyoLiDARUST110LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-110LX 2‑D LiDAR mounted on the vehicle, provides raw point clouds",
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D frames",
    DTDFVocab:producedData DepthCameraFrameTransmitted
]

instance EgoVehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor reporting ego vehicle longitudinal speed",
    DTDFVocab:producedData EgoSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the current steering wheel angle",
    DTDFVocab:producedData SteeringAngleTransmitted
]

// -----------------------------------------------------------------------------
// C2: Acting components
// -----------------------------------------------------------------------------
instance MotorSpeedActuator : DTDFVocab:ActingComponent [
    base:desc "Motor driven by a Vedder electronic speed controller for longitudinal speed control"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Servo responsible for lateral steering of the 1/10‑scale vehicle"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Command interface that receives emergency‑brake signals and cuts power to the motor"
]

// -----------------------------------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// -----------------------------------------------------------------------------
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARUST110LX
]

instance DepthCameraFrameTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
]

instance EgoSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoVehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// -----------------------------------------------------------------------------
// C10: Raw data instances
// -----------------------------------------------------------------------------
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 3‑D point cloud generated by the Hokuyo LiDAR",
    DTDFVocab:fromData LiDARPointCloudTransmitted,
    DTDFVocab:inputTo DataCollectionFE
]

instance DepthCameraFrameData : DTDFVocab:Data [
    base:desc "RGB‑D frame streamed from the Intel RealSense depth camera",
    DTDFVocab:fromData DepthCameraFrameTransmitted,
    DTDFVocab:inputTo DataCollectionFE
]

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Current longitudinal speed of the ego vehicle",
    DTDFVocab:fromData EgoSpeedTransmitted,
    DTDFVocab:inputTo DataCollectionFE
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering angle of the ego vehicle",
    DTDFVocab:fromData SteeringAngleTransmitted,
    DTDFVocab:inputTo DataCollectionFE
]

// -----------------------------------------------------------------------------
// C10: Models
// -----------------------------------------------------------------------------
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering applied to raw LiDAR point clouds for object segmentation",
    DTDFVocab:inputTo DataPreProcessingFE
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based multi‑object tracking model generating object tracks",
    DTDFVocab:inputTo DataPreProcessingFE
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) controller compliant with ISO‑15622 performance class I",
    DTDFVocab:inputTo ControllingFE
]

// -----------------------------------------------------------------------------
// C11: Enablers (Functional Entities)
// -----------------------------------------------------------------------------
instance DataCollectionFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that ingests raw sensor streams via ROS 2, performs initial synchronization and stores them in the SQL database",
    DTDFVocab:enables ComputationOffloadingService,
    DTDFVocab:enables DataMonitoringService
]

instance DataPreProcessingFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that executes DBSCAN clustering and Kalman filtering to produce object tracks",
    DTDFVocab:enables ComputationOffloadingService
]

instance ControllingFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that runs the ACC control model to compute desired speed set‑points",
    DTDFVocab:enables ComputationOffloadingService
]

instance ReportingFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that aggregates vehicle state, object tracks and predicted paths for UI visualisation",
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Cross‑system Data Translation Entity converting ROS 2 messages to the DT internal schema",
    DTDFVocab:enables RemoteManagementService
]

// -----------------------------------------------------------------------------
// C6: Services
// -----------------------------------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI service visualising real‑time vehicle state, projected path and object tracks and generating reports",
    DTDFVocab:provides RealTimeVehicleSpeedInsight,
    DTDFVocab:provides SteeringAngleInsight,
    DTDFVocab:provides ObjectTrackVisualizationInsight,
    DTDFVocab:provides PredictedDrivingPathInsight,
    DTDFVocab:provides DesiredSpeedInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes perception (point‑cloud clustering, tracking) and ACC algorithms on the Digital Twin host",
    DTDFVocab:provides DesiredSpeedInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, adjust speed set‑point and trigger emergency braking",
    DTDFVocab:provides EnableACCAction,
    DTDFVocab:provides DisableACCAction,
    DTDFVocab:provides AdjustSpeedAction,
    DTDFVocab:provides EmergencyBrakeAction
]

// -----------------------------------------------------------------------------
// C17: Insights
// -----------------------------------------------------------------------------
instance RealTimeVehicleSpeedInsight : DTDFVocab:Insight [
    base:desc "Current vehicle speed as computed from ego speed sensor data"
]

instance SteeringAngleInsight : DTDFVocab:Insight [
    base:desc "Current steering wheel angle derived from steering angle sensor"
]

instance ObjectTrackVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualisation of detected and tracked objects generated by DBSCAN‑Kalman pipeline"
]

instance PredictedDrivingPathInsight : DTDFVocab:Insight [
    base:desc "Future vehicle trajectory predicted by the ACC controller"
]

instance DesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Speed set‑point output by the ACC control model"
]

// -----------------------------------------------------------------------------
// C17: Actions
// -----------------------------------------------------------------------------
instance EnableACCAction : DTDFVocab:Action [
    base:desc "User‑initiated command to enable Adaptive Cruise Control",
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "User‑initiated command to disable Adaptive Cruise Control",
    DTDFVocab:IsAutomatic false
]

instance AdjustSpeedAction : DTDFVocab:Action [
    base:desc "User‑initiated adjustment of the desired speed set‑point",
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediate emergency braking command sent to the MotorSpeedActuator",
    DTDFVocab:IsAutomatic true
]

// -----------------------------------------------------------------------------
// C1: Entity composition (multiplicity)
// -----------------------------------------------------------------------------
instance PhysicalTwinEntity : DTDFVocab:Environment [
    base:desc "Physical Twin Entity hosting sensors and actuators on the 1/10‑scale vehicle",
    base:contains HokuyoLiDARUST110LX,
    base:contains IntelRealSenseD435iDepthCamera,
    base:contains EgoVehicleSpeedSensor,
    base:contains SteeringAngleSensor,
    base:contains MotorSpeedActuator,
    base:contains SteeringServoActuator,
    base:contains EmergencyBrakeActuator
]

instance DigitalTwinEntity : DTDFVocab:Environment [
    base:desc "Digital Twin Entity running on NVIDIA Jetson hardware, hosting Functional Entities and services",
    base:contains DataCollectionFE,
    base:contains DataPreProcessingFE,
    base:contains ControllingFE,
    base:contains ReportingFE,
    base:contains DataTranslationFE,
    base:contains DataMonitoringService,
    base:contains ComputationOffloadingService,
    base:contains RemoteManagementService,
    base:contains DBSCANClusteringModel,
    base:contains KalmanFilterTrackingModel,
    base:contains ACCControlModel,
    base:contains LiDARPointCloudData,
    base:contains DepthCameraFrameData,
    base:contains EgoSpeedData,
    base:contains SteeringAngleData
]

instance UserEntity : DTDFVocab:Environment [
    base:desc "User workstation providing UI and remote management capabilities",
    base:contains DataMonitoringService,
    base:contains RemoteManagementService
]

instance CrossSystemDataTranslationEntity : DTDFVocab:Environment [
    base:desc "Cross‑system entity responsible for ROS 2 to DT data translation",
    base:contains DataTranslationFE
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity runs the ACC control algorithm (Controlling FE) and the Remote Management UI, generating desired speed set‑points, enable/disable ACC commands, speed‑set commands and emergency‑brake signals that are transmitted back to the physical twin over the same Wi‑Fi/ROS 2 channel and executed by the Actuation FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is required to maintain a maximum end‑to‑end network latency of 100 ms (R7) and clock synchronization accuracy of 100 ms across all DTS components (R8), enabling real‑time data collection and control at the perception‑cycle rate used for object tracking."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin System (DTS) orchestrates the Physical Twin Entity (sensors, actuators, point‑cloud processing), the Digital Twin Entity (data collection, ACC, reporting, visualization), the User Entity (3D visualization and control panel UI), and a Cross‑System Data Translation entity; intra‑entity communication uses ROS 2 topics, inter‑entity communication uses Wi‑Fi with serialized messages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity perception is achieved through DBSCAN clustering and Kalman filtering of raw LiDAR data; the ACC algorithm complies with ISO 15622 performance class I; system safety is addressed by enforcing a ≤100 ms latency budget and 100 ms clock sync, providing deterministic timing for control actions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑digital communication occurs over a Wi‑Fi network using ROS 2 messages; data is serialized and unit‑converted by the Data Translation FE; the same Wi‑Fi link carries control commands from the DT back to the vehicle."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT components (Digital Twin Entity and User Entity) are deployed on external compute resources—potentially cloud‑based servers—separate from the vehicle‑mounted Jetson Orin Nano that hosts the Physical Twin Entity."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows the ISO 23247 reference architecture (Part 2), uses the ACC functional requirements from ISO 15622, and references ISO/IEC 30173 for terminology; optional OPC UA (IEC 62541) is mentioned as a possible data‑translation mechanism."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations include the 100 ms latency requirement, clock synchronization, and inclusion of an emergency‑brake command; the DT is classified as a Fully Autonomous Digital Twin with Human‑in‑the‑Loop per the liberty‑to‑act taxonomy, but explicit cybersecurity mechanisms are not described."
]