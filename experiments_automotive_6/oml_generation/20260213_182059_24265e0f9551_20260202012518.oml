// ======================
// Physical Sensing Components
// ======================

instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor mounted on lower and upper chassis providing point‑cloud data for object detection and projected driving path."
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor suite measuring vehicle state (position, velocity, orientation) on the 1/10‑scale autonomous vehicle."
    DTDFVocab:producedData VehicleStateTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting motor status (rpm, torque) of the physical vehicle."
    DTDFVocab:producedData MotorStatusTransmitted
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor providing steering servo position feedback."
    DTDFVocab:producedData SteeringServoTransmitted
]

// ======================
// Data Transmitted from Sensors
// ======================

instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance MotorStatusTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance SteeringServoTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
]

// ======================
// Data Instances
// ======================

instance PointCloudData : DTDFVocab:Data [
    base:desc "Raw point‑cloud data generated by LiDAR sensor, used for clustering & tracking and UI monitoring."
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state data (position, velocity) needed for ACC computation and UI display."
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, ACCComputationEnabler
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Motor status information (rpm, torque) collected for diagnostics."
    DTDFVocab:fromData MotorStatusTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance SteeringServoData : DTDFVocab:Data [
    base:desc "Steering servo position feedback for vehicle control monitoring."
    DTDFVocab:fromData SteeringServoTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

// ======================
// Models
// ======================

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "Behavioral ACC model that processes sensor inputs (lead‑vehicle detection, desired‑speed computation) executed in the Digital Twin after off‑loading."
    DTDFVocab:inputTo ACCComputationEnabler
]

instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Point‑cloud clustering and tracking module used for object detection and projected driving path."
    DTDFVocab:inputTo DataTranslationEnabler
]

// ======================
// Enablers
// ======================

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247 Data Translation functional element that serialises messages, aligns types, and performs unit conversion."
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that runs the off‑loaded ACC computation in the cloud and returns the desired speed to the vehicle."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteCommandEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that transmits operator commands (enable/disable ACC, set speed, emergency brake) to vehicle actuators over a low‑latency end‑to‑end link."
    DTDFVocab:enables RemoteManagementService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Component that stores collected sensor data and makes it available for UI logging and report generation."
    DTDFVocab:enables DataMonitoringService
]

// ======================
// Services
// ======================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring service UI displays real‑time vehicle state, projected path, and object tracks; supports saving and report generation."
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTrackInsight, ProjectedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation Offloading service executes ACC algorithm in the digital twin and sends the desired speed back to the vehicle."
    DTDFVocab:provides DesiredSpeedComputationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service allows operators to enable/disable ACC, set desired speed, and issue emergency braking via UI."
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakingAction
]

// ======================
// Insights
// ======================

instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current vehicle state (position, velocity) for operators."
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Insight into detected object tracks derived from point‑cloud clustering."
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Insight into projected driving path displayed on the UI."
]

// ======================
// Actions
// ======================

instance DesiredSpeedComputationAction : DTDFVocab:Action [
    base:desc "Action that computes desired speed based on lead‑vehicle detection."
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable Adaptive Cruise Control remotely."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Action to disable Adaptive Cruise Control remotely."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to set a new desired speed for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Action to trigger emergency braking on the vehicle."
    DTDFVocab:IsAutomatic false
]

// ======================
// Physical Acting Components
// ======================

instance ThrottleActuator : DTDFVocab:ActingComponent [
    base:desc "Physical vehicle throttle actuator receiving desired speed command from the digital twin."
]

instance BrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Physical vehicle brake actuator receiving emergency braking command from the digital twin."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate in the User Entity’s Control Panel (part of the User Interface FE) and are sent to the Physical Twin Entity over the same Wi‑Fi/UDP link used for sensor data. Commands include *enable/disable ACC*, *set desired speed*, *emergency braking*, and the *desired speed* value computed by the off‑loaded ACC service. Each command is encapsulated as a ROS2 message, passed through the Data Translation FE for format validation and unit conversion, and then delivered to the *Actuation FE* which drives the motor and steering servo actuators. Feedback is provided by the vehicle’s state sensors, which are streamed back to the DTS, allowing the UI to confirm command execution. Although explicit authentication mechanisms are not described, the architecture relies on the Data Translation FE to validate message structure before actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires a shared notion of time across device components to enable computation offloading, with a clock synchronization accuracy of 100 ms as mandated by safety‑critical vehicular constraints; this synchronization supports the low‑latency data exchange needed for the ACC offloading and remote management services."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration follows the ISO 23247 reference architecture with an entity‑based pattern; inter‑entity communication and coordination are realized through ROS 2 middleware (packages and nodes) and a network link that provides low end‑to‑end latency between the vehicle (physical twin) and the remote DT where ACC computation is offloaded; the DT Entity aggregates data, performs processing, and returns control commands to the Physical Twin Entity, while the User Entity provides UI interaction."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS uses a hybrid network architecture: intra‑entity communication between ROS2 components runs on a ROS2 middleware bus, while inter‑entity communication (between Physical Twin Entity, Digital Twin Entity and User Entity) is carried out over a Wi‑Fi network using UDP at the transport layer. The system requires a maximum end‑to‑end latency that supports real‑time control and monitoring; a synchronization accuracy of 100 ms is mandated for safety‑critical coordination. No explicit bandwidth figures are given, but the use of UDP implies a design for low‑latency, best‑effort delivery. Reliability and redundancy mechanisms, as well as security protocols (e.g., TLS, authentication), are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The ACC functionality is off‑loaded from the on‑board ECU to a remote computing platform referred to as the cloud; this constitutes the primary hosting environment for the Digital Twin. The cloud host runs ROS2 packages that implement the ACC service, Data Translation, Data Storage and UI services. Computational requirements include sufficient processing power to perform lead‑vehicle detection, speed‑setpoint calculation and real‑time data aggregation, while storage must accommodate collected vehicle‑state logs and generated reports. The architecture supports scaling by deploying additional ROS2 nodes on the cloud as needed, but explicit scaling mechanisms are not described. Deployment models are limited to cloud‑based execution for the off‑loaded ACC service; edge or on‑premise deployment is not mentioned. Availability is addressed only implicitly via the requirement for low latency and continuous data streaming."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is contemplated through standard data‑exchange mechanisms such as OPC Unified Architecture, as suggested by the ISO 23247 specification, and via ROS 2 message transport; the UI communicates with the DT over the same low‑latency network, enabling remote monitoring and management, though specific external enterprise system bindings are not detailed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system is built around ISO 23247 (Digital Twin Framework for Manufacturing), specifically leveraging Part 2 (Reference Architecture) to structure entities and functional entities. The architecture is deliberately independent of specific data formats or communication protocols, allowing integration of domain‑specific technologies such as ROS 2. To address safety‑critical automotive requirements, the authors recommend complementing ISO 23247 with ISO 26262 (road vehicles – functional safety) and aligning the deployment model with AUTOSAR, the de‑facto automotive software architecture standard, which provides hardware‑agnostic component definition and supports retro‑fitting existing automotive platforms."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The automotive digital‑twin case study notes that the ISO 23247 reference architecture does not address safety‑critical requirements; therefore the authors recommend elevating safety to a first‑class concern by incorporating the functional‑safety standard ISO 26262 (Road vehicles – functional safety). This integration implies applying ISO 26262 safety‑lifecycle activities—hazard analysis, risk assessment, allocation of safety goals, and implementation of fail‑safe mechanisms—within the DT, for example for the Data Pre‑Processing and Actuation functional entities deployed on the physical twin."
]