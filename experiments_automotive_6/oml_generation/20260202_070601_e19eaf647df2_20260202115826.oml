    DTDFVocab:inputTo SensorFusionEnabler
]

// C11: Enablers
instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Handles raw sensor data alignment, noise reduction, and feature extraction for LiDAR point clouds."
    DTDFVocab:enables LiDARMonitoringService, ObjectTrackingService
]

instance VehicleMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Aggregates and processes vehicle state data for real-time monitoring and diagnostics."
    DTDFVocab:enables VehicleHealthMonitoringService, DriverBehaviorAnalyticsService
]

instance MotorDiagnosticsEnabler : DTDFVocab:Enabler [
    base:desc "Analyzes motor actuation data to detect anomalies and predict performance degradation."
    DTDFVocab:enables PredictiveMaintenanceService
]

instance SteeringControlEnabler : DTDFVocab:Enabler [
    base:desc "Optimizes steering servo control algorithms for adaptive driving scenarios."
    DTDFVocab:enables AdaptiveSteeringControlService
]

instance ObjectDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Tracks and clusters objects from LiDAR data for situational awareness and collision avoidance."
    DTDFVocab:enables CollisionAvoidanceService, ObjectTrackingService
]

instance ACCOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimizes projected driving paths for Adaptive Cruise Control systems using real-time data."
    DTDFVocab:enables AdaptiveCruiseControlService
]

instance SensorFusionEnabler : DTDFVocab:Enabler [
    base:desc "Fuses multiple sensor inputs (LiDAR, cameras) for comprehensive environmental perception."
    DTDFVocab:enables EnvironmentalPerceptionService
]

instance ROS2CommunicationEnabler : DTDFVocab:Enabler [
    base:desc "Facilitates intra-software component communication using ROS2 protocol for real-time data exchange."
    DTDFVocab:enables DataIntegrationService, RealTimeControlService
]

instance WiFiUDPCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "Enables inter-entity communication between Physical Twin Entity and Digital Twin Entity using Wi-Fi UDP."
    DTDFVocab:enables DataIntegrationService
]

