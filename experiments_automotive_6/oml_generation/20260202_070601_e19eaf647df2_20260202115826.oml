instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Converts raw LiDAR point cloud data into meaningful 3D objects and clusters for tracking."
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance VehicleStateModel : DTDFVocab:Model [
    base:desc "Processes vehicle state data (speed, position, orientation) for real-time monitoring and control."
    DTDFVocab:inputTo VehicleMonitoringEnabler
]

instance MotorPerformanceModel : DTDFVocab:Model [
    base:desc "Analyzes motor actuation data (RPM, torque) to predict performance and detect anomalies."
    DTDFVocab:inputTo MotorDiagnosticsEnabler
]

instance SteeringControlModel : DTDFVocab:Model [
    base:desc "Processes steering servo data to optimize control algorithms for adaptive driving."
    DTDFVocab:inputTo SteeringControlEnabler
]

instance ObjectTrackingModel : DTDFVocab:Model [
    base:desc "Tracks and clusters objects derived from LiDAR data for situational awareness."
    DTDFVocab:inputTo ObjectDetectionEnabler
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "Generates and optimizes projected driving paths for Adaptive Cruise Control systems."
    DTDFVocab:inputTo ACCOptimizationEnabler
]

instance SensorFusionModel : DTDFVocab:Model [
    base:desc "Fuses multiple sensor inputs (LiDAR, cameras) for comprehensive environmental perception."
    DTDFVocab:inputTo SensorFusionEnabler
]

instance RawLiDARData : DTDFVocab:Data [
    base:desc "Unprocessed LiDAR point cloud data collected from the environment."
    DTDFVocab:fromData LiDARPointCloudData
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance ProcessedVehicleStateData : DTDFVocab:Data [
    base:desc "Structured vehicle state data (speed, position, orientation) after preprocessing."
    DTDFVocab:fromData VehicleStateData
    DTDFVocab:inputTo VehicleMonitoringEnabler
]

instance MotorActuationMetrics : DTDFVocab:Data [
    base:desc "Processed motor actuation metrics (RPM, torque) for performance analysis."
    DTDFVocab:fromData MotorActuationData
    DTDFVocab:inputTo MotorDiagnosticsEnabler
]

instance SteeringServoMetrics : DTDFVocab:Data [
    base:desc "Processed steering servo metrics (angle, position) for control optimization."
    DTDFVocab:fromData SteeringServoData
    DTDFVocab:inputTo SteeringControlEnabler
]

instance ObjectTrackClusters : DTDFVocab:Data [
    base:desc "Clustered and tracked objects derived from LiDAR data for situational awareness."
    DTDFVocab:fromData ObjectTrackData
    DTDFVocab:inputTo ObjectDetectionEnabler
]

instance DrivingPathProjection : DTDFVocab:Data [
