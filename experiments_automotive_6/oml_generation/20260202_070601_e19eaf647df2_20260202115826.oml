// C3: Physical sensing components
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "Collects raw LiDAR point cloud data for object detection and environmental mapping in autonomous systems."
    DTDFVocab:producedData LiDARPointCloudData
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Collects vehicle state information including speed, position, and orientation for real-time monitoring."
    DTDFVocab:producedData VehicleStateData
]

instance MotorActuationSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors motor actuation parameters such as RPM and torque for performance tracking."
    DTDFVocab:producedData MotorActuationData
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Tracks steering servo actuation data including angle and position for control feedback."
    DTDFVocab:producedData SteeringServoData
]

instance ObjectTrackingSensor : DTDFVocab:SensingComponent [
    base:desc "Derives object tracks and clustering data from processed LiDAR point clouds for situational awareness."
    DTDFVocab:producedData ObjectTrackData
]

instance AdaptiveCruiseControlSensor : DTDFVocab:SensingComponent [
    base:desc "Generates projected driving path data for Adaptive Cruise Control (ACC) systems."
    DTDFVocab:producedData DrivingPathData
]

instance SensorFusionUnit : DTDFVocab:SensingComponent [
    base:desc "Integrates multiple sensor inputs (e.g., LiDAR, cameras) for comprehensive environmental perception."
    DTDFVocab:producedData SensorFusionData
]

// C4: Physical-to-virtual interaction
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance MotorActuationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorActuationSensor
]

instance SteeringServoData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
]

instance ObjectTrackData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ObjectTrackingSensor
]

instance DrivingPathData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AdaptiveCruiseControlSensor
]

instance SensorFusionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SensorFusionUnit
]

