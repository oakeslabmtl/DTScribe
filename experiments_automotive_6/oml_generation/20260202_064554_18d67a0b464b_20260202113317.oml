// ---------- Sensing Components ----------
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR sensor streaming real-time point clouds"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera providing depth image streams"
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedTelemetry : DTDFVocab:SensingComponent [
    base:desc "Telemetry sensor capturing vehicle speed telemetry"
    DTDFVocab:producedData SpeedDataTransmitted
]

instance SteeringAngleTelemetry : DTDFVocab:SensingComponent [
    base:desc "Telemetry sensor capturing vehicle steering angle"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// ---------- Data Transmitted ----------
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedTelemetry
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleTelemetry
]

instance LeadVehicleDetectionEventTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar, IntelD435iDepthCamera
]

// ---------- Data ----------
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "LiDAR point cloud data used for clustering and tracking"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo MATLABSimulinkProcessor, ROS2Middleware
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image data for obstacle detection"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo MATLABSimulinkProcessor, ROS2Middleware
]

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Vehicle ego speed telemetry data"
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo ROS2Middleware, SQLDatabaseEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Vehicle steering angle telemetry data"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo ROS2Middleware, SQLDatabaseEnabler
]

instance LeadVehicleDetectionEventData : DTDFVocab:Data [
    base:desc "Event data indicating detection of a lead vehicle"
    DTDFVocab:fromData LeadVehicleDetectionEventTransmitted
    DTDFVocab:inputTo ROS2Middleware, SQLDatabaseEnabler
]

// ---------- Models ----------
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN-based point-cloud clustering model for object segmentation"
    DTDFVocab:inputTo MATLABSimulinkProcessor
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking model for object state estimation"
    DTDFVocab:inputTo ROS2Middleware
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "ACC control model following ISO 15622 to compute desired speed"
    DTDFVocab:inputTo NVJetPack5Enabler, CppEnabler
]

instance SQLDatabaseModel : DTDFVocab:Model [
    base:desc "SQL database schema for persistent storage of sensor and event data"
    DTDFVocab:inputTo SQLDatabaseEnabler
]

instance ThreeDVisualizationModel : DTDFVocab:Model [
    base:desc "3D visualization model rendering tracked objects and vehicle state"
    DTDFVocab:inputTo MATLABSimulinkProcessor
]

// ---------- Enablers ----------
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware with DDS for inter-node communication"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, ThreeDVisualizationService
]

instance MATLABSimulinkProcessor : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for advanced point-cloud processing"
    DTDFVocab:enables DataMonitoringService, ThreeDVisualizationService
]

instance NVJetPack5Enabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK enabling GPU-accelerated computation"
    DTDFVocab:enables ACCControlModel, ComputationOffloadingService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ implementation environment for ROS2 nodes"
    DTDFVocab:enables ACCControlModel
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database service for logging and persistent storage"
    DTDFVocab:enables DataMonitoringService
]

instance WiFiConnectivity : DTDFVocab:Enabler [
    base:desc "Wi-Fi networking compliant with 3GPP TS 22.185 for latency control"
    DTDFVocab:enables RemoteManagementService
]

instance GitHubVersionControl : DTDFVocab:Enabler [
    base:desc "GitHub repository for version control and documentation"
]

// ---------- Services ----------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring service displaying speed, steering, object tracks, and projected paths; logs data and generates time-series reports"
    DTDFVocab:provides SpeedMonitoringInsight, SteeringAngleMonitoringInsight, ObjectTrackInsight, PathProjectionInsight, LogStorageInsight, TimeSeriesReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Cloud-based ACC decision logic offloaded from the vehicle; computes desired speed and lead-vehicle detection"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustACCParametersAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote user interface enabling enable/disable ACC, adjust desired speed, and issue emergency brake commands"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustACCParametersAction, EmergencyBrakeAction
]

instance ThreeDVisualizationService : DTDFVocab:Service [
    base:desc "3D visualization rendering vehicle environment and tracked objects for virtual cockpit"
    DTDFVocab:provides ObjectTrackInsight, PathProjectionInsight
]

// ---------- Insights ----------
instance SpeedMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of vehicle speed with trend analysis"
]

instance SteeringAngleMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of vehicle steering angle with trajectory preview"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Live visualization of clustered and tracked objects in the vehicle’s vicinity"
]

instance PathProjectionInsight : DTDFVocab:Insight [
    base:desc "Projected future path of the vehicle based on ACC calculations"
]

instance LogStorageInsight : DTDFVocab:Insight [
    base:desc "Persistent logging of sensor data and events for post-mission analysis"
]

instance TimeSeriesReportInsight : DTDFVocab:Insight [
    base:desc "Time-series reports generated from stored data for troubleshooting"
]

// ---------- Actions ----------
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control (ACC) functionality"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control (ACC) functionality"
    DTDFVocab:IsAutomatic false
]

instance AdjustACCParametersAction : DTDFVocab:Action [
    base:desc "Remote adjustment of ACC parameters such as desired speed and enablement status"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Trigger emergency braking signal to the vehicle"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Issuance of desired‑speed control commands, steering‑angle updates, emergency‑brake activations, and remote‑management directives from the DT’s Digital Twin Entity to the vehicle’s actuators; commands are serialized by the Data Translation FE and sent over the Wi‑Fi network to the vehicle’s Data Collection and Control Entity."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates on a real‑time time scale with end‑to‑end latency capped at 100 ms as required by 3GPP TS 22.185; the system’s clocks are synchronized to an accuracy of 100 ms, and sensor streams and decision outputs are aligned to this 100 ms tick for coordinated processing."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "All functional entities are orchestrated via a ROS2 network: the Physical Twin Entity packages (clustering, tracking, actuation) run on the vehicle; the Digital Twin Entity packages (data collection, ACC control, reporting, data storage) run on a remote host; the User Entity (3D visualization and control panel) runs on an operator workstation; cross‑system data translation bridges ROS2 topics over Wi‑Fi, forming a cohesive digital‑twin constellation that processes real‑time data, executes control logic, and presents UI to users."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Requirements definition – R1 to R8 are captured as system requirements. Architecture design – ISO 23247 RA is mapped to entities and FEs (Sec. IV‑B). Implementation – SW components packaged as ROS 2 nodes and deployed to PT and DT. Deployment – the DT services are made available to operators and developers on an operator workstation. (Further validation and maintenance stages are implied but not explicitly described.)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity sensor data (raw LiDAR, depth images) are preserved through DBSCAN clustering and Kalman filtering, yielding accurate object tracks; ACC logic follows ISO 15622 specifications; real‑time execution meets 100 ms latency; data integrity ensured via clock synchronization to 100 ms and validation checks on message timestamps; report generation offers traceability and auditability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication occurs over a Wi‑Fi network using ROS 2 publish/subscribe messaging. The Data Translation FE handles serialization, type alignment, and unit conversion. End‑to‑end latency is constrained to ≤100 ms, meeting 3GPP requirements."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the NVIDIA Jetson Orin Nano embedded in the vehicle; the Digital Twin Entity is hosted on a remote server or cloud instance; the User Entity runs on an operator workstation; the Cross‑System entity spans the network links between the PT and DT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system follows ISO 23247 reference architecture, ISO 15622 ACC control specification, ROS2 (interoperable with DDS and IEEE 802.11 networking standards), and sensor standards for Hokuyo LiDAR and Intel D435i; the coding follows NVIDIA JetPack SDK conventions; firmware and data interfaces align with open‑source RoboRacer guidelines."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed through low‑latency (<100 ms) deterministic networking, deterministic ROS2 message handling, and adherence to ISO 15622 ACC safety specifications; the acceleration and braking controls are only applied after validation of sensor data and timestamp synchronization; remote command execution is mediated via the Data Translation FE to prevent injection of malformed signals; the design acknowledges the potential for human‑in‑the‑loop accidents and enforces human‑override capability via UI emergency brake."
]