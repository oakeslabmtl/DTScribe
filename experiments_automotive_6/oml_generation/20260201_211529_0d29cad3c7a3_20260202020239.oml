// =============================
// ISO 23247 Entities
// =============================
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "ISO 23247 Physical Twin Entity representing the 1/10‑scale autonomous vehicle"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "ISO 23247 Digital Twin Entity hosting the DT services and processing components"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "ISO 23247 User Entity providing operator interfaces"
    base:contains VisualizationFE, ControlPanelFE
]

instance VisualizationFE : DTDFVocab:Component [
    base:desc "User interface front‑end for visualization of monitoring data"
]

instance ControlPanelFE : DTDFVocab:Component [
    base:desc "User interface front‑end for control actions and remote management"
]

// =============================
// Physical Sensing Components
// =============================
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor providing 3‑D point‑cloud data of the surrounding environment"
    DTDFVocab:producedData LiDARRawPointCloudDataTransmitted
]

instance MotorStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing motor speed and torque signals from the vehicle"
    DTDFVocab:producedData MotorStateDataTransmitted
]

instance SteeringStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing steering angle and rate signals from the vehicle"
    DTDFVocab:producedData SteeringStateDataTransmitted
]

instance ServoStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing servo position and feedback signals from the vehicle"
    DTDFVocab:producedData ServoStateDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing overall vehicle state (speed, yaw rate, etc.)"
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// =============================
// Data Transmitted (Physical → Virtual)
// =============================
instance LiDARRawPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance MotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStateSensor
]

instance SteeringStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringStateSensor
]

instance ServoStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ServoStateSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// =============================
// Processed Data (Virtual)
// =============================
instance ProcessedPointCloudData : DTDFVocab:Data [
    base:desc "Clustered and tracked point‑cloud data after processing by the Point Cloud Clustering & Tracking component"
    DTDFVocab:fromData LiDARRawPointCloudDataTransmitted
    DTDFVocab:inputTo PointCloudClusteringTrackingEnabler, DataTranslationEnabler
]

instance ProcessedVehicleStateData : DTDFVocab:Data [
    base:desc "Aggregated vehicle‑state data (motor, steering, servo, general state) after Data Translation"
    DTDFVocab:fromData MotorStateDataTransmitted, SteeringStateDataTransmitted, ServoStateDataTransmitted, VehicleStateDataTransmitted
    DTDFVocab:inputTo ACCComputationEnabler, RemoteManagementEnabler, DataTranslationEnabler
]

// =============================
// Enablers (Processing & Infrastructure)
// =============================
instance PointCloudClusteringTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Software component that clusters and tracks LiDAR point clouds"
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation functional entity that serialises, aligns message types, and performs unit conversions"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Cloud‑based ACC algorithm (lead‑vehicle detection, distance calculation, desired‑speed computation)"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Remote‑management component enabling ACC enable/disable, speed setting, and emergency‑braking commands"
    DTDFVocab:enables RemoteManagementService
]

instance WiFiUdpTransportEnabler : DTDFVocab:Enabler [
    base:desc "Low‑latency Wi‑Fi link using UDP for physical‑digital communication"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance ROS2IntraDtsEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 network for intra‑Digital Twin System component communication"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

// =============================
// Services
// =============================
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Displays real‑time vehicle state, projected driving path, and detected object tracks; allows view, save, and generate reports"
    DTDFVocab:provides RealTimeVehicleStateInsight, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm on cloud resources and sends the desired speed back to the vehicle for actuation"
    DTDFVocab:provides DesiredSpeedInsight, SendDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to enable/disable ACC, set a desired speed, and issue an emergency‑braking command remotely"
    DTDFVocab:provides ACCControlInsight, EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// =============================
// Insights
// =============================
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Provides up‑to‑date visualization of vehicle dynamics and detected objects"
]

instance DesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Computed desired speed for the ego vehicle based on the ACC algorithm"
]

instance ACCControlInsight : DTDFVocab:Insight [
    base:desc "Current ACC status and parameters as controlled by the operator"
]

// =============================
// Actions
// =============================
instance GenerateReportAction : DTDFVocab:Action [
    base:desc "User‑initiated generation of a vehicle data report"
    DTDFVocab:IsAutomatic false
]

instance SendDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Transmission of the computed desired speed to the vehicle actuators"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets a target speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediate braking command issued remotely"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DTS sends control commands back to the vehicle over the same Wi‑Fi/UDP link. Commands include ACC enable/disable, desired speed set‑point, and emergency‑brake activation. These commands are generated by the Controlling/Actuation functional entities, serialized by the Data Translation component, and transmitted to the vehicle’s actuators (motor, steering servo). The vehicle returns updated state information, which is displayed in the UI to confirm execution."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT requires that the physical twin and its digital counterpart share a common notion of time; clock synchronization must achieve at least 100 ms accuracy, which is the limit imposed by the available hardware. This synchronization constraint is required for computation off‑loading between devices; stricter sub‑100 ms bounds are mandated by external safety‑critical vehicular standards but are not imposed in this implementation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO‑23247 reference architecture with an entity‑based decomposition. Functional Entities are realized as ROS 2 packages; each package contains one or more ROS 2 nodes that implement the FE’s behavior. The three entities communicate via ROS 2 middleware, providing data management, actuation and user interaction. Resource management is achieved by mapping each entity to dedicated compute resources (e.g., separate on‑board computers). The overall orchestration relies on ROS 2’s publish/subscribe and service mechanisms to coordinate the entities."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection consists of a ROS 2 middleware backbone for internal component messaging and a Wi‑Fi network using UDP for external communication between the physical twin and the DTS. The architecture follows a client‑server style where the vehicle acts as a data source and command receiver, while the DTS provides processing and UI services. The system is required to sustain low end‑to‑end latency to meet safety‑critical needs, though exact bandwidth or latency figures are not stated. Redundancy and security mechanisms are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT services can be hosted on compute resources that may reside in the cloud, as the context mentions off‑loading compute to 'better‑suited equipment, e.g., in the cloud'. No specific details on storage size, scaling strategy, deployment models (container, VM, edge) or availability guarantees are provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin complies with ISO 23247 (2021), the 'Digital twin framework for manufacturing' standard. Compliance involves adhering to Part 2 of the standard, which defines a reference architecture based on entities such as the Observable Manufacturing Element (OME), the Data Collection and Device Control Entity, the Digital Twin Entity, and the User Entity. Each entity is composed of Functional Entities that perform specific tasks (e.g., actuation, data transformation, user interfacing). The standard does not prescribe specific implementation technologies, but the architecture may be realized with protocols such as OPC Unified Architecture. No additional certification or interoperability specifications are described in the document."
]