// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing real-time 3D point cloud data for environment perception"
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera capturing RGB-D data for object detection and scene understanding"
    DTDFVocab:producedData DepthCameraData
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard wheel encoder providing real-time ego vehicle speed measurements"
    DTDFVocab:producedData VehicleSpeedData
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor providing real-time ego vehicle steering angle measurements"
    DTDFVocab:producedData SteeringAngleData
]

// C4: Physical-to-Virtual Interaction
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
]

instance VehicleSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance DerivedObjectTracks : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR, IntelRealSenseD435iDepthCamera
]

// C10: Models/Data
instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model implementing lead-vehicle detection and desired speed computation per ISO 15622"
    DTDFVocab:inputTo NVIDIAJetPack50SDK, MATLABSimulinkEnabler
]

instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point cloud clustering algorithm for object segmentation"
    DTDFVocab:inputTo NVIDIAJetPack50SDK
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter implementation for object tracking and state estimation"
    DTDFVocab:inputTo NVIDIAJetPack50SDK
]

instance ThreeDVisualizationModel : DTDFVocab:Model [
    base:desc "3D visualization model rendering vehicle state, projected path, and object tracks"
    DTDFVocab:inputTo ROS2Middleware
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Processed object tracks derived from raw sensor data using clustering and tracking models"
    DTDFVocab:fromData DerivedObjectTracks
    DTDFVocab:inputTo NVIDIAJetPack50SDK
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Real-time ego vehicle state including speed, steering angle, and computed ACC parameters"
    DTDFVocab:fromData VehicleSpeedData, SteeringAngleData
    DTDFVocab:inputTo ROS2Middleware, NVIDIAJetPack50SDK
]

instance HistoricalVehicleData : DTDFVocab:Data [
    base:desc "Persistent storage of object tracks and vehicle state in external SQL database"
    DTDFVocab:fromData DerivedObjectTracks, VehicleSpeedData, SteeringAngleData
    DTDFVocab:inputTo SQLDatabaseEnabler
]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware facilitating real-time communication between system components"
]

instance NVIDIAJetPack50SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK providing CUDA acceleration and computer vision libraries"
]

instance Python38 : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime environment for script execution and data processing"
]

instance CPlusPlus : DTDFVocab:Enabler [
    base:desc "C++ runtime environment for performance-critical components"
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for complex control algorithm development"
]

instance WiFiCommunication : DTDFVocab:Enabler [
    base:desc "Wi-Fi network enabling real-time data streaming between physical and digital twins"
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database system for persistent storage of vehicle state and object tracks"
]

instance DataTranslationFunctionalEntity : DTDFVocab:Enabler [
    base:desc "Functional entity handling message serialization and unit conversion between system components"
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service visualizing real-time vehicle state, projected path, and object tracks in 3D UI generates saved reports"
]

instance ACCComputationService : DTDFVocab:Service [
    base:desc "Service implementing Adaptive Cruise Control algorithm running in digital twin computes lead-vehicle detection and desired speed"
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service enabling operators to enable/disable ACC, adjust speed, and issue emergency braking through UI"
]

instance DataTranslationService : DTDFVocab:Service [
    base:desc "Service providing data translation between physical and digital twin components"
]

instance ObjectDetectionService : DTDFVocab:Service [
    base:desc "Service processing raw sensor data to generate object tracks and environmental understanding"
]

// C17: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time 3D visualization of vehicle state, projected path, and detected objects"
]

instance SystemReportInsight : DTDFVocab:Insight [
    base:desc "Generated reports containing historical vehicle state and object track data"
]

instance ACCStatusInsight : DTDFVocab:Insight [
    base:desc "Current status of Adaptive Cruise Control system including lead vehicle detection"
]

instance DesiredSpeedAction : DTDFVocab:Action [
    base:desc "Computed desired speed for ego vehicle based on ACC algorithm"
    DTDFVocab:IsAutomatic true
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Emergency braking command issued by remote operator"
    DTDFVocab:IsAutomatic false
]

instance ACCControlInsight : DTDFVocab:Insight [
    base:desc "Current ACC system configuration including enabled/disabled state and speed limits"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Processed object tracks with position, velocity, and classification information"
]

instance DataConsistencyInsight : DTDFVocab:Insight [
    base:desc "Verification of data consistency between physical and digital twin components"
]

// C2: Acting Components
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder ESC motor voltage command actuator for speed control"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuation implemented by Actuation Functional Entity"
]

// C1: System Components
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical Twin Entity running on vehicle hardware including Jetson NX antenna and Jetson Orin Nano compute module"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital Twin Entity executed on external compute hardware implementing ACC algorithm and data processing"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User Entity hosting the 3D visualization UI for operator interaction"
]

instance CrossSystemEntity : DTDFVocab:Component [
    base:desc "Cross-System Entity providing data translation services between physical and digital twins"
]

instance TraxxasSlash4x4Platform : DTDFVocab:Component [
    base:desc "1/10-scale autonomous vehicle platform retrofitted with NVIDIA hardware and sensors"
]

instance NVIDIAJetsonNX : DTDFVocab:Component [
    base:desc "NVIDIA Jetson NX antenna module for wireless communication"
]

instance NVIDIAJetsonOrinNano : DTDFVocab:Component [
    base:desc "NVIDIA Jetson Orin Nano compute module for onboard processing"
]

instance VedderESC : DTDFVocab:Component [
    base:desc "Vedder electronic speed controller for motor and steering actuation"
]

// C12: Environments
instance PhysicalVehicleEnvironment : DTDFVocab:Environment [
    base:contains TraxxasSlash4x4Platform, HokuyoUST10LXLiDAR, IntelRealSenseD435iDepthCamera,
                VehicleSpeedSensor, SteeringAngleSensor, MotorVoltageActuator, SteeringServoActuator,
                NVIDIAJetsonNX, NVIDIAJetsonOrinNano, VedderESC
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains DigitalTwinEntity, CrossSystemEntity
]

instance UserInterfaceEnvironment : DTDFVocab:Environment [
    base:contains UserEntity
]

instance ThreeDVisualizationModelEnvironment : DTDFVocab:Environment [
    base:contains ThreeDVisualizationModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Transmission of ACC commands (desired speed), remote‑management commands (enable/disable ACC, set speed, emergency‑brake) from the digital twin to the physical twin over Wi‑Fi via ROS 2, received by the Actuation Functional Entity and applied to the motor/steering hardware."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sub‑second, with a maximum end‑to‑end network latency of 100 ms and clock synchronization accuracy of 100 ms across all DTS components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A distributed architecture mapping the ISO 23247 reference architecture: Physical Twin Entity ↔ Digital Twin Entity ↔ User Entity, connected via ROS 2 intra‑entity links and Wi‑Fi inter‑entity links, with Cross‑System Entity handling data translation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the operational stage (real‑time monitoring and control) and supports development/testing phases through cyber‑physical experimentation, as described in the case study."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time fidelity ensured by ≤100 ms latency and synchronized clocks; ACC functionality conforms to ISO 15622; point‑cloud processing validated through DBSCAN clustering and Kalman filtering; data integrity maintained via standardized ROS 2 messaging and unit conversion."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Wi‑Fi network between the vehicle and external compute; ROS 2 topics for intra‑entity communication; Data Translation FE performs serialization, type alignment, and unit conversion."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the vehicle’s Jetson Orin Nano; Digital Twin Entity runs on an external PC or cloud server hosting ROS 2 nodes; User Entity (UI) runs on a workstation; cross‑system services run on the same host as the Digital Twin Entity; SQL database hosted externally."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system follows ISO 23247 (Digital Twin Manufacturing Framework) for architectural mapping, ISO 15622 for ACC functionality, and uses ROS 2 as a standardized middleware; OPC UA is mentioned as an optional protocol but not employed."
]