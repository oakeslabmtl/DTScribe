// Sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor mounted on the vehicle to capture point-cloud data for obstacle detection."
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance MotorSensor : DTDFVocab:SensingComponent [
    base:desc "Motor actuation sensor providing current motor position and torque signals."
    DTDFVocab:producedData MotorSignalDataTransmitted
]

instance SteeringSensor : DTDFVocab:SensingComponent [
    base:desc "Steering sensor delivering steering angle and rate information."
    DTDFVocab:producedData SteeringSignalDataTransmitted
]

instance ServoSensor : DTDFVocab:SensingComponent [
    base:desc "Servo actuation sensor delivering servo position and velocity insights."
    DTDFVocab:producedData ServoSignalDataTransmitted
]

// Data transmitted by sensing components
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance MotorSignalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSensor
]

instance SteeringSignalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringSensor
]

instance ServoSignalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ServoSensor
]

// Processed data used by enablers
instance LiDARPointCloudProcessed : DTDFVocab:Data [
    base:desc "Processed LiDAR point-cloud after clustering and tracking, providing object tracks for the DT."
    DTDFVocab:inputTo ACCComputationEnabler, DataMonitoringEnabler
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
]

instance VehicleStateProcessed : DTDFVocab:Data [
    base:desc "Vehicle state derived from motor, steering, and servo actuation signals for ACC computations."
    DTDFVocab:inputTo ACCComputationEnabler, DataMonitoringEnabler
    DTDFVocab:fromData MotorSignalDataTransmitted, SteeringSignalDataTransmitted, ServoSignalDataTransmitted
]

// Enablers
instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that offloads accelerated control algorithm (ACC) computations onto the DT."
    DTDFVocab:enables ComputationOffloadingService
]

instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that aggregates processed sensor data for real-time monitoring."
    DTDFVocab:enables DataMonitoringService
]

instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that facilitates remote control commands sent to vehicle."
    DTDFVocab:enables RemoteManagementService
]

// Services
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC algorithm (lead-vehicle detection, desired speed computation) and returns speed commands to the on-board ECU."
    DTDFVocab:provides SpeedCommandAction
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "User interface that displays real-time vehicle state, projected trajectory, and dynamic object tracks allows archiving and generation of performance reports."
    DTDFVocab:provides RealTimeVehicleStateInsight, ProjectedTrajectoryInsight, ObjectTracksInsight, PerformanceReportInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, set desired speed, or trigger an emergency brake via low end-to-end latency channel."
    DTDFVocab:provides ToggleACCAction, SetDesiredSpeedAction, TriggerEmergencyBrakeAction
]

// Actions
instance SpeedCommandAction : DTDFVocab:Action [
    base:desc "Action to transmit computed speed command to the vehicle ECU."
    DTDFVocab:IsAutomatic false
]

instance ToggleACCAction : DTDFVocab:Action [
    base:desc "Operator action to toggle ACC on or off."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator action to set desired cruising speed."
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator action to trigger emergency brake immediately."
    DTDFVocab:IsAutomatic false
]

// Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight providing current vehicle state in real time."
]

instance ProjectedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight depicting projected vehicle trajectory based on ACC prediction."
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Insight displaying dynamic object tracks extracted from LiDAR point-cloud."
]

instance PerformanceReportInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing performance metrics and historical logs, usable for analysis."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Time synchronization across all connected devices is mandated to share a common notion of time, with a required accuracy of 100 ms to satisfy safety-critical vehicular standards that often demand stricter limits. The data exchange and computation‑offloading processes are therefore synchronized on a 100 ms temporal grid, ensuring that physical and digital states are aligned with that granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is architected following ISO 23247, with distinct entity layers: a Physical Twin Entity that hosts the underlying compute, sensors, actuators and general automotive logic (e.g., point‑cloud clustering and tracking); a Digital Twin Entity that encapsulates data management and control mechanisms; and a User Entity that contains the User Interface FE split into 3D Visualization and Control Panel components. Each entity is instantiated as one or more ROS 2 packages, each comprising one or more ROS 2 nodes that communicate via ROS 2 topics and services. The entities are deployed on separate hardware platforms, leading to a distributed orchestration that respects 100 ms clock‑synchronization across nodes. Resource management and system‑wide coordination are handled by the ROS 2 middleware, which routes messages and service calls among nodes, while ownership of functionality is determined by the physical deployment of each entity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin System (DTS) employs an internal ROS 2 network based on DDS for communication between software components, while inter‑entity communication (e.g., between the DTS and external vehicle or user interfaces) is carried out over a Wi‑Fi radio link using the User Datagram Protocol (UDP) at the transport layer, as illustrated in Figure 2. This architecture supports real‑time, low‑latency data exchange for sensor streams and control command distribution."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system is designed in accordance with ISO 23247 – Digital twin framework for manufacturing, adopting its entity‑based reference architecture.  It follows Part 2 of the standard, which defines four core entities – Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity, and User Entity – each composed of Functional Entities for specific tasks such as actuator control, data transformation and user interfacing.  The implementation may use OPC Unified Architecture as an example of a Functional Entity communication protocol, ensuring interoperability with industrial automation systems."
]