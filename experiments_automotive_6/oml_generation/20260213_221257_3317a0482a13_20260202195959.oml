// C1: Physical Twin Architecture Components
instance PhysicalTwinChassisLowerLevel : DTDFVocab:Component [
    base:desc "Lower-level chassis for steering and speed control in the 1/10th-scale autonomous vehicle PT, implementing basic actuation via motor voltage commands"
]

instance PhysicalTwinChassisUpperLevel : DTDFVocab:Component [
    base:desc "Upper-level chassis hosting autonomy components including NVIDIA Jetson NX and Jetson Orin Nano microcomputers, enabling real-time perception processing"
]

instance JetsonOrinNano : DTDFVocab:Component [
    base:desc "NVIDIA Jetson Orin Nano microcomputer deployed in the upper-level chassis for ACC control logic execution"
]

instance JetsonNx : DTDFVocab:Component [
    base:desc "NVIDIA Jetson NX microcomputer deployed in the upper-level chassis for perception processing and ROS2 middleware coordination"
]

instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR sensor providing 3D object detection for ego-vehicle perception in the physical twin"
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i Depth Camera providing environmental perception data for the physical twin's autonomy system"
    DTDFVocab:producedData DepthCameraData
]

instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller managing motor voltage commands for speed control in the lower-level chassis"
]

instance ActuationProcessingUnit : DTDFVocab:Component [
    base:desc "Upper-level chassis processing unit converting desired speed commands to motor voltage outputs via Jetson Orin Nano"
]

// C2: Data Streams
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]

instance SpeedSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VedderElectronicSpeedController
]

instance SteeringAngleSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalTwinChassisLowerLevel
]

instance EgoVehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SpeedSensorData, SteeringAngleSensorData
]

instance ObjectTrackData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudData, DepthCameraData
]

instance ProjectedDrivingPathData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ObjectTrackData
]

// C3: Physical Data
instance LiDARPointCloud : DTDFVocab:Data [
    base:desc "Raw 3D point cloud data from Hokuyo UST-10LX LiDAR, containing position/velocity information of detected objects"
    DTDFVocab:fromData LiDARPointCloudData
    DTDFVocab:inputTo DBSCANImplementation, KalmanFilterImplementation
]

instance DepthCameraImage : DTDFVocab:Data [
    base:desc "Depth camera raw image data from Intel Deepsense D435i, containing environmental perception data for ACC system"
    DTDFVocab:fromData DepthCameraData
    DTDFVocab:inputTo DepthProcessingPipeline
]

instance EgoVehicleState : DTDFVocab:Data [
    base:desc "Real-time ego-vehicle state data including current speed and steering angle, transmitted via ROS2 topics"
    DTDFVocab:fromData EgoVehicleStateData
    DTDFVocab:inputTo VisualizationDashboard, ACCControlLogic
]

instance ObjectTrack : DTDFVocab:Data [
    base:desc "Processed object tracks derived from LiDAR point clouds using DBSCAN clustering and Kalman filtering, containing position/velocity/size information"
    DTDFVocab:fromData ObjectTrackData
    DTDFVocab:inputTo VisualizationDashboard, LeadVehicleDetection
]

instance ProjectedDrivingPath : DTDFVocab:Data [
    base:desc "Projected driving paths generated from object tracks for ACC system visualization, showing future trajectory based on current state"
    DTDFVocab:fromData ProjectedDrivingPathData
    DTDFVocab:inputTo VisualizationDashboard
]

// C4: Models
instance ACCControlModel : DTDFVocab:Model [
    base:desc "ISO 15622-compliant ACC control model implementing speed adjustment logic for lead-vehicle detection and distance maintenance"
    DTDFVocab:inputTo Jetpack50SDK
]

instance PerceptionModel : DTDFVocab:Model [
    base:desc "Perception model combining LiDAR point cloud processing (DBSCAN clustering) and Kalman filtering for object tracking"
    DTDFVocab:inputTo JetsonNx, DBSCANImplementation, KalmanFilterImplementation
]

instance VisualizationModel : DTDFVocab:Model [
    base:desc "3D visualization model for displaying ego-vehicle state, object tracks, and projected driving paths in the DT UI"
    DTDFVocab:inputTo OpenGLRenderingEngine
]

instance ReportingModel : DTDFVocab:Model [
    base:desc "SQL database model for storing historical ACC performance data and generating human-readable reports"
    DTDFVocab:inputTo SQLDatabase
]

// C5: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Core service providing real-time visualization of ego-vehicle state (speed, steering angle), detected object tracks, and projected driving paths via the UI"
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service delegating ACC control logic from vehicle ECUs to cloud/off-board hardware, enabling resource-efficient processing"
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service enabling remote activation/deactivation of ACC, speed adjustments, and emergency braking commands through the UI"
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Service generating human-readable reports via SQL databases containing ACC performance metrics and historical data"
    DTDFVocab:provides PerformanceReportInsight
]

// C6: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 Robot Operating System 2 middleware enabling modular inter-component communication and loose coupling between physical and digital components"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance Jetpack50SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK facilitating hardware integration and software development for Jetson microcomputers in the physical twin"
    DTDFVocab:enables PerceptionModel, ACCControlModel, ActuationProcessingUnit
]

instance Python38 : DTDFVocab:Enabler [
    base:desc "Python 3.8 programming language used for rapid prototyping and ROS2 node development in the digital twin system"
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment used for complex simulations including point cloud clustering and ACC control logic validation"
    DTDFVocab:enables DBSCANImplementation, KalmanFilterImplementation
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL database system for storing historical ACC performance data and generating human-readable reports"
    DTDFVocab:enables ReportingService, ReportingModel
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Data Translation Feature Engine handling serialization/unit conversion via ROS2 topics for consistent data exchange"
    DTDFVocab:enables LiDARPointCloud, DepthCameraImage, EgoVehicleState
]

instance OpenGLRenderingEngine : DTDFVocab:Enabler [
    base:desc "3D rendering library enabling visualization of object tracks and ego-vehicle paths in the digital twin UI"
    DTDFVocab:enables VisualizationModel
]

// C7: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of ego-vehicle state (speed, steering angle) and detected object tracks for operators in the DT UI"
]

instance StateMonitoringAction : DTDFVocab:Action [
    base:desc "Continuous monitoring of vehicle state parameters (speed, steering angle) for ACC system health and performance assessment"
    DTDFVocab:IsAutomatic true
]

instance ControlLogicOffloadingAction : DTDFVocab:Action [
    base:desc "Delegation of ACC control logic from vehicle ECUs to cloud/off-board hardware for computational efficiency"
    DTDFVocab:IsAutomatic true
]

instance ParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Dynamic adjustment of ACC parameters (desired speed) through remote management interface"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Remote activation of emergency braking commands when critical safety conditions are detected"
    DTDFVocab:IsAutomatic false
]

instance PerformanceReportInsight : DTDFVocab:Insight [
    base:desc "Human-readable report generation containing ACC performance metrics and historical data from SQL databases"
]

// C8: User Entities
instance UserVisualizationFE : DTDFVocab:Component [
    base:desc "3D Visualization Frontend component handling all user interactions related to perception visualization (object tracks, paths)"
]

instance UserControlPanelFE : DTDFVocab:Component [
    base:desc "Control Panel Frontend component managing all user interactions for ACC system control (speed adjustments, emergency braking)"
]

// C9: Digital Twin Entity Structure
instance CentralDigitalTwinEntity : DTDFVocab:Component [
    base:desc "Centralized Digital Twin Entity hosting data collection, reporting, and visualization components"
    base:contains UserVisualizationFE, ReportingService, VisualizationDashboard
]

instance DistributedPhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Distributed Physical Twin Entity components deployed on separate hardware (e.g., Jetson Orin Nano) for point cloud processing and actuation"
    base:contains ROS2PerceptionNode, ROS2TrackingNode, ROS2ControlNode, ActuationProcessingUnit
]

// C10: Twinning Process Components
instance RequirementsDefinitionPhase : DTDFVocab:Component [
    base:desc "Phase implementing standardized communication (ROS2), real-time data collection (latency ≤100ms), and clock synchronization (R1-R8)"
]

instance ArchitecturalDesignPhase : DTDFVocab:Component [
    base:desc "Phase mapping ISO 23247 features to ROS2 packages, introducing Physical Twin Entity as a departure from standard architecture"
]

instance ImplementationPhase : DTDFVocab:Component [
    base:desc "ROS2-based deployment phase using MATLAB/Simulink for simulations and ROS2 nodes for real-time processing"
]

instance ValidationPhase : DTDFVocab:Component [
    base:desc "Phase testing latency, safety compliance, and remote management functionality with latency ≤100ms requirement"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin interacts with the physical twin through **Wi-Fi communication** (UDP-based) for inter-entity control, transmitting commands such as enabling/disabling ACC, setting desired speed, or triggering emergency braking. The **Actuation FE** in the Physical Twin Entity converts these commands into motor voltage signals for the Vedder Electronic Speed Controller, ensuring low-latency actuation (≤100 ms end-to-end)."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin operates at a **real-time scale**, with synchronization requirements of **≤100 ms end-to-end latency** between the vehicle and DT Entity, aligned with 3GPP V2V communication standards. Clock synchronization is maintained to **±100 ms accuracy** across distributed devices to ensure event ordering and data integrity. The DT processes data at **perception cycle rates** (typically 10–30 Hz for LiDAR-based tracking) and executes control logic in response to user commands or real-time state updates."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation consists of three primary entities, mapped from ISO 23247: **1) Physical Twin Entity** (hosts sensor data processing, actuation, and middleware components like ROS2 nodes for LiDAR tracking and motor control); **2) Digital Twin Entity** (aggregates data collection, reporting, and visualization components; decomposes into **Data Collection FE**, **Reporting FE**, and **Presentation FE**); **3) User Entity** (split into **3D Visualization FE** and **Control Panel FE** for remote management). The **Data Translation FE** bridges inter-entity communication via ROS2/Wi-Fi networks, ensuring data alignment and unit consistency."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin spans **three lifecycle stages**: **Design Phase** (simulation and validation of ACC logic using MATLAB/Simulink and ROS2), **Manufacturing Phase** (retrofitting the 1/10th-scale autonomous vehicle with sensors and hardware), and **Operational Phase** (real-time monitoring, remote management, and computation offloading during vehicle testing). The DT covers the **as-operated** representation phase, focusing on runtime performance and safety validation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured through **real-time data streams** (LiDAR, cameras) and **high-precision sensor calibration** (e.g., DBSCAN/Kalman filtering for object tracking). Validation mechanisms include: **1) Latency Testing** (≤100 ms end-to-end for control commands); **2) Safety Validation** (ISO 15622 compliance for ACC performance class I); **3) Uncertainty Handling** (data translation FE mitigates unit inconsistencies); **4) Verification** (ROS2 node lifecycle management ensures robustness). The DT’s validity is confirmed via public demonstrations (YouTube video) and open-source artifacts (GitHub repository)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin connects to the physical twin via **ROS2-based intra-entity communication** (onboard) and **Wi-Fi UDP communication** (inter-entity). **Network Protocols**: ROS2 topics for data exchange, Wi-Fi for remote control commands. **Latency Requirements**: ≤100 ms end-to-end latency (3GPP V2V standard). **Clock Synchronization**: NTP-like mechanisms ensure ±100 ms accuracy across distributed devices. **Data Serialization**: The **Data Translation FE** standardizes message formats (e.g., ROS2 topics) and performs unit conversions (e.g., LiDAR coordinates to vehicle-local frames)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is deployed in a **hybrid architecture**: **Physical Twin Entity** components run on-board (Jetson Orin Nano) for real-time processing, while **Digital Twin Entity** and **User Entity** components are hosted externally (cloud/off-board) for computation offloading. **Hosting Technologies**: ROS2 middleware for intra-system communication, Wi-Fi for inter-entity connectivity. **Storage**: SQL databases store historical data externally to the vehicle."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The digital twin integrates with external systems via Wi-Fi for inter-entity communication. While the case study focuses on the ACC system, the architecture supports future expansion to other ADAS subsystems or external DTs via standardized protocols (e.g., ROS2). Cross-domain validation is demonstrated through adaptations of ISO 23247 for aerospace/battery systems, though no external DTs are directly integrated in this implementation."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin adheres to the following standards: **1) ISO 23247**: Reference architecture (RA) for DTs, adapted with the **Physical Twin Entity** (not defined in ISO 23247); **2) ISO 15622**: ACC performance requirements (performance class I); **3) ROS2**: Middleware for inter-component communication; **4) 3GPP 22.185**: Latency requirements for V2V communication (≤100 ms). The case study explores deviations from ISO 23247 (e.g., splitting User Interface FE) to address automotive-specific needs."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is ensured through strict latency constraints (<100 ms), clock synchronization (±100 ms), and adherence to ISO 15622 for ACC performance. Emergency braking commands are prioritized to prevent accidents. While ROS2/Wi-Fi communication may include TLS in general, this implementation does not explicitly mention security protocols. The system operates in a **Fully Autonomous Digital Twin with Human-in-the-Loop**, enabling remote management but with safeguards for critical operations."
]