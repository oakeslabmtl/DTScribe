// 1. Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor providing raw point‑cloud data for the vehicle"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor suite publishing vehicle speed and position"
    DTDFVocab:producedData VehicleStateTransmitted
]

// 2. Data transmitted from sensors
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// 3. Raw data objects
instance LiDARRawPointCloudData : DTDFVocab:Data [
    base:desc "Raw 3‑D point‑cloud data emitted by the LiDAR sensor"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state messages containing speed and position"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo ACCComputationEnabler
]

// 4. Functional models
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Functional entity that clusters raw LiDAR points and tracks objects, producing object tracks"
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance ACCModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model that identifies lead vehicle and computes desired speed based on inter‑vehicle distance"
    DTDFVocab:inputTo ACCComputationEnabler
]

// 5. Enablers (ROS2 / UDP pipelines)
instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 topic pipeline that carries clustered object tracks for visualization and downstream ACC processing"
    DTDFVocab:enables DataMonitoringService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 DDS communication channel that delivers ACC desired speed to the vehicle actuator"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Low‑latency bi‑directional Wi‑Fi UDP link enabling operator commands such as ACC enable/disable and emergency brake"
    DTDFVocab:enables RemoteManagementService
]

// 6. Services offered by the Digital Twin
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI shows real‑time vehicle state, projected trajectory, and object tracks; supports data logging, saving and report generation for developers and operators"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm runs on the cloud DT; desired speed is computed and sent back to the vehicle for actuation"
    DTDFVocab:provides DesiredSpeedControlAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, set target speed and issue an emergency brake command remotely via the UI"
    DTDFVocab:provides EmergencyBrakeAction
]

// 7. Insights and actions generated by services
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides operators with immediate visual feedback of vehicle dynamics and surrounding objects"
]

instance DesiredSpeedControlAction : DTDFVocab:Action [
    base:desc "Automatically applies the speed set‑point computed by the ACC model to the vehicle propulsion system"
    DTDFVocab:IsAutomatic true
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediately commands the vehicle to perform an emergency stop in response to operator input"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the ACC service executing in the Digital Twin Entity. After computing the desired speed based on the lead‑vehicle distance, the ACC service sends a numeric desired‑speed command, as well as Boolean enable/disable ACC commands and an emergency‑brake signal, back to the Physical Twin Entity over the same Wi‑Fi UDP channel. The incoming commands are received by the Actuation FE, which forwards them to the vehicle actuators (motor, steering servo). The vehicle returns updated actuator status and vehicle‑state information, allowing the system to confirm command execution. Validation, authentication and conflict‑resolution mechanisms are not detailed in the documents, but the architecture requires low end‑to‑end latency to satisfy safety‑critical constraints."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DTS requires a shared notion of time across all devices to enable computation offloading, with clock synchronization accuracy bounded to ≤100 ms as dictated by safety‑critical automotive standards. This synchronization supports the ACC data‑monitoring, offloading, and remote‑management services, which also demand low end‑to‑end latency communication between the vehicle and the DT, though precise latency numbers beyond the 100 ms sync bound are not specified."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DTS is orchestrated as an entity‑based system per ISO 23247, with functional entities implemented as ROS 2 packages (each containing one or more ROS 2 nodes). The Physical Twin Entity hosts resource‑specific functions (sensors, actuators, compute), the Digital Twin Entity provides the digital representation and processing (including offloaded ACC computations), and the User Entity offers a 3D visualization and control‑panel UI. Communication between vehicle and DT is designed for low latency, and the overall pattern combines distributed ROS 2 middleware with the ISO‑defined entity hierarchy to manage data collection, processing, and actuation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS uses a two‑layer communication stack. Inside each entity, software components are linked through a ROS 2 network (publish‑subscribe over DDS). Across entities, messages travel over a Wi‑Fi network employing UDP at the transport layer. The system must meet a synchronization accuracy of 100 ms, which defines the maximum tolerated latency for safety‑critical exchanges. No specific bandwidth figures are given. Redundancy or security protocols (e.g., TLS, encryption) are not mentioned in the provided documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Each functional element (FE) is implemented as an independent ROS 2 package that can be deployed on distinct hardware resources. Computation‑intensive services such as the ACC algorithm and Data Translation are off‑loaded to the Digital Twin Entity, which may run on cloud or edge resources, while sensor pre‑processing and actuation reside on the Physical Twin hardware. The architecture therefore supports a hybrid cloud‑edge deployment model, but the documents do not specify exact computational or storage sizing, scalability mechanisms, or availability guarantees."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is envisioned through standard interfaces defined by ISO 23247, such as OPC Unified Architecture (OPC UA), which can be employed for data exchange and device control. The DTS’s UI and remote‑management capabilities imply networked connectivity that can interoperate with enterprise platforms, although the specific protocols used in the demonstrated system are not detailed in the provided documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system is built around compliance with ISO 23247 (parts 1‑4), using its entity‑based reference architecture (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity). Functional Entities are instantiated as ROS 2 packages, which can interoperate with industry protocols such as OPC Unified Architecture. For safety‑critical automotive contexts the authors argue that ISO 26262 should be added as a first‑class standard, and they reference AUTOSAR as the de‑facto automotive software architecture that inspires the hardware‑agnostic deployment of FEs. Timing requirements of ≤ 100 ms clock synchronisation for safety‑critical vehicular applications are mentioned, reflecting alignment with automotive timing standards."
]