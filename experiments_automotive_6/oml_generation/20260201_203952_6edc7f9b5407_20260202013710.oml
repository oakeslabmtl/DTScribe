// C3: Physical sensing components
instance HokuyoUst10LxLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2D LiDAR providing real‑time surrounding point‑cloud data."
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelRealsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering dense 3D point‑clouds."
    DTDFVocab:producedData DepthCameraPointCloudTransmitted
]

instance EncoderSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board encoder speed sensor measuring ego vehicle longitudinal speed."
    DTDFVocab:producedData EgoSpeedTransmitted
]

instance EncoderSteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor (encoder) providing real‑time wheel steering angle."
    DTDFVocab:producedData SteeringAngleTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUst10LxLiDAR
]

instance DepthCameraPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealsenseD435iDepthCamera
]

instance EgoSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderSteeringAngleSensor
]

// C10: Data (raw and processed)
instance RawLiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream received from Hokuyo UST‑10LX."
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DBSCANClusteringEnabler
]

instance RawDepthCameraPointCloudData : DTDFVocab:Data [
    base:desc "Raw depth camera point‑cloud stream from Intel RealSense D435i."
    DTDFVocab:fromData DepthCameraPointCloudTransmitted
    DTDFVocab:inputTo DBSCANClusteringEnabler
]

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle longitudinal speed values."
    DTDFVocab:fromData EgoSpeedTransmitted
    DTDFVocab:inputTo ACCControlEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering angle of the vehicle."
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo ACCControlEnabler
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks generated by DBSCAN clustering and Kalman‑filter tracking."
    DTDFVocab:fromData RawLiDARPointCloudData
    DTDFVocab:inputTo ACCControlEnabler, ReportingEnabler
]

// C10: Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering algorithm used to segment objects."
    DTDFVocab:inputTo DBSCANClusteringEnabler
]

instance KalmanFilterTrackerModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based multi‑target tracker refining DBSCAN clusters."
    DTDFVocab:inputTo DBSCANClusteringEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) algorithm conforming to ISO 15622 performance class I."
    DTDFVocab:inputTo ACCControlEnabler
]

// C11: Enablers (ROS2 packages)
instance DataCollectionEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 package implementing the Data Collection Functional Entity for streaming sensor data."
    DTDFVocab:enables DataMonitoringUIService
]

instance DBSCANClusteringEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 package that runs DBSCAN clustering and Kalman tracking on incoming point‑clouds."
    DTDFVocab:enables ComputationOffloadingACCService
]

instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 package hosting the ACC control algorithm and exposing command interfaces."
    DTDFVocab:enables RemoteManagementUIService
]

instance ReportingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 package responsible for persisting object tracks, speed, and steering data into a SQL database and generating reports."
    DTDFVocab:enables ReportingService
]

// C6: Services
instance DataMonitoringUIService : DTDFVocab:Service [
    base:desc "UI displaying live ego speed, steering angle, object tracks and projected path."
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTracksInsight, ProjectedPathInsight
]

instance ComputationOffloadingACCService : DTDFVocab:Service [
    base:desc "Offloads ACC lead‑vehicle detection and speed computation to the Digital Twin."
    DTDFVocab:provides ACCStatusInsight
]

instance RemoteManagementUIService : DTDFVocab:Service [
    base:desc "Remote UI allowing operators to enable/disable ACC, set desired speed, and trigger emergency brake."
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Generates time‑series reports stored in a SQL database for post‑mission analysis."
    DTDFVocab:provides ReportGenerationInsight
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into vehicle speed and steering angle displayed on the monitoring UI."
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Visualization of detected object tracks and their trajectories."
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected future path of the ego vehicle based on current speed and steering."
]

instance ACCStatusInsight : DTDFVocab:Insight [
    base:desc "Current status of the Adaptive Cruise Control (enabled, target speed, lead distance)."
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Summary of generated reports indicating mission performance metrics."
]

// C17: Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets the desired cruise speed for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking via the Digital Twin."
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller that receives voltage commands to drive the vehicle speed."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo that receives angle commands to adjust wheel steering."
]

// Command data produced by ACCControlModel
instance SpeedCommandData : DTDFVocab:Data [
    base:desc "Voltage command data sent to the Vedder speed controller."
    DTDFVocab:fromData ACCControlModel
]

instance SteeringCommandData : DTDFVocab:Data [
    base:desc "Angle command data sent to the steering servo."
    DTDFVocab:fromData ACCControlModel
]

// Environment containing all physical components
instance MiniAutonomousVehiclePlatform : DTDFVocab:Environment [
    base:contains HokuyoUst10LxLiDAR, IntelRealsenseD435iDepthCamera, EncoderSpeedSensor, EncoderSteeringAngleSensor, VedderElectronicSpeedController, SteeringServoActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity sends desired speed set‑points, ACC enable/disable commands, emergency‑brake signals, and steering adjustments back to the vehicle via the Actuation Functional Entity, which converts them into motor voltage and servo commands."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real‑time operation with end‑to‑end network latency bounded at ≤100 ms and clock synchronization accuracy of 100 ms across all DTS components, satisfying 3GPP TS 22.185 requirements."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A distributed constellation where sensor data flows from the Physical Twin Entity over Wi‑Fi to the Digital Twin Entity (ROS2 network), the Digital Twin processes data, generates control commands and visualizations, and the User Entity provides a UI on a separate workstation; a Cross‑System Data Translation FE harmonises message formats and units."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is used during the operational stage for monitoring, control, and remote management, and also during development/testing as a cyber‑physical experimentation platform for the ACC subsystem."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT maintains high fidelity by using raw LiDAR point clouds and real‑time vehicle state; validity is ensured through latency ≤100 ms, clock sync ≤100 ms, and compliance with ISO 15622 ACC specifications; reporting and SQL storage enable post‑run verification of model outputs."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication uses a Wi‑Fi network employing ROS 2 topics; the Data Translation FE serialises data, aligns message types and performs unit conversion; intra‑entity communication also relies on ROS 2 DDS transport."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity components run on the vehicle’s Jetson Orin Nano; Digital Twin Entity components run on an external compute platform (e.g., PC or cloud) hosting ROS 2 nodes for ACC, clustering, and visualization; User Entity UI runs on a workstation connected via the same Wi‑Fi network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The design follows ISO 23247 reference architecture, uses ISO 15622 for ACC functionality, references ISO/IEC 30173 for digital‑twin concepts, and adopts 3GPP TS 22.185 for latency requirements; ROS 2 provides a standardized middleware layer."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by enforcing a hard latency bound (≤100 ms), clock synchronization (≤100 ms), and implementing emergency‑brake commands; the DT operates in a Human‑in‑the‑Loop fully autonomous mode, with remote actions limited to safety‑critical commands, though specific cybersecurity mechanisms are not detailed."
]