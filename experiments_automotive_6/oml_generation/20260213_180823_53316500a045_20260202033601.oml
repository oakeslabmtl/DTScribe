// C1: Physical Twin Entity Components
instance PhysicalChassisLayer1 : DTDFVocab:Component [
    base:desc "Lower chassis layer of the 1/10-scale teleoperated autonomous vehicle, handling structural mechanics and basic mobility functions in ACC domain"
]

instance PhysicalChassisLayer2 : DTDFVocab:Component [
    base:desc "Upper chassis layer of the 1/10-scale teleoperated autonomous vehicle, managing advanced mobility control and sensor integration for ACC system"
]

instance AdvancedSensorAndControlSystem : DTDFVocab:Component [
    base:desc "Advanced sensor and control technology retrofitted to the vehicle, featuring resource-constrained ECUs with computation offloading for safety-critical ADAS operations"
]

instance AutonomousVehicleAutonomyModule : DTDFVocab:Component [
    base:desc "Core autonomy element implementing Adaptive Cruise Control (ACC) algorithms with resource-constrained ECU processing"
]

// C2: Acting Components
instance ActuatorSteeringSystem : DTDFVocab:ActingComponent [
    base:desc "Steering actuation system for the teleoperated autonomous vehicle, interfacing with upper chassis layer for directional control"
]

instance ActuatorBrakingSystem : DTDFVocab:ActingComponent [
    base:desc "Emergency braking actuation system for the vehicle, offloaded to cloud resources during computation-intensive operations"
]

instance ActuatorSpeedControlSystem : DTDFVocab:ActingComponent [
    base:desc "Speed adjustment actuation system implementing ACC lead vehicle detection and speed calculation algorithms"
]

// C3: Physical Sensing Components
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor capturing 3D point clouds for object detection and tracking in ACC domain"
    DTDFVocab:producedData LiDARPointCloudData
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor monitoring speed, position, and orientation data for ACC system"
    DTDFVocab:producedData VehicleStateData
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor providing real-time servo input data for vehicle control"
    DTDFVocab:producedData SteeringInputData
]

instance ServoPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Servo position sensor tracking actuator positions for precise vehicle control"
    DTDFVocab:producedData ServoPositionData
]

// C4: Data Transmitted
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance SteeringInputData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ServoPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ServoPositionSensor
]

// C5: Data Processing Components
instance PointCloudClusteringTracker : DTDFVocab:Component [
    base:desc "Software component processing raw LiDAR point clouds into clustered and tracked 2D plane data for ACC system"
]

instance DataTranslationService : DTDFVocab:Component [
    base:desc "Data translation service serializing, aligning message types, and performing unit conversions for all data streams"
]

// C6: Digital Twin Entity Components
instance DigitalTwinCore : DTDFVocab:Component [
    base:desc "Core digital twin implementation handling real-time visualization, computation offloading, and remote management"
]

instance ROS2NodeEnvironment : DTDFVocab:Component [
    base:desc "ROS2 package environment containing all digital twin nodes with inter-node communication via ROS2"
]

// C7: User Entity Components
instance UserInterfaceVisualization : DTDFVocab:Component [
    base:desc "3D visualization component of the user interface showing real-time vehicle state, projected paths, and object tracks"
]

instance UserInterfaceControlPanel : DTDFVocab:Component [
    base:desc "Control panel subcomponent of the user interface for ACC system management (speed setting, enable/disable, emergency braking)"
]

// C8: Models/Data
instance ACCLeadVehicleDetectionModel : DTDFVocab:Model [
    base:desc "Machine learning model for detecting lead vehicles in ACC system with computation offloading capabilities"
]

instance SpeedCalculationModel : DTDFVocab:Model [
    base:desc "Speed calculation model determining ACC speed based on distance to lead vehicle using processed LiDAR data"
]

instance ProjectedDrivingPathData : DTDFVocab:Data [
    base:desc "Model-generated data representing projected driving paths based on current vehicle state and sensor inputs"
    DTDFVocab:fromData VehicleStateData, LiDARPointCloudData
]

instance ObjectDetectionData : DTDFVocab:Data [
    base:desc "Processed data from LiDAR point clouds showing detected objects and their tracks for ACC system"
    DTDFVocab:fromData LiDARPointCloudData
]

// C9: Enablers
instance ROS2CommunicationEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 communication framework enabling inter-node communication between digital twin components"
    DTDFVocab:inputTo PointCloudClusteringTracker, DataTranslationService, UserInterfaceVisualization
]

instance CloudComputationEnabler : DTDFVocab:Enabler [
    base:desc "Cloud-based computation offloading service handling ACC system lead vehicle detection and speed calculations"
    DTDFVocab:inputTo ACCLeadVehicleDetectionModel, SpeedCalculationModel
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Remote management interface for enabling/disabling ACC, setting desired speeds, and triggering emergency braking"
    DTDFVocab:inputTo UserInterfaceControlPanel
]

// C10: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time data monitoring service providing visualization of vehicle state, projected driving paths, and detected object tracks with reporting capabilities"
    DTDFVocab:provides VehicleStateVisualizationInsight, ObjectTrackVisualizationInsight, PerformanceReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation offloading service handling ACC system lead vehicle detection and speed calculations offloaded to cloud resources"
    DTDFVocab:provides LeadVehicleDetectionResult, SpeedAdjustmentCommand
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management service enabling ACC system control via user interface (enable/disable, speed setting, emergency braking)"
    DTDFVocab:provides SystemEnableAction, SpeedSettingAction, EmergencyBrakeAction
]

// C11: Insights/Actions
instance VehicleStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of vehicle state parameters (speed, position, orientation) displayed in 3D visualization"
]

instance ObjectTrackVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of detected objects and their trajectories in the vehicle's field of view"
]

instance PerformanceReportAction : DTDFVocab:Action [
    base:desc "Generated report summarizing system performance metrics and detected anomalies for troubleshooting"
    DTDFVocab:IsAutomatic true
]

instance LeadVehicleDetectionResult : DTDFVocab:Insight [
    base:desc "Result of lead vehicle detection algorithm showing detected vehicles and their relative positions"
]

instance SpeedAdjustmentCommand : DTDFVocab:Action [
    base:desc "Automatically generated speed adjustment command based on distance to lead vehicle"
    DTDFVocab:IsAutomatic true
]

instance SystemEnableAction : DTDFVocab:Action [
    base:desc "User-initiated action to enable the ACC system"
    DTDFVocab:IsAutomatic false
]

instance SpeedSettingAction : DTDFVocab:Action [
    base:desc "User action to set desired speed for ACC system"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "User-initiated emergency braking command for safety-critical situations"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands for Adaptive Cruise Control (ACC) are processed by the Controlling FE, serialized via the Data Translation component, and transmitted over Wi-Fi UDP to the Actuation FE for motor and steering servo actuation. Command types beyond ACC, message formats, validation/authentication mechanisms, feedback systems, and execution confirmation details are not specified."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires 100 ms clock synchronization accuracy for computation offloading between devices, adhering to safety-critical vehicular standards but constrained by hardware limitations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows ISO 23247 RA, organizing software components into three entities mapped to ROS2 packages. Each entity is deployed on dedicated hardware: Physical Twin Entity (handling general automotive functions like Point Cloud Clustering & Tracking), Digital Twin Entity (data management and control), and User Entity (3D Visualization and Control Panel). This deviates from ISO 23247 by extending the Physical Twin Entity beyond the standard's OME to encompass broader system resources."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Internal software components communicate via ROS2, while inter-entity communication uses Wi-Fi with UDP transport layer. Network topology, bandwidth, latency requirements, reliability mechanisms, and security protocols are not detailed in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with ISO 23247:2021 Digital Twin Framework for Manufacturing standard, which includes four parts: Overview and general principles (Part 1), Reference architecture (Part 2), Digital representation of physical manufacturing elements (Part 3), and Information exchange (Part 4). Part 2 defines an entity-based reference architecture comprising Observable Manufacturing Elements (OME), Data Collection and Device Control Entity, Digital Twin Entity, and User Entity. Functional Entities (FEs) implement specific tasks, with OPC Unified Architecture (OPC UA) cited as a possible implementation for interoperability."
]