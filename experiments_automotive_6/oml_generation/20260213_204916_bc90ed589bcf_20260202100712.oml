// Physical Sensing Components
instance HokuyoUST10LxLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2‑D LiDAR delivering real‑time point clouds"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense‑D435i depth camera providing 3‑D depth maps and RGB imagery"
    DTDFVocab:producedData DepthMapTransmitted
]

instance VehicleECUSensors : DTDFVocab:SensingComponent [
    base:desc "Vehicle ECU sensors delivering speed, steering‑angle, and inertial‑navigation outputs over CAN bus"
    DTDFVocab:producedData VehicleStateTransmitted
]

// Data Transmitted from Sensors
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LxLiDAR
]

instance DepthMapTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleECUSensors
]

// Virtual Data after Processing
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Processed LiDAR point cloud after unit conversion"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ClusteringFEEnabler
]

instance DepthMapData : DTDFVocab:Data [
    base:desc "Depth map after unit conversion"
    DTDFVocab:fromData DepthMapTransmitted
    DTDFVocab:inputTo DepthProcessingEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state after timestamp alignment"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo TrackingFEEnabler
]

// Enablers
instance ClusteringFEEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity performing point‑cloud clustering with DBSCAN"
    DTDFVocab:enables PointCloudClusteringService
]

instance DepthProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity processing depth maps for 3‑D visualization"
    DTDFVocab:enables DepthVisualizationService
]

instance TrackingFEEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity tracking clustered points with Kalman filter and providing ego‑vehicle state"
    DTDFVocab:enables ObjectTrackingService, DataMonitoringService, StorageService
]

instance RemoteManagementFEEnabler : DTDFVocab:Enabler [
    base:desc "User interface functional entity enabling remote management actions"
    DTDFVocab:enables RemoteManagementService
]

instance CloudComputeEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for offloading the ACC algorithm to cloud compute resources"
    DTDFVocab:enables ComputationOffloadingService
]

instance ControlCommandServiceEnabler : DTDFVocab:Enabler [
    base:desc "Actuation functional entity controlling the Vedder ESC over OPC UA"
    DTDFVocab:enables ControlCommandService
]

// Storage Functional Entity
instance StorageFEEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity enabling storage of processed data in a relational SQL database"
    DTDFVocab:enables StorageService
]

// Models
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Clusters LiDAR point cloud with DBSCAN clustering algorithm"
    DTDFVocab:inputTo ClusteringFEEnabler
]

instance ObjectTrackingModel : DTDFVocab:Model [
    base:desc "Tracks clusters using a Kalman filter to estimate pose and velocity"
    DTDFVocab:inputTo TrackingFEEnabler
]

instance DataStorageModel : DTDFVocab:Model [
    base:desc "Persists processed state vectors in a relational SQL database"
    DTDFVocab:inputTo StorageFEEnabler
]

// Services
instance PointCloudClusteringService : DTDFVocab:Service [
    base:desc "Processes raw point cloud and outputs clustered point sets"
    DTDFVocab:provides ClusteringResultInsight
]

instance DepthVisualizationService : DTDFVocab:Service [
    base:desc "Renders depth maps and RGB imagery in a 3‑D visualization"
    DTDFVocab:provides DepthVisualizationInsight
]

instance ObjectTrackingService : DTDFVocab:Service [
    base:desc "Tracks surrounding objects and provides per‑object state vectors"
    DTDFVocab:provides ObjectTrackingInsight
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI displays vehicle state, projected paths, and detected object tracks allows saving and generating reports"
    DTDFVocab:provides VehicleStateInsight, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads the ACC algorithm to cloud compute computes desired speed and returns command to vehicle"
    DTDFVocab:provides ACCCommandInsight, ExecuteACCCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, and issue emergency braking via UI"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, IssueEmergencyBrakingAction
]

instance StorageService : DTDFVocab:Service [
    base:desc "Stores processed state vectors and vehicle events in the SQL database"
    DTDFVocab:provides DataPersistedInsight
]

instance ControlCommandService : DTDFVocab:Service [
    base:desc "Writes control commands to the Vedder ESC via an OPC UA writable node"
    DTDFVocab:provides ExecutionConfirmationAction
]

// Insights
instance ClusteringResultInsight : DTDFVocab:Insight [
    base:desc "Clustered point cloud representation of surrounding objects"
]

instance DepthVisualizationInsight : DTDFVocab:Insight [
    base:desc "3‑D visualization of depth maps and RGB imagery"
]

instance ObjectTrackingInsight : DTDFVocab:Insight [
    base:desc "Per‑object state vectors with position, velocity, and class label"
]

instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time vehicle state data including speed, steering angle, GPS position"
]

instance ACCCommandInsight : DTDFVocab:Insight [
    base:desc "Desired speed command generated by the ACC algorithm in the cloud"
]

instance DataPersistedInsight : DTDFVocab:Insight [
    base:desc "Confirmation that processed data has been persisted in the relational database"
]

// Actions
instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Generate and save a report from real‑time UI data"
    DTDFVocab:IsAutomatic false
]

instance ExecuteACCCommandAction : DTDFVocab:Action [
    base:desc "Execute ACC command sent from cloud to vehicle"
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance IssueEmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Issue emergency braking command"
    DTDFVocab:IsAutomatic false
]

instance ExecutionConfirmationAction : DTDFVocab:Action [
    base:desc "Confirm command execution on the Vedder ESC"
    DTDFVocab:IsAutomatic false
]

// Acting Component
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder ESC translating desired vehicle speed into motor voltage signals applied to the drive motor"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands flow from the Digital Twin to the physical vehicle through the same Wi‑Fi/UDP channel. The ACC subsystem sends desired speed setpoints that are translated into motor actuation messages by the Actuation FE. The User Interface FE can issue emergency braking commands, which are serialized by the Data Translation FE, authenticated and validated by the Controlling FE before being forwarded to the vehicle. Feedback on command execution is provided by sensor streams (e.g., updated vehicle speed and brake status) which are consumed by the Data Monitoring service and displayed in real time. Conflict resolution mechanisms and detailed authentication procedures are not specified in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Physical and digital twin components share a common clock reference and must maintain a clock synchronization accuracy of no more than 100 milliseconds, in accordance with safety‑critical vehicular standards. The architecture requires that any data exchange between the physical sensors, actuator controllers, and the digital twin’s computational nodes respects this temporal bound, ensuring that end‑to‑end latency from sensor acquisition to actuator command execution does not exceed 100 milliseconds. No further synchronization frequency or protocol specifications are provided in the source documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 Reference Architecture, mapping functional software components into three core entities – User, Digital Twin, and Physical Twin – and then deploying each Feature Extractor (FE) as a distinct ROS 2 package comprising one or more ROS 2 nodes.  The Digital Twin Entity houses data‑management and control logic, the Physical Twin Entity handles pre‑processing, point‑cloud clustering, tracking, and device communication, while the User Entity provides a 3 D visualization and control‑panel interface.  Resource allocation, communication, and coordination are managed by ROS 2 middleware under the umbrella of the ISO 23247 orchestration framework, ensuring modularity and clear ownership of functionality across heterogeneous hardware components."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin’s technical network comprises a ROS2 intra‑process communication layer and a Wi‑Fi based inter‑entity communication layer that uses UDP in the transport layer. The Wi‑Fi link is expected to sustain a maximum end‑to‑end latency of 100 ms to meet real‑time performance requirements. Bandwidth requirements are not quantified, but the architecture assumes sufficient capacity to transmit high‑frequency LiDAR point clouds and vehicle telemetry. Reliability strategies such as packet retransmission or redundant links are not described, and no specific security protocols are enumerated beyond the use of authentication within the Controlling FE."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin components are distributed across heterogeneous hardware: compute resources are allocated to equipment best suited for the workload, including options in the cloud or on‑premise, while data storage resides on a device external to the vehicle. Deployment models support modular placement of entities on distinct hardware components, allowing scalability by adding or relocating compute nodes. Availability and reliability are implied by deploying functional elements on separate devices, but explicit redundancy or high‑availability configurations are not detailed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin is compliant with ISO 23247 – Digital twin framework for manufacturing, Part 2: Reference Architecture, which prescribes an entity‑based reference architecture and mandates adherence to ISO guidance for digital twin implementation. Interoperability is achieved by implementing OPC Unified Architecture (OPC UA) for data exchange between the Data Collection and Device Control Entity and the observed manufacturing elements, enabling integration with existing manufacturing execution systems (MES) and enterprise resource planning (ERP) platforms. No additional certification or compliance frameworks are specified in the provided documents."
]