// ----- Sensing Components -----
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "Acquires raw LiDAR point–cloud data from the vehicle tire sensors."
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors electrical drive status from the vehicle motor drives."
    DTDFVocab:producedData MotorStatusDataTransmitted
]

instance SteeringServoPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Reports positional feedback from the vehicle steering servos."
    DTDFVocab:producedData SteeringServoPositionDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Collects overall vehicle dynamics state such as speed, yaw rate, and GPS pose."
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// ----- Data Transmitted -----
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance SteeringServoPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoPositionSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// ----- Data -----
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Segmentation and clustering of raw LiDAR point cloud data for obstacle detection."
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
    DTDFVocab:inputTo ROS2MiddleWare
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Encoded motor drive status for telemetry."
    DTDFVocab:fromData MotorStatusDataTransmitted
    DTDFVocab:inputTo ROS2MiddleWare
]

instance SteeringServoPositionData : DTDFVocab:Data [
    base:desc "Current steering servo angular position for control feedback."
    DTDFVocab:fromData SteeringServoPositionDataTransmitted
    DTDFVocab:inputTo ROS2MiddleWare
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state vector including speed, heading and location."
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo ROS2MiddleWare
]

// ----- Models -----
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Performs point cloud clustering and object tracking on LiDAR data."
    DTDFVocab:inputTo ROS2MiddleWare
]

instance DataStorageModel : DTDFVocab:Model [
    base:desc "Persist collected telemetry and processed data to local storage."
    DTDFVocab:inputTo ROS2MiddleWare
]

instance VisualizationModel : DTDFVocab:Model [
    base:desc "Renders 3D visualization of vehicle state and object tracks."
    DTDFVocab:inputTo ROS2MiddleWare
]

instance ACCAlgorithmModel : DTDFVocab:Model [
    base:desc "Executes Adaptive Cruise Control (ACC) algorithm for lead–vehicle detection and desired speed calculation."
    DTDFVocab:inputTo ROS2MiddleWare
]

instance ISO12347DataTranslationModel : DTDFVocab:Model [
    base:desc "Serialises and aligns incoming data streams, performs unit conversions, and serialises to ISO12347 message format."
    DTDFVocab:inputTo ROS2MiddleWare
]

// ----- Enablers -----
instance ROS2MiddleWare : DTDFVocab:Enabler [
    base:desc "ROS2 middleware network facilitating message passing over UDP via Wi‑Fi."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance UserInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "GUI front‑end enabling real‑time data monitoring and remote management."
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance CloudComputeEnabler : DTDFVocab:Enabler [
    base:desc "Cloud compute infrastructure hosting off‑board computation tasks."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Low‑latency bidirectional control channel for remote command execution."
    DTDFVocab:enables RemoteManagementService
]

// ----- Services -----
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Streams real‑time vehicle state, path projection, and detected object tracks supports viewing, saving, and generating reports."
    DTDFVocab:provides InsightVehicleStateVisualization, ActionSaveReport, ActionGenerateReport
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm on the cloud and sends resulting speed command back to vehicle for actuation."
    DTDFVocab:provides InsightComputedSpeed, ActionSendSpeedCommand
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set a target speed, and issue emergency braking commands via the UI."
    DTDFVocab:provides InsightRemoteCommandStatus, ActionSetTargetSpeed, ActionEmergencyBrake
]

// ----- Insights -----
instance InsightVehicleStateVisualization : DTDFVocab:Insight [
    base:desc "Visual representation of vehicle dynamics and surroundings in 3D."
]

instance InsightComputedSpeed : DTDFVocab:Insight [
    base:desc "Computed desired speed from ACC algorithm."
]

instance InsightRemoteCommandStatus : DTDFVocab:Insight [
    base:desc "Real‑time status of remote commands executed by the vehicle."
]

// ----- Actions -----
instance ActionSaveReport : DTDFVocab:Action [
    base:desc "Saves current telemetry snapshot as a report file."
    DTDFVocab:IsAutomatic false
]

instance ActionGenerateReport : DTDFVocab:Action [
    base:desc "Generates structured report from collected data."
    DTDFVocab:IsAutomatic false
]

instance ActionSendSpeedCommand : DTDFVocab:Action [
    base:desc "Sends calculated desired speed command to physical vehicle actuators."
    DTDFVocab:IsAutomatic true
]

instance ActionSetTargetSpeed : DTDFVocab:Action [
    base:desc "Sets target speed for ACC algorithm via user interface."
    DTDFVocab:IsAutomatic false
]

instance ActionEmergencyBrake : DTDFVocab:Action [
    base:desc "Triggers emergency braking command directly to vehicle actuators."
    DTDFVocab:IsAutomatic true
]

// ----- Acting Components -----
instance MotorDrive : DTDFVocab:ActingComponent [
    base:desc "Electric motor drive unit converting commanded speed to electrical signals."
]

instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Servo motor that translates steering commands into wheel angles."
]

// ----- Tooling & Enablers -----
instance ToolingROS2 : DTDFVocab:Component [
    base:desc "Robot Operating System 2 used as middleware for ROS2 nodes."
]

instance ToolingNvidiaJetpack500 : DTDFVocab:Component [
    base:desc "NVIDIA JetPack 5.0 SDK providing CUDA, TensorRT, and other GPU acceleration libraries."
]

instance ToolingPython38 : DTDFVocab:Component [
    base:desc "Python 3.8 runtime used for application modules."
]

instance ToolingCpp : DTDFVocab:Component [
    base:desc "C++ language used for performance‑critical modules."
]

instance ToolingMatlabSimulink : DTDFVocab:Component [
    base:desc "MATLAB/Simulink for model‑based development of perception and planning algorithms."
]

// ----- Entities (Components) -----
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical 1/10‑scale autonomous vehicle, hosting lidar, drive, and control systems."
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital twin cluster hosting ROS2 nodes, data storage, and computational services."
]

instance UserEntity : DTDFVocab:Component [
    base:desc "Operator platform providing UI for monitoring, management, and command input."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin computes ACC control outputs (e.g., desired speed, enable/disable ACC, emergency‑brake command) and sends them back to the physical twin. Commands are issued from the Controlling FE / User Interface FE to the Actuation FE, which drives the vehicle actuators (motor, steering servo). The messages are transmitted over the same Wi‑Fi UDP link and are handled within the ROS 2 network of the DT. The documents do not detail the exact command message format, validation/authentication mechanisms, conflict‑resolution logic, or explicit execution acknowledgements."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT requires clock synchronization between devices with an accuracy of 100 ms, as hardware limits prevent tighter synchronization; this aligns with many safety‑critical vehicular standards that demand sub‑100 ms sync. Synchronization is needed for computation offloading and coordinated operation of the Physical Twin Entity and Digital Twin Entity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration is realized by mapping each Functional Entity to an individual ROS2 package; the packages contain one or more ROS2 nodes that communicate over DDS. The overall system follows the ISO 23247 reference architecture, with the Physical Twin Entity handling resource‑specific functions (point‑cloud clustering, tracking, actuation), the Digital Twin Entity providing data management and control, and the User Entity exposing a 3‑D visualization and control‑panel UI. Coordination across entities is achieved through ROS2 topics/services, enabling runtime resource management and component integration across the three hardware platforms."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Time synchronization is a key validity requirement for the twin; devices must share a common notion of time with an accuracy of at least 100 ms, imposed by hardware limitations. While stricter synchronization (sub‑100 ms) is mandated by safety‑critical vehicular standards, the system adopts the 100 ms bound to balance feasibility and safety. No further model fidelity, validation, or uncertainty quantification methods are described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS comprises two communication layers: (1) an intra‑system ROS2 (DDS) network that interconnects all software components (Data Translation, Point Cloud Clustering, Controlling FE, etc.) and (2) an inter‑entity Wi‑Fi link that transports data between the physical twin and the digital twin using UDP at the transport layer. No quantitative bandwidth or latency values are given; however, Document 2 notes that the system must support low end‑to‑end latency communication to satisfy safety‑critical requirements. The documents do not mention redundancy mechanisms, security protocols (e.g., encryption, authentication), or specific network topology beyond the client‑server style flow implied by UI → Controlling FE → Wi‑Fi → Physical twin."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT services (Data Monitoring, Computation Offloading, Remote Management) are intended to run on equipment that can provide higher computational resources than the on‑board ECU, with the example of offloading the ACC logic to the cloud. The documents do not specify the concrete hosting platform (cloud provider, edge node, on‑premise server), the required CPU/memory/storage capacities, scalability mechanisms, deployment models (container, VM, etc.) or availability guarantees."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system is built according to the ISO 23247 digital‑twin framework for manufacturing. It adopts the ISO 23247 reference architecture, defining entities such as the Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity and User Entity, and implements Functional Entities as ROS 2 packages. For temporal coordination the design follows safety‑critical vehicular standards that require clock synchronization tighter than 100 ms; the implementation enforces a 100 ms accuracy bound as dictated by those standards."
]