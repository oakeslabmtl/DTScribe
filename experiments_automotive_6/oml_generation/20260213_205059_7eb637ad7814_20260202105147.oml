// C1: Core physical machine
instance TraxxasSlashVehicle : DTDFVocab:Component [
    base:desc "1/10‑scale autonomous vehicle built from a Traxxas Slash 4×4 Premium chassis, retrofitted with an NVIDIA Jetson Orin Nano, Hokuyo UST‑10LX LiDAR, Intel D435i depth camera, and Vedder ESC."
]

// C1: Physical twin (on Jetson Orin)
instance JetsonOrinNano : DTDFVocab:Component [
    base:desc "Physical twin entity executing ROS 2 nodes for data collection, processing, and control on the vehicle."
]

// C1: Digital twin (remotely hosted)
instance RemoteACCServer : DTDFVocab:Component [
    base:desc "Digital twin entity hosting ACC controller, data storage, and reporting logic on a remote compute server."
]

// C1: User interface
instance WebBasedUI : DTDFVocab:Component [
    base:desc "Web‑based UI providing user control and visualization, connected via ROS 2 over Wi‑Fi."
]

// C2: Acting components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller commanding vehicle longitudinal actuation."
]
instance SteeringServoMotor : DTDFVocab:ActingComponent [
    base:desc "Servo motor commanded for lateral steering actuation via digital twin."
]

// C3: Physical sensing components
instance WheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel encoder or speed‑measurement unit reporting ego vehicle speed."
    DTDFVocab:producedData WheelSpeedDataTransmitted
]
instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering column angle sensor reporting lateral wheel angle."
    DTDFVocab:producedData SteeringAngleDataTransmitted
]
instance HokuyoLidarSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR supplying raw point clouds for clustering and tracking."
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]
instance IntelDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera providing depth images for sensor fusion."
    DTDFVocab:producedData DepthImageDataTransmitted
]

// C4: Physical‑to‑virtual data transfer
instance WheelSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedSensor
]
instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLidarSensor
]
instance DepthImageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCameraSensor
]

// C5: Data objects
instance WheelSpeedData : DTDFVocab:Data [
    base:desc "Serialised ego vehicle speed data transmitted from wheel‐speed sensor."
    DTDFVocab:fromData WheelSpeedDataTransmitted
    DTDFVocab:inputTo ROS2DDSMiddleware
]
instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Serialised steering angle data transmitted from steering‑angle sensor."
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo ROS2DDSMiddleware
]
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data transmitted for processing."
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
    DTDFVocab:inputTo ROS2DDSMiddleware
]
instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image data transmitted from Intel D435i camera."
    DTDFVocab:fromData DepthImageDataTransmitted
    DTDFVocab:inputTo ROS2DDSMiddleware
]
instance LiDARClusteredData : DTDFVocab:Data [
    base:desc "Clusters of LiDAR point cloud produced by DBSCAN clustering."
    DTDFVocab:inputTo ROS2DDSMiddleware
]
instance KalmanObjectTrackData : DTDFVocab:Data [
    base:desc "Kalman‑filter‑tracked object trajectories derived from LiDAR clusters."
    DTDFVocab:inputTo ROS2DDSMiddleware
]
instance ACCCommandData : DTDFVocab:Data [
    base:desc "ACC controller commands for desired following speed following ISO 15622."
    DTDFVocab:inputTo ROS2DDSMiddleware
]
instance Rendering3DData : DTDFVocab:Data [
    base:desc "3‑D rendering data for real‑time visualization of vehicle state and surroundings."
    DTDFVocab:inputTo ROS2DDSMiddleware
]

// C10: Models
instance DBSCANClusterModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of raw LiDAR point clouds for object segmentation."
    DTDFVocab:inputTo ROS2DDSMiddleware
]
instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter tracking of detected objects to produce trajectories."
    DTDFVocab:inputTo ROS2DDSMiddleware
]
instance ACCControllerModel : DTDFVocab:Model [
    base:desc "Adaptive cruise control controller computing desired following speed per ISO 15622."
    DTDFVocab:inputTo ROS2DDSMiddleware
]
instance Presentation3DModel : DTDFVocab:Model [
    base:desc "3‑D presentation model rendering vehicle state and environmental data."
    DTDFVocab:inputTo ROS2DDSMiddleware
]

// C11: Enablers
instance ROS2DDSMiddleware : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware with DDS enabling communication between vehicle and remote server."
    DTDFVocab:enables RealTimeDashboardService, ACCOffloadingService, ACCManagementService, ReportGenerationService
]

// C6: Services
instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Real‑time dashboard providing vehicle state, projected path, and surrounding object tracks."
    DTDFVocab:provides RealTimeDashboardInsight
]
instance ACCOffloadingService : DTDFVocab:Service [
    base:desc "Computation offloading service delivering ACC algorithm to a remote server."
]
instance ACCManagementService : DTDFVocab:Service [
    base:desc "Remote management service for ACC: enable/disable, desired‑speed adjustment, and emergency braking."
    DTDFVocab:provides SetDesiredSpeedAction, ToggleACCAction, EmergencyBrakeAction
]
instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Service generating time‑series reports for performance analysis."
    DTDFVocab:provides ReportGenerationInsight
]

// C17: Actions
instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator action to set desired following speed for ACC."
    DTDFVocab:IsAutomatic false
]
instance ToggleACCAction : DTDFVocab:Action [
    base:desc "Operator action to enable or disable the ACC system."
    DTDFVocab:IsAutomatic false
]
instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator action to trigger emergency braking."
    DTDFVocab:IsAutomatic false
]

// C17: Insights
instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Insight presenting real‑time vehicle state and object tracking on the dashboard."
]
instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight summarising time‑series performance reports for analysis."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin publishes ACC‑derived control commands—desired speed to the Electronic Speed Controller, steering velocity to the steering servo, and optional emergency braking commands—over Wi‑Fi using ROS 2 topics, packaged by the Data Translation Functional Entity and delivered to the vehicle’s on‑board Jetson."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is required to maintain end‑to‑end network latency of ≤100 ms from vehicle to DT entity and to synchronise internal clocks across entities with an accuracy of ≤100 ms, per requirements R7 and R8."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An ISO 23247‑aligned constellation with a Physical Twin Entity on the vehicle, a Digital Twin Entity achieving ACC computation and data management, a User Entity providing 3D visualization and control, and a Cross‑System Entity performing data translation; entities communicate over Wi‑Fi via ROS 2 (DDS) ensuring real‑time data flow."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design/development (DT software defined and mapped to ISO 23247 architecture), Manufacturing (physical vehicle built and instrumented), and Operation (DT running in real‑time for monitoring, remote management, and computation offloading of ACC). The DT represents the vehicle in its operated state."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity ensured by using well‑known algorithms (DBSCAN, Kalman filter, ISO 15622 ACC controller). Validation achieved through real‑time monitoring dashboards, report generation, and comparison against vehicle telemetry. Latency constraints (≤100 ms) serve as a safety‑critical validation metric; clock synchronization provides event ordering guarantees."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between physical twin and DT is via Wi‑Fi; ROS 2 middleware facilitates inter‑entity communication and inter‑entity communication over the network; a Data Translation FE serialises and aligns messages. No mention of specific TCP/UDP payloads or NTP, but ROS 2 uses DDS over transport."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "DT services hosted on a remote compute server (cloud or edge) receiving sensor data from the vehicle’s Jetson Orin Nano; the Physical Twin runs on the vehicle’s onboard hardware; the User Entity (web UI) can be hosted locally or on a web server accessed via the internet."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Architecture follows ISO 23247 (reference architecture for digital twins); ACC controller complies with ISO 15622; communication relies on ROS 2 middleware (DDS) which is an open standard; data processing algorithms follow standard machine‑learning/statistical methods (DBSCAN, Kalman)."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety-critical constraints include maintaining ≤100 ms end‑to‑end latency, synchronising clocks to ≤100 ms, and ensuring human‑in‑the‑loop control. No explicit security mechanisms are described, but the system’s safety is addressed by the latency and synchronization requirements."
]