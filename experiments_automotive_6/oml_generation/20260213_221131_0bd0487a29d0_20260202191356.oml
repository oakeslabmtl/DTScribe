]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "Robot Operating System 2 middleware for deterministic message delivery and interoperability between software components in the automotive CPS"
    DTDFVocab:enables ROS2ComponentCommunication
    DTDFVocab:enables ROS2NetworkLatencyControl
]

instance ROS2ComponentCommunication : DTDFVocab:Enabler [
