    base:desc "Embedded sensors collecting real-time vehicle state data (motor, steering, servo actuation) for autonomous vehicle validation"
    DTDFVocab:producedData VehicleStateData
]

// C4: Physical-to-virtual interaction
instance PointCloudClusteringTrackingFE : DTDFVocab:FunctionalEntity [
    base:desc "Software component for clustering and tracking LiDAR point cloud data into structured object tracks and ego-vehicle state representations"
]

instance DataPreProcessingFE : DTDFVocab:FunctionalEntity [
    base:desc "Functional entity for preprocessing sensor data streams (normalization, alignment, validation) for consistency across heterogeneous inputs"
]

instance DataTranslationFE : DTDFVocab:FunctionalEntity [
    base:desc "Functional entity for translating and converting data formats between different processing stages"
]

instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance PreprocessedSensorData : DTDFVocab:Data [
    base:desc "Normalized and aligned sensor data streams (LiDAR, motor, steering, servo) for consistency across heterogeneous inputs"
    DTDFVocab:fromData DataPreProcessingFE
    DTDFVocab:inputTo DataTranslationFE
]

instance ObjectDetectionTracks : DTDFVocab:Data [
    base:desc "Structured object detection tracks and ego-vehicle state representations derived from LiDAR data processing"
    DTDFVocab:fromData PointCloudClusteringTrackingFE
    DTDFVocab:inputTo UserInterfaceFE
]

instance EgoVehicleState : DTDFVocab:Data [
    base:desc "Digital representation of vehicle state parameters (motor, steering, servo actuation) for real-time synchronization"
