    DTDFVocab:provides DataPreprocessingAction
]

instance ActuationService : DTDFVocab:Service [
    base:desc "Closed-loop control mechanism for dynamic adjustments of autonomous vehicle parameters (e.g., motor voltage signals) with safety constraints"
