    DTDFVocab:enables ActuationService
]

instance MATLABSimulation : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink platform for high-fidelity simulation of complex subsystems (sensor fusion, control algorithms) in autonomous driving"
