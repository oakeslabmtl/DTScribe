// Sensing Components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR providing 3D point cloud data"
    DTDFVocab:producedData LiDARPointCloudData
]

instance DepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera generating depth images"
    DTDFVocab:producedData DepthImageData
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor integrated into the Traxxas platform"
    DTDFVocab:producedData VehicleSpeedData
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring the vehicle’s wheel position"
    DTDFVocab:producedData SteeringAngleData
]

// Data Transmitted
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance DepthImageData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DepthCameraSensor
]

instance VehicleSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Data
instance LiDARPointCloud : DTDFVocab:Data [
    base:desc "3D point cloud data from Hokuyo LiDAR"
    DTDFVocab:fromData LiDARPointCloudData
    DTDFVocab:inputTo DataCollectionEnabler
]

instance DepthImage : DTDFVocab:Data [
    base:desc "Depth image from Intel RealSense camera"
    DTDFVocab:fromData DepthImageData
    DTDFVocab:inputTo DataCollectionEnabler
]

instance VehicleSpeed : DTDFVocab:Data [
    base:desc "Stamped vehicle speed measurement"
    DTDFVocab:fromData VehicleSpeedData
    DTDFVocab:inputTo DataCollectionEnabler
]

instance SteeringAngle : DTDFVocab:Data [
    base:desc "Stamped steering angle measurement"
    DTDFVocab:fromData SteeringAngleData
    DTDFVocab:inputTo DataCollectionEnabler
]

// Models
instance AccControlModel : DTDFVocab:Model [
    base:desc "ACC control model per ISO 15622 computing follower speed"
    DTDFVocab:inputTo AccComputationEnabler
]

instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point clouds for object extraction"
    DTDFVocab:inputTo ClusteringProcessingEnabler
]

instance TrackingKalmanModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking of 3‑D objects"
    DTDFVocab:inputTo TrackingProcessingEnabler
]

instance VehicleStateVisualizationModel : DTDFVocab:Model [
    base:desc "3D visualization model of vehicle state for UI rendering"
    DTDFVocab:inputTo VisualizationEnabler
]

instance SQLDatabaseModel : DTDFVocab:Model [
    base:desc "Model mapping timestamped state and track data to SQL database"
    DTDFVocab:inputTo SQLDataStorageEnabler
]

// Enablers
instance DataCollectionEnabler : DTDFVocab:Enabler [
    base:desc "Collects sensor data and forwards it to processing and monitoring pipelines"
    DTDFVocab:enables RealTimeDataMonitoringService, ReportingService
]

instance AccComputationEnabler : DTDFVocab:Enabler [
    base:desc "Offloads ACC algorithm computations to remote server"
    DTDFVocab:enables ComputationOffloadingService
]

instance ClusteringProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processes point clouds for clustering"
    DTDFVocab:enables ClusteringService
]

instance TrackingProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Runs Kalman filter for object tracking"
    DTDFVocab:enables TrackingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enables 3‑D visualization for user interface"
    DTDFVocab:enables VisualizationUIService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enables remote ACC management commands"
    DTDFVocab:enables RemoteManagementService
]

instance SQLDataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Persists vehicle state and tracking data to external SQL database"
    DTDFVocab:enables DataStorageService
]

instance InsightGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Generates insights for ADAS tuning and system health"
    DTDFVocab:enables InsightGenerationService
]

// Services
instance RealTimeDataMonitoringService : DTDFVocab:Service [
    base:desc "Monitors real‑time data streams and provides vehicle state insight"
    DTDFVocab:provides VehicleStateInsight, TrajectoryProjectionInsight
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Generates reports on ACC performance metrics"
    DTDFVocab:provides PerformanceMetricsInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Performs ACC computation offloading and returns control commands"
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

instance ClusteringService : DTDFVocab:Service [
    base:desc "Provides insight on clustered object objects from LiDAR data"
    DTDFVocab:provides ClusteredPointCloudInsight
]

instance TrackingService : DTDFVocab:Service [
    base:desc "Provides insight into tracked object states for ACC"
    DTDFVocab:provides TrackingInsight
]

instance VisualizationUIService : DTDFVocab:Service [
    base:desc "Renders 3‑D visualization for the user interface"
    DTDFVocab:provides UIVisualizationInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Handles remote ACC enable/disable and desired speed set via UI"
    DTDFVocab:provides RemoteEnableACCAction, RemoteSetDesiredSpeedAction, RemoteEmergencyBrakeAction
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Stores vehicle state and tracking data into the SQL database"
    DTDFVocab:provides DataStoredConfirmationAction
]

instance InsightGenerationService : DTDFVocab:Service [
    base:desc "Generates tuning insights for ACC parameters"
    DTDFVocab:provides ACCParameterAdjustmentInsight
]

// Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Current vehicle state including speed, steering, and location"
]

instance TrajectoryProjectionInsight : DTDFVocab:Insight [
    base:desc "Projected vehicle trajectory for the upcoming time horizon"
]

instance PerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Acc performance metrics such as keeping distance and acceleration"
]

instance ACCParameterAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Recommended ACC parameter adjustments based on performance data"
]

instance UIVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time 3‑D visualization of vehicle and environment"
]

instance ClusteredPointCloudInsight : DTDFVocab:Insight [
    base:desc "Identification of clusters in LiDAR point cloud"
]

instance TrackingInsight : DTDFVocab:Insight [
    base:desc "Tracking of objects in the environment"
]

// Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable the autonomous cruise control subsystem"
    DTDFVocab:IsAutomatic true
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set desired target speed for ACC"
    DTDFVocab:IsAutomatic true
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Trigger emergency braking to bring vehicle to a stop"
    DTDFVocab:IsAutomatic false
]

instance RemoteEnableACCAction : DTDFVocab:Action [
    base:desc "Remote command to enable ACC from user interface"
    DTDFVocab:IsAutomatic false
]

instance RemoteSetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Remote command to set desired speed from user interface"
    DTDFVocab:IsAutomatic false
]

instance RemoteEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Remote command to trigger emergency braking"
    DTDFVocab:IsAutomatic false
]

instance DataStoredConfirmationAction : DTDFVocab:Action [
    base:desc "Confirmation that vehicle data has been stored in SQL database"
    DTDFVocab:IsAutomatic false
]

// Acting Components
instance MotorSpeedCommandActuator : DTDFVocab:ActingComponent [
    base:desc "Transmits motor speed commands to the Vedder Electronic Speed Controller via ESC"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Transmits steering servo commands to vehicle steering mechanism"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Transmits emergency brake commands to the vehicle braking system"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity’s ACC Controlling FE computes desired speed and sends control commands via the Data Translation FE over ROS2 topics to the Physical Twin Entity’s Actuation FE, which generates motor voltage commands for the ESC and steering servo, and issues emergency braking commands, directly actuating the vehicle hardware"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "End‑to‑end latency from vehicle to DT is capped at 100 ms (R7) and clocks are synchronized within 100 ms accuracy (R8); real‑time processing occurs at each perception cycle (~50‑100 Hz), with the ACC control loop executed at the vehicle’s native frequency via the Jetson Orin Nano"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated network of ROS2 nodes mapped to ISO 23247 functional entities; the Physical Twin Entity hosts sensing and actuation nodes on the Jetson Orin Nano, the Digital Twin Entity hosts data pre‑processing, ACC computation, reporting nodes on an external server, and the User Entity hosts a 3‑D visualization and control‑panel UI on a workstation; inter‑entity communication occurs over Wi‑Fi and inter‑node communication uses DDS topics for real‑time data exchange"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin operates in the ‘operated’ life‑cycle stage, providing real‑time monitoring and control during vehicle operation; the case also demonstrates design‑time usage for validation, but the DT primarily models the vehicle’s operational state"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time fidelity ensured with a maximum 100 ms end‑to‑end latency (R7) and 100 ms clock synchronization (R8); validity supported by compliance with ISO 15622 for ACC control; data integrity maintained through ROS2 topic reliability policies and serialization by Data Translation FE; sensor data uncertainty mitigated by DBSCAN clustering and Kalman filter tracking"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Wireless connection via IEEE 802.11 Wi‑Fi between the PT’s Jetson Orin Nano and the DT server; ROS2 topics use DDS over UDP/TCP, with unit conversion handled by the Data Translation FE; ROS2 nodes exchange serialized messages over the network"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital Twin Entity deployed on an external computing platform (cloud or edge server) connected over Wi‑Fi; Physical Twin Entity resides on the vehicle’s Jetson Orin Nano; User Entity hosted on a local workstation/desktop providing UI; deployment follows ISO 23247 distributed architecture"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture (Part 2), ISO 15622 for ACC control, ROS 2 middleware, NVIDIA JetPack 5.0 SDK, and open‑source RoboRacer framework"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations include maintaining a maximum end‑to‑end latency of 100 ms to ensure timely control, synchronizing clocks within 100 ms to maintain event order, and compliance with ISO 15622 for ACC; security aspects are not explicitly addressed in the document"
]