// -------------------------------------------------
// C3: Physical sensing components
instance HokuyoLidarUST110LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-110LX 2D LiDAR mounted on the 1/10‑scale autonomous vehicle"
    DTDFVocab:producedData LiDARPointCloudTransmission
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera providing RGB‑D images"
    DTDFVocab:producedData DepthImageTransmission
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor delivering ego‑vehicle longitudinal speed"
    DTDFVocab:producedData SpeedSignalTransmission
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor reporting wheel steering angle"
    DTDFVocab:producedData SteeringAngleTransmission
]

instance VehicleEncoder : DTDFVocab:SensingComponent [
    base:desc "On‑board rotary encoders used for redundant speed/position feedback"
    DTDFVocab:producedData EncoderSignalTransmission
]

// -------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance LiDARPointCloudTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLidarUST110LX
]

instance DepthImageTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

instance SpeedSignalTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance EncoderSignalTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleEncoder
]

// -------------------------------------------------
// C10: Data instances
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "3‑D point‑cloud generated from Hokuyo LiDAR scans"
    DTDFVocab:fromData LiDARPointCloudTransmission
    DTDFVocab:inputTo DBSCANClusteringAlgorithm, KalmanFilterTrackingAlgorithm, ROS2Middleware
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames from Intel RealSense D435i"
    DTDFVocab:fromData DepthImageTransmission
    DTDFVocab:inputTo MATLABSimulinkToolchain, ROS2Middleware
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Timestamped vehicle speed values (m/s)"
    DTDFVocab:fromData SpeedSignalTransmission
    DTDFVocab:inputTo ROS2Middleware, SQLTimeSeriesDatabase
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Timestamped steering‑angle values (rad)"
    DTDFVocab:fromData SteeringAngleTransmission
    DTDFVocab:inputTo ROS2Middleware, SQLTimeSeriesDatabase
]

instance EncoderData : DTDFVocab:Data [
    base:desc "Encoder tick counts for speed/position verification"
    DTDFVocab:fromData EncoderSignalTransmission
    DTDFVocab:inputTo ROS2Middleware
]

// -------------------------------------------------
// C11: Enablers (tools, middleware, algorithms)
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS 2 DDS middleware used for topic‑based communication over Wi‑Fi"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance DBSCANClusteringAlgorithm : DTDFVocab:Enabler [
    base:desc "DBSCAN algorithm for point‑cloud clustering (implemented in Python 3.8)"
    DTDFVocab:enables ComputationOffloadingService
]

instance KalmanFilterTrackingAlgorithm : DTDFVocab:Enabler [
    base:desc "Kalman filter based multi‑object tracker for fused LiDAR‑camera detections"
    DTDFVocab:enables ComputationOffloadingService
]

instance SQLTimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "SQL database storing time‑series vehicle state and object‑track logs"
    DTDFVocab:enables DataMonitoringService
]

instance MATLABSimulinkToolchain : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink models used for sensor fusion and control logic"
    DTDFVocab:enables ComputationOffloadingService
]

instance Python38Runtime : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime for algorithmic components (DBSCAN, data parsing)"
    DTDFVocab:enables ComputationOffloadingService
]

instance CppRuntime : DTDFVocab:Enabler [
    base:desc "C++17 runtime for high‑performance processing on Jetson Orin Nano"
    DTDFVocab:enables ComputationOffloadingService
]

instance JetPack5SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK providing CUDA, cuDNN, and sensor drivers"
    DTDFVocab:enables ComputationOffloadingService
]

instance WiFiNetwork : DTDFVocab:Enabler [
    base:desc "802.11 Wi‑Fi link used for real‑time transmission of vehicle state and sensor data"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

// -------------------------------------------------
// C6: Services (digital‑twin services)
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI visualization of vehicle state, object tracks, and projected path with reporting and data export"
    DTDFVocab:provides VehicleStateInsight, ObjectTracksInsight, ProjectedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm runs in the DT, computing lead‑vehicle detection and speed set‑points"
    DTDFVocab:provides LeadVehicleDetectionAction, ComputeSpeedSetPointAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI controls to enable/disable ACC, modify desired speed, and trigger emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakingAction
]

// -------------------------------------------------
// C17: Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current vehicle speed and steering angle displayed on the UI"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Insight showing detected object tracks generated from LiDAR clustering and Kalman filtering"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Insight visualizing the planned ACC path based on computed set‑points"
]

// -------------------------------------------------
// C17: Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control on the physical twin"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control on the physical twin"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator adjusts the desired cruising speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator triggers an emergency brake, overriding normal ACC behavior"
    DTDFVocab:IsAutomatic false
]

instance LeadVehicleDetectionAction : DTDFVocab:Action [
    base:desc "DT computes lead‑vehicle presence and issues detection results to the ACC controller"
    DTDFVocab:IsAutomatic true
]

instance ComputeSpeedSetPointAction : DTDFVocab:Action [
    base:desc "DT computes speed set‑points for ACC based on detected lead vehicle and desired speed"
    DTDFVocab:IsAutomatic true
]

// -------------------------------------------------
// C2: Acting components (physical actuators)
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage actuator (VEDDER ESC) controlling vehicle speed"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator driving the front steering mechanism"
]

// -------------------------------------------------
// C5: Twin Entities (multiplicity)
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical twin instantiated on‑board NVIDIA Jetson NX/Orin Nano hardware"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital twin instantiated on off‑board compute resources"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User interface layer providing monitoring and remote management"
]

instance CrossSystemEntity : DTDFVocab:Component [
    base:desc "Cross‑system entity handling data translation, serialization, and unit conversion"
]

// -------------------------------------------------
// C8: Environment (system under study)
instance Scale10AutonomousVehicleEnv : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity, DigitalTwinEntity, UserEntity, CrossSystemEntity,
           HokuyoLidarUST110LX, IntelD435iDepthCamera, VehicleSpeedSensor,
           SteeringAngleSensor, VehicleEncoder,
           MotorVoltageActuator, SteeringServoActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin issues control commands over ROS2/Wi‑Fi to the physical twin, including desired speed values, enable/disable ACC signals, emergency‑brake commands, and any steering adjustments; these are executed by the Actuation FE on the physical twin."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates with a maximum end‑to‑end network latency of 100 ms (R7) and clock synchronization accuracy of 100 ms (R8), supporting near‑real‑time update rates sufficient for ACC control loops."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A distributed architecture where the Physical Twin Entity hosts sensors and actuators, the Digital Twin Entity hosts data collection, ACC computation, visualization preprocessing, and reporting, the User Entity provides a 3D visualization and control‑panel UI, and a Cross‑System Entity handles data translation; communication uses ROS 2 intra‑entity and Wi‑Fi inter‑entity links."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during the operation stage of the vehicle lifecycle, providing runtime monitoring, control, and remote management of the ACC function."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Latency ≤ 100 ms and clock sync ≤ 100 ms guarantee temporal fidelity; ACC behavior adheres to ISO 15622 (performance class I); perception fidelity is ensured by DBSCAN clustering and Kalman‑filter tracking of LiDAR point clouds; data are stored in a SQL database for auditability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bi‑directional communication over a Wi‑Fi network using ROS 2 messages; the Data Translation FE serializes data, aligns message types, and performs unit conversions; all links are designed to meet the 100 ms latency requirement."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the onboard NVIDIA Jetson Orin Nano; the Digital Twin Entity is hosted on external compute (cloud/edge) accessible via Wi‑Fi; UI components of the User Entity run on a separate workstation accessed by operators."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built on the ISO 23247 reference architecture, complies with ISO 15622 for ACC functionality, and utilizes ROS 2 as a standardized middleware; optional OPC UA is mentioned as a possible transport layer."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The design acknowledges the safety‑critical nature of ACC, enforces a maximum 100 ms latency and synchronized clocks to ensure reliable control; however, specific cybersecurity mechanisms are not described in the document."
]