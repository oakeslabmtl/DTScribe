// Sensing Components

instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor capturing point clouds for perception."
    DTDFVocab:producedData PointCloudTransmitted
]

instance MotorStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor providing motor state information from the vehicle."
    DTDFVocab:producedData MotorStateTransmitted
]

instance SteeringServoPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring steering servo position."
    DTDFVocab:producedData SteeringServoPositionTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing overall vehicle state (speed, heading, etc.)."
    DTDFVocab:producedData VehicleStateTransmitted
]

// Data Transmitted from Sensors

instance PointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance MotorStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStateSensor
]

instance SteeringServoPositionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoPositionSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// Processed Data

instance ProcessedPointCloud : DTDFVocab:Data [
    base:desc "Processed point cloud after clustering and tracking."
    DTDFVocab:inputTo DataPreProcessingFE, DataTranslationFE
    DTDFVocab:fromData PointCloudTransmitted
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Object tracks derived from processed point cloud."
    DTDFVocab:inputTo DataPreProcessingFE
    DTDFVocab:fromData PointCloudTransmitted
]

instance ProcessedVehicleState : DTDFVocab:Data [
    base:desc "Vehicle state after calibration and unit conversion."
    DTDFVocab:inputTo DataTranslationFE
    DTDFVocab:fromData VehicleStateTransmitted
]

instance ProcessedMotorState : DTDFVocab:Data [
    base:desc "Motor state after calibration and unit conversion."
    DTDFVocab:inputTo DataTranslationFE
    DTDFVocab:fromData MotorStateTransmitted
]

// Enablers (Functional Entities)

instance DataPreProcessingFE : DTDFVocab:Enabler [
    base:desc "ROS2 package performing data pre‑processing (clustering, tracking)."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "ISO 23247 Data Translation FE for serialisation and unit conversion."
    DTDFVocab:enables DataMonitoringService
]

instance ACCLogicFE : DTDFVocab:Enabler [
    base:desc "ROS2 package implementing Adaptive Cruise Control logic."
    DTDFVocab:enables ComputationOffloadingService
]

instance ActuationFE : DTDFVocab:Enabler [
    base:desc "ROS2 package handling actuation of vehicle controls."
    DTDFVocab:enables RemoteManagementService
]

instance UserInterfaceFE : DTDFVocab:Enabler [
    base:desc "ROS2 package for 3D visualization and remote control UI."
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance DataStorageFE : DTDFVocab:Enabler [
    base:desc "Data storage module persisting vehicle state and reports."
    DTDFVocab:enables DataMonitoringService
]

// Services

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real‑time monitoring of vehicle state, tracks, and reports."
    DTDFVocab:provides VehicleStateInsight, RawDataInsight, SaveSnapshotAction, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service executing ACC logic and computing speed setpoints."
    DTDFVocab:provides ACCDecisionInsight, ComputeSpeedSetPointAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service enabling remote control of ACC, speed, and emergency braking."
    DTDFVocab:provides OperatorControlInsight, EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// Insights

instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time vehicle state insight displayed to operators."
]

instance RawDataInsight : DTDFVocab:Insight [
    base:desc "Insight summarising raw sensor data streams."
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "Insight on ACC decision to adjust vehicle speed."
]

instance OperatorControlInsight : DTDFVocab:Insight [
    base:desc "Insight showing operator remote control status."
]

// Actions

instance SaveSnapshotAction : DTDFVocab:Action [
    base:desc "Action to save snapshot of the current vehicle state."
    DTDFVocab:IsAutomatic false
]

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Action to generate performance analysis reports."
    DTDFVocab:IsAutomatic false
]

instance ComputeSpeedSetPointAction : DTDFVocab:Action [
    base:desc "Automatic action computing desired speed setpoint for ACC."
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Manual action to enable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Manual action to disable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Manual action to set a desired speed on the vehicle."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Manual action to issue an emergency brake command."
    DTDFVocab:IsAutomatic false
]

// Acting Component

instance AccActuator : DTDFVocab:ActingComponent [
    base:desc "Physical actuator controlling vehicle throttle to deliver computed speed setpoints."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin issues control commands back to the Physical Twin via the Actuation FE. Commands include ACC enable/disable, desired speed set‑points, and emergency braking signals, which are consumed by the vehicle’s actuation modules (motor, steering servo). The messages are formatted according to the Data Translation FE specifications and transmitted over the same Wi‑Fi / UDP link. The vehicle acknowledges command execution through updated vehicle state feedback displayed in the 3D visualization."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires clock synchronization between physical and digital components with an accuracy of 100 ms, as mandated by safety‑critical vehicular standards; devices share a common notion of time to enable computation offloading."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 reference architecture, organizing software components into entity‑based functional entities that are implemented as individual ROS2 packages; each package hosts ROS2 nodes that realize the FE, enabling integration and resource management across the three entities."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication between the physical twin and the DTS uses a Wi‑Fi network with UDP transport. Internally, DTS software components communicate over a ROS 2 middleware network. The architecture is designed to meet low end‑to‑end latency requirements needed for safety‑critical ACC operation, but the documents do not specify exact bandwidth, latency values, redundancy mechanisms, or security protocols."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "ACC computation is offloaded from the resource‑constrained vehicle to the Digital Twin hosted on cloud resources, providing higher‑performance compute for the ACC algorithm. The DTS includes UI components for monitoring, data collection, reporting, and remote management, implying a cloud‑based deployment model with sufficient storage for vehicle state logs and scalability to handle additional data streams. Availability is addressed by the requirement for low‑latency communication, but explicit redundancy or fault‑tolerance mechanisms are not specified."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built to comply with the ISO 23247 Digital Twin framework for manufacturing (parts 1–4). The reference architecture is adopted as the primary guideline for defining entities and functional entities. For inter‑device communication the design can employ OPC Unified Architecture (OPC UA) as suggested by the standard. Runtime components are realised as ROS 2 packages, which rely on the DDS (Data Distribution Service) specification for publish‑subscribe communication, providing interoperability with other DDS‑compliant tools. The implementation respects vehicular‑safety clock‑synchronisation requirements of ≤100 ms accuracy, a constraint referenced as a typical mandate of safety‑critical vehicular standards."
]