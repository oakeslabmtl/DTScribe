// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing 2D range scans as raw point clouds"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDeepSenseCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera providing depth images"
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On-board measurement of vehicle speed"
    DTDFVocab:producedData SpeedSignalTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On-board measurement of steering angle"
    DTDFVocab:producedData SteeringAngleSignalTransmitted
]

// C4: Physical-to-virtual interaction
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseCamera
]

instance SpeedSignalTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleSignalTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C10: Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 2D point cloud from LiDAR"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo PreprocessingEnabler, DataTranslationEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image from depth camera"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo PreprocessingEnabler, DataTranslationEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle ego speed signal"
    DTDFVocab:fromData SpeedSignalTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, ACCAlgorithmEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Vehicle steering angle signal"
    DTDFVocab:fromData SteeringAngleSignalTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, ACCAlgorithmEnabler
]

// C10: Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN algorithm clustering LiDAR point cloud to detect objects"
    DTDFVocab:inputTo PreprocessingEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking of object positions over time"
    DTDFVocab:inputTo PreprocessingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "ISO 15222 ACC control model for lead‑vehicle detection and speed set‑point calculation"
    DTDFVocab:inputTo ACCAlgorithmEnabler
]

// C11: Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247 Data Translation functional entity performing unit conversion and serialization over Wi‑Fi"
    DTDFVocab:enables DataMonitoringService, ReportingService
]

instance PreprocessingEnabler : DTDFVocab:Enabler [
    base:desc "Preprocesses sensor data using DBSCAN clustering and Kalman filter for object tracking"
    DTDFVocab:enables DataMonitoringService
]

instance ACCAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Runs ACC algorithm (lead‑vehicle detection and speed set‑point) defined by ISO 15222"
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService
]

instance ReportingEnabler : DTDFVocab:Enabler [
    base:desc "Generates time‑series reports and stores them in SQL database"
    DTDFVocab:enables ReportingService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI visualizing vehicle speed, steering angle, projected path, and object tracks"
    DTDFVocab:provides LiveVehicleStateInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC computation to the digital twin"
    DTDFVocab:provides ACCComputationInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI permits enabling/disabling ACC, adjusting desired speed, and issuing emergency‑brake commands"
    DTDFVocab:provides ManualACCDisableAction, AdjustDesiredSpeedAction, EmergencyBrakeAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Automated generation of time‑series reports stored in SQL database"
    DTDFVocab:provides ACCPerformanceReportInsight
]

// C17: Insights / Actions
instance LiveVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Operators see live vehicle state, projected path, and surrounding object tracks"
]

instance ACCComputationInsight : DTDFVocab:Insight [
    base:desc "Provides ACC algorithm output such as lead‑vehicle distance and speed set‑point"
]

instance ManualACCDisableAction : DTDFVocab:Action [
    base:desc "Operator can disable adaptive cruise control"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator can adjust desired cruising speed"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator can issue emergency brake command to actuators"
    DTDFVocab:IsAutomatic false
]

instance ACCPerformanceReportInsight : DTDFVocab:Insight [
    base:desc "Time‑series report of ACC performance for developer analysis and optimisation"
]

// C2: Acting components
instance VehicleActuationComponent : DTDFVocab:ActingComponent [
    base:desc "Actuation functional entity drives vehicle via Vedder ESC motor voltage commands and steering servo; also used for emergency‑brake commands and speed adjustments"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT via ROS2 over Wi‑Fi, including desired speed set‑points, ACC enable/disable flags, emergency‑brake triggers, and motor/steering actuation commands; these are processed by the Actuation FE on the Physical Twin Entity."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in real‑time with an end‑to‑end network latency budget of ≤100 ms and clock synchronization accuracy of 100 ms across all components, satisfying the 3GPP 22.185 latency requirement for V2V‑type services."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates a Physical Twin Entity (sensors/actuators), a Digital Twin Entity (data collection, ACC computation, visualization, reporting), a User Entity (3D visualization and control‑panel UI), and a Cross‑System Entity (Data Translation FE) communicating over ROS2 and Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during the design and development phase (simulation, cyber‑physical experimentation) and during operational use for monitoring, remote management, and performance reporting of the running vehicle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time fidelity is ensured by the ≤100 ms latency and clock sync constraints; safety validity is addressed by adhering to ISO 15622 ACC specifications and by limiting the control to performance‑class I (no road‑curvature handling). Tracking fidelity relies on DBSCAN clustering and Kalman filtering validated against sensor data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication between PT and DT uses a Wi‑Fi network carrying ROS2 messages; the Data Translation FE serializes and aligns data types. The standardized communication interface (R1) enforces modular, loosely‑coupled message exchange."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the vehicle’s NVIDIA Jetson Orin Nano; Digital Twin Entity components are hosted on an external computing platform (e.g., cloud workstation) with separate ROS2 processes; the User Entity UI runs on an operator workstation connected via the same Wi‑Fi network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) for entity/functional decomposition, uses ISO 15622 for ACC functional requirements, and complies with the standardized communication principle (R1); ROS2 provides a de‑facto standard middleware stack."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by meeting ISO 15622 ACC requirements, enforcing ≤100 ms latency and clock sync, and providing emergency‑brake capability; explicit cybersecurity mechanisms are not described in the document."
]