// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR sensor for object detection in the autonomous vehicle's environment, providing 2D point cloud data."
    DTDFVocab:producedData HokuyoLiDARPointCloudData
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera providing RGB-D data for 3D perception and depth perception of the vehicle's surroundings."
    DTDFVocab:producedData DepthCameraRGBDData
]

instance EgoVehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor measuring the ego vehicle's instantaneous speed in km/h for autonomous control systems."
    DTDFVocab:producedData EgoVehicleSpeedData
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor measuring the steering angle in degrees for vehicle dynamics monitoring and control."
    DTDFVocab:producedData SteeringAngleData
]

// C4: Physical-to-Virtual Interaction
instance HokuyoLiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraRGBDData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]

instance EgoVehicleSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoVehicleSpeedSensor
]

instance SteeringAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance CombinedSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR, IntelDeepsenseD435iDepthCamera, EgoVehicleSpeedSensor, SteeringAngleSensor
    base:desc "Serialized and translated sensor data package transmitted via ROS2 network for digital twin processing."
]

// C10: Models/Data
instance DBSCANPointCloudClusterer : DTDFVocab:Model [
    base:desc "DBSCAN algorithm implementation for clustering LiDAR point cloud data into object segments."
    DTDFVocab:inputTo ROS2NodeProcessingEnabler
]

instance KalmanObjectTracker : DTDFVocab:Model [
    base:desc "Kalman filter implementation for tracking detected objects based on their motion patterns."
    DTDFVocab:inputTo ROS2NodeProcessingEnabler
]

instance ISO15622ACCLibrary : DTDFVocab:Model [
    base:desc "ISO 15622-compliant Adaptive Cruise Control logic for lead vehicle detection and speed computation."
    DTDFVocab:inputTo ROS2NodeProcessingEnabler
]

instance VehicleStateTimeSeriesDB : DTDFVocab:Data [
    base:desc "SQL database storing time-series data of vehicle state parameters including speed, steering angle, and object tracks."
    DTDFVocab:fromData CombinedSensorData
    DTDFVocab:inputTo ROS2NodeProcessingEnabler
]

instance ObjectTrackTimeSeriesDB : DTDFVocab:Data [
    base:desc "SQL database storing time-series data of detected objects' tracks including position, velocity, and acceleration."
    DTDFVocab:fromData CombinedSensorData
    DTDFVocab:inputTo ROS2NodeProcessingEnabler
]

// C11: Enablers
instance NVIDIAJetpack50SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK providing CUDA and cuDNN libraries for GPU-accelerated processing of sensor data."
    DTDFVocab:enables ROS2NodeProcessingService, ACCComputationService
]

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware enabling decentralized communication between autonomous vehicle components via ROS2 nodes."
    DTDFVocab:enables ROS2NodeProcessingService, DataVisualizationService, RemoteManagementService
]

instance Python38Prototyping : DTDFVocab:Enabler [
    base:desc "Python 3.8 environment used for prototyping and rapid development of digital twin algorithms."
    DTDFVocab:enables ROS2NodeProcessingService
]

instance CppLifecycleManagement : DTDFVocab:Enabler [
    base:desc "C++ implementation for managing ROS2 node lifecycle and low-latency control loops."
    DTDFVocab:enables ROS2NodeProcessingService
]

instance MATLABSimulinkPCProcessing : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for complex point cloud processing and simulation of perception algorithms."
    DTDFVocab:enables ROS2NodeProcessingService
]

instance ROS2NodeProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Decentralized ROS2 node deployment framework implementing individual packages for each functional entity."
    DTDFVocab:enables ROS2NodeProcessingService
]

// C6: Services
instance ROS2NodeProcessingService : DTDFVocab:Service [
    base:desc "Decentralized ROS2 node processing service executing perception algorithms (DBSCAN, Kalman filtering) and control logic."
    DTDFVocab:provides RealTime3DVisualizationInsight, TimeSeriesPerformanceReportInsight,
                  ACCComputationAction, RemoteManagementAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Real-time 3D visualization service displaying vehicle state and object tracks for operator transparency."
    DTDFVocab:provides RealTime3DVisualizationInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management service enabling enable/disable of ACC, setting desired speed, and emergency braking commands."
    DTDFVocab:provides RemoteManagementAction
]

instance ACCComputationService : DTDFVocab:Service [
    base:desc "Computation offloading service for ISO 15622-compliant Adaptive Cruise Control logic."
    DTDFVocab:provides ACCComputationAction
]

// C17: Insights/Actions
instance RealTime3DVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time 3D visualization of vehicle state and object tracks for operator transparency and system diagnostics."
]

instance TimeSeriesPerformanceReportInsight : DTDFVocab:Insight [
    base:desc "Time-series reports for performance analysis supporting driver trust and system diagnostics."
]

instance ACCComputationAction : DTDFVocab:Action [
    base:desc "Computation of lead vehicle detection and speed computation for Adaptive Cruise Control."
    DTDFVocab:IsAutomatic true
]

instance RemoteManagementAction : DTDFVocab:Action [
    base:desc "Remote enable/disable of ACC, setting desired speed, and emergency braking commands."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller converting desired speed commands into motor voltage signals for vehicle actuation."
]

instance TraxxasSlashSteeringServo : DTDFVocab:ActingComponent [
    base:desc "Motor-controlled steering servo receiving commands from the electronic speed controller to adjust vehicle direction."
]

// C1: System Under Study
instance AutonomousTraxxasSlashVehicle : DTDFVocab:Component [
    base:desc "1/10-scale autonomous vehicle built from Traxxas Slash 4x4 Premium teleoperated vehicle retrofitted with autonomy components."
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital twin entity representing the autonomous vehicle's virtual counterpart for simulation and analysis."
]

instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical twin entity representing the actual autonomous vehicle hardware with sensing and acting components."
]

instance AutonomousVehicleSystem : DTDFVocab:Environment [
    base:contains AutonomousTraxxasSlashVehicle, DigitalTwinEntity, PhysicalTwinEntity,
                  HokuyoUST10LXLiDAR, IntelDeepsenseD435iDepthCamera,
                  VedderElectronicSpeedController, TraxxasSlashSteeringServo,
                  EgoVehicleSpeedSensor, SteeringAngleSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Transmission of ACC control commands (desired speed, emergency braking, enable/disable) from the digital twin to the physical vehicle's motor and steering actuators via ROS2, converting digital commands into motor voltage signals."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time operation with end-to-end network latency ≤100 ms (per 3GPP TS 22.185) and clock synchronization accuracy of 100 ms across all components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Entity-based architecture with Physical Twin Entity (on vehicle), Digital Twin Entity (cloud), User Entity (remote UI), and Cross-System Data Translation FE; components communicate via ROS2 intra-entity and Wi-Fi inter-entity."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational phase (as operated), used for real-time monitoring, optimization, and remote management of the adaptive cruise control system during vehicle operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "ACC implemented per ISO 15622 performance class I (no road curvature capabilities); real-time constraints enforced via 100 ms latency and clock sync; simplified model for 1/10-scale vehicle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "ROS2 for intra-entity communication, Wi-Fi for inter-entity communication with ≤100 ms end-to-end latency as per 3GPP TS 22.185."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity on NVIDIA Jetson hardware (vehicle), Digital Twin Entity and Data Storage in cloud infrastructure, User Entity on remote devices."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture for digital twin framework, ISO 15622 for adaptive cruise control functionality."
]