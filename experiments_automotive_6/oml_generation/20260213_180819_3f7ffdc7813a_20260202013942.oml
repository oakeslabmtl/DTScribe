// Acting Components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Receives voltage commands derived from desired speed setpoints via ActuationSoftwareComponent, driving the vehicle electric motor."
]
instance ChassisSteeringActuator : DTDFVocab:ActingComponent [
    base:desc "Directly controls the steering angle commanded by the lower‑level chassis controller."
]
instance ActuationSoftwareComponent : DTDFVocab:ActingComponent [
    base:desc "Translates high‑level speed and steering commands into motor voltage signals for VedderElectronicSpeedController and ChassisSteeringActuator."
]

// Sensing Components
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "High‑resolution LiDAR sensor mounted on the vehicle, emits laser point clouds for perception."
    DTDFVocab:producedData LiDARPointCloudTransmitted
]
instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle CAN bus sensor that provides vehicle state information such as speed, acceleration, and yaw rate."
    DTDFVocab:producedData VehicleStateTransmitted
]
instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that monitors motor command voltage and electrical status of the drive motor."
    DTDFVocab:producedData MotorStatusTransmitted
]
instance SteeringServoStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that reports the steering servo position and status."
    DTDFVocab:producedData SteeringServoTransmitted
]

// Physical‑to‑Virtual Interaction (Data Transmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]
instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]
instance MotorStatusTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]
instance SteeringServoTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoStatusSensor
]

// Data (processed or stored)
instance LiDARRawPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data received over UDP via Wi‑Fi from the physical twin."
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]
instance VehicleStateData : DTDFVocab:Data [
    base:desc "Processed vehicle state data (speed, acceleration, yaw) ready for downstream consumers."
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]
instance MotorStatusData : DTDFVocab:Data [
    base:desc "Processed motor command voltage and electrical status data."
    DTDFVocab:fromData MotorStatusTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]
instance SteeringServoData : DTDFVocab:Data [
    base:desc "Processed steering servo position and status data."
    DTDFVocab:fromData SteeringServoTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]
instance ObjectTrackData : DTDFVocab:Data [
    base:desc "High‑level object tracks generated by point‑cloud clustering and tracking."
    DTDFVocab:inputTo PointCloudProcessingEnabler
]
instance EgoVehicleStateData : DTDFVocab:Data [
    base:desc "Ego‑vehicle state information used by the ACC algorithm."
    DTDFVocab:inputTo AccComputationEnabler
]
instance SafeFollowingSpeedCommandData : DTDFVocab:Data [
    base:desc "Desired following speed computed by the ACC algorithm."
    DTDFVocab:inputTo AccComputationEnabler
]

// Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Serialises raw sensor streams, aligns message types, and performs unit conversions before consumption by higher‑level components."
    DTDFVocab:enables DataMonitoringService
]
instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Hosts the point‑cloud clustering and tracking ROS2 nodes that process raw LiDAR data into object tracks."
    DTDFVocab:enables DataMonitoringService
]
instance AccComputationEnabler : DTDFVocab:Enabler [
    base:desc "Encapsulates the ACC ROS2 node that operates off‑board in the cloud and produces a safe following speed command."
    DTDFVocab:enables ComputationOffloadingService
]
instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Persists ObjectTrackData and EgoVehicleStateData in a relational SQL database via the Data Storage component."
    DTDFVocab:enables DataMonitoringService
]
instance RemoteCommandEnabler : DTDFVocab:Enabler [
    base:desc "Handles remote ROS2 service calls for emergency braking, ACC enable/disable, and desired speed configuration."
    DTDFVocab:enables RemoteManagementService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time vehicle state, projected driving path, and detected object tracks to the UI for monitoring and reporting."
    DTDFVocab:provides VehicleStateInsight, ObjectTrackInsight, ReportingAction
]
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes the ACC algorithm off‑board to compute a desired speed and returns the command for actuation."
    DTDFVocab:provides AccDecisionInsight, SetDesiredSpeedAction
]
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to remotely enable/disable ACC, set a desired speed, and issue an emergency braking command with low‑latency bidirectional communication."
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, EmergencyBrakingAction
]

// Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Provides current vehicle state information such as speed, acceleration, and yaw for monitoring."
]
instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Provides detected object tracks and their motion trajectories for visualization."
]
instance AccDecisionInsight : DTDFVocab:Insight [
    base:desc "Indicates the ACC decision on desired following speed and lead vehicle status."
]

// Actions
instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Emergency braking command issued by an operator to halt the vehicle."
    DTDFVocab:IsAutomatic false
]
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Toggle the Adaptive Cruise Control system on or off."
    DTDFVocab:IsAutomatic false
]
instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set a manual desired speed for the vehicle."
    DTDFVocab:IsAutomatic false
]
instance ReportingAction : DTDFVocab:Action [
    base:desc "Generate and save a report of collected vehicle data for analysis."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin computes Adaptive Cruise Control decisions (lead‑vehicle identification, desired speed) and sends control commands back to the vehicle over the same Wi‑Fi UDP link. Commands are packaged by the Data Translation FE into the vehicle’s actuation message format (e.g., desired speed set‑point, ACC enable/disable, emergency brake). The vehicle’s control unit receives the command, validates it, executes the corresponding actuation on motor and steering hardware, and provides implicit acknowledgment through subsequent state updates."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires clock synchronization between devices with an accuracy of 100 ms, which is the maximum tolerance imposed by hardware limitations; this synchronisation frequency is used to enable safe computation off‑loading in the vehicular context."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration follows the ISO 23247 reference architecture, mapping each Functional Entity to a ROS 2 package; each package contains one or more ROS 2 nodes that implement the entity’s functionality. Communication between the Physical Twin Entity (hosting compute, sensors, actuators and services such as Point Cloud Clustering & Tracking), the Digital Twin Entity (handling data pre‑processing, storage and control), and the User Entity (providing 3D visualization and control panels) is realised through ROS 2 publish/subscribe and service mechanisms, enabling component integration and resource management across the distributed hardware."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The architecture requires that all distributed components maintain a common notion of time with a synchronization accuracy of at most 100 ms, as dictated by hardware constraints and safety‑critical timing requirements. Consequently, the communication infrastructure must guarantee clock alignment within this bound, and any computation off‑loading between devices is designed to respect the 100 ms latency ceiling. Temporal fidelity is therefore a primary validation criterion for the twin’s operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Intra‑digital‑twin communication between software components uses ROS 2 (DDS) middleware. Communication between the physical twin and the digital twin occurs over a Wi‑Fi network with UDP as the transport protocol. The topology is a logical client‑server exchange where the vehicle streams sensor data to the DT and receives control messages in return. The system is required to sustain low end‑to‑end latency for safety‑critical ACC operation, but the documents do not give quantitative latency, bandwidth, reliability, redundancy or security protocol details."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The ACC functionality is off‑loaded from the resource‑constrained ECU to the Digital Twin, which can be executed on cloud‑based compute resources or any platform capable of running ROS 2 services. The DT requires sufficient processing power for point‑cloud clustering, tracking, and ACC decision logic, as well as storage for collected vehicle state data and generated reports. The system is designed to maintain low end‑to‑end latency for remote management, though specific hardware, scalability mechanisms, and availability guarantees are not detailed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built on the ISO 23247 Digital Twin framework (parts 1–4), explicitly adopting its entity‑based reference architecture (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity). It acknowledges vehicular safety‑critical clock‑synchronization standards that mandate ≤100 ms accuracy, and mentions the possibility of using OPC Unified Architecture for device communication. The implementation uses ROS2 packages (leveraging DDS) to meet interoperability requirements."
]