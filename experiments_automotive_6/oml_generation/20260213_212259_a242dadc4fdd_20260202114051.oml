// Sensing Components
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing point cloud data"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera providing depth imagery"
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor outputting speed values"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor outputting angle values"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// Data Transmitted
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Point cloud data from Hokuyo UST-10LX LiDAR"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataCollectionFE
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image data from Intel D435i camera"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo DataCollectionFE
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed data unit converted from sensor"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo DataCollectionFE
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle data unit converted from sensor"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo DataCollectionFE
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Object tracks produced by DBSCAN clustering and Kalman filter tracking"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataCollectionFE
]

instance AccControlCommandData : DTDFVocab:Data [
    base:desc "Acceleration control commands output by ACC controller per ISO-15622"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo RemoteControlFE
]

instance PerformanceMetricsData : DTDFVocab:Data [
    base:desc "Real-time performance metrics of ACC logic"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo DataMonitoringService
]

instance TraceLogData : DTDFVocab:Data [
    base:desc "Trace logs from vehicle and DT interactions"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo DataMonitoringService
]

instance ReportData : DTDFVocab:Data [
    base:desc "Timeseries report data with export capability"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo DataMonitoringService
]

instance HistoricalTrendData : DTDFVocab:Data [
    base:desc "Historical data stored in SQL database for trend analysis"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo DataMonitoringService
]

instance Visualization3DMeshData : DTDFVocab:Data [
    base:desc "3D visualization mesh for vehicle and environment rendered in RViz"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataMonitoringService
]

// Models
instance TrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering and Kalman filter tracking algorithm for object tracks"
    DTDFVocab:inputTo DataCollectionFE
]

instance AccControllerModel : DTDFVocab:Model [
    base:desc "ACC controller algorithm implementing lead vehicle detection and following speed calculation per ISO-15622"
    DTDFVocab:inputTo DataCollectionFE
]

instance VisualizationMeshModel : DTDFVocab:Model [
    base:desc "Model generating the 3D visualization mesh for RViz"
    DTDFVocab:inputTo DataMonitoringService
]

// Enablers
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Data Translation Front End serializing raw ROS2 DDS messages and performing unit conversions feeds Data Collection FE"
    DTDFVocab:enables DataMonitoringService
]

instance DataCollectionFE : DTDFVocab:Enabler [
    base:desc "Data Collection Front End performing DBSCAN and Kalman filtering feeds models for ACC tracking and control"
    DTDFVocab:enables AccDecisionLogicOffloadService
]

instance RemoteControlFE : DTDFVocab:Enabler [
    base:desc "Remote Control Front End receiving web commands and translating into DT actions"
    DTDFVocab:enables RemoteManagementService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Realtime UI displaying vehicle speed, steering angle, projected driving path, and object tracks report generation and data export"
    DTDFVocab:provides RealTimePerformanceMetricsInsight, TraceLogsInsight, ReportGenerationInsight, HistoricalTrendAnalysisInsight
]

instance AccDecisionLogicOffloadService : DTDFVocab:Service [
    base:desc "ACC decision logic offloading from vehicle to DT, executing lead vehicle detection and speed control"
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Web-based control panel for enabling/disabling ACC, adjusting desired speed, issuing emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakeAction
]

// Insights
instance RealTimePerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Insight providing real-time performance metrics of ACC logic"
]

instance TraceLogsInsight : DTDFVocab:Insight [
    base:desc "Insight exposing trace logs of system operations"
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight enabling report generation of timeseries data"
]

instance HistoricalTrendAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight analyzing historical trends from SQL database"
]

// Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable ACC logic remotely"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Action to disable ACC logic remotely"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to adjust desired speed of ACC system"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to issue emergency braking command"
    DTDFVocab:IsAutomatic false
]

// Acting Components
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage actuator sending voltage commands to the vehicle's electronic speed controller for acceleration/deceleration"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator commanding vehicle steering mechanism"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator channel transmitting emergency braking commands to the vehicle"
]

// Technical Components
instance DigitalTwinComponent : DTDFVocab:Component [
    base:desc "Digital Twin host running ROS2 on remote server with NVIDIA JetPack 5.0"
]

instance PhysicalTwinComponent : DTDFVocab:Component [
    base:desc "Physical Twin residing on vehicle with Jetson Orin Nano and sensors"
]

instance UserComponent : DTDFVocab:Component [
    base:desc "Operator workstation providing web-based control panel"
]

// Environments
instance VehicleEnvironment : DTDFVocab:Environment [
    base:desc "Physical environment of the vehicle containing sensors, actuators, and control interfaces"
    base:contains HokuyoUST10LXLidar, IntelD435iDepthCamera, VehicleSpeedSensor, SteeringAngleSensor, MotorVoltageActuator, SteeringServoActuator, EmergencyBrakeActuator
]

instance ComputationalEnvironment : DTDFVocab:Environment [
    base:desc "Computational environment hosting the Digital Twin front ends and models"
    base:contains DataTranslationFE, DataCollectionFE, RemoteControlFE, TrackingModel, AccControllerModel, VisualizationMeshModel, DataMonitoringService, AccDecisionLogicOffloadService, RemoteManagementService, DigitalTwinComponent
]

instance PhysicalVehicleEnvironment : DTDFVocab:Environment [
    base:desc "Physical vehicle environment containing the physical twin component"
    base:contains PhysicalTwinComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The ACC FE in the DT computes a desired speed based on the lead vehicle distance and outputs acceleration and braking set‑points; the Actuation FE converts these into motor voltage and steering command messages that are transmitted back to the PT via Wi‑Fi; the DT also publishes emergency brake and enable/disable ACC messages consumed by the PT's actuator interface."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates at the perception cycle rate of the vehicle (approximately 10 Hz), maintaining end‑to‑end communication latency ≤ 100 ms and timestamp synchronization within 100 ms, as required for real‑time ACC control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated system where the Physical Twin Entity streams sensor data to the Digital Twin Entity via Data Translation FE; the Data Collection, Processing, and ACC FEs execute logic; the Actuation FE sends control commands back to the PT; the User Entity provides a UI for monitoring and remote command; all components are interconnected through a Wi‑Fi network and ROS2 message passing."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin is instantiated in the Operated phase of the vehicle lifecycle, providing real‑time monitoring and control while the 1/10‑scale vehicle is in active operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time fidelity enforced by maintaining ≤ 100 ms latency and 100 ms clock synchronization; spatial/temporal accuracy of LiDAR point clouds validated at the sensor level; DBSCAN clustering and Kalman filter tuned for accurate object tracking; ACC controller follows ISO 15622 specifications; data reports provide traceability for verification."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Wi‑Fi radio link using IEEE 802.11 (a‑band) carrying ROS2 DDS messages; Data Translation FE serializes data into binary payloads and performs unit conversion; ROS2 nodes on distributed hosts communicate via publish‑subscribe over DDS; inter‑entity communication uses Ethernet (Linux) at the vehicle and RS‑485 at the PT for actuator commands."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT runs on an external computing platform (edge or cloud server) connected to the vehicle via Wi‑Fi, executing ROS 2 on a Linux operating system. A dedicated SQL database on a peripheral device is used for persisting data due to limited onboard storage.
"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture for manufacturing digital twins adapted to automotive; ISO 15622 standards for ACC control; ROS2 and DDS provide communication standard; use of OPC UA not used; Open‑source RoboRacer firmware."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical constraints: end‑to‑end latency ≤ 100 ms, 100 ms clock sync; emergency braking and ACC enable/disable commands transmitted over secure Wi‑Fi with QoS; data integrity ensured by ROS2 DDS integrity checks; compliance with ISO 23247 and ISO 15622 safety guidelines; remote actuator commands are validated before execution."
]