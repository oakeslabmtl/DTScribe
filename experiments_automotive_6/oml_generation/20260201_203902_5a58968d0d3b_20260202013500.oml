// ====================
// C17: Insights / Actions
// ====================

instance LiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live visualization of vehicle state, sensor streams and projected trajectory for developers and operators."
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Automatic generation of performance and event reports based on streamed data."
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "Computed desired speed and gap‑keeping decision from the ACC algorithm."
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable the Adaptive Cruise Control functionality.",
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable the Adaptive Cruise Control functionality.",
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Adjust the target speed parameter of the ACC controller.",
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Trigger an emergency braking maneuver on the physical vehicle.",
    DTDFVocab:IsAutomatic true
]

// ====================
// C6: Services
// ====================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualizes real‑time speed, steering angle, object tracks and projected path generates reports.",
    DTDFVocab:provides LiveVisualizationInsight,
    DTDFVocab:provides ReportGenerationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs the Adaptive Cruise Control algorithm on the digital twin, processing sensor data and producing desired speed decisions.",
    DTDFVocab:provides ACCDecisionInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI allows operators to enable/disable ACC, adjust desired speed, and trigger emergency braking.",
    DTDFVocab:provides EnableACCAction,
    DTDFVocab:provides DisableACCAction,
    DTDFVocab:provides AdjustDesiredSpeedAction,
    DTDFVocab:provides EmergencyBrakeAction
]

// ====================
// C11: Enablers
// ====================

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware handling topic communication between the physical twin and digital twin.",
    DTDFVocab:enables DataMonitoringService,
    DTDFVocab:enables ComputationOffloadingService,
    DTDFVocab:enables RemoteManagementService
]

instance JetsonSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK providing GPU acceleration and driver support on the Jetson platforms.",
    DTDFVocab:enables DataMonitoringService,
    DTDFVocab:enables ComputationOffloadingService,
    DTDFVocab:enables RemoteManagementService
]

instance MATLABSimulinkTool : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment used for DBSCAN clustering and Kalman filtering.",
    DTDFVocab:enables ComputationOffloadingService
]

instance OPCUATranslation : DTDFVocab:Enabler [
    base:desc "Optional OPC‑UA layer for data translation across functional entities.",
    DTDFVocab:enables RemoteManagementService
]

instance StandardROSPackage : DTDFVocab:Enabler [
    base:desc "Standard ROS 2 packages implementing each functional entity (sensing, actuation, etc.).",
    DTDFVocab:enables DataMonitoringService
]

// ====================
// C10: Models/Data
// ====================

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm implementing ISO 15622 performance‑class‑I logic.",
    DTDFVocab:inputTo ROS2Middleware
]

instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering model for segmenting LiDAR point‑clouds into individual objects.",
    DTDFVocab:inputTo MATLABSimulinkTool
]

instance KalmanTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter model used to track objects across LiDAR scans.",
    DTDFVocab:inputTo MATLABSimulinkTool
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model rendering vehicle state, tracks and projected paths.",
    DTDFVocab:inputTo StandardROSPackage
]

instance VehicleStateSQLDatabaseModel : DTDFVocab:Model [
    base:desc "SQL database schema storing time‑series vehicle state and object‑track data.",
    DTDFVocab:inputTo JetsonSDK
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed values streamed over Wi‑Fi to the digital twin.",
    DTDFVocab:fromData SpeedDataTransmitted,
    DTDFVocab:inputTo ROS2Middleware,
    DTDFVocab:inputTo JetsonSDK
]

instance VehicleSteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering‑angle measurement transmitted to the digital twin.",
    DTDFVocab:fromData SteeringAngleDataTransmitted,
    DTDFVocab:inputTo ROS2Middleware,
    DTDFVocab:inputTo JetsonSDK
]

instance ObjectTracksPointCloudData : DTDFVocab:Data [
    base:desc "Raw 2‑D LiDAR point‑cloud representing detected object tracks.",
    DTDFVocab:fromData LiDARPointCloudTransmitted,
    DTDFVocab:inputTo ROS2Middleware,
    DTDFVocab:inputTo MATLABSimulinkTool
]

instance EnvironmentDepthImageData : DTDFVocab:Data [
    base:desc "Depth image from the Intel D435i camera used for perception.",
    DTDFVocab:fromData DepthImageTransmitted,
    DTDFVocab:inputTo ROS2Middleware,
    DTDFVocab:inputTo MATLABSimulinkTool
]

// ====================
// C4: Physical‑to‑virtual interaction (Data transmitted)
// ====================

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]

// ====================
// C3: Physical sensing components
// ====================

instance EgoSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Real‑time ego vehicle speed sensor mounted on the 1/10‑scale autonomous vehicle.",
    DTDFVocab:producedData SpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor providing the current wheel steering position.",
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2‑D LiDAR used for object detection and point‑cloud generation.",
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering RGB‑D images for environment perception.",
    DTDFVocab:producedData DepthImageTransmitted
]

// ====================
// C2: Acting components
// ====================

instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller (Vedder) receiving voltage commands to drive the motor."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo that receives position commands to set the vehicle's steering angle."
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency brake command interface that triggers a rapid stop of the vehicle."
]

// ====================
// C14: Environment (optional grouping)
// ====================

instance VehicleEnvironment : DTDFVocab:Environment [
    base:contains EgoSpeedSensor,
    SteeringAngleSensor,
    HokuyoLiDAR,
    IntelDepthCamera,
    MotorVoltageActuator,
    SteeringServoActuator,
    EmergencyBrakeActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends desired speed set‑points, ACC enable/disable commands, speed‑modification commands, and emergency‑brake signals to the PT through the Actuation FE, which translates them into motor voltage and steering commands over the same Wi‑Fi/ROS 2 channel."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is required to maintain end‑to‑end latency ≤ 100 ms between vehicle and DT (R7) and clock synchronization accuracy of 100 ms (R8), supporting near‑real‑time control and monitoring."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A distributed architecture where the Physical Twin Entity runs on the on‑board Jetson, the Digital Twin Entity and User Entity run on external compute (e.g., cloud or workstation). Entities communicate via ROS 2 over Wi‑Fi, with a Cross‑System Data Translation FE handling serialization and unit conversion."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity perception through LiDAR point clouds and depth camera data, validated clustering/tracking (DBSCAN + Kalman filter), adherence to ISO 15622 ACC performance class I, latency ≤ 100 ms and clock sync ≤ 100 ms to ensure safety‑critical operation, and off‑line reporting for post‑run validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bi‑directional communication over a Wi‑Fi network using ROS 2 topics; data is serialized and unit‑converted by a Data Translation FE (compatible with OPC UA if needed). Inter‑entity links also use ROS 2 over the same wireless link."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity resides on the vehicle’s NVIDIA Jetson Orin Nano; Digital Twin Entity and User Entity are deployed on separate external hardware (e.g., a PC or cloud server) each as ROS 2 packages. Entities are isolated per hardware layer as shown in Figure 2."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) for entity and functional entity structuring, adopts ISO 15622 for ACC control logic, references ISO/IEC 30173:2023 for digital‑twin concepts, and mentions optional use of OPC UA (IEC 62541) for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed for safety‑critical ACC operation per ISO 15622, enforces ≤ 100 ms latency and clock sync to avoid unsafe timing, and includes an emergency‑brake command. Security mechanisms are not explicitly described in the document."
]