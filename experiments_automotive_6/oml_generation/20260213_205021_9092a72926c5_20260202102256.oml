// C3: Physical sensing components
instance LidarSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor capturing high-frequency raw point cloud streams (XYZ+intensity) transmitted over WiFi using UDP"
    DTDFVocab:producedData LidarPointCloudTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Component gathering vehicle state information (e.g., acceleration, motor state, steering, servo)"
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// C4: Physical-to-virtual interaction
instance LidarPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LidarSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// C10: Models/Data
instance LidarPointCloudData : DTDFVocab:Data [
    base:desc "Normalized LiDAR point cloud data after serialization, unit conversion, and message type normalization"
    DTDFVocab:fromData LidarPointCloudTransmitted
    DTDFVocab:inputTo ROS2CommunicationEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Normalized vehicle state data after unit conversion and semantic consistency enforcement"
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo WebUIEnabler, CloudComputeEnabler
]

instance ObjectTrackingModel : DTDFVocab:Model [
    base:desc "Clustered and tracked object model derived from LiDAR point cloud"
    DTDFVocab:inputTo ROS2CommunicationEnabler
]

instance VehicleStateInterpretationModel : DTDFVocab:Model [
    base:desc "Interpretation model mapping raw vehicle state data into actionable information for UI"
    DTDFVocab:inputTo WebUIEnabler
]

// C11: Enablers
instance ROS2CommunicationEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 node handling data ingestion and distribution over topics among entities"
    DTDFVocab:enables DataMonitoringService
]

instance WebUIEnabler : DTDFVocab:Enabler [
    base:desc "Web-based UI framework exposing real-time telemetry and remote management controls"
    DTDFVocab:enables RemoteManagementService
]

instance CloudComputeEnabler : DTDFVocab:Enabler [
    base:desc "Cloud compute platform receiving ACC decision logic offload requests and returning speed command"
    DTDFVocab:enables ComputationOffloadingService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service streaming real-time vehicle state, projected trajectory and detected object tracks to the web UI, with data export and report generation capabilities."
    DTDFVocab:provides VehicleStateVisualizationInsight, ObjectTrackingInsight, DataExportAction, ReportGenerationAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service offloading ACC decision logic from vehicle ECU to cloud resource and returning computed speed command."
    DTDFVocab:provides ReturnComputedSpeedCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service enabling remote operators to enable/disable ACC, set desired speed, and trigger emergency braking via UI with low latency and safety-critical safeguards."
    DTDFVocab:provides ACCEnableAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights/Actions
instance VehicleStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of vehicle state data in the web UI."
]

instance ObjectTrackingInsight : DTDFVocab:Insight [
    base:desc "Visual representation of clustered and tracked objects in the web UI."
]

instance DataExportAction : DTDFVocab:Action [
    base:desc "Exports collected telemetry data for further analysis."
    DTDFVocab:IsAutomatic false
]

instance ReportGenerationAction : DTDFVocab:Action [
    base:desc "Generates reports from collected telemetry data."
    DTDFVocab:IsAutomatic false
]

instance ReturnComputedSpeedCommandAction : DTDFVocab:Action [
    base:desc "Returns computed speed command from cloud to vehicle."
    DTDFVocab:IsAutomatic true
]

instance ACCEnableAction : DTDFVocab:Action [
    base:desc "Enables Adaptive Cruise Control in the vehicle."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets desired cruising speed for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Triggers emergency braking in the vehicle."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands issued by the digital twin to the physical twin originate from the Motor Actuation FE and Steering Servo Actuation FE components. These command messages are passed through the Data Translation FE, where they are serialised and converted into the required units prior to transmission. The commands are conveyed over the Wi‑Fi network using UDP to the physical twin. The provided description does not mention any specific validation or authentication mechanisms, feedback loops, conflict‑resolution strategies or explicit command‑execution confirmation protocols."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Synchronization accuracy requirement of 100 ms between the physical and digital layers. All device clocks are synchronized so timestamped data and compute offloading events maintain this bound, ensuring causal consistency across the system."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration follows an entity‑based pattern inspired by ISO 23247. Functional elements are mapped to ROS 2 packages, and each package contains one or more ROS 2 nodes that implement the FE’s behavior. Data exchange between entities is performed through ROS‑2 middleware (topics, services, actions). Resource management is distributed across the hardware platform; compute offloading is enabled by shared time synchronisation. The architecture is modular, allowing independent deployment of each FE while maintaining system‑wide coordination through ROS 2."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑component data exchange inside the Digital Twin is performed on a ROS2 network, leveraging ROS2’s DDS‑based publish‑subscribe middleware with QoS profiles tailored to the application. Physical and virtual twin entities are linked across the boundary by a Wi‑Fi network that leaks data over UDP in the transport layer. This flat, controller‑centric topology exposes the Digital Twin’s services to on‑board sensors and external modules. Explicit bandwidth, latency, reliability, redundancy, or security requirements are not specified in the documents, so no quantitative constraints can be derived. The sketch in Fig. 2 indicates that sensor data propagates directly from the vehicle (LiDAR, motor, steering, servo sensors) into the Data Translation FE, then through the ROS2 network to downstream visualization and reporting components."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin interfaces with external components primarily through ROS 2 middleware, conforming to the ISO 23247 functional element model. The Physical Twin Entity is closely aligned with the Open M2M Ecosystem (OME) to host resource‑specific functionality. No explicit enterprise or cross‑system integration patterns are described beyond these ROS 2 interactions."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The document states that the digital twin follows the ISO 23247 Part 2 reference architecture, which defines an entity‑based structure with Observable Manufacturing Elements, Data Collection and Device Control, Digital Twin and User entities. Each entity contains Functional Entities for specific tasks. While the standard does not prescribe a particular middleware, the example model indicates that OPC Unified Architecture could be used to implement the functional entities. No explicit mention of other industry standards or certification frameworks is provided."
]