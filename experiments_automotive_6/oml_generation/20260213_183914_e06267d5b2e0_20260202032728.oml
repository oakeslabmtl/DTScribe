// ===========================
// Physical Sensing Components
// ===========================

// C3: Physical sensing components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing point‑cloud data for perception"
    DTDFVocab:producedData LiDARPointCloudTx
]

instance IntelDepthSenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DepthSense D435i depth camera providing depth image streams"
    DTDFVocab:producedData DepthCameraTx
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board speed sensor delivering vehicle speed measurements"
    DTDFVocab:producedData SpeedTx
]

instance VehicleSteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor delivering current steering wheel angle"
    DTDFVocab:producedData SteeringAngleTx
]

// ===========================
// Data Transmission (Physical → Virtual)
// ===========================

// C4: Physical-to-virtual interaction
instance LiDARPointCloudTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthSenseD435iCamera
]

instance SpeedTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSteeringAngleSensor
]

// ===========================
// Virtual Data Artifacts
// ===========================

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream serialized and unit‑converted"
    DTDFVocab:fromData LiDARPointCloudTx
    DTDFVocab:inputTo PerceptionEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image stream serialized and unit‑converted"
    DTDFVocab:fromData DepthCameraTx
    DTDFVocab:inputTo PerceptionEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed measurement (m/s) serialized and unit‑converted"
    DTDFVocab:fromData SpeedTx
    DTDFVocab:inputTo ACCEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle measurement (rad) serialized and unit‑converted"
    DTDFVocab:fromData SteeringAngleTx
    DTDFVocab:inputTo PerceptionEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Tracked object trajectories (position, velocity) after DBSCAN + Kalman filtering"
    DTDFVocab:inputTo PerceptionEnabler
]

instance ProjectedPathData : DTDFVocab:Data [
    base:desc "Projected vehicle path generated by ACC algorithm"
    DTDFVocab:inputTo ACCEnabler
]

// ===========================
// Models (Digital Twin Algorithms)
// ===========================

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering to isolate individual objects"
    DTDFVocab:inputTo PerceptionEnabler
]

instance KalmanFilterTrackerModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based multi‑object tracker consuming DBSCAN clusters"
    DTDFVocab:inputTo PerceptionEnabler
]

instance ACCModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) model following ISO 15622 to compute desired speed"
    DTDFVocab:inputTo ACCEnabler
]

// ===========================
// Enablers (Software / Middleware)
// ===========================

// DigitalTwin instance required for DTComponent restriction
instance DigitalTwin : DTDFVocab:DigitalTwin [
    base:desc "Digital Twin representation"
]

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware handling ROS topics, services, and actions over Wi‑Fi"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, ReportGenerationService
    base:isContainedIn DigitalTwin
]

instance WiFiNetworkEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi network providing the physical‑to‑virtual communication channel"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, ReportGenerationService
    base:isContainedIn DigitalTwin
]

instance PerceptionEnabler : DTDFVocab:Enabler [
    base:desc "Perception pipeline executing DBSCAN and Kalman filter to produce object tracks"
    DTDFVocab:enables DataMonitoringService
    base:isContainedIn DigitalTwin
]

instance ACCEnabler : DTDFVocab:Enabler [
    base:desc "ACC computation engine running the ACC model and returning desired speed"
    DTDFVocab:enables ComputationOffloadingService
    base:isContainedIn DigitalTwin
]

instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Remote command executor allowing operators to enable/disable ACC, adjust speed, and trigger emergency braking"
    DTDFVocab:enables RemoteManagementService
    base:isContainedIn DigitalTwin
]

instance ReportingEnabler : DTDFVocab:Enabler [
    base:desc "Report generator storing time‑series data in a SQL database and producing PDF/CSV reports"
    DTDFVocab:enables ReportGenerationService
    base:isContainedIn DigitalTwin
]

// ===========================
// Services (Digital Twin Capabilities)
// ===========================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI visualisation of vehicle state, projected path and object tracks"
    DTDFVocab:provides VehicleSpeedInsight, SteeringAngleInsight, ObjectTrackInsight, ProjectedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC computation to the digital twin and returns the desired speed"
    DTDFVocab:provides DesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to remotely manage ACC and trigger emergency actions"
    DTDFVocab:provides EnableACCAction, AdjustDesiredSpeedAction, EmergencyBrakingAction
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generates and stores analytical reports from sensor and model data"
    DTDFVocab:provides GenerateReportAction
]

// ===========================
// Insights (Information Delivered)
// ===========================

instance VehicleSpeedInsight : DTDFVocab:Insight [
    base:desc "Current vehicle speed displayed in the UI (m/s)"
]

instance SteeringAngleInsight : DTDFVocab:Insight [
    base:desc "Current steering angle displayed in the UI (rad)"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Live visualisation of tracked objects with trajectories"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected future path of the vehicle based on ACC output"
]

// ===========================
// Actions (Commands Executed)
// ===========================

instance DesiredSpeedAction : DTDFVocab:Action [
    base:desc "Automatic command setting the vehicle's target speed as computed by ACC"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable the ACC functionality"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator command to manually adjust the desired speed set‑point"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator command to trigger immediate emergency braking"
    DTDFVocab:IsAutomatic false
]

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Operator command to generate a time‑series report stored in the SQL database"
    DTDFVocab:IsAutomatic false
]

// ===========================
// Acting Components (Physical Actuators)
// ===========================

instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Motor driven via Vedder electronic speed controller for speed control"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo controlling the steering angle of the vehicle"
]

// ===========================
// System Entities (Multiplicity)
// ===========================

instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical 1/10‑scale autonomous vehicle housing sensors and actuators"
    base:isContainedIn VehicleHostingEnvironment
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Virtual representation running perception, ACC and UI services"
    base:isContainedIn ExternalHostEnvironment
]

instance UserEntity : DTDFVocab:Component [
    base:desc "Human operator interacting through the UI and remote management console"
    base:isContainedIn ExternalHostEnvironment
]

// ===========================
// Environment (Hosting)
// ===========================

instance VehicleHostingEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity, MotorActuator, SteeringServoActuator, HokuyoUST10LXLiDAR, IntelDepthSenseD435iCamera, VehicleSpeedSensor, VehicleSteeringAngleSensor
]

instance ExternalHostEnvironment : DTDFVocab:Environment [
    base:contains DigitalTwinEntity, ROS2MiddlewareEnabler, WiFiNetworkEnabler, PerceptionEnabler, ACCEnabler, RemoteControlEnabler, ReportingEnabler, DataMonitoringService, ComputationOffloadingService, RemoteManagementService, ReportGenerationService, UserEntity
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity issues control commands—including desired speed for ACC, enable/disable ACC, and emergency‑brake commands—through the Actuation FE over the same Wi‑Fi/ROS 2 link, which are applied to the motor and steering servo of the physical twin."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in real time with a maximum end‑to‑end latency of 100 ms between vehicle and DT (requirement R7) and requires clock synchronization across components within 100 ms accuracy (requirement R8)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates the Physical Twin Entity (sensors, actuators, point‑cloud processing), the Digital Twin Entity (data collection, ACC, reporting, visualization preprocessing), the User Entity (3D visualization UI and control panel), and a Cross‑System Entity (Data Translation FE) communicating via ROS 2 topics over Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during the operation stage for monitoring, control, and remote management, and also during development/testing to troubleshoot ACC behavior, reflecting both operational and developmental life‑cycle phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity LiDAR and depth‑camera data are used for perception; the ACC algorithm complies with ISO 15622; latency and clock‑sync constraints (≤100 ms) ensure timely and coherent interaction, supporting safety‑critical operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses a Wi‑Fi network running ROS 2; data are serialized and transformed by the Data Translation Functional Entity; the standardized communication interface mandated by requirement R1 ensures modular, loosely‑coupled components."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity and User Entity are hosted on external compute hardware (e.g., a workstation or cloud server) distinct from the vehicle’s onboard Jetson; each functional entity runs as a ROS 2 package on its respective host."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows the ISO 23247 reference architecture, adopts the ISO 15622 specification for ACC, utilizes the ISO/IEC 30173 conceptual framework, and implements the standardized communication interface required by R1; ROS 2 provides a de‑facto standard for middleware."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by enforcing a ≤100 ms latency, 100 ms clock sync, and by implementing ACC per ISO 15622; emergency‑brake commands can be issued remotely. No explicit security mechanisms (e.g., authentication, encryption) are described in the document."
]