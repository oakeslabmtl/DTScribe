// =====================
// Physical Sensing Components
// =====================

instance EgoSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Real‑time ego vehicle speed sensor on the 1/10‑scale autonomous vehicle."
    DTDFVocab:producedData EgoSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor providing the current steering wheel position."
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

instance HokuyoUST110LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑110LX 2‑D LiDAR used for object detection and raw point‑cloud generation."
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera supplying depth images for environment perception."
    DTDFVocab:producedData DepthCameraDataTransmitted
]

// =====================
// Data Transmitted (Physical → Virtual)
// =====================

instance EgoSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST110LXLiDAR
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

// =====================
// Digital Twin Data Objects
// =====================

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Time‑series vehicle speed data stored in the SQL database."
    DTDFVocab:fromData EgoSpeedDataTransmitted
    DTDFVocab:inputTo ROS2Middleware, SQLDatabase
]

instance VehicleSteeringAngleData : DTDFVocab:Data [
    base:desc "Time‑series steering angle data stored in the SQL database."
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo ROS2Middleware, SQLDatabase
]

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Aggregated LiDAR point‑clouds used for clustering and tracking."
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
    DTDFVocab:inputTo ROS2Middleware, MATLABSimulinkClusteringTracking
]

instance DepthCameraImageData : DTDFVocab:Data [
    base:desc "Depth images used for environment perception and optional visualization."
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

// =====================
// Models (Digital Twin)
// =====================

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model implementing ISO 15622 performance‑class‑I logic."
    DTDFVocab:inputTo NVIDIAJetPack5SDK, ROS2Middleware
]

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering model applied to LiDAR point‑clouds for object grouping."
    DTDFVocab:inputTo MATLABSimulinkClusteringTracking
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking model for maintaining object tracks over time."
    DTDFVocab:inputTo MATLABSimulinkClusteringTracking
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model rendering speed, steering angle, object tracks and projected path."
    DTDFVocab:inputTo ROS2Middleware
]

// =====================
// Enablers (Technologies)
// =====================

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware handling communication via topics for sensor data, models and services."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance NVIDIAJetPack5SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK providing GPU‑accelerated computation for the ACC algorithm."
    DTDFVocab:enables ComputationOffloadingService
]

instance MATLABSimulinkClusteringTracking : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment executing DBSCAN clustering and Kalman filter tracking."
    DTDFVocab:enables ComputationOffloadingService
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL database storing time‑series vehicle state and object tracks for reporting."
    DTDFVocab:enables DataMonitoringService
]

instance OPCUADatatranslation : DTDFVocab:Enabler [
    base:desc "OPC‑UA interface optionally used for data translation between Physical and Digital twins."
    DTDFVocab:enables RemoteManagementService
]

instance WiFiNetworking : DTDFVocab:Enabler [
    base:desc "Wi‑Fi link transmitting sensor streams from the Physical Twin to the Digital Twin."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

// =====================
// Services (Digital Twin)
// =====================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring service visualizes real‑time speed, steering angle, object tracks and projected path; generates reports."
    DTDFVocab:provides LiveVisualizationInsight, ReportingInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation Offloading service runs the ACC algorithm (lead‑vehicle detection, following‑speed computation) on the Digital Twin."
    DTDFVocab:provides DesiredSpeedInsight, ComputeACCDecisionAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service enables operators to enable/disable ACC, adjust desired speed, and issue emergency braking via UI."
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakeAction, OperatorControlInsight
]

// =====================
// Insights
// =====================

instance LiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live UI visualization of vehicle speed, steering angle, object tracks and projected path."
]

instance ReportingInsight : DTDFVocab:Insight [
    base:desc "Automated generation of performance reports for developers and operators."
]

instance DesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Calculated desired speed output from the ACC model."
]

instance OperatorControlInsight : DTDFVocab:Insight [
    base:desc "Operator UI insight allowing adjustment of ACC parameters and monitoring of system status."
]

// =====================
// Actions
// =====================

instance ComputeACCDecisionAction : DTDFVocab:Action [
    base:desc "Computation of desired speed based on lead‑vehicle detection and following‑speed logic."
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Command to enable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Command to disable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator adjustment of the ACC target speed."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Emergency brake command issued remotely to stop the vehicle."
    DTDFVocab:IsAutomatic false
]

// =====================
// Acting Components (Physical Actuation)
// =====================

instance MotorVoltageCommandActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage command generated by the Actuation Functional Entity and sent to the vehicle’s motor controller."
]

instance SteeringServoActuationActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuation command generated by the Actuation Functional Entity for steering control."
]

instance EmergencyBrakeCommandActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency brake command generated by the Actuation Functional Entity and transmitted to the vehicle’s brake system."
]

// =====================
// System Entities
// =====================

instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical Twin Entity comprising sensors, actuators and embedded computing on the 1/10‑scale autonomous vehicle."
    base:contains EgoSpeedSensor, SteeringAngleSensor, HokuyoUST110LXLiDAR, IntelDeepSenseD435iDepthCamera, MotorVoltageCommandActuator, SteeringServoActuationActuator, EmergencyBrakeCommandActuator
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital Twin Entity responsible for data collection, ACC computation, visualization and reporting."
    base:contains DataMonitoringService, ComputationOffloadingService, RemoteManagementService, ACCControlModel, DBSCANClusteringModel, KalmanFilterTrackingModel, Visualization3DModel, ROS2Middleware, SQLDatabase, NVIDIAJetPack5SDK, MATLABSimulinkClusteringTracking, WiFiNetworking
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User Entity providing the UI for operators and developers to interact with the Digital Twin."
]

instance CrossSystemDataTranslationEntity : DTDFVocab:Component [
    base:desc "Cross‑System Entity delivering data translation, unit conversion and serialization between Physical Twin and Digital Twin."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends desired speed set‑points, ACC enable/disable commands, speed‑modification commands, and emergency‑brake signals to the PT through the Actuation FE, which translates them into motor voltage and steering commands over the same Wi‑Fi/ROS 2 channel."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is required to maintain end‑to‑end latency ≤ 100 ms between vehicle and DT (R7) and clock synchronization accuracy of 100 ms (R8), supporting near‑real‑time control and monitoring."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A distributed architecture where the Physical Twin Entity runs on the on‑board Jetson, the Digital Twin Entity and User Entity run on external compute (e.g., cloud or workstation). Entities communicate via ROS 2 over Wi‑Fi, with a Cross‑System Data Translation FE handling serialization and unit conversion."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity perception through LiDAR point clouds and depth camera data, validated clustering/tracking (DBSCAN + Kalman filter), adherence to ISO 15622 ACC performance class I, latency ≤ 100 ms and clock sync ≤ 100 ms to ensure safety‑critical operation, and off‑line reporting for post‑run validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bi‑directional communication over a Wi‑Fi network using ROS 2 topics; data is serialized and unit‑converted by a Data Translation FE (compatible with OPC UA if needed). Inter‑entity links also use ROS 2 over the same wireless link."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity resides on the vehicle’s NVIDIA Jetson Orin Nano; Digital Twin Entity and User Entity are deployed on separate external hardware (e.g., a PC or cloud server) each as ROS 2 packages. Entities are isolated per hardware layer as shown in Figure 2."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) for entity and functional entity structuring, adopts ISO 15622 for ACC control logic, references ISO/IEC 30173:2023 for digital‑twin concepts, and mentions optional use of OPC UA (IEC 62541) for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed for safety‑critical ACC operation per ISO 15622, enforces ≤ 100 ms latency and clock sync to avoid unsafe timing, and includes an emergency‑brake command. Security mechanisms are not explicitly described in the document."
]