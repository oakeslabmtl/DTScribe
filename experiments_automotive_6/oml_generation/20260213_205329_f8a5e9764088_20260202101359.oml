// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "A lidar unit capturing raw point cloud at high frame rates for object detection"
    DTDFVocab:producedData LiDARRawPointCloudDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "A set of sensors measuring vehicle speed, acceleration, steering angle, and yaw rate"
    DTDFVocab:producedData VehicleStateTelemetryDataTransmitted
]

instance MotorSteeringTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Electronic control unit telemetry providing motor current, torque, and steering torque data"
    DTDFVocab:producedData MotorSteeringTelemetryDataTransmitted
]

// C4: Physical-to-virtual interaction
instance LiDARRawPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance MotorSteeringTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSteeringTelemetrySensor
]

// C10: Models/Data
instance ProcessedPointCloudData : DTDFVocab:Data [
    base:desc "Point cloud processed into a format suitable for clustering and tracking"
    DTDFVocab:inputTo PointCloudProcessingEnabler
    DTDFVocab:fromData LiDARRawPointCloudDataTransmitted
]

instance ProcessedObjectTracksData : DTDFVocab:Data [
    base:desc "Clusters of point cloud mapped to tracked objects with 3D positions and velocities"
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance LeadVehicleDetectionData : DTDFVocab:Data [
    base:desc "Boolean and ID information indicating the presence of a leading vehicle"
    DTDFVocab:inputTo CloudComputeEnabler
]

instance LeadVehicleDistanceData : DTDFVocab:Data [
    base:desc "Euclidean distance to the leading vehicle derived from object track data"
    DTDFVocab:inputTo CloudComputeEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Derived vehicle state vector (speed, acceleration, steering angle) for ACC and monitoring"
    DTDFVocab:inputTo DataTranslationEnabler
    DTDFVocab:fromData VehicleStateTelemetryDataTransmitted
]

instance MotorSteeringTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry of motor and steering actuation parameters for logging and diagnostics"
    DTDFVocab:inputTo DataTranslationEnabler
    DTDFVocab:fromData MotorSteeringTelemetryDataTransmitted
]

instance DesiredSpeedData : DTDFVocab:Data [
    base:desc "Computed desired vehicle speed for ACC to be sent to the onboard ECU"
    DTDFVocab:inputTo CloudComputeEnabler
]

// C11: Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Serializes and aligns incoming sensor data streams using ROS2 and performs unit conversions"
    DTDFVocab:enables DataMonitoringService
]

instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Clusters raw point cloud into object tracks and projects future trajectories using ROS2 tools"
    DTDFVocab:enables ComputationOffloadingService
]

instance CloudComputeEnabler : DTDFVocab:Enabler [
    base:desc "Transport layer that offloads ACC computation to a low‑latency cloud provider via UDP over Wi‑Fi"
    DTDFVocab:enables ComputationOffloadingService
]

instance UIEnabler : DTDFVocab:Enabler [
    base:desc "Web-based user interface network stack providing real‑time visualization and operator controls"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance CloudDataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Persists telemetry into a time‑series database (e.g., InfluxDB) using OPC UA"
    DTDFVocab:enables DataMonitoringService
]

instance ReportingEngineEnabler : DTDFVocab:Enabler [
    base:desc "Generates analytical reports and historical data snapshots from logged telemetry"
    DTDFVocab:enables DataMonitoringService
]

// C10: Models
instance ACCBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model of the ACC that defines the control law for desired speed computation"
    DTDFVocab:inputTo CloudComputeEnabler
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Displays real‑time vehicle state, tracks, and projected paths supports report creation"
    DTDFVocab:provides VehicleStateInsight, ObjectTrackingInsight, DesiredSpeedComputationInsight, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Cloud‑based Adaptive Cruise Control module that calculates desired speed and sends control commands"
    DTDFVocab:provides DesiredSpeedComputationInsight, SetVehicleSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable ACC, override desired speed, and trigger emergency braking over a low‑latency link"
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedUserAction, EmergencyBrakeAction
]

// C17: Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time vehicle state metrics visualized in the UI"
]

instance ObjectTrackingInsight : DTDFVocab:Insight [
    base:desc "Live view of detected objects and their predicted trajectories"
]

instance DesiredSpeedComputationInsight : DTDFVocab:Insight [
    base:desc "Computed desired speed value for ACC shown to operators"
]

// C17: Actions
instance SetVehicleSpeedAction : DTDFVocab:Action [
    base:desc "Sends computed desired speed command to the on‑board ECU"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables or disables the ACC module in the digital twin and vehicle"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedUserAction : DTDFVocab:Action [
    base:desc "Operator‑initiated override to set a manual desired speed"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Triggers an emergency braking maneuver on the vehicle"
    DTDFVocab:IsAutomatic true
]

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Generates a historical data report from logged telemetry"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the digital twin (e.g., desired speed or emergency braking) are encapsulated as UDP packets via the Wi‑Fi network and delivered to the vehicle’s actuation controllers. Commands are processed by the Data Translation component which formats the message, performs unit‑conversions, and aligns message types. Vehicle actuation hardware executes the commands, and acknowledgment messages reporting execution status are sent back to the digital twin, ensuring round‑trip confirmation. Conflict resolution between concurrent commands is handled by the control‑panel FE, which prioritises safety‑critical instructions."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin System requires all component clocks to be synchronized with an accuracy of 100 ms. Network latency from the vehicle to the Digital Twin Entity must not exceed 100 ms. This 100 ms bound is specifically chosen due to hardware limitations, although stricter synchronization (<100 ms) is normally mandated for safety‑critical vehicular applications."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows ISO 23247 Reference Architecture. Each Functional Element (FE) is implemented as an individual ROS 2 package, which may contain one or more ROS 2 nodes. This mapping aligns the software components with the ISO 23247 entity-based structure, resulting in three distinct entities: User, Digital Twin, and Physical Twin. The User Entity hosts the User Interface FE split into a 3D Visualization FE and a Control Panel FE. The Digital Twin Entity houses data storage, preprocessing, and control logic. The Physical Twin Entity interfaces directly with the vehicle’s compute, sensors, and actuators and executes compute‑heavy functions such as point‑cloud clustering and tracking."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Software components communicate over a ROS2 network, while inter‑entity communication occurs over a Wi‑Fi network using UDP as the transport layer. The Data Translation component (ISO 23247 Data Translation FE) manages serialization, message type alignment, and unit conversions across the network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to ISO 23247 – Digital twin framework for manufacturing, particularly Part 2 (reference architecture). The standard describes an entity‑based architecture comprising an Observable Manufacturing Element (OME), a Data Collection and Device Control Entity, a Digital Twin Entity, and a User Entity, each composed of Functional Entities (FEs) that perform tasks such as actuating the OME, transforming data, and interfacing with users. While ISO 23247 does not prescribe implementation details, it recommends interoperability protocols such as OPC Unified Architecture (OPC UA) for communication between functional entities."
]