// C3: Physical sensing components
instance HokuyoUSt10LX2DLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2‑D LiDAR mounted on the vehicle, providing distance measurements for the Point Cloud Clustering & Tracking component"
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera mounted on the vehicle, supplying RGB‑D data for perception tasks"
    DTDFVocab:producedData DepthRGBDataTransmitted
]

// C4: Physical‑to‑virtual interaction – Data Transmitted
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "LiDAR point cloud data transmitted from Hokuyo UST‑10LX 2‑D LiDAR"
    DTDFVocab:producedFrom HokuyoUSt10LX2DLidar
]

instance DepthRGBDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "RGB‑D data transmitted from Intel DeepSense D435i depth camera"
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

// C10: Models/Data – Raw Data captured in the DTS
instance RawPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data received by the DTS"
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
]

instance RawDepthRGBData : DTDFVocab:Data [
    base:desc "Raw RGB‑D data received by the DTS"
    DTDFVocab:fromData DepthRGBDataTransmitted
]

// C10: Computational model for perception
instance PointCloudClusteringTracking : DTDFVocab:Model [
    base:desc "Computational model performing DBSCAN clustering and Kalman filter tracking on raw LiDAR point clouds to produce object tracks"
    DTDFVocab:inputTo ClusteringTrackingEnabler
]

// C11: Enablers
instance ClusteringTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that processes raw LiDAR point clouds and provides object tracks via the Clustering Tracking Service"
    DTDFVocab:enables ClusteringTrackingService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that aggregates object tracks and ego vehicle state into a relational SQL database"
    DTDFVocab:enables DataMonitoringService
]

instance OffloadingServiceEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for computation off‑loading of the Adaptive Cruise Control (ACC) algorithm to cloud resources"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that allows operators to enable/disable ACC, set target speed, and issue emergency‑brake commands"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance ClusteringTrackingService : DTDFVocab:Service [
    base:desc "Service that delivers computed object tracks to the digital twin"
    DTDFVocab:provides ObjectTrackInsight
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service that provides real‑time data monitoring, visualisation, and reporting of vehicle state, projected trajectory, and object tracks"
    DTDFVocab:provides VehicleStateInsight, TrajectoryProjectionInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service that streams the computed desired speed from cloud‑based ACC algorithm back to the vehicle"
    DTDFVocab:provides DesiredSpeedControlAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service that exports remote management capabilities to the operator UI"
    DTDFVocab:provides EmergencyBrakeAction, EnableACCAction, SetTargetSpeedAction
]

// C17: Insights
instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Insight representing detected object tracks in the environment"
]

instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight representing ego vehicle state variables"
]

instance TrajectoryProjectionInsight : DTDFVocab:Insight [
    base:desc "Insight representing projected driving path"
]

// C17: Actions
instance DesiredSpeedControlAction : DTDFVocab:Action [
    base:desc "Automatic action that commands desired speed to the vehicle’s speed controller"
    DTDFVocab:IsAutomatic true
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Manual action to trigger emergency braking"
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Manual action to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Manual action to set a target speed for the vehicle"
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller converting desired speed commands into motor voltage commands for propulsion"
]

instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Steering servo that adjusts wheel angle in response to control commands"
]

// Environment holding the physical components
instance VehicleEnvironment : DTDFVocab:Environment [
    base:contains HokuyoUSt10LX2DLidar, IntelDeepSenseD435iDepthCamera, VedderElectronicSpeedController, SteeringServo
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DTS runs the ACC service, computes the lead‑vehicle identification and desired speed, and sends the desired speed command back to the vehicle where an Actuation Front‑End (Motor, Steering, Servo) executes the actuation. The Remote Management UI can also transmit enable/disable ACC commands, set‑point speed adjustments and emergency‑braking commands to the physical twin. These control messages are conveyed over the same Wi‑Fi UDP channel used for sensor data, but the documents do not detail the command payload format, validation, authentication, or acknowledgement protocols."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires that all devices share a common notion of time to enable computation offloading; clock synchronization must achieve 100 ms accuracy (limited by hardware), while many safety‑critical vehicular standards mandate tighter synchronization, indicating that the digital twin operates on a sub‑second time granularity with a synchronization interval of at most 100 ms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin follows the ISO 23247 reference architecture, organizing software components into Functional Entities (FEs) that are implemented as individual ROS 2 packages containing one or more ROS 2 nodes. The Physical Twin Entity hosts resource‑specific functionality (e.g., point‑cloud clustering), the Digital Twin Entity provides data management and control, and the User Entity contains the User Interface FE split into visualization and control panel. This entity‑based design orchestrates the system through ROS 2 communication and ROS‑based component integration."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS intra‑component communication relies on a ROS 2 network, providing publish/subscribe messaging among software modules. Inter‑entity (physical‑digital) communication uses a Wi‑Fi network with UDP as the transport protocol. The system is required to support low end‑to‑end latency communication to satisfy safety‑critical ACC operation, though specific latency, bandwidth, reliability, redundancy or security protocol details are not provided in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin’s compute workload (e.g., the ACC algorithm, data collection, reporting and visualization services) is off‑loaded from the resource‑constrained vehicle to external compute resources described as “cloud” or other off‑vehicle platforms. These platforms host ROS 2 nodes for the various Front‑Ends (Data Monitoring, Computation Offloading, Remote Management) and provide storage for collected vehicle state and sensor data. Deployment can thus be distributed, with the physical twin on‑board the vehicle and the digital twin services on remote servers or edge devices capable of running the required ROS 2 components. While the documents mention the need for scalability and low latency, they do not specify concrete hardware models, storage capacities, scalability mechanisms, redundancy strategies, or availability guarantees."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The ISO 23247 framework allows Functional Entities to be implemented with standards such as OPC Unified Architecture (OPC UA), suggesting that external data exchange and interoperability with other enterprise systems can be achieved via OPC UA. No additional external integration patterns or protocols are detailed in the provided documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adopts the ISO 23247 digital‑twin framework for manufacturing, specifically part 2 (Reference Architecture), to structure the twin into Observable Manufacturing Elements, Data Collection and Device Control Entity, Digital Twin Entity, and User Entity, each composed of Functional Entities. The implementation follows the ISO‑defined entity‑based approach and aligns software components with the corresponding functional entities. Communication and interoperability may employ OPC Unified Architecture (OPC UA) as suggested in the standard, although the actual deployment uses ROS 2 packages for intra‑twin communication."
]