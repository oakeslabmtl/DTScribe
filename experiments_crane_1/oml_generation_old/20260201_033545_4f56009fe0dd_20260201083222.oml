// ----------------------------------------------------
// C3: Physical sensing components
// ----------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorControllerFeedback : DTDFVocab:SensingComponent [
    base:desc "Motor controller feedback (position/speed) accessed via the Arduino interface"
    DTDFVocab:producedData MotorFeedbackDataTransmitted
]

// ----------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// ----------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance MotorFeedbackDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerFeedback
]

// ----------------------------------------------------
// C5: Data (time‑series)
// ----------------------------------------------------
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo MQTTBrokerMosquitto, TimescaleDBDatabase
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo MQTTBrokerMosquitto, TimescaleDBDatabase
]

instance MotorFeedbackTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of motor position and speed feedback"
    DTDFVocab:fromData MotorFeedbackDataTransmitted
    DTDFVocab:inputTo MQTTBrokerMosquitto, TimescaleDBDatabase
]

// ----------------------------------------------------
// C10: Models / Data used by services
// ----------------------------------------------------
instance CADModelFusion360 : DTDFVocab:Model [
    base:desc "CAD models created in Autodesk Fusion 360"
    DTDFVocab:inputTo SimulationService
]

instance KinematicModelTrajectoryGenerator : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator"
    DTDFVocab:inputTo TrajectoryGenerationService
]

instance DynamicSimulationModelCrane : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the crane and its controllers"
    DTDFVocab:inputTo SimulationService
]

instance ValidationMetricsData : DTDFVocab:Data [
    base:desc "Validation metrics produced by the Continuous Validation Service"
    DTDFVocab:inputTo ContinuousValidationService
]

// ----------------------------------------------------
// C11: Enablers (tools, platforms)
// ----------------------------------------------------
instance MQTTBrokerMosquitto : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for publishing sensor data and events"
    DTDFVocab:enables DataLoggingService, ContinuousValidationService
]

instance TimescaleDBDatabase : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) for historical storage of time‑series data"
    DTDFVocab:enables HistoricalDataStorageService, ContinuousValidationService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboards for real‑time visualization"
    DTDFVocab:enables RealTimeVisualizationService
]

instance DockerComposeOrchestrator : DTDFVocab:Enabler [
    base:desc "Docker‑Compose for containerised deployment of all twin services"
    DTDFVocab:enables DataLoggingService, HistoricalDataStorageService, RealTimeVisualizationService,
               TrajectoryGenerationService, SimulationService, ContinuousValidationService
]

instance PhysicalCraneInterfacePython : DTDFVocab:Enabler [
    base:desc "Python 'gantrylib' module that reads sensor values from Arduino and motor controllers and publishes via MQTT"
    DTDFVocab:enables DataLoggingService, ContinuousValidationService
]

// ----------------------------------------------------
// C6: Services
// ----------------------------------------------------
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs incoming sensor data into TimescaleDB"
    DTDFVocab:provides DataLoggingInsight
]

instance HistoricalDataStorageService : DTDFVocab:Service [
    base:desc "Stores time‑series data persistently in TimescaleDB"
    DTDFVocab:provides HistoricalDataInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualisation dashboards via Grafana"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal crane trajectories with confidence intervals"
    DTDFVocab:provides TrajectoryVisualizationInsight, TrajectorySelectionAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs full‑physics simulation of crane and controllers"
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares measured trajectories with simulated ones and raises alerts when thresholds are exceeded"
    DTDFVocab:provides ValidationAlertInsight
]

// ----------------------------------------------------
// C17: Insights / Actions
// ----------------------------------------------------
instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert raised when validation thresholds are exceeded"
]

instance TrajectoryVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualises optimal trajectories and confidence intervals for the operator"
]

instance TrajectorySelectionAction : DTDFVocab:Action [
    base:desc "Enables operator to select new trajectories to improve performance"
    DTDFVocab:IsAutomatic false
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Shows live sensor and state visualisation on Grafana dashboards"
]

instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Confirms successful logging of sensor data"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Provides access to stored historical time‑series data"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Presents simulation results and performance predictions"
]

// ----------------------------------------------------
// C2: Acting components
// ----------------------------------------------------
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor controlled by TMC4671‑Eval controller"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor controlled by TMC4671‑Eval controller"
]

instance ElectromagnetHoistTip : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist tip used to pick up containers"
]

// ----------------------------------------------------
// C13: Environment and physical component
// ----------------------------------------------------
instance PhysicalGantryCrane : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane comprising cart motor, hoist motor, electromagnet, swing‑angle encoder, and anemometer"
]

instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains PhysicalGantryCrane, CartStepperMotor, HoistStepperMotor, ElectromagnetHoistTip,
                     SwingAngleEncoder, WindSpeedAnemometer, MotorControllerFeedback
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application receives desired motion commands from the Trajectory Generator Service (optimal trajectories) via the MQTT broker and forwards them through the Physical Crane Interface to the motor controllers and electromagnet to actuate the crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A hybrid cyber‑physical architecture where the physical crane is connected to a personal computer via a Python interface; services run as Docker containers on the same machine; MQTT broker mediates messaging among services; data persists in TimescaleDB; operators interact via a web‑based HMI and Grafana dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin includes design artefacts (CAD models of the crane), manufacturing/assembly representation (physical hardware), and operational models (kinematic model, simulation, real‑time data) used during runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously computes distance metrics between measured trajectories and simulated trajectories, compares them against a predefined threshold, and triggers operator alerts when breached; simulation provides confidence bounds (upper/lower) displayed on the dashboard."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Message exchange between PT and DT components uses MQTT (Eclipse Mosquitto) over TCP/IP; sensor data and control commands are serialized in MQTT topics; low‑level controller communication is via serial/USB to Arduino."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital‑twin containers (TimescaleDB, MQTT broker, Grafana, trajectory generator, simulator, validation) are Dockerised and deployed on a single personal computer using a Docker‑Compose file that automatically initialises the database and dashboard."
]