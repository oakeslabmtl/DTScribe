// --------------------------------------------------------------
// Sensing Components
// --------------------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing-angle encoder measuring hoist swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed for the gantry crane"
    DTDFVocab:producedData WindDataTransmitted
]

instance ArduinoAcquisitionUnit : DTDFVocab:SensingComponent [
    base:desc "Arduino-based acquisition unit collecting sensor signals from the encoder and anemometer"
    DTDFVocab:producedData ArduinoDataTransmitted
]

// --------------------------------------------------------------
// Data Transmitted
// --------------------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Data transmitted from SwingAngleEncoder containing swing angle measurements"
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Data transmitted from Anemometer containing wind speed measurements"
    DTDFVocab:producedFrom Anemometer
]

instance ArduinoDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Data transmitted from ArduinoAcquisitionUnit containing raw sensor payloads"
    DTDFVocab:producedFrom ArduinoAcquisitionUnit
]

// --------------------------------------------------------------
// Data Instances (stored in TimescaleDB)
// --------------------------------------------------------------
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time-series swing angle data stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, GrafanaEnabler
]

instance WindData : DTDFVocab:Data [
    base:desc "Time-series wind speed data stored in TimescaleDB"
    DTDFVocab:fromData WindDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, GrafanaEnabler
]

instance ArduinoRawData : DTDFVocab:Data [
    base:desc "Raw acquisition data from Arduino stored in TimescaleDB"
    DTDFVocab:fromData ArduinoDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, GrafanaEnabler
]

// --------------------------------------------------------------
// Acting Components
// --------------------------------------------------------------
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor driven by TMC4671‑Eval controller moving the gantry horizontally"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor driven by TMC4671‑Eval controller lifting the load"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet used to grip and release pucks"
]

// --------------------------------------------------------------
// Models
// --------------------------------------------------------------
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the crane created with Autodesk Fusion 360"
    DTDFVocab:inputTo Fusion360Enabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used for generating optimal swing‑free trajectories"
    DTDFVocab:inputTo PythonGantryLibEnabler
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of crane dynamics and controller behavior"
    DTDFVocab:inputTo DockerComposeEnabler
]

// --------------------------------------------------------------
// Enablers (Tools & Platforms)
// --------------------------------------------------------------
instance PythonGantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module providing kinematic calculations and control logic"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker and Docker‑Compose orchestrating containerised services on a single PC"
    DTDFVocab:enables CraneSimulationService, ContinuousValidationService, HumanMachineInterfaceService, TrajectoryGeneratorService, LoggingApplicationService, GrafanaDashboardService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL‑based) storing operational time‑series data"
    DTDFVocab:enables LoggingApplicationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard visualizing stored time‑series data"
    DTDFVocab:enables GrafanaDashboardService
]

instance MosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker enabling messaging between services"
    DTDFVocab:enables ContinuousValidationService, HumanMachineInterfaceService
]

instance ArduinoFirmwareEnabler : DTDFVocab:Enabler [
    base:desc "Arduino firmware (KiCad shield) acquiring sensor signals"
]

instance Fusion360Enabler : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion 360 tool used for creating CAD geometry"
]

instance OpenSourceKinematicsLibEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source kinematics library supporting trajectory generation"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance OpenSourceControlLibEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source control library for crane controller implementation"
]

// --------------------------------------------------------------
// Services
// --------------------------------------------------------------
instance LoggingApplicationService : DTDFVocab:Service [
    base:desc "Logging Application records sensor data into TimescaleDB"
    DTDFVocab:provides FaultDetectionInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana Dashboard visualizes operational data for operators"
    DTDFVocab:provides OperationalDataVisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Trajectory Generator Service creates optimal swing‑free trajectories using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance CraneSimulationService : DTDFVocab:Service [
    base:desc "Simulation Service simulates crane dynamics and controller behavior"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous Validation Service validates executed trajectories against planned ones and flags deviations"
    DTDFVocab:provides DeviationFlagInsight, OperatorNotificationAction
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Human‑Machine Interface allows operator control of the crane and displays alerts"
    DTDFVocab:provides OperatorControlAction
]

// --------------------------------------------------------------
// Insights
// --------------------------------------------------------------
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal, swing‑free trajectories are generated for each move"
]

instance DeviationFlagInsight : DTDFVocab:Insight [
    base:desc "Continuous validation flags deviations from planned trajectories"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Time‑series classification research identifies system faults"
]

instance OperationalDataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization insight presenting operational time‑series data to operators"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight describing simulation results of crane dynamics"
]

// --------------------------------------------------------------
// Actions
// --------------------------------------------------------------
instance OperatorNotificationAction : DTDFVocab:Action [
    base:desc "Notifies operators of trajectory deviations enabling corrective actions"
    DTDFVocab:IsAutomatic false
]

instance FaultDetectionAction : DTDFVocab:Action [
    base:desc "Triggers fault diagnosis workflow based on classification results"
    DTDFVocab:IsAutomatic true
]

instance OperatorControlAction : DTDFVocab:Action [
    base:desc "Allows operator to command crane movements via the HMI"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends motion commands and trajectory set‑points, generated by the Trajectory Generator Service, to the Physical Crane Interface via MQTT; the interface translates them to controller commands for the cart and hoist motors and activates the electromagnet."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A C4‑model based architecture linking the Physical Crane, Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface with digital services (Database, MQTT broker, Dashboard, Trajectory Generator, Simulation, Continuous Validation) orchestrated via Docker Compose on a single workstation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans design (CAD models in Autodesk Fusion‑360, kinematic model), manufacturing (physical crane assembly), and operation (real‑time monitoring, logging, validation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, checks against predefined thresholds and alerts operators via the dashboard; model validation methods are reused from prior work to ensure twin accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual data conveyed via a Python interface over serial/USB to the Arduino and motor controllers; MQTT (Eclipse Mosquitto) used for signalling between services; all components communicate over localhost network within Docker Compose."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software runs on a personal computer; Docker containers host the TimescaleDB, MQTT broker and Grafana dashboard; Python modules and applications run as processes; deployment is automated with a Docker Compose file."
]