// C2: Acting Components
instance XAxisMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Motor driving the trolley along the X‑axis of the gantry crane"
]

instance YAxisMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Motor driving the hoist along the Y‑axis of the gantry crane"
]

instance MotorControllerXAxisActuator : DTDFVocab:ActingComponent [
    base:desc "Motor controller receiving commands for the X‑axis motor"
]

instance MotorControllerYAxisActuator : DTDFVocab:ActingComponent [
    base:desc "Motor controller receiving commands for the Y‑axis motor"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet attached to the hoist end for gripping small pucks"
]

instance PowerSupplyUnitActuator : DTDFVocab:ActingComponent [
    base:desc "Shared power‑supply unit powering all actuators"
]

instance ArduinoBoardActuator : DTDFVocab:ActingComponent [
    base:desc "Arduino board mediating communication between motor controllers, sensors and the digital twin"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring angular deviation of the crane’s load"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer recording ambient wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// C10: Data
instance SwingAngleMeasurementData : DTDFVocab:Data [
    base:desc "Raw swing angle measurement values"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedMeasurementData : DTDFVocab:Data [
    base:desc "Raw wind speed measurement values"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance storing logged sensor and actuator data"
    DTDFVocab:enables HistoricalLoggingService
]

instance ControlEngineEnabler : DTDFVocab:Enabler [
    base:desc "Computation engine that uses CAD and kinematic models to generate optimal motion commands"
    DTDFVocab:enables OptimalControlService
]

instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Visualization engine rendering the crane’s kinematic state and puck positions"
    DTDFVocab:enables DataVisualizationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation engine comparing real‑time measurements with the CAD/kinematic model"
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes and transmits optimal motion commands to the crane controller based on model predictions"
    DTDFVocab:provides ComputeOptimalMotionAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Continuously logs sensor and actuator states into TimescaleDB"
    DTDFVocab:provides LogMeasurementAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Renders the crane’s kinematic state and puck positions for operators"
    DTDFVocab:provides VisualizeKinematicStateInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares real‑time measurements with the CAD/kinematic model to detect deviations"
    DTDFVocab:provides DetectDeviationInsight
]

// C17: Insights/Actions
instance ComputeOptimalMotionAction : DTDFVocab:Action [
    base:desc "Computes and transmits motion commands to the crane controller"
    DTDFVocab:IsAutomatic true
]

instance LogMeasurementAction : DTDFVocab:Action [
    base:desc "Inserts raw sensor measurements into TimescaleDB"
    DTDFVocab:IsAutomatic true
]

instance VisualizeKinematicStateInsight : DTDFVocab:Insight [
    base:desc "Provides visual representation of current crane kinematics and puck locations"
]

instance DetectDeviationInsight : DTDFVocab:Insight [
    base:desc "Detects deviations between measured state and model predictions"
]

// C10: Models/Data
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "CAD geometric model of the laboratory‑scale gantry crane"
    DTDFVocab:inputTo ControlEngineEnabler, VisualizationEngineEnabler, ValidationEngineEnabler
]

instance KinematicBehaviorModel : DTDFVocab:Model [
    base:desc "Kinematic (behavioral) model used to simulate crane motion and generate control commands"
    DTDFVocab:inputTo ControlEngineEnabler, ValidationEngineEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, a Python program, sends control commands to the Physical Crane Interface, which in turn drives the actuators of the Physical Crane. Trajectory commands generated by the Trajectory Generator Service are delivered to the Control Application for execution. The document does not detail the command message format, validation, authentication, or acknowledgment mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The exemplar adopts an ad‑hoc architecture based on containerization and virtualization. Physical components such as Raspberry‑Pi devices (Air Quality Management) or virtual machines (GreenhouseDT) host sensors and expose data to the digital twin through an ActiveMQ message broker. Time‑series and state information are stored in an InfluxDB database. The software stack is organized into multiple Docker containers, as illustrated by the C4 container diagram, and the overall system architecture is visualized with C4 context and container diagrams. No commercial digital‑twin framework is employed; service coordination relies on the message broker and standard network protocols."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A continuous validation service is provided that compares real‑time crane states with predictions from the kinematic model, allowing detection of model drift. The documents do not specify quantitative fidelity targets, uncertainty quantification methods, or detailed verification procedures."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin relies on an MQTT broker that provides signaling between the Trajectory Generator Service, Simulation Service, Continuous Validation Service and other components. The containers (Python applications, TimescaleDB, Grafana) are connected via this broker using the MQTT protocol. No further details on network topology, bandwidth, latency, redundancy or security are provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system is intended to run on a single personal computer onto which the physical crane is plugged. All software components—including the Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface, and the digital‑twin services—execute on this host. Core digital‑twin services (TimescaleDB database, MQTT broker, Grafana dashboard) are containerized with Docker for easy deployment and isolation. No cloud, edge, or separate on‑premise servers are used; scalability and availability depend on the resources and stability of the host PC, and no explicit redundancy or high‑availability mechanisms are described."
]