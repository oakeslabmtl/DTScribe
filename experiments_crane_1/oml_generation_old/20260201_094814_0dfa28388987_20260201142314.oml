instance PhysicalCraneContainer : DTDFVocab:Component [ // Return code: 1 | Stderr:
    base:desc "Docker container running the physical gantry crane hardware interface."
]

instance PhysicalCraneInterfaceContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the Python control application that translates trajectories into stepper motor commands."
]

instance ControlApplicationContainer : DTDFVocab:Component [
    base:desc "Docker container for the main Control Application that publishes motor command messages to the MQTT broker."
]

instance LoggingApplicationContainer : DTDFVocab:Component [
    base:desc "Docker container for the Logging Application that subscribes to sensor and event topics and persists data to TimescaleDB."
]

instance HMIContainer : DTDFVocab:Component [
    base:desc "Docker container serving the Human–Machine Interface via a web dashboard."
]

instance TimescaleDBContainer : DTDFVocab:Component [
    base:desc "Docker container provisioning a PostgreSQL‑based TimescaleDB instance for telemetry storage."
]

instance GrafanaContainer : DTDFVocab:Component [
    base:desc "Docker container running Grafana for real‑time visualization of time‑series data."
]

instance TrajectoryGeneratorServiceContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the Trajectory Generation Service that produces swing‑free velocity‑position waypoints."
]

instance SimulationServiceContainer : DTDFVocab:Component [
    base:desc "Docker container running the Real‑time Simulation Service that evaluates crane dynamics."
]

instance ContinuousValidationServiceContainer : DTDFVocab:Component [
    base:desc "Docker container for the Continuous Validation Service that compares real motion against expected trajectories."
]

instance MosquittoBrokerContainer : DTDFVocab:Component [
    base:desc "Docker container running the Eclipse Mosquitto MQTT broker facilitating publish/subscribe messaging."
]

instance DockerComposeContainer : DTDFVocab:Component [
    base:desc "Docker Compose orchestration container that manages all singleton containers."
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Orchestrator enabling all singleton Docker containers via docker‑compose."
    DTDFVocab:enables PhysicalCraneContainer, PhysicalCraneInterfaceContainer, ControlApplicationContainer, LoggingApplicationContainer, HMIContainer, TimescaleDBContainer, GrafanaContainer, TrajectoryGeneratorServiceContainer, SimulationServiceContainer, ContinuousValidationServiceContainer, MosquittoBrokerContainer
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance enabler that enables data persistence and analytics services."
    DTDFVocab:enables LoggingService, ContinuousValidationService, VisualizationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana instance enabler that enables real‑time visualization services."
    DTDFVocab:enables VisualizationService
]

instance MosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker enabler that enables all publish/subscribe services."
    DTDFVocab:enables ControlApplicationService, LoggingService, ContinuousValidationService, TrajectoryGenerationService, RealTimeSimulationService, FaultDetectionService
]

instance PythonEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime enabler that supplies the Python services."
    DTDFVocab:enables ControlApplicationService, LoggingService, TrajectoryGenerationService, RealTimeSimulationService, ContinuousValidationService, FaultDetectionService, VisualizationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the Continuous Validation Service."
    DTDFVocab:enables ContinuousValidationService
]

instance CommandPublicationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that the Control Application published motor commands to MQTT."
]

instance ControlApplication : DTDFVocab:ActingComponent [
    base:desc "Python application that publishes motor command messages and trajectory execution events to the MQTT broker."
]

instance PhysicalCraneInterface : DTDFVocab:ActingComponent [
    base:desc "Interface translating trajectory waypoints into stepper pulse commands for cart and hoist motors."
]

instance TrajectoryGeneratorActingComponent : DTDFVocab:ActingComponent [
    base:desc "Component that generates optimised, swing‑free velocity‑position trajectories."
]

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder mounted on the hoist shaft, publishing encoder counts via MQTT."
    DTDFVocab:producedData SwingAngleEncoderTopic
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed, publishing readings via MQTT."
    DTDFVocab:producedData AnemometerTopic
]

instance StepperMotorCurrentReadout : DTDFVocab:SensingComponent [
    base:desc "Analog current readouts from the stepper motor drivers, publishing readings via MQTT."
    DTDFVocab:producedData StepperCurrentTopic
]

instance ArduinoSerialConnection : DTDFVocab:SensingComponent [
    base:desc "USB serial connection from the Arduino controller that streams raw sensor data via MQTT."
    DTDFVocab:producedData ArduinoSerialTopic
]

instance SwingAngleEncoderTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance StepperCurrentTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StepperMotorCurrentReadout
]

instance ArduinoSerialTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoSerialConnection
]

instance TrajectoryExecutionEventTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ControlApplication
]

instance SwingAngleTelemetry : DTDFVocab:Data [
    base:desc "Persisted swing‑angle telemetry with UTC timestamps."
    DTDFVocab:fromData SwingAngleEncoderTopic
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEnabler
]

instance AnemometerTelemetry : DTDFVocab:Data [
    base:desc "Persisted wind‑speed telemetry with UTC timestamps."
    DTDFVocab:fromData AnemometerTopic
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEnabler
]

instance StepperCurrentTelemetry : DTDFVocab:Data [
    base:desc "Persisted stepper motor current telemetry with UTC timestamps."
    DTDFVocab:fromData StepperCurrentTopic
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEnabler
]

instance ArduinoSerialTelemetry : DTDFVocab:Data [
    base:desc "Persisted raw serial data from the Arduino controller with UTC timestamps."
    DTDFVocab:fromData ArduinoSerialTopic
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEnabler
]

instance TrajectoryExecutionEventData : DTDFVocab:Data [
    base:desc "Persisted trajectory execution events (start, progress, finish) with UTC timestamps."
    DTDFVocab:fromData TrajectoryExecutionEventTopic
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEnabler
]

instance CADModelFusion360 : DTDFVocab:Model [
    base:desc "Fusion 360 CAD model of the lab‑scale gantry crane."
]

instance SymbolicKinematicModel : DTDFVocab:Model [
    base:desc "Symbolic kinematic model used by the Trajectory Generation Service."
]

instance SimulationStateModelCart : DTDFVocab:Model [
    base:desc "Simulation state model of the cart dynamics."
]

instance SimulationStateModelHoist : DTDFVocab:Model [
    base:desc "Simulation state model of the hoist dynamics."
]

instance TimescaleDBTelemetryTable : DTDFVocab:Data [
    base:desc "TimescaleDB table storing aggregated telemetry data."
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance GrafanaDashboardDataModel : DTDFVocab:Model [
    base:desc "Grafana dashboard computing statistics and confidence bounds from telemetry."
    DTDFVocab:inputTo GrafanaEnabler
]

instance ControlApplicationService : DTDFVocab:Service [
    base:desc "Service that publishes motor commands and trajectory events to MQTT."
    DTDFVocab:provides CommandPublicationInsight
]

instance LoggingService : DTDFVocab:Service [
    base:desc "Service that persists sensor telemetry and event data to TimescaleDB."
    DTDFVocab:provides DataPersistedInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service that generates swing‑free optimal trajectories."
    DTDFVocab:provides UpdateTrajectoryPlanAction
]

instance RealTimeSimulationService : DTDFVocab:Service [
    base:desc "Service that runs real‑time simulation of the crane dynamics."
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that validates real motion against expected trajectories and detects anomalies."
    DTDFVocab:provides TrajectoryDeviationInsight, SwingBehaviorDeviationInsight, FaultDetectionAlertInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service that performs time‑series classification for fault detection."
    DTDFVocab:provides FaultDetectionAlertInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that renders real‑time telemetry dashboards in Grafana."
    DTDFVocab:provides RealTimeAlertInsight
]

instance TrajectoryDeviationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that the executed trajectory deviates from the calculated optimal path."
]

instance SwingBehaviorDeviationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating abnormal swing behaviour detected in the hoist."
]

instance FaultDetectionAlertInsight : DTDFVocab:Insight [
    base:desc "Insight alerting operators to detected faults via time‑series classification."
]

instance RealTimeAlertInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time alert status on the Grafana dashboard."
]

instance DataPersistedInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful persistence of telemetry data to TimescaleDB."
]

instance UpdateTrajectoryPlanAction : DTDFVocab:Action [
    base:desc "Automatic action to update the trajectory plan when deviations are detected."
    DTDFVocab:IsAutomatic true
]

instance TriggerPreventiveMaintenanceAction : DTDFVocab:Action [
    base:desc "Automatic action to trigger preventive maintenance when fault is detected."
    DTDFVocab:IsAutomatic true
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating simulation results for comparison with real motion."
]

instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Lab‑scale gantry crane system with cart, hoist, stepper motors, electromagnet, sensors, and controller."
    base:contains PhysicalCraneContainer, PhysicalCraneInterfaceContainer, ControlApplicationContainer, LoggingApplicationContainer, HMIContainer, TimescaleDBContainer, GrafanaContainer, TrajectoryGeneratorServiceContainer, SimulationServiceContainer, ContinuousValidationServiceContainer, MosquittoBrokerContainer, SwingAngleEncoder, Anemometer, StepperMotorCurrentReadout, ArduinoSerialConnection, CartComponent, HoistComponent, ElectromagnetComponent, PSU, ArduinoControllerComponent
]

instance CartComponent : DTDFVocab:Component [
    base:desc "Cart component driven along the horizontal rail."
]

instance HoistComponent : DTDFVocab:Component [
    base:desc "Hoist component operating in the vertical axis."
]

instance ElectromagnetComponent : DTDFVocab:Component [
    base:desc "Electromagnet used to pick up and release small container‑like pucks."
]

instance PSU : DTDFVocab:Component [
    base:desc "Power Supply Unit powering the crate and controllers."
]

instance ArduinoControllerComponent : DTDFVocab:Component [
    base:desc "Arduino controller interfacing sensors and stepper motor drivers."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal, swing‑free trajectories for a requested pick‑and‑place operation. The Control Application subscribes to the trajectory stream and issues step‑pulse and electromagnet commands via the Physical Crane Interface to the motors and the electromagnet. The Control Application also sends operational events (homing, zeroing) to the Physical Crane Interface. MQTT is used only for inter‑service signaling; actuation reaches the hardware through direct serial commands from the Physical Crane Interface."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time continuous operation with data streams at sub‑second resolution (sensor polling and command execution). Validation and fault detection run continuously alongside the crane operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin constellation follows a C4 container diagram: on the physical side, the Physical Crane, Physical Crane Interface, Control Application, Logging Application, and Human‑Machine Interface; on the digital side, the TimescaleDB, MQTT Broker, Trajectory Generator Service, Simulation Service, Continuous Validation Service, and Grafana Dashboard, all communicating via MQTT within a Docker network, with the public Docker compose file bringing up the stack with a single command and auto‑initializing the database and dashboards."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The exemplar covers the design (CAD models and kinematic model), manufacturing (constructed physical crane), and operation (runtime control, logging and validation) stages. The digital twin provides a simulation model for design verification, continuous validation during operation, and can be leveraged for post‑mortem analysis of manufactured parts."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service implements a formal distance metric between measured positions (from the swing‑angle encoder and motor steps) and simulated reference trajectories, using a configurable threshold to trigger alerts. The simulator uses the same kinematic model as the trajectory generator, providing a closed‑loop validation loop. The logging application records all sensor data for retrospective analysis, enabling post‑mortem verification. The system is validated by comparing motor current signatures against known good signatures and by inspecting the confidence bounds shown on Grafana."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The physical crane interfaces to the host PC via a USB serial connection handled by the Physical Crane Interface Python program. The twin’s services on the host (control, logging, validation) communicate via the internal network of Docker containers. Inter‑service messaging uses MQTT topics on the local Mosquitto broker; data persistence occurs through the TimescaleDB database over the local network. Communication between the host and the physical crane is device‑level (serial) rather than networked."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire twin stack is deployed locally on a single personal computer. Docker Compose launches the TimescaleDB, Mosquitto, Grafana and all service containers. The Physical Crane Interface, Control Application, Logging Application, HMI, and gantrylib module run on the host’s Python interpreter. The crane hardware is connected to the Arduino via USB. All code and documentation are available on GitHub for download and reuse."
]