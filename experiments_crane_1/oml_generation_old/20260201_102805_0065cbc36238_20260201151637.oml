// ----- Sensing Components -----
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder measures pendulum motion."
    DTDFVocab:producedData SwingAngleData
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Airborne attached anemometer measures wind speed."
    DTDFVocab:producedData WindSpeedData
]

instance MotorStatusEncoder : DTDFVocab:SensingComponent [
    base:desc "Arduino encoder reports motor status."
    DTDFVocab:producedData MotorStatusData
]

instance CurrentFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "TMC4671 encoder provides current feedback."
    DTDFVocab:producedData CurrentData
]

instance PositionFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "TMC4671 encoder provides position feedback."
    DTDFVocab:producedData PositionData
]

// ----- Data Transmitted -----
instance SwingAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance MotorStatusData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusEncoder
]

instance CurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentFeedbackSensor
]

instance PositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionFeedbackSensor
]

// ----- Data -----
instance SwingAngleTimeseries : DTDFVocab:Data [
    base:desc "Time‑series of swing angle measurements stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDB
    DTDFVocab:fromData SwingAngleData
]

instance WindSpeedTimeseries : DTDFVocab:Data [
    base:desc "Time‑series of wind speed from anemometer stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDB
    DTDFVocab:fromData WindSpeedData
]

instance MotorStatusTimeseries : DTDFVocab:Data [
    base:desc "Time‑series of motor status from Arduino stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDB
    DTDFVocab:fromData MotorStatusData
]

instance CurrentTimeseries : DTDFVocab:Data [
    base:desc "Time‑series of motor current feedback stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDB
    DTDFVocab:fromData CurrentData
]

instance PositionTimeseries : DTDFVocab:Data [
    base:desc "Time‑series of motor position feedback stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDB
    DTDFVocab:fromData PositionData
]

// ----- Acting Components -----
instance CartStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Stepper motor controlling cart motion."
]

instance HoistStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Stepper motor controlling hoist motion."
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet for container pickup."
]

// ----- Physical Crane -----
instance PhysicalCrane : DTDFVocab:Component [
    base:desc "Laboratory‑scale gantry crane inspired by harbor cranes in Antwerp."
]

// ----- Enablers -----
instance PythonProgramming : DTDFVocab:Enabler [
    base:desc "Python programming language used to implement all services."
    DTDFVocab:enables LoggingApplication, ContinuousValidationService, TrajectoryGeneratorService, SimulationService, DashboardService, MQTTBrokerService
]

instance DockerContainer : DTDFVocab:Enabler [
    base:desc "Docker containerization of digital twin services."
    DTDFVocab:enables LoggingApplication, ContinuousValidationService, TrajectoryGeneratorService, SimulationService, DashboardService, MQTTBrokerService
]

instance DockerCompose : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestrates the Digital Twin container services."
    DTDFVocab:enables LoggingApplication, ContinuousValidationService, TrajectoryGeneratorService, SimulationService, DashboardService, MQTTBrokerService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB database storing crane state streams."
    DTDFVocab:enables LoggingApplication, ContinuousValidationService
]

instance GrafanaDashboards : DTDFVocab:Enabler [
    base:desc "Grafana dashboards for real‑time visualization."
    DTDFVocab:enables DashboardService
]

instance EclipseMosquittoMQTT : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for internal service signaling."
    DTDFVocab:enables MQTTBrokerService
]

instance gantrylibModule : DTDFVocab:Enabler [
    base:desc "gantrylib Python module for working with the crane hardware."
    DTDFVocab:enables TrajectoryGeneratorService
]

instance CapellaArcadiaModel : DTDFVocab:Enabler [
    base:desc "Capella Arcadia MBSE model used to generate simulation code."
    DTDFVocab:enables SimulationService
]

// ----- Models -----
instance CADModel : DTDFVocab:Model [
    base:desc "CAD model from Autodesk Fusion360."
    DTDFVocab:inputTo CapellaArcadiaModel
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model for optimal trajectory planning."
    DTDFVocab:inputTo gantrylibModule
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics simulation model of crane dynamics."
    DTDFVocab:inputTo gantrylibModule
]

// ----- Services -----
instance LoggingApplication : DTDFVocab:Service [
    base:desc "Logging application continuously records crane state variables into TimescaleDB."
    DTDFVocab:provides CraneStateLoggingInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Validates executed trajectories against simulation results in real‑time."
    DTDFVocab:provides ValidationAlertInsight, ValidationMetricInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Kinematic model‑based optimal trajectory planning for the crane."
    DTDFVocab:provides TrajectoryPlanInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Physics simulation service of crane dynamics."
    DTDFVocab:provides SimulationResultInsight
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Grafana‑based real‑time visualization of sensor data and validation alerts."
    DTDFVocab:provides RealTimeDataInsight
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service signaling."
    DTDFVocab:provides MessagingInsight
]

// ----- Insights -----
instance CraneStateLoggingInsight : DTDFVocab:Insight [
    base:desc "Insight into recorded crane state streams."
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Insight on validation alerts when executed trajectory deviates from simulation."
]

instance ValidationMetricInsight : DTDFVocab:Insight [
    base:desc "Distance metrics between real and simulated trajectory execution."
]

instance TrajectoryPlanInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory plan generated by kinematic model."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation output of crane dynamics."
]

instance RealTimeDataInsight : DTDFVocab:Insight [
    base:desc "Live stream of sensor data and validation metrics visualized in Grafana."
]

instance MessagingInsight : DTDFVocab:Insight [
    base:desc "Insight into inter‑service MQTT messaging status."
]

// ----- Environment -----
instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains SwingAngleEncoder, WindSpeedAnemometer, MotorStatusEncoder, CurrentFeedbackSensor, PositionFeedbackSensor,
    CartStepperMotorActuator, HoistStepperMotorActuator, ElectromagnetActuator,
    LoggingApplication, ContinuousValidationService, TrajectoryGeneratorService, SimulationService, DashboardService,
    MQTTBrokerService, TimescaleDB, GrafanaDashboards, EclipseMosquittoMQTT,
    PythonProgramming, DockerContainer, DockerCompose,
    gantrylibModule, CapellaArcadiaModel,
    CADModel, KinematicModel, PhysicsSimulationModel,
    PhysicalCrane
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal, swing‑free motion trajectories using the crane’s kinematic model. These trajectories are passed to the Control Application, which dispatches motion commands to the crane interface, driving the motors and electromagnet. Upon threshold breaches, the Continuous Validation Service triggers visual alerts on the Grafana dashboard, giving operators the opportunity to intervene manually; no automated actuator adjustments are performed by the twin."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All twin services operate in continuous real‑time, engaging at the same sampling cadence as the control loop (order of milliseconds to seconds). Data acquisition, logging and validation run concurrently with crane operation, enabling immediate feedback and operator intervention."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical Crane – physical hardware; Crane Interface – Python program connecting to hardware controllers; Control Application – Python app that drives the crane; Logging Application – logs state to TimescaleDB; MQTT Broker – messaging backbone; Database – TimescaleDB; Dashboard – Grafana; Trajectory Generator Service – generates movement plans; Simulation Service – simulates crane dynamics; Continuous Validation Service – compares execution against simulation; all orchestrated via Docker containers and local networking"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design – CAD and Arcadia models developed in Autodesk Fusion360 and Capella/Arcadia. Manufacturing – BOM and Arduino shield fabricated in KiCad, parts assembled into the crane. Operated – the assembled crane is connected via USB/serial to a PC; the gantrylib Python module runs the interface, control, logging and HMI, with Docker‑managed services for DB, broker and dashboard."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service compares real‑world sensor data with simulated trajectory outputs, computes distance metrics and flags deviations exceeding predefined thresholds, ensuring model validity; the kinematic model and simulation provide faithful representation of crane physics"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical crane connects to the host PC via USB serial to the Arduino; the Python interface communicates over serial to the Arduino; inter‑service communication occurs through MQTT (TCP) and local database writes via PostgreSQL drivers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All Digital Twin services containerized using Docker and orchestrated with Docker‑Compose, running locally on a personal computer; the physical crane is connected to the same host via serial or USB; database, MQTT broker and Grafana dashboard run in separate Docker containers"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "No explicit adherence to industry or interoperability standards is referenced; the twin relies on open‑source tools and a C4 model for architectural description."
]