// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart, controlled by a TMC4671-Eval driver through the Physical Crane Interface."
]
instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist, controlled by a TMC4671-Eval driver through the Physical Crane Interface."
]
instance ElectroMagnetOnHoist : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist for picking up small pucks representing containers."
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the hoist measuring swing angle during crane operation."
    DTDFVocab:producedData SwingAngleDataTransmitted
]
instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting the crane kinematics."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Models/Data
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the lab-scale gantry crane, obtained from Fusion 360."
    DTDFVocab:inputTo PythonRuntimeEnabler
]
instance KinematicModel : DTDFVocab:Model [
    base:desc "Analytical kinematic model of cart and hoist motions."
    DTDFVocab:inputTo PythonRuntimeEnabler
]
instance SimulationModel : DTDFVocab:Model [
    base:desc "Physics-based simulation model integrating crane dynamics."
    DTDFVocab:inputTo PythonRuntimeEnabler
]
instance TrajectoryOptimizationModel : DTDFVocab:Model [
    base:desc "Optimal control solver computing swing-free trajectories."
    DTDFVocab:inputTo PythonRuntimeEnabler
]
instance TimeSeriesTelemetryData : DTDFVocab:Data [
    base:desc "Continuous telemetry stream from the physical crane, stored in TimescaleDB."
    DTDFVocab:inputTo PythonRuntimeEnabler
]
instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Simulated position and swing traces generated by the Simulation Service."
    DTDFVocab:inputTo PythonRuntimeEnabler
]
instance ValidationDistanceMetrics : DTDFVocab:Data [
    base:desc "Distance metrics computed by the Continuous Validation Service comparing real and simulated trajectories."
    DTDFVocab:inputTo PythonRuntimeEnabler
]

// C5: Data instances
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Measured swing angle value from the SwingAngleEncoder."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance WindSpeedData : DTDFVocab:Data [
    base:desc "Measured wind speed value from the Anemometer."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB Docker container storing all time-series telemetry data."
    DTDFVocab:enables LoggingApplicationService
]
instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker orchestrating messaging between microservices."
    DTDFVocab:enables TrajectoryGeneratorService,
                       SimulationService,
                       ContinuousValidationService,
                       GrafanaDashboardService
]
instance PythonRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python 3 runtime environment executing gantrylib modules."
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes swing-free optimal trajectories using the crane’s kinematic model."
    DTDFVocab:provides OptimalTrajectoryInsight,
                       TrajectoryCommandAction
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Runs a physics-based simulation of the crane and its controllers to predict position and swing."
    DTDFVocab:provides PredictedTrajectoryInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares real-time trajectory execution against simulation, calculates distance metrics, and triggers threshold breaches."
    DTDFVocab:provides TrajectoryDeviationAlertInsight,
                       RaiseAlertAction
]
instance LoggingApplicationService : DTDFVocab:Service [
    base:desc "Writes telemetry data continuously to TimescaleDB via the logging application."
    DTDFVocab:provides TelemetryLoggedInsight
]
instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana instance displaying live and historical traces and validation alerts."
    DTDFVocab:provides LiveVisualizationInsight,
                       UpdateDashboardAction
]
instance MqttBrokerService : DTDFVocab:Service [
    base:desc "Eclipse Mosquitto MQTT broker handling inter-service signalling."
    DTDFVocab:provides MessageRoutingInsight
]

// C17: Insights
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Provides swing-free optimal trajectory parameters for the crane."
]
instance PredictedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Provides predicted position and swing traces from the simulation."
]
instance TrajectoryDeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alerts operators to deviations between executed and predicted trajectories."
]
instance TelemetryLoggedInsight : DTDFVocab:Insight [
    base:desc "Acknowledges successful logging of telemetry data."
]
instance LiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Displays live crane state and validation alerts in Grafana."
]
instance MessageRoutingInsight : DTDFVocab:Insight [
    base:desc "Indicates successful routing of messages between services via MQTT."
]

// C17: Actions
instance TrajectoryCommandAction : DTDFVocab:Action [
    base:desc "Command signal generated by the Digital Twin to the Physical Crane Interface to follow an optimized trajectory."
    DTDFVocab:IsAutomatic true
]
instance RaiseAlertAction : DTDFVocab:Action [
    base:desc "Automatic action to notify operators when trajectory deviation exceeds threshold."
    DTDFVocab:IsAutomatic true
]
instance UpdateDashboardAction : DTDFVocab:Action [
    base:desc "Automated update of Grafana panels with latest telemetry and validation data."
    DTDFVocab:IsAutomatic true
]

// C1: Environment
instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains TimescaleDBContainer,
                    MqttBrokerContainer,
                    GrafanaDashboardContainer,
                    TrajectoryGeneratorApp,
                    SimulationApp,
                    ContinuousValidationApp,
                    LoggingApplicationInstance,
                    PhysicalCraneInterfaceComponent
]

// C13: Component instances
instance TimescaleDBContainer : DTDFVocab:Component [
    base:desc "Docker container running TimescaleDB for storing time-series telemetry."
]
instance MqttBrokerContainer : DTDFVocab:Component [
    base:desc "Docker container running the Eclipse Mosquitto MQTT broker."
]
instance GrafanaDashboardContainer : DTDFVocab:Component [
    base:desc "Docker container running Grafana for visualising telemetry and alerts."
]
instance TrajectoryGeneratorApp : DTDFVocab:Component [
    base:desc "Python module implementing the Trajectory Generator Service."
]
instance SimulationApp : DTDFVocab:Component [
    base:desc "Python module implementing the Simulation Service."
]
instance ContinuousValidationApp : DTDFVocab:Component [
    base:desc "Python module implementing the Continuous Validation Service."
]
instance LoggingApplicationInstance : DTDFVocab:Component [
    base:desc "Python module realizing the Logging Application writing to TimescaleDB."
]
instance PhysicalCraneInterfaceComponent : DTDFVocab:Component [
    base:desc "Physical interface transmitting command signals from the digital twin to the TMC4671 drivers."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Virtual services generate trajectory commands and motor control signals: the Trajectory Generator Service outputs optimal trajectories that are sent to the Control Application, which then forwards step commands over the crane interface to the physical motors; the Continuous Validation Service can also trigger alerts to the operator via the dashboard."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is a set of interconnected containers: the physical crane hardware, a Crane Interface, a Control Application, a Logging Application, the MQTT broker, the TimescaleDB database, the Trajectory Generator Service, the Simulation Service, the Continuous Validation Service, and the Grafana Dashboard, all coordinated via Docker Compose on a personal computer."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin covers the design stage (CAD and kinematic models), the manufacturing stage (physical construction of the crane and electronics), and the operational stage (runtime data logging, validation, and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation is continuous: executed trajectories are compared against simulated trajectories using distance metrics; thresholds trigger alerts. The kinematic model is the basis for trajectory generation; model fidelity is enhanced by integrating actual sensor data. The validation workflow ensures that simulation accuracy matches real‑world operation, but formal verification or bounded-error analysis is not documented."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Connection between physical and digital sides is established via the host PC: the Arduino board wires (likely USB/serial) connect the sensors and actuators to the PC; all services run on the same host; inter‑process communication occurs over the local TCP/IP network within the Docker Compose bridge; MQTT broker exchanges messages on port 1883 (unsecured), while TimescaleDB accepts PostgreSQL protocol on port 5432."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin runs on a personal computer; all Python modules are installed via pip; database, MQTT broker, and dashboard are Docker containers managed by docker‑compose. Code and documentation are hosted on GitHub; the repository contains a Docker compose file for first‑time setup and a MkDocs‑based docs site. The environment can be provisioned with a single docker‑compose command."
]