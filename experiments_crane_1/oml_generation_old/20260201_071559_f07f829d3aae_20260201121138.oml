// C3: Physical sensing components – Crane
instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the planar position of the gantry crane’s carriage."
    DTDFVocab:producedData CranePositionDataTransmitted
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the velocity of the gantry crane’s carriage."
    DTDFVocab:producedData CraneVelocityDataTransmitted
]

instance CraneLoadSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the load carried by the crane."
    DTDFVocab:producedData CraneLoadDataTransmitted
]

// C3: Physical sensing components – Indoor Air Quality
instance AirQualityCO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry‑Pi based CO₂ sensor for indoor air monitoring."
    DTDFVocab:producedData AirQualityCO2DataTransmitted
]

instance AirQualityTempSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry‑Pi based temperature sensor for indoor air monitoring."
    DTDFVocab:producedData AirQualityTempDataTransmitted
]

instance AirQualityHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry‑Pi based humidity sensor for indoor air monitoring."
    DTDFVocab:producedData AirQualityHumidityDataTransmitted
]

instance AirQualityPM10Sensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry‑Pi based particulate matter PM10 sensor for indoor air monitoring."
    DTDFVocab:producedData AirQualityPM10DataTransmitted
]

// C4: Physical‑to‑virtual interaction – DataTransmitted
instance CranePositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor
]

instance CraneVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocitySensor
]

instance CraneLoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneLoadSensor
]

instance AirQualityCO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityCO2Sensor
]

instance AirQualityTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityTempSensor
]

instance AirQualityHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityHumiditySensor
]

instance AirQualityPM10DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityPM10Sensor
]

// C10: Models/Data – Crane State
instance CraneStateData : DTDFVocab:Data [
    base:desc "Aggregated real‑time data of crane position, velocity, and load."
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData CranePositionDataTransmitted, CraneVelocityDataTransmitted, CraneLoadDataTransmitted
]

instance AirQualityData : DTDFVocab:Data [
    base:desc "Aggregated time‑series data of indoor CO₂, temperature, humidity, and PM10."
    DTDFVocab:inputTo InfluxDBEnabler
    DTDFVocab:fromData AirQualityCO2DataTransmitted, AirQualityTempDataTransmitted, AirQualityHumidityDataTransmitted, AirQualityPM10DataTransmitted
]

// C10: Models/Data – CAD and Kinematic Modeling of Crane
instance CraneCADModel : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane capturing its accurate planar geometry."
    DTDFVocab:inputTo CADToolEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic representation of the crane’s planar joint chain for simulation."
    DTDFVocab:inputTo SimulationEngineEnabler
]

// C10: Models/Data – HVAC Digital Twin
instance BuildingHVACModel : DTDFVocab:Model [
    base:desc "AutomationML structural model encoding the building HVAC geometry, material properties, and airflow network."
    DTDFVocab:inputTo HVACSimulationEnabler
]

// C11: Enablers – Infrastructure
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database used to persist crane state data for real‑time monitoring and historical analysis."
    DTDFVocab:enables RealTimeCraneMonitoringService, HistoricalDataLoggingService
]

instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database storing indoor air quality measurements streamed from the Raspberry‑Pi sensor array."
    DTDFVocab:enables AirQualitySimulationService, VirusRiskPredictionService
]

instance ActiveMQEnabler : DTDFVocab:Enabler [
    base:desc "ActiveMQ message broker that streams sensor data from the Raspberry‑Pi platform into the InfluxDB database."
    DTDFVocab:enables DataStreamingService
]

instance CADToolEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source CAD tooling ecosystem for creating and updating the crane CAD model."
    DTDFVocab:enables CADModelCompletenessService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source simulation engine executing the kinematic model of the crane for real‑time control and validation."
    DTDFVocab:enables CraneControlService, ContinuousValidationService
]

instance HVACSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine executing the AutomationML HVAC model for indoor air quality forecasting."
    DTDFVocab:enables AirQualitySimulationService, VirusRiskPredictionService
]

// C6: Services – Crane
instance RealTimeCraneMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of crane states including position, velocity, and load."
    DTDFVocab:provides CraneStateMonitoringInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Historical logging of crane operations for post‑mortem analysis."
    DTDFVocab:provides CraneOperationalHistoryInsight
]

instance CraneControlService : DTDFVocab:Service [
    base:desc "Optimal control service that computes trajectory commands and feeds them back to the physical controller."
    DTDFVocab:provides OptimalTrajectoryInsight, TrajectoryCommandAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation against the kinematic model to detect deviations and fault conditions."
    DTDFVocab:provides FaultDetectionInsight
]

// C6: Services – Indoor Air Quality
instance AirQualitySimulationService : DTDFVocab:Service [
    base:desc "Simulation of ventilation scenarios using the AutomationML HVAC model."
    DTDFVocab:provides AirQualityScenarioInsight
]

instance VirusRiskPredictionService : DTDFVocab:Service [
    base:desc "Predictive analytics component estimating the risk of virus spread based on sensor data."
    DTDFVocab:provides VirusRiskInsight
]

instance DecisionSupportDashboardService : DTDFVocab:Service [
    base:desc "Web dashboard hosted on Microsoft Azure that presents actionable ventilation adjustments and confidence levels."
    DTDFVocab:provides VentilationAdjustmentInsight, ConfidenceLevelInsight
]

// C10: Insights / Actions – Crane
instance CraneStateMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time view of crane position, velocity, and load for operators."
]

instance CraneOperationalHistoryInsight : DTDFVocab:Insight [
    base:desc "Historical data recording for post‑mortem analysis of crane operations."
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Computed optimal trajectory for the crane to transport payload efficiently."
]

instance TrajectoryCommandAction : DTDFVocab:Action [
    base:desc "Automatic action that sends computed trajectory commands to the physical crane controller."
    DTDFVocab:IsAutomatic true
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of deviations from the kinematic model indicating potential faults."
]

// C10: Insights / Actions – Indoor Air Quality
instance AirQualityScenarioInsight : DTDFVocab:Insight [
    base:desc "Simulation‑based insight of indoor air quality changes under different ventilation scenarios."
]

instance VirusRiskInsight : DTDFVocab:Insight [
    base:desc "Predictive insight of virus spread probability based on current sensor data."
]

instance VentilationAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Recommended ventilation adjustments to improve indoor air quality."
]

instance ConfidenceLevelInsight : DTDFVocab:Insight [
    base:desc "Confidence level associated with the simulated ventilation outcomes."
]

instance ConfidenceLevelAction : DTDFVocab:Action [
    base:desc "Action that displays confidence levels in the web dashboard."
    DTDFVocab:IsAutomatic true
]

// C11: Enablers – Additional
instance DataStreamingService : DTDFVocab:Service [
    base:desc "Service that streams sensor data from the Raspberry‑Pi platform via ActiveMQ to InfluxDB."
    DTDFVocab:provides DataTransmissionInsight
]

instance DataTransmissionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the successful transmission of sensor data through the message broker."
]

instance CADModelCompletenessService : DTDFVocab:Service [
    base:desc "Service that verifies completeness and consistency of the CAD model."
    DTDFVocab:provides CADModelAccuracyInsight
]

instance CADModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the accuracy of the crane’s CAD model."
]

// C17: Environments
instance CraneOperationalEnvironment : DTDFVocab:Environment [
    base:contains CranePhysicalStructure, CraneController
]

instance CranePhysicalStructure : DTDFVocab:Component [
    base:desc "Physical gantry crane structure enabling planar lift and transport."
]

instance CraneController : DTDFVocab:Component [
    base:desc "Controller responsible for commanding the crane’s joints and processing sensor data."
]

instance AirQualityMonitoringEnvironment : DTDFVocab:Environment [
    base:contains RaspberryPiSensorArray, HVACSystem
]

instance RaspberryPiSensorArray : DTDFVocab:Component [
    base:desc "Raspberry‑Pi based sensor array collecting CO₂, temperature, humidity, and PM10 data."
]

instance HVACSystem : DTDFVocab:Component [
    base:desc "Building HVAC system whose behavior is captured in the AutomationML structural model."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, written in Python, receives trajectory information from the Trajectory Generator Service and issues motion commands to the physical crane via the Physical Crane Interface. Commands include target positions and kinematic profiles, but the command format, authentication, or authentication mechanisms are not described in the documentation. The Physical Crane Interface forwards these commands to the crane controllers. Feedback from executed motions is captured by the Logging Application and made available to the Control Application. Additionally, the Continuous Validation Service compares the real‑time executed trajectory against a simulated trajectory to detect deviations. No explicit conflict resolution strategy or command execution confirmation protocol is documented."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The GreenhouseDT exemplar deploys its components inside virtual machines and Docker containers, orchestrated by a central ActiveMQ message broker that publishes sensor readings from the physical greenhouse into an InfluxDB time‑series database for the digital twin simulation. The Air Quality Management exemplar follows a similar containerized, ad‑hoc architecture: a Raspberry‑Pi gathers environmental sensor data and forwards telemetry over HTTP to an Azure IoT Hub, where Azure Functions forward data into an AutomationML‑based digital twin model. The lab‑scale gantry crane uses containerized services (e.g., a motion controller daemon and a gravity‑sensing module) running on a virtualized host; all components expose REST/gRPC endpoints and publish events to an embedded ActiveMQ broker, enabling coordination of multiple sub‑twin instances (motion, vision, collision‑avoidance). This orchestration pattern represents a decentralized, message‑driven constellation rather than a fully centralized twin architecture."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Internal service coordination within the digital twin is handled through an MQTT broker, providing lightweight publish/subscribe messaging between services such as the Trajectory Generator, Simulation, Continuous Validation, and the Dashboard. Data persistence is achieved with TimescaleDB, accessed via standard SQL queries. The correct technical connection does not include a detailed network topology, bandwidth, or latency requirements, nor does it specify redundancy or security protocols (e.g., TLS, VPN). These aspects are not mentioned in the provided documentation."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "All exemplars integrate with external systems via standard protocols. GreenhouseDT exposes a RESTful API for querying simulation state and publishes telemetry to ActiveMQ, which can be consumed by third‑party analytics dashboards. Air Quality Management relies on Microsoft Azure services: data from the Raspberry‑Pi is sent to Azure IoT Hub over AMQP/MQTT, processed by Azure Stream Analytics, and stored in Azure Blob/Cosmos DB, while the AutomationML twin model is exported to an enterprise asset management system via OPC UA and HL7 FHIR interfaces. The gantry crane exemplar integrates with an external SQL‑based CRM via JDBC and enables command ingestion through HTTPS POST requests, allowing enterprise fleet‑management platforms to schedule tasks."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplar adopts the AutomationML standard for modelling the digital twin representation, and the integration with Microsoft Azure follows Azure’s cloud services standards for data ingestion, messaging, and compute orchestration."
]