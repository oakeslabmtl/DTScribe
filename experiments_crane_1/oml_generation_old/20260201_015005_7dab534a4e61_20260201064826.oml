// =============================
// C3: Physical sensing components
// =============================

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring swing angle of pendulum motion of the hoist."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoBoardSensor : DTDFVocab:SensingComponent [
    base:desc "Arduino board that reads the swing‑angle encoder, the anemometer and motor‑driver feedback."
    DTDFVocab:producedData ArduinoSensorDataTransmitted
]

// =============================
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// =============================

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance ArduinoSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoBoardSensor
]

// =============================
// C5: Data
// =============================

instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurement."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo PhysicalCraneInterface, LoggingApplication
]

instance WindSpeedMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed measurement."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo PhysicalCraneInterface, LoggingApplication
]

instance ArduinoSensorMeasurement : DTDFVocab:Data [
    base:desc "Aggregated sensor payload from the Arduino (encoder, wind, motor feedback)."
    DTDFVocab:fromData ArduinoSensorDataTransmitted
    DTDFVocab:inputTo PhysicalCraneInterface, LoggingApplication
]

// =============================
// C6: Services
// =============================

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that writes time‑stamped measurements to TimescaleDB and publishes events via MQTT."
    DTDFVocab:provides MeasurementStoredInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboard service visualizing real‑time and historical crane data."
    DTDFVocab:provides DashboardVisualizationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Kinematics‑based service that computes swing‑free optimal trajectories."
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Dynamic simulation of crane mechanics and controller behavior."
    DTDFVocab:provides SimulationResultInsight
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Continuous validation comparing measured vs. simulated trajectories and issuing alerts."
    DTDFVocab:provides ValidationMetricsInsight, AdjustCraneMotionAction
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Web‑based HMI allowing operators to monitor status and issue commands."
    DTDFVocab:provides OperatorControlInsight
]

// =============================
// C11: Enablers
// =============================

instance PhysicalCraneInterface : DTDFVocab:Enabler [
    base:desc "Python‑based library (gantrylib) that streams sensor data to the logging pipeline."
    DTDFVocab:enables DataLoggingService
]

instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Python application that receives streamed data and writes it to TimescaleDB."
    DTDFVocab:enables DataLoggingService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL) time‑series database storing all measurements."
    DTDFVocab:enables DataLoggingService, ValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for publish/subscribe of status and events."
    DTDFVocab:enables VisualizationService, ValidationService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana container rendering dashboards from TimescaleDB and MQTT streams."
    DTDFVocab:enables VisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Docker container running the trajectory generation algorithm."
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Docker container executing the crane dynamics simulation."
    DTDFVocab:enables SimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Service that consumes measurement and simulation data to produce validation metrics."
    DTDFVocab:enables ValidationService
]

instance HumanMachineInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Web HMI container exposing operator control panels."
    DTDFVocab:enables HumanMachineInterfaceService
]

// =============================
// C10: Models / Data
// =============================

instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the lab‑scale gantry crane."
    DTDFVocab:inputTo VisualizationService
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the trajectory generator."
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of crane mechanics and controllers."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance MeasurementTimeSeriesData : DTDFVocab:Data [
    base:desc "Historical time‑series measurement data stored in TimescaleDB."
    DTDFVocab:fromData SwingAngleDataTransmitted, WindSpeedDataTransmitted, ArduinoSensorDataTransmitted
    DTDFVocab:inputTo ContinuousValidationEnabler, VisualizationService
]

instance ValidationMetricsData : DTDFVocab:Data [
    base:desc "Distance metrics and threshold alerts generated by the continuous validation service."
    DTDFVocab:fromData MeasurementTimeSeriesData
    DTDFVocab:inputTo HumanMachineInterfaceEnabler, ContinuousValidationEnabler
]

// =============================
// C17: Insights / Actions
// =============================

instance MeasurementStoredInsight : DTDFVocab:Insight [
    base:desc "Insight that measurements have been successfully persisted in TimescaleDB."
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight that current crane state is visualized on the Grafana dashboard."
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight providing an optimal, swing‑free movement plan for the crane."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight presenting simulated crane dynamics for comparison with real data."
]

instance ValidationMetricsInsight : DTDFVocab:Insight [
    base:desc "Insight delivering validation metrics and alerts when deviations exceed thresholds."
]

instance AdjustCraneMotionAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of crane motion commands based on validation results."
    DTDFVocab:IsAutomatic true
]

instance OperatorControlInsight : DTDFVocab:Insight [
    base:desc "Insight exposing operator‑initiated commands from the HMI to the control application."
]

// =============================
// C2: Acting Components (physical)
// =============================

instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart motion, controlled by a Trinamic TMC4671‑Eval board."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist motion, controlled by a Trinamic TMC4671‑Eval board."
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist for picking up containers."
]

instance ArduinoControlBoard : DTDFVocab:ActingComponent [
    base:desc "Arduino board issuing motion commands to the motor controllers."
]

// =============================
// C9: Environment (Docker‑Compose container constellation)
// =============================

instance CraneTwinEnvironment : DTDFVocab:Environment [
    base:contains TimescaleDBEnabler, GrafanaDashboardEnabler, PhysicalCraneInterface,
               TrajectoryGeneratorEnabler, SimulationEngineEnabler,
               ContinuousValidationEnabler, HumanMachineInterfaceEnabler,
               MQTTBrokerEnabler, LoggingApplication
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (Python) receives trajectory commands from the Trajectory Generator Service (via MQTT or direct API) and forwards motion set‑points to the Physical Crane Interface, which then drives the motor controllers; also the Continuous Validation Service can trigger operator alerts that influence manual overrides through the Human‑Machine Interface."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A C4‑modelled architecture where the physical crane is interfaced through a Python layer; sensor data flows to the Logging Application, then to TimescaleDB and MQTT; DT services (trajectory generation, simulation, validation) consume data via MQTT, generate outputs, and the HMI presents visualisations via Grafana, all deployed on a single personal computer using Docker‑Compose."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The exemplar covers design (CAD models in Autodesk Fusion 360 and kinematic model), manufacturing (Bill‑of‑Materials and assembled hardware), and operation (runtime logging, control, validation, and visualization)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares executed trajectories (measured by sensors) with simulated trajectories, computes distance metrics, checks against a predefined acceptable threshold, and raises alerts on the Grafana dashboard when the threshold is exceeded."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication uses the MQTT protocol (Eclipse Mosquitto broker) for signalling; data persistence uses SQL over PostgreSQL (TimescaleDB) accessed by Python applications; the Human‑Machine Interface communicates with services via standard REST/HTTP endpoints provided by the Python modules."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components run on a single PC; Docker containers host the TimescaleDB, MQTT broker, and Grafana dashboard; the remaining Python services run as processes within the gantrylib module; deployment is automated with a Docker‑Compose file that also initializes the database and dashboard."
]