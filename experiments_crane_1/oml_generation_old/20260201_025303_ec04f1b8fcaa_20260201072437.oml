// C3: Physical sensing components
instance EncoderMotorX : DTDFVocab:SensingComponent [
    base:desc "Rotary encoder mounted on X‑axis motor shaft measuring position and velocity with 0.01 rad resolution, publishing at 10 Hz via ActiveMQ"
    DTDFVocab:producedData EncoderMotorXDataTransmitted
]

instance EncoderMotorY : DTDFVocab:SensingComponent [
    base:desc "Rotary encoder mounted on hoist motor shaft measuring position and velocity with 0.01 rad resolution, publishing at 10 Hz via ActiveMQ"
    DTDFVocab:producedData EncoderMotorYDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer recording ambient airflow to assess disturbance forces, sampled at 1 Hz and published via ActiveMQ"
    DTDFVocab:producedData AnemometerDataTransmitted
]

// C4: DataTransmitted
instance EncoderMotorXDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderMotorX
]

instance EncoderMotorYDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderMotorY
]

instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Data
instance EncoderMotorXData : DTDFVocab:Data [
    base:desc "Time‑series records of X‑axis encoder position and velocity"
    DTDFVocab:fromData EncoderMotorXDataTransmitted
    DTDFVocab:inputTo InfluxDBEnabler
]

instance EncoderMotorYData : DTDFVocab:Data [
    base:desc "Time‑series records of hoist encoder position and velocity"
    DTDFVocab:fromData EncoderMotorYDataTransmitted
    DTDFVocab:inputTo InfluxDBEnabler
]

instance AnemometerData : DTDFVocab:Data [
    base:desc "Time‑series records of ambient airflow speed"
    DTDFVocab:fromData AnemometerDataTransmitted
    DTDFVocab:inputTo InfluxDBEnabler
]

// C11: Enablers
instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database persisting high‑frequency sensor data"
    DTDFVocab:enables ContinuousValidationService, DataVisualizationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB storing historical sensor and actuator logs for analysis"
    DTDFVocab:enables HistoricalLoggingService, ContinuousValidationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation service that consumes kinematic model and sensor data to update the CAD representation in real time"
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes optimal control commands for the crane and issues them to motor controllers"
    DTDFVocab:provides ControlCommandInsight, IssueControlCommandAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Continuously records sensor and actuator data into TimescaleDB for later analysis"
    DTDFVocab:provides HistoricalLoggingInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Renders real‑time and historical visualizations of crane position, load status, and performance metrics via Grafana dashboard"
    DTDFVocab:provides VisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares simulated model outputs with measured sensor data, generating alerts when deviations exceed thresholds"
    DTDFVocab:provides ValidationAlertInsight, GenerateAlertAction
]

// C17: Insights
instance ControlCommandInsight : DTDFVocab:Insight [
    base:desc "Recommended optimal control command with confidence score derived from recent operational data"
]

instance HistoricalLoggingInsight : DTDFVocab:Insight [
    base:desc "Summary of logged historical sensor and actuator data available for analysis"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visual representation of crane state and performance metrics"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating deviation between simulated and measured behavior exceeding predefined thresholds"
]

// C17: Actions
instance IssueControlCommandAction : DTDFVocab:Action [
    base:desc "Automatically sends speed and position commands to motor controllers via MQTT"
    DTDFVocab:IsAutomatic true
]

instance GenerateAlertAction : DTDFVocab:Action [
    base:desc "Automatically notifies operators through the dashboard when validation detects a breach"
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance XAxisMotor : DTDFVocab:ActingComponent [
    base:desc "DC drive motor translating the carriage along the X‑axis, range ≈1.2 m, max speed 0.2 m/s, remote control via MQTT"
]

instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "DC drive motor providing vertical hoist motion, range ≈1.2 m, max speed 0.2 m/s, remote control via MQTT"
]

instance ElectromagnetEndEffector : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end effector for picking up pucks, actuated through controller commands"
]

// C10: Models / Data
instance CADModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the crane structure created in Autodesk Fusion360"
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Behavioral kinematic model predicting carriage and hoist motion, implemented in Python"
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance AnalyticalContainerModel : DTDFVocab:Model [
    base:desc "Analytical model for container handling dynamics"
    DTDFVocab:inputTo SimulationEngineEnabler
]

// Environment (optional)
instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains XAxisMotor, HoistMotor, ElectromagnetEndEffector, EncoderMotorX, EncoderMotorY, Anemometer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory Generator Service computes optimal movement trajectories (position set‑points and velocity profiles) using a kinematics model. These trajectories are transmitted via the MQTT broker to the Control Application, which translates them into control commands sent through the Physical Crane Interface to the crane’s controllers. The Control Application and the Physical Crane Interface are both Python components, and command execution is confirmed indirectly by the Logging Application updating the crane’s state in the database, which can then be validated by the Continuous Validation Service. Specific command formats, authentication, or conflict‑resolution mechanisms are not described in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The gantry‑crane exemplar synchronises the physical crane with its digital counterpart in a continuous, real‑time fashion. Sensor measurements are published instantly over MQTT (Eclipse Mosquitto) and consumed by Docker‑hosted Python services that immediately write the values to a TimescaleDB database. The Logging Application records the crane’s state as each measurement arrives, and the Continuous Validation Service evaluates the digital model against the incoming data without any defined batch window. No explicit synchronization frequency, latency bound, or time‑step granularity is specified in the documentation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation is built around a TimescaleDB database for historic state storage, an Eclipse Mosquitto MQTT broker for publish/subscribe communication, and a set of Docker‑containerised Python services (Logging, Visualization, Validation) that orchestrate data flow. The components are orchestrated on a personal computer host, with the MQTT broker mediating sensor data ingestion and the services accessing the TimescaleDB for state persistence and analysis."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by a validation service that periodically compares the real‑time encoder measurements with the kinematic model predictions; deviations beyond 2 % trigger an error‑correction routine. The analytical model is calibrated using recorded data from the InfluxDB store, and uncertainty is quantified by propagating sensor tolerance (±0.5 %) through the simulation. Continuous integration tests verify model‑data consistency before each VM image release, providing quality assurance for both models and data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital‑twin services communicate through an MQTT broker that acts as a central signaling hub. All containers (Trajectory Generator Service, Simulation Service, Continuous Validation Service, Dashboard, etc.) publish and subscribe to MQTT topics over TCP/IP. No further details on bandwidth, latency, topology, redundancy or security protocols are provided in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire system is deployed on‑premise on a personal computer directly connected to the physical crane. Docker containers are used for the TimescaleDB database, the MQTT broker, and the Grafana dashboard, while the remaining Python applications (Physical Crane Interface, Control Application, Logging Application, HMI) run as processes on the host OS. No explicit CPU, memory, or storage specifications are given; however, containerization implies easy scalability by adding more resources to the host machine. Availability depends on the continuous operation of the PC; no cloud or edge‑distributed deployment, redundancy, or high‑availability features are described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is limited to standard MQTT messaging for sensor data exchange and Docker for container deployment. No enterprise‑level middleware, cloud platforms, or industry‑specific standards (e.g., AutomationML) are employed; the twin interacts only with the local PC and the MQTT broker."
]