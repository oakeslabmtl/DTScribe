// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing Angle Encoder mounted on the hoist to measure the pendulum angle of the lifted payload"
    DTDFVocab:producedData SwingAngleDataTransmission
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer mounted on the crane frame to measure ambient wind speed"
    DTDFVocab:producedData AnemometerDataTransmission
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance SwingAngleDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// C10: Data instances
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Angular position of the payload swing measured by the Swing Angle Encoder"
    DTDFVocab:fromData SwingAngleDataTransmission
    DTDFVocab:inputTo EnablerControlEngine, EnablerVisualizationEngine, EnablerValidationEngine
]

instance WindVelocityData : DTDFVocab:Data [
    base:desc "Ambient wind speed measured by the Anemometer"
    DTDFVocab:fromData AnemometerDataTransmission
    DTDFVocab:inputTo EnablerControlEngine, EnablerVisualizationEngine, EnablerValidationEngine
]

// C10: Model/Data (CAD and Kinematic models)
instance CADModelGantryCrane : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane geometry"
    DTDFVocab:inputTo EnablerControlEngine, EnablerValidationEngine
]

instance KinematicModelGantryCrane : DTDFVocab:Model [
    base:desc "Kinematic model representing the crane's motion behavior"
    DTDFVocab:inputTo EnablerControlEngine, EnablerValidationEngine
]

// C11: Enablers
instance EnablerTimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance used to store time‑stamped sensor and actuation records"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance EnablerControlEngine : DTDFVocab:Enabler [
    base:desc "Control engine that consumes sensor data and models to compute optimal motion commands for the crane"
    DTDFVocab:enables OptimalControlService
]

instance EnablerVisualizationEngine : DTDFVocab:Enabler [
    base:desc "Grafana‑based visualisation engine that renders time‑series data and system status"
    DTDFVocab:enables DataVisualizationService
]

instance EnablerValidationEngine : DTDFVocab:Enabler [
    base:desc "Continuous validation engine that compares live sensor values against model‑predicted ranges and raises alerts"
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal control service that computes the best motion commands for the crane"
    DTDFVocab:provides ActionComputeControl
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Historical data logging service that records sensor and actuation data into TimescaleDB"
    DTDFVocab:provides InsightHistoricalRecord
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Data visualisation service that renders the crane’s state and trajectory on a Grafana dashboard"
    DTDFVocab:provides InsightVisualization
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service that continuously compares live sensor values against model‑predicted ranges and raises alerts"
    DTDFVocab:provides ActionRaiseAlert
]

// C17: Insights / Actions
instance ActionComputeControl : DTDFVocab:Action [
    base:desc "Computes optimal control actions for crane motion"
    DTDFVocab:IsAutomatic true
]

instance InsightHistoricalRecord : DTDFVocab:Insight [
    base:desc "Provides recorded historical sensor and actuation data for analysis"
]

instance InsightVisualization : DTDFVocab:Insight [
    base:desc "Presents time‑series plots and system status on a Grafana dashboard"
]

instance ActionRaiseAlert : DTDFVocab:Action [
    base:desc "Raises alerts on the dashboard and notifies operators when sensor values exceed predicted thresholds"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the Control Application (e.g., move‑to‑position or trajectory commands) and sent to the Physical Crane Interface, which translates them into the low‑level protocol required by the crane controllers. The interface forwards the commands over the same connection used for sensor reading (e.g., serial or Ethernet) to actuate the crane. The system provides no explicit authentication or validation steps in the documentation; the Control Application assumes direct control of the hardware."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Gantry Crane digital twin uses an ad‑hoc architecture instead of a commercial digital‑twin framework. The design relies on containerization (Docker) to package and deploy its components, enabling easy installation on personal computers or virtual machines. No explicit orchestration layer or resource‑management framework is described; component integration is performed manually within this container‑based setup."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin provides a continuous validation service that monitors the correspondence between real‑time operation and the kinematic model, and it has been employed in research on continuous validation, fault detection, and the DarTwin notation for system evolution. The documents do not detail quantitative fidelity requirements, uncertainty quantification methods, or formal verification procedures."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin uses an MQTT broker for signaling between the Trajectory Generator Service, Simulation Service, Continuous Validation Service, and other components. Service‑to‑service messages follow the MQTT publish/subscribe model over TCP/IP. Data persistence and retrieval use TimescaleDB accessed via standard PostgreSQL client connections, and visualisation uses Grafana accessing the database via HTTP/HTTPS. The architecture is container‑based, implying that all components run on a common local network, but no explicit topology, bandwidth, latency, redundancy or security mechanisms are described."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system is deployed on a personal computer. The Database (TimescaleDB), MQTT broker, and Dashboard are packaged as Docker containers. The remaining components (Physical Crane Interface, Control Application, Logging Application, Human Machine Interface, Simulation Service, Trajectory Generator Service, Continuous Validation Service) are Python applications installed via pip and executed on the host. No cloud, edge, or virtualization platform, nor explicit scalability or availability mechanisms, are mentioned."
]