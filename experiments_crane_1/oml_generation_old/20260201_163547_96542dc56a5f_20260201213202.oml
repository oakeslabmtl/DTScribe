    base:desc "Automated HVAC system with variable speed fans and dampers for adjusting indoor air quality parameters based on digital twin predictions."
]

// C1: Environments
instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:desc "Controlled laboratory setting with temperature/humidity regulation for real-time experimentation and digital twin validation."
    base:contains CranePhysicalSystem, AirQualityMonitoringSystem
]

instance CranePhysicalSystem : DTDFVocab:Environment [
    base:desc "Modular lab-scale gantry crane system with kinematic joints, embedded controller, and real-time synchronization capabilities."
    base:contains CranePositionEncoder, CraneVelocitySensor, CraneForceTorqueSensor, CraneEnvironmentalSensor, CraneMotorActuator
]

instance AirQualityMonitoringSystem : DTDFVocab:Environment [
    base:desc "Raspberry Pi-based sensor network for real-time indoor air quality monitoring integrated with Azure cloud processing."
