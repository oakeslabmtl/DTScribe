// C3: Physical Sensing Components
instance CranePositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution encoder measuring 3D position (X, Y, Z axes) of the gantry crane payload with sub-millimeter precision for real-time kinematic validation."
    DTDFVocab:producedData CranePositionDataTransmitted
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Laser-based velocity sensor measuring linear and angular velocities of crane components at 100Hz sampling rate for dynamic validation."
    DTDFVocab:producedData CraneVelocityDataTransmitted
]

instance CraneForceTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Load cell array measuring force/torque on crane joints with 1ms response time for actuator validation and fault detection."
    DTDFVocab:producedData CraneForceTorqueDataTransmitted
]

instance CraneEnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Multi-sensor unit measuring temperature, humidity, and vibration levels in the laboratory environment for environmental validation."
    DTDFVocab:producedData CraneEnvironmentalDataTransmitted
]

instance AirQualityCO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Non-dispersive infrared (NDIR) CO2 sensor with ±50ppm accuracy for real-time indoor air quality monitoring via Raspberry Pi interface."
    DTDFVocab:producedData AirQualityCO2DataTransmitted
]

instance AirQualityTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Digital temperature sensor with ±0.5°C accuracy measuring ambient conditions for air quality modeling."
    DTDFVocab:producedData AirQualityTemperatureDataTransmitted
]

instance AirQualityHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Capacitive humidity sensor with ±2% RH accuracy for relative humidity monitoring in indoor environments."
    DTDFVocab:producedData AirQualityHumidityDataTransmitted
]

// C4: Data Transmitted
instance CranePositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionEncoder
]

instance CraneVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocitySensor
]

instance CraneForceTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneForceTorqueSensor
]

instance CraneEnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneEnvironmentalSensor
]

instance AirQualityCO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityCO2Sensor
]

instance AirQualityTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityTemperatureSensor
]

instance AirQualityHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityHumiditySensor
]

// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Forward/inverse kinematic model derived from FreeCAD CAD model using PyBullet library for 3D trajectory prediction and validation."
    DTDFVocab:inputTo RosSimulationEngine, MatlabControlFramework
]

instance CraneDynamicModel : DTDFVocab:Model [
    base:desc "Multi-body dynamics model implemented in RoboticsToolbox for energy-efficient trajectory optimization and actuator validation."
    DTDFVocab:inputTo MatlabControlFramework
]

instance AirQualitySimulationModel : DTDFVocab:Model [
    base:desc "AutomationML-based indoor air quality model simulating pollutant dispersion and virus spread scenarios using Azure cloud resources."
    DTDFVocab:inputTo AzureCloudProcessing, AirQualityVisualizationService
]

instance CraneHistoricalData : DTDFVocab:Data [
    base:desc "Time-series database storing crane sensor data (position, velocity, force) at 100Hz+ resolution for validation and predictive analytics."
    DTDFVocab:fromData CranePositionDataTransmitted, CraneVelocityDataTransmitted, CraneForceTorqueDataTransmitted
    DTDFVocab:inputTo ContinuousValidationService
]

instance AirQualityRealTimeData : DTDFVocab:Data [
    base:desc "Structured time-series data from Raspberry Pi sensors (CO2, temperature, humidity) transmitted via MQTT to Azure for real-time air quality analysis."
    DTDFVocab:fromData AirQualityCO2DataTransmitted, AirQualityTemperatureDataTransmitted, AirQualityHumidityDataTransmitted
    DTDFVocab:inputTo AirQualityVisualizationService
]

instance DarTwinEvolutionModel : DTDFVocab:Model [
    base:desc "Custom Python-based DarTwin notation model tracking system evolution and twin updates for versioned management of crane modifications."
    DTDFVocab:inputTo GitVersionControl
]

// C11: Enablers
instance RosSimulationEngine : DTDFVocab:Enabler [
    base:desc "ROS-based real-time simulation environment enabling hardware-in-the-loop testing between physical crane and digital twin with 10ms latency."
    DTDFVocab:enables RealTimeTrajectoryOptimizationService, ContinuousValidationService
]

instance MatlabControlFramework : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for developing and deploying optimal control algorithms (PID, MPC) with real-time execution capabilities."
    DTDFVocab:enables ClosedLoopControlIntegrationService
]

instance AzureCloudProcessing : DTDFVocab:Enabler [
    base:desc "Microsoft Azure cloud infrastructure providing scalable data processing, time-series analysis, and predictive modeling for air quality applications."
    DTDFVocab:enables AirQualityVisualizationService
]

instance InfluxDBSensorData : DTDFVocab:Enabler [
    base:desc "InfluxDB time-series database optimized for high-frequency sensor data storage (100Hz+) with structured validation and synchronization capabilities."
    DTDFVocab:enables ContinuousValidationService
]

instance ActiveMQMessageBroker : DTDFVocab:Enabler [
    base:desc "ActiveMQ message broker facilitating real-time bidirectional communication between physical greenhouse systems and digital twin components."
    DTDFVocab:enables RealTimeDataStreamingService
]

instance GitVersionControl : DTDFVocab:Enabler [
    base:desc "Git-based version control system managing code and documentation updates for both physical and digital twin components."
    DTDFVocab:enables SystemEvolutionTrackingService
]

instance DockerContainerization : DTDFVocab:Enabler [
    base:desc "Docker containerization platform enabling reproducible deployment of DT services across different environments with modular architecture."
    DTDFVocab:enables ServiceDeploymentService
]

instance FaultDetectionFramework : DTDFVocab:Enabler [
    base:desc "Python-based anomaly detection framework using Isolation Forest and Autoencoders trained on historical data for fault detection in crane operations."
    DTDFVocab:enables FaultDetectionService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB time-series database optimized for high-volume crane sensor data logging with continuous validation capabilities."
    DTDFVocab:enables ContinuousValidationService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT-based message broker facilitating asynchronous communication between physical crane components and digital twin services."
    DTDFVocab:enables RealTimeDataStreamingService
]

// C6: Services
instance RealTimeTrajectoryOptimizationService : DTDFVocab:Service [
    base:desc "Service computing energy-efficient or time-optimal paths for crane payloads using kinematic/dynamic models with real-time feedback."
    DTDFVocab:provides TrajectoryOptimizationInsight, OptimizedPathAction
]

instance ClosedLoopControlIntegrationService : DTDFVocab:Service [
    base:desc "Service feeding optimized control commands back to physical crane controller via bidirectional data streaming for adaptive adjustments."
    DTDFVocab:provides ControlFeedbackInsight, AdaptiveControlAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service implementing real-time validation algorithms comparing physical sensor data with digital twin predictions using Kalman filters."
    DTDFVocab:provides ValidationMetricsInsight, ModelDiscrepancyAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service using anomaly detection to identify kinematic failures, sensor drifts, or actuator malfunctions by correlating DT simulations with ground truth."
    DTDFVocab:provides FaultDetectionInsight, MaintenanceRecommendationAction
]

instance AirQualityVisualizationService : DTDFVocab:Service [
    base:desc "Service rendering real-time air quality data visualization using Azure cloud resources for scenario analysis and decision support."
    DTDFVocab:provides VisualizationDashboardInsight, ScenarioAnalysisAction
]

instance SystemEvolutionTrackingService : DTDFVocab:Service [
    base:desc "Service tracking system modifications and their impact on the digital twin using DarTwin notation for versioned twin management."
    DTDFVocab:provides EvolutionTrackingInsight, TwinUpdateAction
]

instance RealTimeDataStreamingService : DTDFVocab:Service [
    base:desc "Service facilitating real-time data streaming between physical components and digital twin services."
    DTDFVocab:provides DataStreamingInsight
]

instance ServiceDeploymentService : DTDFVocab:Service [
    base:desc "Service managing deployment of digital twin components across different environments."
    DTDFVocab:provides DeploymentStatusInsight
]

// C17: Insights/Actions
instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized 3D trajectory paths for crane payloads with energy consumption metrics and time efficiency analysis."
]

instance OptimizedPathAction : DTDFVocab:Action [
    base:desc "Automatic execution of optimized trajectories with real-time adjustments based on environmental conditions."
    DTDFVocab:IsAutomatic true
]

instance ControlFeedbackInsight : DTDFVocab:Insight [
    base:desc "Real-time feedback metrics from closed-loop control system including error margins and stability indicators."
]

instance AdaptiveControlAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of control parameters based on sensor feedback and digital twin predictions."
