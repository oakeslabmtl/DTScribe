// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures the swinging motion of the hoist to ensure stability and validate trajectory accuracy."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Measures wind speed, which affects the crane's dynamics and is used for simulation and validation purposes."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorControllerTMC4671 : DTDFVocab:SensingComponent [
    base:desc "Provides feedback on motor position, speed, and current draw for stepper motors, enabling real-time monitoring of the crane's state."
    DTDFVocab:producedData MotorTelemetryDataTransmitted
]

instance ArduinoAggregator : DTDFVocab:SensingComponent [
    base:desc "Aggregates sensor data (from SwingAngleEncoder, Anemometer, and MotorControllerTMC4671) and transmits it to the LoggingApplication for storage in TimescaleDB."
    DTDFVocab:producedData AggregatedSensorDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MotorTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerTMC4671
]

instance AggregatedSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoAggregator
]

instance TrajectoryExecutionTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ControlApplication
]

// C10: Models/Data
instance CraneCADModel : DTDFVocab:Model [
    base:desc "3D representation of the crane stored in the CAD folder for visualization and design reference."
    DTDFVocab:inputTo Fusion360
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Mathematical model of the crane's mechanics used by the TrajectoryGeneratorService to compute optimal swing-free paths."
    DTDFVocab:inputTo TrajectoryGeneratorService
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model replicating the crane's dynamics including wind effects for validation purposes."
    DTDFVocab:inputTo SimulationService
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Time-series data of motor positions, speeds, and currents from the TMC4671-Eval controllers."
    DTDFVocab:fromData MotorTelemetryDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time-series data of swing angles measured by the SwingAngleEncoder."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time-series data of wind speed measured by the Anemometer."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance TrajectoryExecutionLogs : DTDFVocab:Data [
    base:desc "Time-series data containing timestamps, motor commands, and telemetry from trajectory execution."
    DTDFVocab:fromData TrajectoryExecutionTelemetryTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance SimulatedTrajectories : DTDFVocab:Data [
    base:desc "Precomputed optimal trajectories generated by the TrajectoryGeneratorService."
    DTDFVocab:inputTo ContinuousValidationService
]

instance ArcadiaSystemModels : DTDFVocab:Data [
    base:desc "Model-Based Systems Engineering artifacts in Capella representing system architecture and evolution for teaching purposes."
    DTDFVocab:inputTo CapellaMBSE
]

// C11: Enablers
instance PythonGantryLib : DTDFVocab:Enabler [
    base:desc "Python-based module containing core control logic, trajectory generation, and simulation capabilities."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ControlApplication, LoggingApplication
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "PostgreSQL-based time-series database optimized for storing and querying crane state data with high write/read performance."
    DTDFVocab:enables LoggingApplication
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Open-source dashboard for real-time visualization of trajectories, alerts, and historical data with confidence bounds."
    DTDFVocab:enables DataVisualizationService
]

instance MQTTBrokerMosquitto : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker enabling lightweight, event-driven communication between services with low-latency pub/sub model."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, FaultDetectionService, LoggingApplication
]

instance DockerContainerization : DTDFVocab:Enabler [
    base:desc "Containerization platform deploying Database, MQTTBroker, and Dashboard via docker-compose for consistent environments."
    DTDFVocab:enables DatabaseService, MQTTBrokerMosquitto, GrafanaDashboard
]

instance Fusion360 : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion 360 CAD tool for creating and managing 3D representations of the crane."
    DTDFVocab:enables CraneCADModel
]

instance CapellaMBSE : DTDFVocab:Enabler [
    base:desc "Arcadia-based MBSE tool for modeling system architecture and evolution using DarTwin notation."
    DTDFVocab:enables ArcadiaSystemModels
]

instance ArduinoControlSystem : DTDFVocab:Enabler [
    base:desc "Arduino-based control system managing motors, electromagnet, and sensors with custom KiCad-designed shield."
    DTDFVocab:enables PhysicalCraneInterface
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes swing-free optimal trajectories using the CraneKinematicModel to minimize residual motion and operational time."
    DTDFVocab:provides OptimalTrajectoryInsight
    DTDFVocab:inputTo MQTTBrokerMosquitto
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Replicates crane dynamics including wind effects using CraneSimulationModel for validation against real-world execution."
    DTDFVocab:provides SimulationValidationInsight
    DTDFVocab:inputTo MQTTBrokerMosquitto
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories (TrajectoryExecutionLogs) with simulated trajectories (SimulatedTrajectories) using distance metrics."
    DTDFVocab:provides TrajectoryDeviationInsight
    DTDFVocab:inputTo MQTTBrokerMosquitto
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Extends continuous validation with time-series classification to localize faults in sensor/actuator data (e.g., motor jams, sensor drifts)."
    DTDFVocab:provides FaultLocalizationInsight
    DTDFVocab:inputTo MQTTBrokerMosquitto
]

instance LoggingApplication : DTDFVocab:Service [
    base:desc "Continuously logs crane state data (MotorPositionData, SwingAngleData, WindSpeedData) to TimescaleDB via MQTTBrokerMosquitto."
    DTDFVocab:provides HistoricalDataInsight
    DTDFVocab:inputTo MQTTBrokerMosquitto
]

instance ControlApplication : DTDFVocab:Service [
    base:desc "Executes optimal trajectories received from TrajectoryGeneratorService by translating them into motor commands for precise movement."
    DTDFVocab:provides ControlCommandAction
    DTDFVocab:inputTo ArduinoControlSystem
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Visualizes real-time and historical data including trajectory traces with simulated confidence bounds (blue/yellow) for validation."
    DTDFVocab:provides VisualizationInsight
    DTDFVocab:inputTo GrafanaDashboard
]

instance DatabaseService : DTDFVocab:Service [
    base:desc "Manages TimescaleDB instance storing all time-series crane data for post-mortem analysis and predictive maintenance."
    DTDFVocab:provides HistoricalAnalysisInsight
    DTDFVocab:inputTo DockerContainerization
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Swing-free paths computed to reduce operational time and improve safety by minimizing residual motion."
]

instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Validation of simulated trajectories against real-world execution to refine DT accuracy over time."
]

instance TrajectoryDeviationInsight : DTDFVocab:Insight [
    base:desc "Identification of deviations between executed and simulated trajectories triggering alerts when thresholds are breached."
]

instance FaultLocalizationInsight : DTDFVocab:Insight [
    base:desc "Localization of system faults (e.g., motor failures, sensor drifts) using time-series classification techniques."
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Post-mortem analysis of crane behavior supporting predictive maintenance and process improvements."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of trajectories with confidence bounds and alert notifications via GrafanaDashboard."
]

instance HistoricalAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analysis of historical crane data for identifying patterns and supporting system evolution documentation."
]

instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Translation of optimal trajectories into precise motor commands for crane actuation."
    DTDFVocab:IsAutomatic true
]

// C1: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor responsible for horizontal translation of the crane cart controlled via TMC4671-Eval motor controller."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor responsible for vertical lifting of the hoist controlled via TMC4671-Eval motor controller."
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet positioned at the end of the hoist for picking up and releasing containers (pucks)."
]

// C2: Physical Components
instance PhysicalCraneFrame : DTDFVocab:Component [
    base:desc "Structural frame supporting the crane's mechanical components including motors and sensors."
]

instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Python program interfacing between ArduinoControlSystem and DT services to execute commands."
]

instance ControlApplicationContainer : DTDFVocab:Component [
    base:desc "Container hosting the ControlApplication service for trajectory execution."
]

instance LoggingApplicationContainer : DTDFVocab:Component [
    base:desc "Container hosting the LoggingApplication service for state data collection."
]

instance HumanMachineInterface : DTDFVocab:Component [
    base:desc "Interface allowing operators to adjust control parameters (e.g., logging frequency, validation thresholds)."
]

// C5: Digital Twin Components
instance DatabaseContainer : DTDFVocab:Component [
    base:desc "Docker container hosting TimescaleDB for time-series data storage."
]

instance DashboardContainer : DTDFVocab:Component [
    base:desc "Docker container hosting GrafanaDashboard for real-time visualization."
]

instance TrajectoryGeneratorServiceContainer : DTDFVocab:Component [
    base:desc "Container hosting TrajectoryGeneratorService for optimal path computation."
]

instance SimulationServiceContainer : DTDFVocab:Component [
    base:desc "Container hosting SimulationService for dynamic replication."
]

instance ContinuousValidationServiceContainer : DTDFVocab:Component [
    base:desc "Container hosting ContinuousValidationService for trajectory comparison."
]

instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Docker container hosting Eclipse Mosquitto MQTT broker for event-driven coordination."
]

// C7: Environments
instance PhysicalSideEnvironment : DTDFVocab:Environment [
    base:contains PhysicalCraneFrame, CartStepperMotor, HoistStepperMotor,
                 CraneElectromagnet, SwingAngleEncoder, Anemometer,
                 MotorControllerTMC4671, ArduinoAggregator,
                 PhysicalCraneInterface, ControlApplicationContainer,
                 LoggingApplicationContainer, HumanMachineInterface
]

instance DigitalTwinSideEnvironment : DTDFVocab:Environment [
    base:contains DatabaseContainer, DashboardContainer,
                 TrajectoryGeneratorServiceContainer, SimulationServiceContainer,
                 ContinuousValidationServiceContainer, MQTTBrokerContainer
]

instance DecentralizedServicesEnvironment : DTDFVocab:Environment [
    base:contains TrajectoryGeneratorService, SimulationService,
                 ContinuousValidationService, FaultDetectionService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The interactions from the virtual world (DT) to the physical world (PT) include:
    - **Optimal Trajectory Commands**: The **Trajectory Generator Service** computes swing-free trajectories using a **kinematic model** of the crane and sends them to the **Control Application**, which translates them into motor commands for the **Physical Crane Interface**.
    - **Control Signals**: The **Control Application** issues real-time commands to the **Arduino**, which drives the **stepper motors** and **electromagnet** via the **TMC4671-Eval controllers**.
    - **Simulation-Driven Adjustments**: The **Simulation Service** generates synthetic trajectories for validation, and the **Continuous Validation Service** uses these to adjust control parameters dynamically if discrepancies are detected."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twinning time scale is **real-time** for control and validation purposes, with the following characteristics:
    - **Control Loop**: The **Control Application** and **Physical Crane Interface** operate at a **millisecond-to-subsecond** scale to execute motor commands and read sensor data.
    - **Logging Frequency**: The **Logging Application** records crane state data at a **high temporal resolution** (not explicitly quantified but implied to be sub-second for validation purposes).
    - **Validation Latency**: The **Continuous Validation Service** processes trajectory comparisons in **near real-time**, with alerts generated within seconds of threshold breaches.
    - **Simulation Sync**: The **Simulation Service** runs in parallel to the PT, with synchronized timestamps to ensure temporal alignment for validation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated as follows:
    - **Physical-Digital Interface**: The **Physical Crane Interface** (Python) acts as a bridge between the **Arduino** (PT) and the **Control Application** (DT).
    - **Service Orchestration**: Services communicate via the **MQTT Broker** (Eclipse Mosquitto) using a **publish-subscribe** model for event-driven coordination.
    - **Data Pipeline**:
        1. **Sensing → Logging**: Arduino → **Logging Application** → **TimescaleDB**.
        2. **Control → Execution**: **Trajectory Generator Service** → **Control Application** → **Physical Crane Interface** → Arduino → Motors.
        3. **Validation Loop**: **Logging Application** → **TimescaleDB** → **Continuous Validation Service** → **Grafana Dashboard** (alerts).
    - **Deployment**: All Python services are bundled in **gantrylib** (pip-installable), while infrastructure components (**Database**, **MQTT Broker**, **Dashboard**) are containerized via **Docker** for portability."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the following lifecycle stages of its physical counterpart:
    1. **As Designed**: Represented by **CAD models** (Autodesk Fusion 360) and **kinematic models** used for trajectory planning.
    2. **As Manufactured**: Validated through **continuous validation** during operation, comparing simulated (designed) behavior with executed (real) behavior.
    3. **As Operated**: Supports **real-time monitoring**, **fault detection**, and **adaptive control** during active use. The DT does not explicitly model manufacturing deviations but assumes the PT is built to design specifications."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
    - **Model Accuracy**:
        - The **kinematic model** in the **Trajectory Generator Service** is validated against real-world trajectories using **distance metrics** (e.g., Euclidean distance between simulated and executed paths).
        - The **Simulation Service** replicates the crane’s dynamics, including wind effects (from the anemometer), to improve fidelity.
    - **Validation Mechanisms**:
        - **Continuous Validation**: Real-time comparison of executed vs. simulated trajectories ([4], [5]).
        - **Threshold-Based Alerts**: Operators are notified if trajectory deviations exceed acceptable bounds (e.g., swing angle errors).
        - **Fault Detection**: Time-series classification ([6]) identifies anomalies in motor currents, swing angles, or wind speed.
    - **Uncertainty Handling**:
        - Simulated trajectories include **confidence bounds** (visualized in Grafana) to account for model uncertainties.
        - Wind speed data is incorporated into simulations to mitigate environmental variability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connections between PT and DT include:
    - **Network Protocols**:
        - **MQTT (Eclipse Mosquitto)**: Used for lightweight, event-driven communication between services (e.g., **Logging Application** → **TimescaleDB**, **Continuous Validation Service** → **Dashboard**).
        - **Serial Communication**: Arduino communicates with motor controllers and sensors via **UART/USB**.
    - **Architecture**:
        - **Centralized Control**: The **Control Application** acts as a single point of coordination for motor commands.
        - **Decentralized Services**: Services like **Trajectory Generator** and **Simulation Service** operate independently but share data via MQTT.
    - **Data Flow**:
        - **PT → DT**: Sensor data (encoder, anemometer, motor feedback) is streamed to the **Logging Application** via Arduino.
        - **DT → PT**: Control commands (trajectories) are sent from the **Control Application** to the **Physical Crane Interface** (Python) and then to the Arduino."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted and deployed as follows:
    - **Physical Deployment**:
        - The **Physical Crane** and **Arduino** are connected to a **personal computer** running the Python services (**gantrylib**).
        - The **Database**, **MQTT Broker**, and **Dashboard** are containerized using **Docker** and managed via a **docker-compose** file.
    - **Software Deployment**:
        - **gantrylib**: A Python module installed via **pip**, containing all DT services (e.g., **Trajectory Generator**, **Logging Application**).
        - **Docker Containers**: Pre-configured images for **TimescaleDB**, **Grafana**, and **Eclipse Mosquitto** are pulled from public repositories.
        - **First-Time Setup**: The **docker-compose** file automates database initialization, dashboard configuration, and network setup.
    - **Accessibility**: The exemplar is **open-source** (MIT license) and hosted on **GitHub**, with documentation available via **MkDocs** and **GitHub Pages**."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration with external systems is limited but includes:
    - **Data Exchange**: The **MQTT Broker** could theoretically integrate with other IoT platforms or enterprise systems, though this is not implemented in the current exemplar.
    - **Extensibility**: The **gantrylib** module is designed to be modular, allowing future integration with:
        - **Harbor Systems**: Extended to include **container identification** and **ship digital twins** (as done in the **Blended Intensive Programme**).
        - **Digital Twin Frameworks**: Potential integration with **Eclipse Ditto** or **Eclipse BaSyx** for industry relevance (currently ad-hoc).
    - **No Explicit APIs**: The exemplar does not expose REST/gRPC APIs for external systems, relying instead on **MQTT** for internal communication."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership and privacy considerations are as follows:
    - **Ownership**: The exemplar is **open-source** (MIT license), implying that data generated by the system is **publicly accessible** if shared via GitHub or documentation.
    - **Privacy**:
        - No explicit **GDPR** or **data anonymization** mechanisms are implemented, as the system is a **lab-scale demonstrator** with no personal or sensitive data.
        - **TimescaleDB** stores raw sensor and control data, which could include timestamps and operational metrics but no identifiable information.
    - **Ethical Use**: The exemplar is designed for **research and education**, with no commercial or proprietary data involved."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT adheres to the following standards and practices:
    - **Open-Source Tools**:
        - **Python** (widely adopted for scientific computing).
        - **TimescaleDB** (PostgreSQL-compatible, SQL-based).
        - **MQTT** (OASIS standard for IoT messaging).
        - **Docker** (CNCF standard for containerization).
    - **Modeling Standards**:
        - **C4 Model**: Used for architecture visualization (context, container, component diagrams).
        - **Arcadia (Capella)**: For **Model-Based Systems Engineering (MBSE)**.
    - **No Proprietary Frameworks**: The exemplar avoids commercial DT platforms (e.g., Siemens MindSphere, PTC ThingWorx), opting for **ad-hoc integration** of open-source tools."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety considerations include:
    - **Operational Safety**:
        - The **Control Application** includes **homing and zeroing** functions to ensure safe initialization of the crane.
        - **Hardware Limits**: Motor controllers (TMC4671-Eval) enforce current and speed limits to prevent mechanical damage.
    - **Cybersecurity**:
        - **No Explicit Security Measures**: The exemplar does not implement **authentication**, **encryption**, or **firewalls**, as it is a **lab-scale system** with no exposure to untrusted networks.
        - **MQTT Security**: While Eclipse Mosquitto supports TLS, it is not enabled by default in the exemplar.
    - **Remote Operations**:
        - The DT can **remotely control** the PT via the **Control Application**, but this is restricted to **local lab environments** with no human-machine interaction risks (e.g., no workers in the crane’s operational area).
        - **Fault Detection** ([6]) mitigates risks by identifying anomalies before they cause failures, but no **emergency stop** or **safety interlocks** are described for human safety."
]