// ----------------------------------------------------------
// Physical Sensing Components
// ----------------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing Angle Encoder mounted on the crane, measures crane swing angle in degrees"
    DTDFVocab:producedData SwingAngleDataStream
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer attached to the crane, measures wind speed in meters per second"
    DTDFVocab:producedData AnemometerDataStream
]

// ----------------------------------------------------------
// Data Transmitted (raw streams from sensors)
// ----------------------------------------------------------
instance SwingAngleDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// ----------------------------------------------------------
// Processed Data Entities
// ----------------------------------------------------------
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Timestamped swing angle values (degrees) logged for analysis"
    DTDFVocab:fromData SwingAngleDataStream
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Timestamped wind speed values (m/s) logged for analysis"
    DTDFVocab:fromData AnemometerDataStream
    DTDFVocab:inputTo TimescaleDBEnabler
]

// ----------------------------------------------------------
// Digital Twin Models
// ----------------------------------------------------------
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "CAD geometric model of the laboratory‑scale gantry crane structure"
    DTDFVocab:inputTo DockerContainerEnabler
]

instance KinematicBehavioralModel : DTDFVocab:Model [
    base:desc "Kinematic behavioral model capturing crane and hook motion dynamics"
    DTDFVocab:inputTo DockerContainerEnabler
]

// ----------------------------------------------------------
// Enablers (Infrastructure / Runtime Platforms)
// ----------------------------------------------------------
instance DockerContainerEnabler : DTDFVocab:Enabler [
    base:desc "Docker container platform used to host all micro‑service containers"
    DTDFVocab:enables CADKinematicModelService,
                OptimalControlService,
                HistoricalLoggingService,
                RealTimeVisualizationService,
                ContinuousValidationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL) instance for time‑series storage of sensor and operational data"
    DTDFVocab:enables HistoricalLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "ActiveMQ MQTT broker enabling publish/subscribe communication among micro‑services"
    DTDFVocab:enables ContinuousValidationService,
                RealTimeVisualizationService
]

// ----------------------------------------------------------
// Services Offered by the Digital Twin
// ----------------------------------------------------------
instance CADKinematicModelService : DTDFVocab:Service [
    base:desc "Provides CAD geometry and kinematic computations for crane pose and motion"
    DTDFVocab:provides RealTimePoseInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Generates optimal control commands for trajectory execution based on current state"
    DTDFVocab:provides AdjustControlAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Continuously logs sensor streams, actuation commands and model predictions for post‑run analysis"
    DTDFVocab:provides HistoricalDataInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualisation of crane pose, hook position and puck locations"
    DTDFVocab:provides RealTimePoseInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates physical behaviour against model predictions, detecting deviations"
    DTDFVocab:provides FaultDetectionInsight
]

// ----------------------------------------------------------
// Insights and Actions
// ----------------------------------------------------------
instance RealTimePoseInsight : DTDFVocab:Insight [
    base:desc "Live visual insight into the current pose of the crane and transported pucks"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects deviations between measured behaviour and model predictions to support fault detection"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight derived from archived sensor and command logs for retrospective analysis"
]

instance AdjustControlAction : DTDFVocab:Action [
    base:desc "Automatically adjust control commands to correct trajectory deviations"
    DTDFVocab:IsAutomatic true
]

// ----------------------------------------------------------
// Physical System Components (Environment)
// ----------------------------------------------------------
instance LaboratoryGantryCrane : DTDFVocab:Environment [
    base:desc "Laboratory‑scale gantry crane inspired by Port of Antwerp harbor cranes; includes mini‑gantry, electronic controller and surrogate pucks"
    base:contains SwingAngleEncoder,
                Anemometer,
                CraneControlUnit,
                GantryStructure,
                PuckSurrogate
]

instance CraneControlUnit : DTDFVocab:Component [
    base:desc "Electronic controller (Arduino) interfacing sensors and actuators on the crane"
]

instance GantryStructure : DTDFVocab:Component [
    base:desc "Miniature gantry frame providing the mechanical backbone of the crane"
]

instance PuckSurrogate : DTDFVocab:Component [
    base:desc "Small metal pucks used as surrogate containers for logistics experiments"
]

// ----------------------------------------------------------
// Micro‑service Containers (Multiplicity – Six containers)
// ----------------------------------------------------------
instance DatabaseContainer : DTDFVocab:Component [
    base:desc "Container hosting TimescaleDB for time‑series data storage"
]

instance DashboardContainer : DTDFVocab:Component [
    base:desc "Container providing user dashboard for visualising real‑time crane data"
]

instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Container executing the OptimalControlService to generate trajectory commands"
]

instance SimulationContainer : DTDFVocab:Component [
    base:desc "Container running simulation workloads (e.g., predictive motion scenarios)"
]

instance ContinuousValidationContainer : DTDFVocab:Component [
    base:desc "Container hosting the ContinuousValidationService for model‑vs‑reality checks"
]

instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Container running the ActiveMQ MQTT broker for inter‑service messaging"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends motion commands (motor speed set‑points, hoist position targets) to the Physical Crane Interface, which translates them into controller‑specific messages (e.g., serial or CAN commands) that drive the two motor controllers on the crane. Trajectories generated by the Trajectory Generator Service are consumed by the Control Application. The documents do not specify authentication or command format details; execution feedback is obtained indirectly through the Logging Application that records the resulting crane state, allowing operators to verify that commands were enacted."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin operates with continuous runtime monitoring: the Logging Application continuously writes the crane state to the TimescaleDB, the Continuous Validation Service continuously compares live measurements with simulation results, and notifications are sent in near‑real‑time via the Grafana dashboard. No explicit synchronization interval, latency bound, or temporal granularity is specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin follows a modular micro‑service architecture orchestrated by an MQTT broker for inter‑service signaling. All services share a central TimescaleDB for persistence, and Grafana visualises the data. The Trajectory Generator uses a kinematics model to produce swing‑free trajectories, the Simulation Service emulates crane dynamics, and the Continuous Validation Service validates executed trajectories against simulations, alerting operators via the dashboard. Resource management is implied by container‑level isolation, and the overall orchestration is ad‑hoc rather than based on a commercial digital‑twin framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by employing a kinematic model that reflects the actual crane’s degrees of freedom and by continuously validating that model against logged operational data. The exemplar is used to demonstrate continuous validation methods, fault detection via time‑series classification, and co‑evolution of the twin using the DarTwin notation. Validation and verification are performed through these continuous validation loops, though explicit uncertainty quantification and error correction mechanisms are not detailed in the provided documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital‑twin components run on a single on‑premise PC. Docker‑containerised services (TimescaleDB, Grafana, Eclipse Mosquitto MQTT broker) are connected via a Docker bridge network; inter‑service signalling uses MQTT over TCP (default port 1883). Python services (Control Application, Logging Application, Simulation Service, etc.) communicate with the MQTT broker and the database over localhost. No explicit bandwidth, latency, redundancy, or security protocol (e.g., TLS) requirements are mentioned."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system is deployed on‑premise on a personal computer. Software components consist of Python modules bundled in the pip‑installable 'gantrylib' package and Docker containers for the TimescaleDB database, Grafana dashboard, and MQTT broker, orchestrated with a Docker‑Compose file for one‑command start/stop. Deployment is therefore edge‑centric, with storage provided by TimescaleDB (optimised for time‑series) and compute performed by the host PC. Scalability is limited to the host’s resources; the Docker architecture allows easy replication of containers, but no cloud or multi‑node deployment, reliability, or high‑availability mechanisms are described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with the physical crane is achieved via a Python‑based Physical Crane Interface that connects to the crane controllers. Twin components exchange data using MQTT messages and access the shared TimescaleDB via SQL. Visualization is provided through Grafana. No external enterprise protocols (e.g., OPC‑UA), standards, or other digital twins are referenced, so integration is limited to the local hardware and internal services."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management digital twin is built on an AutomationML‑based model, complying with the AutomationML standard for representing engineering data. Architectural descriptions are expressed using the C4 model, and the overall implementation follows open‑source conventions hosted on GitHub, facilitating interoperability through widely adopted container and messaging standards (Docker, ActiveMQ)."
]