// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor that drives the lateral cart of the gantry crane, controlled via a TMC4671 eval board."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor that raises and lowers the hoist carriage, controlled via a TMC4671 eval board."
]

instance HoistElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist carriage for picking up and releasing pucks."
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the swing arm that measures the hoist swing angle."
    DTDFVocab:producedData SwingAngleMeasured
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Wind speed sensor mounted on the crane frame that records local wind conditions."
    DTDFVocab:producedData WindSpeedMeasured
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the cart stepper motor that provides the cart horizontal position."
    DTDFVocab:producedData MotorPositionMeasured
]

instance ElectromagnetStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Status sensor that indicates whether the hoist electromagnet is engaged or disengaged."
    DTDFVocab:producedData ElectromagnetStatusMeasured
]

// C4: Physical-to-virtual interaction
instance SwingAngleMeasured : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedMeasured : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorPositionMeasured : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance ElectromagnetStatusMeasured : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ElectromagnetStatusSensor
]

// C10: Models/Data
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane, including frame, arm, and carriage."
    DTDFVocab:inputTo TimescaleDBContainer
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Symbolic kinematic model that defines joint coordinates and swing dynamics."
    DTDFVocab:inputTo TimescaleDBContainer
]

instance PhysicalDynamicModel : DTDFVocab:Model [
    base:desc "Physics‑based dynamic model that captures inertia, damping, and external disturbances."
    DTDFVocab:inputTo TimescaleDBContainer
]

instance TrajectoryOptimizationModel : DTDFVocab:Model [
    base:desc "Trajectory optimization model that computes time‑optimal lift‑and‑move plans."
    DTDFVocab:inputTo TimescaleDBContainer
]

instance ValidationModel : DTDFVocab:Model [
    base:desc "Model used for continuous validation that compares real and simulated trajectories."
    DTDFVocab:inputTo TimescaleDBContainer
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series data of swing angles measured during crane operation."
    DTDFVocab:fromData SwingAngleMeasured
    DTDFVocab:inputTo TimescaleDBContainer
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series data of wind speed recorded by the anemometer."
    DTDFVocab:fromData WindSpeedMeasured
    DTDFVocab:inputTo TimescaleDBContainer
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Time‑series data of cart horizontal positions."
    DTDFVocab:fromData MotorPositionMeasured
    DTDFVocab:inputTo TimescaleDBContainer
]

instance ElectromagnetStatusData : DTDFVocab:Data [
    base:desc "Time‑series data indicating electromagnet engage/disengage status."
    DTDFVocab:fromData ElectromagnetStatusMeasured
    DTDFVocab:inputTo TimescaleDBContainer
]

// C11: Enablers
instance TimescaleDBContainer : DTDFVocab:Enabler [
    base:desc "TimescaleDB container that stores all telemetry, models, and validation data."
    DTDFVocab:enables LoggingService, SimulationService, DataVisualizationService
]

instance MosquittoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker that relays topic updates from the logging application to services."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, LoggingService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana container that visualizes real‑time and historical data from TimescaleDB."
    DTDFVocab:enables DataVisualizationService
]

instance PhysicalCraneInterfaceContainer : DTDFVocab:Enabler [
    base:desc "Docker container that hosts the logging application which reads sensors and publishes MQTT topics."
    DTDFVocab:enables PhysicalCraneInterfaceService
]

// C6: Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Service that reads sensor measurements, stores them in TimescaleDB, and publishes MQTT topics."
    DTDFVocab:provides DataLoggedInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service that uses the kinematic and CAD models to generate optimal lift trajectories."
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Full‑scale simulation service that executes dynamic models in real‑time."
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that compares real‑world sensor data with simulated trajectories and triggers alerts on deviation."
    DTDFVocab:provides DeviationAlertInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service that feeds TimescaleDB data to Grafana dashboards for real‑time and historical visualization."
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance PhysicalCraneInterfaceService : DTDFVocab:Service [
    base:desc "Service that interfaces with the physical crane, ingesting encoder data and issuing motor commands."
    DTDFVocab:provides PhysicalActuationInsight
]

// C17: Insights/Actions
instance RealtimeSwingAngleInsight : DTDFVocab:Insight [
    base:desc "Provides real‑time swing angle deviations for operator awareness."
]

instance RealtimeWindSpeedInsight : DTDFVocab:Insight [
    base:desc "Real‑time wind speed readings used for dynamic trajectory adjustments."
]

instance RealtimeMotorPositionInsight : DTDFVocab:Insight [
    base:desc "Immediate feedback on cart position accuracy."
]

instance RealtimeElectromagnetStatusInsight : DTDFVocab:Insight [
    base:desc "Indicates real‑time engagement state of the hoist electromagnet."
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Displays computed optimal trajectory for the next load transfer."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Shows simulated crane dynamics for verification purposes."
]

instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Triggers alerts when real trajectory deviates beyond predefined thresholds."
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Feeds live sensor data to Grafana panels for operator dashboards."
]

instance PhysicalActuationInsight : DTDFVocab:Insight [
    base:desc "Reports on the execution of motor actuation commands."
]

instance DataLoggedInsight : DTDFVocab:Insight [
    base:desc "Insight generated by the LoggingService indicating successful data logging."
]

instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Sends motor command packets to the TMC4671 controllers."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory generation and control commands are produced by the Trajectory Generator Service, then sent via the Physical Crane Interface (Python driver) to the motor controllers and electromagnet; MQTT topics carry real‑time execution updates back to the operator’s HMI."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Services operate in near real‑time: logging occurs at each sensor sample, trajectory generation and validation are performed for each commanded trajectory, and simulation runs concurrently with execution; the TimescaleDB handles high‑frequency time‑series data, while MQTT handles event‑driven messages."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation is an orchestrated set of Docker containers (Database, MQTT broker, Dashboard, Trajectory Generator, Simulation, Continuous Validation) linked via local networking, all coordinated by the gantrylib library running on a single personal computer that also hosts the physical crane interface."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The exemplar spans the design phase (CAD models in Autodesk Fusion360), the manufacturing phase (Bill‑of‑Materials and assembled hardware), and the operational phase (runtime logging, validation, and control during crane operation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation is achieved by continuous comparison of real trajectory data with simulated trajectories; distance metrics are computed and compared against a user‑defined threshold, with alerts emitted upon breach; fault detection research further refines validation by leveraging time‑series classification techniques."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses MQTT (internal signaling), PostgreSQL/TimescaleDB for data storage, and a serial (or USB) Python driver that connects to the Arduino‑based motor controllers; all interfaces are locally hosted on the same PC."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin runs locally on a personal computer; Docker Compose brings up TimescaleDB, Mosquitto, and Grafana in containers, while the Python gantrylib and HMI run natively; code and documentation are publicly available on Cosys‑Lab GitHub under an MIT license."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not explicitly presented in the documents; the exemplar is designed to run independently without external system integration."
]