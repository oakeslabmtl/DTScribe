    base:desc "Overview of historical greenhouse telemetry recorded in InfluxDB."
]
instance GreenhouseLiveTelemetryInsight : DTDFVocab:Insight [
    base:desc "Live rendering of greenhouse telemetry in Azure dashboards."
]
