// C11: Enablers
instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database used by GreenhouseDT to store historical telemetry of HVAC, lighting and irrigation sensors."
    DTDFVocab:enables GreenhouseHistoricalDataLoggingService
]
instance ActiveMQEnabler : DTDFVocab:Enabler [
    base:desc "ActiveMQ message broker that forwards event streams and control commands between greenhouse plant and its digital twin."
    DTDFVocab:enables GreenhouseRealTimeVisualizationService
]
instance AzureAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Azure cloud analytics layer that hosts predictive machine‑learning models for greenhouse and indoor air‑quality forecasting."
    DTDFVocab:enables GreenhousePredictiveAnalyticsService, AirQualityPredictiveAnalyticsService
]
instance AzureDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Azure dashboards providing runtime visualization of telemetry for greenhouse and air‑quality management."
    DTDFVocab:enables GreenhouseRealTimeVisualizationService, AirQualityRuntimeVisualizationService
]
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database storing crane telemetry logs of position, velocity, acceleration, payload mass and alarm status."
    DTDFVocab:enables CraneHistoricalDataLoggingService, CraneRealTimeVisualizationService
]
instance VTKEnabler : DTDFVocab:Enabler [
    base:desc "VTK rendering library used to render the 3‑D representation of the gantry crane in real time."
    DTDFVocab:enables CraneRealTimeVisualizationService
]
instance PlotlyEnabler : DTDFVocab:Enabler [
    base:desc "Plotly plotting framework used for live motion‑state charts of the gantry crane."
    DTDFVocab:enables CraneRealTimeVisualizationService
]
instance RaspberryPiEnabler : DTDFVocab:Enabler [
    base:desc "Raspberry Pi platform hosting sensors and control software for the Air Quality Management exemplar."
    DTDFVocab:enables AirQualityRuntimeVisualizationService
]
instance AutomationMLEnabler : DTDFVocab:Enabler [
    base:desc "AutomationML‑based model instantiated on Raspberry Pi to support simulation scenarios for air quality."
    DTDFVocab:enables AirQualitySimulationService
]

// C6: Services
instance GreenhouseHistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that records greenhouse telemetry into InfluxDB for post‑hoc analysis."
    DTDFVocab:provides GreenhouseHistoricalTelemetryInsight
]
instance GreenhouseRealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Service that streams greenhouse telemetry to Azure dashboards via ActiveMQ."
    DTDFVocab:provides GreenhouseLiveTelemetryInsight
]
instance GreenhousePredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service that forecasts future temperature, humidity and irrigation needs using Azure ML models."
    DTDFVocab:provides GreenhousePredictiveInsight, GreenhouseExecuteControlAction
]
instance GreenhouseControlService : DTDFVocab:Service [
    base:desc "Control service that adjusts HVAC, lighting and irrigation actuators to maintain desired environmental set‑points."
    DTDFVocab:provides GreenhouseControlInsight, GreenhouseExecuteControlAction
]
instance AirQualityRuntimeVisualizationService : DTDFVocab:Service [
    base:desc "Service that streams live air‑quality metrics to Azure dashboards."
    DTDFVocab:provides AirQualityRuntimeInsight
]
instance AirQualitySimulationService : DTDFVocab:Service [
    base:desc "Service that models hypothetical changes in ventilation or occupancy to evaluate virus‑transmission risk."
    DTDFVocab:provides AirQualitySimulationInsight, RunSimulationScenarioAction
]
instance AirQualityPredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service that forecasts future CO₂ and temperature trends on Azure."
    DTDFVocab:provides AirQualityPredictiveInsight, ForecastAction
]
instance CraneOptimalControlService : DTDFVocab:Service [
    base:desc "Service that calculates time‑optimal carriage trajectories for the gantry crane."
    DTDFVocab:provides CraneOptimalTrajectoryInsight, CraneExecuteOptimalTrajectoryAction
]
instance CraneHistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that logs crane telemetry into TimescaleDB."
    DTDFVocab:provides CraneHistoricalTelemetryInsight
]
instance CraneRealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Service that renders real‑time 3‑D visualization and plots of crane motion."
    DTDFVocab:provides CraneLiveTelemetryInsight, RenderCraneboardAction
]
instance CraneContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that compares live telemetry against model predictions and alerts when deviations exceed thresholds."
    DTDFVocab:provides CraneDeviationAlertInsight, CraneTriggerAlarmAction
]

// C17: Insights
