// Acting Components
instance CartLinearMotor : DTDFVocab:ActingComponent [
    base:desc "Horizontal cart linear motor driven by a Trinamic TMC4671 eval motor controller"
]
instance HoistLinearMotor : DTDFVocab:ActingComponent [
    base:desc "Vertical hoist linear motor driven by a Trinamic TMC4671 eval motor controller"
]
instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist end that can pick up or release containers"
]
instance TrinamicMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671 Eval motor controller that drives both the cart and hoist motors"
]
instance PythonControlInterface : DTDFVocab:ActingComponent [
    base:desc "Python-based control interface that commands the motors and emits command traces"
]

// Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder measuring pendulum motion"
    DTDFVocab:producedData SwingAngleDataTransmitted
]
instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer that measures wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]
instance CartPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder that measures cart position along the horizontal axis"
    DTDFVocab:producedData CartPositionDataTransmitted
]
instance HoistPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder that measures hoist position along the vertical axis"
    DTDFVocab:producedData HoistPositionDataTransmitted
]
instance MotorVoltageSensor : DTDFVocab:SensingComponent [
    base:desc "Voltage sensor on the cart motor"
    DTDFVocab:producedData MotorVoltageDataTransmitted
]
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor on the cart motor"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// Validation Metrics Sensor
instance ValidationMetricsSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor emitting validation metrics for continuous comparison"
    DTDFVocab:producedData ValidationMetricsDataTransmitted
]

// Data Transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]
instance CartPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartPositionEncoder
]
instance HoistPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistPositionEncoder
]
instance MotorVoltageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorVoltageSensor
]
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]
instance CommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PythonControlInterface
]
instance ValidationMetricsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ValidationMetricsSensor
]

// Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "High-frequency time‑series data for swing angle"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBDatabase
]
instance WindSpeedData : DTDFVocab:Data [
    base:desc "High-frequency time‑series data for wind speed"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBDatabase
]
instance CartPositionData : DTDFVocab:Data [
    base:desc "High-frequency time‑series data for cart position"
    DTDFVocab:fromData CartPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBDatabase
]
instance HoistPositionData : DTDFVocab:Data [
    base:desc "High-frequency time‑series data for hoist position"
    DTDFVocab:fromData HoistPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBDatabase
]
instance MotorVoltageData : DTDFVocab:Data [
    base:desc "High-frequency time‑series data for motor voltage"
    DTDFVocab:fromData MotorVoltageDataTransmitted
    DTDFVocab:inputTo TimescaleDBDatabase
]
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "High-frequency time‑series data for motor current"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo TimescaleDBDatabase
]
instance CommandTraceData : DTDFVocab:Data [
    base:desc "Collected command traces emitted by the Python control interface"
    DTDFVocab:fromData CommandDataTransmitted
    DTDFVocab:inputTo TimescaleDBDatabase
]
instance ValidationMetricsData : DTDFVocab:Data [
    base:desc "Continuous validation metrics comparing executed and simulated trajectories"
    DTDFVocab:fromData ValidationMetricsDataTransmitted
    DTDFVocab:inputTo TimescaleDBDatabase
]

// Models/Data (digitally stored elements)
instance CADModel : DTDFVocab:Model [
    base:desc "CAD geometry stored in the CAD folder"
    DTDFVocab:inputTo GantrylibLibrary
]
instance KinematicModel : DTDFVocab:Model [
    base:desc "Analytical kinematic equations used by the trajectory generator"
    DTDFVocab:inputTo GantrylibLibrary
]
instance SimulationModel : DTDFVocab:Model [
    base:desc "Discrete‑time simulation model implemented in Python"
    DTDFVocab:inputTo GantrylibLibrary
]

// Enablers
instance TimescaleDBDatabase : DTDFVocab:Enabler [
    base:desc "TimescaleDB database for high‑frequency time‑series data and command traces"
    DTDFVocab:enables DatabaseService
]
instance GantrylibLibrary : DTDFVocab:Enabler [
    base:desc "Python gantrylib module providing kinematic calculations and trajectory generation"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService
]
instance TrinamicDriver : DTDFVocab:Enabler [
    base:desc "Trinamic TMC4671 motor driver enabling motor actuation"
    DTDFVocab:enables TrajectoryGeneratorService
]
instance ArduinoMicrocontroller : DTDFVocab:Enabler [
    base:desc "Arduino microcontroller with custom shield used for sensor readout"
    DTDFVocab:enables HardwareInterfaceService
]
instance MosquittoMQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service messaging"
    DTDFVocab:enables BrokerService
]
instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for visualization of trajectory plots, swing angle, wind speed, and fault alerts"
    DTDFVocab:enables DashboardService
]
instance HardwareInterfaceService : DTDFVocab:Service [
    base:desc "Service handling hardware communication via Trinamic and Arduino"
    DTDFVocab:provides HardwareTelemetryInsight
]

// Services
instance DatabaseService : DTDFVocab:Service [
    base:desc "Service responsible for logging raw sensor, command, and validation data into TimescaleDB"
    DTDFVocab:provides DataStorageInsight
]
instance BrokerService : DTDFVocab:Service [
    base:desc "Service providing MQTT messaging for inter‑service communication"
    DTDFVocab:provides MQTTMessageInsight
]
instance DashboardService : DTDFVocab:Service [
    base:desc "Service that renders trajectory plots with confidence bounds, overlays swing angle and wind speed, and displays fault alerts"
    DTDFVocab:provides TrajectoryPlotInsight, SwingAndWindOverlayInsight, FaultAlertTableInsight
]
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service that generates optimal trajectories using the crane's kinematic model"
    DTDFVocab:provides GeneratedTrajectoryInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs the discrete‑time simulation of the crane's response to planned trajectories"
    DTDFVocab:provides SimulatedTrajectoryInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that compares executed versus simulated trajectories and triggers alerts when distance metrics exceed a threshold"
    DTDFVocab:provides FaultCategorizationInsight, MaintenanceScheduleAction, OperatorInterventionAction
]

// Insights
instance TrajectoryPlotInsight : DTDFVocab:Insight [
    base:desc "Plot of executed trajectory overlayed with simulation confidence bounds"
]
instance SwingAndWindOverlayInsight : DTDFVocab:Insight [
    base:desc "Overlay of real‑time swing angle and wind speed on trajectory plots"
]
instance FaultAlertTableInsight : DTDFVocab:Insight [
    base:desc "Table of fault alerts generated by the continuous validation service"
]
instance DataStorageInsight : DTDFVocab:Insight [
    base:desc "Insight on data retention and storage health within the TimescaleDB database"
]
instance MQTTMessageInsight : DTDFVocab:Insight [
    base:desc "Insight on the flow of MQTT messages between services"
]
instance GeneratedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight on trajectories generated by the trajectory generator"
]
instance SimulatedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight on simulated trajectories produced by the simulation service"
]
instance FaultCategorizationInsight : DTDFVocab:Insight [
    base:desc "Insight that categorizes faults detected during continuous validation"
]
instance HardwareTelemetryInsight : DTDFVocab:Insight [
    base:desc "Insight derived from raw hardware telemetry data"
]

// Actions
instance MaintenanceScheduleAction : DTDFVocab:Action [
    base:desc "Action that schedules maintenance when fault conditions persist"
    DTDFVocab:IsAutomatic true
]
instance OperatorInterventionAction : DTDFVocab:Action [
    base:desc "Action that notifies the operator to intervene immediately"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The trajectory‑generator service produces optimal joint trajectories; the control application subscribes to these trajectories and translates them into motor step pulses sent to the motor drivers via the Python interface; the continuous‑validation service publishes alerts to the Grafana dashboard when measurement‑simulation divergence exceeds a predefined threshold; the operator can manually issue override commands through the GUI that are routed back to the control application."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time operation: services run concurrently as the crane moves, trajectory generation and validation occur in sync with the moves, and logging updates the database continuously."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A Docker‑Compose orchestrated stack consisting of the physical crane (Python interface and Arduino), the twin’s database, MQTT broker, dashboard, trajectory generator, simulation, and continuous validation services, all connected via a local network and sharing the same data store."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design‑phase: CAD models in Autodesk Fusion360 and kinematic model in the Trajectory Generator; Manufacturing‑phase: physical Arduino, motor drivers, encoders, electromagnet, shuttle assembly; Operation‑phase: runtime state logging, real‑time trajectory execution, continuous validation and fault detection; each phase is represented in the twin through either static models or dynamic data streams."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation is achieved by continuously comparing executed trajectory data with the simulation model using distance metrics; alerts trigger when deviations exceed predefined thresholds, ensuring that the twin’s representation remains valid; the simulation’s fidelity depends on the accuracy of the kinematic model and sensor calibration."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The twin employs MQTT (Eclipse Mosquitto) for service‑to‑service messaging, TimescaleDB (PostgreSQL) for storing time‑series data, and a serial/USB connection between the Python control interface and the Arduino; all services communicate over Docker networking on a single host."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin components are containerised and deployed via Docker Compose on a single Linux workstation; database and dashboard volumes persist data, and the physical interface runs directly on the host, with the Arduino connected over USB."
]