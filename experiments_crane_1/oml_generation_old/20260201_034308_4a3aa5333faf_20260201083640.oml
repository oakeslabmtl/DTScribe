// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring hoist swing angle on the lab‑scale gantry crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed that influences crane motion"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical‑to‑virtual interaction (data transmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C11: Data (sensor measurements)
instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurement from the encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo LoggingEnabler, ValidationEnabler
]

instance WindSpeedMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed measurement from the anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo LoggingEnabler, ValidationEnabler
]

// C10: Models
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "Fusion 360 CAD geometry of the gantry crane"
    DTDFVocab:inputTo VisualizationEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used to compute optimal swing‑free trajectories"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the crane and its controllers"
    DTDFVocab:inputTo SimulationEnabler, ValidationEnabler
]

// C11: Enablers
instance LoggingEnabler : DTDFVocab:Enabler [
    base:desc "Python Physical Crane Interface & Logging Application that ingest sensor data and write to TimescaleDB"
    DTDFVocab:enables DataLoggingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana component that consumes stored data for performance dashboards"
    DTDFVocab:enables DataVisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Service that runs the kinematic model to generate optimal trajectories"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Real‑time simulation engine executing the dynamic model of the crane"
    DTDFVocab:enables SimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation component that compares executed trajectories with simulated ones"
    DTDFVocab:enables ContinuousValidationService
]

instance MQTTSignalingEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker interface that distributes state updates and alerts to other DT services"
    DTDFVocab:enables MQTTSignalingService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Streams crane state (motor positions, sensor readings, timestamps) to a TimescaleDB time‑series database"
    DTDFVocab:provides DataLoggingAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualizes system performance and sensor history"
    DTDFVocab:provides PerformanceVisualizationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free trajectories based on the kinematic model"
    DTDFVocab:provides OptimalSwingFreeTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs a real‑time simulation of crane dynamics and controller behavior"
    DTDFVocab:provides SimulationStateInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates executed motion against simulated trajectories and raises alerts"
    DTDFVocab:provides RealTimeValidationAlertInsight
]

instance MQTTSignalingService : DTDFVocab:Service [
    base:desc "Publishes crane state and validation alerts over MQTT for consumption by other DT components"
    DTDFVocab:provides ParameterAdjustmentAction
    DTDFVocab:provides OperationHaltAction
]

// C17: Insights
instance OptimalSwingFreeTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal swing‑free trajectory computed for the current load and wind conditions"
]

instance RealTimeValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when measured motion deviates from the simulated model beyond a defined threshold"
]

instance PerformanceVisualizationInsight : DTDFVocab:Insight [
    base:desc "Dashboard visualizes key performance indicators such as swing angle, wind speed, and trajectory error"
]

instance SimulationStateInsight : DTDFVocab:Insight [
    base:desc "Current simulated state of the crane displayed for operator reference"
]

// C17: Actions
instance DataLoggingAction : DTDFVocab:Action [
    base:desc "Automatically writes received sensor data to TimescaleDB"
    DTDFVocab:IsAutomatic true
]

instance ParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Operator can adjust control parameters via the HMI"
    DTDFVocab:IsAutomatic false
]

instance OperationHaltAction : DTDFVocab:Action [
    base:desc "Operator can halt crane operation immediately"
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving horizontal cart movement, controlled by a TMC4671‑Eval driver"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving vertical hoist movement, controlled by a TMC4671‑Eval driver"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist end used to pick up and release pucks"
]

// C5: Physical components (generic)
instance ArduinoControlBoard : DTDFVocab:Component [
    base:desc "Arduino‑based board that reads sensors, drives motor drivers and runs the control logic"
]

// C5: Environment composition
instance GantryCranePhysicalEnvironment : DTDFVocab:Environment [
    base:contains CartStepperMotor, HoistStepperMotor, ElectromagnetActuator, SwingAngleEncoder, Anemometer, ArduinoControlBoard
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control Application (and the Human‑Machine Interface) send motion set‑points, trajectory commands, and electromagnet activation signals to the Physical Crane Interface, which translates them to controller commands that drive the stepper motors and electromagnet on the crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of the physical crane linked to a Python Interface, a Control Application, a Logging Application and an HMI on the physical side; these communicate through MQTT with the digital side composed of the database, dashboard, trajectory generator, simulator, and continuous‑validation services, all running on a single PC and containerized for easy deployment."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the design stage (CAD models of the crane in Autodesk Fusion 360), the manufacturing/implementation stage (physical frame, motors, Arduino board), and the operation stage (runtime data logging, simulation, validation, and trajectory planning)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, and checks them against a predefined threshold; violations trigger operator alerts on the Grafana dashboard, providing on‑line verification of model fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between services uses MQTT (Eclipse Mosquitto) for signaling; sensor and state data are written to TimescaleDB via standard PostgreSQL SQL; the HMI and other applications retrieve data from the database using Grafana’s data source plug‑ins."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All Dockerized components (TimescaleDB, MQTT broker, Grafana) are launched on a personal computer via a Docker‑Compose file. The Python modules run natively on the same host. The entire stack is open‑source and publicly available on GitHub."
]