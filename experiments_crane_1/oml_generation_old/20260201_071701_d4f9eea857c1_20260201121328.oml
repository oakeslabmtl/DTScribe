// C1: Environment
instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains GantryCrane, PhysicalCraneInterface, LoggingApplication,
    OptimalControlEngine, ContinuousValidationEngine, FaultDetectionEngine,
    DataVisualizationDashboard
]

// C1: Component
instance GantryCrane : DTDFVocab:Component [
    base:desc "Lab-scale gantry crane consisting of a vertical rail, horizontal carriage, crane arm, and controller, operating in a confined laboratory environment for rapid positioning of payloads."
]

// C2: Acting Components
// (No acting components referenced in the extracted characteristics)

// C3: Physical sensing components
instance PhysicalCraneInterface : DTDFVocab:SensingComponent [
    base:desc "Python program connecting to the crane controllers and reading the current state of the crane, including position, velocity, and load."
    DTDFVocab:producedData PositionDataTransmitted, VelocityDataTransmitted, LoadDataTransmitted
]

instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Measures the crane carriage and arm position."
    DTDFVocab:producedData PositionDataTransmitted
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Measures the velocity of the crane carriage and arm."
    DTDFVocab:producedData VelocityDataTransmitted
]

instance LoadSensor : DTDFVocab:SensingComponent [
    base:desc "Measures the load carried by the crane."
    DTDFVocab:producedData LoadDataTransmitted
]

// C4: Data transmitted
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalCraneInterface, PositionSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalCraneInterface, VelocitySensor
]

instance LoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalCraneInterface, LoadSensor
]

// C10: Models/Data
instance PositionTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data representing the crane position."
    DTDFVocab:inputTo LoggingApplication, ContinuousValidationEngine, OptimalControlEngine
    DTDFVocab:fromData PositionDataTransmitted
]

instance VelocityTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data representing the crane velocity."
    DTDFVocab:inputTo LoggingApplication, ContinuousValidationEngine, OptimalControlEngine
    DTDFVocab:fromData VelocityDataTransmitted
]

instance LoadTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data representing the crane load."
    DTDFVocab:inputTo LoggingApplication, ContinuousValidationEngine
    DTDFVocab:fromData LoadDataTransmitted
]

// C11: Enablers
instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Python application that writes state updates to a TimescaleDB database."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance OptimalControlEngine : DTDFVocab:Enabler [
    base:desc "Engine that generates feed-forward trajectories to accelerate the crane toward desired positions."
    DTDFVocab:enables OptimalControlService
]

instance ContinuousValidationEngine : DTDFVocab:Enabler [
    base:desc "Engine that compares live sensor data against the kinematic model to detect deviations and faults."
    DTDFVocab:enables ContinuousValidationService
]

instance FaultDetectionEngine : DTDFVocab:Enabler [
    base:desc "Engine that applies diagnostic logic to identified deviations to flag abnormal behavior."
    DTDFVocab:enables FaultDetectionService
]

instance DataVisualizationDashboard : DTDFVocab:Enabler [
    base:desc "Dashboard that presents real-time kinematic states and archived metrics."
    DTDFVocab:enables DataVisualizationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Generates feed-forward trajectories to accelerate the physical crane toward desired positions."
    DTDFVocab:provides GenerateOptimalTrajectoryAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Records telemetry such as speed, acceleration, payload load, and actuator positions into a persistent time-series database for later analysis."
    DTDFVocab:provides LogTelemetryAction, TelemetryLoggingInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Presents real-time kinematic states and archived metrics through graphical dashboards."
    DTDFVocab:provides RealTimeKinematicStateInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares live sensor data against the kinematic model to detect deviations and faults in near real-time."
    DTDFVocab:provides DeviationDetectionInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Applies diagnostic logic to the validated observations to identify and flag abnormal behavior."
    DTDFVocab:provides FaultDetectionInsight, FlagAbnormalBehaviorAction
]

// C17: Insights and Actions
instance GenerateOptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Generates a feed-forward trajectory for crane operation based on desired positions."
    DTDFVocab:IsAutomatic true
]

instance LogTelemetryAction : DTDFVocab:Action [
    base:desc "Writes telemetry data to the TimescaleDB database."
    DTDFVocab:IsAutomatic true
]

instance FlagAbnormalBehaviorAction : DTDFVocab:Action [
    base:desc "Flags abnormal behavior detected by the fault detection engine."
    DTDFVocab:IsAutomatic true
]

instance RealTimeKinematicStateInsight : DTDFVocab:Insight [
    base:desc "Real-time kinematic states displayed in dashboards."
]

instance DeviationDetectionInsight : DTDFVocab:Insight [
    base:desc "Deviations between live sensor data and model predictions identified by continuous validation."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Faults in crane operation identified by fault detection logic."
]

instance TelemetryLoggingInsight : DTDFVocab:Insight [
    base:desc "Historical telemetry data stored for later analysis."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control of the physical crane is performed by the Control Application, a Python program that sends command messages to the Physical Crane Interface. The commands are simple control instructions (e.g., move to a specified coordinates, lift load, start/stop). The Control Application does not specify validation, authentication or conflict resolution within the documentation; however, any issued command is executed on the crane’s controllers via the interface. Feedback from the crane (e.g., updated state) is reported back to the interface and subsequently logged by the Logging Application."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The exemplar adopts a hybrid software stack orchestrated through containerized services running on virtual machines. The architecture layers include: a physical layer comprising Raspberry‑Pi single‑board computers (in the Air Quality Management case) or greenhouse sensors, a data ingestion layer using an ActiveMQ message broker to decouple sensor streams from downstream services, a persistence layer built on InfluxDB to store time‑series telemetry for status analysis and prediction engines, a virtualization layer leveraging pre‑configured virtual machine images that bundle software and prerecorded datasets, and an integration layer that pieces together automation workflows within Microsoft Azure for simulation, runtime visualization and prediction. Coordination is achieved through asynchronous message queues and container orchestration, with resource management handled by virtual machine slots and container resource limits. The system follows an event‑driven microservices architecture wherein each functional domain (sensor acquisition, data storage, simulation, visualization) is implemented as an independent container, and overall system coordination is centrally managed by the message broker and Azure pipelines."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin relies on an MQTT broker for inter‑service messaging, connecting the Trajectory Generator Service, Simulation Service, Continuous Validation Service, Database, and Dashboard. Data flows from the Physical Crane into the Logging Application, which writes to TimescaleDB; the Desktop Dashboard (Grafana) queries this database. Network topology is not explicitly defined beyond the presence of these services; no bandwidth, latency, reliability, redundancy, or security protocols are specified in the documentation."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The twin leverages standard, open‑source communication protocols: sensor data is published over the MQTT‑like protocol supported by ActiveMQ; instrumentation data is encapsulated following AutomationML schemas to ensure semantic interoperability. The Azure services expose RESTful APIs and Event Grid topics to publish state changes, while the pipeline integrates with external analytics services via HTTP/HTTPS. In addition, the Raspberry‑Pi hardware directly interfaces with external sensors over I²C/SPI, forwarding data through the broker to Azure IoT Hub. The integration pattern follows a publish‑sub approach, decoupling the twin’s internal services from external enterprise systems and enabling easy plugging of additional digital twins via the same broker architecture."
]