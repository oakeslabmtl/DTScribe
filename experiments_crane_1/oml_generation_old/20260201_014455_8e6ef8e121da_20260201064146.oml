// ------------------------------------------------------------
// C3: Physical sensing components
// ------------------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the gantry crane boom"
    DTDFVocab:producedData CraneStateDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting the crane movement"
    DTDFVocab:producedData CraneStateDataTransmitted
]

instance Electromagnet : DTDFVocab:SensingComponent [
    base:desc "Electromagnet detecting the presence of the payload hook"
    DTDFVocab:producedData CraneStateDataTransmitted
]

// ------------------------------------------------------------
// C4: Physical-to-virtual interaction (Data transmitted)
// ------------------------------------------------------------
instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder, Anemometer, Electromagnet
]

// ------------------------------------------------------------
// C5: Data (raw / processed)
// ------------------------------------------------------------
instance CraneStateData : DTDFVocab:Data [
    base:desc "Aggregated state data from swing angle, wind speed and electromagnet sensors"
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, SimulationServiceEnabler
]

// ------------------------------------------------------------
// C10: Models / Data artefacts
// ------------------------------------------------------------
instance GantryCraneCADModel : DTDFVocab:Model [
    base:desc "Detailed CAD geometry of the lab‑scale gantry crane"
    DTDFVocab:inputTo SimulationServiceEnabler, TrajectoryGeneratorEnabler
]

instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model capturing motion relationships of crane axes and hoist"
    DTDFVocab:inputTo ContinuousValidationEnabler, SimulationServiceEnabler
]

// ------------------------------------------------------------
// C11: Enablers (containerised components, middleware, DB)
// ------------------------------------------------------------
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑containerised TimescaleDB instance for time‑series storage"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑containerised Grafana dashboard for real‑time visualisation"
    DTDFVocab:enables RealTimeVisualizationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for inter‑service signalling"
    DTDFVocab:enables OptimalControlService
]

instance SimulationServiceEnabler : DTDFVocab:Enabler [
    base:desc "Containerised simulation service executing CAD and kinematic models"
    DTDFVocab:enables ContinuousValidationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Containerised service generating optimal motion trajectories"
    DTDFVocab:enables OptimalControlService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Container that continuously validates live crane data against the kinematic model"
    DTDFVocab:enables ContinuousValidationService
]

// ------------------------------------------------------------
// C6: Services
// ------------------------------------------------------------
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes and sends motion commands to the crane controller"
    DTDFVocab:provides VentilationRecommendationAction, AlertThresholdAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Records sensor and actuator data into TimescaleDB for later analysis"
    DTDFVocab:provides AirQualityMetricsInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides live visual dashboards of crane state and trajectory"
    DTDFVocab:provides VisualDashboardInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares live sensor data with the kinematic model to detect deviations"
    DTDFVocab:provides PollutantForecastInsight
]

// ------------------------------------------------------------
// C17: Insights / Actions
// ------------------------------------------------------------
instance AirQualityMetricsInsight : DTDFVocab:Insight [
    base:desc "Derived air‑quality metrics from historical crane operation data"
]

instance VisualDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time visual dashboard showing crane position, trajectory and sensor readings"
]

instance PollutantForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of pollutant levels based on simulation and current crane activity"
]

instance VentilationRecommendationAction : DTDFVocab:Action [
    base:desc "Automatic recommendation to adjust ventilation for improved indoor air quality"
    DTDFVocab:IsAutomatic true
]

instance AlertThresholdAction : DTDFVocab:Action [
    base:desc "Triggers alerts when sensor readings exceed predefined safety thresholds"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "A Control Application, implemented in Python, uses the same Physical Crane Interface to issue command messages to the crane controllers. Desired motion trajectories are computed by the Trajectory Generator Service and passed to the Control Application, which then transmits control commands (e.g., motor speed, hoist actuation) to the physical crane. The execution of commands is observed by the Logging Application and validated by the Continuous Validation Service, which compares measured trajectories with simulated ones. Specific command formats, authentication or confirmation mechanisms are not described in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows an ad‑hoc, container‑based orchestration pattern (as modelled with the C4 diagram). Core services (trajectory generation, simulation, continuous validation) are implemented as Python applications that communicate via an MQTT broker for signaling. Persistent state is stored in a TimescaleDB database, and visualisation is provided through a Grafana dashboard. The physical crane interface is a Python program that connects to the crane controllers. No commercial digital twin framework is used; integration relies on the described containers and the MQTT messaging backbone."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through continuous validation methods that compare the kinematic model’s predictions with measured behaviour of the physical crane. The exemplar has been employed in research on continuous validation, fault detection, and the DarTwin notation for systematic evolution of the twin, indicating that verification and validation processes are integral to its operation. Details on uncertainty quantification, error correction mechanisms, or formal quality‑assurance procedures are not explicitly provided."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital‑twin components are deployed as Docker containers on a single host computer. The TimescaleDB database, Grafana dashboard and Eclipse Mosquitto MQTT broker run in Docker containers orchestrated by Docker‑Compose. All Python services (Physical Crane Interface, Control Application, Logging Application, Trajectory Generator, Simulation Service, Continuous Validation Service) run on the host and communicate with the containers over the local TCP/IP stack, using MQTT for signalling between services and standard database connections for TimescaleDB. The network topology is essentially a local star where each service connects to the MQTT broker; no explicit bandwidth, latency, redundancy or security protocol specifications are provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire system is hosted on‑premise on a personal computer. Python components are packaged in a pip‑installable module (gantrylib). The database, MQTT broker and dashboard are containerised with Docker and started via a Docker‑Compose file, which also handles initial database and dashboard setup. Deployment relies on open‑source software (TimescaleDB, Grafana, Eclipse Mosquitto) and does not use cloud platforms. Scalability is limited to the resources of the host machine; the documents do not describe additional scaling, high‑availability or redundancy mechanisms."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external components is achieved through standard protocols and tools: an MQTT broker enables inter‑service messaging; TimescaleDB serves as the time‑series data store; Grafana provides external visualisation access; and the Physical Crane Interface uses a Python program to talk to the crane controllers. The documents do not mention interoperability with enterprise systems, external standards (e.g., OPC‑UA), or other digital twins."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin is built using AutomationML, a standardized data‑exchange format for engineering models. The exemplar follows model‑driven engineering practices and adopts common containerisation and virtualization standards for deployment, ensuring interoperability with other tools and platforms."
]