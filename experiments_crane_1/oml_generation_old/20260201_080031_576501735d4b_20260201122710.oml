// C1: Components and Environment
instance LaboratoryScaleGantryCrane : DTDFVocab:Component [
    base:desc "Laboratory‑scale gantry crane with horizontal gantry frame, vertical rails, trolley rail (X axis), vertical actuator/hoist (Y axis), and load‑bearing carriage"
]

instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains LaboratoryScaleGantryCrane
]

// C2: Acting Components
instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671 Eval controller board driving the cart motor on the X axis"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671 Eval controller board driving the hoist motor on the Y axis"
]

instance LoadReleaseElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted at the hoist end for load release"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing motion"
    DTDFVocab:producedData SwingAngleDataEvent
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer recording wind speed affecting the crane"
    DTDFVocab:producedData WindSpeedDataEvent
]

instance CargoPuckVisionTracker : DTDFVocab:SensingComponent [
    base:desc "Vision system camera that tracks the position of the cargo puck"
    DTDFVocab:producedData CargoPuckPositionDataEvent
]

// C4: DataTransmitted from sensors
instance SwingAngleDataEvent : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataEvent : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance CargoPuckPositionDataEvent : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CargoPuckVisionTracker
]

// C5: Data from sensor transmission
instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Swing‑angle measurement time‑series data captured by SwingAngleEncoder"
    DTDFVocab:fromData SwingAngleDataEvent
    DTDFVocab:inputTo DataIngestionEnabler
]

instance WindSpeedMeasurement : DTDFVocab:Data [
    base:desc "Wind speed measurement time‑series data captured by WindSpeedAnemometer"
    DTDFVocab:fromData WindSpeedDataEvent
    DTDFVocab:inputTo DataIngestionEnabler
]

instance CargoPuckPositionMeasurement : DTDFVocab:Data [
    base:desc "Cargo puck position measurement time‑series data captured by CargoPuckVisionTracker"
    DTDFVocab:fromData CargoPuckPositionDataEvent
    DTDFVocab:inputTo DataIngestionEnabler
]

// C5: Simulated state data (generated by SimulationService)
instance SimulatedStateDataEvent : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationService
]

instance SimulatedStateMeasurement : DTDFVocab:Data [
    base:desc "Simulated state time‑series data generated by SimulationService"
    DTDFVocab:fromData SimulatedStateDataEvent
    DTDFVocab:inputTo SimulationOutputEnabler
]

// C10: Model
instance KinematicModel : DTDFVocab:Model [
    base:desc "Analytical kinematic model mapping joint inputs to Cartesian positions derived from CAD geometry"
    DTDFVocab:inputTo KinematicModelEnabler
]

// C11: Enablers
instance DataIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that ingests sensor data into TimescaleDB for time‑series storage and processing"
    DTDFVocab:enables RealTimeMonitoringService, HistoricalDataLoggingService, ValidationService
]

instance KinematicModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that provides the kinematic model to planning and simulation services"
    DTDFVocab:enables TrajectoryPlanningService, SimulationService
]

instance SimulationOutputEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that forwards simulated state data to the ValidationService"
    DTDFVocab:enables ValidationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service that provides real‑time monitoring of shaft positions and load displacements from sensor data"
    DTDFVocab:provides ShaftPositionInsight, LoadDisplacementInsight
]

instance TrajectoryPlanningService : DTDFVocab:Service [
    base:desc "Service that uses the kinematic model to perform optimal trajectory planning for cart and hoist motors"
    DTDFVocab:provides TrajectoryPlanInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that numerically integrates the kinematic equations to simulate crane motion"
    DTDFVocab:provides SimulatedStateInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that logs historical sensor data with timestamps into the database"
    DTDFVocab:provides HistoricalDataInsight
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Service that consumes brokered sensor data and simulated states, calculates distance metrics, and compares against thresholds"
    DTDFVocab:provides ValidationResultInsight, TriggerAlarmAction, AdjustVentilationAction
]

// C17: Insights
instance ShaftPositionInsight : DTDFVocab:Insight [
    base:desc "Insight showing real‑time shaft positions derived from sensor data"
]

instance LoadDisplacementInsight : DTDFVocab:Insight [
    base:desc "Insight showing real‑time load displacement measurements"
]

instance TrajectoryPlanInsight : DTDFVocab:Insight [
    base:desc "Insight providing computed optimal trajectory plans for cart and hoist motors"
]

instance SimulatedStateInsight : DTDFVocab:Insight [
    base:desc "Insight of simulated crane state (position, velocity) derived from kinematic model"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight presenting historical sensor data logs with timestamps"
]

instance ValidationResultInsight : DTDFVocab:Insight [
    base:desc "Insight giving the distance metric between live sensor readings and simulated values, indicating validation status"
]

instance AlarmTriggerInsight : DTDFVocab:Insight [
    base:desc "Insight that indicates whether validation thresholds have been breached and an alarm should be triggered"
]

// C17: Actions
instance TriggerAlarmAction : DTDFVocab:Action [
    base:desc "Automatic action issued by ValidationService when validation thresholds are breached"
    DTDFVocab:IsAutomatic true
]

instance AdjustVentilationAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust ventilation in response to validation breach"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends control commands to the Physical Crane through the Physical Crane Interface, a Python program that connects directly to the crane controllers. The command flow uses the crane’s native controller interface; no explicit authentication, validation, or conflict‑resolution mechanisms are described."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The lifecycle of the exemplar Digital Twin follows a three‑phase sequence. In the **Design and Modeling** phase, the twin is conceived using AutomationML for the indoor air quality exemplar, and by extension a domain‑specific modeling language for the greenhouse uses a similar generic model. This phase establishes the conceptual twin, refines sensor mappings for the Raspberry‑Pi or greenhouse sensors, and defines the simulation and prediction capabilities. In the **Implementation and Deployment** phase, the twin and the physical system are containerized or virtualized; Docker‑compose files (present in the GitHub repository) orchestrate a set of services, which include an InfluxDB time‑series database for sensor data, an ActiveMQ message broker to shuttle telemetry, and a virtual machine image that pre‑installs all software components. Finally, in the **Operation and Validation** phase, the twin runs continuously, providing real‑time monitoring via a Grafana dashboard and performing continuous validation—distance metrics between real and simulated values are calculated automatically; if the metric falls outside an acceptable threshold, the twin triggers an alert or an adaptive change to the physical system. The transition between these stages is governed by the release cycle in the repository, with clear packaging of each phase’s artefacts for reproducibility."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by a Continuous Validation Service that continuously compares executed trajectories with simulated trajectories. It calculates a distance metric between the real and simulated points, compares the value with a predefined acceptable threshold, and, if the threshold is breached, automatically notifies operators via the dashboard while logging the discrepancy for potential model refinement. Operators can then review the data and adjust the model parameters to improve accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Within the Digital Twin, an MQTT broker mediates signaling between services such as the Trajectory Generator Service, Simulation Service, and Continuous Validation Service. The document does not provide details on external network topology, bandwidth, latency, redundancy or security protocols for communication between the digital twin and the physical crane."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components are deployed on a single on‑premises computer located in the laboratory. The core services (TimescaleDB, MQTT Broker, and Grafana Dashboard) are containerized using Docker, enabling isolated and reproducible environments. The Control Application, Physical Crane Interface, Logging Application, Trajectory Generator Service, Simulation Service, and Continuous Validation Service run as native Python processes or dockerized containers on the same machine. This edge deployment eliminates cloud dependencies, ensures low‑latency communication, and satisfies the requirement for an on‑premises, single‑site deployment model. No virtualization beyond Docker containers is described, and the system is not designed for multi‑site or cloud‑based scaling in the provided documentation."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "All data exchange occurs internally via MQTT (or ActiveMQ) with no described integration to external enterprise systems or other digital twins. The twin does not use standard interoperability protocols such as OPC‑UA or AutomationML for external communication."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplar adopts the C4 Model to document system architecture—context, container, component, and dynamic diagrams are prepared to illustrate the relationships between the green‑house hardware, sensors, Twin services, the InfluxDB backend, and the ActiveMQ broker. The digital twin itself is structured using AutomationML, a recognized industry specification for modeling mechanical and electromechanical systems, which facilitates interoperability with other Engineering design tools. The data layer utilizes InfluxDB, which follows the open‑source line protocol and Grafana capabilities, ensuring compatibility with a broad ecosystem of monitoring solutions. Communication between the physical system (Raspberry‑Pi or greenhouse controllers) and the twin services uses a standard message broker, ActiveMQ, which supports MQTT‑style topics, thereby aligning with common IoT messaging protocols. No proprietary or non‑standard compliance frameworks are explicitly referenced in the documentation."
]