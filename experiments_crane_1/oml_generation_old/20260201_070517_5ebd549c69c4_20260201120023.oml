// Component instances
instance GantryCrane : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane with a steel frame, linear rails, hoist motor, and digital controller, providing translation along x‑axis and rotation about z‑axis."
]
instance SteelFrame : DTDFVocab:Component [
    base:desc "Steel structural frame of the gantry crane."
]
instance LinearRails : DTDFVocab:Component [
    base:desc "Precision linear rails enabling horizontal motion of the crane."
]
instance HoistMotor : DTDFVocab:Component [
    base:desc "Motor responsible for vertical load lifting in the crane."
]
instance DigitalController : DTDFVocab:Component [
    base:desc "Digital controller managing the crane’s actuator commands."
]
instance LabEnvironment : DTDFVocab:Environment [
    base:contains GantryCrane
]

// Sensing components
instance PositionTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Telemetry sensor providing real‑time position data from the crane controller."
    DTDFVocab:producedData CraneTelemetryPositionData
]
instance VelocityTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Telemetry sensor providing real‑time velocity data from the crane controller."
    DTDFVocab:producedData CraneTelemetryVelocityData
]
instance LoadTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Telemetry sensor providing real‑time load (current lifted weight) data from the crane controller."
    DTDFVocab:producedData CraneTelemetryLoadData
]
instance StatusFlagTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Telemetry sensor providing real‑time status flag data (e.g., fault, limit switch) from the crane controller."
    DTDFVocab:producedData CraneTelemetryStatusData
]
instance TemperaturePiSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry‑Pi embedded temperature sensor monitoring indoor air quality."
    DTDFVocab:producedData LabTemperatureData
]
instance HumidityPiSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry‑Pi embedded humidity sensor monitoring indoor air quality."
    DTDFVocab:producedData LabHumidityData
]
instance CO2PiSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry‑Pi embedded CO₂ sensor monitoring indoor air quality."
    DTDFVocab:producedData LabCO2Data
]

// Data transmitted instances
instance CraneTelemetryPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionTelemetrySensor
]
instance CraneTelemetryVelocityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocityTelemetrySensor
]
instance CraneTelemetryLoadData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadTelemetrySensor
]
instance CraneTelemetryStatusData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StatusFlagTelemetrySensor
]
instance LabTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperaturePiSensor
]
instance LabHumidityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumidityPiSensor
]
instance LabCO2Data : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2PiSensor
]

// Data instances
instance CraneTelemetryTimeseries : DTDFVocab:Data [
    base:desc "High‑resolution time‑stamped telemetry stream of position, velocity, load, and status flags."
    DTDFVocab:inputTo TimescaleDBLoggingEnabler
    DTDFVocab:fromData CraneTelemetryPositionData, CraneTelemetryVelocityData, CraneTelemetryLoadData, CraneTelemetryStatusData
]
instance LabAirQualityTimeseries : DTDFVocab:Data [
    base:desc "Time‑stamped measurements of temperature, humidity, and CO₂ levels for indoor air quality monitoring."
    DTDFVocab:inputTo AzureAnalyticsEnabler
    DTDFVocab:fromData LabTemperatureData, LabHumidityData, LabCO2Data
]

// Enablers
instance TimescaleDBLoggingEnabler : DTDFVocab:Enabler [
    base:desc "Logs crane telemetry directly into a TimescaleDB database via a TCP/IP socket from Python interface."
    DTDFVocab:enables HistoricalDataLoggingService
]
instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Feeds live telemetry to the kinematic validation engine for continuous model agreement checking."
    DTDFVocab:enables ContinuousValidationService
]
instance MotionPlanningEnabler : DTDFVocab:Enabler [
    base:desc "Provides telemetry and kinematic model data to the motion planning engine for optimal trajectories."
    DTDFVocab:enables MotionPlanningService
]
instance ControlCommandExecutionEnabler : DTDFVocab:Enabler [
    base:desc "Sends refined control commands generated by the twin back to the physical crane controller."
    DTDFVocab:enables ControlCommandExecutionService
]
instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Supplies real‑time crane state and planned trajectories to the 3‑D visualization system."
    DTDFVocab:enables RealTimeVisualizationService
]
instance AzureAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Ingests room‑environment telemetry into Azure for predictive analytics and scenario forecasting."
    DTDFVocab:enables AirQualityAnalyticsService
]

// Services
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Stores continuous crane telemetry for post‑hoc analysis."
    DTDFVocab:provides HistoricalDataLoggingInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares live sensor data against the kinematic model and flags deviations."
    DTDFVocab:provides ValidationInsight, ValidationAction
]
instance MotionPlanningService : DTDFVocab:Service [
    base:desc "Calculates motion‑planning trajectories that respect actuator limits while accelerating motion."
    DTDFVocab:provides MotionOptimizationInsight, MotionPlanAction
]
instance ControlCommandExecutionService : DTDFVocab:Service [
    base:desc "Executes refined control instructions on the physical crane to enhance performance."
    DTDFVocab:provides ControlExecutionInsight, ControlExecutionAction
]
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Displays real‑time 3‑D visualization of the crane state and planned trajectory."
    DTDFVocab:provides VisualizationInsight
]
instance AirQualityAnalyticsService : DTDFVocab:Service [
    base:desc "Performs predictive analytics on indoor air quality data for virus‑spreading scenarios."
    DTDFVocab:provides AirQualityForecastInsight, AirQualityControlAction
]

// Insights
instance HistoricalDataLoggingInsight : DTDFVocab:Insight [
    base:desc "Provides logged telemetry history for analysis."
]
instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Highlights model‑sensor discrepancies in real time."
]
instance MotionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommends optimized motion trajectories."
]
instance ControlExecutionInsight : DTDFVocab:Insight [
    base:desc "Validates execution of refined control commands."
]
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Shows real‑time 3‑D crane state."
]
instance AirQualityForecastInsight : DTDFVocab:Insight [
    base:desc "Predicts indoor air quality trends for virus spread mitigation."
]

// Actions
instance ValidationAction : DTDFVocab:Action [
    base:desc "Triggers fault handling when model deviation exceeds thresholds."
    DTDFVocab:IsAutomatic true
]
instance MotionPlanAction : DTDFVocab:Action [
    base:desc "Generates trajectory commands for the crane."
    DTDFVocab:IsAutomatic true
]
instance ControlExecutionAction : DTDFVocab:Action [
    base:desc "Sends refined control commands to the crane controller."
    DTDFVocab:IsAutomatic true
]
instance AirQualityControlAction : DTDFVocab:Action [
    base:desc "Adjusts environmental conditions based on forecasted air quality."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are issued by the Control Application, a Python component that consumes trajectory data from the Trajectory Generator Service. The Control Application uses the Physical Crane Interface to translate high‑level trajectory commands (target positions, speeds, and accelerations) into concrete controller instructions sent over a TCP/IP socket to the crane’s low‑level controllers. The documents do not describe explicit authentication or encryption, but the execution of a command is confirmed indirectly through the Logging Application’s continuous state capture, which stores the resulting physical state in TimescaleDB – the state is then visualised in the Grafana dashboard and compared by the Continuous Validation Service."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin relies on an MQTT broker to mediate inter‑service signalling between the Trajectory Generator, Simulation, Validation services, and the Dashboard. The broker operates over the standard MQTT protocol (TCP/IP, default port 1883) and is configured to publish trajectory events, state updates, and validation thresholds, while services subscribe to relevant topics. No additional security mechanisms such as TLS or username/password authentication are detailed in the documents, nor are bandwidth or latency requirements specified."
]