// ===== Sensing Components (Physical Sensing) =====
instance RaspberryPiTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor on the Raspberry Pi sensor stack."
    DTDFVocab:producedData RaspberryPiTemperatureTelemetry
]

instance RaspberryPiHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor on the Raspberry Pi sensor stack."
    DTDFVocab:producedData RaspberryPiHumidityTelemetry
]

instance RaspberryPiCO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ concentration sensor on the Raspberry Pi sensor stack."
    DTDFVocab:producedData RaspberryPiCO2Telemetry
]

instance RaspberryPiParticulateSensor : DTDFVocab:SensingComponent [
    base:desc "Particulate matter sensor on the Raspberry Pi sensor stack."
    DTDFVocab:producedData RaspberryPiParticulateTelemetry
]

instance GantryPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring gantry longitudinal position."
    DTDFVocab:producedData GantryPositionTelemetry
]

instance LoadMassSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring payload mass on the crane."
    DTDFVocab:producedData LoadMassTelemetry
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor electrical currents."
    DTDFVocab:producedData MotorCurrentTelemetry
]

instance SafetyFlagSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor detecting safety flag states from the crane controller."
    DTDFVocab:producedData SafetyFlagTelemetry
]

// ===== Data Transmitted (Physical‑to‑Virtual) =====
instance RaspberryPiTemperatureTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RaspberryPiTemperatureSensor
]

instance RaspberryPiHumidityTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RaspberryPiHumiditySensor
]

instance RaspberryPiCO2Telemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RaspberryPiCO2Sensor
]

instance RaspberryPiParticulateTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RaspberryPiParticulateSensor
]

instance GantryPositionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GantryPositionSensor
]

instance LoadMassTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadMassSensor
]

instance MotorCurrentTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance SafetyFlagTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SafetyFlagSensor
]

// ===== Data (Virtual) =====
instance RaspberryPiTemperatureData : DTDFVocab:Data [
    base:desc "Recorded internal temperature data from Raspberry Pi sensor stack."
    DTDFVocab:fromData RaspberryPiTemperatureTelemetry
    DTDFVocab:inputTo AzureIoTDataEnabler
]

instance RaspberryPiHumidityData : DTDFVocab:Data [
    base:desc "Recorded relative humidity data from Raspberry Pi sensor stack."
    DTDFVocab:fromData RaspberryPiHumidityTelemetry
    DTDFVocab:inputTo AzureIoTDataEnabler
]

instance RaspberryPiCO2Data : DTDFVocab:Data [
    base:desc "Recorded CO₂ concentration data from Raspberry Pi sensor stack."
    DTDFVocab:fromData RaspberryPiCO2Telemetry
    DTDFVocab:inputTo AzureIoTDataEnabler
]

instance RaspberryPiParticulateData : DTDFVocab:Data [
    base:desc "Recorded particulate matter concentration data from Raspberry Pi sensor stack."
    DTDFVocab:fromData RaspberryPiParticulateTelemetry
    DTDFVocab:inputTo AzureIoTDataEnabler
]

instance GantryPositionData : DTDFVocab:Data [
    base:desc "Recorded gantry longitudinal position data streamed from the crane."
    DTDFVocab:fromData GantryPositionTelemetry
    DTDFVocab:inputTo CraneTelemetryEnabler
]

instance LoadMassData : DTDFVocab:Data [
    base:desc "Recorded payload mass data streamed from the crane."
    DTDFVocab:fromData LoadMassTelemetry
    DTDFVocab:inputTo CraneTelemetryEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Recorded motor current data streamed from the crane."
    DTDFVocab:fromData MotorCurrentTelemetry
    DTDFVocab:inputTo CraneTelemetryEnabler
]

instance SafetyFlagData : DTDFVocab:Data [
    base:desc "Recorded safety flag status data streamed from the crane."
    DTDFVocab:fromData SafetyFlagTelemetry
    DTDFVocab:inputTo CraneTelemetryEnabler
]

// ===== Models =====
instance GantryKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model capturing the crane's motion constraints."
    DTDFVocab:inputTo KinematicModelEnabler
]

instance GantryCADModel : DTDFVocab:Model [
    base:desc "3D CAD model of the lab‑scale gantry crane."
    DTDFVocab:inputTo CADModelEnabler
]

// ===== Enablers (Technical Enablement) =====
instance AzureIoTDataEnabler : DTDFVocab:Enabler [
    base:desc "Enabler interfacing with Azure IoT Hub to ingest air‑quality sensor data."
    DTDFVocab:enables AirQualityRealTimeMonitoringService, AirQualityPredictiveAnalyticsService
]

instance CraneTelemetryEnabler : DTDFVocab:Enabler [
    base:desc "Enabler logging crane telemetry to TimescaleDB and feeding monitoring services."
    DTDFVocab:enables CraneRealTimeMonitoringService, HistoricalDataLoggingService, ContinuousValidationService
]

instance ControlCommandEnabler : DTDFVocab:Enabler [
    base:desc "Enabler transmitting control commands to the crane's electronic controller."
    DTDFVocab:enables OptimalControlGenerationService
]

instance VisualizationWebDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Enabler serving real‑time visualisation of crane state and CAD model on a web dashboard."
    DTDFVocab:enables DataVisualizationService
]

instance KinematicModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler feeding the kinematic model to the control generation service."
    DTDFVocab:enables OptimalControlGenerationService
]

instance CADModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler delivering the CAD model to the visualization service."
    DTDFVocab:enables DataVisualizationService
]

// ===== Services =====
instance AirQualityRealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Streams real‑time indoor air‑quality metrics to operators."
    DTDFVocab:provides AirQualityMetricsInsight
]

instance AirQualityPredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Generates predictive analytics for future air‑quality trends to inform virus‑spreading risk mitigation."
    DTDFVocab:provides FutureAirQualityTrendInsight
]

instance CraneRealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Streams real‑time kinematic state and controller status of the gantry crane."
    DTDFVocab:provides CranePoseInsight
]

instance OptimalControlGenerationService : DTDFVocab:Service [
    base:desc "Computes optimal motor commands to follow desired crane paths."
    DTDFVocab:provides GenerateControlCommandAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Records sensor streams and actuator actions for historical analysis."
    DTDFVocab:provides HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Displays interactive dashboards that show crane pose alongside its CAD model."
    DTDFVocab:provides DisplayDashboardAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares digital model predictions against live measurements to detect drift or anomalies."
    DTDFVocab:provides ValidationAnomalyInsight
]

// ===== Insights =====
instance AirQualityMetricsInsight : DTDFVocab:Insight [
    base:desc "Insight into current indoor air‑quality metrics for operator awareness."
]

instance FutureAirQualityTrendInsight : DTDFVocab:Insight [
    base:desc "Insight into predicted future air‑quality trends for risk mitigation."
]

instance CranePoseInsight : DTDFVocab:Insight [
    base:desc "Insight into the real‑time pose of the gantry crane."
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing recorded sensor streams and control actions."
]

instance ValidationAnomalyInsight : DTDFVocab:Insight [
    base:desc "Insight identifying anomalies between digital twin predictions and live measurements."
]

// ===== Actions =====
instance GenerateControlCommandAction : DTDFVocab:Action [
    base:desc "Automatically generated motor command to follow desired crane path."
    DTDFVocab:IsAutomatic true
]

instance DisplayDashboardAction : DTDFVocab:Action [
    base:desc "Operator notification action to refresh the visual dashboard."
    DTDFVocab:IsAutomatic false
]

// ===== Components =====
instance GantryFrameComponent : DTDFVocab:Component [
    base:desc "Mechanical gantry frame providing support structure."
]

instance TrolleyComponent : DTDFVocab:Component [
    base:desc "Trolley carriage enabling horizontal motion."
]

instance HoistComponent : DTDFVocab:Component [
    base:desc "Hoist mechanism supporting vertical payload movement."
]

instance ControllerComponent : DTDFVocab:Component [
    base:desc "Electronic controller driving all crane axes."
]

// ===== Environment =====
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains GantryFrameComponent, TrolleyComponent, HoistComponent, ControllerComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, implemented in Python, issues high‑level motion commands (desired gantry coordinates, thrust setpoints, and safety limits) to the Physical Crane Interface, which in turn converts them into controller‑specific messages and sends them over the same TCP connection used for telemetry. Validation of commands is performed within the interface by basic sanity checks; feedback on command execution is provided only indirectly by the Logging Application, which records the resulting crane state after each command. The document does not specify explicit authentication, conflict resolution strategies, or confirmation protocols."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Gantry Crane digital twin orchestrates its services through an MQTT-based publish/subscribe layer using Eclipse Mosquitto, which transports sensor telemetry and control messages between physical actuators and the digital twin services. Sensor data are ingested and persisted in a TimescaleDB instance – the time‑series extension of PostgreSQL – enabling efficient storage, high‑frequency ingestion, and query of position, velocity, load, and environmental metrics. Monitoring and visualization are provided by Grafana dashboards that query TimescaleDB to display real‑time plots of crane dynamics and status. The complete software stack can be deployed on a single personal computer or distributed across Docker containers, supporting rapid iteration, reproducible builds, and easy scalability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Internal services of the digital twin communicate primarily via an MQTT broker, which handles signalling between the Trajectory Generator Service, Simulation Service, Continuous Validation Service, and the Dashboard. Communications between services are therefore carried over MQTT (TLS‑enabled TCP by default on port 1883), while the TimescaleDB database is accessed over standard PostgreSQL TCP (port 5432). The architecture follows a container‑based model as described by the C4 diagram, implying a local network topology with service containers interacting over the same LAN. The document does not detail bandwidth, latency, or redundancy mechanisms for the network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar adopts AutomationML as its digital twin modelling language, and relies on Microsoft Azure cloud services for data ingestion, analytics and storage, aligning with common industry practices for secure cloud deployment.  The GreenhouseDT exemplar uses InfluxDB for time‑series data storage and ActiveMQ as the message broker; both are standard open‑source solutions widely used in industrial IoT contexts.  No specific external certification, ISO standard, or formal compliance framework is mentioned in the documents."
]