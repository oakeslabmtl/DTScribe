// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures angular deviation of suspended load (container puck) during motion with high spatial resolution. Sampling frequency inferred to be real-time (≥10Hz) for stability control."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Measures wind speed/direction near crane's operational area with industrial-grade accuracy (±0.1 m/s). Data transmitted via wireless/serial interfaces."
    DTDFVocab:producedData WindDataTransmitted
]

instance LoadCell : DTDFVocab:SensingComponent [
    base:desc "Monitors weight of suspended load (container puck) with high precision. Data integrated into Continuous Validation Service for trajectory validation."
    DTDFVocab:producedData LoadDataTransmitted
]

instance LimitSwitch : DTDFVocab:SensingComponent [
    base:desc "Detects end-of-travel positions for crane's horizontal and vertical movements. Provides binary state signals for safety constraints."
    DTDFVocab:producedData LimitSwitchDataTransmitted
]

// C4: Data Transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance LoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadCell
]

instance LimitSwitchDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LimitSwitch
]

instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder, LoadCell, LimitSwitch
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "Represents forward/inverse kinematics of gantry crane including bridge, hoist, and load dynamics. Used for trajectory generation and simulation."
    DTDFVocab:inputTo PythonControllerEnabler, GrafanaVisualizationEnabler
]

instance CADModel : DTDFVocab:Model [
    base:desc "3D representation of gantry crane structure created in Autodesk Fusion 360. Serves as reference for physical-to-digital alignment."
    DTDFVocab:inputTo GrafanaVisualizationEnabler
]

instance CraneStateData : DTDFVocab:Data [
    base:desc "Aggregated real-time data including position, velocity, acceleration, and load measurements from all sensing components."
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, GrafanaVisualizationEnabler
]

instance HistoricalCraneData : DTDFVocab:Data [
    base:desc "Time-series operational data stored for long-term trend analysis and performance benchmarking."
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers
instance PythonControllerEnabler : DTDFVocab:Enabler [
    base:desc "Python-based implementation of control logic, kinematic models, and service execution. Runs on personal computer interfaced with Arduino microcontroller."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database extension for PostgreSQL storing operational metrics with millisecond precision for historical logging."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance GrafanaVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Real-time and historical data dashboard platform connected to TimescaleDB for interactive system behavior exploration."
    DTDFVocab:enables DataVisualizationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Lightweight publish-subscribe protocol for bidirectional data streaming between physical and digital systems with low latency."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

instance DockerContainerizationEnabler : DTDFVocab:Enabler [
    base:desc "Containerization platform for packaging and deploying services in reproducible environments using Docker."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, DataVisualizationService
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes optimal paths for container movement using kinematic constraints and real-time sensor feedback."
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Executes physics-based simulations of crane operations using kinematic model to predict behavior under varying conditions."
    DTDFVocab:provides PredictedCraneBehaviorInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares real-time measurements with simulated trajectories using distance metrics to quantify discrepancies and detect faults."
    DTDFVocab:provides ValidationResultInsight, CorrectiveAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Stores operational data in TimescaleDB for post-processing, trend analysis, and performance benchmarking."
    DTDFVocab:provides HistoricalTrendInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Provides real-time and historical visualization of crane states including 3D CAD overlays and time-series plots."
    DTDFVocab:provides VisualizedSystemStateInsight
]

// C2: Acting Components
instance CartMotor : DTDFVocab:ActingComponent [
    base:desc "Propels crane horizontally along gantry beam with closed-loop control for precise positioning. Actuation range constrained by track length."
]

instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Vertically lifts/lowers load via cable-and-pulley system with current/position limits for safety. Implements closed-loop control for dynamic load handling."
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Picks up/drops container pucks via electromagnetic adhesion with timeout-based release for safety. Actuation range limited by crane's reachable volume."
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Computed optimal path for container movement considering kinematic constraints and real-time environmental conditions."
]

instance PredictedCraneBehaviorInsight : DTDFVocab:Insight [
    base:desc "Simulated crane behavior under varying conditions including load dynamics and environmental factors."
]

instance ValidationResultInsight : DTDFVocab:Insight [
    base:desc "Quantitative comparison between executed and simulated trajectories using distance metrics to assess digital twin accuracy."
]

instance HistoricalTrendInsight : DTDFVocab:Insight [
    base:desc "Long-term performance trends and operational patterns extracted from historical crane data."
]

instance VisualizedSystemStateInsight : DTDFVocab:Insight [
    base:desc "Interactive visualization of crane states including real-time sensor data and simulated trajectories."
]

instance CorrectiveAction : DTDFVocab:Action [
    base:desc "Automated notification to operators when validation metrics exceed predefined thresholds, suggesting potential system faults."
    DTDFVocab:IsAutomatic true
]

// C1: System Components
instance GantryCraneMechanicalStructure : DTDFVocab:Component [
    base:desc "Scaled-down mechanical structure including movable bridge, hoist, and container puck system for simulating industrial crane operations."
]

instance ArduinoMicrocontroller : DTDFVocab:Component [
    base:desc "Embedded microcontroller interfacing between Python controller and physical actuators/sensors for real-time data acquisition and actuation."
]

instance PersonalComputerController : DTDFVocab:Component [
    base:desc "Host system running Python-based control application with kinematic and dynamic models for crane operation."
]

instance TimescaleDatabase : DTDFVocab:Component [
    base:desc "PostgreSQL extension specialized for time-series data storage of crane operational metrics."
]

instance GrafanaDashboard : DTDFVocab:Component [
    base:desc "Web-based visualization platform displaying real-time and historical crane states with interactive controls."
]

// C7: Environments
instance CraneControlEnvironment : DTDFVocab:Environment [
    base:desc "Physical operational environment for lab-scale gantry crane including mechanical structure, sensors, and actuators."
    base:contains GantryCraneMechanicalStructure, CartMotor, HoistMotor, Electromagnet,
                 SwingAngleEncoder, Anemometer, LoadCell, LimitSwitch
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:desc "Virtual environment hosting all digital twin services and models."
    base:contains PersonalComputerController, ArduinoMicrocontroller, TimescaleDatabase,
                 GrafanaDashboard, KinematicModel, CADModel
]

instance ServiceExecutionEnvironment : DTDFVocab:Environment [
    base:desc "Containerized execution environment for digital twin services using Docker."
    base:contains DockerContainerizationEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the **Control Application** and **Human Machine Interface (HMI)**, which interact with the **Physical Crane Interface** (a Python program connecting to crane controllers). The **Trajectory Generator Service** generates optimal trajectories (e.g., swing-free movements) and likely feeds these into the Control Application for execution. The **Continuous Validation Service** compares **executed trajectories** (measured data) with **simulated trajectories** post-execution but does not validate control messages in real-time. No details are provided on command types, message formats, validation/authentication mechanisms, feedback systems, conflict resolution, or command execution confirmation. The **MQTT Broker** facilitates signaling between services but is not explicitly used for control command transmission."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system exhibits a dual temporal paradigm: **GreenhouseDT** operates with **prerecorded data** in virtual machines, enabling offline analysis and simulation without real-time synchronization. In contrast, the **Air Quality Management** exemplar supports **runtime visualization**, **simulation**, and **prediction**, implying real-time or near-real-time data processing for indoor air quality monitoring. The **Gantry Crane** system, while not explicitly detailed in temporal granularity, aligns with continuous operational demands, as it requires **real-time status updates** and likely **low-latency coordination** for container movement. No explicit synchronization frequencies (e.g., Hz) or latency requirements are specified, but the distinction between **offline (GreenhouseDT)** and **real-time (Air Quality Management/Gantry Crane)** operations is clear. The Air Quality exemplar’s use of **Microsoft Azure tools** suggests cloud-based processing, which may introduce variable latency depending on service tiers, while GreenhouseDT’s **InfluxDB** and **ActiveMQ** imply event-driven or batch-oriented synchronization mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin systems in the documents adopt a **lightweight, ad-hoc orchestration approach** without relying on commercial digital twin frameworks. The **GreenhouseDT** exemplar uses **InfluxDB** (a time-series database) and **ActiveMQ** (a message broker) for **event-driven coordination** between physical and digital components, enabling behavioral adaptation. The **Air Quality Management** exemplar employs **AutomationML** for digital twin modeling and **Microsoft Azure tools** for pipeline implementation, suggesting a **hybrid orchestration** combining **model-driven engineering** and **cloud-based services**. The **gantry crane system** (logistics/cyber-physical domain) follows similar design choices, such as **containerization or virtualization**, to facilitate dissemination but lacks explicit details on system-wide coordination. All exemplars emphasize **modularity** and **easy dissemination** via **virtual machines or containers**, with no centralized orchestration layer."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The **Lab Scale Gantry Crane** Digital Twin enforces **fidelity** through:
  1. **Continuous Validation Service**: Operates in **real-time**, comparing **executed trajectories** (from encoders/motors) with **simulated trajectories** (from the kinematic model). **Distance metrics** (e.g., Euclidean error) quantify deviations, triggering **corrective actions** if thresholds are exceeded.
  2. **Uncertainty Sources**: Primarily stem from **sensor noise** (e.g., encoder quantization), **model approximations** (e.g., simplified kinematics), and **external disturbances** (e.g., wind). Quantification is implicit via **distance metrics** but lacks explicit statistical analysis.
  3. **Quality Assurance**: Relies on **closed-loop validation**—discrepancies between physical and digital states prompt **adaptive adjustments** (e.g., recalibrating motor controllers). No formal **verification/validation (V&V) protocols** (e.g., ISO 15926) are mentioned, but the **Continuous Validation Service** serves as an **embedded QA mechanism**. The system’s **ad-hoc architecture** prioritizes **practical robustness** over standardized compliance."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **Digital Twin** system employs a **service-oriented architecture** with containers communicating via an **MQTT Broker** for lightweight, event-driven signaling. The network topology is centralized, with the **Database (TimescaleDB)** as the primary data store and **Grafana Dashboard** for visualization. Communication protocols include **MQTT** for inter-service messaging (e.g., **Logging Application** → **MQTT Broker** → **Dashboard**) and unspecified protocols for **Physical Crane Interface** ↔ **Control Application** (likely TCP/IP or serial). Bandwidth/latency requirements are not quantified, but the **Continuous Validation Service** implies low-latency comparisons between executed and simulated trajectories. Redundancy mechanisms are not described, but the **MQTT Broker** ensures reliable message delivery between services. Security protocols are unspecified, though the **TimescaleDB** database likely enforces access controls for data integrity."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **Digital Twin** is deployed on-premise alongside the **Physical Crane**, with no explicit cloud/edge distinction. Computational requirements are distributed across six containers: **Database (TimescaleDB)** for time-series storage, **Trajectory Generator Service** (kinematics-based optimization), **Simulation Service** (physics-based modeling), and **Continuous Validation Service** (real-time trajectory comparison). Storage scales with logged data (e.g., crane state metrics, trajectory logs), but no auto-scaling mechanisms are mentioned. The deployment model is **monolithic for the Physical Crane** (hardware + interface) and **microservices-based for the Digital Twin** (containerized services). Availability/reliability is assured by the **Logging Application**’s continuous data capture and the **Dashboard**’s real-time alerts, though no fault-tolerance protocols (e.g., backups, failovers) are specified."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin systems demonstrate **limited horizontal integration** with external systems, relying on **ad-hoc or domain-specific protocols**. The **GreenhouseDT** exemplar integrates with **InfluxDB** (for data storage) and **ActiveMQ** (for messaging), but no interoperability standards (e.g., OPC UA, MQTT) or enterprise system dependencies are mentioned. The **Air Quality Management** exemplar uses **AutomationML** for digital twin modeling and **Microsoft Azure tools**, implying potential integration with **cloud-based analytics or enterprise systems**, but no explicit protocols or standards are detailed. The **gantry crane system** (logistics domain) lacks specific integration details, though the use of **C4 Model** suggests modular software architecture. None of the exemplars explicitly describe **cross-Digital Twin coordination** or **enterprise system dependencies** beyond their immediate technical stacks."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The **Air Quality Management** exemplar adheres to **AutomationML** for digital twin modeling, a **standardized engineering format** for automation and control systems, ensuring **interoperability** with other tools in the pipeline. The **GreenhouseDT** exemplar uses **InfluxDB** (a time-series database standard) and **ActiveMQ** (a message broker protocol) for data exchange, though these are not domain-specific standards. The **gantry crane system** employs the **C4 Model** for architecture documentation, which is a **software architecture standard** but not a digital twin-specific one. **Certification requirements** or **compliance frameworks** (e.g., ISO, IEC) are not mentioned. The **ad-hoc approaches** in all exemplars suggest **limited adherence to commercial digital twin frameworks**, prioritizing **domain-specific customization** over standardized compliance."
]