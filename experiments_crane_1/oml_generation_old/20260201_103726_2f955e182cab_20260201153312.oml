    DTDFVocab:inputTo InfluxDBTimeSeriesEnabler
]

instance TimescaleDBGantryCraneData : DTDFVocab:Data [
    base:desc "Time-series data of crane state metrics (position, velocity, acceleration, controller signals, operational status) stored in TimescaleDB for real-time synchronization."
    DTDFVocab:fromData CranePositionDataTransmitted, CraneVelocityDataTransmitted, CraneForceTorqueDataTransmitted, CraneOrientationDataTransmitted, CraneControllerSignalDataTransmitted, CraneStatusDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

