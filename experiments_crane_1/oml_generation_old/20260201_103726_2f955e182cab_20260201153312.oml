// C10: Models/Data
instance AutomationMLAirQualityModel : DTDFVocab:Model [
    base:desc "AutomationML-based digital twin model for air quality management integrating structured model-driven engineering principles for simulation, prediction, and runtime visualization."
    DTDFVocab:inputTo AzureCloudPipelineEnabler, AutomationMLSimulationEnabler
]

instance GreenhouseBehavioralAdaptationModel : DTDFVocab:Model [
    base:desc "Behavioral adaptation model for greenhouse digital twin enabling dynamic real-time adjustments in both physical and digital representations."
    DTDFVocab:inputTo VirtualMachineImageEnabler, InfluxDBTimeSeriesEnabler
]

instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "CAD-derived kinematic model of the gantry crane including forward/inverse kinematics equations for degrees of freedom with continuous validation against physical measurements."
    DTDFVocab:inputTo MATLABSymbolicMathEnabler, ROSRealTimeCommunicationEnabler
]

instance GantryCraneControlAlgorithmModel : DTDFVocab:Model [
    base:desc "Control algorithm model for optimal trajectory planning and closed-loop control optimization of the gantry crane system."
    DTDFVocab:inputTo MATLABSimulinkEnabler, ROSControlNodeEnabler
]

