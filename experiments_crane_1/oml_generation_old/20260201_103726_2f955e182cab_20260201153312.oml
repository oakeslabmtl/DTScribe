    base:desc "Historical or simulated sensor inputs embedded within virtual machine images for initialization of the GreenhouseDT exemplar."
    DTDFVocab:fromData GreenhouseSensorDataTransmitted
    DTDFVocab:inputTo VirtualMachineImageEnabler
]

