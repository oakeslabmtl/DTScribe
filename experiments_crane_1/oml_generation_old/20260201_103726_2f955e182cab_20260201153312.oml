instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Controlled laboratory environment for the lab-scale gantry crane system with predefined workspace boundaries and safety mechanisms."
    base:contains GantryCranePhysicalComponent, CraneControllerComponent
]

instance GantryCranePhysicalComponent : DTDFVocab:Component [
    base:desc "Mechanically actuated gantry crane with kinematic constraints including linear motion along rails and payload suspension via hoist mechanism."
]

instance CraneControllerComponent : DTDFVocab:Component [
    base:desc "Embedded or external control hardware/software interfacing with crane actuators to execute trajectories or user commands."
]

instance AirQualityManagementEnvironment : DTDFVocab:Environment [
    base:desc "Indoor environment monitored by Raspberry Pi sensors for air quality management with virus spread prevention focus."
    base:contains RaspberryPiAirQualitySensor
]

