// ====================
// C3: Physical sensing components
// ====================

instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor exposing the current crane position via the controller"
    DTDFVocab:producedData PositionDataTransmitted
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Velocity sensor exposing the current crane velocity via the controller"
    DTDFVocab:producedData VelocityDataTransmitted
]

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring the crane swing angle"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed affecting crane motion"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor exposing motor controller status flags"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

// ====================
// C4: DataTransmitted (from sensors)
// ====================

instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySensor
]

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

// ====================
// C10: Data (stored in TimescaleDB)
// ====================

instance PositionData : DTDFVocab:Data [
    base:desc "Time‑series of crane position measurements"
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance VelocityData : DTDFVocab:Data [
    base:desc "Time‑series of crane velocity measurements"
    DTDFVocab:fromData VelocityDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Time‑series of motor controller status flags"
    DTDFVocab:fromData MotorStatusDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// ====================
// C11: Enablers (infrastructure)
// ====================

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database storing all logged crane state"
    DTDFVocab:enables LoggingService, ContinuousValidationService, GrafanaDashboardService
]

instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker routing signalling between all twin services"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, LoggingService
]

instance TrajectoryEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime executing the Trajectory Generator algorithm"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime executing the crane behavioural simulation model"
    DTDFVocab:enables SimulationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler supplying CAD visualisation assets to the Grafana dashboard"
    DTDFVocab:enables GrafanaDashboardService
]

// ====================
// C6: Services
// ====================

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates swing‑free optimal motion plans using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Emulates crane dynamics and controller behaviour for 'what‑if' analysis"
    DTDFVocab:provides PredictedTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares logged sensor data with simulated trajectories, computes distance metrics and raises alerts"
    DTDFVocab:provides ValidationAlertInsight
]

instance LoggingService : DTDFVocab:Service [
    base:desc "Records all incoming crane state data into TimescaleDB"
    DTDFVocab:provides DataLoggingInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Visualises trajectories, validation results and operator alerts via Grafana"
    DTDFVocab:provides VisualizationInsight
]

// ====================
// C17: Insights
// ====================

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Prescriptive insight: swing‑free optimal motion plans displayed on the dashboard"
]

instance PredictedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Predictive insight: simulated sensor traces for generated trajectories"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Diagnostic insight: alerts when measured vs. simulated distance exceeds configurable threshold"
]

instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Historical insight: persistent record of all crane state variables"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual insight: dashboards with trajectory monitoring, confidence bands and alerts"
]

// ====================
// C17: Actions
// ====================

instance ReplanAction : DTDFVocab:Action [
    base:desc "Operator re‑plans trajectory via the Python front‑end when validation alerts occur"
    DTDFVocab:IsAutomatic false
]

instance HaltCraneAction : DTDFVocab:Action [
    base:desc "Operator halts crane motion through the control application"
    DTDFVocab:IsAutomatic false
]

// ====================
// C2: Acting Components
// ====================

instance MotorDriveActuator : DTDFVocab:ActingComponent [
    base:desc "Motorised drives of the gantry crane executing motion commands issued by the Control Application"
]

// ====================
// C5: Physical Components
// ====================

instance PhysicalCrane : DTDFVocab:Component [
    base:desc "Lab‑scale hydraulically driven gantry crane with swing‑angle encoder and anemometer"
]

instance ControlApplication : DTDFVocab:Component [
    base:desc "Python control application issuing motion, homing and zeroing commands via the Physical Crane Interface"
]

instance LoggingApplication : DTDFVocab:Component [
    base:desc "Python logging application receiving crane state from the Physical Crane Interface and forwarding it to TimescaleDB"
]

instance HumanMachineInterface : DTDFVocab:Component [
    base:desc "Web UI (Grafana) allowing operators to monitor trajectories, view validation alerts and issue re‑plan or halt actions"
]

// ====================
// C10: Models/Data
// ====================

instance KinematicModel : DTDFVocab:Model [
    base:desc "Analytical kinematic model used to compute swing‑free trajectories"
    DTDFVocab:inputTo TrajectoryEngineEnabler, SimulationEngineEnabler
]

instance BehavioralSimulationModel : DTDFVocab:Model [
    base:desc "Behavioural simulation model of crane dynamics and low‑level controller behaviour"
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance CADModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the gantry crane for visualisation"
    DTDFVocab:inputTo VisualizationEnabler
]

// ====================
// C9: Environment (optional aggregation)
// ====================

instance GantryCraneLabEnvironment : DTDFVocab:Environment [
    base:contains PhysicalCrane, MotorDriveActuator, ControlApplication, LoggingApplication, HumanMachineInterface,
                 MqttBrokerEnabler, TimescaleDBEnabler, VisualizationEnabler,
                 TrajectoryGeneratorService, SimulationService, ContinuousValidationService, LoggingService, GrafanaDashboardService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin provides control commands through several services. The Trajectory Generator Service uses a kinematic model of the crane to compute optimal movement trajectories that end with zero residual swing. These trajectory set‑points are sent to the Control Application, which uses the Physical Crane Interface (a Python program) to transmit the commands to the crane’s motor controllers. The Human Machine Interface (a Python front‑end) allows an operator to manually configure and trigger commands, which are likewise routed through the Control Application to the physical hardware. No explicit command message format, authentication, or conflict‑resolution mechanisms are described in the documents; confirmation of command execution is implied by the Logging Application’s continuous state logging."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a service‑oriented architecture orchestrated by Docker‑Compose. All six digital‑twin containers are launched together, sharing a Docker network. The MQTT broker provides publish/subscribe messaging that synchronises the Trajectory Generator, Simulation, and Continuous Validation services. The TimescaleDB stores time‑series data accessed by the Logging Application and Grafana for visualisation. Interaction between services occurs via MQTT messages and standard SQL queries to the database, constituting a loosely coupled yet centrally coordinated constellation of components."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The gantry‑crane digital twin follows a four‑stage lifecycle described in the papers: (1) Development – creation of CAD geometry and a kinematic model of the crane, packaged as Python modules; (2) Integration – the models are wrapped as services (Trajectory Generator, Simulation, Continuous Validation) and deployed together with supporting components (TimescaleDB, Grafana, MQTT broker) via a single Docker‑compose command; (3) Operation – the running services ingest real‑time state from the Physical Crane Interface, log data to TimescaleDB, generate optimal trajectories, simulate them and continuously validate measured vs simulated trajectories; (4) Evolution – the exemplar is reused in successive research projects (continuous‑validation methods, fault‑detection, DarTwin notation) where new services or model refinements are added and redeployed. Transition between stages is managed by the Docker‑compose orchestration; lifecycle governance is informal and relies on the open‑source GitHub repository for version control and documentation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by continuously validating measured trajectories against the simulation output. The Continuous Validation Service computes distance metrics between the real‑world execution and the simulated trajectory, compares them to a configurable threshold, and raises alerts via the Grafana dashboard if the deviation exceeds the limit. Validation thus detects model drift, sensor noise or controller faults. Uncertainty sources include measurement noise from the crane controllers and simplifications in the kinematic and simulation models. The threshold provides a quantitative bound on acceptable error, serving as a quality‑assurance mechanism for both models and data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin relies on an MQTT broker (Eclipse Mosquitto) that handles signalling between the Trajectory Generator, Simulation, Continuous Validation and other services. All services are packaged as Docker containers (Database, MQTT broker, Dashboard, and the Python services) and are orchestrated with a Docker‑compose file, creating a local container network (typically the default bridge network). The documents do not detail bandwidth, latency, or redundancy requirements, nor do they specify additional security protocols beyond the choice of an open‑source MQTT broker."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire system is deployed on a single personal computer (on‑premise). The physical‑side software runs as native Python processes, while the digital‑twin components (TimescaleDB, Grafana dashboard, and MQTT broker) are containerised with Docker. Deployment is automated via a Docker‑compose file that brings up the database, broker and dashboard with a single command and also performs first‑time initialization of the database and dashboard. The required infrastructure therefore includes a PC capable of running Docker and Python, sufficient storage for time‑series data in TimescaleDB, and modest compute resources for the simulation and validation services. Scalability is implied by the containerised architecture (additional instances could be started), but no explicit cloud or edge hosting, high‑availability, or redundancy mechanisms are described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External integration is realised through standard protocols: MQTT is used for inter‑service signalling, and the TimescaleDB (PostgreSQL‑compatible) is accessed via SQL by the Logging Application and Grafana dashboard. No explicit links to other enterprise systems or external digital twins are described, but the use of widely adopted protocols (MQTT, SQL) enables straightforward extension to outside systems that support these standards."
]