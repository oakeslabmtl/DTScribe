// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry‑Pi temperature sensor used in the Air Quality Management exemplar."
    DTDFVocab:producedData TemperatureDataTransmission
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry‑Pi humidity sensor used in the Air Quality Management exemplar."
    DTDFVocab:producedData HumidityDataTransmission
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry‑Pi CO₂ sensor used in the Air Quality Management exemplar."
    DTDFVocab:producedData CO2DataTransmission
]

instance ParticleSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry‑Pi particulate matter sensor used in the Air Quality Management exemplar."
    DTDFVocab:producedData ParticleDataTransmission
]

instance SoilMoistureSensor : DTDFVocab:SensingComponent [
    base:desc "Soil moisture sensor supplying data for the GreenhouseDT exemplar."
    DTDFVocab:producedData SoilMoistureDataTransmission
]

instance CraneStateSensor : DTDFVocab:SensingComponent [
    base:desc "Python based interface that reads crane state: position, velocity, currents, load weight and alarm flags."
    DTDFVocab:producedData CraneStateDataTransmission
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance TemperatureDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance CO2DataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance ParticleDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ParticleSensor
]

instance SoilMoistureDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SoilMoistureSensor
]

instance CraneStateDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneStateSensor
]

// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Validated kinematic model of the lab‑scale gantry crane used for simulation."
    DTDFVocab:inputTo AzureMachineLearningEnabler
]

instance AirQualityPredictionModel : DTDFVocab:Model [
    base:desc "AutomationML based model that predicts indoor air quality forecasts."
    DTDFVocab:inputTo AzureMachineLearningEnabler
]

instance VirusSpreadPredictionModel : DTDFVocab:Model [
    base:desc "Model that provides preventive scenarios for virus spread in indoor spaces."
    DTDFVocab:inputTo AzureMachineLearningEnabler
]

// C5: Data instances
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature measurement recorded from the Raspberry‑Pi sensor."
    DTDFVocab:fromData TemperatureDataTransmission
    DTDFVocab:inputTo InfluxDBEnabler
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity measurement recorded from the Raspberry‑Pi sensor."
    DTDFVocab:fromData HumidityDataTransmission
    DTDFVocab:inputTo InfluxDBEnabler
]

instance CO2Data : DTDFVocab:Data [
    base:desc "CO₂ concentration measurement recorded from the Raspberry‑Pi sensor."
    DTDFVocab:fromData CO2DataTransmission
    DTDFVocab:inputTo InfluxDBEnabler
]

instance ParticleData : DTDFVocab:Data [
    base:desc "Particulate matter level recorded from the Raspberry‑Pi sensor."
    DTDFVocab:fromData ParticleDataTransmission
    DTDFVocab:inputTo InfluxDBEnabler
]

instance SoilMoistureData : DTDFVocab:Data [
    base:desc "Soil moisture measurement supplied by the GreenhouseDT exemplar."
    DTDFVocab:fromData SoilMoistureDataTransmission
    DTDFVocab:inputTo InfluxDBEnabler
]

instance CraneTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data stream from the gantry crane including position, velocity, currents, load weight."
    DTDFVocab:fromData CraneStateDataTransmission
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers
instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database that stores greenhouse environmental sensor data."
    DTDFVocab:enables EnvironmentalMonitoringService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance that logs crane telemetry and other time‑seried data."
    DTDFVocab:enables CraneMonitoringService
]

instance ActiveMQEnabler : DTDFVocab:Enabler [
    base:desc "ActiveMQ message broker used to stream data to dashboards and other components."
    DTDFVocab:enables DashboardService
]

instance AzureMachineLearningEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that interfaces with Azure Machine Learning services for predictive analytics and model execution."
    DTDFVocab:enables AnalyticsService, OptimalControlAlgorithmService
]

// C6: Services
instance EnvironmentalMonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors greenhouse environmental data, performs anomaly detection, and feeds data to visualization."
    DTDFVocab:provides EnvironmentalAnomalyInsight, ClimateTrendInsight
]

instance CraneMonitoringService : DTDFVocab:Service [
    base:desc "Service that provides real‑time monitoring of crane state and health assessment."
    DTDFVocab:provides CraneHealthInsight, OperationStatusInsight
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Web‑based dashboard that visualizes real‑time sensor data, historical trends, and simulation results."
    DTDFVocab:provides RealTimeVisualizationInsight, HistoricalDataInsight
]

instance AnalyticsService : DTDFVocab:Service [
    base:desc "Service that performs predictive analytics for indoor air quality and virus‑spread prevention."
    DTDFVocab:provides AirQualityForecastInsight, VirusSpreadPreventionInsight
]

instance OptimalControlAlgorithmService : DTDFVocab:Service [
    base:desc "Service that generates control commands for the gantry crane based on kinematic model and real‑time telemetry."
    DTDFVocab:provides CraneControlCommandAction
]

// C17: Insights
instance EnvironmentalAnomalyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating anomalies in greenhouse temperature, humidity, or soil moisture."
]

instance ClimateTrendInsight : DTDFVocab:Insight [
    base:desc "Insight that visualizes long‑term climate trends within the greenhouse."
]

instance CraneHealthInsight : DTDFVocab:Insight [
    base:desc "Insight that assesses the health and performance of the gantry crane based on telemetry."
]

instance OperationStatusInsight : DTDFVocab:Insight [
    base:desc "Insight that reports the current operation status of the crane, including alarms and work completion."
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight that presents live 3D rendering of the crane and environment."
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight that displays historical sensor data and trends for analysis."
]

instance AirQualityForecastInsight : DTDFVocab:Insight [
    base:desc "Insight that forecasts indoor air quality for future time steps."
]

instance VirusSpreadPreventionInsight : DTDFVocab:Insight [
    base:desc "Insight that recommends preventive actions to mitigate virus spread in indoor spaces."
]

// C17: Actions
instance CraneControlCommandAction : DTDFVocab:Action [
    base:desc "Action that sends commands to the gantry crane to adjust position or load based on control algorithm."
    DTDFVocab:IsAutomatic true
]

// C3: Components and Environment
instance MechanicalCraneComponent : DTDFVocab:Component [
    base:desc "Physical gantry crane comprising mechanical arm, hook, and load carriage."
]

instance ControlInterfaceComponent : DTDFVocab:Component [
    base:desc "Python based interface that connects crane controllers to the logging application."
]

instance LabScaleCraneEnvironment : DTDFVocab:Environment [
    base:contains MechanicalCraneComponent, ControlInterfaceComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the Software domain (Control Application) and are synthesized by the Trajectory Generator Service, which emits optimal movement trajectories computed by a kinematic model. Trajectory data are passed as Python objects (e.g., dictionaries containing waypoints and control limits) to the Physical Crane Interface, which serializes them into low‑level actuator commands compatible with the crane controllers. Confirmation of command execution is achieved by the Continuous Validation Service, which compares live sensor readings (pulled by the Logging Application) with simulated execution results, computing distance metrics and notifying operators via the Dashboard when thresholds are breached. Authentication and conflict‑resolution mechanisms are not detailed in the document; however, the system design assumes that only authorized services communicate via the MQTT broker, and the Dashboard provides a unified feedback and control point for operator intervention."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin’s orchestration is implemented using containerized components deployed on virtual machines. An ActiveMQ message broker mediates data flow from the physical system to the twin, while sensor telemetry and simulation results are stored in an InfluxDB time‑series database. The architecture follows a loosely coupled, event‑driven pattern, with no commercial twin framework employed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication relies on an MQTT broker for signalling, enabling publish/subscribe messaging between the Trajectory Generator, Simulation Service, Continuous Validation Service, and the Dashboard. The system architecture is a local, edge‑centric network where services are Python processes communicating over MQTT, TCP/IP stacks, and direct database connections to TimescaleDB. Bandwidth and latency requirements are not specified; reliability is implied by the use of an MQTT broker, but redundancy or security protocols (e.g., TLS, authentication) are not mentioned."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin stack is deployed on‑premises (edge) alongside the physical crane hardware, utilizing local compute nodes to run Python services (Control Application, Trajectory Generator, Simulation, Continuous Validation) and a TimescaleDB instance. Data storage is provisioned on the same local infrastructure, with sufficient capacity to archive all time‑series telemetry generated by the Logging Application. Scalability is not explicitly addressed, suggesting a single‑node deployment; availability is supported by continuous logging and live validation feedback, but no redundancy or high‑availability mechanisms for services or database are described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with the physical plant is achieved through a Raspberry‑Pi equipped with sensors that publish telemetry to the ActiveMQ broker; the twin also adopts an AutomationML model for structural representation. Microsoft Azure services (including Azure IoT Hub and related cloud tooling) are used for downstream processing, visualization, simulation, and prediction, thereby establishing dependencies on on‑premise hardware, the message broker, and the Azure cloud stack."
]