// ===========================
// Physical Sensing Components
// ===========================
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing-angle encoder measuring crane hoist swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoControllerInterface : DTDFVocab:SensingComponent [
    base:desc "Arduino board reading swing encoder, anemometer and motor‑controller status signals"
    DTDFVocab:producedData ArduinoStatusDataTransmitted
]

// ===========================
// Data Transmitted (MQTT)
// ===========================
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance ArduinoStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoControllerInterface
]

// ===========================
// Time‑Series Data (TimescaleDB)
// ===========================
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle readings stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance ArduinoStatusTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of motor positions and controller status streamed by Arduino"
    DTDFVocab:fromData ArduinoStatusDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// ===========================
// Acting (Physical) Components
// ===========================
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the crane cart"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the crane hoist"
]

instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval controller for the cart motor"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval controller for the hoist motor"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist for picking up containers"
]

instance ArduinoActuatorInterface : DTDFVocab:ActingComponent [
    base:desc "Arduino‑based interface that drives the motors and the electromagnet"
]

// ===========================
// Enablers (Tooling & Infrastructure)
// ===========================
instance PythonRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime used for all application logic"
    DTDFVocab:enables DataLoggingService,
                    GrafanaDashboardService,
                    TrajectoryGeneratorService,
                    SimulationService,
                    ContinuousValidationService,
                    HumanMachineInterfaceService
]

instance DockerEngineEnabler : DTDFVocab:Enabler [
    base:desc "Docker engine providing containerisation of services"
]

instance DockerComposeOrchestratorEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestrates TimescaleDB, MQTT broker, and Grafana containers"
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) for time‑series storage"
    DTDFVocab:enables DataLoggingService
]

instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for event distribution"
    DTDFVocab:enables ContinuousValidationService,
                    TrajectoryGeneratorService,
                    SimulationService,
                    GrafanaDashboardService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for visualisation of logged data"
    DTDFVocab:enables GrafanaDashboardService
]

instance GantryLibEnabler : DTDFVocab:Enabler [
    base:desc "gantrylib Python module (pip install) providing crane kinematics utilities"
    DTDFVocab:enables TrajectoryGeneratorService,
                    SimulationService
]

instance KiCadEnabler : DTDFVocab:Enabler [
    base:desc "KiCad used to design the Arduino shield for sensor and actuator connections"
]

instance MkDocsEnabler : DTDFVocab:Enabler [
    base:desc "MkDocs used to generate project documentation"
]

instance CapellaArcadiaEnabler : DTDFVocab:Enabler [
    base:desc "Capella/Arcadia models for Model‑Based Systems Engineering"
]

// ===========================
// Services
// ===========================
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuously streams crane state (motor positions, encoder readings, wind speed) to TimescaleDB"
    DTDFVocab:provides CraneStateLoggingInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Provides visualisation of time‑series data and alerts on a Grafana dashboard"
    DTDFVocab:provides VisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes optimal swing‑free trajectory using the crane kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs runtime simulation of crane dynamics and controller behaviour"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories with simulated ones, generating alerts on deviation"
    DTDFVocab:provides TrajectoryDeviationAlertInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Operator control panel allowing parameter adjustments and manual overrides"
    DTDFVocab:provides OperatorControlAction
]

// ===========================
// Insights & Actions
// ===========================
instance CraneStateLoggingInsight : DTDFVocab:Insight [
    base:desc "Logged state of the crane available for analysis"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Grafana visualisation of sensor streams and generated alerts"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal swing‑free path suggested by the Trajectory Generator"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation trace of planned versus actual crane motion"
]

instance TrajectoryDeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert when trajectory deviation exceeds configured thresholds"
]

instance OperatorControlAction : DTDFVocab:Action [
    base:desc "Operator adjusts control parameters via the HMI"
    DTDFVocab:IsAutomatic false
]

// ===========================
// Models / Data Artifacts
// ===========================
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the lab‑scale gantry crane"
    DTDFVocab:inputTo TrajectoryGeneratorService,
                    SimulationService,
                    GantryLibEnabler
]

instance CADModelFusion360 : DTDFVocab:Model [
    base:desc "CAD model of the crane and Arduino shield created with Autodesk Fusion 360"
    DTDFVocab:inputTo MkDocsEnabler
]

// ===========================
// Environment
// ===========================
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains CartStepperMotor,
                 HoistStepperMotor,
                 CartMotorController,
                 HoistMotorController,
                 Electromagnet,
                 ArduinoActuatorInterface,
                 SwingAngleEncoder,
                 Anemometer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (Python) consumes trajectory commands from the Trajectory Generator Service via the MQTT broker and sends motion set‑points to the Physical Crane Interface, which forwards them to the motor controllers; the HMI can also issue commands that are relayed similarly."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical layer: crane hardware, Arduino, motor controllers, sensors; interface layer: Python Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface; virtual layer: TimescaleDB, MQTT broker, Grafana dashboard, Trajectory Generator, Simulation, Continuous Validation; all virtual components run as Docker containers on a personal computer and communicate via MQTT and SQL."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin includes design artefacts (CAD models of the crane), a kinematic model used for trajectory generation, and runtime artefacts (historical state data, simulation results) supporting both design and operational phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, checks against predefined thresholds and raises operator alerts, thereby providing runtime verification of the kinematic model."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor and controller data are transferred to the twin via a Python interface over serial/USB; state updates are published to the MQTT broker (Eclipse Mosquitto) and persisted in TimescaleDB via SQL; DT services subscribe/publish to MQTT topics; Grafana reads data from TimescaleDB via PostgreSQL protocol."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All virtual components are dockerised and launched together with Docker‑Compose on a single personal computer; the Python modules run locally; source code and Docker files are hosted on a public GitHub repository."
]