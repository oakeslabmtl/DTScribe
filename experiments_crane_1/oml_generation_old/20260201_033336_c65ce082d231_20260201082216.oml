// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor moving the crane cart, driven by a Trinamic TMC4671‑Eval controller"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor controlling the hoist, driven by a Trinamic TMC4671‑Eval controller"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist used to pick up payloads"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring the pendulum angle of the gantry crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting crane dynamics"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoSensorHub : DTDFVocab:SensingComponent [
    base:desc "Arduino board aggregating sensor readings and publishing via MQTT"
    DTDFVocab:producedData ArduinoSensorDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance ArduinoSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoSensorHub
]

// C10: Data
instance SwingAngleTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of swing angle measurements stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBContainer
]

instance WindSpeedTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of wind speed measurements stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBContainer
]

instance ArduinoSensorTimeSeriesData : DTDFVocab:Data [
    base:desc "Aggregated sensor data (including motor states) stored in TimescaleDB"
    DTDFVocab:fromData ArduinoSensorDataTransmitted
    DTDFVocab:inputTo TimescaleDBContainer
]

// C11: Enablers
instance TimescaleDBContainer : DTDFVocab:Enabler [
    base:desc "Docker container running TimescaleDB for time‑series storage"
    DTDFVocab:enables DataLoggingService
]

instance GrafanaContainer : DTDFVocab:Enabler [
    base:desc "Docker container running Grafana for dashboard visualization"
    DTDFVocab:enables RealTimeVisualizationService
]

instance MosquittoContainer : DTDFVocab:Enabler [
    base:desc "Docker container running Eclipse Mosquitto MQTT broker for pub/sub messaging"
    DTDFVocab:enables DataLoggingService, RealTimeVisualizationService, TrajectoryGenerationService, PhysicsSimulationService, ContinuousValidationService, OperatorNotificationService
]

instance GantryLibProcess : DTDFVocab:Enabler [
    base:desc "Python module gantrylib containing algorithms for trajectory generation, simulation and validation"
    DTDFVocab:enables TrajectoryGenerationService, PhysicsSimulationService, ContinuousValidationService
]

instance Fusion360CADTool : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion360 used for CAD geometry creation"
    DTDFVocab:enables CADVisualizationService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs incoming sensor data from the MQTT broker into TimescaleDB"
    DTDFVocab:provides DataStorageInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of sensor data via Grafana dashboards"
    DTDFVocab:provides VisualizationInsight
]

instance CADVisualizationService : DTDFVocab:Service [
    base:desc "Provides interactive visualization of the crane CAD model"
    DTDFVocab:provides CADViewInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal motion trajectories using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight, AdjustCraneCommandAction
]

instance PhysicsSimulationService : DTDFVocab:Service [
    base:desc "Simulates crane dynamics and controller behavior"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates measured trajectories against simulation"
    DTDFVocab:provides ValidationAlertInsight, InvestigateFaultAction
]

instance OperatorNotificationService : DTDFVocab:Service [
    base:desc "Sends operator notifications via the Grafana dashboard"
    DTDFVocab:provides OperatorAlertInsight
]

// C17: Insights
instance DataStorageInsight : DTDFVocab:Insight [
    base:desc "Indicates that sensor data has been successfully stored in the database"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Dashboard shows current crane state and sensor readings"
]

instance CADViewInsight : DTDFVocab:Insight [
    base:desc "Operator can view the 3D CAD model of the crane"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Provides optimal trajectory parameters for cart and hoist motion"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation outputs predicted trajectories and motor states"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert raised when measured behavior deviates from simulated trajectory"
]

instance OperatorAlertInsight : DTDFVocab:Insight [
    base:desc "Notifies operator of validation alerts and system status"
]

// C17: Actions
instance AdjustCraneCommandAction : DTDFVocab:Action [
    base:desc "Operator adjusts crane commands based on optimal trajectory insight"
    DTDFVocab:IsAutomatic false
]

instance InvestigateFaultAction : DTDFVocab:Action [
    base:desc "Operator investigates fault when a validation alert is raised"
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance CraneCADModel : DTDFVocab:Model [
    base:desc "CAD geometry of the crane created with Autodesk Fusion360"
    DTDFVocab:inputTo Fusion360CADTool
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the gantry crane used for trajectory generation"
    DTDFVocab:inputTo GantryLibProcess
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model of the crane and its controllers"
    DTDFVocab:inputTo GantryLibProcess
]

// C17: Environment and Components
instance PersonalComputerEnvironment : DTDFVocab:Environment [
    base:contains TimescaleDBComponent,
    GrafanaDashboardComponent,
    MosquittoBrokerComponent,
    TrajectoryGeneratorComponent,
    SimulationComponent,
    ContinuousValidationComponent
]

instance TimescaleDBComponent : DTDFVocab:Component [
    base:desc "TimescaleDB Docker container storing time‑series sensor data"
]

instance GrafanaDashboardComponent : DTDFVocab:Component [
    base:desc "Grafana Docker container providing real‑time visualization dashboards"
]

instance MosquittoBrokerComponent : DTDFVocab:Component [
    base:desc "Eclipse Mosquitto MQTT broker container enabling message exchange"
]

instance TrajectoryGeneratorComponent : DTDFVocab:Component [
    base:desc "Python process (gantrylib) that generates optimal trajectories"
]

instance SimulationComponent : DTDFVocab:Component [
    base:desc "Python process (gantrylib) that runs physics simulation of the crane"
]

instance ContinuousValidationComponent : DTDFVocab:Component [
    base:desc "Python process (gantrylib) that performs continuous validation of measured data"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital‑twin services (e.g., Trajectory Generator Service and Simulation Service) send motion commands through the MQTT broker to the Control Application, which uses the Physical Crane Interface to command the motor controllers and electromagnet on the physical crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "All components run on a single personal computer; Docker containers host the database, MQTT broker, and dashboard, while Python modules provide the Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface, and the various twin services, all communicating via MQTT and SQL queries."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the design stage (CAD models in Autodesk Fusion‑360 and kinematic model) and the operated stage (runtime sensor data, trajectory execution, validation) of the crane."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares executed trajectories with simulation outputs, computes distance metrics, and checks them against a predefined threshold; breaches trigger operator alerts, providing on‑line fidelity assessment of the twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses MQTT (Eclipse Mosquitto) for command and telemetry messages, and SQL over TCP/IP for database access; all services reside on the same Docker network on the host PC."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is hosted on a personal computer; Docker containers run the TimescaleDB, MQTT broker, and Grafana dashboard, while the gantrylib Python package is installed via pip and started with Docker‑Compose, enabling one‑command deployment."
]