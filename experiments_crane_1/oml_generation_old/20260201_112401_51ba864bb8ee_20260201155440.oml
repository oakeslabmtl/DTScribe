// C2: Acting Components
instance HorizontalCartMotor : DTDFVocab:ActingComponent [
    base:desc "Motor responsible for horizontal movement of the lab-scale gantry crane with closed-loop control for precise positioning"
]

instance VerticalHoistMotor : DTDFVocab:ActingComponent [
    base:desc "Motor responsible for vertical hoisting of the lab-scale gantry crane payload with kinematic constraints enforcement"
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist's end enabling container pickup and release operations"
]

// C3: Physical Sensing Components
instance CranePositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder sensor providing real-time position feedback for the horizontal cart movement"
    DTDFVocab:producedData CranePositionDataTransmitted
]

instance CraneVelocityEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder sensor providing real-time velocity feedback for the horizontal cart movement"
    DTDFVocab:producedData CraneVelocityDataTransmitted
]

instance HoistPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder sensor providing real-time position feedback for the vertical hoist movement"
    DTDFVocab:producedData HoistPositionDataTransmitted
]

instance HoistVelocityEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder sensor providing real-time velocity feedback for the vertical hoist movement"
    DTDFVocab:producedData HoistVelocityDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor monitoring motor currents for both horizontal and vertical actuators"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance CranePositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionEncoder
]

instance CraneVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocityEncoder
]

instance HoistPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistPositionEncoder
]

instance HoistVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistVelocityEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Models/Data
instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Parametric kinematic model of the lab-scale gantry crane using Denavit-Hartenberg parameters for forward/inverse kinematics"
    DTDFVocab:inputTo KinematicSimulationEnabler, TrajectoryPlanningEnabler
]

instance TrajectoryExecutionData : DTDFVocab:Data [
    base:desc "Time-series operational data including motor currents, encoder positions, and controller commands during crane operation"
    DTDFVocab:fromData CranePositionDataTransmitted, CraneVelocityDataTransmitted, HoistPositionDataTransmitted, HoistVelocityDataTransmitted, MotorCurrentDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance SimulatedTrajectoryData : DTDFVocab:Data [
    base:desc "Simulated trajectory data generated by the kinematic model for comparison with physical execution"
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HistoricalOperationalData : DTDFVocab:Data [
    base:desc "Longitudinal data for performance benchmarking and system degradation analysis"
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database optimized for high-write workloads storing operational data with millisecond precision"
    DTDFVocab:enables HistoricalDataLoggingService, ContinuousValidationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Real-time dashboard visualization tool for crane state monitoring and trajectory execution"
    DTDFVocab:enables DataVisualizationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker enabling low-latency bidirectional data streaming between physical and digital components"
    DTDFVocab:enables DataTransmissionService
]

instance KinematicSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python-based kinematic libraries (PyRobot, URDF parsers) for trajectory planning and validation"
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

instance TrajectoryPlanningEnabler : DTDFVocab:Enabler [
    base:desc "Control algorithms for generating optimal movement trajectories based on kinematic constraints"
    DTDFVocab:enables OptimalControlService
]

instance DockerContainerizationEnabler : DTDFVocab:Enabler [
    base:desc "Docker containerization for packaging and deploying digital twin services in isolated, reproducible environments"
    DTDFVocab:enables ServiceDeploymentService
]

instance ArduinoInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Arduino-based microcontrollers interfacing crane sensors and actuators"
    DTDFVocab:enables PhysicalActuatorControlService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Generates and executes optimal movement trajectories for the crane using its kinematic model ensuring energy-efficient and precise payload transport"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Records time-series operational data for post-analysis, trend detection, and performance benchmarking"
    DTDFVocab:provides HistoricalPerformanceInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Provides real-time and retrospective dashboards to monitor crane state, trajectory execution, and system health"
    DTDFVocab:provides CraneStateVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares measurements from executed trajectories with simulated trajectories using distance metrics to quantify synchronization fidelity"
    DTDFVocab:provides ValidationAccuracyInsight, FaultDetectionInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Implements anomaly detection by analyzing deviations between physical and digital twin states to classify faults and trigger alerts"
    DTDFVocab:provides FaultClassificationInsight
]

instance DataTransmissionService : DTDFVocab:Service [
    base:desc "Facilitates low-latency bidirectional data streaming between physical crane components and digital twin services"
    DTDFVocab:provides DataSynchronizationInsight
]

instance ServiceDeploymentService : DTDFVocab:Service [
    base:desc "Deploys digital twin services in containerized environments ensuring consistency across development and testing phases"
    DTDFVocab:provides DeploymentConsistencyInsight
]

instance PhysicalActuatorControlService : DTDFVocab:Service [
    base:desc "Controls crane actuators (motors, electromagnet) based on trajectory commands and sensor feedback"
    DTDFVocab:provides ActuatorControlInsight
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Energy-efficient and precise movement trajectories optimized for crane operation"
]

instance HistoricalPerformanceInsight : DTDFVocab:Insight [
    base:desc "Longitudinal analysis of crane performance metrics and operational trends"
]

instance CraneStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of crane kinematic state and trajectory execution"
]

instance ValidationAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantitative metrics of synchronization fidelity between physical and digital twin trajectories"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identified anomalies and potential faults in crane operation based on physical-digital twin discrepancies"
]

instance FaultClassificationInsight : DTDFVocab:Insight [
    base:desc "Classified faults based on historical data patterns and deviation analysis"
]

instance DataSynchronizationInsight : DTDFVocab:Insight [
    base:desc "Low-latency data synchronization status between physical and digital components"
]

instance DeploymentConsistencyInsight : DTDFVocab:Insight [
    base:desc "Consistent service deployment across development and testing environments"
]

instance ActuatorControlInsight : DTDFVocab:Insight [
    base:desc "Real-time control status of crane actuators with position and velocity feedback"
]

// C1: Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Controlled laboratory environment for the lab-scale gantry crane system"
    base:contains PhysicalCraneComponent, ControlSystemComponent, SensorNetworkComponent
]

// C5: Components
instance PhysicalCraneComponent : DTDFVocab:Component [
    base:desc "Mechanically actuated gantry crane with kinematic constraints representative of industrial cranes but simplified for laboratory use"
]

instance ControlSystemComponent : DTDFVocab:Component [
    base:desc "Embedded or software-based control system interfaced with crane actuators to execute motion commands and enforce safety constraints"
]

instance SensorNetworkComponent : DTDFVocab:Component [
    base:desc "Network of encoders and current sensors providing real-time feedback for crane position, velocity, and motor currents"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control flows originate from the **Trajectory Generator Service**, which leverages a kinematics model of the crane to generate optimal movement trajectories devoid of residual swinging motion. These trajectories are relayed to the **Control Application**, which uses the **Physical Crane Interface** to issue commands to the physical crane’s controllers. The **Logging Application** provides feedback by recording executed trajectories, enabling the **Continuous Validation Service** to compare real-world performance against simulations. No explicit details on control message formats (e.g., PWM, stepper motor commands), validation/authentication mechanisms, or conflict resolution protocols are documented. Command execution confirmation is implied through the logging and validation pipeline but not explicitly described as a discrete mechanism."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin systems in the documents follow a **lightweight, ad-hoc orchestration pattern** with **modular integration** of components. The **GreenhouseDT** exemplar employs a **hybrid architecture** combining **InfluxDB (time-series database)**, **ActiveMQ (message broker)**, and **virtual machines (VMs)** for behavioral adaptation, indicating a **service-oriented constellation** where data ingestion, processing, and twin adaptation are decoupled. The **Air Quality Management** exemplar uses **AutomationML-based digital twins** integrated with **Microsoft Azure tools**, suggesting a **model-driven orchestration pipeline** for runtime visualization, simulation, and prediction. Both exemplars avoid commercial frameworks, opting instead for **containerization/virtualization (e.g., VMs, Raspberry Pi)** to ensure **easy dissemination and reproducibility**. The **gantry crane system** (logistics/cyber-physical domain) adopts a **C4 Model** for architecture visualization, implying **component-level coordination** but lacks explicit details on resource management or system-wide orchestration. **Resource management** is implied through the use of **prerecorded data in VMs (GreenhouseDT)** and **sensor-driven Raspberry Pi setups (Air Quality Management)**, but no centralized governance or dynamic scaling mechanisms are described."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The **GreenhouseDT** exemplar emphasizes **self-adaptive behavioral models** with **prerecorded data** in VMs, implying a focus on **offline validation** via historical datasets. The **Air Quality Management** exemplar includes **runtime visualization, simulation, and prediction** applications, suggesting **real-time validation** through Azure-based pipelines. However, no explicit **uncertainty quantification**, **error correction mechanisms**, or **formal verification methods** (e.g., model calibration protocols) are documented. Both exemplars adopt an **ad-hoc approach**, lacking standardized fidelity metrics or commercial framework-backed validation processes."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin system employs a **TimescaleDB** database as the central repository for all system-generated data, including crane state logs, trajectory metrics, and simulation outputs. Inter-service communication is managed via an **MQTT Broker**, facilitating asynchronous signaling between containers (e.g., Trajectory Generator, Simulation, Validation). The system is deployed locally on a personal computer, with containers orchestrated using a **docker compose** file, though no specifics on network topology (e.g., client-server, peer-to-peer), bandwidth/latency requirements, or security protocols (e.g., TLS) are provided. The architecture implies a tightly coupled, local deployment with no explicit redundancy or failover mechanisms."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **Digital Twin Hosting and Deployment** infrastructure is **on-premise**, co-located with the physical gantry crane system to minimize latency. The **digital twin containers** (Database, Dashboard, Trajectory Generator, Simulation, Validation, MQTT Broker) are deployed as **Python-based services** on local servers or high-performance workstations, with **TimescaleDB** (a time-series database optimized for high-write workloads) as the primary storage backend. **Computational requirements** are moderate for trajectory generation and simulation but demand **real-time processing** for validation tasks. **Storage requirements** scale with operational duration, as the Logging Application continuously archives crane state data. **Scalability mechanisms** are not explicitly described, but the modular container architecture (C4 Model) allows for horizontal scaling of services (e.g., additional MQTT brokers or validation instances). **Deployment models** are **monolithic for the physical crane** (hardware + interface) but **microservices-based for the digital twin**, enabling independent updates to services like the Trajectory Generator or Dashboard. **Availability/reliability assurance** is implied by the **Continuous Validation Service**, which monitors system integrity and alerts operators to breaches in physical-digital alignment, though no explicit redundancy (e.g., failover databases) is mentioned."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin systems demonstrate **limited but domain-specific horizontal integration** with external systems. The **GreenhouseDT** exemplar relies on **InfluxDB (time-series database)** and **ActiveMQ (message broker)** for internal data exchange but does not explicitly detail integration with external enterprise systems or other Digital Twins. The **Air Quality Management** exemplar uses **AutomationML** for digital twin modeling and **Microsoft Azure tools** for pipeline implementation, indicating **standardized data exchange (AutomationML)** with potential interoperability in construction engineering contexts. However, dependencies on external systems (e.g., cloud services, IoT platforms) are not elaborated beyond Azure’s role. The **gantry crane system** lacks explicit integration details but aligns with the broader trend of **ad-hoc, domain-specific Digital Twins** with no mention of cross-system protocols or enterprise interoperability. **Data exchange protocols** are only implied (e.g., AutomationML, Azure APIs), and no **federated Digital Twin architectures** or **standardized interoperability frameworks** (e.g., OPC UA, MQTT) are referenced."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The **Air Quality Management** exemplar adheres to **AutomationML** for digital twin modeling and **Microsoft Azure tools** for pipeline implementation, ensuring interoperability within construction engineering contexts. The **Lab-Scale Gantry Crane** uses the **C4 Model** for architecture documentation, though no explicit industry standards (e.g., ISO, IEC) are mentioned. The **GreenhouseDT** system employs **InfluxDB** (time-series database) and **ActiveMQ** (message broker), but no compliance frameworks (e.g., ISO 27001, GDPR) or interoperability standards (e.g., OPC UA, AMQP) are referenced in the documents. Only **AutomationML** is explicitly noted as a standardization effort."
]