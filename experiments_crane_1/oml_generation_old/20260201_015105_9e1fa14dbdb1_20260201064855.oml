// --------------------------------------------------------------------------- // Return code: 1 | Stderr:
// Acting Components (Physical)
// ---------------------------------------------------------------------------
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor that drives the cart along the gantry"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor that raises and lowers the hoist"
]

instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval controller for the cart stepper motor"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval controller for the hoist stepper motor"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist for picking up pucks"
]

// ---------------------------------------------------------------------------
// Physical Sensing Components
// ---------------------------------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the hoist"
    DTDFVocab:producedData SwingAngleTelemetry
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed"
    DTDFVocab:producedData WindSpeedTelemetry
]

instance ArduinoBoard : DTDFVocab:SensingComponent [
    base:desc "Arduino board reading swing‑angle, wind speed and motor states"
    DTDFVocab:producedData MotorStateTelemetry
]

// ---------------------------------------------------------------------------
// Data transmitted from sensors
// ---------------------------------------------------------------------------
instance SwingAngleTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorStateTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoBoard
]

// ---------------------------------------------------------------------------
// Persisted Data (time‑series)
// ---------------------------------------------------------------------------
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurements stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleTelemetry
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed measurements stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedTelemetry
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance MotorStateTimeSeries : DTDFVocab:Data [
    base:desc "Time‑stamped motor‑state (current, voltage, position) stored in TimescaleDB"
    DTDFVocab:fromData MotorStateTelemetry
    DTDFVocab:inputTo TimescaleDBEnabler
]

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane (Autodesk Fusion 360)"
    DTDFVocab:inputTo GrafanaEnabler
]

instance KinematicCraneModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator Service"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance CraneDynamicsSimulationModel : DTDFVocab:Model [
    base:desc "Full‑physics simulation model of crane dynamics used by the Simulation Service"
    DTDFVocab:inputTo CraneSimulationEnabler
]

// ---------------------------------------------------------------------------
// Enablers (Docker containers / tools)
// ---------------------------------------------------------------------------
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance for time‑series storage"
    DTDFVocab:enables DataLoggingService, RealTimeVisualizationService, ContinuousValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service signalling"
    DTDFVocab:enables DataLoggingService, RealTimeVisualizationService, TrajectoryGenerationService, CraneSimulationService, ContinuousValidationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard container for real‑time visualization"
    DTDFVocab:enables RealTimeVisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Container running the optimal trajectory generation algorithm"
    DTDFVocab:enables TrajectoryGenerationService
]

instance CraneSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Container executing the physics‑based crane simulation"
    DTDFVocab:enables CraneSimulationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Container performing continuous validation of measured vs simulated trajectories"
    DTDFVocab:enables ContinuousValidationService
]

// ---------------------------------------------------------------------------
// Services
// ---------------------------------------------------------------------------
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuously writes incoming sensor data into TimescaleDB"
    DTDFVocab:provides SensorTrendInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of sensor trends via Grafana"
    DTDFVocab:provides SensorTrendInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal trajectories using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance CraneSimulationService : DTDFVocab:Service [
    base:desc "Runs full‑physics simulation of crane dynamics and controllers"
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares measured trajectories with simulated ones and raises alerts"
    DTDFVocab:provides TrajectoryDeviationInsight, OperatorNotificationAction, CorrectiveAdjustmentAction
]

// ---------------------------------------------------------------------------
// Insights
// ---------------------------------------------------------------------------
instance TrajectoryDeviationInsight : DTDFVocab:Insight [
    base:desc "Alert when the actual trajectory deviates from the optimal trajectory"
]

instance SensorTrendInsight : DTDFVocab:Insight [
    base:desc "Visualization of time‑series sensor trends (swing angle, wind speed, motor states)"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Recommendation of the optimal trajectory for the next operation"
]

// ---------------------------------------------------------------------------
// Actions
// ---------------------------------------------------------------------------
instance OperatorNotificationAction : DTDFVocab:Action [
    base:desc "Automatic notification sent to the operator when validation detects a deviation"
    DTDFVocab:IsAutomatic true
]

instance CorrectiveAdjustmentAction : DTDFVocab:Action [
    base:desc "Manual corrective action performed by the operator to adjust the crane"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application issues motion commands (target positions, velocity profiles) to the Physical Crane Interface, which translates them into motor controller commands for the cart and hoist motors and activates the electromagnet; trajectory commands generated by the Trajectory Generator Service are delivered through the same path. The Human Machine Interface can also send manual commands via the same interface."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of the physical crane, a Python interface to the crane, a Control Application, a Logging Application, a Human Machine Interface, and six digital‑twin containers (database, dashboard, trajectory generator, simulator, continuous validation, MQTT broker) orchestrated via Docker Compose on a single PC."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the design stage (CAD models of the crane and kinematic model), the manufacturing stage (physical crane built from the Bill‑of‑Materials), and the operation stage (runtime data logging, simulation, validation, and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service continuously compares executed trajectories with simulated trajectories, computes distance metrics, and checks them against a predefined threshold; breaches generate operator alerts via the dashboard, ensuring model fidelity during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses a Python serial/USB link to the Arduino for sensor and actuator data, MQTT (Eclipse Mosquitto) for intra‑service messaging over TCP/IP, and SQL over TCP/IP for database access. All components are networked within the Docker bridge network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software runs on a personal computer; Docker containers host the database, MQTT broker, and Grafana dashboard; the gantrylib Python module runs natively. Deployment is automated with a Docker‑Compose file; the whole system is open‑source on GitHub."
]