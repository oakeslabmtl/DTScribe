// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart motor (stepper) driven by Trinamic TMC4671‑Eval motor controller via Crane Interface Python module"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist motor (stepper) driven by Trinamic TMC4671‑Eval motor controller via Crane Interface Python module"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet actuator for container pick‑up, controlled through the Crane Interface Python module"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder monitoring hoist oscillation"
    DTDFVocab:producedData SwingAngleTelemetry
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed over the gantry crane"
    DTDFVocab:producedData WindSpeedTelemetry
]

instance MotorPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Motor position sensor via Arduino providing encoder ticks for stepper motors"
    DTDFVocab:producedData MotorPositionTelemetry
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor currents and control states for the stepper motors"
    DTDFVocab:producedData MotorCurrentTelemetry
]

// C4: Physical-to-virtual interaction
instance SwingAngleTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance MotorPositionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionSensor
]

instance MotorCurrentTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Models/Data
instance ModelCADGeometry : DTDFVocab:Model [
    base:desc "CAD geometry exported from Autodesk Fusion360, defining the physical layout of the gantry crane"
    DTDFVocab:inputTo PythonGantryLib
]

instance ModelKinematicTrajectory : DTDFVocab:Model [
    base:desc "Python‑based kinematic model for trajectory planning"
    DTDFVocab:inputTo PythonGantryLib
]

instance ModelMotorControllerSimulation : DTDFVocab:Model [
    base:desc "Discrete‑time simulation model of the motor controllers and crane dynamics"
    DTDFVocab:inputTo PythonGantryLib
]

instance DataTimeseries : DTDFVocab:Data [
    base:desc "Continuous timeseries data stored in TimescaleDB, combining telemetry, simulation outputs, and validation metrics"
    DTDFVocab:inputTo TimescaleDBTimescaleEnabler, MosquittoBrokerEnabler
]

instance DataSimulationOutput : DTDFVocab:Data [
    base:desc "Simulation outputs of crane dynamics and controller logic"
    DTDFVocab:inputTo TimescaleDBTimescaleEnabler, MosquittoBrokerEnabler
]

instance DataValidationMetrics : DTDFVocab:Data [
    base:desc "Distance‑metric comparison between measured and simulated trajectories with threshold alerts"
    DTDFVocab:inputTo TimescaleDBTimescaleEnabler, MosquittoBrokerEnabler
]

// C11: Enablers
instance TimescaleDBTimescaleEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance for persistence of time‑series logging data"
    DTDFVocab:enables DataLoggingApplicationService, SimulationService, ContinuousValidationService
]

instance MosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service message transport"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, DashboardService
]

instance PythonGantryLib : DTDFVocab:Enabler [
    base:desc "Python stack comprising gantrylib, Flask‑style services, and model execution engines"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana for dashboard visualization and insight dashboards"
    DTDFVocab:enables DashboardService
]

// C6: Services
instance DataLoggingApplicationService : DTDFVocab:Service [
    base:desc "Continuous data logging application persisting telemetry into TimescaleDB"
    DTDFVocab:provides InsightLoggingData
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service performing kinematic model‑based optimal motion planning"
    DTDFVocab:provides InsightTrajectoryPlanning, ActionReplanTrajectory
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service executing real‑time simulation of crane dynamics and controller logic"
    DTDFVocab:provides InsightSimulationOutput
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service comparing measured and simulated trajectories, issuing threshold alerts and fault probabilities"
    DTDFVocab:provides InsightValidationMetrics, InsightFaultProbability
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Grafana‑based visualization service for real‑time trajectory performance metrics and swing indicators"
    DTDFVocab:provides InsightTrajectoryPerformance, InsightSwingingMotionIndicator
]

instance MqttBrokerService : DTDFVocab:Service [
    base:desc "MQTT broker for inter‑service message transport"
    DTDFVocab:provides InsightMqttEvent
]

// C17: Insights
instance InsightLoggingData : DTDFVocab:Insight [
    base:desc "Persisted timeseries logging data for historical trend analysis"
]

instance InsightTrajectoryPlanning : DTDFVocab:Insight [
    base:desc "Optimized trajectory plan derived from kinematic model"
]

instance InsightSimulationOutput : DTDFVocab:Insight [
    base:desc "Simulation output representing expected crane dynamics"
]

instance InsightValidationMetrics : DTDFVocab:Insight [
    base:desc "Distance‑metric validation metrics comparing measured vs simulated trajectories"
]

instance InsightTrajectoryPerformance : DTDFVocab:Insight [
    base:desc "Real‑time trajectory performance metrics for operator feedback"
]

instance InsightSwingingMotionIndicator : DTDFVocab:Insight [
    base:desc "Swing angle indicators to assess hoist oscillation severity"
]

instance InsightFaultProbability : DTDFVocab:Insight [
    base:desc "Fault probability estimation from continuous validation"
]

instance InsightTrendAnalysis : DTDFVocab:Insight [
    base:desc "Historical trend analysis of telemetry for predictive maintenance"
]

instance InsightPredictiveMaintenance : DTDFVocab:Insight [
    base:desc "Predictive maintenance planning based on trend analysis and fault probabilities"
]

instance InsightMqttEvent : DTDFVocab:Insight [
    base:desc "MQTT event stream for real‑time inter‑service communication"
]

// C17: Actions
instance ActionReplanTrajectory : DTDFVocab:Action [
    base:desc "Automatic trajectory replanning triggered by real‑time performance metrics"
    DTDFVocab:IsAutomatic true
]

instance ActionScheduleMaintenance : DTDFVocab:Action [
    base:desc "Maintenance scheduling action based on fault probability and trend analysis"
    DTDFVocab:IsAutomatic false
]

instance ActionTuneParameters : DTDFVocab:Action [
    base:desc "Parameter tuning action to adjust kinematic model based on validation results"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory waypoints and control commands produced by the Trajectory Generator Service are transmitted over the Crane Interface to the motor controllers via serial/USB connections. Notifications (e.g., fault alerts) are sent to the operator through the Grafana dashboard. MQTT broker also conveys command and status messages between twin services and the physical interface."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in near real‑time; data is logged at the system’s physical command rate, trajectory generation and validation produce outputs within the same cycle, ensuring low‑latency feedback loops suitable for live operation and monitoring."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A Docker‑based microservice constellation orchestrated with docker‑compose: the TimescaleDB container, Mosquitto MQTT broker, Grafana dashboard; Python application containers (logging, trajectory, simulation, validation, crane interface); all co‑located on a single personal computer forming a cohesive, real‑time twin ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin lifecycle covers the as‑designed phase (CAD kinematic and control models), as‑manufactured phase (physical assembly and firmware integration), and as‑operated phase (runtime logging, continuous validation, and evolutionary updates)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service computes distance metrics between measured accelerations/positions and simulated counterparts, comparing them against predefined thresholds to trigger alerts. Validation relies on real‑world sensor data versus high‑fidelity simulation to assess model fidelity. No explicit uncertainty quantification beyond thresholding is reported."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical–digital communication via serial/USB to Arduino controllers; inter‑service messaging over MQTT (Eclipse Mosquitto); database access over PostgreSQL/SQL; docker networking provides isolated networks between containers. Data types include position, velocity, encoder counts, trajectory waypoints, and validation metrics."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Full codebase and required artefacts are hosted on GitHub (https://github.com/Cosys-Lab/lab-scale-gantry-crane). The Python gantrylib module is distributed via pip, the database, MQTT broker, and Grafana dashboards are containerised and deployed locally with docker‑compose on any Linux/Windows PC with Docker, enabling immediate local testing without additional infrastructure."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "No explicit integration with external digital twins or enterprise systems is described; all interactions are confined within the internal twin services and the local operator interface. Data export capabilities are available via TimescaleDB queries or Grafana dashboards."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The project adheres to open‑source standards: MQTT for messaging, TimescaleDB (PostgreSQL extension) for timeseries, Eclipse Mosquitto as the MQTT broker, and the GNU GPL‑like MIT license for source code. No formal industry‑level twin standards (e.g., ISA‑95, Asset Administration Shell) are referenced."
]