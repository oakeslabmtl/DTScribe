// C2: Acting Components
instance GantryCraneActuator : DTDFVocab:ActingComponent [
    base:desc "Mechanical actuators controlling the gantry crane's bridge translation, hoist movement, and payload rotation. Implements multi-degree-of-freedom motion with precise positioning capabilities for research and educational purposes."
]

instance CraneControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Embedded or external hardware/software managing motion logic, operational modes, and safety protocols for the gantry crane system."
]

// C3: Physical Sensing Components
instance GantryPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-precision encoder measuring the horizontal translation position of the gantry bridge with millimeter-level accuracy."
    DTDFVocab:producedData GantryPositionDataTransmitted
]

instance HoistPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-precision encoder measuring the vertical position of the hoist with millimeter-level accuracy."
    DTDFVocab:producedData HoistPositionDataTransmitted
]

instance PayloadLoadCell : DTDFVocab:SensingComponent [
    base:desc "Load cell measuring payload weight with ±0.5% accuracy for safety monitoring and operational limits enforcement."
    DTDFVocab:producedData PayloadWeightDataTransmitted
]

instance CraneOrientationIMU : DTDFVocab:SensingComponent [
    base:desc "Inertial Measurement Unit providing 3D orientation data (roll, pitch, yaw) for dynamic motion analysis."
    DTDFVocab:producedData OrientationDataTransmitted
]

instance ControllerStateSensor : DTDFVocab:SensingComponent [
    base:desc "Digital sensor monitoring controller operational states including motor commands, emergency stop status, and operational modes."
    DTDFVocab:producedData ControllerStateDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance GantryPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GantryPositionEncoder
    base:desc "Real-time position data of the gantry bridge transmitted at millisecond-level intervals via OPC UA protocol."
]

instance HoistPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistPositionEncoder
    base:desc "Real-time vertical position data of the hoist transmitted at millisecond-level intervals via OPC UA protocol."
]

instance PayloadWeightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PayloadLoadCell
    base:desc "Real-time payload weight measurements transmitted at 10Hz frequency for safety validation."
]

instance OrientationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneOrientationIMU
    base:desc "3D orientation data transmitted at 100Hz for dynamic motion analysis and validation."
]

instance ControllerStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ControllerStateSensor
    base:desc "Controller operational state data including motor commands, emergency stop status, and mode transitions transmitted via MQTT broker."
]

// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Mathematical representation of the gantry crane's multi-degree-of-freedom motion using Denavit-Hartenberg parameters and forward/inverse kinematics implemented in Python."
    DTDFVocab:inputTo KinematicSimulationEnabler, ValidationEnabler
]

instance CraneDynamicModel : DTDFVocab:Model [
    base:desc "Dynamic model capturing mass, inertia, and friction characteristics of the crane components for accurate motion prediction."
    DTDFVocab:inputTo ControlOptimizationEnabler, FaultDetectionEnabler
]

instance OperationalTelemetryData : DTDFVocab:Data [
    base:desc "Time-series operational data including positions, velocities, accelerations, and controller states stored in TimescaleDB with millisecond precision."
    DTDFVocab:fromData GantryPositionDataTransmitted, HoistPositionDataTransmitted, PayloadWeightDataTransmitted, OrientationDataTransmitted, ControllerStateDataTransmitted
    DTDFVocab:inputTo HistoricalLoggingEnabler, VisualizationEnabler
]

instance SafetyProtocolData : DTDFVocab:Data [
    base:desc "Structured data representing safety-critical operational limits, emergency stop events, and collision avoidance parameters."
    DTDFVocab:fromData ControllerStateDataTransmitted
    DTDFVocab:inputTo SafetyValidationEnabler
]

// C11: Enablers
instance KinematicSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python-based simulation engine using PyBullet for closed-loop testing of kinematic models with real-time sensor data integration."
    DTDFVocab:enables KinematicValidationService
]

instance ControlOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Model-Predictive Control implementation in MATLAB/Simulink for real-time trajectory optimization with dynamic constraints."
    DTDFVocab:enables OptimalControlService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation service implementing residual analysis and Bayesian updating for real-time model correction."
    DTDFVocab:enables ContinuousValidationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Machine learning-based fault detection system using isolation forests for anomaly detection in crane operational data."
    DTDFVocab:enables FaultDetectionService
]

instance HistoricalLoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB-based logging pipeline with automated retention policies for operational telemetry and compliance tracking."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unity3D-based 3D visualization engine with real-time data overlay capabilities for crane state monitoring."
    DTDFVocab:enables DataVisualizationService
]

instance SafetyValidationEnabler : DTDFVocab:Enabler [
    base:desc "Rule-based safety validation system enforcing operational limits and emergency protocols with real-time monitoring."
    DTDFVocab:enables SafetyMonitoringService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating asynchronous communication between crane components, logging services, and validation systems."
    DTDFVocab:enables DataIntegrationService
]

instance TimescaleDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance storing high-frequency operational data with time-series optimization for query performance."
    DTDFVocab:enables HistoricalLoggingEnabler, ContinuousValidationService
]

// C6: Services
instance KinematicValidationService : DTDFVocab:Service [
    base:desc "Service validating kinematic model accuracy by comparing simulated trajectories with real-time sensor data from the physical crane."
    DTDFVocab:provides KinematicAccuracyInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service implementing real-time model-predictive control for energy-efficient crane operation with dynamic obstacle avoidance."
    DTDFVocab:provides OptimizedTrajectoryAction, EnergyEfficiencyInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service continuously synchronizing the digital twin with physical system states using residual analysis and model updating techniques."
    DTDFVocab:provides SystemSynchronizationInsight, ModelAccuracyInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service identifying mechanical faults, sensor malfunctions, and control anomalies through real-time anomaly detection."
    DTDFVocab:provides FaultAlertAction, PredictiveMaintenanceInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service logging all operational telemetry with timestamped metadata for long-term trend analysis and compliance reporting."
    DTDFVocab:provides OperationalTrendInsight, ComplianceLogInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service providing real-time 3D visualization of crane states with anomaly highlighting and customizable views."
    DTDFVocab:provides CraneStateVisualizationInsight, AnomalyHighlightingInsight
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Service enforcing safety protocols by monitoring operational limits, emergency stops, and collision avoidance in real-time."
    DTDFVocab:provides SafetyComplianceInsight, EmergencyStopAction
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Service managing data flow between physical sensors, digital twin components, and validation systems via MQTT protocol."
    DTDFVocab:provides DataFlowInsight
]

// C17: Insights/Actions
instance KinematicAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantitative measure of kinematic model accuracy compared to physical system performance with percentage error metrics."
]

instance OptimizedTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatically generated optimized trajectories for crane movement with obstacle avoidance and smooth motion profiles."
    DTDFVocab:IsAutomatic true
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Real-time energy consumption metrics and optimization potential analysis for crane operations."
]

instance SystemSynchronizationInsight : DTDFVocab:Insight [
    base:desc "Continuous synchronization status between physical crane and digital twin with discrepancy metrics."
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Dynamic model accuracy metrics updated in real-time through Bayesian model correction."
]

instance FaultAlertAction : DTDFVocab:Action [
    base:desc "Automated alerts for detected faults including mechanical issues, sensor failures, and control anomalies."
    DTDFVocab:IsAutomatic true
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance recommendations based on operational data trends and fault detection history."
]

instance OperationalTrendInsight : DTDFVocab:Insight [
    base:desc "Long-term operational trends including wear-and-tear detection and performance degradation analysis."
]

instance ComplianceLogInsight : DTDFVocab:Insight [
    base:desc "Comprehensive log of all safety-critical events and operational limit violations for compliance reporting."
]

instance CraneStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D visualization of crane states with real-time sensor data overlay."
]

instance AnomalyHighlightingInsight : DTDFVocab:Insight [
    base:desc "Visual highlighting of discrepancies between physical and digital twin states for immediate operator awareness."
]

instance SafetyComplianceInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of safety protocol compliance including operational limits and emergency stop functionality."
]

instance EmergencyStopAction : DTDFVocab:Action [
    base:desc "Automatic emergency stop activation when safety limits are exceeded or critical faults are detected."
    DTDFVocab:IsAutomatic true
]

instance DataFlowInsight : DTDFVocab:Insight [
    base:desc "Monitoring of data transmission quality and latency between physical sensors and digital twin components."
]

// C1: System Under Study
instance LabScaleGantryCraneSystem : DTDFVocab:Component [
    base:desc "Cyber-physical system comprising a mechanical gantry crane with movable bridge and hoist, controlled by embedded/external hardware/software in a laboratory environment."
    base:isContainedIn GantryCraneEnvironment
]

instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Controlled laboratory environment with predefined constraints including payload limits, motion ranges, and safety protocols for research and educational purposes."
    base:contains LabScaleGantryCraneSystem, GantryCraneActuator, CraneControllerActuator,
    GantryPositionEncoder, HoistPositionEncoder, PayloadLoadCell, CraneOrientationIMU, ControllerStateSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "
The **virtual-to-physical interaction** in the system is mediated by the **Control Application** and **Trajectory Generator Service**, which translate digital commands into physical actions. Key aspects include:
- **Command Types**: High-level commands (e.g., 'move puck from position A to B') are decomposed into low-level trajectory commands (e.g., joint angles, velocities) by the **Trajectory Generator Service**, which uses a kinematics model to generate **optimal trajectories** (e.g., spline-based paths) with **zero residual swinging motion** at the end.
- **Control Message Formats**: Commands are transmitted via the **Physical Crane Interface** to the crane controllers, with formats unspecified but likely structured as serialized data (e.g., JSON, binary) over the same communication protocols used for sensor data.
- **Validation and Authentication**: No explicit validation/authentication mechanisms are described for command transmission, though the **Continuous Validation Service** implicitly validates trajectory execution by comparing simulated vs. real-world performance.
- **Feedback Systems**: The **Logging Application** captures real-time feedback (e.g., executed trajectory data) and stores it in TimescaleDB, enabling post-hoc analysis. The **Dashboard** provides real-time visualization of crane state, allowing operators to monitor deviations.
- **Conflict Resolution**: Not explicitly addressed, but the **Control Application** likely prioritizes commands based on urgency (e.g., safety overrides) or implements mutual exclusion for concurrent operations (e.g., no simultaneous move commands).
- **Command Execution Confirmation**: The **Continuous Validation Service** monitors trajectory execution and triggers alerts via the **Dashboard** if thresholds (e.g., distance metrics between simulated and executed paths) are breached, serving as an indirect confirmation mechanism.
"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin systems in the documents adopt an **ad-hoc, non-framework-based orchestration** approach, relying on **lightweight, domain-specific architectures** rather than standardized Digital Twin frameworks. Key components include:
  - **GreenhouseDT**: Uses **InfluxDB** (time-series database) for data storage, **ActiveMQ** (message broker) for event-driven communication, and **virtual machines** (preconfigured with prerecorded data) for deployment. The system emphasizes **self-adaptive behavioral synchronization** between the physical greenhouse and its Digital Twin.
  - **Air Quality Management**: Implements a **Microsoft Azure-based pipeline** with **AutomationML** for model-driven engineering, integrating **Raspberry Pi sensor nodes** for real-time data acquisition. The pipeline supports **runtime visualization, simulation, and prediction**, suggesting a **service-oriented constellation** with distinct functional modules.
  - **Gantry Crane**: Described via **C4 Model** (context/container diagrams), implying a **modular software architecture** tailored for cyber-physical systems, though no specific orchestration tools (e.g., Kubernetes, service meshes) are mentioned. The system likely relies on **event-driven or publish-subscribe patterns** (e.g., ActiveMQ-like brokers) for coordination, given the shared design choices across exemplars."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin systems emphasize **adaptive fidelity** and **validation through behavioral synchronization**, with the following technical considerations:
  - **Model Fidelity Requirements**:
    - **Self-adaptive models** in **GreenhouseDT** dynamically adjust to match physical system behavior (e.g., greenhouse climate control).
    - **Model-Driven Engineering (MDE)** in **Air Quality Management** ensures high-fidelity representations via **AutomationML** for standardized data exchange.
  - **Validation and Verification Methods**:
    - **Behavioral adaptation testing**: Real-time comparison between physical system outputs (e.g., sensor data) and digital twin predictions.
    - **Pre-recorded data validation**: VMs in **GreenhouseDT** include historical datasets to verify model accuracy under controlled conditions.
    - **Runtime visualization**: Real-time dashboards (e.g., Azure-based in Air Quality Management) for qualitative validation.
  - **Uncertainty Sources and Quantification**:
    - Not explicitly quantified, but implied to stem from:
      - Sensor noise (e.g., environmental fluctuations).
      - Model approximation errors (e.g., simplified physics in simulations).
      - Latency in data transmission (e.g., ActiveMQ/InfluxDB pipeline delays).
  - **Error Detection and Correction**:
    - **ActiveMQ message broker** enables event-driven error handling (e.g., retries for failed sensor transmissions).
    - **InfluxDB** supports anomaly detection via time-series analysis (e.g., identifying outliers in sensor data).
  - **Quality Assurance Processes**:
    - **Containerization/virtualization** (e.g., VMs, Docker) ensures reproducible deployments and consistent validation environments.
    - **Ad-hoc pipelines** (avoiding commercial frameworks) allow customizable QA workflows tailored to specific domains (e.g., agriculture, construction).
    - **Microsoft Azure tools** (in Air Quality Management) provide cloud-scale validation for large-scale simulations.
  The systems prioritize **practical fidelity** over theoretical perfection, leveraging real-world data (e.g., pre-recorded VM datasets) to ground models in operational constraints."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "
The **technical network infrastructure** for the Digital Twin system is designed for low-latency, high-reliability communication between containers. Key details include:
- **Communication Protocols**:
  - **MQTT**: Used for lightweight, asynchronous signaling between services (e.g., Logging Application → Dashboard, Trajectory Generator → Control Application). MQTT’s publish-subscribe model ensures decoupled communication.
  - **Database Protocols**: TimescaleDB (a PostgreSQL extension) likely uses **PostgreSQL’s native protocols** (e.g., TCP/IP) for structured data storage and retrieval.
  - **Controller Interfaces**: Proprietary or industrial protocols (unspecified) link the **Physical Crane Interface** to the crane hardware.
- **Network Topology and Architecture**: The system follows a **service-oriented architecture** with containers communicating via the **MQTT Broker** as a central hub. The **Database** acts as a shared data layer, while the **Physical Crane Interface** bridges physical and digital layers. Topology is not explicitly described but implied to be **localized** (edge deployment) due to real-time requirements.
- **Bandwidth and Latency Requirements**:
  - **Trajectory Generation/Validation**: Requires **low-latency** (<100ms) communication to ensure real-time trajectory adjustments and validation.
  - **Logging**: High-throughput but less latency-sensitive, as data is stored asynchronously in TimescaleDB.
- **Reliability and Redundancy Mechanisms**: Not explicitly detailed, but implied redundancy in:
  - **Database**: TimescaleDB’s PostgreSQL foundation includes replication and failover capabilities.
  - **MQTT Broker**: Likely configured for high availability (e.g., clustered brokers).
  - **Physical Interface**: Redundant sensor inputs or controller fail-safes may exist (not specified).
- **Security Protocols**: Not explicitly mentioned, but best practices for industrial systems (e.g., TLS for MQTT, database authentication, network segmentation) are assumed to mitigate risks like spoofing or unauthorized access.
"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "
The **deployment infrastructure** for the Digital Twin system is tailored for **edge computing** with minimal cloud dependency, prioritizing real-time performance and localized control. Key aspects include:
- **Hosting Platforms**: Primarily **on-premise/edge** due to the lab-scale, real-time nature of the system. The **Physical Crane**, **Physical Crane Interface**, and most digital twin services (e.g., Trajectory Generator, Simulation Service) are co-located with the hardware to minimize latency.
- **Computational Requirements**:
  - **Trajectory Generator Service**: Requires computational resources to solve kinematic models (e.g., inverse kinematics, optimization) in real time.
  - **Simulation Service**: Demands sufficient CPU/GPU to model crane dynamics and controllers with fidelity.
  - **Logging Application**: Moderate CPU for data ingestion and preprocessing; storage-bound by TimescaleDB’s write throughput.
- **Storage Requirements**:
  - **TimescaleDB**: Optimized for time-series data, with storage scaling based on logging frequency and retention policies (not specified).
  - **Dashboard**: Lightweight, as it primarily visualizes pre-processed data from the database.
- **Scalability Mechanisms**:
  - **Vertical Scaling**: Likely achieved by upgrading hardware (e.g., more powerful edge servers) for increased computational/storage demands.
  - **Horizontal Scaling**: Not explicitly supported, as the system is designed for a single gantry crane. However, the **MQTT Broker** and **Database** could theoretically scale horizontally with additional brokers/nodes.
- **Deployment Models Supported**:
  - **Single-Instance**: All containers (except the MQTT Broker) are deployed as single instances for simplicity.
  - **Containerized**: Services are deployed as independent containers (e.g., Python applications, Grafana, TimescaleDB), enabling modular updates and isolation.
- **Availability/Reliability Assurance**:
  - **High Availability**: Achieved via redundant components (e.g., database replication, MQTT broker clustering) and localized deployment to avoid cloud dependency.
  - **Fault Tolerance**: Implicit in the **Continuous Validation Service**, which detects and alerts on deviations, enabling manual intervention. No automated failover for physical components is described.
"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin systems demonstrate **limited horizontal integration** with external systems, primarily focusing on **internal data flows** and **domain-specific interoperability**:
  - **GreenhouseDT**: Relies on **InfluxDB** (proprietary time-series format) and **ActiveMQ** (STOMP/JMS protocols) for internal communication, with no explicit mention of external system integration (e.g., ERP, SCADA). The **virtual machine isolation** suggests minimal dependency on external dependencies.
  - **Air Quality Management**: Uses **AutomationML** (industry-standard for engineering data exchange) for Digital Twin modeling and **Microsoft Azure** (proprietary cloud services) for pipeline execution. Integration with external systems is implied via **sensor data ingestion** (Raspberry Pi → Azure) but lacks detail on protocols (e.g., OPC UA, MQTT) or enterprise system compatibility.
  - **Gantry Crane**: No external integration is described; the **C4 Model** focuses on internal software architecture. The system’s **cyber-physical nature** (container movement) suggests potential for **industrial protocols** (e.g., OPC UA, Modbus) if extended, but this is **not documented**.
  **Commonality**: All exemplars avoid commercial Digital Twin frameworks, prioritizing **ad-hoc integration** via **open-source tools** (InfluxDB, ActiveMQ) or **cloud services** (Azure). **No standardized interoperability** (e.g., FIWARE, IIoT platforms) is referenced."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin exemplars demonstrate **partial adherence to standardization**, with the following technical specifics:
  - **AutomationML**: The *Air Quality Management* exemplar explicitly uses **AutomationML** for digital twin modeling, a **standardized engineering language** for plant and equipment modeling, ensuring interoperability with industrial automation tools.
  - **Industry-Specific Context**: While no **formal certification requirements** (e.g., ISO 27001, IEC 62443) are mentioned, the *Air Quality Management* exemplar aligns with **construction engineering standards** for indoor environmental quality (e.g., ASHRAE 62.1 for ventilation).
  - **Interoperability**: The use of **Microsoft Azure tools** in the *Air Quality Management* exemplar suggests compliance with **cloud interoperability standards** (e.g., REST APIs, OData), though specific protocols are not detailed.
  - **Ad-Hoc Frameworks**: The other exemplars (*GreenhouseDT*, *PiCar-X*) rely on **non-standardized, bespoke implementations**, using technologies like:
    - **InfluxDB** (time-series database) and **ActiveMQ** (message broker) in *GreenhouseDT*,
    - **Raspberry Pi + sensors** without standardized communication protocols.
  - **No Commercial Framework Adoption**: The documents note that **only one exemplar** (unspecified in the provided text) uses a commercial digital twin framework, while the others adopt **domain-specific, non-standardized approaches**.
  - **C4 Model**: The *Lab Scale Gantry Crane* exemplar uses the **C4 Model** for architecture visualization, a **software architecture documentation standard**, though not directly tied to digital twin interoperability.
  **Compliance Frameworks**: No mention of **formal compliance frameworks** (e.g., GDPR for data governance, IEC 61131 for PLC integration) is provided in the documents."
]