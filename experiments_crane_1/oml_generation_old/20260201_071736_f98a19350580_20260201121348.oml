// C3: Physical sensing components
instance EncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Position encoder attached to the trolley, providing encoder counts for translational motion"
    DTDFVocab:producedData EncoderDataTransmitted
]

instance ForceSensor : DTDFVocab:SensingComponent [
    base:desc "Load-sensing actuator that measures vertical force applied during lifting"
    DTDFVocab:producedData ForceDataTransmitted
]

instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "High-resolution position sensor capturing vertical position of the hoist"
    DTDFVocab:producedData PositionDataTransmitted
]

// C4: Physical-to-virtual interaction
instance EncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderSensor
]

instance ForceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ForceSensor
]

instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

// C10: Models/Data
instance PersistedEncoderData : DTDFVocab:Data [
    base:desc "Persisted encoder telemetry stored in a TimescaleDB instance"
    DTDFVocab:inputTo TimescaleDBStorage
    DTDFVocab:fromData EncoderDataTransmitted
]

instance PersistedForceData : DTDFVocab:Data [
    base:desc "Persisted load-sensing telemetry stored in a TimescaleDB instance"
    DTDFVocab:inputTo TimescaleDBStorage
    DTDFVocab:fromData ForceDataTransmitted
]

instance PersistedPositionData : DTDFVocab:Data [
    base:desc "Persisted vertical position telemetry stored in a TimescaleDB instance"
    DTDFVocab:inputTo TimescaleDBStorage
    DTDFVocab:fromData PositionDataTransmitted
]

// C11: Enablers
instance TimescaleDBStorage : DTDFVocab:Enabler [
    base:desc "TimescaleDB used to persist and serve crane telemetry for downstream services"
    DTDFVocab:enables MonitoringService, ControlService, ValidationService, VisualizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring service that displays encoder, force, and position data streams"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Optimal-control service that computes lift and trajectory commands via deterministic kinematic optimization"
    DTDFVocab:provides OptimalControlAction
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service that compares live sensor readings against kinematic model predictions"
    DTDFVocab:provides ContinuousValidationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualization service that overlays CAD geometry of the crane onto real-time operational states"
    DTDFVocab:provides DeviceVisualizationInsight
]

// C17: Insights
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight into live encoder, force, and position data for operational awareness"
]

instance ContinuousValidationInsight : DTDFVocab:Insight [
    base:desc "Insight that identifies discrepancies between sensor readings and model predictions"
]

instance DeviceVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing a CAD overlay visualization of crane dynamics in real time"
]

// C17: Actions
instance OptimalControlAction : DTDFVocab:Action [
    base:desc "Action to inject computed lift and trajectory commands into the physical crane controller"
    DTDFVocab:IsAutomatic true
]

// Components
instance HorizontalBridge : DTDFVocab:Component [
    base:desc "Horizontal bridge of the gantry crane that spans the dual rails"
]

instance DualRails : DTDFVocab:Component [
    base:desc "Two parallel rails that guide the horizontal bridge"
]

instance Trolley : DTDFVocab:Component [
    base:desc "Trolley that moves along the horizontal bridge, supporting the hoist"
]

instance Hoist : DTDFVocab:Component [
    base:desc "Hoist that raises and lowers the payload vertically"
]

instance Controller : DTDFVocab:Component [
    base:desc "Industrial-grade controller that generates motion commands for the crane actuators"
]

// Environment
instance CraneLabEnvironment : DTDFVocab:Environment [
    base:contains HorizontalBridge, DualRails, Trolley, Hoist, Controller, EncoderSensor, ForceSensor, PositionSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application uses the same Physical Crane Interface to issue control commands to the crane. Commands consist of motion primitives derived from trajectories generated by the Trajectory Generator Service; the interface transmits these commands to the crane hardware. The system currently does not detail the exact message format, validation or authentication mechanisms, feedback loops, conflict resolution policies, nor explicit confirmation of command execution received by the physical crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The GreenhouseDT exemplar follows a modular, containerised/virtualised architecture. Sensor data from the physical greenhouse model are encapsulated and transmitted via an ActiveMQ message broker to an InfluxDB time‑series database for persistence. The digital twin logic, which implements behavioural adaptation, runs in a virtual‑machine context that hosts the twin model, the message broker, and the database as separate services, orchestrated through a common virtualisation layer. This pattern decouples data acquisition, messaging and storage while maintaining a single, centrally coordinated twin instance for the physical greenhouse."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The infrastructure relies on an MQTT broker for inter-service signaling within the digital twin stack. Communication between services (such as Trajectory Generator, Simulation, and Continuous Validation) occurs via MQTT topics. Database interactions use standard PostgreSQL clients established over the local network by the Python applications. The document does not provide explicit details on overall network topology, bandwidth or latency requirements, redundancy or reliability mechanisms, or security protocols applied to network communications."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The exemplar leverages Microsoft Azure services for cloud‑based analytics and runtime visualization. The digital twin model is represented in AutomationML, a standard modelling language that facilitates interoperability with building‑automation and engineering tools. Data exchange between on‑premises components and Azure occurs over the ActiveMQ publish/subscribe messaging protocol and Azure Service Bus, enabling a protocol‑agnostic integration pattern with external systems such as cloud dashboards and analytics pipelines."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar employs an AutomationML-based digital twin representation, aligning with the AutomationML industrial interoperability standard, and leverages Microsoft Azure cloud services for data processing and analytics, but the documentation does not specify additional certification or compliance frameworks."
]