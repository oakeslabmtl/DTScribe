// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing-angle encoder measuring hoist swinging motion"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmission)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Data definitions
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series swing‑angle measurements streamed from the encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series wind‑speed measurements streamed from the anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers (tools / platforms)
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) container for storing time‑series sensor and state data"
    DTDFVocab:enables DataLoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana container for visualizing stored data on dashboards"
    DTDFVocab:enables DataVisualizationService
]

instance GantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module (installed via pip) for generating swing‑free trajectories"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime and libraries for simulating crane dynamics and controllers"
    DTDFVocab:enables SimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime for continuous validation comparing measured and simulated trajectories"
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuously captures crane state (position, swing angle, wind speed, etc.) and stores it in TimescaleDB"
    DTDFVocab:provides DataLoggingInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Renders stored time‑series and simulated trajectories in Grafana dashboards"
    DTDFVocab:provides DashboardVisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Kinematic model‑based service producing swing‑free optimized motion plans using gantrylib"
    DTDFVocab:provides OptimizedTrajectoryInsight, ApplyOptimizedTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates crane dynamics and controller behavior to generate predicted trajectories"
    DTDFVocab:provides SimulatedTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates measured trajectories against simulated ones and issues alerts when deviations exceed thresholds"
    DTDFVocab:provides ContinuousValidationAlertInsight, OperatorInterventionAction
]

// C17: Insights
instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Continuous state capture recorded in TimescaleDB for later analysis"
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Simulated results displayed on Grafana dashboards support operator understanding and planning"
]

instance OptimizedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimized motion plans reduce swing, influencing control decisions"
]

instance SimulatedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Simulated crane trajectory data used for validation and planning"
]

instance ContinuousValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when measured trajectory deviates beyond configured thresholds"
]

// C17: Actions
instance ApplyOptimizedTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatically apply generated optimal trajectory to the crane controller"
    DTDFVocab:IsAutomatic true
]

instance OperatorInterventionAction : DTDFVocab:Action [
    base:desc "Operator manually intervenes to correct crane motion after an alert"
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance StepperMotorCart : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart axis of the gantry crane"
]

instance StepperMotorHoist : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist rope of the gantry crane"
]

instance TrinamicControllerCart : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval motor controller for the cart stepper motor"
]

instance TrinamicControllerHoist : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval motor controller for the hoist stepper motor"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist used to pick up containers"
]

// C10: Models / Data
instance CADCraneModel : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane created in Autodesk Fusion360"
    DTDFVocab:inputTo TrajectoryGeneratorService, SimulationService
]

instance KinematicCraneModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator for swing‑free motion planning"
    DTDFVocab:inputTo TrajectoryGeneratorService
]

instance DynamicsSimulationModel : DTDFVocab:Model [
    base:desc "Physical simulation model of crane dynamics and controllers used by the Simulation Service"
    DTDFVocab:inputTo SimulationService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends motion commands (including optimal trajectories generated by the Trajectory Generator Service) to the Physical Crane Interface, which forwards them to the motor controllers; the Continuous Validation Service can trigger operator alerts via the Grafana dashboard based on validation results."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in near real‑time. The Logging Application records data continuously (sampled at the controller update rate). The Continuous Validation Service runs immediately after a trajectory is completed, comparing measurement and simulation results within seconds. The Grafana dashboard updates in real time as new records are inserted. Trajectory generation and simulation are performed on‑demand but complete within milliseconds to seconds, enabling interactive planning."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "All digital components run on a personal computer; Docker containers provide the database, MQTT broker and Grafana dashboard, while Python services (Control Application, Logging Application, Trajectory Generator, Simulation, Continuous Validation) communicate via MQTT and share data through the TimescaleDB; the Physical Crane Interface bridges the PT hardware to the digital side."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the design stage (CAD models in Autodesk Fusion360 and kinematic model) and the operated stage (real‑time logging, validation and control during execution)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, and checks against predefined thresholds; the Trajectory Generator produces swing‑free optimal trajectories based on the kinematic model, ensuring high fidelity between planned and executed motion."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses a Python‑based interface over serial/USB to the Arduino and motor controllers, MQTT (Eclipse Mosquitto) over TCP/IP for inter‑service signalling, and PostgreSQL protocol for TimescaleDB access."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital twin services are hosted locally on a single PC; Docker containers (Database, MQTT Broker, Grafana) are started with a Docker Compose file; Python modules run in the host environment and are installed via pip."
]