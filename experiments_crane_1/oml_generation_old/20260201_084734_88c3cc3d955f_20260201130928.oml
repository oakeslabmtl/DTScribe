// Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains CartStepMotor, HoistStepMotor, SwingAngleEncoderSensor, AnemometerSensor
]

// Physical Actuating Components
instance CartStepMotor : DTDFVocab:ActingComponent [
    base:desc "Step‑per‑sec motor driving horizontal cart movement on the gantry crane"
]
instance HoistStepMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor raising and lowering the crane load via the hoist line"
]

// Physical Sensing Components
instance SwingAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring the lateral displacement of the crane scaffold at 10 Hz outputs 13‑bit pulses per revolution"
    DTDFVocab:producedData SwingAngleTx
]
instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer providing an analog voltage proportional to wind speed affecting crane stability digitised at 1 Hz"
    DTDFVocab:producedData AnemometerVoltageTx
]

// Data Transmitted from Sensors
instance SwingAngleTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensor
]
instance AnemometerVoltageTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// Telemetry Data
instance SwingAngleTelemetry : DTDFVocab:Data [
    base:desc "Swing‑angle telemetry data recorded with timestamps synchronized to the controller clock"
    DTDFVocab:fromData SwingAngleTx
    DTDFVocab:inputTo LoggingApplicationEnabler, MQTTBrokerEnabler
]
instance AnemometerTelemetry : DTDFVocab:Data [
    base:desc "Anemometer wind‑speed telemetry data recorded with timestamps synchronized to the controller clock"
    DTDFVocab:fromData AnemometerVoltageTx
    DTDFVocab:inputTo LoggingApplicationEnabler, MQTTBrokerEnabler
]

// Enablers
instance LoggingApplicationEnabler : DTDFVocab:Enabler [
    base:desc "Python logging application that persists telemetry into TimescaleDB via Dockerised TimescaleDB container"
    DTDFVocab:enables HistoricalDataLoggingService
]
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker publishing sensor telemetry to subscribers in real time"
    DTDFVocab:enables ContinuousValidationService
]
instance PythonSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python simulation engine executing kinematic model to generate trajectory plans"
    DTDFVocab:enables OptimalControlService
]
instance GrafanaVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard rendering 3‑D CAD/kinematic models and real‑time telemetry from TimescaleDB"
    DTDFVocab:enables DashboardService
]
instance HistoryDataLoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB enabler that stores historical telemetry snapshots for analytics"
    DTDFVocab:enables HistoricalDataLoggingService
]

// Models
instance CADModel : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane geometry created in Autodesk Fusion360"
    DTDFVocab:inputTo GrafanaVisualizationEnabler
]
instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model defining link lengths and motor positions used for simulation"
    DTDFVocab:inputTo PythonSimulationEnabler
]

// Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service that calculates optimal trajectory plans for the crane"
    DTDFVocab:provides MotionPlanInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously validates live sensor data against planning models, alerting when deviation exceeds threshold"
    DTDFVocab:provides DeviationThresholdExceededInsight, OperatorNotificationAction
]
instance DashboardService : DTDFVocab:Service [
    base:desc "Web‑based dashboard visualising real‑time status, trend analytics, and event logs from TimescaleDB"
    DTDFVocab:provides RealTimeStatusInsight
]
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that logs historical telemetry data for long‑term analytics"
    DTDFVocab:provides HistoricalDataInsight
]

// Insights
instance MotionPlanInsight : DTDFVocab:Insight [
    base:desc "Insight representing trajectory plans generated by optimal control"
]
instance DeviationThresholdExceededInsight : DTDFVocab:Insight [
    base:desc "Insight detecting when live measurement deviates from plan beyond the configured threshold"
]
instance RealTimeStatusInsight : DTDFVocab:Insight [
    base:desc "Insight presenting current operational status on the dashboard"
]
instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight summarising historical telemetry trends for analysis"
]

// Actions
instance OperatorNotificationAction : DTDFVocab:Action [
    base:desc "Automatic notification sent to operator when deviation threshold is exceeded"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, implemented in Python, utilizes the Physical Crane Interface to issue movement commands to the crane’s controller. The Trajectory Generator Service provides pre‑computed optimal trajectories derived from the crane’s kinematic model, which the Control Application uses to generate the sequence of control commands. Receipt of execution confirmation, command validation procedures, authentication mechanisms, conflict resolution, and feedback loops are not specified in the document."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A continuous validation service compares live sensor measurements against the kinematic simulation predictions. When the deviation exceeds a predefined threshold (for example, a few centimeters in position or degrees in swing angle), the service logs a warning and can trigger an automatic safety stop. Data integrity checks such as timestamp ordering, outlier detection, and redundancy of critical sensor streams are employed to ensure model validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All services communicate on a local network confined to a single personal computer. Inter‑service signaling is mediated by an MQTT Broker, while persistent data storage is handled by a TimescaleDB database. The Grafana Dashboard retrieves data directly from this database for visualization. No explicit bandwidth, latency, redundancy, or security protocol details are given in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system is deployed on‑premise on a personal computer. For deployment convenience, the Database, MQTT Broker, and Dashboard containers are packaged with Docker, indicating a containerized deployment model. No further scalability or high‑availability mechanisms are described in the document."
]