    DTDFVocab:producedData CraneVelocityDataTransmitted
]

instance CraneAccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "MEMS-based accelerometer array measuring 3-axis acceleration with 16-bit resolution for trajectory validation."
    DTDFVocab:producedData CraneAccelerationDataTransmitted
]

instance CraneTrajectoryLogger : DTDFVocab:SensingComponent [
    base:desc "Embedded logging system recording executed trajectories with timestamp synchronization for post-analysis."
    DTDFVocab:producedData CraneTrajectoryDataTransmitted
]

instance AirQualityCO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Non-dispersive infrared CO2 sensor measuring indoor air quality with ±50ppm accuracy for virus spread prediction."
    DTDFVocab:producedData AirQualityDataTransmitted
]

instance GreenhouseEnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Multi-sensor array measuring temperature, humidity, and light levels for behavioral adaptation of greenhouse twin."
    DTDFVocab:producedData GreenhouseEnvironmentalDataTransmitted
]

