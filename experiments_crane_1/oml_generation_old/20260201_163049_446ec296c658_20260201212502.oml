]

// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "OpenKinematics-based forward/inverse kinematics solver for gantry crane motion prediction with ±0.5% error tolerance."
    DTDFVocab:inputTo CraneSimulationEngine
    DTDFVocab:inputTo CraneControlAlgorithm
]

instance CraneDynamicModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink-based dynamic simulation model incorporating mass distribution and friction parameters."
    DTDFVocab:inputTo CraneSimulationEngine
]

instance AirQualitySimulationModel : DTDFVocab:Model [
    base:desc "AutomationML-based CFD model predicting indoor air quality dynamics with 95% confidence interval."
    DTDFVocab:inputTo AirQualityAnalyticsEngine
]

instance GreenhouseBehavioralModel : DTDFVocab:Model [
    base:desc "Adaptive behavioral model using reinforcement learning for greenhouse environmental condition optimization."
    DTDFVocab:inputTo GreenhouseControlSystem
]

instance CraneRawTelemetryData : DTDFVocab:Data [
    base:desc "Timestamp-synchronized raw sensor data including position, velocity, acceleration, and trajectory metrics."
    DTDFVocab:fromData CranePositionDataTransmitted
    DTDFVocab:fromData CraneVelocityDataTransmitted
    DTDFVocab:fromData CraneAccelerationDataTransmitted
    DTDFVocab:fromData CraneTrajectoryDataTransmitted
    DTDFVocab:inputTo DataValidationService
    DTDFVocab:inputTo FaultDetectionEngine
]

instance CraneProcessedTelemetryData : DTDFVocab:Data [
    base:desc "Preprocessed and normalized telemetry data with unit conversions and outlier filtering for analysis."
    DTDFVocab:fromData CraneRawTelemetryData
    DTDFVocab:inputTo CraneOptimizationService
    DTDFVocab:inputTo CraneVisualizationEngine
]

instance AirQualityTimeSeriesData : DTDFVocab:Data [
    base:desc "InfluxDB-stored time-series data of CO2 levels, temperature, and humidity for predictive analytics."
    DTDFVocab:fromData AirQualityDataTransmitted
    DTDFVocab:inputTo AirQualityAnalyticsEngine
]

instance GreenhouseEnvironmentalData : DTDFVocab:Data [
    base:desc "Historical and real-time environmental data used for behavioral adaptation of greenhouse twin."
    DTDFVocab:fromData GreenhouseEnvironmentalDataTransmitted
    DTDFVocab:inputTo GreenhouseControlSystem
]

// C11: Enablers
instance CraneSimulationEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink-based simulation environment for kinematic and dynamic analysis of crane operations."
    DTDFVocab:enables CraneMonitoringService
    DTDFVocab:enables CraneOptimizationService
    DTDFVocab:enables CraneValidationService
]

instance CraneControlAlgorithm : DTDFVocab:Enabler [
    base:desc "Model Predictive Control implementation for real-time trajectory optimization with 98% success rate."
