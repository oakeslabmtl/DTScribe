    DTDFVocab:inputFrom CraneProcessedTelemetryData
]

instance DataValidationService : DTDFVocab:Enabler [
    base:desc "Continuous validation service comparing physical trajectories with simulated predictions using Kalman Filter."
    DTDFVocab:enables CraneValidationService
    DTDFVocab:inputFrom CraneRawTelemetryData
]

instance FaultDetectionEngine : DTDFVocab:Enabler [
    base:desc "Autoencoder-based anomaly detection system trained on historical data for fault prediction."
    DTDFVocab:enables CraneFaultDetectionService
    DTDFVocab:inputFrom CraneProcessedTelemetryData
]

instance CraneVisualizationEngine : DTDFVocab:Enabler [
    base:desc "Blender-based 3D visualization engine for interactive crane state monitoring and trajectory playback."
    DTDFVocab:enables CraneVisualizationService
    DTDFVocab:inputFrom CraneProcessedTelemetryData
]

instance AirQualityAnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Python-based analytics engine using Pandas/NumPy for time-series analysis of air quality data."
