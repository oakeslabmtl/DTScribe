    DTDFVocab:inputFrom GreenhouseEnvironmentalData
]

instance PythonDataProcessing : DTDFVocab:Enabler [
    base:desc "Python environment with Pandas/NumPy for data logging, validation, and fault detection analytics."
    DTDFVocab:enables DataValidationService
    DTDFVocab:enables FaultDetectionEngine
]

instance ROSCommunication : DTDFVocab:Enabler [
    base:desc "Robot Operating System framework for bidirectional data streaming between physical and digital components."
    DTDFVocab:enables CraneControlAlgorithm
    DTDFVocab:enables GreenhouseControlSystem
]

instance InfluxDBStorage : DTDFVocab:Enabler [
    base:desc "Time-series database for structured storage of operational data with sub-second write latency."
    DTDFVocab:enables AirQualityAnalyticsEngine
    DTDFVocab:inputFrom AirQualityTimeSeriesData
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT message broker enabling asynchronous data transmission between physical sensors and digital twin."
    DTDFVocab:enables CraneSimulationEngine
    DTDFVocab:enables AirQualityAnalyticsEngine
]

