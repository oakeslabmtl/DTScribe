// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing-angle encoder that measures the angular displacement of the hoisted load."
    DTDFVocab:producedData SwingAngleTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer that measures ambient wind speed affecting the load."
    DTDFVocab:producedData WindSpeedTransmitted
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance SwingAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Data objects
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped angular displacement measurements from the swing‑angle encoder."
    DTDFVocab:fromData SwingAngleTransmitted
    DTDFVocab:inputTo TimescaleDB, ContinuousValidationEngine
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind speed measurements from the anemometer."
    DTDFVocab:fromData WindSpeedTransmitted
    DTDFVocab:inputTo TimescaleDB, ContinuousValidationEngine
]

// C11: Enablers (software/runtime infrastructure)
instance MqttBrokerMosquitto : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker mediating bi‑directional messaging between physical and digital sides."
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB PostgreSQL‑based time‑series database storing operational sensor data."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance ContinuousValidationEngine : DTDFVocab:Enabler [
    base:desc "Dockerised engine that continuously compares live sensor data with the kinematic model."
    DTDFVocab:enables ContinuousValidationService
]

instance HistoricalLoggingEngine : DTDFVocab:Enabler [
    base:desc "Docker container that extracts sensor data from TimescaleDB for archival purposes."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance OptimalControlEngine : DTDFVocab:Enabler [
    base:desc "Docker container running the optimal control algorithm using CAD and kinematic models."
    DTDFVocab:enables OptimalControlService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboards visualising real‑time and historic crane states."
    DTDFVocab:enables DataVisualizationService
]

instance ModelingEngine : DTDFVocab:Enabler [
    base:desc "Dockerised processing engine linking CAD and kinematic models for trajectory computation."
    DTDFVocab:enables OptimalControlService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes trajectories for the trolley to achieve target positions while guaranteeing zero residual swinging motion."
    DTDFVocab:provides TrajectoryComputationAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Records operational data from the crane for later analysis."
    DTDFVocab:provides HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Visualises real‑time and historic crane states through graphical dashboards."
    DTDFVocab:provides VisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares live sensor data with the kinematic model to detect deviations."
    DTDFVocab:provides ValidationInsight
]

// C17: Insights / Actions
instance TrajectoryComputationAction : DTDFVocab:Action [
    base:desc "Generates control set‑points for trolley motion ensuring zero swing."
    DTDFVocab:IsAutomatic true
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Provides aggregated historical operational metrics for post‑hoc analysis."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Displays current and historical crane state visualisations via Grafana."
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Detects deviations between measured sensor data and model predictions."
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance GantryCADModel : DTDFVocab:Model [
    base:desc "Detailed geometric CAD model of the lab‑scale gantry crane."
    DTDFVocab:inputTo ModelingEngine
]

instance GantryKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model describing trolley translation and load lifting behavior."
    DTDFVocab:inputTo ModelingEngine
]

// C2: Acting components
instance CartMovementMotor : DTDFVocab:ActingComponent [
    base:desc "Electric motor that drives the carriage along the linear guide (cart movement)."
]

instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Electric motor that raises and lowers the hoist rope (load lifting)."
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist end that picks up and releases container pucks."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (a Python application) uses the Physical Crane Interface to send commands to the crane controllers, thereby controlling the crane. No further details on command structure, validation, or acknowledgment are given."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is orchestrated with Docker containers. Core components include a Python‑based simulation/model, an MQTT broker for bidirectional communication with the physical crane, and a TimescaleDB instance for storing time‑series data. Docker (e.g., Docker Compose) coordinates container deployment, networking, and resource isolation, providing an ad‑hoc but cohesive integration of all twin services."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The exemplar includes a continuous validation service that constantly checks the consistency between the physical crane’s measured state and the predictions generated by the CAD‑based kinematic model. This service underpins research on continuous validation methods, fault detection, and the DarTwin notation for system evolution. Validation is performed online during operation by comparing streamed sensor data against model outputs; however, the document does not provide quantitative fidelity thresholds, explicit uncertainty quantification techniques, or detailed quality‑assurance procedures beyond this comparative validation approach."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication is performed via an MQTT broker for signaling, while the Database (TimescaleDB) and Dashboard (Grafana) are accessed directly by the respective services. The architecture consists of multiple containers running on the same system; no specific network topology, bandwidth, latency, redundancy, or security mechanisms are described."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All six digital‑twin containers (Database, Dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service, MQTT Broker) are deployed alongside the physical‑crane software on the same hardware platform, using containerized Python applications and a TimescaleDB instance. The document does not mention cloud or edge platforms, scalability approaches, or availability guarantees."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration is limited to the MQTT protocol for data exchange with the physical crane; all components run locally without reliance on external cloud services or enterprise middleware. No additional external standards or enterprise system interfaces (such as OPC UA, AutomationML, or Azure services) are mentioned."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar adopts AutomationML (AML) as the model‑exchange and specification framework for its digital twin (referred to as AML4DT), thereby complying with the AutomationML standard for representing engineering data and enabling interoperability. No other explicit industry standards, certification requirements, or compliance frameworks are mentioned for the GreenhouseDT or the lab‑scale gantry crane exemplars."
]