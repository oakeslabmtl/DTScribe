// C2: Acting Components
instance LinearActuatorLeft : DTDFVocab:ActingComponent [
    base:desc "Left linear actuator (motor) of the gantry crane, part of the crane's drive system."
]
instance LinearActuatorRight : DTDFVocab:ActingComponent [
    base:desc "Right linear actuator (motor) of the gantry crane."
]
instance ElectromagnetLifter : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet used for lifting payloads on the gantry crane."
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Rotary encoder that measures the swing angle of the gantry crane."
    DTDFVocab:producedData SwingAngleDataRecord
]
instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer that measures wind speed around the gantry crane."
    DTDFVocab:producedData WindSpeedDataRecord
]
instance CraneStateLogger : DTDFVocab:SensingComponent [
    base:desc "Python logging application that reads telemetry (position, velocity, load) from the crane control computer and writes it to TimescaleDB."
    DTDFVocab:producedData CraneStateDataRecord
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataRecord : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance WindSpeedDataRecord : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]
instance CraneStateDataRecord : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneStateLogger
]

// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the gantry crane implemented in the gantrylib Python library."
    DTDFVocab:inputTo DockerImageCraneEngine, TimescaleDBService
]
instance AirQualityPredictionModel : DTDFVocab:Model [
    base:desc "Simulation engine that predicts future air‑quality conditions in the laboratory environment."
    DTDFVocab:inputTo MQTTBroker, InfluxDBService
]
instance CraneStateData : DTDFVocab:Data [
    base:desc "Recorded positional, velocity, and load data of the gantry crane, stored in TimescaleDB."
    DTDFVocab:fromData CraneStateDataRecord
    DTDFVocab:inputTo CraneKinematicModel, ContinuousValidationService
]
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Swing angle measurement data of the crane, stored for validation."
    DTDFVocab:fromData SwingAngleDataRecord
    DTDFVocab:inputTo ContinuousValidationService
]
instance WindSpeedData : DTDFVocab:Data [
    base:desc "Wind speed measurement data from the anemometer, used for environmental context."
    DTDFVocab:fromData WindSpeedDataRecord
]
instance AirQualityData : DTDFVocab:Data [
    base:desc "Historical and real‑time air‑quality indices (temperature, humidity, IAQ) extracted from InfluxDB."
    DTDFVocab:inputTo AirQualityPredictionModel, DataVisualizationService
]
instance ForecastedAirQualityData : DTDFVocab:Data [
    base:desc "Predicted future air‑quality conditions generated by the simulation engine."
    DTDFVocab:inputTo DataVisualizationService
]

// C11: Enablers
instance DockerImageCraneEngine : DTDFVocab:Enabler [
    base:desc "Docker image hosting the Python gantrylib library and associated services."
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]
instance TimescaleDBService : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance used for high‑throughput time‑series logging of crane telemetry."
    DTDFVocab:enables HistoricalDataLoggingService
]
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker that mediates data flow between physical sensors and the digital twin."
    DTDFVocab:enables DataVisualizationService
]
instance InfluxDBService : DTDFVocab:Enabler [
    base:desc "InfluxDB instance used for archiving environmental sensor data such as temperature and humidity."
    DTDFVocab:enables DataVisualizationService
]
instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboard that visualizes real‑time crane telemetry and environmental indices."
    DTDFVocab:enables DataVisualizationService
]
instance ArduinoFirmware : DTDFVocab:Enabler [
    base:desc "Firmware running on the Arduino microcontroller that controls the crane actuators."
]
instance KiCadDesign : DTDFVocab:Enabler [
    base:desc "KiCad PCB design used to create the Cannon board that hosts the Arduino firmware."
]
instance Fusion360Model : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion360 CAD model of the gantry crane architecture."
]
instance CapellaArchitecture : DTDFVocab:Enabler [
    base:desc "Capella functional architecture model of the gantry crane system."
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service that computes optimal motion trajectories for the gantry crane based on user‑defined payload constraints."
    DTDFVocab:provides TrajectoryComputationInsight
]
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that logs real‑time historical data streams (position, velocity, current, temperature) for post‑hoc analysis."
]
instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service that exposes live and archived crane states and environmental indices via the Grafana dashboard."
    DTDFVocab:provides DashboardInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that compares physical measurements with the kinematic model to detect drift or faults."
    DTDFVocab:provides DriftAlertInsight
]

// C17: Insights/Actions
instance TrajectoryComputationInsight : DTDFVocab:Insight [
    base:desc "Insight that shows the computed optimal trajectory for the current payload configuration."
]
instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Insight that presents live telemetry in the Grafana dashboard."
]
instance DriftAlertInsight : DTDFVocab:Insight [
    base:desc "Alert when continuous validation detects significant deviation between measured and modeled crane states."
]
instance ForecastedAirQualityInsight : DTDFVocab:Insight [
    base:desc "Insight that displays predicted future air‑quality conditions in the laboratory."
]
instance ManualVentilationAdjustmentAction : DTDFVocab:Action [
    base:desc "Action that allows operators to manually adjust ventilation based on forecasted air‑quality insights."
    DTDFVocab:IsAutomatic false
]

// C17: Actions derived from services
instance AirQualityForecastAction : DTDFVocab:Action [
    base:desc "Action to trigger control of ventilation settings based on forecasted air‑quality predictions."
    DTDFVocab:IsAutomatic false
    DTDFVocab:provides ForecastedAirQualityInsight
]

// C17: Environment
instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains LinearActuatorLeft, LinearActuatorRight, ElectromagnetLifter, SwingAngleEncoder, AnemometerSensor, CraneStateLogger
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin’s Control Application operates as a Python process that consumes trajectories generated by the Trajectory Generator Service. A trajectory is a sequence of positional waypoints computed by a kinematic model that is intended to drive the crane without residual swing. The Control Application forwards these waypoints to the Physical Crane Interface, which translates them into low‑level motor/actuator commands sent to the crane controllers. The interface exposes no details on message format or authentication in the documents; it simply relays the high‑level commands to the physical hardware. Feedback from the physical system is captured by the Physical Crane Interface and recorded by the Logging Application for post‑hoc validation by the Continuous Validation Service."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated following a microservice architecture depicted by the C4 Context and Container diagrams. The Physical Crane component streams real‑time sensor telemetry (acoustic, torque, motor currents, end‑effector position) to a central MQTT broker. The Control Application consumes these topics, invokes a Trajectory Generator service (implemented in Python/ROS) to compute optimal motion plans, and publishes plan packets to a dedicated MQTT topic consumed by the Crane control unit. A Simulation Service runs inside a Docker container; it subscribes to planned trajectories, forwards them to a physics‑based simulator (Gazebo, PyBullet), and returns simulated telemetry. All services – control, trajectory generation, simulation – are containerized, deployed on VMs (Ubuntu 20.04), and communicate via secure TLS‑enabled MQTT with QoS 1. Coordination is achieved by the broker; the Control Application acts as a central orchestrator, scheduling tasks and aggregating telemetry for ingestion into InfluxDB and visualization dashboards. The architecture follows a layered client‑server pattern with the Control Application as the orchestrator and the Crane actuator as the subordinate client."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "GreenhouseDT follows a lifecycle that starts with a C4‑model based architectural design where the greenhouse layout and sensor network are diagrammed. The implementation phase bundles the system into Docker containers that include an InfluxDB time‑series database, an ActiveMQ message broker, and a virtual‑machine image that provides pre‑recorded data for the greenhouse. Deployment is achieved via the pre‑configured VM image, enabling rapid installation on a host machine. During operation the twin collects real‑time sensor data through MQTT, writes to InfluxDB, and synchronises adaptations with the physical greenhouse. Evolution of the twin is governed by an ad‑hoc version‑control strategy recorded in the GitHub repository; changes are tracked by Git commits and the repository’s README document outlines the iterative development process."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication is performed via an MQTT broker that acts as the messaging backbone for the Trajectory Generator Service, Simulation Service, and Continuous Validation Service, using MQTT's publish/subscribe semantics over TCP/IP (default port 1883). Data persistence and analytics are carried out with TimescaleDB, accessed over the standard PostgreSQL wire protocol. The system therefore relies on standard TCP/IP networking for both MQTT and database traffic; no specific network topology, bandwidth, latency, reliability, redundancy or security protocols beyond the MQTT and PostgreSQL defaults are mentioned."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Both the physical and digital twin stacks are deployed on a single personal computer (edge device). The Python applications (crane interface, control, logging, trajectory generation, simulation, validation, dashboard) and supporting services (TimescaleDB, Eclipse Mosquitto MQTT broker) run in Docker containers orchestrated by a docker‑compose file. The deployment is a single‑node edge configuration; no horizontal scaling or high‑availability features are described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adheres to a set of open standards: sensor data are transmitted using MQTT over an ActiveMQ broker, time‑series data are stored in InfluxDB (built on PostgreSQL), the Air‑Quality twin is described using AutomationML, and architecture diagrams are created with the C4 model notation. Deployment is platform‑agnostic through Docker containers. All source code is distributed under the MIT license as indicated by the LICENSE file in the GitHub repository."
]