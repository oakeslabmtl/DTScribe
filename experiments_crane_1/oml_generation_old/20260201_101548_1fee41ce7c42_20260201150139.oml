// Actuation components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart, controlled via TMC4671 Eval board."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist, controlled via TMC4671 Eval board."
]

instance TMC4671EvalBoard : DTDFVocab:ActingComponent [
    base:desc "TMC4671 Eval board providing motor driver functionality for both cart and hoist motors."
]

instance ElectromagnetOnHoist : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist to pick up and hold container pucks."
]

// Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder mounted on the hoist to measure pendulum motion."
    DTDFVocab:producedData SwingAngleData
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer to measure wind speed affecting the crane."
    DTDFVocab:producedData WindSpeedData
]

instance PositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder on the cart shaft to monitor cart position."
    DTDFVocab:producedData PositionData
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor monitoring motor electrical current for the cart and hoist."
    DTDFVocab:producedData MotorCurrentData
]

// Data transmitted constructs
instance SwingAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance PositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionEncoder
]

instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance ValidationMetricDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContinuousValidationService
]

instance TrajectoryRecordDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TrajectoryGenerationService
]

// Virtual data instances
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of swing angle measurements stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData SwingAngleData
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of wind speed measurements stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData WindSpeedData
]

instance PositionTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of cart position measurements stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData PositionData
]

instance MotorCurrentTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of motor current measurements stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData MotorCurrentData
]

instance ValidationDistanceMetricTable : DTDFVocab:Data [
    base:desc "Continuous validation distance metric table used for trajectory accuracy assessment."
    DTDFVocab:inputTo ContinuousValidationEnabler
    DTDFVocab:fromData ValidationMetricDataTransmitted
]

instance TrajectoryRecordData : DTDFVocab:Data [
    base:desc "Recorded trajectories of the cart and hoist for analysis and replay."
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
    DTDFVocab:fromData TrajectoryRecordDataTransmitted
]

instance SimulationConfidenceBounds : DTDFVocab:Data [
    base:desc "Confidence bounds of the physics‑based simulation model."
    DTDFVocab:inputTo SimulationEnabler
]

// Modeling and simulation components
instance CADModelGantryCrane : DTDFVocab:Model [
    base:desc "CAD model of the laboratory‑scale gantry crane built in Autodesk Fusion360."
    DTDFVocab:inputTo SimulationEnabler
]

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Kinematic model used for optimal trajectory generation."
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model predicting cart and hoist motion."
    DTDFVocab:inputTo SimulationEnabler
]

// Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB service for time‑series storage via PostgreSQL extension."
    DTDFVocab:enables DataLoggingService, ContinuousValidationService, TrajectoryGenerationService, FaultDetectionService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana service for real‑time data visualization dashboards."
    DTDFVocab:enables DashboardVisualizationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service communication."
    DTDFVocab:enables MQTTCommunicationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Service providing simulation capabilities for the crane."
    DTDFVocab:enables SimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for continuous validation comparing executed trajectories against simulation."
    DTDFVocab:enables ContinuousValidationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for optimal trajectory generation service."
    DTDFVocab:enables TrajectoryGenerationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for fault detection via time‑series classification."
    DTDFVocab:enables FaultDetectionService
]

// Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service responsible for logging sensor data into TimescaleDB."
    DTDFVocab:provides LogDataInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Service providing real‑time dashboard visualizations via Grafana."
    DTDFVocab:provides DashboardInsight
]

instance MQTTCommunicationService : DTDFVocab:Service [
    base:desc "Service for publishing and subscribing MQTT messages between devices and services."
    DTDFVocab:provides MQTTDataRoutingInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service executing physics‑based simulation of the crane."
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service comparing executed trajectories against simulation predictions."
    DTDFVocab:provides ValidationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service generating optimal trajectories for cart and hoist movement."
    DTDFVocab:provides TrajectoryInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service detecting faults through time‑series classification of sensor data."
    DTDFVocab:provides FaultClassificationInsight
]

// Insights and actions
instance LogDataInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that sensor data has been successfully logged into TimescaleDB."
]

instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Insight reflecting current crane status displayed on the Grafana dashboard."
]

instance MQTTDataRoutingInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful routing of MQTT messages between instruments and services."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight representing simulation results of crane motion based on current state."
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Insight providing continuous validation distance metric indicating trajectory accuracy."
]

instance TrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight containing generated optimal trajectory for requested container movement."
]

instance FaultClassificationInsight : DTDFVocab:Insight [
    base:desc "Insight identifying the type of fault detected in the crane system."
]

// Environment
instance LaboratoryScaleGantryCraneEnv : DTDFVocab:Environment [
    base:contains CartStepperMotor, HoistStepperMotor, TMC4671EvalBoard, ElectromagnetOnHoist,
           SwingAngleEncoder, Anemometer, PositionEncoder, MotorCurrentSensor,
           DataLoggingService, DashboardVisualizationService, ContinuousValidationService,
           TrajectoryGenerationService, FaultDetectionService, MQTTCommunicationService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory Generator and Control Application create optimal movement trajectories and send corresponding velocity/position commands through the Crane Interface to the motor driver boards; the MQTT broker mediates command payloads from the virtual side to the physical actuators; a Human–Machine Interface allows operators to send manual control commands which are likewise forwarded to the hardware."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate continuously in real‑time on the host machine; the Logging Application streams data as soon as sensors produce it; the Continuous Validation Service evaluates trajectories immediately after execution; the Trajectory Generator produces paths whenever requested; all are synchronized by the host’s system clock."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical side: crane hardware, Arduino controller, motor driver boards, sensors, and a Python crane interface; Digital side: Dockerised services (database, MQTT broker, dashboard, logging, simulation, validation, trajectory generator) interconnected via MQTT and HTTP; all orchestrated by Docker Compose on a single host computer, with the Human‑Machine Interface providing operator interaction."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "During design the DT uses CAD models of the crane (ideal geometry); manufacturing corresponds to the physically constructed crane whose parts are embodied by the actual hardware; operational twin services run in parallel with the physical system, continually updating models via sensor data and providing real‑time control and analytics."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity ensured by continuous comparison of logged sensor data against the simulated trajectory; a distance metric is computed and compared to a user‑defined threshold to trigger alerts; fault‑classification uses time‑series methods to identify deviations; validation assures that the digital trajectory matches physical execution within acceptable bounds."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT (Eclipse Mosquitto) broker handles publish/subscribe messaging between services (logging, validation, trajectory generator, dashboard); database connectivity uses PostgreSQL protocol; control commands are sent over serial/USB (via Crane Interface) to the TMC4671 motor drivers; the Human‑Machine Interface communicates over HTTP to the dashboard; all services run on the same host, connected via the local network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital twin services are containerised with Docker and launched using a Docker‑Compose file; the system runs on a local PC co‑locating the physical crane; the GitHub repository contains the code, Docker files, and documentation; the developer can install the Python module via pip and start the stack on any Linux/Windows machine supporting Docker."
]