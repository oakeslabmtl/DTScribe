// Sensors
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder for cart position"
    DTDFVocab:producedData CartMotorPositionDataTransmitted
]

instance HoistMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder for hoist position"
    DTDFVocab:producedData HoistMotorPositionDataTransmitted
]

instance LoggingApplication : DTDFVocab:SensingComponent [
    base:desc "Logging application streaming sensor and motor state data to TimescaleDB"
    DTDFVocab:producedData HistoricalLogDataTransmitted
]

// Data transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CartMotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoder
]

instance HoistMotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoder
]

instance HistoricalLogDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoggingApplication
]

// Data instances
instance SwingAngleDataSeries : DTDFVocab:Data [
    base:desc "Time‑series data of swing angle from Swing‑angle encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedDataSeries : DTDFVocab:Data [
    base:desc "Time‑series data of wind speed from anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance CartMotorPositionDataSeries : DTDFVocab:Data [
    base:desc "Time‑series data of cart motor position from motor encoder"
    DTDFVocab:fromData CartMotorPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HoistMotorPositionDataSeries : DTDFVocab:Data [
    base:desc "Time‑series data of hoist motor position from motor encoder"
    DTDFVocab:fromData HoistMotorPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HistoricalLogData : DTDFVocab:Data [
    base:desc "Historical logs of crane operations recorded by LoggingApplication"
    DTDFVocab:fromData HistoricalLogDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB used for logging and storing time‑series data"
    DTDFVocab:enables DatabaseService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana used for time‑series visualization of logged data"
    DTDFVocab:enables DashboardService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for publishing sensor data over MQTT topics"
    DTDFVocab:enables MQTTBrokerService
]

instance PYRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime environment for running userland services and simulation"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

// Models
instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the trajectory generator and simulator"
    DTDFVocab:inputTo PYRuntimeEnabler
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of crane and its controllers"
    DTDFVocab:inputTo PYRuntimeEnabler
]

instance CADModel : DTDFVocab:Model [
    base:desc "CAD models of crane components used for visualization"
    DTDFVocab:inputTo GrafanaEnabler
]

// Actions
instance TuneParametersAction : DTDFVocab:Action [
    base:desc "Action to tune trajectory generator parameters based on operator input"
    DTDFVocab:IsAutomatic false
]

instance DataQueryAction : DTDFVocab:Action [
    base:desc "Action to retrieve sensor data from the database"
    DTDFVocab:IsAutomatic false
]

// Insights
instance OptimalPathCalculationInsight : DTDFVocab:Insight [
    base:desc "Insight providing optimal path calculations for crane movement"
]

instance SimulationVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time simulation visualization"
]

instance TrajectoryDeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Insight alerting operators to trajectory deviation"
]

instance HistoricalLogAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight providing historical log analysis of crane operations"
]

// Services
instance DatabaseService : DTDFVocab:Service [
    base:desc "Containerised database service for storing crane sensor data"
    DTDFVocab:provides DataQueryAction
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Containerised dashboard for visualising time‑series data through Grafana"
    DTDFVocab:provides HistoricalLogAnalysisInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Containerised trajectory generator service using a kinematic model"
    DTDFVocab:provides OptimalPathCalculationInsight, TuneParametersAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Containerised real‑time simulation service of crane controllers"
    DTDFVocab:provides SimulationVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Containerised continuous validation service comparing measured and simulated trajectories"
    DTDFVocab:provides TrajectoryDeviationAlertInsight
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Containerised MQTT broker service for data publishing"
    DTDFVocab:provides MQTTDataPublishInsight
]

instance MQTTDataPublishInsight : DTDFVocab:Insight [
    base:desc "Insight indicating data has been published over MQTT topic"
]

// Acting components (physical actuators)
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart motor (stepper) driven by TMC4671–Eval controller"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist motor (stepper) driven by TMC4671–Eval controller"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet for picking up containers, controlled via Python interface"
]

// Physical system component
instance LabScaleGantryCrane : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane used for container handling in a laboratory environment, consisting of cart and hoist motors, an electromagnet, controlled via a Python interface and controller."
]

// Environments
instance PhysicalCraneEnvironment : DTDFVocab:Environment [
    base:contains SwingAngleEncoder, Anemometer, CartMotorEncoder, HoistMotorEncoder, LoggingApplication, LabScaleGantryCrane, CartStepperMotor, HoistStepperMotor, ElectromagnetActuator
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains DatabaseService, DashboardService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService, MQTTBrokerService,
           TimescaleDBEnabler, GrafanaEnabler, MQTTBrokerEnabler, PYRuntimeEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Trajectory Generator Service and Control Application are transmitted via MQTT to the Physical Crane Interface to drive the cart and hoist motors and the electromagnet; Validation alerts are also forwarded to the Human‑Machine Interface for operator action."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time continuous operation with sensor data logged at millisecond granularity, trajectory generation and validation executed per motion cycle, and near real‑time dashboard updates."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Services are orchestrated via Docker networking: sensor data and control messages travel over MQTT topics; simulation, trajectory generation and validation services subscribe to relevant topics; results are persisted in TimescaleDB and visualised by Grafana, while operator control is provided through a Python HMI."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design: CAD models in Autodesk Fusion360 and Capella Arcadia models capture the crane geometry and kinematics. Development: Python implementation of the kinematic model, simulation, and digit twin services. Operation: Continuous logging, real‑time control, simulation, and validation during crane use."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service computes a distance metric between measured and simulated trajectories, compares against a predefined threshold, and triggers alerts; the simulation uses a validated kinematic model to ensure swing‑motion residuals are minimized."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical–to–virtual: Python Physical Crane Interface streams sensor data over TCP to the Logging Application, which writes to TimescaleDB via PostgreSQL’s native protocol. Virtual–to–physical: Control commands are published on MQTT topics (broker Mosquitto) and consumed by the Control Application, which then commands the Physical Crane Interface. All services are networked within Docker Compose, using default ports (PostgreSQL 5432, MQTT 1883)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Containerised deployment via Docker and docker‑compose on a local workstation, with services exposed on local ports; repository hosted on GitHub for version control and reproducibility."
]