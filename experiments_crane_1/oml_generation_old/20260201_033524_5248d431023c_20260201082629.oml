// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing-angle encoder measuring the hoist swing on the lab‑scale gantry crane"
    DTDFVocab:producedData SwingAngleDataTx
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the gantry crane"
    DTDFVocab:producedData WindSpeedDataTx
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

// C10: Data
instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped swing angle measurement transmitted via MQTT"
    DTDFVocab:fromData SwingAngleDataTx
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped wind speed measurement transmitted via MQTT"
    DTDFVocab:fromData WindSpeedDataTx
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers (tooling)
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database container used for persisting logged measurements"
    DTDFVocab:enables LoggingApplicationService
]

instance PythonGantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module providing core algorithms for trajectory generation and simulation"
    DTDFVocab:enables TrajectoryGeneratorService
    DTDFVocab:enables SimulationService
]

instance GrafanaVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana container used for visualizing time‑series data and simulation results"
    DTDFVocab:enables VisualizationDashboardService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for message exchange between physical crane interface and digital twin services"
    DTDFVocab:enables MQTTSignallingService
]

instance DockerComposeOrchestratorEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestrates all containerised twin components"
    DTDFVocab:enables LoggingApplicationService
    DTDFVocab:enables VisualizationDashboardService
    DTDFVocab:enables TrajectoryGeneratorService
    DTDFVocab:enables SimulationService
    DTDFVocab:enables ContinuousValidationService
    DTDFVocab:enables MQTTSignallingService
]

// C6: Services
instance LoggingApplicationService : DTDFVocab:Service [
    base:desc "Logging Application continuously records received sensor states into TimescaleDB"
    DTDFVocab:provides RealTimeAlertInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Grafana Dashboard visualizes logged data and simulation outputs for decision support"
    DTDFVocab:provides SimulationResultVisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Trajectory Generator computes optimal swing‑free trajectories for the crane"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation Service runs crane dynamics simulations using the simulation model"
    DTDFVocab:provides SimulationResultVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous Validation Service compares executed trajectories with simulated ones and produces validation metrics"
    DTDFVocab:provides RealTimeAlertInsight
]

instance MQTTSignallingService : DTDFVocab:Service [
    base:desc "Generic MQTT signalling service routes sensor and command messages between components"
    DTDFVocab:provides RealTimeAlertInsight
]

// C17: Insights and Actions
instance RealTimeAlertInsight : DTDFVocab:Insight [
    base:desc "Real‑time alerts when validation metrics exceed predefined thresholds, enabling operators to intervene"
]

instance SimulationResultVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of simulation results to support operator decision making"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory information delivered to motion planner to eliminate residual swing"
]

instance OperatorInterventionAction : DTDFVocab:Action [
    base:desc "Operator intervenes to correct crane motion based on alert"
    DTDFVocab:IsAutomatic false
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator to compute optimal crane trajectories"
    DTDFVocab:inputTo PythonGantryLibEnabler
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model used by the Simulation Service to predict crane dynamics"
    DTDFVocab:inputTo PythonGantryLibEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal motion trajectories and sends them via MQTT to the Control Application, which uses the Physical Crane Interface to command the motor controllers; the Human‑Machine Interface also sends operator commands through the same path to the physical crane."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates in near real‑time: sensor data are streamed continuously and logged; validation compares measured trajectories with simulated ones as soon as new data arrive, generating instant alerts; trajectory generation and control run during movement execution, providing online guidance. No explicit sampling frequency is documented."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A cyber‑physical system where the physical crane and its controller are linked via a Python interface to a suite of digital twin services (trajectory generation, simulation, continuous validation) that communicate over MQTT, store data in TimescaleDB, and present results via a Grafana dashboard; user interaction is provided by a web‑based Human‑Machine Interface."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin covers the designed/ideal stage (CAD models of the crane in Autodesk Fusion 360 and a kinematic model) as well as the operated stage (real‑time sensor data, logging, validation and control during physical operation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service continuously compares measured trajectories with simulated trajectories, computes distance metrics, and checks them against a predefined threshold; violations trigger operator alerts on the dashboard, ensuring model fidelity is monitored during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication between PT and DT is realized through an MQTT broker (Eclipse Mosquitto) over TCP/IP; the Python interface subscribes/publishes to MQTT topics to exchange control commands and sensor updates."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital twin services are containerised with Docker and orchestrated via a single docker‑compose file; they run on a personal computer that also hosts the physical crane interface; the source code and Docker assets are publicly hosted on GitHub."
]