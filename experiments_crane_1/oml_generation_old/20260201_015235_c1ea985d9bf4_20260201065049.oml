// C2: Acting Components
instance CartMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor moving the crane carriage"
]

instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor raising and lowering the hoist"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist for picking containers"
]

instance TMC4671EvalController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval motor controller for both stepper motors"
]

instance ArduinoBoard : DTDFVocab:ActingComponent [
    base:desc "Arduino board acquiring sensor signals and driving actuators"
]

instance PowerSupplyUnit : DTDFVocab:ActingComponent [
    base:desc "PSU providing power to all electronics"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the crane"
    DTDFVocab:producedData SwingAngleMeasurement
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Wind‑speed sensor (anemometer) attached to the crane"
    DTDFVocab:producedData WindSpeedMeasurement
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance SwingAngleMeasurement : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedMeasurement : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Models/Data – Time‑series Data
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleMeasurement
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedMeasurement
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

// C10: Models
instance CraneCADModel : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane (Autodesk Fusion360)"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler, SimulationEngineEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the trajectory generator to compute optimal paths"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance CraneDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the crane and its controllers"
    DTDFVocab:inputTo SimulationEngineEnabler
]

// C11: Enablers (software / infrastructure)
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL) time‑series database for persisting operational data"
    DTDFVocab:enables DataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for event distribution between DT services"
    DTDFVocab:enables ContinuousValidationService, HumanMachineInterfaceService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana container visualising real‑time and historical data"
    DTDFVocab:enables GrafanaDashboardService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python trajectory generator (gantrylib) producing optimal movement plans"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation service container executing the dynamic crane model"
    DTDFVocab:enables CraneSimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Service that compares measured trajectories with simulated ones"
    DTDFVocab:enables ContinuousValidationService
]

instance HMIEnabler : DTDFVocab:Enabler [
    base:desc "Human‑machine interface web UI for operator monitoring and control"
    DTDFVocab:enables HumanMachineInterfaceService
]

instance ControlAppEnabler : DTDFVocab:Enabler [
    base:desc "Control application communicating with the Arduino over serial"
    DTDFVocab:enables ControlApplicationService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs sensor measurements to TimescaleDB"
    DTDFVocab:provides DataLoggedInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Visualises real‑time and historical data for operators"
    DTDFVocab:provides AdjustParametersAction, InterveneOperatorAction
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Supplies optimal movement plans for the crane"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance CraneSimulationService : DTDFVocab:Service [
    base:desc "Runs dynamic simulation of crane behaviour"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Provides alerts on model‑measurement discrepancies"
    DTDFVocab:provides ValidationAlertInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Operator interface for monitoring, parameter adjustment and intervention"
    DTDFVocab:provides AdjustParametersAction, InterveneOperatorAction
]

instance ControlApplicationService : DTDFVocab:Service [
    base:desc "Directly controls crane motors via Arduino commands"
    DTDFVocab:provides DirectControlAction
]

// C17: Insights
instance DataLoggedInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data was successfully logged to TimescaleDB"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating a discrepancy between measured and simulated trajectories"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory plan generated for the requested move"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Result of the crane dynamic simulation for a given trajectory"
]

// C17: Actions
instance AdjustParametersAction : DTDFVocab:Action [
    base:desc "Operator may adjust control parameters via the dashboard"
    DTDFVocab:IsAutomatic false
]

instance InterveneOperatorAction : DTDFVocab:Action [
    base:desc "Operator can intervene to stop or modify crane motion"
    DTDFVocab:IsAutomatic false
]

instance DirectControlAction : DTDFVocab:Action [
    base:desc "Direct control commands sent to Arduino for motor actuation"
    DTDFVocab:IsAutomatic false
]

// Environment grouping physical components
instance GantryCraneLabEnvironment : DTDFVocab:Environment [
    base:contains CartMotor, HoistMotor, ElectromagnetActuator,
                 TMC4671EvalController, ArduinoBoard, PowerSupplyUnit,
                 SwingAngleEncoder, Anemometer
]

// Component containers (digital twin infrastructure)
instance TimescaleDBContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the TimescaleDB instance"
]

instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Docker container running the Eclipse Mosquitto MQTT broker"
]

instance GrafanaContainer : DTDFVocab:Component [
    base:desc "Docker container hosting Grafana for visualization"
]

instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Docker container executing the trajectory generation service"
]

instance SimulationServiceContainer : DTDFVocab:Component [
    base:desc "Docker container running the crane simulation service"
]

instance ContinuousValidationContainer : DTDFVocab:Component [
    base:desc "Docker container providing continuous validation of measurements"
]

instance HMIContainer : DTDFVocab:Component [
    base:desc "Docker container delivering the human‑machine interface"
]

instance ControlAppContainer : DTDFVocab:Component [
    base:desc "Docker container for the Python-based control and logging applications"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application and Trajectory Generator Service send motion commands and electromagnet activation signals through the Python Physical Crane Interface to the motor controllers; command messages are also routed via the MQTT broker to the interface."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A cyber‑physical system where the physical crane is interfaced by a Python program to a set of services (control, logging, trajectory generation, simulation, validation) that communicate via MQTT and share data in a TimescaleDB; operators interact through a Grafana dashboard and a Python HMI."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectory data with simulated trajectories, computes distance metrics, checks against predefined thresholds, and raises alerts on the dashboard when the model fidelity falls below acceptable limits."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol (Eclipse Mosquitto) for signalling between services, SQL/TimescaleDB connections for data storage and retrieval, HTTP APIs used by Grafana, and Python‑based socket/serial communication between the Physical Crane Interface and the Arduino controllers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital‑twin services are containerised with Docker and orchestrated via Docker‑Compose on a personal computer; the Python modules run directly on the host OS; the full system is hosted in a GitHub repository with installation scripts and documentation."
]