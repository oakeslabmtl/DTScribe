// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder that measures pendulum motion of the hoist"
]
instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer that records wind speed"
]
instance ArduinoController : DTDFVocab:SensingComponent [
    base:desc "Arduino‑based controller that reads motor encoder counts, swing‑angle data, wind speed, and electromagnet state; publishes telemetry via the crane interface"
]

// C4: Physical-to-virtual interaction
instance SwingAngleTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance WindSpeedTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]
instance CartMotorPositionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoController
]
instance HoistMotorPositionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoController
]
instance ElectromagnetStateTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoController
]

// C10: Models/Data
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry frame and components modeled in Autodesk Fusion360"
    DTDFVocab:inputTo SimulationServiceEnabler
]
instance KinematicModel : DTDFVocab:Model [
    base:desc "Mathematical kinematic model that governs cart and hoist movement"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]
instance SimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model used by the Simulation Service"
    DTDFVocab:inputTo SimulationServiceEnabler
]

// C4: Data instances
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of motor positions and swing angle stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler, GrafanaEnabler, ContinuousValidationEnabler
    DTDFVocab:fromData SwingAngleTelemetry
]
instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of wind speed stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler, GrafanaEnabler
    DTDFVocab:fromData WindSpeedTelemetry
]
instance CartMotorPositionTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of cart motor encoder counts stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEnabler
    DTDFVocab:fromData CartMotorPositionTelemetry
]
instance HoistMotorPositionTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of hoist motor encoder counts stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEnabler
    DTDFVocab:fromData HoistMotorPositionTelemetry
]
instance ElectromagnetStateTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of electromagnet on/off state stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData ElectromagnetStateTelemetry
]
instance SimulatedTrajectoryTimeSeries : DTDFVocab:Data [
    base:desc "Simulated trajectories produced by the physics‑based SimulationService"
    DTDFVocab:inputTo SimulationServiceEnabler, ContinuousValidationEnabler
    DTDFVocab:fromData SimulatedTrajectoryTelemetry
]
instance ValidationMetricTimeSeries : DTDFVocab:Data [
    base:desc "Continuous validation metrics comparing measured and simulated trajectories"
    DTDFVocab:inputTo ContinuousValidationEnabler, GrafanaEnabler
    DTDFVocab:fromData ValidationMetricTelemetry
]
instance FaultClassificationTimeSeries : DTDFVocab:Data [
    base:desc "Fault classification results generated by the FaultDetectionService"
    DTDFVocab:inputTo FaultDetectionEnabler, GrafanaEnabler
    DTDFVocab:fromData FaultClassificationTelemetry
]

// Temporary telemetry for simulation and validation outputs
instance SimulatedTrajectoryTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationServiceEnabler
]
instance ValidationMetricTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContinuousValidationEnabler
]
instance FaultClassificationTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FaultDetectionEnabler
]

// C17: Insights/Actions
instance TrajectoryPerformanceMetricInsight : DTDFVocab:Insight [
    base:desc "Trajectory performance metrics calculated by the Validation Service"
]
instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Validation alerts indicating significant deviations between measured and simulated trajectories"
]
instance FaultClassificationResultInsight : DTDFVocab:Insight [
    base:desc "Fault classification results indicating detected fault modes"
]
instance OperatorAlertInsight : DTDFVocab:Insight [
    base:desc "Operator alerts triggered when validation metrics exceed predefined thresholds"
]
instance UpdateTrajectoryParametersAction : DTDFVocab:Action [
    base:desc "Action to update trajectory tuning parameters"
    DTDFVocab:IsAutomatic false
]
instance MotorCalibrationAction : DTDFVocab:Action [
    base:desc "Action to perform motor calibration adjustments"
    DTDFVocab:IsAutomatic false
]
instance ElectromagnetSwitchAction : DTDFVocab:Action [
    base:desc "Action to switch the electromagnet on or off"
    DTDFVocab:IsAutomatic true
]

// C1: Acting Components
instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist end that can be switched on/off to pick up and release pucks"
]
instance CartMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Cart motor driven by a TMC4671 motor controller, controlling horizontal rail motion"
]
instance HoistMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Hoist motor driven by a TMC4671 motor controller, controlling vertical lift motion"
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB container used for continuous time‑series data logging"
    DTDFVocab:enables ContinuousDataLoggingService
]
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for real‑time data streaming between physical and virtual components"
    DTDFVocab:enables ContinuousDataLoggingService, RealTimeDataVisualizationService
]
instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard container used for real‑time data visualization in Grafana"
    DTDFVocab:enables RealTimeDataVisualizationService, ContinuousValidationService, FaultDetectionService
]
instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Container running the Trajectory Generation Service that produces optimal trajectories using the kinematic model"
    DTDFVocab:enables TrajectoryGenerationService
]
instance SimulationServiceEnabler : DTDFVocab:Enabler [
    base:desc "Container running the Physics‑Based Simulation Service that runs the physics‑based simulation model"
    DTDFVocab:enables PhysicsBasedSimulationService
]
instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Container running the Continuous Validation Service that compares measured vs simulated trajectories"
    DTDFVocab:enables ContinuousValidationService
]
instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Container running the Fault Detection Service that classifies faults from time‑series signals"
    DTDFVocab:enables FaultDetectionService
]
instance OperatorAlertEnabler : DTDFVocab:Enabler [
    base:desc "Container that triggers operator alerts when validation metrics exceed thresholds"
    DTDFVocab:enables OperatorAlertService
]

// C6: Services
instance ContinuousDataLoggingService : DTDFVocab:Service [
    base:desc "Service that logs continuous real‑time telemetry to the Time‑Series database"
    DTDFVocab:provides ElectromagnetStateTimeSeries, CartMotorPositionTimeSeries, HoistMotorPositionTimeSeries, WindSpeedTimeSeries, SwingAngleTimeSeries
]
instance RealTimeDataVisualizationService : DTDFVocab:Service [
    base:desc "Service that visualises real‑time data via Grafana dashboards"
    DTDFVocab:provides TrajectoryPerformanceMetricInsight, ValidationAlertInsight, FaultClassificationResultInsight, OperatorAlertInsight
]
instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service that generates optimal trajectories for the gantry crane using the kinematic model"
    DTDFVocab:provides UpdateTrajectoryParametersAction
]
instance PhysicsBasedSimulationService : DTDFVocab:Service [
    base:desc "Service that runs physics‑based simulation of crane motion to produce simulated trajectories"
    DTDFVocab:provides SimulatedTrajectoryTimeSeries
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that validates measured trajectories against simulated trajectories and computes validation metrics"
    DTDFVocab:provides ValidationMetricTimeSeries, ValidationAlertInsight
]
instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service that classifies faults from time‑series signals and generates fault classification results"
    DTDFVocab:provides FaultClassificationTimeSeries, FaultClassificationResultInsight
]
instance OperatorAlertService : DTDFVocab:Service [
    base:desc "Service that issues operator alerts based on validation metrics"
    DTDFVocab:provides OperatorAlertInsight, ElectromagnetSwitchAction
]

// C17: Insights/Actions (already defined above)

// C10: Data (already defined above)

// C2: Environment and Components
instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains GantryCranePhysicalSystem, PythonCraneInterfaceContainer, MQTTBrokerContainer, TimescaleDBContainer, GrafanaDashboardContainer, TrajectoryGeneratorContainer, SimulationContainer, ContinuousValidationContainer
]
instance GantryCranePhysicalSystem : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane that transports lightweight pucks along the horizontal rail and hoists them vertically"
]
instance PythonCraneInterfaceContainer : DTDFVocab:Component [
    base:desc "Container running the Physical Crane Interface that publishes telemetry to the MQTT broker"
]
instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Container running Eclipse Mosquitto MQTT broker for inter‑service messaging"
]
instance TimescaleDBContainer : DTDFVocab:Component [
    base:desc "Container running TimescaleDB for continuous time‑series storage"
]
instance GrafanaDashboardContainer : DTDFVocab:Component [
    base:desc "Container running Grafana for real‑time data visualisation"
]
instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Container running the Trajectory Generator Service"
]
instance SimulationContainer : DTDFVocab:Component [
    base:desc "Container running the Physics‑Based Simulation Service"
]
instance ContinuousValidationContainer : DTDFVocab:Component [
    base:desc "Container running the Continuous Validation Service"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service produces optimal, swing‑free trajectory waypoints and publishes them to the MQTT broker. The Control Application subscribes to these trajectory commands, translates them into motor control signals via the Physical Crane Interface, and drives the physical motors. The Continuous Validation Service also publishes alert messages to the broker, which are consumed by the Human‑Machine Interface and displayed on the Grafana dashboard."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in a continuous real‑time mode: sensor data are logged continuously, trajectories are generated and validated in real time. The continuous validation service runs asynchronously in real time, validating each executed trajectory as it occurs. Exact time‑tick values are not specified, but the system is designed for milliseconds‑scale responsiveness and instant alerting."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation is a full stack of containers: Physical Crane (hardware), Physical Crane Interface (Python), Control Application (Python), Logging Application (Python), Human‑Machine Interface (Python/HTML), Database (TimescaleDB), Dashboard (Grafana), Trajectory Generator (Python), Simulation Service (Python), Continuous Validation Service (Python), and MQTT Broker (Eclipse Mosquitto). All components are connected via Docker networking and communicate over MQTT or direct file‑based APIs."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The exemplar represents the crane in its manufactured and operated state: the CAD models and the kinematic simulation were created after the hardware was assembled, and the twin runs on the operated system in continuous validation mode. The twin therefore covers the operating lifecycle phase, while future extensions could model future designs or retrofits."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validity is ensured by continuous comparison of measured trajectory execution against the simulation model; distance metrics are calculated and checked against a threshold, triggering operator alerts when breached. The CAD and kinematic models are verified against physical measurements, and the data logging pipeline is verified by cross‑checking timestamps and sensor values. Future work aims to incorporate full physical simulation to further tighten fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑component communication uses a local MQTT broker (Eclipse Mosquitto) for publish/subscribe messaging; the Physical Crane Interface communicates with the hardware via serial/USB to the Arduino. All messages are transported over TCP/IP sockets within the Docker network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin runs on an individual personal computer (any OS that supports Docker). Docker Compose brings up all containers (TimescaleDB, Mosquitto, Grafana, and the Python services). The source code and container artefacts are hosted openly on GitHub under the MIT license."
]