// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart axis of the gantry crane"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist rope of the gantry crane"
]

instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval motor controller for the cart stepper motor"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval motor controller for the hoist stepper motor"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted at the hoist used to pick up pucks"
]

instance ArduinoActuatorInterface : DTDFVocab:ActingComponent [
    base:desc "Arduino‑based board driving the electromagnet and motor controllers"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Models/Data
instance CadGeometricModel : DTDFVocab:Model [
    base:desc "CAD geometric models of the lab‑scale gantry crane"
    DTDFVocab:inputTo DockerComposeOrchestrator
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used for trajectory generation"
    DTDFVocab:inputTo PythonGantrayLibEnabler
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model of the crane and its controllers"
    DTDFVocab:inputTo MosquittoMQTTBrokerEnabler
]

instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance ValidationMetricData : DTDFVocab:Data [
    base:desc "Distance‑metric data produced by the Continuous Validation Service"
    DTDFVocab:inputTo DockerComposeOrchestrator
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database for persisting measurement data"
    DTDFVocab:enables LoggingApplicationService
]

instance DockerComposeOrchestrator : DTDFVocab:Enabler [
    base:desc "Docker Compose orchestrates all logical service containers"
    DTDFVocab:enables LoggingApplicationService,
                      GrafanaDashboardService,
                      TrajectoryGeneratorService,
                      SimulationService,
                      ContinuousValidationService,
                      MQTTBrokerService
]

instance PythonGantrayLibEnabler : DTDFVocab:Enabler [
    base:desc "gantrylib Python module (pip‑installable) providing kinematic calculations"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance MosquittoMQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for messaging between services"
    DTDFVocab:enables MQTTBrokerService,
                      SimulationService,
                      ContinuousValidationService
]

// C6: Services
instance LoggingApplicationService : DTDFVocab:Service [
    base:desc "Data logging service publishing crane state to TimescaleDB"
    DTDFVocab:provides DataLoggingInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualizing logged data and real‑time status"
    DTDFVocab:provides RealTimeStatusInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal motion plans using the kinematic model"
    DTDFVocab:provides TrajectoryOptimizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation of crane dynamics and controller behavior"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates executed trajectories against simulated ones"
    DTDFVocab:provides ValidationResultInsight
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "MQTT messaging broker coordinating service communication"
    DTDFVocab:provides MessagingInsight
]

// C17: Insights/Actions
instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Confirmation that crane state has been successfully logged"
]

instance RealTimeStatusInsight : DTDFVocab:Insight [
    base:desc "Real‑time crane status displayed on the HMI/dashboard"
]

instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory plans ready for execution"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation results of proposed crane motions"
]

instance ValidationResultInsight : DTDFVocab:Insight [
    base:desc "Quantitative validation results and alerts indicating deviations"
]

instance MessagingInsight : DTDFVocab:Insight [
    base:desc "Status of inter‑service messaging through MQTT"
]

instance FaultNotificationAction : DTDFVocab:Action [
    base:desc "Operator receives fault notifications on the HMI"
    DTDFVocab:IsAutomatic false
]

// C8: Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains CartStepperMotor, HoistStepperMotor,
                      CartMotorController, HoistMotorController,
                      Electromagnet, ArduinoActuatorInterface,
                      SwingAngleEncoder, Anemometer,
                      TimescaleDBEnabler, DockerComposeOrchestrator,
                      PythonGantrayLibEnabler, MosquittoMQTTBrokerEnabler,
                      LoggingApplicationService, GrafanaDashboardService,
                      TrajectoryGeneratorService, SimulationService,
                      ContinuousValidationService, MQTTBrokerService
]

// C9: Components (logical containers)
instance DatabaseContainer : DTDFVocab:Component [
    base:desc "Docker container running TimescaleDB"
]

instance DashboardContainer : DTDFVocab:Component [
    base:desc "Docker container running Grafana for visualization"
]

instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the Trajectory Generator Service"
]

instance SimulationContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the Simulation Service"
]

instance ContinuousValidationContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the Continuous Validation Service"
]

instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Docker container running Eclipse Mosquitto MQTT broker"
]

instance LoggingApplicationContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the Logging Application"
]

instance ControlApplicationContainer : DTDFVocab:Component [
    base:desc "Docker container running the control logic interfacing with the Arduino"
]

instance HumanMachineInterfaceContainer : DTDFVocab:Component [
    base:desc "Docker container providing the HMI/dashboard to operators"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (Python) sends motion set‑points and actuator commands to the Physical Crane Interface, which forwards them to the motor controllers and electromagnet; trajectory commands generated by the Trajectory Generator Service are delivered in the same way."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates continuously in (near) real‑time: sensor data are logged and validated continuously, and trajectory generation and validation run on the fly during operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centrally orchestrated set of Docker containers on a personal computer: the physical side runs Python programs communicating with the Arduino; the virtual side consists of a TimescaleDB instance, Grafana dashboard, MQTT broker, and the three service containers (trajectory generation, simulation, continuous validation) that exchange data via MQTT and the database."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers design (CAD models of the crane in Autodesk Fusion‑360), manufacturing (BOM for the physical crane), and operation (runtime data logging, simulation, validation, and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, checks them against a predefined threshold, and triggers operator alerts via the dashboard when the threshold is exceeded, ensuring model fidelity during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses a Python interface over serial/USB to the Arduino, MQTT (Eclipse Mosquitto) for event signalling between services, HTTP(S) for Grafana dashboard access, and SQL (PostgreSQL) queries to TimescaleDB for data retrieval."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All virtual components are Dockerised and launched together with a single Docker Compose command; the repository (including source code, CAD files, and documentation) is publicly hosted on GitHub, and the Python module is distributed via pip."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture description follows the C4 Model notation for context, container, and component diagrams; the digital‑twin uses open‑source standards such as MQTT, TimescaleDB (PostgreSQL), and Grafana."
]