// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the crane trolley."
    DTDFVocab:producedData SwingAngleTransmission
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the crane."
    DTDFVocab:producedData WindSpeedTransmission
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance SwingAngleTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing angle measurement from the encoder."
    DTDFVocab:fromData SwingAngleTransmission
    DTDFVocab:inputTo LoggingSoftware, ValidationSoftware, VisualizationSoftware, ControlSoftware, MQTTBroker
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind speed measurement from the anemometer."
    DTDFVocab:fromData WindSpeedTransmission
    DTDFVocab:inputTo LoggingSoftware, ValidationSoftware, VisualizationSoftware, ControlSoftware, MQTTBroker
]

// C2: Acting components
instance LinearRotaryActuator : DTDFVocab:ActingComponent [
    base:desc "Drive motors (linear/rotary) that actuate the crane’s trolley motion."
]

// C10: Models/Data
instance GantryCraneCADModel : DTDFVocab:Model [
    base:desc "Open‑source CAD geometric model of the lab‑scale gantry crane."
    DTDFVocab:inputTo OpenSourceCADTool, VisualizationSoftware, MQTTBroker
]

instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model representing the motion behavior of the gantry crane."
    DTDFVocab:inputTo KinematicModellingLibrary, SimulationSoftware, MQTTBroker
]

// C11: Enablers
instance OpenSourceCADTool : DTDFVocab:Enabler [
    base:desc "Freely available CAD tool used for geometry handling and visualization."
    DTDFVocab:enables RealTimeVisualizationService
]

instance KinematicModellingLibrary : DTDFVocab:Enabler [
    base:desc "Open‑source library for kinematic simulation of the crane."
    DTDFVocab:enables SimulationService
]

instance ControlSoftware : DTDFVocab:Enabler [
    base:desc "Custom control application generating optimal motion commands."
    DTDFVocab:enables OptimalMotionControlService
]

instance LoggingSoftware : DTDFVocab:Enabler [
    base:desc "Logging application that writes time‑series crane state data to TimescaleDB."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance VisualizationSoftware : DTDFVocab:Enabler [
    base:desc "Visualization component (Grafana) for real‑time display of crane operation."
    DTDFVocab:enables RealTimeVisualizationService
]

instance ValidationSoftware : DTDFVocab:Enabler [
    base:desc "Continuous validation module that compares live data with model predictions."
    DTDFVocab:enables ContinuousValidationService
]

instance TrajectoryGeneratorSoftware : DTDFVocab:Enabler [
    base:desc "Trajectory generator that computes optimal motion paths for the crane."
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationSoftware : DTDFVocab:Enabler [
    base:desc "Simulation service that runs virtual crane motion scenarios."
    DTDFVocab:enables SimulationService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance used for persistent storage of sensor and actuator data."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker facilitating data exchange among services."
    DTDFVocab:enables OptimalMotionControlService,
                  HistoricalDataLoggingService,
                  RealTimeVisualizationService,
                  ContinuousValidationService,
                  TrajectoryGeneratorService,
                  SimulationService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboard presenting live and historical crane metrics."
    DTDFVocab:enables RealTimeVisualizationService
]

// C6: Services
instance OptimalMotionControlService : DTDFVocab:Service [
    base:desc "Service that computes and dispatches optimal motion commands to the crane."
    DTDFVocab:provides MotionOptimizationInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that records time‑stamped crane state data into TimescaleDB."
    DTDFVocab:provides HistoricalMonitoringInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Service that streams live crane data to Grafana for operator monitoring."
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously validates physical behavior against the kinematic model."
    DTDFVocab:provides ValidationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service that generates feasible motion trajectories for task execution."
    DTDFVocab:provides TrajectoryPlanningInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that simulates crane motion and predicts outcomes of ‘what‑if’ scenarios."
    DTDFVocab:provides AirflowSimulationInsight
]

// C17: Insights / Actions
instance MotionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal motion profiles to improve efficiency."
]

instance HistoricalMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight derived from historical logs enabling trend analysis and anomaly detection."
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing operators with immediate visual feedback of crane status."
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Insight flagging discrepancies between measured data and kinematic model predictions."
]

instance TrajectoryPlanningInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting feasible trajectories that respect safety constraints."
]

instance AirflowSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from simulated air‑flow and contaminant spread, applicable to environmental assessments."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the Control Application (and optionally by the Trajectory Generator Service) and sent via the Physical Crane Interface to the motor controllers of the crane. Commands are issued as Python API calls over the same network used by the interface; execution is performed by the motor controllers driving the cart and hoist. Confirmation of command execution is logged by the Logging Application. Authentication, validation, or conflict‑resolution mechanisms are not described in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a container‑based, event‑driven constellation. Each functional element is modeled as a C4‑container (not a Docker container) that must be present for operation. The MQTT broker acts as the integration backbone, routing messages between the Trajectory Generator, Simulation, Continuous Validation and the Human‑Machine Interface. Persistent state is stored in a TimescaleDB instance, which is read by the Logging Application, Dashboard and Validation Service. The Dashboard (Grafana) visualises data from the database in real time. The Trajectory Generator uses a kinematics model to compute swing‑free trajectories, which are fed to the Simulation Service and, after execution, to the Validation Service that compares measured versus simulated trajectories and raises alerts via the Dashboard. Resource management relies on the shared database and broker, and the overall coordination is orchestrated through MQTT topics and periodic polling of the database."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The exemplar provides a continuous validation service that compares the kinematic model against observed crane behavior to detect model drift and faults. Validation and fault‑detection methods have been demonstrated in research papers using this setup, and the DarTwin notation has been applied for model evolution. Quantitative fidelity thresholds, uncertainty quantification, and detailed QA processes are not explicitly described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system’s software components are packaged as Docker containers (TimescaleDB, Eclipse Mosquitto MQTT broker, Grafana dashboard) and orchestrated with Docker‑Compose on a single host PC. Communication between services uses MQTT (publish/subscribe) for signaling and standard TCP/IP for database access (SQL) and HTTP for Grafana. No explicit bandwidth, latency, redundancy, or security protocols are specified in the provided documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components run on‑premise on a personal computer. Docker containers host the database, MQTT broker, and dashboard; the remaining Python services are installed via the pip‑installable gantrylib module. Computational needs are modest (single‑core CPU, modest RAM) and storage is provided by TimescaleDB. Deployment is performed with a single docker‑compose command, enabling start/stop of the containerised services. No cloud or edge platform is used, and scalability mechanisms are not described in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external components is realised through a Python‑based Physical Crane Interface that communicates with the crane controllers (protocol unspecified) and publishes state updates to the MQTT broker. All twin services consume these MQTT messages and write measurements to TimescaleDB. The Dashboard accesses the database via Grafana’s data source plugins (SQL/Timescale). No enterprise‑level standards such as OPC UA or AutomationML are used in this exemplar; the only explicit protocol is MQTT for inter‑service signaling, and the system relies on open‑source tools (TimescaleDB, Grafana, Python) for data exchange."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar adopts the AutomationML standard for its digital‑twin model representation, ensuring model‑driven interoperability. No other industry certifications or standards are mentioned for the exemplars."
]