// -----------------------------------------------------
// Physical Sensing Components
// -----------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorPositionFeedback : DTDFVocab:SensingComponent [
    base:desc "Motor controller feedback providing motor position"
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance MotorSpeedFeedback : DTDFVocab:SensingComponent [
    base:desc "Motor controller feedback providing motor speed"
    DTDFVocab:producedData MotorSpeedDataTransmitted
]

// -----------------------------------------------------
// Data Transmitted from Sensors
// -----------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionFeedback
]

instance MotorSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSpeedFeedback
]

// -----------------------------------------------------
// Time‑Series Data Records
// -----------------------------------------------------
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series swing‑angle measurements stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, SimulationEngineEnabler, ValidationEngineEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series wind‑speed measurements stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, SimulationEngineEnabler, ValidationEngineEnabler
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Time‑series motor‑position feedback stored in TimescaleDB"
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, SimulationEngineEnabler, ValidationEngineEnabler
]

instance MotorSpeedData : DTDFVocab:Data [
    base:desc "Time‑series motor‑speed feedback stored in TimescaleDB"
    DTDFVocab:fromData MotorSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, SimulationEngineEnabler, ValidationEngineEnabler
]

// -----------------------------------------------------
// Acting Components (Physical)
// -----------------------------------------------------
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart axis"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist cable"
]

instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval controller for the cart stepper motor"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval controller for the hoist stepper motor"
]

instance HoistElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist end for picking pucks"
]

instance ArduinoControllerBoard : DTDFVocab:ActingComponent [
    base:desc "Arduino board issuing PWM/IO signals to motor drivers and electromagnet"
]

// -----------------------------------------------------
// Digital Twin Models / Data
// -----------------------------------------------------
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane exported from Fusion360"
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model describing joint relationships of the crane"
    DTDFVocab:inputTo SimulationEngineEnabler, TrajectoryEngineEnabler
]

instance CraneDynamicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based dynamics simulation model of crane motion"
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance DistanceMetricValidationModel : DTDFVocab:Model [
    base:desc "Model for computing distance‑metric validation between executed and simulated trajectories"
    DTDFVocab:inputTo ValidationEngineEnabler
]

// -----------------------------------------------------
// Enablers (Tooling & Infrastructure)
// -----------------------------------------------------
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB PostgreSQL‑based time‑series database container"
    DTDFVocab:enables LoggingApplicationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Docker container running the physics simulation engine"
    DTDFVocab:enables SimulationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Docker container executing continuous validation algorithms"
    DTDFVocab:enables ContinuousValidationService
]

instance TrajectoryEngineEnabler : DTDFVocab:Enabler [
    base:desc "Docker container providing optimal trajectory generation"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Grafana container rendering real‑time dashboards"
    DTDFVocab:enables GrafanaDashboardService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for service signalling"
    DTDFVocab:enables MQTTBrokerService
]

// -----------------------------------------------------
// Services
// -----------------------------------------------------
instance LoggingApplicationService : DTDFVocab:Service [
    base:desc "Python logging application that writes sensor/actuator time‑series into TimescaleDB"
    DTDFVocab:provides StoreSensorDataAction
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboards visualising sensor plots, simulation confidence bounds, and alerts"
    DTDFVocab:provides RealTimeSensorPlotInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service that computes optimal motion plans for the crane"
    DTDFVocab:provides OptimalMotionPlanInsight, ExecuteMotionPlanAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation of crane dynamics using kinematic and CAD models"
    DTDFVocab:provides SimulationConfidenceBoundsInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates executed trajectories against simulated ones and raises deviation alerts"
    DTDFVocab:provides DeviationAlertInsight, AdjustControlParametersAction
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Message broker mediating MQTT events between twin services"
    DTDFVocab:provides MessageTransportInsight, PublishMessageAction
]

// -----------------------------------------------------
// Insights
// -----------------------------------------------------
instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Deviation alert generated when executed trajectory diverges from simulated trajectory"
]

instance OptimalMotionPlanInsight : DTDFVocab:Insight [
    base:desc "Optimal motion plan (set of waypoints and timings) proposed by the trajectory generator"
]

instance SimulationConfidenceBoundsInsight : DTDFVocab:Insight [
    base:desc "Confidence bounds indicating reliability of the current simulation results"
]

instance RealTimeSensorPlotInsight : DTDFVocab:Insight [
    base:desc "Live plots of swing angle, wind speed, and motor feedback shown on Grafana dashboards"
]

instance MessageTransportInsight : DTDFVocab:Insight [
    base:desc "Status of MQTT messages exchanged between twin services"
]

// -----------------------------------------------------
// Actions
// -----------------------------------------------------
instance StoreSensorDataAction : DTDFVocab:Action [
    base:desc "Persist incoming sensor and actuator time‑series into TimescaleDB"
    DTDFVocab:IsAutomatic true
]

instance ExecuteMotionPlanAction : DTDFVocab:Action [
    base:desc "Command the physical crane to follow the optimal motion plan"
    DTDFVocab:IsAutomatic false
]

instance AdjustControlParametersAction : DTDFVocab:Action [
    base:desc "Operator‑initiated adjustment of controller gains based on validation alerts"
    DTDFVocab:IsAutomatic false
]

instance PublishMessageAction : DTDFVocab:Action [
    base:desc "Publish MQTT messages to notify other services of state changes"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal motion trajectories and publishes them via MQTT; the Control Application subscribes, translates the trajectory into motor command sequences and sends them to the Physical Crane Interface, which drives the motors and electromagnet. The Human‑Machine Interface can also issue commands through the same path."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A C4‑style architecture where the Physical Crane Interface, Control Application, Logging Application, and Human‑Machine Interface run as Python processes on a PC; the digital twin services (Trajectory Generator, Simulation, Continuous Validation), MQTT broker, TimescaleDB, and Grafana run as Docker containers; communication occurs via MQTT messages and database reads/writes."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans design (CAD models of the crane in Autodesk Fusion360), modeling (kinematic model used by trajectory generation and simulation), and operation (real‑time logging, validation, and control during runtime)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured execution trajectories with simulated ones, computes distance metrics, and checks them against predefined thresholds; violations trigger operator alerts on the Grafana dashboard, ensuring model fidelity and operational validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication uses MQTT (Eclipse Mosquitto) for command and event signalling, and TCP/IP connections to a TimescaleDB instance for time‑series data transfer; the Physical Crane Interface accesses motor controllers and sensors via a Python‑based serial/USB link to the Arduino."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components are hosted on a single personal computer; Docker containers host the database, MQTT broker, and Grafana dashboard, while the remaining services run as Python processes within the gantrylib package. Deployment is automated with a Docker‑compose file and the code is publicly available on GitHub."
]