// C3: Physical sensing components
instance SwingAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder measuring pendulum motion of the hoist line"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed impacting crane operations"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor/encoder signals captured by the Arduino, monitoring stepper motor positions"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensor
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

// C1: Acting components
instance PhysicalCraneInterface : DTDFVocab:ActingComponent [
    base:desc "Python 'PhysicalCrane Interface' sending PWM/stepper commands to cart and hoist motors via Arduino"
]

instance ControlApplicationActuator : DTDFVocab:ActingComponent [
    base:desc "Control Application translating trajectory commands into low-level motor driver instructions"
]

// C10: Models
instance Fusion360CraneCADModel : DTDFVocab:Model [
    base:desc "Autodesk Fusion360 CAD model of the lab-scale gantry crane"
    DTDFVocab:inputTo CADModelEnabler
]

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Kinematic model used for optimal cart/hoist trajectory planning"
    DTDFVocab:inputTo KinematicModelEnabler
]

instance CraneControlSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of crane and controller dynamics"
    DTDFVocab:inputTo SimulationModelEnabler
]

// C10: Data
instance MotorStateTimeSeries : DTDFVocab:Data [
    base:desc "Time-series of motor states, currents, and cart positions stored in TimescaleDB"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance SensorReadingTimeSeries : DTDFVocab:Data [
    base:desc "Time-series of environmental sensor readings (wind speed) stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance SimulationOutputTimeSeries : DTDFVocab:Data [
    base:desc "Time-series of simulated trajectory outputs (position, velocity, swing angle)"
    DTDFVocab:inputTo SimulationModelEnabler
]

instance TrajectoryExecutionLogData : DTDFVocab:Data [
    base:desc "Log of executed trajectory commands and resulting motor states"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database extended PostgreSQL for efficient time-series storage"
    DTDFVocab:enables LoggingApplicationService, ContinuousValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter-service messaging"
    DTDFVocab:enables ContinuousValidationService, TrajectoryGeneratorService, SimulationService
]

instance SimulationModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for simulation dynamics model used by Simulation Service"
    DTDFVocab:enables SimulationService
]

instance PythonGantrylibEnabler : DTDFVocab:Enabler [
    base:desc "Python 'gantrylib' library enabling trajectory calculations"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for visualizing telemetry, alerts, and simulation results"
    DTDFVocab:enables GrafanaDashboardService
]

instance ArduinoUnoEnabler : DTDFVocab:Enabler [
    base:desc "Arduino Uno controller with custom KiCad shield enabling actuator command execution"
    DTDFVocab:enables ControlApplicationActuator
]

instance CADModelEnabler : DTDFVocab:Enabler [
    base:desc "CAD model repository enabling reference during design review"
    DTDFVocab:enables Fusion360CraneCADModel
]

instance KinematicModelEnabler : DTDFVocab:Enabler [
    base:desc "Kinematic model repository enabling trajectory planning calculations"
    DTDFVocab:enables KinematicTrajectoryModel
]

// C6: Services
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service computing distance metric between executed and simulated trajectories, alerting operators when deviations exceed thresholds"
    DTDFVocab:provides TrajectoryDeviationAlertInsight, RequestMaintenanceAction
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service computing optimal cart/hoist trajectories for zero-residual swing motion"
    DTDFVocab:provides OptimalTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service simulating crane and controller dynamics to generate expected trajectories and performance metrics"
    DTDFVocab:provides SimulationResultInsight
]

instance LoggingApplicationService : DTDFVocab:Service [
    base:desc "Service logging telemetry from sensors and actuators into TimescaleDB"
    DTDFVocab:provides DataLoggedInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Service visualizing live and historical data, alerts, and simulation outputs via Grafana dashboards"
    DTDFVocab:provides VisualizationDashboardInsight
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Eclipse Mosquitto MQTT broker for inter-service message passing"
    DTDFVocab:provides MQTTBrokerInsight
]

// C17: Insights / Actions
instance TrajectoryDeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert to operators when trajectory deviations exceed thresholds, prompting maintenance or recalibration"
]

instance RequestMaintenanceAction : DTDFVocab:Action [
    base:desc "Automatic trigger for maintenance or recalibration when trajectory deviations exceed thresholds"
    DTDFVocab:IsAutomatic true
]

instance OptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Command sequence generated by Trajectory Generator Service to execute optimal cart and hoist trajectory"
    DTDFVocab:IsAutomatic true
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight on simulated trajectory performance and swing angles, informing system dynamics"
]

instance DataLoggedInsight : DTDFVocab:Insight [
    base:desc "Log completion insight indicating successful recording of telemetry data"
]

instance VisualizationDashboardInsight : DTDFVocab:Insight [
    base:desc "Visualization of live and historical data, alerts, and simulation results in Grafana dashboards"
]

instance MQTTBrokerInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful inter-service message routing via Mosquitto MQTT broker"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT are sent via the Python Control Application to the Physical Crane Interface; the interface communicates over serial USB to the Arduino, which translates the commands into motor driver signals for the TMC4671 drivers driving the cart and hoist stepper motors."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Services operate continuously in real‑time; trajectory generation and validation are invoked on demand but leverage the continuous telemetry stream; database writes and dashboard updates occur at each logging interval; synchronization between PT and DT is performed continuously (real‑time) over the local network."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated locally via Docker Compose: database, broker, dashboard, trajectory generator, simulation, validation services; inter‑service communication via MQTT topics; physical interface via serial USB to Arduino; all services share a local network; the twin is hosted on a single PC and publicly available on GitHub."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers all three TAM phases: (i) design (CAD/kinematic model used for trajectory planning), (ii) manufacturing (physical crane built from BOM, firmware on Arduino), and (iii) operation (real‑time data logging, continuous validation and operator dashboard during runtime)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service computes distance metrics between recorded trajectories and their simulated counterparts, applying user‑defined thresholds to flag deviations; the kinematic and simulation models are validated against recorded sensor data; measurement noise from encoders and wind sensor acknowledged; updates to models are applied based on continuous validation results."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Local loopback network: Docker containers communicate over host network; MQTT broker uses TCP on localhost port 1883; TimescaleDB uses PostgreSQL protocol over TCP; Physical interface uses USB serial; no external network exposure reported."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin components are containerized and orchestrated through Docker Compose on a single personal computer; repository includes docker compose file that auto‑initializes TimescaleDB, Grafana, and Mosquitto; the Python module is pip‑installable; GitHub repository hosts source, documentation, and deployment scripts."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Open‑source standards: SQL/TimescaleDB for time‑series; MQTT for messaging; Docker and Docker‑Compose for deployment; Autodesk Fusion360 files for CAD; KiCad for PCB schematics; Capella/Arcadia for MBSE; adherence to these common open‑source tools supports interoperability."
]