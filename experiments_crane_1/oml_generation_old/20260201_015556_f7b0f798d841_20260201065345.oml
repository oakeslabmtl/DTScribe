// ===================== // Return code: 1 | Stderr:
// Sensing Components
// =====================

// Swing angle encoder measuring crane swinging motion
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder that measures the swinging motion of the hoist"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

// Anemometer measuring ambient wind speed
instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer that measures wind speed around the gantry crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// Motor state sensor (controller feedback) reporting stepper motor positions and currents
instance MotorStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that captures stepper motor states (position, speed, current) from the TMC4671‑Eval controllers"
    DTDFVocab:producedData MotorStateDataTransmitted
]

// =====================
// Data Transmitted (via MQTT)
// =====================

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStateSensor
]

// =====================
// Runtime Data (stored in TimescaleDB)
// =====================

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance MotorStateData : DTDFVocab:Data [
    base:desc "Time‑series of motor position, speed and current values"
    DTDFVocab:fromData MotorStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

// =====================
// Models
// =====================

instance CraneCADModel : DTDFVocab:Model [
    base:desc "Detailed CAD geometry of the gantry crane created in Autodesk Fusion360"
    DTDFVocab:inputTo PythonGanryLibEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used for swing‑free trajectory planning"
    DTDFVocab:inputTo PythonGanryLibEnabler
]

instance CraneDynamicModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model representing crane dynamics and controller behavior"
    DTDFVocab:inputTo PythonGanryLibEnabler
]

// =====================
// Enablers (Tools & Platforms)
// =====================

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance used for time‑series storage"
    DTDFVocab:enables DataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker facilitating message exchange between physical interface and services"
    DTDFVocab:enables DataLoggingService, TrajectoryGenerationService, SimulationService, ContinuousValidationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for real‑time visualization of sensor data and simulation confidence bounds"
    DTDFVocab:enables VisualizationService
]

instance PythonGanryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantry‑crane library (gantrylib) providing algorithms for trajectory generation, simulation and validation"
    DTDFVocab:enables TrajectoryGenerationService, SimulationService, ContinuousValidationService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑Compose setup that orchestrates all containerised services"
    DTDFVocab:enables DataLoggingService, VisualizationService, TrajectoryGenerationService, SimulationService, ContinuousValidationService
]

// =====================
// Services
// =====================

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Collects data from MQTT and writes time‑stamped records to TimescaleDB"
    DTDFVocab:provides DataLoggingInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time dashboards via Grafana, displaying sensor data and simulation confidence bounds"
    DTDFVocab:provides ConfidenceBoundInsight, OperatorAlertAction
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free motion plans using the crane kinematic model"
    DTDFVocab:provides MotionPlanInsight, TrajectoryReplanAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Emulates crane dynamics and controller behavior based on the dynamic model"
    DTDFVocab:provides ConfidenceBoundInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories with simulated ones, computes error metrics and raises alerts when thresholds are exceeded"
    DTDFVocab:provides ErrorMetricInsight, OperatorAlertAction
]

// =====================
// Insights
// =====================

instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Insight providing information about data logging status and health"
]

instance MotionPlanInsight : DTDFVocab:Insight [
    base:desc "Optimal swing‑free trajectory generated for the crane"
]

instance ConfidenceBoundInsight : DTDFVocab:Insight [
    base:desc "Simulation confidence bounds displayed on Grafana to aid operator decision‑making"
]

instance ErrorMetricInsight : DTDFVocab:Insight [
    base:desc "Quantitative error metrics indicating deviation between actual and simulated trajectories"
]

// =====================
// Actions
// =====================

instance OperatorAlertAction : DTDFVocab:Action [
    base:desc "Operator alert triggered when error metrics exceed predefined thresholds"
    DTDFVocab:IsAutomatic true
]

instance TrajectoryReplanAction : DTDFVocab:Action [
    base:desc "Automatic re‑planning of the crane trajectory based on validation feedback"
    DTDFVocab:IsAutomatic true
]

// =====================
// Acting Components
// =====================

instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart, controlled by a TMC4671‑Eval controller"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist, controlled by a TMC4671‑Eval controller"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist for picking up experimental pucks"
]

// =====================
// Environment (Docker Containers)
// =====================

instance DockerEnvironment : DTDFVocab:Environment [
    base:contains DataLoggingService, VisualizationService, TrajectoryGenerationService, SimulationService, ContinuousValidationService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands such as trajectory set‑points generated by the Trajectory Generator Service, or manual commands from the Human‑Machine Interface, are sent from the Control Application through the Physical Crane Interface to the motor controllers and electromagnet, effecting motion of the cart and hoist."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall constellation consists of the physical crane linked via a Python interface to a set of digital services. Data flows from the crane to the MQTT broker and TimescaleDB; services (trajectory generation, simulation, validation) subscribe to MQTT topics, process data, and publish results back to the broker or database; the HMI visualises data on Grafana and issues operator commands back to the crane through the same interface."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin covers the design stage (CAD models in Autodesk Fusion360 and a kinematic model), the manufacturing/assembly stage (BOM and hardware components), and the operational stage (runtime data acquisition, monitoring, and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by using a physics‑based kinematic model for trajectory planning and a detailed simulation of crane dynamics; validity is continuously assessed by the Continuous Validation Service, which computes distance metrics between measured trajectories and simulated counterparts, compares them against an acceptable threshold, and notifies operators via the dashboard when the threshold is breached."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT relies on MQTT (Eclipse Mosquitto) for event signalling and Python sockets for the Physical Crane Interface; sensor data and control commands are transmitted over TCP/IP within the local host environment where all containers run."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin’s services (database, MQTT broker, Grafana) are deployed as Docker containers orchestrated by a Docker‑Compose file; the remaining Python applications (gantrylib, control, logging, HMI) run directly on the host PC. The entire system is hosted on a personal computer and distributed via an open‑source GitHub repository."
]