// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder mounted on the hoist to measure azimuth"
    DTDFVocab:producedData SwingAngleTelemetry
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Low‑cost anemometer mounted on the crane to monitor wind speed"
    DTDFVocab:producedData WindSpeedTelemetry
]

// C4: Physical‑to‑virtual interaction
instance SwingAngleTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Models/Data
instance SensorData : DTDFVocab:Data [
    base:desc "Collected sensor readings from swing‑angle encoder and anemometer, persisted in TimescaleDB"
    DTDFVocab:fromData SwingAngleTelemetry, WindSpeedTelemetry
    DTDFVocab:inputTo TimescaleDBDatabase, PythonRuntime
]

instance TrajectoryTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TrajectoryGeneratorService
]

instance TrajectoryData : DTDFVocab:Data [
    base:desc "Feasible cargo movement trajectories computed by the Trajectory Generator Service, stored in TimescaleDB"
    DTDFVocab:fromData TrajectoryTelemetry
    DTDFVocab:inputTo TimescaleDBDatabase, PythonRuntime
]

instance SimulationTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationService
]

instance SimulationData : DTDFVocab:Data [
    base:desc "Dynamic simulation results of the crane motion from Simulation Service, persisted in TimescaleDB"
    DTDFVocab:fromData SimulationTelemetry
    DTDFVocab:inputTo TimescaleDBDatabase, PythonRuntime
]

instance ValidationTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ValidationService
]

instance ValidationReportData : DTDFVocab:Data [
    base:desc "Validation reports comparing measured actuator positions to model predictions produced by Validation Service, stored in TimescaleDB"
    DTDFVocab:fromData ValidationTelemetry
    DTDFVocab:inputTo TimescaleDBDatabase, PythonRuntime
]

instance GantryCADModel : DTDFVocab:Model [
    base:desc "CAD model of the lab‑scale gantry crane generated with Autodesk Fusion 360"
    DTDFVocab:inputTo Fusion360CADTool, GAntyLibPythonModule
]

instance GantryKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model capturing geometry and motion constraints of the crane, used by the Trajectory Generator Service"
    DTDFVocab:inputTo PythonRuntime
]

// C11: Enablers
instance DockerContainerization : DTDFVocab:Enabler [
    base:desc "Docker containerization used to deploy isolated Python services, MQTT broker, TimescaleDB, and Grafana"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, DataLoggingService, ValidationService, VisualizationDashboardService
]

instance PythonRuntime : DTDFVocab:Enabler [
    base:desc "Python application runtime for Trajectory Generator, Simulation, Data Logging, and Validation services"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, DataLoggingService, ValidationService
]

instance MQTTBrokerEclipseMosquitto : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for inter-service and physical‑to‑virtual communication on dedicated topics for commands, telemetry, and validation reports"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, DataLoggingService, ValidationService, VisualizationDashboardService
]

instance TimescaleDBDatabase : DTDFVocab:Enabler [
    base:desc "TimescaleDB PostgreSQL time‑series database for persisting trajectory, sensor, simulation, and validation data"
    DTDFVocab:enables DataLoggingService, ValidationService, VisualizationDashboardService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboards displaying live state, historical data, and alerts for operators"
    DTDFVocab:enables VisualizationDashboardService
]

instance GAntyLibPythonModule : DTDFVocab:Enabler [
    base:desc "Custom Python module 'gantrylib' providing kinematic computations"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService
]

instance Fusion360CADTool : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion 360 used to generate the CAD geometry of the crane"
    DTDFVocab:enables DataLoggingService
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service that computes feasible cargo trajectories using the kinematic model and sends command trajectories to actuator controllers"
    DTDFVocab:provides OptimalTrajectoryInsight, SendCommandAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that executes dynamic simulations of crane motion producing virtual trajectory data for comparison with real executions"
    DTDFVocab:provides SimulationOutcomeInsight
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Python Logging Application that streams state information from the Physical Crane interface into TimescaleDB in real‑time"
    DTDFVocab:provides RealTimeTelemetryInsight
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Service that performs continuous model‑validation comparing measured actuator positions to model predictions"
    DTDFVocab:provides ValidationReportInsight, AlertAction
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Service that provides real‑time monitoring, historical data visualization, and alerting via Grafana dashboards"
    DTDFVocab:provides HistoricalTrendInsight
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Computed optimal trajectory plan for cargo pucks, guiding operators toward efficient and safe motion"
]

instance SendCommandAction : DTDFVocab:Action [
    base:desc "Sends high‑level trajectory commands to stepper motor controllers over MQTT"
    DTDFVocab:IsAutomatic true
]

instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Resulting trajectory data from dynamic simulations for comparison against real executions"
]

instance RealTimeTelemetryInsight : DTDFVocab:Insight [
    base:desc "Live telemetry of crane state from sensor data displayed in Grafana dashboards"
]

instance ValidationReportInsight : DTDFVocab:Insight [
    base:desc "Validation report detailing deviations between measured motion and model predictions"
]

instance AlertAction : DTDFVocab:Action [
    base:desc "Triggers alerts to operators when validation thresholds are exceeded"
    DTDFVocab:IsAutomatic true
]

instance HistoricalTrendInsight : DTDFVocab:Insight [
    base:desc "Trend analysis of historical data between past crane operations and predicted performance"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Trajectory Generator Service are executed by the Control Application via the Physical Crane Interface. The specific command formats, validation, authentication, feedback, conflict resolution, or execution confirmation mechanisms are not described in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Docker Compose orchestrates three containers: a TimescaleDB instance (PostgreSQL with time‑series extension) for permanent storage of telemetry and control logs, an Eclipse Mosquitto MQTT broker for real‑time messaging between the Arduino on the crane and the software stack, and a web‑based dashboard for runtime visualization and supervisory control.  Two Python applications run on the host PC: one is a logging daemon that consumes MQTT messages and writes them into TimescaleDB; the other is an HMI that serves the web dashboard and exposes REST endpoints for external interfaces."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A Continuous Validation Service runs in parallel to the crane operation, continually comparing the real‑world trajectory telemetry against the virtual trajectory generated by the Simulation Service. It computes a distance metric (e.g., Euclidean distance between corresponding pose samples) and applies a predefined acceptance threshold. If the metric exceeds the threshold, the service notifies operators via the operator dashboard, enabling rapid investigation and corrective action."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system uses an MQTT broker for inter-service signaling and a TimescaleDB server as the data store. The document mentions MQTT and the database protocol but does not detail network topology, bandwidth, latency, reliability, redundancy, or security requirements for the communication infrastructure."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system is deployed on on‑premise hardware running Python applications, TimescaleDB, Grafana, and an MQTT broker. No cloud or edge deployment details are provided. Computational and storage requirements, scalability mechanisms, and redundancy are not specified in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External integration is achieved via the MQTT protocol.  The Arduino publishes sensor telemetry and receives control commands on MQTT topics (e.g., crane/status, crane/command).  External clients, such as operator stations or other systems, can subscribe to or publish on these topics for real‑time interaction.  Historical data can be queried from TimescaleDB through standard SQL over the network.  No additional enterprise or cloud integration (e.g., Azure) is defined in the exemplar."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The GreenhouseDT exemplar employs open‑source tools: InfluxDB for time‑series data storage and ActiveMQ as a message broker, deployed via virtual machine images. The Air Quality Management exemplar is based on an AutomationML digital twin model and uses Microsoft Azure services. No explicit industry‑standard compliance, certification, or interoperability frameworks are documented in the provided excerpts."
]