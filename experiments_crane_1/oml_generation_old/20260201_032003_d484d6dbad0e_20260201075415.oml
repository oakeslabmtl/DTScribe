// C3: Physical sensing components (logging application acts as a sensor)
instance CraneStateLogger : DTDFVocab:SensingComponent [
    base:desc "Python logging application that continuously reads the crane's state from the physical controller"
    DTDFVocab:producedData CraneStateMessage
]

// C4: Physical-to-virtual interaction
instance CraneStateMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneStateLogger
]

instance CraneStateData : DTDFVocab:Data [
    base:desc "Historical time‑series of crane sensor and actuator measurements stored in TimescaleDB"
    DTDFVocab:fromData CraneStateMessage
    DTDFVocab:inputTo TimescaleDBContainer
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "CAD‑derived kinematic model of the laboratory‑scale gantry crane"
    DTDFVocab:inputTo PythonLogicContainer
]

instance ControlAlgorithmModel : DTDFVocab:Model [
    base:desc "Optimal‑control algorithm model used to compute crane motion commands"
    DTDFVocab:inputTo PythonLogicContainer
]

// C11: Enablers
instance PythonLogicContainer : DTDFVocab:Enabler [
    base:desc "Docker‑packaged Python modules implementing twin logic, optimal control and validation"
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

instance TimescaleDBContainer : DTDFVocab:Enabler [
    base:desc "Dockerized TimescaleDB instance for persisting crane state time‑series"
    DTDFVocab:enables HistoricalLoggingService
]

instance MQTTBrokerContainer : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating bi‑directional publish/subscribe between the physical crane controller and digital services"
]

instance GrafanaDashboardContainer : DTDFVocab:Enabler [
    base:desc "Grafana dashboard container visualising crane state and logged data"
    DTDFVocab:enables DataVisualizationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service that calculates and dispatches optimal control commands to the crane"
    DTDFVocab:provides DispatchControlCommandAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Service that archives sensor and actuator data continuously"
    DTDFVocab:provides HistoricalTrendInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service that displays real‑time crane state and historical data via Grafana"
    DTDFVocab:provides VisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously validates live measurements against the kinematic model"
    DTDFVocab:provides ValidationInsight, TriggerValidationAlertAction
]

// C17: Insights/Actions
instance DispatchControlCommandAction : DTDFVocab:Action [
    base:desc "Dispatches calculated control command to the crane actuator"
    DTDFVocab:IsAutomatic true
]

instance HistoricalTrendInsight : DTDFVocab:Insight [
    base:desc "Insight into historical trends of crane operation derived from logged data"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight presented on the Grafana dashboard showing real‑time and historical crane status"
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating conformity of live measurements with the kinematic model"
]

instance TriggerValidationAlertAction : DTDFVocab:Action [
    base:desc "Triggers an alert when validation detects deviation from the kinematic model"
    DTDFVocab:IsAutomatic true
]

// Optional: System description
instance LaboratoryGantryCraneSystem : DTDFVocab:Environment [
    base:contains CraneStructureComponent, CraneControllerComponent
]

instance CraneStructureComponent : DTDFVocab:Component [
    base:desc "Mechanical structure of the laboratory‑scale gantry crane"
]

instance CraneControllerComponent : DTDFVocab:Component [
    base:desc "Electronic controller that drives crane motions"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, a Python program, uses the Physical Crane Interface to send control commands to the crane’s controllers. Commands are generated by higher‑level digital‑twin services (e.g., the Trajectory Generator) and passed through the interface; the document provides no details on command types, message formats, validation/authentication, feedback, conflict resolution, or execution confirmation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The lab‑scale gantry crane exemplar adopts an ad‑hoc architecture that relies on containerisation (e.g., Docker) for packaging its software components instead of a commercial digital‑twin framework. Its software architecture is described using the C4 modelling approach with context and container diagrams."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin relies on an MQTT broker for signaling between containers (e.g., Trajectory Generator, Simulation, Continuous Validation). MQTT operates over TCP, but the document does not describe the network topology, bandwidth or latency requirements, redundancy mechanisms, or security protocols used for the connection."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All five system containers (Physical Crane, Physical Crane Interface, Control Application, Logging Application, Human Machine Interface) and the six digital‑twin containers (Database, Dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service, MQTT Broker) are deployed as software containers on local hardware (on‑premise PC). The database runs TimescaleDB, the dashboard uses Grafana, and the MQTT broker provides signalling. The documentation does not mention cloud or edge platforms, explicit compute or storage specifications, scalability mechanisms, deployment models beyond containerisation, or availability guarantees."
]