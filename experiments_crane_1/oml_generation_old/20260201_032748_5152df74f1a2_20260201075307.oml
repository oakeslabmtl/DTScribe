// C3: Physical sensing components
instance IndoorAirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry‑Pi equipped with indoor air‑quality sensors for the AutomationML digital twin"
    DTDFVocab:producedData AirQualityDataTransmitted
]

instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Physical crane interface capturing position and sensor readings of the laboratory gantry crane"
    DTDFVocab:producedData CraneStateDataTransmitted
]

instance PreRecordedGreenhouseSensor : DTDFVocab:SensingComponent [
    base:desc "Prerecorded greenhouse sensor data stored in InfluxDB used for behavioural adaptation"
    DTDFVocab:producedData GreenhouseRecordedDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndoorAirQualitySensor
]

instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor
]

instance GreenhouseRecordedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PreRecordedGreenhouseSensor
]

// C10: Data
instance AirQualitySensorData : DTDFVocab:Data [
    base:desc "Live indoor air‑quality measurements streamed from the Raspberry‑Pi"
    DTDFVocab:fromData AirQualityDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, GrafanaEnabler, SimulationEngineEnabler
]

instance CraneStateData : DTDFVocab:Data [
    base:desc "Continuous time‑series of crane position and operational parameters"
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler, GrafanaEnabler
]

instance GreenhouseHistoricalData : DTDFVocab:Data [
    base:desc "Prerecorded greenhouse sensor time‑series stored in InfluxDB"
    DTDFVocab:fromData GreenhouseRecordedDataTransmitted
    DTDFVocab:inputTo InfluxDBEnabler, AzureCloudEnabler, DockerOrchestrationEnabler
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for runtime communication between physical devices and the digital twin"
    DTDFVocab:enables RuntimeVisualizationService, DataVisualizationService, OptimalControlService
]

instance ActiveMQEnabler : DTDFVocab:Enabler [
    base:desc "ActiveMQ broker used by GreenhouseDT for message exchange"
    DTDFVocab:enables HistoricalLoggingService
]

instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database storing greenhouse data"
    DTDFVocab:enables HistoricalLoggingService, AdaptiveBehaviourService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database persisting crane operational data"
    DTDFVocab:enables HistoricalLoggingService
]

instance DockerOrchestrationEnabler : DTDFVocab:Enabler [
    base:desc "Docker container runtime orchestrating all twin services"
    DTDFVocab:enables OptimalControlService, SimulationService, PredictionService, ContinuousValidationService, AdaptiveBehaviourService, DataVisualizationService
]

instance AzureCloudEnabler : DTDFVocab:Enabler [
    base:desc "Microsoft Azure hosting environment for the AutomationML twin"
    DTDFVocab:enables RuntimeVisualizationService, SimulationService, PredictionService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana platform providing visual dashboards"
    DTDFVocab:enables RuntimeVisualizationService, DataVisualizationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine (e.g., Python/Modelica) executing system dynamics and forecasts"
    DTDFVocab:enables SimulationService, PredictionService
]

// C10: Models/Data
instance AutomationMLModel : DTDFVocab:Model [
    base:desc "AutomationML‑based representation of the indoor air‑quality twin"
    DTDFVocab:inputTo DockerOrchestrationEnabler
]

instance GreenhouseBehaviourModel : DTDFVocab:Model [
    base:desc "Behavioural adaptation model allowing the greenhouse twin to adjust based on observed data"
    DTDFVocab:inputTo DockerOrchestrationEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "CAD and kinematic model of the laboratory gantry crane"
    DTDFVocab:inputTo DockerOrchestrationEnabler
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Mathematical model used for simulating system dynamics"
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance PredictionModel : DTDFVocab:Model [
    base:desc "Predictive model generating forecasts of future air‑quality and crane states"
    DTDFVocab:inputTo SimulationEngineEnabler
]

// C6: Services
instance RuntimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides runtime visualisation of sensor streams via Grafana"
    DTDFVocab:provides RuntimeVisualizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Executes system dynamics simulation using the SimulationModel"
    DTDFVocab:provides SimulationInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Generates future‑state forecasts based on the PredictionModel"
    DTDFVocab:provides PredictionInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes and dispatches optimal control commands for crane motions"
    DTDFVocab:provides ControlAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Continuously logs operational parameters to TimescaleDB/InfluxDB"
    DTDFVocab:provides AdaptiveBehaviourInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Visualises crane state and performance metrics"
    DTDFVocab:provides RuntimeVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates live sensor data against CAD and kinematic models"
    DTDFVocab:provides ValidationAction
]

instance AdaptiveBehaviourService : DTDFVocab:Service [
    base:desc "Adapts the greenhouse twin behaviour based on incoming data"
    DTDFVocab:provides AdaptiveBehaviourInsight
]

// C17: Insights / Actions
instance RuntimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Runtime visualisation of sensor streams for operator monitoring"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation of system dynamics to explore hypothetical scenarios"
]

instance PredictionInsight : DTDFVocab:Insight [
    base:desc "Prediction of future states for proactive decision making"
]

instance AdaptiveBehaviourInsight : DTDFVocab:Insight [
    base:desc "Behavioural adaptation of the twin based on observed data"
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Automatically adjusts crane motion parameters for optimal control"
    DTDFVocab:IsAutomatic true
]

instance ValidationAction : DTDFVocab:Action [
    base:desc "Automatically compares live data with CAD/kinematic models for validation"
    DTDFVocab:IsAutomatic true
]

// C1: System components and environment
instance GantryCraneComponent : DTDFVocab:Component [
    base:desc "Laboratory‑scale gantry crane including mechanical structure and controller"
]

instance AirQualityTwinComponent : DTDFVocab:Component [
    base:desc "AutomationML digital twin for indoor air‑quality monitoring"
]

instance GreenhouseComponent : DTDFVocab:Component [
    base:desc "Physical greenhouse whose data are stored in InfluxDB for behavioural adaptation"
]

instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains GantryCraneComponent, AirQualityTwinComponent, GreenhouseComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are issued by the Control Application, a Python program that uses the Physical Crane Interface to communicate with the crane’s controllers. The document states that the Control Application “uses the crane interface to control the crane,” implying that command messages (e.g., motion set‑points) are sent from the digital‑twin side to the physical hardware. Details such as command formatting, validation, authentication, or acknowledgment mechanisms are not provided."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The lab‑scale gantry crane digital twin adopts an ad‑hoc architectural style rather than a commercial DT framework. Its software components are modelled with the C4 method and are packaged as Docker containers (e.g., database, MQTT broker, dashboard) to enable easy deployment via virtualization/containerisation. Coordination among components is performed by custom services written for the exemplar, with no explicit orchestration platform described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin relies on an MQTT broker for signaling between the Trajectory Generator Service, Simulation Service, Continuous Validation Service, and other components. Services also access the TimescaleDB database directly (presumably over a standard database client) and the Grafana Dashboard reads from this database. The document does not detail network topology, bandwidth, latency, redundancy, or security protocols beyond the use of MQTT for messaging."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software components of the digital twin (Database, MQTT broker, Logging Application, Control Application, Trajectory Generator Service, Simulation Service, Continuous Validation Service, Dashboard, and Human‑Machine Interface) are intended to run on a single personal computer. The components are packaged as Docker containers, allowing them to be started on the host machine without additional orchestration infrastructure. Thus the deployment is on‑premise/edge, container‑based, with storage provided by the local TimescaleDB instance and compute supplied by the host PC. No cloud platforms, scalability mechanisms, or high‑availability features are described."
]