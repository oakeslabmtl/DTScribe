// -----------------------------------------------------------------------------
// C2: Acting Components (Physical Acting Components)
// -----------------------------------------------------------------------------
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cartesian stepper motor of the lab‑scale gantry crane, drives the crane carriage."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor of the lab‑scale gantry crane, lifts the load."
]

instance TrinamicDriverCart : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval controller driving the cart stepper motor."
]

instance TrinamicDriverHoist : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval controller driving the hoist stepper motor."
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted at the hoist end, used to pick up small pucks."
]

// -----------------------------------------------------------------------------
// C3: Physical Sensing Components
// -----------------------------------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing on the physical crane."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed on the physical crane."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// -----------------------------------------------------------------------------
// C4: Physical‑to‑Virtual Interaction (Data Transmission)
// -----------------------------------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

// -----------------------------------------------------------------------------
// C10: Data (Timeseries stored in TimescaleDB)
// -----------------------------------------------------------------------------
instance SwingAngleTimeseriesData : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle stream stored in TimescaleDB."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEngine
]

instance WindSpeedTimeseriesData : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed stream stored in TimescaleDB."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEngine
]

// -----------------------------------------------------------------------------
// C10: Models
// -----------------------------------------------------------------------------
instance CraneCAD3DModel : DTDFVocab:Model [
    base:desc "Detailed 3‑D CAD geometry of the gantry crane used for visualisation."
    DTDFVocab:inputTo GrafanaDashboardEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model describing cart and hoist motion used for trajectory planning."
    DTDFVocab:inputTo TrajectoryGeneratorEngine, PhysicsSimulationEngine
]

instance CraneControllerModel : DTDFVocab:Model [
    base:desc "Controller model representing the control law executed by the crane controller."
    DTDFVocab:inputTo PhysicsSimulationEngine
]

// -----------------------------------------------------------------------------
// C11: Enablers (Tools & Platforms)
// -----------------------------------------------------------------------------
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) storing time‑series sensor data."
    DTDFVocab:enables DataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker forwarding sensor streams to digital‑twin services."
    DTDFVocab:enables ContinuousValidationEngine, TrajectoryGeneratorEngine, PhysicsSimulationEngine
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard visualising sensor data and simulation results."
    DTDFVocab:enables DashboardVisualizationService
]

instance TrajectoryGeneratorEngine : DTDFVocab:Enabler [
    base:desc "Trajectory generator service (Docker container) producing swing‑free motion plans."
    DTDFVocab:enables TrajectoryGenerationService
]

instance PhysicsSimulationEngine : DTDFVocab:Enabler [
    base:desc "Physics‑based simulation service (Docker container) evaluating crane dynamics."
    DTDFVocab:enables PhysicsSimulationService
]

instance ContinuousValidationEngine : DTDFVocab:Enabler [
    base:desc "Continuous validation service (Docker container) comparing measured and simulated trajectories."
    DTDFVocab:enables ContinuousValidationService
]

// -----------------------------------------------------------------------------
// C6: Services (Digital‑Twin Functionalities)
// -----------------------------------------------------------------------------
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuous data logging service streaming sensor data into TimescaleDB."
    DTDFVocab:provides DataLoggedInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Grafana‑based visualisation service presenting live sensor and simulation data."
    DTDFVocab:provides DashboardUpdateInsight, AdjustOperatorParametersAction
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal, swing‑free motion trajectories using the kinematic model."
    DTDFVocab:provides OptimalSwingFreeTrajectoryInsight, GenerateOptimalTrajectoryAction
]

instance PhysicsSimulationService : DTDFVocab:Service [
    base:desc "Runs physics‑based simulation of planned trajectories with the controller model."
    DTDFVocab:provides SimulationRunInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates measured trajectories against simulated ones and raises alerts."
    DTDFVocab:provides FidelityThresholdAlert
]

// -----------------------------------------------------------------------------
// C17: Insights & Actions
// -----------------------------------------------------------------------------
instance DataLoggedInsight : DTDFVocab:Insight [
    base:desc "Indicates that sensor data have been successfully persisted in TimescaleDB."
]

instance DashboardUpdateInsight : DTDFVocab:Insight [
    base:desc "Visual dashboard reflects the latest sensor and simulation data."
]

instance OptimalSwingFreeTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Trajectory generator has produced an optimal swing‑free motion plan."
]

instance SimulationRunInsight : DTDFVocab:Insight [
    base:desc "Physics simulation completed for the proposed trajectory."
]

instance FidelityThresholdAlert : DTDFVocab:Insight [
    base:desc "Validation service alerts: measured trajectory deviates beyond fidelity thresholds."
]

instance GenerateOptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatically generate an optimal trajectory for the crane."
    DTDFVocab:IsAutomatic true
]

instance AdjustOperatorParametersAction : DTDFVocab:Action [
    base:desc "Operator adjusts control parameters via the HMI based on dashboard visualisation."
    DTDFVocab:IsAutomatic false
]

// -----------------------------------------------------------------------------
// C5: Physical & Virtual Containers (Multiplicity)
// -----------------------------------------------------------------------------
instance PhysicalCraneInterfaceContainer : DTDFVocab:Component [
    base:desc "Docker container running the Physical Crane Interface Python program."
]

instance ControlApplicationContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the crane control application."
]

instance LoggingApplicationContainer : DTDFVocab:Component [
    base:desc "Docker container executing the continuous logging application."
]

instance HumanMachineInterfaceContainer : DTDFVocab:Component [
    base:desc "Docker container providing the operator HMI (web UI)."
]

instance TimescaleDBContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the TimescaleDB time‑series database."
]

instance GrafanaDashboardContainer : DTDFVocab:Component [
    base:desc "Docker container running Grafana for dashboard visualisation."
]

instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Docker container running Eclipse Mosquitto MQTT broker."
]

instance TrajectoryGeneratorServiceContainer : DTDFVocab:Component [
    base:desc "Docker container implementing the trajectory generator service."
]

instance SimulationServiceContainer : DTDFVocab:Component [
    base:desc "Docker container implementing the physics‑based simulation service."
]

instance ContinuousValidationServiceContainer : DTDFVocab:Component [
    base:desc "Docker container implementing the continuous validation service."
]

// -----------------------------------------------------------------------------
// C8: Tooling & Enablers (Implementation Stack)
// -----------------------------------------------------------------------------
// (Already captured via Enablers above – Python, gantrylib, Docker, GitHub, etc.)

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application uses the Physical Crane Interface to transmit command messages (velocity/position set‑points, electromagnet activation) to the motor controllers, and the Trajectory Generator Service provides optimal trajectory set‑points that are executed on the crane in real time."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall constellation consists of a physical crane linked via a Python interface to control, logging and HMI applications; virtual services run as Docker containers communicating through MQTT, persisting data in TimescaleDB, and exposing visualisations through Grafana, forming a tightly coupled cyber‑physical loop."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the as‑designed stage (CAD models of the crane in Autodesk Fusion360), the as‑built stage (kinematic model derived from the physical hardware), and the as‑operated stage (real‑time sensor data, logged trajectories and validation results)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by the Continuous Validation Service, which continuously compares measured trajectories with simulated ones using distance metrics and predefined thresholds; violations trigger operator notifications on the dashboard, providing a runtime validation loop."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑component communication uses TCP/IP‑based MQTT (Eclipse Mosquitto) for signaling and PostgreSQL protocol for TimescaleDB access; the Python interfaces exchange JSON‑like messages over the local network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software runs on a single personal computer; the database, MQTT broker and Grafana are containerised with Docker, started via a Docker‑Compose file; the Python modules are installed with pip; the complete repository is hosted publicly on GitHub under an MIT licence."
]