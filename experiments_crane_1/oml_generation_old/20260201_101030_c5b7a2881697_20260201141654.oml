// C3: Physical sensing components // Return code: 1 | Stderr:
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑Angle Encoder (rotary encoder, 10 kHz sampling, 0.1° resolution) mounted on the hoist shaft reports swing dynamics."
    DTDFVocab:producedData SwingAngleEncoderTx
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed (0‑35 m/s, 2 Hz update rate) embedded at the upper gantry section."
    DTDFVocab:producedData AnemometerTx
]

instance ArduinoSerialHub : DTDFVocab:SensingComponent [
    base:desc "Arduino microcontroller collects raw sensor signals and exposes them via a serial UART to the Raspberry‑Pi Pi forwards data to the Logging Application."
    DTDFVocab:producedData ArduinoTelemetryTx
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance SwingAngleEncoderTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance ArduinoTelemetryTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoSerialHub
]

instance KinematicPredictionTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationEngineService
]

// C10: Models/Data (Data)
instance CraneTelemetryData : DTDFVocab:Data [
    base:desc "Complete state history (position, velocity, motor currents, encoder angles) persisted in TimescaleDB by the Logging Application."
    DTDFVocab:fromData ArduinoTelemetryTx
    DTDFVocab:inputTo LoggingEnabler
]

instance PredictedTrajectoryData : DTDFVocab:Data [
    base:desc "Trajectory predictions generated by the kinematic model in MATLAB/Simulink, representing expected cart and hoist positions over time."
    DTDFVocab:fromData KinematicPredictionTx
    DTDFVocab:inputTo ValidationEnabler
]

// C11: Enablers
instance PythonCraneInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Python‑based Physical Crane Interface controlling stepper motors and reading encoder data implements actuation commands."
    DTDFVocab:enables MotionPlanningControlService
]

instance LoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB persistence service by the Logging Application that writes telemetry to the time‑series database."
    DTDFVocab:enables HistoricalLoggingService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "MQTT‑based Continuous Validation Service comparing real‑time measured states against simulation predictions."
    DTDFVocab:enables ContinuousValidationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard service providing interactive real‑time visualization of crane state and predictions."
    DTDFVocab:enables RuntimeVisualizationService
]

instance DiagnosticEnabler : DTDFVocab:Enabler [
    base:desc "MQTT‑based Diagnostic Monitoring Service observing controller health and safety events."
    DTDFVocab:enables DiagnosticMonitoringService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink engine executing kinematic forward calculations to produce trajectory predictions."
    DTDFVocab:enables SimulationEngineService
]

// C6: Services
instance MotionPlanningControlService : DTDFVocab:Service [
    base:desc "Optimal motion‑planning and control of the gantry based on its kinematic model."
    DTDFVocab:provides OptimalMotionPlanInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation of executed trajectories against model predictions."
    DTDFVocab:provides TrajectoryValidationInsight
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Historical trajectory and state logging for post‑hoc analysis."
    DTDFVocab:provides HistoricalLogInsight
]

instance RuntimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time data visualization via graphical interfaces."
    DTDFVocab:provides VisualizedStateInsight
]

instance DiagnosticMonitoringService : DTDFVocab:Service [
    base:desc "Diagnostic monitoring of the physical controller."
    DTDFVocab:provides DiagnosticInsight
]

instance SimulationEngineService : DTDFVocab:Service [
    base:desc "Simulation engine executing forward kinematics to generate trajectory predictions."
]

// C17: Insights / Actions
instance OptimalMotionPlanInsight : DTDFVocab:Insight [
    base:desc "Optimal motion plan for the gantry derived from the kinematic constraints."
]

instance TrajectoryValidationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating whether the real trajectory matches the prediction within tolerance."
]

instance VisualizedStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of crane state provided to end‑users."
]

instance DiagnosticInsight : DTDFVocab:Insight [
    base:desc "Insight indicating controller status or fault detection."
]

instance HistoricalLogInsight : DTDFVocab:Insight [
    base:desc "Insight representing historical telemetry logs for post‑hoc analysis."
]

instance PublishVisualizationAction : DTDFVocab:Action [
    base:desc "Action to publish updated visualization to dashboards."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Control Application (using trajectory data from the Trajectory Generator Service) are sent to the Physical Crane via the Physical Crane Interface, which forwards the instructions to the crane’s hardware controllers. The documents provide no detail on validation, authentication, feedback, conflict resolution, or command execution confirmation mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin system follows a C4 container architectural model and is deployed in six Docker containers to separate concerns and simplify orchestration. The containers are: (1) an MQTT broker that serves as the central signaling medium for inter-service communication; (2) a twin core container housing the simulation engine and state model that represents the physical gantry crane; (3) a data store container (e.g., InfluxDB) that persists time‑series sensor and telemetry data; (4) a gateway service container responsible for ingesting sensor data from the physical crane’s onboard Raspberry‑Pi; (5) a web dashboard container that visualizes the twin’s state and analytics for operators; and (6) a monitoring/alerts container that performs anomaly detection and generates notifications. The containers communicate through MQTT topics and shared database access, creating a decoupled yet coordinated runtime environment that facilitates maintenance, scaling, and clear separation of duties within the twin system."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A Continuous Validation Service continuously compares the measured execution of trajectories against the simulated trajectories produced by the dynamic model. Discrepancies beyond configured tolerances are flagged for further inspection, ensuring that the Digital Twin maintains fidelity to real‑world behaviour."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All inter‑component communication occurs over a local area network. Core services (Control Application, Logging Application, Trajectory Generator Service, Simulation Service, Continuous Validation Service) exchange messages via a lightweight MQTT broker; each service subscribes to the appropriate topics and publishes its status or telemetry. The Physical Crane Interface communicates with the crane controller hardware via a native TCP socket. No explicit bandwidth or latency metrics are specified in the document, and the document does not describe redundancy or security mechanisms beyond the MQTT broker’s presence."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin components are intended for on‑premise deployment on the host machine that directly controls the gantry crane. The Python containers run as local processes, utilizing a single TimescaleDB instance for persistent time‑series data. No cloud or edge deployment options are described, and the deployment model is a monolithic, single‑host architecture with no explicit scaling provisions beyond the modular container design outlined in the container diagram."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplars cite an AutomationML based digital twin model and the use of Microsoft Azure cloud services, indicating alignment with industry standards for digital twin representation and cloud deployment. No explicit certification, compliance frameworks or interoperability standards are mentioned."
]