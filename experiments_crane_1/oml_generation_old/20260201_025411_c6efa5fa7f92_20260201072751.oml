// C2: Acting Components
instance LinearCartMotor : DTDFVocab:ActingComponent [
    base:desc "Electric motor that drives linear motion of the cart along the rails, commanded via networked controller."
]

instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Electric motor that drives the vertical hoist motion, commanded via networked controller."
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist end, switched on/off to grip and release small pucks."
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the hoist to measure swing angle with high angular resolution."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer positioned near the crane to measure ambient wind speed for disturbance modelling."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Data (raw sensor measurements)
instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle values streamed from the SwingAngleEncoder."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance WindSpeedMeasurement : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed values streamed from the Anemometer."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

// C10: Models/Data
instance GantryCADModel : DTDFVocab:Model [
    base:desc "Geometric CAD representation of the gantry crane created in Autodesk Fusion360."
    DTDFVocab:inputTo GrafanaDashboardEnabler
]

instance GantryKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model that generates simulated cart and hoist trajectories for validation."
    DTDFVocab:inputTo ValidationEngineEnabler
]

// C11: Enablers
instance DockerContainerEngine : DTDFVocab:Enabler [
    base:desc "Docker container platform that hosts all twin services and auxiliary components."
    DTDFVocab:enables OptimalControlService, HistoricalLoggingService, DataVisualizationService, ContinuousValidationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance storing time‑series sensor and actuator data."
    DTDFVocab:enables HistoricalLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker providing bi‑directional data flow between physical crane and twin."
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboards visualising CAD model, sensor streams and analytics."
    DTDFVocab:enables DataVisualizationService
]

instance PhysicalCraneInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Python program (gantrylib) that reads state from the Arduino controllers and forwards it to the twin."
    DTDFVocab:enables ContinuousValidationService
]

instance OptimalControlEngineEnabler : DTDFVocab:Enabler [
    base:desc "Real‑time trajectory generation engine delivering optimal control set‑points."
    DTDFVocab:enables OptimalControlService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Engine that compares simulated trajectories against measured sensor data."
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Generates optimal control commands (speed/position set‑points) for cart and hoist in real time."
    DTDFVocab:provides ControlRecommendationInsight, AdjustTrajectoryAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Archives sensor and actuator measurements into TimescaleDB for later analysis."
    DTDFVocab:provides HistoricalTrendInsight, StoreSensorDataAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Displays live crane state, sensor streams and model predictions on Grafana dashboards."
    DTDFVocab:provides RealTimeVisualizationInsight, RenderDashboardAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Automatically validates physical behaviour against the kinematic model and raises alerts."
    DTDFVocab:provides ValidationResultInsight, GenerateAlertAction
]

// C17: Insights
instance ControlRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimal‑control recommendation derived from the trajectory optimisation engine."
]

instance HistoricalTrendInsight : DTDFVocab:Insight [
    base:desc "Trend analysis of historical swing‑angle and wind‑speed data stored in TimescaleDB."
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live visual representation of crane motion, sensor readings and model predictions."
]

instance ValidationResultInsight : DTDFVocab:Insight [
    base:desc "Confidence bounds and deviation metrics resulting from continuous validation."
]

// C17: Actions
instance AdjustTrajectoryAction : DTDFVocab:Action [
    base:desc "Updates motor set‑points to follow the optimal trajectory."
    DTDFVocab:IsAutomatic true
]

instance StoreSensorDataAction : DTDFVocab:Action [
    base:desc "Writes incoming sensor measurements into TimescaleDB."
    DTDFVocab:IsAutomatic true
]

instance RenderDashboardAction : DTDFVocab:Action [
    base:desc "Refreshes Grafana panels with the latest data."
    DTDFVocab:IsAutomatic true
]

instance GenerateAlertAction : DTDFVocab:Action [
    base:desc "Triggers an alert when validation deviation exceeds predefined thresholds."
    DTDFVocab:IsAutomatic true
]

// C18: Environment
instance LaboratoryLogisticsEnvironment : DTDFVocab:Environment [
    base:contains LinearCartMotor, HoistMotor, ElectromagnetActuator,
                SwingAngleEncoder, Anemometer,
                GantryCADModel, GantryKinematicModel,
                DockerContainerEngine, TimescaleDBEnabler,
                MQTTBrokerEnabler, GrafanaDashboardEnabler,
                PhysicalCraneInterfaceEnabler, OptimalControlEngineEnabler,
                ValidationEngineEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Virtual‑to‑physical interaction is provided by the Control Application, a Python application that issues control commands to the crane via the Physical Crane Interface. Commands originate from twin services such as the Trajectory Generator Service and are sent to the physical controllers; the document does not detail command formats, validation, or acknowledgment mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows an ad‑hoc orchestration rather than a commercial digital‑twin framework. Its architecture is visualised with the C4 model. Deployment uses containerisation (Docker) and virtualization (VM images) that host the constituent services. Core components include an InfluxDB time‑series database for sensor data storage, an ActiveMQ message broker for event‑driven communication between the physical sensors and the twin, and the twin logic packaged as Docker containers. The services are composed and managed with Docker Compose, providing resource management on the host VM. All artefacts are open‑source and hosted on GitHub."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The exemplar is used to demonstrate continuous validation methods and fault detection techniques, indicating that model fidelity is actively monitored by comparing real‑time actual data against predictions of the kinematic model. Validation and verification are performed through a continuous validation service, and fault detection methods are applied to identify deviations. Specific uncertainty quantification, error correction procedures, or quality assurance processes are not described in the document."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The twin’s technical connection relies on an MQTT broker that carries signaling messages between the twin services (Trajectory Generator, Simulation, Continuous Validation, etc.). State data is stored in a TimescaleDB instance and visualised by a Grafana dashboard, both accessed over the host’s internal network. All components are modelled as containers in the C4 diagram, implying they share a common network topology on a single host, but no specific bandwidth, latency, or security protocols are described."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment consists of a set of containerised components (Python services, TimescaleDB, Grafana, MQTT broker) running on‑premise on a single workstation or lab server. The architecture does not reference cloud platforms; computational and storage requirements are modest, suitable for a lab‑scale environment, and the containers provide the primary scalability mechanism."
]