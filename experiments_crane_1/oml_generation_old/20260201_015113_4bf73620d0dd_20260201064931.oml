// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the crane cart along the gantry"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor controlling the vertical hoist movement"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist for picking and placing pucks"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring crane hoist swing angle"
    DTDFVocab:producedData SwingAngleDataMessage
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed"
    DTDFVocab:producedData WindSpeedDataMessage
]

instance MotorControllerStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Arduino‑based acquisition of stepper motor controller status and electromagnet state"
    DTDFVocab:producedData MotorStatusDataMessage
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance SwingAngleDataMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance MotorStatusDataMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerStatusSensor
]

// C5: Data (Time‑series stored in TimescaleDB)
instance SwingAngleTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series swing‑angle measurements stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataMessage
    DTDFVocab:inputTo TimescaleDBEnabler, SimulationEngineEnabler
]

instance WindSpeedTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series wind‑speed measurements stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedDataMessage
    DTDFVocab:inputTo TimescaleDBEnabler, SimulationEngineEnabler
]

instance MotorStatusTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series motor controller and electromagnet status stored in TimescaleDB"
    DTDFVocab:fromData MotorStatusDataMessage
    DTDFVocab:inputTo TimescaleDBEnabler, SimulationEngineEnabler
]

// C11: Enablers (tools/infrastructure)
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB PostgreSQL‑based time‑series database container"
    DTDFVocab:enables DataLoggingService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python simulation engine (e.g., pybullet) executing the physics model"
    DTDFVocab:enables SimulationService
]

instance PythonGantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module providing kinematic and trajectory generation functions"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestrates all containerized services"
    DTDFVocab:enables DataLoggingService, VisualizationService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService, HMIService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana container for dashboard visualization"
    DTDFVocab:enables VisualizationService
]

instance MosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker container for pub/sub of sensor, trajectory, and validation messages"
    DTDFVocab:enables DataLoggingService, SimulationService, ContinuousValidationService, TrajectoryGeneratorService, HMIService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logging Application that receives MQTT messages and writes time‑series data into TimescaleDB"
    DTDFVocab:provides PersistMeasurementData
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Grafana Dashboard visualizing measurement and trajectory data"
    DTDFVocab:provides RealTimeDashboardInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free trajectories using the kinematic model"
    DTDFVocab:provides GenerateOptimalTrajectory
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation of crane dynamics and controller actions"
    DTDFVocab:provides SimulatedTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Validates executed trajectories against simulated ones and alerts on deviations"
    DTDFVocab:provides TrajectoryDeviationAlert
]

instance HMIService : DTDFVocab:Service [
    base:desc "Human‑Machine Interface allowing operator interaction and intervention"
    DTDFVocab:provides OperatorInterventionAction
]

// C17: Insights / Actions
instance PersistMeasurementData : DTDFVocab:Action [
    base:desc "Persist incoming measurement data into TimescaleDB"
    DTDFVocab:IsAutomatic true
]

instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Provides visual dashboards of live crane status and trajectories"
]

instance GenerateOptimalTrajectory : DTDFVocab:Action [
    base:desc "Compute swing‑free optimal trajectory for puck transport"
    DTDFVocab:IsAutomatic true
]

instance SimulatedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Predicts crane motion and trajectory using physics simulation"
]

instance TrajectoryDeviationAlert : DTDFVocab:Insight [
    base:desc "Alert when executed trajectory deviates from simulated optimal trajectory"
]

instance OperatorInterventionAction : DTDFVocab:Action [
    base:desc "Allows operator to intervene and adjust crane motion"
    DTDFVocab:IsAutomatic false
]

// C10: Models / Data assets
instance CADCraneModel : DTDFVocab:Model [
    base:desc "CAD model of the lab‑scale gantry crane from Autodesk Fusion360"
    DTDFVocab:inputTo VisualizationService
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator for swing‑free path planning"
    DTDFVocab:inputTo PythonGantryLibEnabler
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics simulation model used by the Simulation Service to emulate crane dynamics"
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (e.g., move cart, move hoist, activate electromagnet) are generated by the Trajectory Generator Service or issued by the Human‑Machine Interface, sent over MQTT to the Control Application, which uses the Physical Crane Interface to drive the motor controllers via serial/USB links."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A cyber‑physical system where the physical crane is linked to a Python‑based Physical Crane Interface; the interface communicates via MQTT with six Docker‑container services (Database, MQTT broker, Dashboard, Trajectory Generator, Simulation, Continuous Validation). The Control Application and Human‑Machine Interface issue commands, while the Logging Application continuously records state to the database; all services run on a single personal computer."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, checks against predefined thresholds, and alerts operators via the dashboard when deviations exceed acceptable limits, thereby assessing model fidelity in real time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Mosquitto MQTT broker is used for all inter‑service signaling; Python applications communicate with the Arduino over serial/USB; Docker containers share a common network on the host PC; the database is accessed via standard PostgreSQL/SQL connections."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software components run on a personal computer. The database, MQTT broker, and Grafana dashboard are Docker‑containerized and started with a single Docker‑Compose command. The Python modules are installed via pip and executed directly on the host OS."
]