// ==============================
// C2: Acting Components (Physical)
// ==============================
instance GantryCraneActuator : DTDFVocab:ActingComponent [
    base:desc "Motorised actuators driving the gantry crane’s movements and electromagnet for puck handling."
]

// ==============================
// C3: Physical Sensing Components
// ==============================
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the crane boom."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed around the crane."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ElectromagnetStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting the on/off status of the crane’s electromagnet."
    DTDFVocab:producedData MagnetStatusDataTransmitted
]

// ==============================
// C4: Physical‑to‑Virtual Interaction (Data Transmission)
// ==============================
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MagnetStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ElectromagnetStatusSensor
]

// ==============================
// C5: Data (Stored Records)
// ==============================
instance SwingAngleRecord : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurement."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance WindSpeedRecord : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed measurement."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance MagnetStatusRecord : DTDFVocab:Data [
    base:desc "Time‑stamped electromagnet status (on/off)."
    DTDFVocab:fromData MagnetStatusDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

// ==============================
// C10: Models / Data Enablers
// ==============================
instance GantryCraneCADModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the lab‑scale gantry crane."
    DTDFVocab:inputTo OpenSourceSimulationEngine
]

instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model capturing the crane’s motion dynamics."
    DTDFVocab:inputTo OpenSourceSimulationEngine
]

// ==============================
// C11: Enablers (Software / Infrastructure)
// ==============================
instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database storing all sensor and actuator records."
    DTDFVocab:enables HistoricalLoggingService, ContinuousValidationService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboard visualising realtime crane state and performance metrics."
    DTDFVocab:enables DataVisualizationService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker used for signalling between containerised services."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

instance OpenSourceSimulationEngine : DTDFVocab:Enabler [
    base:desc "Open‑source simulation package employed for trajectory generation, kinematic validation and dynamic simulation."
    DTDFVocab:enables SimulationService, ContinuousValidationService, OptimalControlService
]

// ==============================
// C6: Services
// ==============================
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes the most efficient motion trajectories for the crane."
    DTDFVocab:provides TrajectoryOptimizationInsight, AdjustTrajectoryAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Archives sensor and actuator data for later analysis."
    DTDFVocab:provides DataArchiveAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Presents graphical visualisations of crane state, trajectories and performance metrics."
    DTDFVocab:provides PerformanceMetricInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Automatically compares physical crane behaviour against the kinematic model to detect deviations."
    DTDFVocab:provides DeviationDetectionInsight, RealTimeAlertInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates indoor airflow and contaminant dispersion for scenario analysis."
    DTDFVocab:provides ForecastedConcentrationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates feasible crane trajectories based on current state and optimisation goals."
    DTDFVocab:provides TrajectoryGenerationInsight
]

// ==============================
// C17: Insights / Actions
// ==============================
instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory computed for the current payload and target location."
]

instance DeviationDetectionInsight : DTDFVocab:Insight [
    base:desc "Detected deviation between observed crane motion and kinematic model prediction."
]

instance PerformanceMetricInsight : DTDFVocab:Insight [
    base:desc "Visual performance metrics (e.g., energy consumption, travel time) of the crane operation."
]

instance RealTimeAlertInsight : DTDFVocab:Insight [
    base:desc "Real‑time alert indicating unsafe or unexpected crane behaviour."
]

instance ForecastedConcentrationInsight : DTDFVocab:Insight [
    base:desc "Predicted indoor contaminant concentration levels for virus‑spread prevention."
]

instance TrajectoryGenerationInsight : DTDFVocab:Insight [
    base:desc "Feasible trajectory generated for the requested pick‑and‑place operation."
]

instance DataArchiveAction : DTDFVocab:Action [
    base:desc "Store the incoming sensor and actuator records permanently in TimescaleDB."
    DTDFVocab:IsAutomatic true
]

instance AdjustTrajectoryAction : DTDFVocab:Action [
    base:desc "Send updated motion commands to the crane controller to follow the optimal trajectory."
    DTDFVocab:IsAutomatic true
]

instance NotifyOperatorAction : DTDFVocab:Action [
    base:desc "Notify the operator via the web dashboard about a detected deviation or alert."
    DTDFVocab:IsAutomatic false
]

// ==============================
// C1: System Under Study (Physical Twin)
// ==============================
instance GantryCranePhysicalTwin : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane inspired by the harbor cranes of the Port of Antwerp, equipped with a motorised mechanism, controller unit and interchangeable pucks."
]

// ==============================
// C13: Environment
// ==============================
instance CraneLabEnvironment : DTDFVocab:Environment [
    base:contains GantryCranePhysicalTwin, GantryCraneActuator, SwingAngleEncoder, Anemometer, ElectromagnetStatusSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal motion trajectories (position and velocity set‑points) using a kinematics model. These trajectories are sent to the Control Application through the MQTT broker (Eclipse Mosquitto) as messages containing command parameters. The Control Application, a Python program using the Physical Crane Interface, translates the messages into low‑level motor commands that are issued to the crane’s motor controllers via the Arduino. Feedback is provided by the Logging Application and the Continuous Validation Service, which compare executed trajectories with simulated ones. The documents do not specify explicit command validation, authentication, or conflict‑resolution mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a service‑oriented, event‑driven architecture orchestrated by an MQTT broker. Physical crane data is collected by the Logging Application and stored in TimescaleDB; the Dashboard visualises this data via Grafana. The Trajectory Generator uses a kinematics model to produce swing‑free trajectories, which are fed to the Simulation Service and to the physical crane through the Control Application. The Continuous Validation Service continuously compares executed trajectories with the simulated ones, computes distance metrics and raises alerts on the Dashboard when thresholds are exceeded. All components are described using the C4 model and are deployed as separate containers (software containers, not Docker) that communicate via MQTT and database queries."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin provides a continuous validation service that checks the consistency between the CAD/kinematic models and the operational data recorded from the crane, enabling ongoing quality assurance. No detailed validation methodology, uncertainty quantification, or error correction mechanisms are described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital‑twin components run on a single host PC. Docker containers host the TimescaleDB database, the Grafana dashboard and the Eclipse Mosquitto MQTT broker. Containers communicate over the internal Docker network using MQTT (publish/subscribe) for service signalling and HTTP/HTTPS for Grafana access. The Physical Crane Interface communicates locally with the Arduino over a serial/USB link. Bandwidth and latency requirements are not quantified; reliability is achieved via Docker orchestration and the broker’s ability to buffer messages. No security protocols (e.g., TLS, authentication) are mentioned for the network communication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The software is packaged as a Python module (gantrylib) installable with pip and runs on a personal computer. Docker Compose orchestrates the TimescaleDB, MQTT broker and Grafana containers, providing one‑command startup and automatic initialization of the database and dashboard. Deployment is on‑premise (edge) rather than cloud; computational load consists of Python services, a time‑series database and a web dashboard. Scalability is limited to the host PC’s resources; while Docker containers could be replicated, the documents do not describe automatic scaling. Availability is supported by Docker Compose’s ability to restart containers automatically."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external actors is achieved through standard protocols: MQTT is used for inter‑service signalling, and the TimescaleDB database exposes data via SQL for external analytics. The Grafana dashboard provides a web‑based UI for operators and researchers, enabling monitoring and control from external devices. The architecture also supports interaction with human users (operator, researcher) as described in the context diagram, but no explicit enterprise‑level standards (e.g., AutomationML, OPC UA) are mentioned for this twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin model is defined using AutomationML, an open industry standard for engineering data exchange, and follows a model‑driven digital‑twin engineering approach. No additional certification or compliance frameworks are reported."
]