// C3: Physical Sensing Components
instance AirQualityCarbonDioxideSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry Pi-equipped CO2 sensor for real-time indoor air quality monitoring in the Air Quality Management exemplar"
    DTDFVocab:producedData AirQualitySensorDataTransmitted
]

instance AirQualityParticulateMatterSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry Pi-equipped particulate matter sensor for real-time indoor air quality monitoring in the Air Quality Management exemplar"
    DTDFVocab:producedData AirQualitySensorDataTransmitted
]

instance AirQualityTemperatureHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry Pi-equipped temperature and humidity sensor for real-time indoor air quality monitoring in the Air Quality Management exemplar"
    DTDFVocab:producedData AirQualitySensorDataTransmitted
]

instance GreenhouseEnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor (temperature, humidity, light) for monitoring the physical greenhouse state in the GreenhouseDT exemplar"
    DTDFVocab:producedData GreenhouseEnvironmentalDataTransmitted
]

instance GantryCranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor (encoder-based) for tracking joint angles and payload position in the lab-scale gantry crane system"
    DTDFVocab:producedData GantryCraneKinematicDataTransmitted
]

instance GantryCraneMotionSensor : DTDFVocab:SensingComponent [
    base:desc "Motion sensor for capturing velocity, acceleration, and swinging motion of payloads in the lab-scale gantry crane system"
    DTDFVocab:producedData GantryCraneKinematicDataTransmitted
]

instance GantryCraneLoadSensor : DTDFVocab:SensingComponent [
    base:desc "Load sensor for measuring payload weight and motor currents in the lab-scale gantry crane system"
    DTDFVocab:producedData GantryCraneOperationalDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance AirQualitySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityCarbonDioxideSensor, AirQualityParticulateMatterSensor, AirQualityTemperatureHumiditySensor
    base:desc "Real-time sensor data stream from Raspberry Pi sensors for air quality parameters (CO2, PM, temperature, humidity) with millisecond-level updates"
]

instance GreenhouseEnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseEnvironmentalSensor
    base:desc "Environmental data stream from greenhouse sensors (temperature, humidity, light) for behavioral adaptation"
]

instance GantryCraneKinematicDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GantryCranePositionSensor, GantryCraneMotionSensor
    base:desc "High-frequency (100Hz+) kinematic data stream from position and motion sensors for real-time trajectory validation"
]

instance GantryCraneOperationalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GantryCraneLoadSensor
    base:desc "Operational metrics stream from load sensors including motor currents, payload weight, and controller status"
]

// C10: Models/Data
instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Parametric kinematic model of the gantry crane generated using FreeCAD and ROS MoveIt for forward/inverse kinematics"
    DTDFVocab:inputTo KinematicSimulationEnabler, ControlOptimizationEnabler
]

instance GantryCranePhysicsModel : DTDFVocab:Model [
    base:desc "Physics-based simulation model implemented in Gazebo/Ignition for co-simulation with the physical crane"
    DTDFVocab:inputTo PhysicsSimulationEnabler
]

instance AirQualitySpatialModel : DTDFVocab:Model [
    base:desc "Geometric model of indoor space represented in AutomationML for air quality simulation"
    DTDFVocab:inputTo AirQualitySimulationEnabler
]

instance AirQualityBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model of airflow dynamics and virus spread prediction using AutomationML-based digital twin engineering"
    DTDFVocab:inputTo AirQualitySimulationEnabler, AirQualityPredictionEnabler
]

instance GreenhouseBehavioralModel : DTDFVocab:Model [
    base:desc "Self-adaptive behavioral model for greenhouse environmental control using prerecorded VM data"
    DTDFVocab:inputTo GreenhouseAdaptationEnabler
]

instance GantryCraneHistoricalData : DTDFVocab:Data [
    base:desc "Time-series historical data of crane operations including sensor readings, control commands, and validation metrics"
    DTDFVocab:fromData GantryCraneKinematicDataTransmitted, GantryCraneOperationalDataTransmitted
    DTDFVocab:inputTo DataLoggingEnabler
]

instance AirQualityHistoricalData : DTDFVocab:Data [
    base:desc "Time-series historical data of indoor air quality measurements for trend analysis and predictive modeling"
    DTDFVocab:fromData AirQualitySensorDataTransmitted
    DTDFVocab:inputTo AirQualitySimulationEnabler, AirQualityPredictionEnabler
]

instance GreenhouseHistoricalData : DTDFVocab:Data [
    base:desc "Time-series environmental data from greenhouse sensors for behavioral adaptation analysis"
    DTDFVocab:fromData GreenhouseEnvironmentalDataTransmitted
    DTDFVocab:inputTo GreenhouseAdaptationEnabler
]

// C11: Enablers
instance KinematicSimulationEnabler : DTDFVocab:Enabler [
    base:desc "ROS MoveIt and PyRobot enabler for kinematic solvers and trajectory planning in the gantry crane system"
    DTDFVocab:enables GantryCraneTrajectoryService, GantryCraneValidationService
]

instance PhysicsSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Gazebo/Ignition enabler for physics-based co-simulation between physical and digital twins"
    DTDFVocab:enables GantryCraneSimulationService, GantryCraneValidationService
]

instance DataStreamingEnabler : DTDFVocab:Enabler [
    base:desc "ROS Topics/Nodes and MQTT enabler for low-latency (100ms) data streaming between physical crane and digital twin"
    DTDFVocab:enables GantryCraneTrajectoryService, GantryCraneValidationService
]

instance DataLoggingEnabler : DTDFVocab:Enabler [
    base:desc "SQLite and InfluxDB enabler for time-series data storage and query optimization of crane operations"
    DTDFVocab:enables GantryCraneHistoricalLoggingService
]

instance ControlOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Python (NumPy, SciPy, Pyomo) enabler for optimal control strategies (LQR, MPC) and reinforcement learning"
    DTDFVocab:enables GantryCraneControlService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "RViz, Matplotlib, and Flask/Dash enabler for real-time 3D/2D visualization and remote monitoring"
    DTDFVocab:enables GantryCraneVisualizationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Python (scikit-learn, TensorFlow) enabler for machine learning-based model validation and anomaly detection"
    DTDFVocab:enables GantryCraneValidationService
]

instance AirQualitySimulationEnabler : DTDFVocab:Enabler [
    base:desc "AutomationML and Microsoft Azure enabler for spatial and behavioral air quality simulation"
    DTDFVocab:enables AirQualitySimulationService
]

instance AirQualityPredictionEnabler : DTDFVocab:Enabler [
    base:desc "Microsoft Azure tools enabler for predictive analytics of air quality trends"
    DTDFVocab:enables AirQualityPredictionService
]

instance GreenhouseAdaptationEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB and ActiveMQ enabler for real-time behavioral adaptation of greenhouse systems"
    DTDFVocab:enables GreenhouseAdaptationService
]

// C6: Services
instance GantryCraneTrajectoryService : DTDFVocab:Service [
    base:desc "Real-time trajectory planning and adaptive motion parameter adjustment for energy optimization and wear reduction"
    DTDFVocab:provides GantryCraneOptimizedTrajectoryInsight
]

instance GantryCraneSimulationService : DTDFVocab:Service [
    base:desc "Physics-based co-simulation service enabling what-if analysis without risking the physical system"
    DTDFVocab:provides GantryCraneSimulationValidationInsight
]

instance GantryCraneValidationService : DTDFVocab:Service [
    base:desc "Continuous real-time validation comparing digital twin predictions with physical observations using RMSE metrics"
    DTDFVocab:provides GantryCraneValidationStatusInsight
]

instance GantryCraneControlService : DTDFVocab:Service [
    base:desc "Optimal control execution service implementing LQR and MPC strategies for crane operation"
    DTDFVocab:provides GantryCraneControlCommandAction
]

instance GantryCraneVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D/2D visualization service rendering crane state in real-time with anomaly highlighting"
    DTDFVocab:provides GantryCraneStateVisualizationInsight
]

instance GantryCraneHistoricalLoggingService : DTDFVocab:Service [
    base:desc "Time-series data storage and event-based logging service for crane operations and control commands"
