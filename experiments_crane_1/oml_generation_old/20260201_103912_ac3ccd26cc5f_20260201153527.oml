    DTDFVocab:provides GreenhouseAdaptationStatusInsight
]

// C17: Insights/Actions
instance GantryCraneOptimizedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimized motion parameters (speed, acceleration) for energy-efficient crane operation derived from kinematic models"
]

instance GantryCraneSimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Validation metrics comparing simulated trajectories with physical execution using Euclidean distance metrics"
]

instance GantryCraneValidationStatusInsight : DTDFVocab:Insight [
    base:desc "Real-time RMSE-based consistency check between digital twin predictions and physical observations"
]

