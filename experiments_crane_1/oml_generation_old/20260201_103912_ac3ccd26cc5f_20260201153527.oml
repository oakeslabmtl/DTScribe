    base:desc "Real-time 3D/2D visualization of crane state including joint angles, payload trajectories, and force diagrams"
]

instance GantryCraneHistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Queryable historical dataset of crane operations for post-mortem analysis and performance benchmarking"
]

instance GantryCraneFaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detected anomalies in sensor data streams indicating potential faults (e.g., torque spikes, position drift)"
]

instance GantryCraneMaintenanceAction : DTDFVocab:Action [
    base:desc "Predictive maintenance recommendations based on fault detection results"
    DTDFVocab:IsAutomatic false
]

instance AirQualitySimulationResultInsight : DTDFVocab:Insight [
    base:desc "Predicted air quality dynamics including spatial distribution of pollutants and airflow patterns"
]

instance AirQualityForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasted air quality trends enabling proactive ventilation adjustments"
]

