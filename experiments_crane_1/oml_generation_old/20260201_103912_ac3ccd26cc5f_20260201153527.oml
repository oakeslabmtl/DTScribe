]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection service monitoring sensor streams for faults (e.g., motor failure, sensor drift) with predictive maintenance capabilities"
    DTDFVocab:provides GantryCraneFaultDetectionInsight
]

