instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring oscillation angle of hoist during movement"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring wind speed for crane stability assessment"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Swing angle data with high temporal resolution"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDB, EclipseMosquitto
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Wind speed data for environmental impact assessment"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDB, EclipseMosquitto
]

instance CartMotor : DTDFVocab:ActingComponent [
    base:desc "Motor controlling cart movement with associated controller"
]

instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Motor controlling hoisting movement with associated controller"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at hoist end for container pickup"
]

instance AutodeskFusion360 : DTDFVocab:Enabler [
    base:desc "CAD modeling tool for geometric representation"
    DTDFVocab:enables SimulationService
]

instance Capella : DTDFVocab:Enabler [
    base:desc "System architecture design tool"
    DTDFVocab:enables SimulationService
]

instance Gantrylib : DTDFVocab:Enabler [
    base:desc "Python module packaging C4 Containers for modular software structure"
    DTDFVocab:enables ModularService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "Time-series database for operational data storage"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance Grafana : DTDFVocab:Enabler [
    base:desc "Visualization tool for dashboard creation"
    DTDFVocab:enables RealTimeDataVisualizationService
]

instance EclipseMosquitto : DTDFVocab:Enabler [
    base:desc "MQTT broker for real-time physical-digital communication"
    DTDFVocab:enables RealTimeDataVisualizationService, ContinuousValidationService, FaultDetectionService, TrajectoryGeneratorService, SimulationService, PredictiveModelingService, OptimalControlService
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service for optimal control of physical crane"
    DTDFVocab:provides OptimalControlInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service for logging operational data to TimescaleDB"
    DTDFVocab:provides HistoricalDataLoggingInsight
]

instance RealTimeDataVisualizationService : DTDFVocab:Service [
    base:desc "Service for real-time data visualization of crane operations"
    DTDFVocab:provides RuntimeVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service for continuous validation against physical system behavior"
    DTDFVocab:provides ContinuousValidationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service for fault detection mechanisms"
    DTDFVocab:provides FaultDetectionInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service computing paths using kinematic model"
    DTDFVocab:provides TrajectoryGenerationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service dynamically modeling crane behavior for real-time analysis"
    DTDFVocab:provides SimulationInsight
]

instance PredictiveModelingService : DTDFVocab:Service [
    base:desc "Service for predictive modeling of virus spread prevention strategies"
    DTDFVocab:provides PredictiveModelingInsight
]

instance ModularService : DTDFVocab:Service [
    base:desc "Service for modular software structure implementation"
    DTDFVocab:provides ModularInsight
]

instance DevelopmentService : DTDFVocab:Service [
    base:desc "Service for system development and deployment"
    DTDFVocab:provides DevelopmentInsight
]

instance GitHubVersionControl : DTDFVocab:Enabler [
    base:desc "GitHub for version control in ad-hoc development"
    DTDFVocab:enables DevelopmentService
]

instance C4Modeling : DTDFVocab:Enabler [
    base:desc "C4 Model for system architecture visualization"
    DTDFVocab:enables DevelopmentService
]

instance Containerization : DTDFVocab:Enabler [
    base:desc "Containerization technology for deployment"
    DTDFVocab:enables DevelopmentService
]

instance Virtualization : DTDFVocab:Enabler [
    base:desc "Virtualization technology for deployment"
    DTDFVocab:enables DevelopmentService
]

instance CADModel : DTDFVocab:Model [
    base:desc "CAD model for geometric representation"
    DTDFVocab:inputTo SimulationService
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model for motion simulation"
    DTDFVocab:inputTo TrajectoryGeneratorService, SimulationService
]

instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Python program interfacing physical crane to digital twin"
]

instance GantryCrane : DTDFVocab:Component [
    base:desc "Lab-scale gantry crane for industrial automation"
]

instance GantryCraneController : DTDFVocab:Component [
    base:desc "Controller for gantry crane operation"
]

