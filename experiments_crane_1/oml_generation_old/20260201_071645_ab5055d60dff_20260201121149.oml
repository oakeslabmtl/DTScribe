// Sensing components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "MotorPositionEncoder encodes the shaft angular position of the gantry crane motor, sampled continuously."
    DTDFVocab:producedData PositionDataTransmitted
]

instance MotorVelocityEncoder : DTDFVocab:SensingComponent [
    base:desc "MotorVelocityEncoder provides continuous measurement of the shaft angular velocity from the motor encoder."
    DTDFVocab:producedData VelocityDataTransmitted
]

// Data transmitted from physical sensors
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorVelocityEncoder
]

// Processed data stored for services
instance PositionData : DTDFVocab:Data [
    base:desc "PositionData numeric shaft position (rad) of the crane motor."
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, KinematicEngineEnabler, MQTTStackEnabler
]

instance VelocityData : DTDFVocab:Data [
    base:desc "VelocityData numeric shaft velocity (rad/s) of the crane motor."
    DTDFVocab:fromData VelocityDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, KinematicEngineEnabler, MQTTStackEnabler
]

// Enablers (tools and stubs)
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDBEnabler lightweight time‑series database for logging all sensor streams."
    DTDFVocab:enables LoggingService
]

instance MQTTStackEnabler : DTDFVocab:Enabler [
    base:desc "MQTTStackEnabler MQTT stack used for continuous streaming of motor state data."
    DTDFVocab:enables MonitoringService
]

instance KinematicEngineEnabler : DTDFVocab:Enabler [
    base:desc "KinematicEngineEnabler open‑source kinematic modeling engine for forward and inverse kinematics."
    DTDFVocab:enables ControlService, ValidationService
]

instance CADPackageEnabler : DTDFVocab:Enabler [
    base:desc "CADPackageEnabler open‑source CAD package to generate geometry of the crane."
    DTDFVocab:enables VisualizationService
]

instance WebDashboardEnabler : DTDFVocab:Enabler [
    base:desc "WebDashboardEnabler web‑based dashboards for rendering data and visualizations."
    DTDFVocab:enables VisualizationService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "MonitoringService continuously monitors shaft positions and velocities via MQTT streams."
    DTDFVocab:provides ShaftPositionInsight, ShaftVelocityInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "ControlService closed‑loop optimal control module computing actuator commands from the kinematic model."
    DTDFVocab:provides ActuatorCommandAction
]

instance LoggingService : DTDFVocab:Service [
    base:desc "LoggingService logs all sensor streams into TimescaleDB for historical analysis."
    DTDFVocab:provides HistoricalLogInsight
]

instance ValidationService : DTDFVocab:Service [
    base:desc "ValidationService continuously validates live measurements against the kinematic model to detect deviations."
    DTDFVocab:provides DeviationDetectedInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "VisualizationService renders CAD geometry and motion trajectories via web dashboards."
    DTDFVocab:provides MotionTrajectoryInsight, CADRenderingInsight
]

// Insights and Action
instance ShaftPositionInsight : DTDFVocab:Insight [
    base:desc "ShaftPositionInsight real‑time insight into the crane motor shaft position."
]

instance ShaftVelocityInsight : DTDFVocab:Insight [
    base:desc "ShaftVelocityInsight real‑time insight into the crane motor shaft velocity."
]

instance HistoricalLogInsight : DTDFVocab:Insight [
    base:desc "HistoricalLogInsight insight into the historical log of all sensor data."
]

instance DeviationDetectedInsight : DTDFVocab:Insight [
    base:desc "DeviationDetectedInsight indicates deviation between measured and modelled states."
]

instance MotionTrajectoryInsight : DTDFVocab:Insight [
    base:desc "MotionTrajectoryInsight visual insight of motion trajectories in the gantry crane."
]

instance CADRenderingInsight : DTDFVocab:Insight [
    base:desc "CADRenderingInsight rendered CAD model of the crane geometry."
]

instance ActuatorCommandAction : DTDFVocab:Action [
    base:desc "ActuatorCommandAction automatic command output to i.e., the gantry carriage or linear axes."
    DTDFVocab:IsAutomatic true
]

// Physical actuating components
instance HoistActuator : DTDFVocab:ActingComponent [
    base:desc "HoistActuator controls vertical motion of the hoist carriage."
]

instance LinearAxis1Actuator : DTDFVocab:ActingComponent [
    base:desc "LinearAxis1Actuator controls first linear axis motion."
]

instance LinearAxis2Actuator : DTDFVocab:ActingComponent [
    base:desc "LinearAxis2Actuator controls second linear axis motion."
]

instance RotaryJointActuator : DTDFVocab:ActingComponent [
    base:desc "RotaryJointActuator controls rotation of the rotary joint."
]

// Environment of the gantry crane
instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains HoistActuator, LinearAxis1Actuator, LinearAxis2Actuator, RotaryJointActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital twin services generate control plans: the Trajectory Generator Service computes optimal movement trajectories, and the Simulation Service validates them. The resulting trajectory commands are offered to the Control Application, which then uses the Physical Crane Interface to send commands to the physical crane. Command formats are unspecified but are likely serialized in a Python‑friendly structure (e.g., JSON or binary). The document does not report on validation, authentication, conflict‑resolution, or confirmation mechanisms after command execution."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "GreenhouseDT orchestrates its digital twin through containerised services running on virtual machines, with sensor data ingested and persisted in an InfluxDB time‑series database; inter‑component communication is handled by an Apache ActiveMQ message broker using a publish‑subscribe model that supports synchronous state updates and real‑time control loops within the self‑adaptive twin.  The Air Quality Management exemplar employs a Raspberry‑Pi sensor suite whose telemetry is transmitted via MQTT to Microsoft Azure IoT services, after which an AutomationML‑based digital twin model is visualised and simulated through Azure‑hosted components.  Both exemplars adopt lightweight containerisation or virtualization strategies, allowing isolated deployment, straightforward scaling, and consistent coordination between physical and virtual subsystems."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All intra‑system communication between digital twin services is mediated by an MQTT broker, providing publish‑subscribe messaging for event signaling. The Physical Crane Interface communicates directly with the crane controllers via an unspecified protocol (possibly serial or Ethernet). The network topology is essentially a star, with all services connecting to the MQTT broker and the database. Bandwidth, latency, and QoS requirements are not stated, and no security protocols (TLS, authentication, etc.) are detailed in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system appears to be deployed on on‑premises infrastructure (local server or edge device) running the Python applications, MQTT broker, TimescaleDB database, and Grafana dashboard. No cloud deployment, scalability mechanisms, or availability/reliability guarantees are explicitly described in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "GreenhouseDT integrates with external systems through its Apache ActiveMQ broker, exposing JMS interfaces, and with InfluxDB’s HTTP and Line Protocol APIs for time‑series data ingestion and retrieval; these interfaces enable data exchange with third‑party logging, monitoring or analytics tools.  The Air Quality Management exemplar leverages Microsoft Azure’s cloud stack, where sensor telemetry is sent via secure MQTT to Azure IoT Hub, then processed by Azure stream analytics feeding the AutomationML model stored in Azure Blob Storage; downstream enterprise applications can retrieve the twin data via Azure’s REST APIs.  This combination of open‑source broker, time‑series database, and commercial cloud platform provides horizontal connectivity to data sources, analytics services and potential enterprise ERP or MES systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin model conforms to the AutomationML industry standard. The exemplar uses open‑source technologies such as InfluxDB and ActiveMQ; no adherence to commercial twin framework or additional certification requirements is described."
]