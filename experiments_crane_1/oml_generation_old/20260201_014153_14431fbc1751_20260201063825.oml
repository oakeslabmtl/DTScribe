// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the crane boom, data collected via Arduino"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed, data collected via Arduino"
    DTDFVocab:producedData AnemometerDataTransmitted
]

instance MotorStateFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor providing motor state feedback (position, speed, current) from the TMC4671 controller via Arduino"
    DTDFVocab:producedData MotorStateDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStateFeedbackSensor
]

// C10: Models/Data (measurements)
instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurement from the encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance AnemometerMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed measurement from the anemometer"
    DTDFVocab:fromData AnemometerDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance MotorStateMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped motor position, speed, and current feedback"
    DTDFVocab:fromData MotorStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

// C10: Models (kinematic and simulation)
instance GantryKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the gantry crane used to compute swing‑free trajectories"
    DTDFVocab:inputTo DockerComposeEnabler
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model reproducing crane behaviour and controller response"
    DTDFVocab:inputTo DockerComposeEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) storing logged measurements and simulated data"
    DTDFVocab:enables DataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for lightweight inter‑service signalling"
    DTDFVocab:enables ContinuousValidationService, TrajectoryGeneratorService, SimulationService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑Compose stack orchestrating containerised services (Trajectory Generator, Simulation, Validation, Grafana, etc.)"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, VisualizationService, MQTTBrokerService
]

instance PythonPhysicalInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Python‑based Physical Crane Interface exposing commands over serial/USB to control the stepper motor"
    DTDFVocab:enables ControlService, DataLoggingService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuously reads crane state via the Physical Crane Interface and writes raw time‑series to TimescaleDB"
    DTDFVocab:provides StoreMeasurementAction
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes optimal, swing‑free movement trajectories using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs the crane simulation model to predict behaviour for generated trajectories"
    DTDFVocab:provides PredictedBehaviourInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares executed trajectories with simulated ones, computes distance metrics, and raises alerts"
    DTDFVocab:provides ValidationAlertInsight, ValidationAlertAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Real‑time Grafana dashboard visualising measured and simulated trajectory traces with confidence bounds"
    DTDFVocab:provides VisualizationInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Issues motion commands (start/stop, speed, position) to the crane via the Physical Crane Interface"
    DTDFVocab:provides ExecuteTrajectoryAction
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Facilitates inter‑service communication by publishing/subscribing to MQTT topics"
    DTDFVocab:provides MessagingInsight
]

// C17: Insights
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal swing‑free movement trajectory computed for a given pick‑and‑place task"
]

instance PredictedBehaviourInsight : DTDFVocab:Insight [
    base:desc "Predicted crane dynamics and controller response for a proposed trajectory"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Detection that measured trajectory deviates beyond the configured threshold"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Live visual representation of measured vs. simulated trajectories on Grafana"
]

instance MessagingInsight : DTDFVocab:Insight [
    base:desc "Status of MQTT message flow between twin services"
]

// C17: Actions
instance StoreMeasurementAction : DTDFVocab:Action [
    base:desc "Persist raw sensor measurement into TimescaleDB"
    DTDFVocab:IsAutomatic true
]

instance ValidationAlertAction : DTDFVocab:Action [
    base:desc "Raise operator alert in the dashboard when validation threshold is exceeded"
    DTDFVocab:IsAutomatic true
]

instance ExecuteTrajectoryAction : DTDFVocab:Action [
    base:desc "Command the crane to execute a generated trajectory"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin generates control commands through several services. The Trajectory Generator Service computes optimal movement trajectories (kinematic model, swing‑free) and forwards them to the Control Application. The Control Application uses the same Physical Crane Interface to transmit set‑point commands to the Arduino‑controlled motor controllers (cart and hoist) – presumably as serial command messages. Operators can also issue commands via the Human‑Machine Interface, which routes them through the Control Application. The Continuous Validation Service monitors execution and, when a threshold is breached, notifies the operator via the Grafana dashboard. No explicit command format, authentication, or confirmation protocol is described in the documents; the interaction assumes trusted local execution on the same host."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a container‑based microservice architecture orchestrated with Docker‑compose. Core services (Trajectory Generator, Simulation, Continuous Validation) communicate via an MQTT broker (publish‑subscribe) and share state through a TimescaleDB time‑series database. Results are visualized on a Grafana dashboard. Python applications implement the Physical Crane Interface, Control Application, Logging Application, and Human‑Machine Interface. This pattern provides a service‑oriented architecture with a central messaging bus and a shared data store for coordination and resource management."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through a Continuous Validation Service that continuously compares measured trajectory data from the physical crane with the simulated trajectories generated by the Simulation Service, computing distance metrics and checking them against a predefined acceptance threshold; violations trigger operator alerts via the Grafana dashboard. The trajectory generator’s requirement for zero residual swing defines a high‑fidelity kinematic constraint, and the validation process constitutes the primary verification method described for the twin’s analytical and behavioral models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All twin services are deployed as Docker containers on a single personal computer, forming a local Docker network. Communication among services uses: • MQTT (Eclipse Mosquitto) over TCP for signalling and data streaming; • PostgreSQL protocol for TimescaleDB access; • HTTP/HTTPS (Grafana dashboard) to query the database. The documents do not detail network topology beyond the single‑host Docker setup, nor do they specify bandwidth, latency, redundancy, or security mechanisms such as TLS or authentication for MQTT or database connections."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The exemplar runs on‑premise on a personal computer. Core components (TimescaleDB, Grafana, Eclipse Mosquitto) are containerised with Docker and orchestrated via a Docker‑Compose file that handles first‑time initialization. The Python‑based control, logging, and service applications are installed from the pip‑distributed gantrylib module and run directly on the host OS. Storage requirements are driven by TimescaleDB for time‑series logs; compute requirements are modest (a typical workstation can host all containers). Scalability is limited to adding more services or scaling containers manually; no cloud or auto‑scaling features are mentioned. Availability relies on Docker’s container lifecycle management, but explicit redundancy or high‑availability strategies are not described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external components is realized through standard tools and protocols: MQTT is used as the lightweight publish‑subscribe protocol for inter‑service communication; TimescaleDB (PostgreSQL extension) stores time‑series data; Grafana provides data visualization; Docker‑compose manages container deployment. No explicit coupling to external enterprise systems or other digital twins is documented."
]