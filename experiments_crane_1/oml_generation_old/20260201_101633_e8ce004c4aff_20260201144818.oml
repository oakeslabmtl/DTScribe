// Components
instance PhysicalCrane : DTDFVocab:Component [
    base:desc "3‑D CAD model of the central gantry frame and motors originating from Forge 360 design."
]
instance CraneInterfaceComponent : DTDFVocab:Component [
    base:desc "Python program (gantrylib) reading motor and sensor states from the physical crane."
]
instance ControlApplication : DTDFVocab:Component [
    base:desc "Application commanding the stepper motors via TMC4671‑Eval controllers."
]
instance LoggingApplication : DTDFVocab:Component [
    base:desc "Writes all telemetry samples to the TimescaleDB instance."
]
instance HumanMachineInterface : DTDFVocab:Component [
    base:desc "Telemetry dashboard for operators."
]
instance TimescaleDBDatabase : DTDFVocab:Component [
    base:desc "TimescaleDB instance for time‑series storage of crane state."
]
instance GrafanaDashboard : DTDFVocab:Component [
    base:desc "Grafana dashboard for real‑time visualization."
]
instance MqttBroker : DTDFVocab:Component [
    base:desc "Eclipse Mosquitto MQTT broker mediating inter‑service communication."
]
instance DockerComposeTool : DTDFVocab:Component [
    base:desc "Docker Compose configuration for containerized services."
]
instance MkDocsDocumentation : DTDFVocab:Component [
    base:desc "MkDocs site documenting the digital twin architecture."
]

// Enablers
instance GantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python package gantrylib enabling hardware interfacing."
]
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Database enabler that allows writing to TimescaleDB."
]
instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Visualization enabler for Grafana dashboards."
]
instance MosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker enabler that publishes telemetry over MQTT."
]
instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker Compose enabler managing the container lifecycle."
]
instance MkDocsEnabler : DTDFVocab:Enabler [
    base:desc "MkDocs enabler that builds documentation."
]
instance LoggingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that enables the LoggingService using TimescaleDB."
    DTDFVocab:enables LoggingService
]
instance TrajectoryEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that enables the TrajectoryGenerationService."
    DTDFVocab:enables TrajectoryGenerationService
]
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that enables the SimulationService."
    DTDFVocab:enables SimulationService
]
instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that enables the ContinuousValidationService."
    DTDFVocab:enables ContinuousValidationService
]

// Sensing Components
instance SwingAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring the hoist swing."
    DTDFVocab:producedData CraneTelemetryPacket
]
instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the crane."
    DTDFVocab:producedData CraneTelemetryPacket
]
instance CartMotorPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor on the cart motor controller."
    DTDFVocab:producedData CraneTelemetryPacket
]
instance CartMotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current feedback sensor on the cart motor controller."
    DTDFVocab:producedData CraneTelemetryPacket
]
instance HoistMotorPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor on the hoist motor controller."
    DTDFVocab:producedData CraneTelemetryPacket
]
instance HoistMotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current feedback sensor on the hoist motor controller."
    DTDFVocab:producedData CraneTelemetryPacket
]

// Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Step‑step cart motor driven by a TMC4671‑Eval controller."
]
instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Step‑step hoist motor driven by a TMC4671‑Eval controller."
]
instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval motor controller for cart motor."
]
instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval motor controller for hoist motor."
]
instance HoistElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist used to pick up containers."
]

// Data Transmitted (over MQTT)
instance CraneTelemetryPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleSensor,
                        Anemometer,
                        CartMotorPositionSensor,
                        CartMotorCurrentSensor,
                        HoistMotorPositionSensor,
                        HoistMotorCurrentSensor
]

// Telemetry Record stored in TimescaleDB
instance CraneTelemetryRecord : DTDFVocab:Data [
    base:desc "Telemetry samples from the crane stored in TimescaleDB."
    DTDFVocab:fromData CraneTelemetryPacket
    DTDFVocab:inputTo LoggingEnabler,
                    TrajectoryEnabler,
                    SimulationEnabler,
                    ValidationEnabler
]

// Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Logs real‑time telemetry to TimescaleDB."
    DTDFVocab:provides RealTimeMonitoringInsight
]
instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal crane trajectories using a kinematic model."
    DTDFVocab:provides TrajectoryOptimizationInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates crane dynamics and controllers using the dynamic model."
    DTDFVocab:provides SimulationRunInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories with simulated ones and notifies operators when deviations exceed a threshold."
    DTDFVocab:provides ValidationAlertAction
]

// Insights
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring of crane dynamics derived from telemetry."
]
instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized trajectory suggestions based on the kinematic crane model."
]
instance SimulationRunInsight : DTDFVocab:Insight [
    base:desc "Results of crane dynamic simulations for applied trajectories."
]
instance ValidationAlertAction : DTDFVocab:Action [
    base:desc "Alert operators when executed trajectory deviates from simulated trajectory beyond threshold."
    DTDFVocab:IsAutomatic true
]
instance FaultPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicts potential faults from time‑series classification of telemetry data."
]

// Models
instance KinematicCraneModel : DTDFVocab:Model [
    base:desc "Cubic spline kinematic model of the gantry crane."
]
instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Python implementation of crane dynamics and controller simulation."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Twin’s Trajectory Generator Service outputs optimal movement trajectories (including swing‑free motion profiles) to the Control Application, which sends velocity setpoints to the cart and hoist motor controllers. Continuous Validation Service can produce alerts sent to the dashboard to trigger operator actions."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time operation and logging during crane execution; trajectory‑based validation performed after each executed trajectory; no specific sampling frequency is specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin constellation is coordinated by a Docker Compose network that links the Physical Crane Interface, Control Application, Logging Application, Trajectory Generator Service, Simulation Service, Continuous Validation Service, MQTT broker, TimescaleDB, and Grafana dashboard; data flows through MQTT topics and the database, while the dashboard provides a unified view for operators."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the full lifecycle: the CAD and kinematic models represent the design phase; the simulation and control scripts emulate the manufactured system; during operation, live telemetry logs and continuous validation monitor the PT and the twin’s behavior, allowing runtime adaptations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by using a physics‑based kinematic model for trajectory planning and a dynamic simulation that includes motor dynamics; validation is performed by continuously comparing measured state trajectories against simulated ones, computing distance metrics and triggering alerts if deviation exceeds a threshold, thereby verifying both model accuracy and system behaviour."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual data flow uses serial/USB communications to the Arduino, which forwards sensor data to the Logging Application. Virtual services communicate via MQTT (Eclipse Mosquitto) and store/retrieve data from TimescaleDB using SQL. Control commands follow the same path back to the motors."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin is deployed on a personal computer; the database, MQTT broker, and Grafana dashboards are run in Docker containers as defined in a Docker Compose file, while the gantrylib Python package is installed via pip and executed directly on the host. This lightweight deployment enables easy spin‑up and shut‑down."
]