// ===========================
// Physical Sensing Components
// ===========================
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing Angle Encoder measuring the crane swing angle"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting crane stability"
    DTDFVocab:producedData AnemometerDataTransmitted
]

// ===========================
// Physical Acting Component
// ===========================
instance CraneMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Motorized trolley actuator that drives horizontal movement of the gantry crane"
]

// ===========================
// Data Transmission Elements
// ===========================
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// ===========================
// Data Instances
// ===========================
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing angle measurements from the encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo PhysicalCraneInterface, LoggingApplication, MQTTBroker
]

instance AnemometerData : DTDFVocab:Data [
    base:desc "Time‑series of wind speed measurements from the anemometer"
    DTDFVocab:fromData AnemometerDataTransmitted
    DTDFVocab:inputTo PhysicalCraneInterface, LoggingApplication, MQTTBroker
]

// ===========================
// Enablers (Software/Infrastructure)
// ===========================
instance PhysicalCraneInterface : DTDFVocab:Enabler [
    base:desc "Python program that receives Arduino sensor streams and forwards state to twin services"
    DTDFVocab:enables OptimalControlService, RealTimeVisualizationService
]

instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Application that records incoming sensor data into TimescaleDB"
    DTDFVocab:enables HistoricalLoggingService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for inter‑service signalling"
    DTDFVocab:enables ContinuousValidationService, RealTimeVisualizationService
]

instance TimescaleDBDatabase : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database storing historical sensor and actuator data"
    DTDFVocab:enables HistoricalLoggingService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for real‑time visualization of crane performance"
    DTDFVocab:enables RealTimeVisualizationService
]

instance SimulationServiceEnabler : DTDFVocab:Enabler [
    base:desc "Backend service executing kinematic simulations of crane trajectories"
    DTDFVocab:enables SimulationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Service generating optimal motion trajectories from the kinematic model"
    DTDFVocab:enables OptimalControlService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Engine that compares logged physical data with simulated trajectories"
    DTDFVocab:enables ContinuousValidationService
]

// ===========================
// Models
// ===========================
instance CADModel : DTDFVocab:Model [
    base:desc "Geometric CAD representation of the gantry crane structure"
    DTDFVocab:inputTo SimulationService, RealTimeVisualizationService
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Behavioral kinematic model used for motion simulation and optimal control"
    DTDFVocab:inputTo SimulationService, OptimalControlService
]

// ===========================
// Services
// ===========================
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Provides optimal control commands for crane motion based on the kinematic model"
    DTDFVocab:provides ControlDecisionInsight, ExecuteControlAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Logs sensor and actuator states into TimescaleDB for later analysis"
    DTDFVocab:provides HistoricalLoggingInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of crane position, speed, and load via Grafana"
    DTDFVocab:provides VisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates physical crane behavior against simulated trajectories"
    DTDFVocab:provides ValidationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults and anomalies in crane operation for research studies"
    DTDFVocab:provides FaultDetectionInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Executes kinematic simulations to generate reference trajectories"
    DTDFVocab:provides SimulationResultInsight
]

// ===========================
// Insights
// ===========================
instance ControlDecisionInsight : DTDFVocab:Insight [
    base:desc "Optimal motion commands derived from the kinematic model for crane control"
]

instance HistoricalLoggingInsight : DTDFVocab:Insight [
    base:desc "Aggregated historical log of sensor and actuator data stored in TimescaleDB"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Live display of crane position, speed, and load on Grafana dashboard"
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Comparison results between physical measurements and simulated trajectories"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identified anomalies and fault conditions in crane operation"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulated trajectory data used for validation and control decision making"
]

// ===========================
// Actions
// ===========================
instance ExecuteControlAction : DTDFVocab:Action [
    base:desc "Command sent to the crane motor actuator to execute the optimal trajectory"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal movement trajectories using a kinematic model of the crane. These trajectories are passed to the Control Application, a Python application that uses the Physical Crane Interface to send command set‑points to the motor controllers (cart and hoist) of the physical crane. The Control Application therefore drives the crane according to the digital twin’s plan, and receives feedback through the same interface to confirm execution. The documents do not specify command formats, authentication, or conflict‑resolution mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a service‑oriented constellation orchestrated through an MQTT broker that provides pub/sub signaling among the Trajectory Generator, Simulation, and Continuous Validation services. Runtime data are persisted in a TimescaleDB instance and visualized via a Grafana dashboard. The logical components are described using the C4 model, and the twin can operate independently of the physical crane, enabling a decoupled yet tightly coordinated architecture."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The exemplar is employed to demonstrate continuous validation methods, fault detection techniques, and the DarTwin notation for system evolution, indicating that model fidelity is maintained through ongoing validation, though specific validation procedures or uncertainty quantification methods are not detailed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital‑twin components run on a single personal computer and are orchestrated with Docker Compose. The Database (TimescaleDB), MQTT Broker (Eclipse Mosquitto) and Dashboard (Grafana) are containerised and communicate over the host’s TCP/IP network. Signalling between services uses MQTT publish/subscribe; Grafana accesses the database via HTTP/SQL; and the Python applications interact with the MQTT broker and the database over standard TCP ports. The documents do not provide explicit bandwidth, latency, reliability, redundancy, or security protocol details."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin is deployed on‑premise on a personal computer. The Python modules are installed via pip (gantrylib). Docker containers host the TimescaleDB database, the MQTT broker, and the Grafana dashboard, and are started with a single docker‑compose command that also performs first‑time initialization of the database and dashboard. Computational and storage requirements are modest and suitable for a single workstation; scalability is limited to what Docker Compose can provide, and no cloud, edge, or distributed deployment models are mentioned. Availability is handled by Docker’s container management and automatic initialization scripts."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external components is achieved via the MQTT protocol for inter‑service messaging, SQL/TimescaleDB for data storage, and Grafana for visualization. No enterprise‑level standards (e.g., AutomationML) or external digital twins are referenced; the twin relies on these open‑source tools for data exchange and interoperability."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar models its digital twin using AutomationML, thereby adhering to the AutomationML standard for engineering data exchange. No other industry standards or certification frameworks are explicitly referenced in the documents."
]