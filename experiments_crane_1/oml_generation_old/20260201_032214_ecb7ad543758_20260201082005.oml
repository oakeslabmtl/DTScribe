// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring payload swing"
    DTDFVocab:producedData SensorMqttDataStream
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData SensorMqttDataStream
]

// C4: Physical-to-virtual interaction (data transmission)
instance SensorMqttDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder, Anemometer
]

// C10: Models/Data
instance CadFusion360Model : DTDFVocab:Model [
    base:desc "CAD models in Autodesk Fusion‑360"
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator"
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model of the crane and its controllers"
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance OperationalTimeseriesData : DTDFVocab:Data [
    base:desc "Time‑series operational data stored in TimescaleDB"
    DTDFVocab:fromData SensorMqttDataStream
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) for time‑series storage"
    DTDFVocab:enables DataLoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana for visualization of real‑time status and historic trends"
    DTDFVocab:enables GrafanaDashboardService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for signalling between services"
    DTDFVocab:enables TrajectoryGeneratorService, CraneSimulationService, ContinuousValidationService
]

instance PythonRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime and gantrylib package for application logic"
    DTDFVocab:enables TrajectoryGeneratorService, CraneSimulationService, ContinuousValidationService, DataLoggingService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logging application that records sensor data into TimescaleDB"
    DTDFVocab:provides HistoricTrendInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualization service for operators"
    DTDFVocab:provides RealTimeStatusInsight, HistoricTrendInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Optimal trajectory generation service providing swing‑free paths"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance CraneSimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation service of crane and controllers"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service comparing executed vs simulated trajectories"
    DTDFVocab:provides DeviatingTrajectoryAlertInsight, AdjustControlParametersAction, InterveneOperatorAction
]

// C17: Insights
instance DeviatingTrajectoryAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when executed trajectory deviates from simulated optimal trajectory"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Provides optimal swing‑free trajectory computed by the Trajectory Generator"
]

instance RealTimeStatusInsight : DTDFVocab:Insight [
    base:desc "Real‑time status of crane operation displayed on Grafana"
]

instance HistoricTrendInsight : DTDFVocab:Insight [
    base:desc "Historic trends of operational data visualized on Grafana"
]

// C17: Actions
instance AdjustControlParametersAction : DTDFVocab:Action [
    base:desc "Operator can adjust control parameters via the Human‑Machine Interface"
    DTDFVocab:IsAutomatic false
]

instance InterveneOperatorAction : DTDFVocab:Action [
    base:desc "Operator can manually intervene to stop or modify crane motion"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance CartStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor with Trinamic TMC4671‑Eval controller"
]

instance HoistStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor with Trinamic TMC4671‑Eval controller"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet end‑effector used to pick up and release pucks"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends motion commands (e.g., optimal trajectories generated by the Trajectory Generator Service) through the Physical Crane Interface to the motor controllers; the HMI also allows operators to issue commands that are relayed similarly via MQTT."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous (real‑time) operation: the Logging Application records state continuously, and the Continuous Validation Service runs continuously to compare live measurements with simulations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical sensors feed data via the Arduino to a Python interface that publishes to MQTT; services (trajectory generation, simulation, validation) subscribe to MQTT, read/write state from the TimescaleDB, and publish results to the Grafana dashboard; the Control Application consumes trajectory outputs to command the motors, closing the loop."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin spans the design stage (CAD models of the crane), the manufacturing/assembly stage (physical crane hardware), and the operational stage (runtime data acquisition, simulation, and validation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service computes distance metrics between measured trajectories and simulated trajectories, compares them against a predefined threshold, and raises alerts on the dashboard when the threshold is exceeded, thereby providing runtime fidelity checks."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication is performed over MQTT (Eclipse Mosquitto); data persistence uses TimescaleDB accessed via standard SQL; all containers share a Docker network; Python applications communicate with the Arduino via serial links."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software runs on a single personal computer; Docker containers host the database, MQTT broker, and Grafana dashboard; the gantrylib Python module is installed with pip; Docker‑Compose starts and stops the entire stack with a single command."
]