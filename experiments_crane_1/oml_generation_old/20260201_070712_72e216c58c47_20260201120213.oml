// C3: Physical Sensing Components // Return code: 1 | Stderr:
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted on Raspberry‑Pi air‑quality board."
    DTDFVocab:producedData TempDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor mounted on Raspberry‑Pi air‑quality board."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO2 concentration sensor mounted on Raspberry‑Pi air‑quality board."
    DTDFVocab:producedData CO2DataTransmitted
]

instance PM25Sensor : DTDFVocab:SensingComponent [
    base:desc "PM2.5 particulate matter sensor mounted on Raspberry‑Pi air‑quality board."
    DTDFVocab:producedData PM25DataTransmitted
]

instance RaspberryPiAirQualityBoard : DTDFVocab:Component [
    base:desc "Raspberry‑Pi board hosting temperature, humidity, CO2, and PM2.5 sensors."
    base:contains TemperatureSensor, HumiditySensor, CO2Sensor, PM25Sensor
]

// C4: Data Transmitted
instance TempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance PM25DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PM25Sensor
]

// C10: Models/Data
instance TempDataSeries : DTDFVocab:Data [
    base:desc "Time‑series temperature measurements ingested into TimescaleDB."
    DTDFVocab:fromData TempDataTransmitted
    DTDFVocab:inputTo TimescaleDBConnector
]

instance HumidityDataSeries : DTDFVocab:Data [
    base:desc "Time‑series humidity measurements ingested into TimescaleDB."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo TimescaleDBConnector
]

instance CO2DataSeries : DTDFVocab:Data [
    base:desc "Time‑series CO2 concentration measurements ingested into TimescaleDB."
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo TimescaleDBConnector
]

instance PM25DataSeries : DTDFVocab:Data [
    base:desc "Time‑series PM2.5 particulate matter measurements ingested into TimescaleDB."
    DTDFVocab:fromData PM25DataTransmitted
    DTDFVocab:inputTo TimescaleDBConnector
]

// C11: Enablers
instance TimescaleDBConnector : DTDFVocab:Enabler [
    base:desc "Connector that streams sensor time‑series data from Logging Application into TimescaleDB."
]

instance ActiveMQBroker : DTDFVocab:Enabler [
    base:desc "ActiveMQ message broker coordinating data flow between physical sensors and the digital twin."
]

// C6: Services
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Continuously captures and archives sensor traces for post‑hoc analysis."
    DTDFVocab:provides HistoricalTrendInsight
]

instance OptimizationControlService : DTDFVocab:Service [
    base:desc "Computes optimal motion trajectories to minimize energy consumption or operation time."
    DTDFVocab:provides HVACAdjustmentAction, IrrigationAdjustmentAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Displays real‑time 3D rendering of greenhouse state and sensor streams."
    DTDFVocab:provides LiveVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Automated comparison between digital twin predictions and physical measurements, flagging deviations."
    DTDFVocab:provides DeviationFlagAction
]

// Linking Enablers to Services
instance TimescaleDBConnectorEnables : DTDFVocab:Enabler [
    base:desc "TimescaleDB Connector enables Historical Data Logging Service."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance ActiveMQBrokerEnables : DTDFVocab:Enabler [
    base:desc "ActiveMQ Broker enables Optimization Control, Data Visualization, and Continuous Validation Services."
    DTDFVocab:enables OptimizationControlService, DataVisualizationService, ContinuousValidationService
]

// C17: Insights/Actions
instance HistoricalTrendInsight : DTDFVocab:Insight [
    base:desc "Aggregated historical trends of temperature, humidity, CO2, and PM2.5 from stored time‑series."
]

instance LiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live sensor streams and 3D rendering of greenhouse interior state."
]

instance HVACAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic HVAC control to maintain optimized indoor climate."
    DTDFVocab:IsAutomatic true
]

instance IrrigationAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic irrigation control to conserve water based on predictive models."
    DTDFVocab:IsAutomatic true
]

instance DeviationFlagAction : DTDFVocab:Action [
    base:desc "Automated flagging of deviations between twin predictions and physical sensor measurements."
    DTDFVocab:IsAutomatic true
]

// C1: Environment
instance GreenhouseEnvironment : DTDFVocab:Environment [
    base:contains RaspberryPiAirQualityBoard, TimescaleDBConnector, ActiveMQBroker
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control Application issues movement commands to the crane through the Physical Crane Interface. Commands are derived from trajectories generated by the Trajectory Generator Service and sent via the same Python API to the physical crane’s controllers. Feedback and command confirmation are handled within the application; no external authentication, validation or conflict‑resolution protocols are described."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows a loosely coupled, messaging‑centric pattern: sensor data flows from the greenhouse’s data acquisition system to the twin via an ActiveMQ broker; the twin stores historical data in an InfluxDB time‑series database and runs on pre‑built virtual machine images that include prerecorded data for testing. Deployment is achieved through containerized or virtualized environments, with separate virtual machines hosting the twin application, the message broker, and the database, thereby decoupling each component for scalability."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The exemplars follow a four‑phase development and operation cycle: design & modeling (construction of the physical plant model using AutomationML or simple sensor scripts), simulation & prediction (running virtual experiments or predictive analytics on Azure or local VM), deployment (installing the twin on the target hardware via containerised virtual machines or Docker stacks), and runtime monitoring & adaptive control (continuous data ingestion from Raspberry‑Pi sensors into an InfluxDB database over ActiveMQ, with automated behavioural adjustments to the greenhouse or indoor air‑quality system). Transition management between these phases is achieved by versioned VM images released through GitHub and automated Azure pipelines that rebuild the twin image when code changes are merged, ensuring consistent rollback and governance of model updates."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Services communicate over an MQTT broker, which is used for signaling between the Trajectory Generator, Simulation, Continuous Validation, and dashboard services. All Python processes publish and subscribe to relevant topics on the broker. No additional network topology, bandwidth, latency, reliability, or security details are provided in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Not in Document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External integration is mediated by the ActiveMQ message broker, which supports AMQP and OpenWire protocols, enabling data ingestion from the physical greenhouse to external analytics or control systems. The twin exposes an HTTP/REST API for external consumption, and the entire stack is versioned and distributed via a GitHub repository, allowing integration with CI/CD pipelines and cloud services. Additionally, the Azure‑based Air Quality exemplar demonstrates how similar twin architectures can be integrated with Microsoft Azure services for cloud‑based analytics."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The GreenhouseDT and Air Quality Management exemplars comply with the AutomationML standard for physical‑plant representation, ensuring interoperability between plant model tools and the twin. The use of Microsoft Azure IoT Suite provides adherence to Azure’s standardised device telemetry and messaging protocols. No additional commercial twin‑framework standards or industry certification requirements are referenced in the provided documents."
]