// C3: Physical sensing components // Return code: 1 | Stderr:
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder that measures the swing angle of the crane payload"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer that measures wind speed affecting the crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Data produced from sensors
instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Raw swing‑angle measurement (in degrees) received from the Swing Angle Encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo PythonPhysicalCraneInterface
]

instance WindSpeedMeasurement : DTDFVocab:Data [
    base:desc "Raw wind‑speed measurement (in m/s) received from the Anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo PythonPhysicalCraneInterface
]

// C10: Additional data and models
instance HistoricalCraneStateData : DTDFVocab:Data [
    base:desc "Historical time‑series of crane states (position, velocity, controller commands) stored in TimescaleDB"
    DTDFVocab:inputTo LoggingApplication
]

instance RealTimeVisualizationData : DTDFVocab:Data [
    base:desc "Live crane state stream visualized on operator dashboards"
    DTDFVocab:inputTo AzurePipeline
]

instance CADModelOfGantryCrane : DTDFVocab:Model [
    base:desc "Detailed CAD model of the gantry‑crane structure, carriage and payload"
    DTDFVocab:inputTo C4ModellingApproach, DockerContainerPlatform
]

instance KinematicModelOfCrane : DTDFVocab:Model [
    base:desc "Kinematic model describing the motion of the motor‑driven carriage and payload"
    DTDFVocab:inputTo PythonPhysicalCraneInterface
]

// C11: Enablers
instance PythonPhysicalCraneInterface : DTDFVocab:Enabler [
    base:desc "Python‑based interface that receives raw sensor measurements from the Arduino board and forwards them to downstream applications"
    DTDFVocab:enables OptimalMotionControlService, ContinuousValidationService
]

instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Application that writes time‑stamped records of angle, wind‑speed and controller states into TimescaleDB"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "Time‑series PostgreSQL database used for historical data logging"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance AzurePipeline : DTDFVocab:Enabler [
    base:desc "Microsoft Azure pipeline that processes sensor streams, runs air‑quality simulations and presents results via dashboards"
    DTDFVocab:enables RealTimeVisualizationService, AirQualityRuntimeVisualizationService, AirQualitySimulationService, AirQualityPredictionService
]

instance C4ModellingApproach : DTDFVocab:Enabler [
    base:desc "C4 modelling approach used for architectural documentation of the digital twin"
]

instance DockerContainerPlatform : DTDFVocab:Enabler [
    base:desc "Containerisation technology (Docker) used to package twin services in an ad‑hoc, framework‑free setup"
]

// C6: Services
instance OptimalMotionControlService : DTDFVocab:Service [
    base:desc "Provides optimal motion‑control commands for the carriage based on the kinematic model and current sensor feedback"
    DTDFVocab:provides MotionOptimizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates the kinematic model against measured swing‑angle and wind data"
    DTDFVocab:provides ModelValidationInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Logs crane state data to TimescaleDB for later analysis"
    DTDFVocab:provides HistoricalTrendInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Streams live crane data to operator dashboards for monitoring"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance AirQualityRuntimeVisualizationService : DTDFVocab:Service [
    base:desc "Runtime visualization of sensor measurements collected by a Raspberry‑Pi"
    DTDFVocab:provides AirQualityDashboardInsight
]

instance AirQualitySimulationService : DTDFVocab:Service [
    base:desc "Simulates indoor air‑quality dynamics"
    DTDFVocab:provides AirQualitySimulationInsight
]

instance AirQualityPredictionService : DTDFVocab:Service [
    base:desc "Predicts future air‑quality states to aid virus‑spread prevention"
    DTDFVocab:provides AirQualityPredictionInsight
]

// C17: Insights
instance MotionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight into optimal motion trajectories to improve throughput and reduce swing"
]

instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating discrepancies between model predictions and measured data"
]

instance HistoricalTrendInsight : DTDFVocab:Insight [
    base:desc "Insight derived from historical crane state trends for performance analysis"
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight providing current operational status for the operator"
]

instance AirQualityDashboardInsight : DTDFVocab:Insight [
    base:desc "Visualization of current air‑quality measurements from the Raspberry‑Pi"
]

instance AirQualitySimulationInsight : DTDFVocab:Insight [
    base:desc "Results of indoor air‑quality dynamics simulation"
]

instance AirQualityPredictionInsight : DTDFVocab:Insight [
    base:desc "Forecast of future air‑quality conditions to support preventive actions"
]

// C8: Physical components (contextual)
instance GantryCraneStructure : DTDFVocab:Component [
    base:desc "Lab‑scale gantry‑type crane frame inspired by Port of Antwerp harbor cranes"
]

instance MotorDrivenCarriage : DTDFVocab:Component [
    base:desc "Motor‑driven carriage that moves along the gantry"
]

instance ControllerUnit : DTDFVocab:Component [
    base:desc "Controller unit that issues motion commands to the carriage"
]

instance InterchangeablePuck : DTDFVocab:Component [
    base:desc "Container surrogate (puck) that can be placed on the carriage for transport"
]

instance EnvironmentLogisticsLab : DTDFVocab:Environment [
    base:contains GantryCraneStructure, MotorDrivenCarriage, ControllerUnit, InterchangeablePuck
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, a Python program, uses the Physical Crane Interface to issue command messages to the crane’s motor controllers and the electromagnet. Commands include motion set‑points for cart translation, hoist speed, and electromagnet activation/deactivation. The exact message format and validation mechanisms are not described, nor are authentication or acknowledgement protocols. Execution confirmation is provided to the operator through the Human Machine Interface and the Continuous Validation Service."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The lab‑scale gantry crane digital twin follows a container‑based orchestration pattern. Six twin‑related containers are deployed: a TimescaleDB instance storing all sensor and log data, a Grafana dashboard visualising that data, a Trajectory Generator Service that uses a kinematics model to compute swing‑free movement plans, a Simulation Service that reproduces the crane and controller behaviour, a Continuous Validation Service that continuously compares executed trajectories with their simulated counterpart and raises alerts when distance metrics exceed a threshold, and an MQTT broker that provides lightweight, publish‑subscribe signalling among the services. All services are implemented in Python and interact through the MQTT broker and the shared TimescaleDB, constituting a loosely‑coupled, centrally‑managed constellation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin provides a continuous validation service that monitors the correspondence between the physical crane behavior and its digital models, supporting model verification during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital‑twin services communicate over a local Docker‑based network. An Eclipse Mosquitto MQTT broker provides publish/subscribe signaling between the Trajectory Generator, Simulation, Continuous Validation, and other services. The TimescaleDB database and Grafana dashboard run as separate Docker containers reachable via the Docker bridge network. No explicit bandwidth, latency, or redundancy specifications are given; the deployment relies on standard TCP/IP within a single host."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin components are deployed on‑premise on a single personal computer. Python containers are bundled in the pip‑installable gantrylib module, while the Database (TimescaleDB), MQTT broker (Mosquitto) and Dashboard (Grafana) are containerized with Docker and orchestrated via a docker‑compose file. This on‑edge deployment requires modest compute (a typical PC) and storage for time‑series data; scalability is achieved by replicating Docker containers, though no cloud or distributed hosting is described. Availability is managed through Docker‑compose start‑up scripts that initialise the services automatically."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar adopts an AutomationML‑based digital twin, complying with the AutomationML (AML) specification for model‑driven twin engineering. No other standards, certifications, or interoperability frameworks are explicitly mentioned."
]