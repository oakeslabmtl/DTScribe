// C3: Physical sensing components
instance SwingAngleSensor : DTDFVocab:SensingComponent [
  base:desc "Swing‑angle encoder that measures the crane's swing angle and feeds this data to the twin."
  DTDFVocab:producedData SwingAngleMessage
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
  base:desc "Anemometer measuring wind speed around the crane."
  DTDFVocab:producedData AnemometerMessage
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
  base:desc "Sensor reading controller status and motor position via TMC4671 motor drivers."
  DTDFVocab:producedData MotorStatusMessage
]

// Physical‑to‑virtual interaction (Data Transmitted)
instance SwingAngleMessage : DTDFVocab:DataTransmitted [
  DTDFVocab:producedFrom SwingAngleSensor
]

instance AnemometerMessage : DTDFVocab:DataTransmitted [
  DTDFVocab:producedFrom AnemometerSensor
]

instance MotorStatusMessage : DTDFVocab:DataTransmitted [
  DTDFVocab:producedFrom MotorStatusSensor
]

// C10: Models/Data
instance SwingAngleData : DTDFVocab:Data [
  base:desc "Time‑series data of swing angle stored in TimescaleDB."
  DTDFVocab:fromData SwingAngleMessage
  DTDFVocab:inputTo TimescaleDBEnabler
]

instance AnemometerData : DTDFVocab:Data [
  base:desc "Time‑series data of wind speed."
  DTDFVocab:fromData AnemometerMessage
  DTDFVocab:inputTo TimescaleDBEnabler
]

instance MotorStatusData : DTDFVocab:Data [
  base:desc "Time‑series data of motor positions and controller health status."
  DTDFVocab:fromData MotorStatusMessage
  DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers
instance MosquittoBroker : DTDFVocab:Enabler [
  base:desc "Eclipse Mosquitto MQTT broker exposing topics for twin communication."
  DTDFVocab:enables MQTTBrokerService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
  base:desc "TimescaleDB instance storing telemetry logs."
  DTDFVocab:enables DatabaseService
]

instance SimulationEngine : DTDFVocab:Enabler [
  base:desc "Physics‑based simulation engine of crane dynamics and controller behavior."
  DTDFVocab:enables PhysicsBasedSimulationService
]

instance TrajectoryGeneratorEngine : DTDFVocab:Enabler [
  base:desc "Analytical kinematic model engine used for optimal trajectory generation."
  DTDFVocab:enables TrajectoryGenerationService
]

instance ContinuousValidatorEngine : DTDFVocab:Enabler [
  base:desc "Engine performing real‑time distance‑metric validation between logged and simulated trajectories."
  DTDFVocab:enables ContinuousValidationService
]

instance FaultDetectorEngine : DTDFVocab:Enabler [
  base:desc "Time‑series classification engine for fault probability prediction."
  DTDFVocab:enables FaultDetectionService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
  base:desc "Grafana dashboard system visualizing live telemetry with confidence bounds."
  DTDFVocab:enables DashboardVisualizationService
]

instance HumanMachineInterface : DTDFVocab:Enabler [
  base:desc "Python‑based human‑machine interface for operator control."
  DTDFVocab:enables HumanMachineInterfaceService
]

// C6: Services
instance DatabaseService : DTDFVocab:Service [
  base:desc "Service providing real‑time data logging and storage via TimescaleDB."
  DTDFVocab:provides DataLoggingStatusInsight
]

instance MQTTBrokerService : DTDFVocab:Service [
  base:desc "Service providing message brokering via Mosquitto."
  DTDFVocab:provides MessageBrokerStatusInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
  base:desc "Service generating optimal crane trajectories using analytical models."
  DTDFVocab:provides TrajectoryPerformanceMetrics
]

instance PhysicsBasedSimulationService : DTDFVocab:Service [
  base:desc "Service running detailed physics‑based simulation of crane and controller."
  DTDFVocab:provides SimulationIntegrityInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
  base:desc "Service performing continuous validation of logged vs simulated trajectories."
  DTDFVocab:provides RealTimeValidationAlert
]

instance FaultDetectionService : DTDFVocab:Service [
  base:desc "Service detecting faults through time‑series classification."
  DTDFVocab:provides FaultProbabilityPrediction
]

instance DashboardVisualizationService : DTDFVocab:Service [
  base:desc "Service providing real‑time dashboards and historical trend analysis."
  DTDFVocab:provides HistoricalMotorLoadTrend
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
  base:desc "Service enabling operator interaction and configuration."
  DTDFVocab:provides UpdateControlParameters
]

// C17: Insights/Actions
instance TrajectoryPerformanceMetrics : DTDFVocab:Insight [
  base:desc "Insight of trajectory performance metrics such as path deviation and completion time."
]

instance RealTimeValidationAlert : DTDFVocab:Insight [
  base:desc "Insight of real‑time validation alerts when trajectory deviates beyond threshold."
]

instance HistoricalMotorLoadTrend : DTDFVocab:Insight [
  base:desc "Insight providing historical trend analysis of motor loads."
]

instance FaultProbabilityPrediction : DTDFVocab:Insight [
  base:desc "Insight of fault probability predictions from classification models."
]

instance DataLoggingStatusInsight : DTDFVocab:Insight [
  base:desc "Insight of real‑time data logging status of telemetry data into TimescaleDB."
]

instance MessageBrokerStatusInsight : DTDFVocab:Insight [
  base:desc "Insight of MQTT broker activity and message throughput."
]

instance SimulationIntegrityInsight : DTDFVocab:Insight [
  base:desc "Insight of simulation fidelity compared to logged data."
]

instance UpdateControlParameters : DTDFVocab:Action [
  base:desc "Action representing automated or operator‑initiated updates to control parameters without altering physical system."
  DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance CartActuatorAct : DTDFVocab:ActingComponent [
  base:desc "Stepper wheel motor for cart movement controlled by TMC4671 controller."
]

instance HoistActuatorAct : DTDFVocab:ActingComponent [
  base:desc "Stepper wheel motor for hoist movement controlled by TMC4671 controller."
]

instance ElectromagnetActuatorAct : DTDFVocab:ActingComponent [
  base:desc "Electromagnet used to pick up and release pucks."
]

// C4: Physical Sensing Components (Components)
instance GantryFrameComponent : DTDFVocab:Component [
  base:desc "Gantry frame supporting the crane structure."
]

instance ArduinoLogicUnitComponent : DTDFVocab:Component [
  base:desc "Arduino microcontroller that reads sensors and writes commands to motor controllers."
]

instance TwelveVoltPowerSupplyComponent : DTDFVocab:Component [
  base:desc "12 V power supply unit powering the system electronics."
]

instance IntegratedControlElectronicsComponent : DTDFVocab:Component [
  base:desc "Integrated controller electronics managing motor drivers and sensors."
]

// C17: Environment
instance LaboratoryScaleGantryCrane : DTDFVocab:Environment [
  base:contains GantryFrameComponent, CartActuatorAct, HoistActuatorAct, ElectromagnetActuatorAct,
           SwingAngleSensor, AnemometerSensor, MotorStatusSensor,
           ArduinoLogicUnitComponent, TwelveVoltPowerSupplyComponent, IntegratedControlElectronicsComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal Cartesian trajectories using a kinematic model of the crane and publishes the resulting motor commands to the Physical Crane Interface over MQTT. The Control Application consumes these commands and forwards them to the appropriate motor controllers. Resulting state changes are reflected back to the twin via the logging stream."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation comprises the Physical Crane and its control interface, the Control Application, Logging Application, HMI, and the digital twin stack: Database, MQTT broker, Trajectory Generator Service, Simulation Service, Continuous Validation Service, Dashboard. All are connected through a local network via MQTT for inter‑service communication, with persistent state in TimescaleDB. The whole system is orchestrated by a Docker Compose setup deployed on a personal PC."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The exemplar spans all twin lifecycle stages: (a) design‑time – CAD models in Autodesk Fusion360 and kinematic models used by trajectory generation; (b) manufacturing – BOM assembled in the lab, custom shield and Arduino firmware deployed; (c) operation – runtime services (control, logging, validation) deployed via Docker Compose on a host PC, with data collection, visualization and fault monitoring continuously active."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation is performed by the Continuous Validation Service which computes distance metrics between executed trajectories (PT logs) and simulated trajectories, comparing them against a pre‑defined acceptable threshold. The kinematic model’s fidelity is ensured during design and validated against physical measurements. Uncertainty arising from sensor noise, motor delays, and wind is implicitly addressed by the simulation confidence bounds."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Intra‑twin communication uses MQTT (Eclipse Mosquitto) over TCP on the local host. Data persistence via TimescaleDB uses PostgreSQL over TCP. The Physical Crane Interface communicates with the Arduino microcontroller over a serial/USB link; the controllers are addressed by the motor drivers via the Python program."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital twin services are packaged as Docker containers and launched via a Docker Compose configuration on the same host PC as the physical crane. The database, broker, and dashboard containers are initialised automatically. The repository is hosted on GitHub and serves documentation via MkDocs on GitHub Pages."
]