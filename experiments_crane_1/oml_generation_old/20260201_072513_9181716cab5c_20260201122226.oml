// Acting Components
instance CartMotorDrive : DTDFVocab:ActingComponent [
    base:desc "Electromechanical cart motor drive via Trinamic TMC4671–Eval driver controlled by an Arduino motor‑controller board."
]

instance HoistMotorDrive : DTDFVocab:ActingComponent [
    base:desc "Electromechanical hoist motor drive via Trinamic TMC4671–Eval driver controlled by an Arduino motor‑controller board."
]

// Physical Sensing Components
instance CartMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the cart motor to measure rotational position; sampled by PhysicalCraneInterface."
    DTDFVocab:producedData CartMotorEncoderDataTrans
]

instance HoistMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the hoist motor to measure rotational position; sampled by PhysicalCraneInterface."
    DTDFVocab:producedData HoistMotorEncoderDataTrans
]

instance CartMotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor on the cart motor to monitor electrical consumption; sampled by PhysicalCraneInterface."
    DTDFVocab:producedData CartMotorCurrentSensorDataTrans
]

instance HoistMotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor on the hoist motor to monitor electrical consumption; sampled by PhysicalCraneInterface."
    DTDFVocab:producedData HoistMotorCurrentSensorDataTrans
]

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder measuring hoist oscillation; sampled by PhysicalCraneInterface."
    DTDFVocab:producedData SwingAngleEncoderDataTrans
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed impacting the crane; sampled by PhysicalCraneInterface."
    DTDFVocab:producedData WindSpeedAnemometerDataTrans
]

// Data Transmitted (over MQTT)
instance CartMotorEncoderDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoder
]

instance HoistMotorEncoderDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoder
]

instance CartMotorCurrentSensorDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorCurrentSensor
]

instance HoistMotorCurrentSensorDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorCurrentSensor
]

instance SwingAngleEncoderDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedAnemometerDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

// Data Instances
instance CartMotorEncoderData : DTDFVocab:Data [
    base:desc "Cart motor encoder readings timestamped and transmitted over MQTT at ~100 Hz."
    DTDFVocab:fromData CartMotorEncoderDataTrans
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HoistMotorEncoderData : DTDFVocab:Data [
    base:desc "Hoist motor encoder readings timestamped and transmitted over MQTT at ~100 Hz."
    DTDFVocab:fromData HoistMotorEncoderDataTrans
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance CartMotorCurrentData : DTDFVocab:Data [
    base:desc "Current measurement of the cart motor captured via Arduino firmware."
    DTDFVocab:fromData CartMotorCurrentSensorDataTrans
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HoistMotorCurrentData : DTDFVocab:Data [
    base:desc "Current measurement of the hoist motor captured via Arduino firmware."
    DTDFVocab:fromData HoistMotorCurrentSensorDataTrans
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Swing angle of the hoist measured by the encoder; essential for trajectory optimization."
    DTDFVocab:fromData SwingAngleEncoderDataTrans
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Wind speed affecting the crane dynamics; used for fault detection and validation."
    DTDFVocab:fromData WindSpeedAnemometerDataTrans
    DTDFVocab:inputTo TimescaleDBEnabler
]

// Models
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Mathematical kinematic model of the gantry crane used for trajectory generation and simulation."
    DTDFVocab:inputTo EnablerModelLibrary
]

instance CADCraneChassisModel : DTDFVocab:Model [
    base:desc "CAD geometry of the crane chassis served to the simulation service."
    DTDFVocab:inputTo EnablerModelLibrary
]

// Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker centrally hosted on the host, facilitating publish/subscribe communication."
    DTDFVocab:enables RealTimeDataLoggingService, TrajectoryGeneratorService, ControlApplicationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database storing sensor logs, trajectory commands, simulation outputs, and validation metrics."
    DTDFVocab:enables RealTimeDataLoggingService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService, FaultDetectionService, GrafanaDashboardService
]

instance ContainerRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Docker container runtime orchestrating all services on a single host."
    DTDFVocab:enables RealTimeDataLoggingService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService, FaultDetectionService, GrafanaDashboardService, ControlApplicationService
]

instance EnablerModelLibrary : DTDFVocab:Enabler [
    base:desc "Library enclosure enabling the use of crane models by the trajectory generator and simulation services."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService
]

// Services
instance RealTimeDataLoggingService : DTDFVocab:Service [
    base:desc "Collects sensor data streams over MQTT and persists them in TimescaleDB."
    DTDFVocab:provides DataCollectionInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal crane trajectories using the kinematic model, minimizing swing."
    DTDFVocab:provides TrajectoryOptimizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates crane dynamics to predict trajectory and provide confidence intervals."
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares logged sensor data against simulation predictions, alerts if distance exceeds threshold."
    DTDFVocab:provides ValidationAlertInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Classifies time‑series data to localise anomalies in motors or sensors."
    DTDFVocab:provides FaultLocalizationInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Visualises key metrics from TimescaleDB on Grafana dashboards for stakeholders."
    DTDFVocab:provides MaintenancePlanInsight
]

instance ControlApplicationService : DTDFVocab:Service [
    base:desc "Receives operator adjustments and commands, publishes trajectory commands via MQTT."
    DTDFVocab:provides OperatorAdjustmentAction
]

// Insights
instance DataCollectionInsight : DTDFVocab:Insight [
    base:desc "Sensor data logged from the PhysicalCraneInterface and stored in TimescaleDB."
]

instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Calculated trajectory minimising swing for the lab‑scale gantry crane."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation output predictions of crane dynamics at each time step."
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Validation alert when deviation between measured and simulated trajectories exceeds predefined threshold."
]

instance FaultLocalizationInsight : DTDFVocab:Insight [
    base:desc "Anomaly detected in motor encoder currents or wind speed, localising fault to specific component."
]

instance MaintenancePlanInsight : DTDFVocab:Insight [
    base:desc "Recommended maintenance schedule derived from error statistics and usage patterns."
]

// Actions
instance OperatorAdjustmentAction : DTDFVocab:Action [
    base:desc "Manual operator adjustment of the trajectory generator parameters via HMI."
    DTDFVocab:IsAutomatic false
]

instance MaintenanceScheduleAction : DTDFVocab:Action [
    base:desc "Automated maintenance schedule generation and notification."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The trajectory generator publishes target angles and motor step commands to the control application via MQTT; the control application translates these into driver signals for the motors. The continuous‑validation service can push alerts to the HMI dashboard. All commands flow through the Mosquitto broker."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Control and validation run in real‑time at sub‑second intervals (~10–100 Hz for telemetry, <1 s for trajectory updates); simulation runs asynchronously on the same host, producing confidence bounds within milliseconds of trajectory generation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated by a docker‑compose file that starts the MQTT broker, TimescaleDB, and Grafana containers. The physical‑crane interface, control application, logging application, and HMI run as Python processes on the host PC and communicate via MQTT topics. Services exchange messages through the broker; all telemetry is persisted to the database; dashboards ingest and display live data."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design phase: CAD models and kinematic model created; Manufacturing phase: physical crane constructed from BOM; Operation phase: crane runs real‑time; Twin provides continuous validation and fault detection throughout operation; Research and teaching use cases drive evolution across the full lifecycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service computes residual distances between recorded sensor trajectories and simulated trajectories; a threshold defines acceptable quality. Simulations are validated against real platform data; CAD and kinematic models are verified against the constructed crane. Validation metrics and fault‑detection performance are reported in related publications."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication uses MQTT over TCP/IP on localhost; the physical sensors and actuators connect via Arduino over serial USB; control commands are published to MQTT topics consumed by driver modules; telemetry is written to TimescaleDB via PostgreSQL queries."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin services run in Docker containers on a single personal computer using Docker‑compose. The stack includes TimescaleDB, Mosquitto, Grafana, and Python applications; deployment is achieved by running 'docker‑compose up --build'."
]