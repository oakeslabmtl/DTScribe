// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing‑angle of the crane carriage"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the lab crane, read via Arduino"
    DTDFVocab:producedData AnemometerDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// C10: Data
instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Real‑time swing‑angle value streamed from the encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo PhysicalCraneInterfaceEnabler
]

instance AnemometerMeasurement : DTDFVocab:Data [
    base:desc "Real‑time wind speed measurement from the anemometer"
    DTDFVocab:fromData AnemometerDataTransmitted
    DTDFVocab:inputTo PhysicalCraneInterfaceEnabler
]

instance CraneStateRecord : DTDFVocab:Data [
    base:desc "Time‑series record of crane pose, puck positions and sensor readings persisted in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers (tools, platforms, logical containers)
instance PhysicalCraneInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Python program that connects to the crane controllers and exposes sensor streams"
    DTDFVocab:enables OptimalControlService, HistoricalLoggingService, DataVisualizationService, ContinuousValidationService
]

instance LoggingApplicationEnabler : DTDFVocab:Enabler [
    base:desc "Application that continuously reads crane state via the PhysicalCraneInterface and writes into TimescaleDB"
    DTDFVocab:enables HistoricalLoggingService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance storing historical operational data"
    DTDFVocab:enables HistoricalLoggingService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard visualising crane pose, puck locations and metrics"
    DTDFVocab:enables DataVisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Service generating optimal motion trajectories for the crane"
    DTDFVocab:enables OptimalControlService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation service used for what‑if analysis and air‑quality scenario testing"
    DTDFVocab:enables AirQualitySimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Service that continuously compares measured behaviour against the kinematic model"
    DTDFVocab:enables ContinuousValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker handling messaging between all logical containers"
    DTDFVocab:enables OptimalControlService, HistoricalLoggingService, DataVisualizationService, ContinuousValidationService, AirQualityVisualizationService, AirQualitySimulationService, AirQualityPredictionService
]

// C10: Models/Data
instance CraneCADModel : DTDFVocab:Model [
    base:desc "Detailed CAD geometry of the laboratory‑scale gantry crane"
    DTDFVocab:inputTo SimulationEnabler, DataVisualizationService
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model describing crane motion, used for control and validation"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler, ContinuousValidationEnabler
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes and dispatches optimal motion commands to the crane controller"
    DTDFVocab:provides DispatchMotionCommand
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Records sensor readings and actuator states over time into TimescaleDB"
    DTDFVocab:provides HistoricalMetricsInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Renders crane pose, puck positions and operation metrics on the Grafana dashboard"
    DTDFVocab:provides RealTimePoseInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Automatically compares measured behaviour against the kinematic model to detect deviations"
    DTDFVocab:provides DeviationAlertInsight
]

instance AirQualityVisualizationService : DTDFVocab:Service [
    base:desc "Streams indoor air‑quality sensor data from a Raspberry‑Pi to a runtime visualization dashboard"
    DTDFVocab:provides AirQualityRealtimeInsight
]

instance AirQualitySimulationService : DTDFVocab:Service [
    base:desc "Performs what‑if analysis of ventilation or occupancy changes on indoor air quality"
    DTDFVocab:provides AirQualityWhatIfInsight
]

instance AirQualityPredictionService : DTDFVocab:Service [
    base:desc "Generates forecasts of pollutant levels to support mitigation decisions"
    DTDFVocab:provides AirQualityForecastInsight
]

// C17: Insights / Actions
instance DispatchMotionCommand : DTDFVocab:Action [
    base:desc "Automatic dispatch of computed motion commands to the crane controller"
    DTDFVocab:IsAutomatic true
]

instance HistoricalMetricsInsight : DTDFVocab:Insight [
    base:desc "Aggregated historical metrics of crane operations for analysis"
]

instance RealTimePoseInsight : DTDFVocab:Insight [
    base:desc "Live visualisation of crane pose and puck locations"
]

instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert signalling deviation between measured behaviour and kinematic model predictions"
]

instance AirQualityRealtimeInsight : DTDFVocab:Insight [
    base:desc "Runtime visualisation of indoor air‑quality measurements"
]

instance AirQualityWhatIfInsight : DTDFVocab:Insight [
    base:desc "Simulation results of hypothetical ventilation or occupancy changes"
]

instance AirQualityForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted indoor pollutant levels for future time horizons"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, a Python service, uses the Physical Crane Interface to transmit control commands to the crane’s controllers. Commands (such as movement trajectories generated by the Trajectory Generator Service) are sent through the interface to the motors and hoist, effecting physical actions on the crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital‑twin architecture follows a service‑oriented pattern where the six containers are coordinated via an MQTT broker for event‑driven signalling and a common TimescaleDB for state persistence. The Physical Crane Interface (a Python program) feeds real‑time measurements into the Logging Application, which stores them in the database. The Trajectory Generator Service creates optimal movement plans using a kinematics model; the Simulation Service can replay these plans; the Continuous Validation Service continuously compares logged measurements with simulated results, computes distance metrics, and raises alerts via the Grafana dashboard when thresholds are exceeded. All services are implemented in Python and run on virtual machines or containers, enabling modular deployment and resource management."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The exemplar is employed to illustrate continuous‑validation methods, fault‑detection techniques based on time‑series classification, and co‑evolution validation of the digital twin. Validation is achieved by comparing predictions of the kinematic model with measured behaviour of the physical crane and by applying the DarTwin notation for system evolution, constituting the quality‑assurance process for model fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital‑twin services are deployed as Docker containers on a single host computer and orchestrated with Docker Compose. An Eclipse Mosquitto MQTT broker provides signaling between services, while the TimescaleDB database and Grafana dashboard are also containerized. Communication between services occurs over the local Docker network using MQTT for inter‑service messages and standard TCP/IP for database and dashboard access."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin runs on‑premise on a personal computer. Python containers are packaged in the pip‑installable module gantrylib, and the Database, MQTT Broker, and Dashboard are containerized with Docker. Deployment is performed via a provided Docker‑Compose file that starts and stops all containers on the host, offering a reproducible, single‑machine deployment with open‑source components."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external components is realized through the MQTT protocol (for inter‑service signalling) and standard open‑source tools: TimescaleDB for time‑series storage and Grafana for data visualization. The Physical Crane Interface connects to the crane controllers via a Python API, exposing sensor data to the twin. No enterprise‑level standards (e.g., AutomationML) or additional external Digital Twins are referenced for this exemplar."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar uses AutomationML as the modeling framework for its digital twin, complying with the AutomationML specification to achieve interoperable model exchange. No additional industry standards, certifications, or compliance frameworks are mentioned in the documents."
]