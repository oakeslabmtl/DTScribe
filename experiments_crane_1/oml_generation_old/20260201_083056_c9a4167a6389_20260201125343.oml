// C3: Physical sensing components
instance GreenhouseTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted inside the greenhouse to monitor ambient temperature"
    DTDFVocab:producedData GreenhouseTemperatureDataTransmitted
]

instance GreenhouseHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor mounted inside the greenhouse to monitor interior humidity"
    DTDFVocab:producedData GreenhouseHumidityDataTransmitted
]

instance GreenhouseLightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor mounted inside the greenhouse to monitor irradiance"
    DTDFVocab:producedData GreenhouseLightDataTransmitted
]

instance AirQualityCO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor in the Raspberry‑Pi-based indoor air quality instrument suite"
    DTDFVocab:producedData AirQualityCO2DataTransmitted
]

instance AirQualityVOCSensor : DTDFVocab:SensingComponent [
    base:desc "Volatile organic compound sensor in the indoor air quality instrument suite"
    DTDFVocab:producedData AirQualityVOCDataTransmitted
]

instance AirQualityPMSensor : DTDFVocab:SensingComponent [
    base:desc "Particulate matter sensor (PM2.5 / PM10) in the indoor air quality instrument suite"
    DTDFVocab:producedData AirQualityPMDataTransmitted
]

instance AirQualityTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor in the indoor air quality instrument suite"
    DTDFVocab:producedData AirQualityTemperatureDataTransmitted
]

instance AirQualityHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor in the indoor air quality instrument suite"
    DTDFVocab:producedData AirQualityHumidityDataTransmitted
]

instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position encoder for the lab‑scale gantry crane"
    DTDFVocab:producedData CranePositionDataTransmitted
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Velocity encoder for the lab‑scale gantry crane"
    DTDFVocab:producedData CraneVelocityDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance GreenhouseTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseTemperatureSensor
]

instance GreenhouseHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseHumiditySensor
]

instance GreenhouseLightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseLightSensor
]

instance AirQualityCO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityCO2Sensor
]

instance AirQualityVOCDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityVOCSensor
]

instance AirQualityPMDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityPMSensor
]

instance AirQualityTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityTemperatureSensor
]

instance AirQualityHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityHumiditySensor
]

instance CranePositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor
]

instance CraneVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocitySensor
]

// C10: Models/Data
instance GreenhouseTemperatureData : DTDFVocab:Data [
    base:desc "Recorded temperature reading from greenhouse sensor"
    DTDFVocab:fromData GreenhouseTemperatureDataTransmitted
    DTDFVocab:inputTo InfluxDBEnabler
]

instance GreenhouseHumidityData : DTDFVocab:Data [
    base:desc "Recorded humidity reading from greenhouse sensor"
    DTDFVocab:fromData GreenhouseHumidityDataTransmitted
    DTDFVocab:inputTo InfluxDBEnabler
]

instance GreenhouseLightData : DTDFVocab:Data [
    base:desc "Recorded light intensity reading from greenhouse sensor"
    DTDFVocab:fromData GreenhouseLightDataTransmitted
    DTDFVocab:inputTo InfluxDBEnabler
]

instance AirQualityCO2Data : DTDFVocab:Data [
    base:desc "Recorded CO₂ concentration from indoor air quality sensor"
    DTDFVocab:fromData AirQualityCO2DataTransmitted
    DTDFVocab:inputTo AzureIoTHubEnabler, AzureMachineLearningEnabler, AutomationMLEnabler
]

instance AirQualityVOCData : DTDFVocab:Data [
    base:desc "Recorded VOC level from indoor air quality sensor"
    DTDFVocab:fromData AirQualityVOCDataTransmitted
    DTDFVocab:inputTo AzureIoTHubEnabler, AzureMachineLearningEnabler, AutomationMLEnabler
]

instance AirQualityPMData : DTDFVocab:Data [
    base:desc "Recorded particulate matter concentration from indoor air quality sensor"
    DTDFVocab:fromData AirQualityPMDataTransmitted
    DTDFVocab:inputTo AzureIoTHubEnabler, AzureMachineLearningEnabler, AutomationMLEnabler
]

instance AirQualityTemperatureData : DTDFVocab:Data [
    base:desc "Recorded temperature from indoor air quality sensor"
    DTDFVocab:fromData AirQualityTemperatureDataTransmitted
    DTDFVocab:inputTo AzureIoTHubEnabler, AzureMachineLearningEnabler, AutomationMLEnabler
]

instance AirQualityHumidityData : DTDFVocab:Data [
    base:desc "Recorded humidity from indoor air quality sensor"
    DTDFVocab:fromData AirQualityHumidityDataTransmitted
    DTDFVocab:inputTo AzureIoTHubEnabler, AzureMachineLearningEnabler, AutomationMLEnabler
]

instance CranePositionData : DTDFVocab:Data [
    base:desc "Recorded crane position from position encoder"
    DTDFVocab:fromData CranePositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, LoggingAppEnabler
]

instance CraneVelocityData : DTDFVocab:Data [
    base:desc "Recorded crane velocity from velocity encoder"
    DTDFVocab:fromData CraneVelocityDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, LoggingAppEnabler
]

// C11: Enablers
instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database persisting greenhouse sensor streams and control logs"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance ActiveMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "ActiveMQ broker routing instrumentation and command messages between greenhouse hardware and Twin simulation"
    DTDFVocab:enables OptimalMotionPlanningService
]

instance AzureIoTHubEnabler : DTDFVocab:Enabler [
    base:desc "Azure IoT Hub receiving Raspberry‑Pi sensor data and forwarding to Azure ML services"
    DTDFVocab:enables DataVisualizationService, ContinuousValidationService
]

instance AzureMachineLearningEnabler : DTDFVocab:Enabler [
    base:desc "Azure Machine Learning processing for runtime visualization, simulation, and predictive forecasting"
    DTDFVocab:enables ContinuousValidationService, SelfAdaptiveBehaviorLearningService
]

instance AutomationMLEnabler : DTDFVocab:Enabler [
    base:desc "AutomationML representation of the indoor air quality environment providing structural model data"
    DTDFVocab:enables DataVisualizationService
]

instance DockerContainerRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Docker container runtime packaging Twin logic and data connectors for reproducible deployment"
    DTDFVocab:enables HistoricalDataLoggingService, SelfAdaptiveBehaviorLearningService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database storing crane state updates logged by the Logging Application"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance LoggingAppEnabler : DTDFVocab:Enabler [
    base:desc "Logging Application that collects and timestamps crane status information before ingestion"
    DTDFVocab:enables HistoricalDataLoggingService
]

// C6: Services
instance OptimalMotionPlanningService : DTDFVocab:Service [
    base:desc "Trajectory generation service that computes collision‑free paths for the gantry crane"
    DTDFVocab:provides OptimalPathAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Captures state traces (position, velocity, actuator commands) for post‑mortem analysis"
    DTDFVocab:provides HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Interactive dashboard displaying live telemetry and logged data"
    DTDFVocab:provides VisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares real‑time sensor measurements against the kinematic model to detect discrepancies"
    DTDFVocab:provides TrajectoryDeviationInsight, PathCorrectionAction, OperatorAlertAction
]

instance SelfAdaptiveBehaviorLearningService : DTDFVocab:Service [
    base:desc "Self‑adaptive behavior model that learns from greenhouse data exported in virtual machine images"
    DTDFVocab:provides LearningInsight
]

// C17: Insights
instance TrajectoryDeviationInsight : DTDFVocab:Insight [
    base:desc "Quantifies deviations between actual and predicted crane trajectory to indicate motion within tolerance bands"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Provides logged deviation statistics for offline analysis and iterative control strategy refinement"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Displays live telemetry and historical data to operators via the interactive dashboard"
]

instance LearningInsight : DTDFVocab:Insight [
    base:desc "Insights derived from greenhouse data used to refine the self‑adaptive Twin behavior model"
]

// C17: Actions
instance PathCorrectionAction : DTDFVocab:Action [
    base:desc "Automatically adjusts crane path based on deviation analysis to maintain trajectory accuracy"
    DTDFVocab:IsAutomatic true
]

instance OperatorAlertAction : DTDFVocab:Action [
    base:desc "Alerts operators when crane motion deviates beyond predefined tolerance bands requiring manual intervention"
    DTDFVocab:IsAutomatic false
]

instance OptimalPathAction : DTDFVocab:Action [
    base:desc "Computes and recommends collision‑free optimal motion path for the gantry crane"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application orchestrates the crane by sending control commands through the Python‑based Crane Interface to the Physical Crane’s controller hardware. Commands (e.g., move to target coordinates) are issued from the Control Application logic and forwarded to the crane. The document does not detail command formats, validation, authentication, or feedback mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin is organized into six Docker containers (or virtual machine images) as specified by the container diagram. These components include: a Python logging service that captures physical sensor streams and pushes them to a database; an MQTT broker that routes messages between services; a validation service that continuously compares sensor data to the simulated state; a visualization service that renders runtime status; a simulation engine that provides predicted dynamics; and a database service that persists historical state. The system follows an ad‑hoc coordination pattern, with each container exposing well‑defined APIs over MQTT and REST, orchestrated by container tooling (Docker) to enable isolated deployment and scaling. The C4 context diagram positions the twin as a single logical entity interacting solely with the physical gantry via the shared messaging middleware."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital twin services (Trajectory Generator, Simulation, Continuous Validation) communicate via an MQTT broker that provides publish/subscribe signaling between services. The broker enables inter‑service messaging. Specific network topology, bandwidth, latency, redundancy or security protocols are not described in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system components are deployed as containers, following the C4 container model. The document indicates that the TimescaleDB database, MQTT broker, and application services are co‑located with the physical crane system, implying on‑premise or edge hosting. No explicit cloud, scalability, availability, or deployment models are detailed."
]