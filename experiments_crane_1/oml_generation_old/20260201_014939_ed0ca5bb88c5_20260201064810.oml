// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoBoard : DTDFVocab:SensingComponent [
    base:desc "Arduino board reading sensors and providing status information to the control software"
    DTDFVocab:producedData ArduinoStatusDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance ArduinoStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoBoard
]

// C10: Data (time‑series operational data)
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series swing‑angle measurements"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo PythonPhysicalCraneInterface, TimescaleDBEngine
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series wind‑speed measurements"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo PythonPhysicalCraneInterface, TimescaleDBEngine
]

instance ArduinoStatusData : DTDFVocab:Data [
    base:desc "Operational status data streamed from the Arduino board"
    DTDFVocab:fromData ArduinoStatusDataTransmitted
    DTDFVocab:inputTo PythonPhysicalCraneInterface, TimescaleDBEngine
]

// C2: Acting components (physical)
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the crane cart, controlled by TMC4671‑Eval motor controller"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist, controlled by TMC4671‑Eval motor controller"
]

instance TMC4671EvalMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval motor controller interfacing with stepper motors and the Arduino board"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist end used for payload handling, controllable via the crane controller"
]

// C10: Models/Data
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the crane used by the simulation engine"
    DTDFVocab:inputTo SimulationEngine
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator to compute swing‑free motion plans"
    DTDFVocab:inputTo TrajectoryGeneratorEngine
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the crane and its controllers"
    DTDFVocab:inputTo SimulationEngine
]

instance ContinuousValidationModel : DTDFVocab:Model [
    base:desc "Continuous‑validation model performing distance‑metric comparison of executed vs. simulated trajectories"
    DTDFVocab:inputTo ValidationEngine
]

// C11: Enablers
instance DockerComposeOrchestration : DTDFVocab:Enabler [
    base:desc "Docker and Docker‑Compose manage the containerised services"
    DTDFVocab:enables DataLoggingService, GrafanaDashboardService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService, HumanMachineInterfaceService
]

instance PythonPhysicalCraneInterface : DTDFVocab:Enabler [
    base:desc "Python program (gantrylib) streams sensor readings and controller state via MQTT"
    DTDFVocab:enables DataLoggingService, HumanMachineInterfaceService
]

instance TimescaleDBEngine : DTDFVocab:Enabler [
    base:desc "TimescaleDB stores time‑series operational data"
    DTDFVocab:enables DataLoggingService
]

instance GrafanaVisualizationEngine : DTDFVocab:Enabler [
    base:desc "Grafana visualises data stored in TimescaleDB"
    DTDFVocab:enables GrafanaDashboardService
]

instance MQTTBrokerEngine : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker handles service coordination and event notifications"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, HumanMachineInterfaceService
]

instance TrajectoryGeneratorEngine : DTDFVocab:Enabler [
    base:desc "Algorithmic engine generating optimal swing‑free trajectories"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Engine executing the digital replica of crane dynamics"
    DTDFVocab:enables SimulationService
]

instance ValidationEngine : DTDFVocab:Enabler [
    base:desc "Engine performing continuous validation of trajectory adherence"
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Writes time‑series data into TimescaleDB"
    DTDFVocab:provides DataPersistedInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Provides Grafana dashboard for data visualisation"
    DTDFVocab:provides VisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Supplies optimal motion plans that reduce crane swing"
    DTDFVocab:provides SwingReductionInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs a digital replica of crane dynamics"
    DTDFVocab:provides SimulationOutputInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed vs. simulated trajectories and raises alerts when deviation exceeds limits"
    DTDFVocab:provides RealTimeAlertInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Human‑machine interface allowing operators to adjust logging parameters and execute control commands"
    DTDFVocab:provides AdjustLoggingParametersAction, ExecuteControlCommandAction
]

// C17: Insights
instance DataPersistedInsight : DTDFVocab:Insight [
    base:desc "Indicates that operational data have been successfully persisted in TimescaleDB"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Displays real‑time operational metrics on the Grafana dashboard"
]

instance SwingReductionInsight : DTDFVocab:Insight [
    base:desc "Trajectory Generator provides motion plans that minimise crane swing"
]

instance SimulationOutputInsight : DTDFVocab:Insight [
    base:desc "Simulation Service produces predicted crane dynamics for analysis"
]

instance RealTimeAlertInsight : DTDFVocab:Insight [
    base:desc "Continuous Validation Service generates alerts when trajectory deviation exceeds defined thresholds"
]

// C17: Actions
instance AdjustLoggingParametersAction : DTDFVocab:Action [
    base:desc "Operator adjusts logging parameters via the HMI"
    DTDFVocab:IsAutomatic false
]

instance ExecuteControlCommandAction : DTDFVocab:Action [
    base:desc "Operator sends control commands to the crane controller"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends motion commands and trajectory set‑points (generated by the Trajectory Generator Service) to the Physical Crane Interface, which forwards them to the motor controllers and electromagnet, thereby actuating the cart, hoist and pick‑up actions."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical crane ↔ Python Physical Crane Interface ↔ Control and Logging applications; services communicate via MQTT broker; all persistent data reside in TimescaleDB; Grafana visualizes database content; all services are Docker‑containerised and orchestrated with a single docker‑compose command."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers design (CAD models in Autodesk Fusion360), manufacturing (Bill‑of‑Materials and Arduino shield), and operation (runtime data acquisition, logging, simulation and validation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, and raises alerts when the metric exceeds a predefined threshold; the simulation uses the same kinematic model as the trajectory generator to ensure model fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT (Eclipse Mosquitto) for lightweight publish/subscribe signaling between services; PostgreSQL/TimescaleDB for time‑series storage accessed via standard SQL; Python APIs for direct serial/USB communication with the Arduino and motor controllers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software runs on a single personal computer; Docker containers host the database, MQTT broker and Grafana dashboard; Docker‑Compose automates setup and networking; the gantrylib Python module is installed with pip; the repository is publicly available on GitHub."
]