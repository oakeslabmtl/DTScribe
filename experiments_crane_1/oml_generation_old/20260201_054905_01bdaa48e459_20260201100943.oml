import "https://example.com/DTDFVocab" as DTDFVocab

instance OptimalControlAction : DTDFVocab:Action [
    base:desc "Adjusts crane parameters in real-time",
    DTDFVocab:IsAutomatic true
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Access to historical operational metrics for analysis"
]

instance SystemStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive monitoring of current system states"
]

instance ModelAccuracyValidationInsight : DTDFVocab:Insight [
    base:desc "Dynamic assessment of digital model accuracy against physical crane"
]

instance TrajectoryGenerationInsight : DTDFVocab:Insight [
    base:desc "Optimal path computation for crane movements"
]

instance SimulationPredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive analysis of future crane operations"
]

instance CodeVersioningInsight : DTDFVocab:Insight [
    base:desc "Tracking of code repository versions"
]

instance ContainerDeploymentInsight : DTDFVocab:Insight [
    base:desc "Containerized deployment of digital twin components"
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Adjusts crane parameters in real-time for optimal operation",
    DTDFVocab:provides OptimalControlAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Persistent storage of operational metrics for historical analysis",
    DTDFVocab:provides HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Interactive monitoring of system states through runtime visualization",
    DTDFVocab:provides SystemStateVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Dynamically assesses accuracy of digital model against physical crane",
    DTDFVocab:provides ModelAccuracyValidationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes optimal movement paths for crane operations",
    DTDFVocab:provides TrajectoryGenerationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Performs predictive analysis of crane operations",
    DTDFVocab:provides SimulationPredictionInsight
]

instance CodeVersioningService : DTDFVocab:Service [
    base:desc "Manages version control of digital twin code repositories",
    DTDFVocab:provides CodeVersioningInsight
]

instance ContainerDeploymentService : DTDFVocab:Service [
    base:desc "Deploys digital twin components using containerization",
    DTDFVocab:provides ContainerDeploymentInsight
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database for persistent data storage",
    DTDFVocab:enables HistoricalDataLoggingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Provides runtime visualization capabilities for system monitoring",
    DTDFVocab:enables DataVisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Computes optimal movement paths using kinematic model",
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Leverages kinematic model for predictive analysis",
    DTDFVocab:enables SimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Compares real-time operational values against thresholds for validation",
    DTDFVocab:enables ContinuousValidationService
]

instance GitHubEnabler : DTDFVocab:Enabler [
    base:desc "GitHub-hosted code repositories for version control",
    DTDFVocab:enables CodeVersioningService
]

instance ContainerizationEnabler : DTDFVocab:Enabler [
    base:desc "Containerization technologies for code dissemination",
    DTDFVocab:enables ContainerDeploymentService
]

instance CraneStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder, Anemometer
]

instance CraneStateDataRecord : DTDFVocab:Data [
    base:desc "Crane state data stored in TimescaleDB",
    DTDFVocab:fromData CraneStateData,
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance CADModel : DTDFVocab:Model [
    base:desc "Geometric representation of the gantry crane structure",
    DTDFVocab:inputTo VisualizationEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Motion simulation model for gantry crane",
    DTDFVocab:inputTo TrajectoryGeneratorEnabler, SimulationEnabler
]

instance C4Model : DTDFVocab:Model [
    base:desc "Architecture visualization using context and container diagrams",
    DTDFVocab:inputTo VisualizationEnabler
]

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Monitors hoist swing dynamics",
    DTDFVocab:producedData CraneStateData
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Measures wind speed",
    DTDFVocab:producedData CraneStateData
]

instance ArduinoMicrocontroller : DTDFVocab:Component [
    base:desc "Real-time data acquisition and control of sensor inputs"
]

instance PhysicalCraneStructure : DTDFVocab:Component [
    base:desc "Physical structure of the lab-scale gantry crane"
]

instance CraneController : DTDFVocab:Component [
    base:desc "Dedicated controller for the physical gantry crane"
]

instance HorizontalCartMotor : DTDFVocab:ActingComponent [
    base:desc "Motor for horizontal movement along gantry rail"
]

instance VerticalHoistMotor : DTDFVocab:ActingComponent [
    base:desc "Motor for vertical hoisting operations"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet for container pickup and release"
]

instance HMI : DTDFVocab:Component [
    base:desc "Human Machine Interface for configuration and control"
]

instance GantryCraneSystem : DTDFVocab:Environment [
    base:desc "Lab-scale gantry crane cyber-physical system for reproducible digital twin research",
    base:contains PhysicalCraneStructure, CraneController, SwingAngleEncoder, Anemometer, ArduinoMicrocontroller, HorizontalCartMotor, VerticalHoistMotor, Electromagnet, HMI
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control Application executes trajectory commands generated by Trajectory Generator Service via Physical Crane Interface to control the physical crane. Continuous Validation Service compares executed trajectories against simulations, triggering operator alerts if discrepancies exceed thresholds."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system architecture is visualized using the C4 Model with context and container diagrams, employing Docker containerization for component isolation and deployment. It follows an ad-hoc approach without a commercial digital twin framework, integrating components through message-based communication."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A Continuous Validation Service compares real-time measurements of executed trajectories against simulated trajectories, calculating distance metrics (e.g., Euclidean) and comparing deviations against predefined thresholds to ensure model fidelity and data accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol facilitates communication between services via MQTT Broker; TimescaleDB and Grafana handle data storage and visualization. Network topology, bandwidth, latency, redundancy, and security protocols are not specified."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system is deployed on-premise on a personal computer, with the Database, MQTT Broker, and Dashboard services containerized using Docker. Docker Compose is employed for orchestrating these containerized components. No cloud or edge deployment infrastructure is mentioned, and computational/storage requirements are not explicitly specified beyond standard personal computer hardware."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar uses AutomationML for digital twin modeling and Microsoft Azure tools. GreenhouseDT implements ActiveMQ (MQTT protocol) for messaging, InfluxDB (SQL-based time-series database), and containerization via Docker. The Gantry Crane system adopts MQTT for communication protocols, SQL for data storage and querying, and Docker for containerized deployment to ensure interoperability."
]