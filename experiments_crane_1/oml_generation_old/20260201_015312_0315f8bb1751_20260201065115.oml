// ------------------------------------------------------------
// C3: Physical sensing components
// ------------------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing"
    DTDFVocab:producedData SwingAngleDataTransmission
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed"
    DTDFVocab:producedData WindSpeedDataTransmission
]

instance ArduinoControllerBoard : DTDFVocab:SensingComponent [
    base:desc "Arduino board that reads swing encoder, anemometer and motor feedback"
    DTDFVocab:producedData CraneStateDataTransmission
]

// ------------------------------------------------------------
// C2: Acting components
// ------------------------------------------------------------
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor moving the gantry along the rails"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor lifting and lowering the load"
]

instance TrinamicTMC4671EvalController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval motor controller driving the stepper motors"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist for attaching pucks"
]

// ------------------------------------------------------------
// C4: Physical‑to‑virtual interaction (Data Transmitted)
// ------------------------------------------------------------
instance SwingAngleDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CraneStateDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartStepperMotor, HoistStepperMotor, Electromagnet, ArduinoControllerBoard
]

// ------------------------------------------------------------
// C10: Data (time‑series) stored in TimescaleDB
// ------------------------------------------------------------
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmission
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedDataTransmission
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance CraneStateTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of motor velocities, positions and electromagnet status stored in TimescaleDB"
    DTDFVocab:fromData CraneStateDataTransmission
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Log of continuous sensor and actuator data for analysis"
]

// ------------------------------------------------------------
// C11: Models
// ------------------------------------------------------------
instance Fusion360CraneCADModel : DTDFVocab:Model [
    base:desc "3‑D CAD model of the lab‑scale gantry crane from Autodesk Fusion360"
    DTDFVocab:inputTo TrajectoryGeneratorService, SimulationService
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the trajectory generator for motion planning"
    DTDFVocab:inputTo TrajectoryGeneratorService, SimulationService
]

// ------------------------------------------------------------
// C11: Enablers (tools & platforms)
// ------------------------------------------------------------
instance PythonGanryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module providing trajectory generation and simulation utilities"
    DTDFVocab:enables TrajectoryGeneratorService, FaultDetectionService, SimulationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) storing time‑series sensor and actuator data"
    DTDFVocab:enables DataLoggingService, ValidationService, SimulationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana platform for dashboard visualisation"
    DTDFVocab:enables VisualizationService, HMIService
]

instance EclipseMosquittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for real‑time sensor data transport"
    DTDFVocab:enables DataLoggingService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestration of containerised DT services"
    DTDFVocab:enables DataLoggingService, VisualizationService, TrajectoryGeneratorService,
               SimulationService, ValidationService, FaultDetectionService, HMIService
]

// ------------------------------------------------------------
// C6: Services
// ------------------------------------------------------------
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuous data logging service ingesting MQTT streams into TimescaleDB"
    DTDFVocab:provides DataLoggingInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Grafana based visualisation of sensor data, trajectories and validation results"
    DTDFVocab:provides OptimalTrajectoryInsight, ValidationAlertInsight, FaultClassificationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free trajectories using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation of crane motion for validation purposes"
    DTDFVocab:provides ValidationAlertInsight
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Continuously validates executed trajectories against simulated ones"
    DTDFVocab:provides ValidationAlertInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Research extension for fault detection and classification"
    DTDFVocab:provides FaultClassificationInsight
]

instance HMIService : DTDFVocab:Service [
    base:desc "Web‑based Human‑Machine Interface for operator interaction"
    DTDFVocab:provides OperatorDecisionAction
]

// ------------------------------------------------------------
// C17: Insights
// ------------------------------------------------------------
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight of optimal, swing‑free trajectories for the crane"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert when executed trajectory deviates from the simulated trajectory"
]

instance FaultClassificationInsight : DTDFVocab:Insight [
    base:desc "Indicator of fault classification derived from sensor patterns"
]

// ------------------------------------------------------------
// C17: Actions
// ------------------------------------------------------------
instance OperatorDecisionAction : DTDFVocab:Action [
    base:desc "Operator decision support via dashboard; actions are manual only"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal swing‑free trajectories and publishes them via MQTT to the Control Application, which uses the Physical Crane Interface to command the motor controllers and electromagnet; alerts from the Continuous Validation Service are also sent to the Human‑Machine Interface through the dashboard."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of the physical crane, a Python interface to its controllers, a control application, a logging application, an MQTT broker for inter‑service messaging, services (trajectory generation, simulation, continuous validation), a TimescaleDB backend, a Grafana dashboard, and a web‑based HMI, all orchestrated via Docker‑Compose on a single PC."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin incorporates CAD models (design stage) and a kinematic model used during operation, thus covering both the design/ideal representation and the as‑operated stage; manufacturing details are not explicitly modelled."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, checks against a predefined threshold, and raises alerts; model validation methods from prior work are reused to ensure fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT components uses MQTT (Eclipse Mosquitto) for command and event messages, and HTTP/SQL connections from the logging application to the TimescaleDB; all services run on the same Docker network on a personal computer."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT services are containerised with Docker and started with a single Docker‑Compose file; the Python modules run on the host PC; the entire system is hosted on a public GitHub repository with MIT license and documented via MkDocs."
]