// C3: Physical sensing components
instance GantryPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures position of gantry components (linear motion) with millisecond-level precision for real-time control and trajectory validation."
    DTDFVocab:producedData GantryPositionDataTransmitted
]

instance HoistPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures vertical position of hoist with millisecond-level precision for closed-loop control and payload stability."
    DTDFVocab:producedData HoistPositionDataTransmitted
]

instance LoadCellSensor : DTDFVocab:SensingComponent [
    base:desc "Measures force exerted on payload for safety-critical overload detection and dynamic load compensation."
    DTDFVocab:producedData LoadForceDataTransmitted
]

instance CraneVelocityIMU : DTDFVocab:SensingComponent [
    base:desc "Inertial measurement unit capturing velocity and acceleration of crane components for dynamic model validation."
    DTDFVocab:producedData CraneVelocityDataTransmitted
]

instance LimitSwitchArray : DTDFVocab:SensingComponent [
    base:desc "Binary sensors monitoring physical constraints (e.g., end-stops, safety zones) for collision prevention."
    DTDFVocab:producedData SafetyConstraintDataTransmitted
]

instance RaspberryPiAirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry Pi with embedded sensors (PM2.5, CO2, temperature, humidity) for real-time indoor air quality monitoring."
    DTDFVocab:producedData AirQualityDataTransmitted
]

instance GreenhouseEnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensors (temperature, humidity, light) integrated with InfluxDB for greenhouse climate control."
    DTDFVocab:producedData GreenhouseEnvironmentDataTransmitted
]

// C4: Physical-to-virtual interaction
instance GantryPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GantryPositionEncoder
]

instance HoistPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistPositionEncoder
]

instance LoadForceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadCellSensor
]

instance CraneVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocityIMU
]

instance SafetyConstraintDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LimitSwitchArray
]

instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RaspberryPiAirQualitySensor
]

instance GreenhouseEnvironmentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseEnvironmentalSensor
]

// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink or Python (PyBullet) implementation of forward/inverse kinematics for gantry crane motion simulation."
    DTDFVocab:inputTo KinematicSimulationEnabler
]

instance CraneDynamicModel : DTDFVocab:Model [
    base:desc "Physics-based model capturing crane dynamics (forces, torques) implemented in MATLAB/Simulink or Python."
    DTDFVocab:inputTo DynamicSimulationEnabler
]

instance ControlAlgorithmModel : DTDFVocab:Model [
    base:desc "PID/MPC controller implementation for crane motion control with adaptive parameter tuning."
    DTDFVocab:inputTo ControlOptimizationEnabler
]

instance AirQualitySimulationModel : DTDFVocab:Model [
    base:desc "AutomationML-based model for air flow dynamics and pollutant dispersion simulation."
    DTDFVocab:inputTo AirQualitySimulationEnabler
]

instance TrajectoryExecutionLog : DTDFVocab:Data [
    base:desc "Timestamped records of executed crane movements including waypoints, control signals, and execution timestamps."
    DTDFVocab:fromData GantryPositionDataTransmitted, HoistPositionDataTransmitted
    DTDFVocab:inputTo TrajectoryValidationEnabler
]

instance SensorTelemetryData : DTDFVocab:Data [
    base:desc "Raw sensor readings from encoders, load cells, and IMUs with millisecond-level time synchronization."
    DTDFVocab:fromData GantryPositionDataTransmitted, HoistPositionDataTransmitted, LoadForceDataTransmitted, CraneVelocityDataTransmitted
    DTDFVocab:inputTo DataPreprocessingEnabler
]

instance AirQualityTimeSeriesData : DTDFVocab:Data [
    base:desc "Time-series data from Raspberry Pi sensors (PM2.5, CO2, temperature, humidity) stored in TimescaleDB."
    DTDFVocab:fromData AirQualityDataTransmitted
    DTDFVocab:inputTo AirQualityAnalyticsEnabler
]

instance GreenhouseClimateData : DTDFVocab:Data [
    base:desc "Time-series environmental data from greenhouse sensors stored in InfluxDB for behavioral adaptation."
    DTDFVocab:fromData GreenhouseEnvironmentDataTransmitted
    DTDFVocab:inputTo GreenhouseAdaptationEnabler
]

// C11: Enablers
instance KinematicSimulationEnabler : DTDFVocab:Enabler [
    base:desc "ROS-based real-time simulation engine for kinematic model execution and hardware-in-the-loop testing."
    DTDFVocab:enables TrajectoryOptimizationService, ModelValidationService
]

instance DynamicSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Physics simulation engine (e.g., PyBullet) for dynamic model validation and force distribution analysis."
    DTDFVocab:enables FaultDetectionService, SafetyValidationService
]

instance ControlOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Python (SciPy/Pyomo) or MATLAB implementation for real-time trajectory optimization and adaptive control."
    DTDFVocab:enables OptimalControlService, AdaptiveControlService
]

instance AirQualitySimulationEnabler : DTDFVocab:Enabler [
    base:desc "AutomationML-based simulation pipeline for air flow and pollutant dispersion modeling."
    DTDFVocab:enables AirQualitySimulationService
]

instance TrajectoryValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation framework comparing logged trajectories with simulated trajectories using residual analysis."
    DTDFVocab:enables ContinuousValidationService
]

instance DataPreprocessingEnabler : DTDFVocab:Enabler [
    base:desc "Python-based data filtering and aggregation pipeline for sensor telemetry with millisecond-level time alignment."
    DTDFVocab:enables FaultDetectionService
]

instance AirQualityAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Microsoft Azure-based pipeline for real-time air quality analytics and predictive modeling."
    DTDFVocab:enables RuntimeVisualizationService, PredictionService
]

instance GreenhouseAdaptationEnabler : DTDFVocab:Enabler [
    base:desc "Behavioral adaptation engine using pre-recorded data and InfluxDB time-series analysis for greenhouse control."
    DTDFVocab:enables SelfAdaptationService
]

instance TimescaleDBStorage : DTDFVocab:Enabler [
    base:desc "High-write workload optimized database for storing crane operational logs with sub-millisecond time synchronization."
    DTDFVocab:enables HistoricalDataLoggingService, ComparativeVisualizationService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Real-time visualization dashboard for crane state monitoring with 3D CAD overlays and sensor heatmaps."
    DTDFVocab:enables RealTimeDashboardService
]

// C6: Services
instance TrajectoryOptimizationService : DTDFVocab:Service [
    base:desc "Computes optimal motion profiles minimizing energy consumption or maximizing throughput using kinematic/dynamic models."
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance ModelValidationService : DTDFVocab:Service [
    base:desc "Compares digital twin predictions with real-world sensor data using statistical methods (residual analysis, Kalman filtering)."
    DTDFVocab:provides ModelConsistencyInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Enforces real-time trajectory optimization with adaptive parameter tuning based on sensor feedback."
    DTDFVocab:provides AdaptiveControlAction
]

instance AdaptiveControlService : DTDFVocab:Service [
    base:desc "Dynamically adjusts control parameters (PID gains) based on real-time sensor feedback for system stability."
    DTDFVocab:provides StabilityMaintenanceAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Automated cross-referencing of logged trajectories with simulated trajectories to detect anomalies."
    DTDFVocab:provides ValidationAlertAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Machine learning-based anomaly detection (Isolation Forests, LSTM autoencoders) for mechanical faults and control failures."
    DTDFVocab:provides FaultDetectionInsight
]

instance SafetyValidationService : DTDFVocab:Service [
    base:desc "Validates physical constraints (collision prevention, overload detection) using dynamic simulation models."
    DTDFVocab:provides SafetyComplianceInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Stores structured operational data in queryable format for post-mortem analysis and trend detection."
    DTDFVocab:provides HistoricalTrendInsight
]

instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Displays 3D CAD models synchronized with live sensor data for operator monitoring."
    DTDFVocab:provides CraneStateInsight
]

instance ComparativeVisualizationService : DTDFVocab:Service [
    base:desc "Overlays simulated vs. actual trajectories to validate digital twin fidelity."
    DTDFVocab:provides FidelityValidationInsight
]

instance AirQualitySimulationService : DTDFVocab:Service [
    base:desc "Simulates air flow dynamics and pollutant dispersion using AutomationML-based models."
    DTDFVocab:provides AirFlowDynamicsInsight
]

instance RuntimeVisualizationService : DTDFVocab:Service [
    base:desc "Real-time visualization of indoor air quality metrics via sensor data from Raspberry Pi."
    DTDFVocab:provides AirQualityVisualizationInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Predicts virus spread risks through data-driven analytics using Azure Machine Learning."
    DTDFVocab:provides VirusSpreadRiskInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Self-adapting control system for greenhouse using pre-recorded data and behavioral feedback loops."
    DTDFVocab:provides ClimateOptimizationAction
]

