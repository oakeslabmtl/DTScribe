// C3: Physical Sensing Components
instance CranePositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures joint angles and positions of the gantry crane for trajectory validation and control feedback. Uses high-resolution encoders for precise kinematic data acquisition."
    DTDFVocab:producedData CranePositionData
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Captures linear and angular velocity of crane components using tachometers or IMU-based sensors for dynamic validation and control tuning."
    DTDFVocab:producedData CraneVelocityData
]

instance CraneAccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors acceleration profiles of crane actuators and payload using accelerometers or derived data from position/velocity sensors for vibration analysis and fault detection."
    DTDFVocab:producedData CraneAccelerationData
]

instance LoadStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Detects payload presence and weight using load cells or force/torque sensors integrated into the crane's hook mechanism."
    DTDFVocab:producedData LoadStatusData
]

instance ControllerFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Provides real-time feedback from the embedded controller (e.g., PID outputs, actuator commands) for closed-loop validation and control adaptation."
    DTDFVocab:producedData ControllerFeedbackData
]

instance TrajectoryExecutionMonitor : DTDFVocab:SensingComponent [
    base:desc "Tracks puck displacement and swinging motion residuals during trajectory execution using vision systems or additional encoders for precise motion validation."
    DTDFVocab:producedData TrajectoryExecutionData
]

// C4: Physical-to-Virtual Interaction
instance CranePositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionEncoder
]

instance CraneVelocityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocitySensor
]

instance CraneAccelerationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneAccelerationSensor
]

instance LoadStatusData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadStatusSensor
]

instance ControllerFeedbackData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ControllerFeedbackSensor
]

instance TrajectoryExecutionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TrajectoryExecutionMonitor
]

// C10: Models/Data
instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Forward/inverse kinematic model of the gantry crane created using MATLAB/Simulink or ROS, including assembly constraints and mass properties for trajectory planning."
    DTDFVocab:inputTo KinematicSimulationEnabler
]

instance CraneDynamicsModel : DTDFVocab:Model [
    base:desc "Physics-based rigid-body dynamics model for collision detection and load stability analysis, implemented in FreeCAD or Blender for parametric simulations."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance ControlAlgorithmModel : DTDFVocab:Model [
    base:desc "PID/MPC control algorithms with fixed-step solvers for real-time execution, developed in MATLAB/Simulink or Python with PyControl for adaptive tuning."
    DTDFVocab:inputTo ControlAlgorithmEnabler
]

instance HistoricalOperationData : DTDFVocab:Data [
    base:desc "Time-series database of high-fidelity operational data including joint trajectories, control inputs, and environmental conditions stored in TimescaleDB for post-mortem analysis."
    DTDFVocab:fromData CranePositionData, CraneVelocityData, CraneAccelerationData, LoadStatusData
    DTDFVocab:inputTo DataStorageEnabler
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Streaming sensor data from physical crane (position, velocity, acceleration, load status) synchronized via PTP/NTP for real-time validation and control."
    DTDFVocab:fromData CranePositionData, CraneVelocityData, CraneAccelerationData, ControllerFeedbackData, TrajectoryExecutionData
    DTDFVocab:inputTo DataStreamingEnabler
]

instance SimulatedTrajectoryData : DTDFVocab:Data [
    base:desc "Digitally generated trajectory data from kinematic/dynamic simulations used for comparing against physical execution in continuous validation services."
    DTDFVocab:fromData TrajectoryExecutionData
    DTDFVocab:inputTo SimulationEngineEnabler
]

// C11: Enablers
instance KinematicSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink or ROS-based environment for forward/inverse kinematics modeling, trajectory planning, and collision detection with parametric 3D CAD integration."
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Gazebo/Ignition simulation engine for ROS-based digital twins to mirror real-time crane dynamics with physics-based simulations."
    DTDFVocab:enables SimulationService
]

instance ControlAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Embedded microcontroller or industrial PC running RTOS (QNX/VxWorks) with MATLAB/Simulink or Python-based control algorithms for real-time execution."
    DTDFVocab:enables RealTimeControlService
]

instance DataStreamingEnabler : DTDFVocab:Enabler [
    base:desc "MQTT/OPC UA/ROS Topics for lightweight IoT data streaming from physical crane to digital twin with PTP/NTP time synchronization."
    DTDFVocab:enables RealTimeDataStreamingService
]

instance DataBufferEnabler : DTDFVocab:Enabler [
    base:desc "ZeroMQ/Kafka message queuing system for asynchronous handling of high-frequency sensor data without latency."
    DTDFVocab:enables HighFrequencyDataHandlingService
]

instance DigitalTwinFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Custom Python/C++ libraries or commercial platforms (Siemens MindSphere) to orchestrate digital twin services including validation, control, and visualization."
    DTDFVocab:enables DigitalTwinOrchestrationService
]

instance OntologyModelingEnabler : DTDFVocab:Enabler [
    base:desc "OWL/RDF or Neo4j knowledge graph for structuring digital twin metadata, defining relationships between physical/digital entities, and enabling semantic queries."
    DTDFVocab:enables SemanticQueryService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB/TimescaleDB for time-series sensor data storage and PostgreSQL/MySQL for structured metadata with MongoDB for unstructured data."
    DTDFVocab:enables DataLoggingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Plotly Dash/Grafana/React.js for real-time dashboards with interactive 3D models (Three.js/WebGL) and MATLAB/Python for offline analysis."
    DTDFVocab:enables RealTimeVisualizationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Statistical tools (SciPy/StatsModels) and machine learning libraries (Scikit-learn/TensorFlow) for residual analysis, hypothesis testing, and uncertainty quantification."
    DTDFVocab:enables ContinuousValidationService
]

instance EvolutionTrackingEnabler : DTDFVocab:Enabler [
    base:desc "DarTwin notation and Neo4j knowledge graph for modeling digital twin evolution including model updates, control algorithm changes, and sensor calibrations."
    DTDFVocab:enables SystemEvolutionTrackingService
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes optimal motion profiles using MPC or reinforcement learning, enforcing kinematic constraints and payload stability for real-time control."
    DTDFVocab:provides OptimalTrajectoryInsight, TrajectoryOptimizationAction
]

instance RealTimeControlService : DTDFVocab:Service [
    base:desc "Executes PID/MPC control algorithms in real-time using embedded hardware with CAN bus/EtherCAT for actuator interfacing."
    DTDFVocab:provides ControlFeedbackInsight, ActuatorCommandAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares digital twin predictions with physical sensor data using statistical methods (Kalman filtering) or machine learning (autoencoders) for synchronization validation."
    DTDFVocab:provides ValidationResultInsight, AlertTriggerAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Monitors sensor residuals and system dynamics to detect faults (sensor drift, motor stalls) using Isolation Forest or SVM with threshold-based alerts."
    DTDFVocab:provides FaultDetectionResultInsight, FaultIsolationAction
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Stores high-fidelity operational data in time-series databases with metadata tagging for query-based retrieval and historical analysis."
    DTDFVocab:provides DataLoggingStatusInsight, DataStorageAction
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides interactive 3D dashboards with time-series plots and heatmaps for monitoring system health, control performance, and validation metrics."
    DTDFVocab:provides VisualizationInsight, DashboardUpdateAction
]

instance OfflineAnalysisService : DTDFVocab:Service [
    base:desc "Supports custom scripting (Python/MATLAB) for post-processing logged data including trajectory animations, spectral analysis, and discrepancy comparisons."
    DTDFVocab:provides AnalysisResultInsight, CustomScriptExecutionAction
]

instance SystemEvolutionTrackingService : DTDFVocab:Service [
    base:desc "Tracks system changes using DarTwin notation in a knowledge graph for traceability and reproducibility of research results."
    DTDFVocab:provides EvolutionTrackingInsight, VersionControlAction
]

instance DigitalTwinOrchestrationService : DTDFVocab:Service [
    base:desc "Orchestrates digital twin services including validation, control, and visualization using custom Python/C++ libraries or commercial platforms."
    DTDFVocab:provides OrchestrationStatusInsight, ServiceCoordinationAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Executes physics-based simulations of crane dynamics for validation and predictive analysis."
    DTDFVocab:provides SimulationResultInsight
]

instance RealTimeDataStreamingService : DTDFVocab:Service [
    base:desc "Handles real-time data streaming from physical crane to digital twin components."
    DTDFVocab:provides DataStreamingStatusInsight
]

instance HighFrequencyDataHandlingService : DTDFVocab:Service [
    base:desc "Processes high-frequency sensor data with low latency for real-time applications."
    DTDFVocab:provides DataProcessingStatusInsight
]

instance SemanticQueryService : DTDFVocab:Service [
    base:desc "Enables semantic queries on digital twin metadata and relationships."
    DTDFVocab:provides QueryResultInsight
]

instance DataAnalysisService : DTDFVocab:Service [
    base:desc "Performs data analysis on historical operation data for model retraining and trend identification."
    DTDFVocab:provides AnalysisResultInsight
]

