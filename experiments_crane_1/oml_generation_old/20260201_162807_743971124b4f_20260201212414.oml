instance CranePhysicalEnvironment : DTDFVocab:Environment [
    base:desc "Lab-scale physical environment housing the gantry crane system with embedded controllers and sensing components."
    base:contains CranePositionEncoder, CraneVelocitySensor, CraneAccelerationSensor, CraneLoadCell, CraneControllerStatusSensor, CraneMotorController
]

