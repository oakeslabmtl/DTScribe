instance CraneDigitalTwinCore : DTDFVocab:DigitalTwin [
    base:desc "Core digital twin instance for the lab-scale gantry crane enabling bidirectional synchronization with physical system."
    base:contains CraneKinematicModel, CraneDynamicModel, CraneTrajectoryDatabase
    base:isContainedIn CranePhysicalEnvironment
]

instance AirQualityDigitalTwinCore : DTDFVocab:DigitalTwin [
    base:desc "Digital twin instance for indoor air quality management system providing simulation, prediction, and visualization capabilities."
    base:contains AirQualitySimulationModel, AirQualitySensorCalibrationData
