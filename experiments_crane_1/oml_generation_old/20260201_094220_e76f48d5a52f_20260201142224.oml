// ---------------------------- // Return code: 1 | Stderr:
// 1. Physical Sensing Components
// ----------------------------

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Supports continuous measurement of the swing angle of the crane’s cart and hoist system, feeding data to the logging application."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Measures wind speed impacting the gantry crane during operation."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Reads positional feedback from the cart stepper motor driven by a TMC4671-Eval driver."
    DTDFVocab:producedData CartMotorPositionDataTransmitted
]

instance HoistMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Provides positional data from the hoist stepper motor controlled by a TMC4671-Eval driver."
    DTDFVocab:producedData HoistMotorPositionDataTransmitted
]

// ----------------------------
// 2. Data Transmitted
// ----------------------------

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CartMotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoder
]

instance HoistMotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoder
]

// ----------------------------
// 3. Data
// ----------------------------

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing angle of the cart‑hoist assembly."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo PhysicalCraneInterfaceModule
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Wind velocity measured over the crane’s operating theater."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo PhysicalCraneInterfaceModule
]

instance CartMotorPositionData : DTDFVocab:Data [
    base:desc "Position of the cart’s stepper motor measured by the encoder."
    DTDFVocab:fromData CartMotorPositionDataTransmitted
    DTDFVocab:inputTo PhysicalCraneInterfaceModule
]

instance HoistMotorPositionData : DTDFVocab:Data [
    base:desc "Position of the hoist stepper motor measured by the encoder."
    DTDFVocab:fromData HoistMotorPositionDataTransmitted
    DTDFVocab:inputTo PhysicalCraneInterfaceModule
]

// ----------------------------
// 4. Acting Components
// ----------------------------

instance CartTMC4671StepperMotorDriver : DTDFVocab:ActingComponent [
    base:desc "Stepping driver that actuates the cart axis via the TMC4671‑Eval board."
]

instance HoistTMC4671StepperMotorDriver : DTDFVocab:ActingComponent [
    base:desc "Stepping driver controlling the hoist axis with a TMC4671‑Eval board."
]

instance ElectromagnetController : DTDFVocab:ActingComponent [
    base:desc "Controls the electromagnet used for picking up containers/pucks on the crane."
]

// ----------------------------
// 5. Models/Data
// ----------------------------

instance CADModel_GantryFrame : DTDFVocab:Model [
    base:desc "Fusion 360 CAD model of the gantry’s steel frame."
    DTDFVocab:inputTo GanTriLibPackage
]

instance CADModel_Stacker : DTDFVocab:Model [
    base:desc "CAD representation of the cart and hoist assembly."
    DTDFVocab:inputTo GanTriLibPackage
]

instance KinematicMotionModel : DTDFVocab:Model [
    base:desc "Kinematic model used for trajectory generation of the cart‑hoist system."
    DTDFVocab:inputTo GanTriLibPackage
]

instance TrajectoryGeneratorAlgorithm : DTDFVocab:Model [
    base:desc "Algorithm that generates optimal trajectories given target points and constraints."
    DTDFVocab:inputTo GanTriLibPackage
]

instance TrajectorySimulationModel : DTDFVocab:Model [
    base:desc "Simulation model that evaluates candidate trajectories and produces confidence bounds."
    DTDFVocab:inputTo GanTriLibPackage
]

// ----------------------------
// 6. Enablers
// ----------------------------

instance GanTriLibPackage : DTDFVocab:Enabler [
    base:desc "Python package providing kinematic, trajectory, and simulation utilities used across the twin."
    DTDFVocab:enables TrajectoryOptimizationService, TrajectorySimulationService, ContinuousValidationService
]

instance PhysicalCraneInterfaceModule : DTDFVocab:Enabler [
    base:desc "Python module that streams sensor data from the Arduino over MQTT to the broker."
    DTDFVocab:enables RealTimeDataLoggingService
]

instance LoggingApplicationModule : DTDFVocab:Enabler [
    base:desc "Python service that subscribes to the MQTT broker and writes time‑series data to TimescaleDB."
    DTDFVocab:enables RealTimeDataLoggingService
]

instance ControlApplicationModule : DTDFVocab:Enabler [
    base:desc "Python controller that receives trajectory commands and controls stepper motors via the TMC4671 drivers."
    DTDFVocab:enables ContinuousValidationService
]

instance HumanMachineInterfaceModule : DTDFVocab:Enabler [
    base:desc "Python interface that renders dashboards and accepts operator interventions."
]

instance TimeScaleDBContainer : DTDFVocab:Enabler [
    base:desc "Docker container running TimescaleDB, storing all logged time‑series data."
]

instance MosquittoMQTTBrokerContainer : DTDFVocab:Enabler [
    base:desc "Docker container hosting the Eclipse Mosquitto MQTT broker for real‑time data exchange."
]

instance GrafanaDashboardContainer : DTDFVocab:Enabler [
    base:desc "Docker container running Grafana for real‑time visualization of trajectory adherence, wind speed, and joint positions."
]

// ----------------------------
// 7. Services
// ----------------------------

instance RealTimeDataLoggingService : DTDFVocab:Service [
    base:desc "Logs incoming sensor data in real‑time to a TimescaleDB database."
    DTDFVocab:provides LogInspectionInsight
]

instance TimeSeriesVisualizationService : DTDFVocab:Service [
    base:desc "Provides dashboards in Grafana displaying swing‑angle, motor positions, wind speed, and trajectory adherence."
    DTDFVocab:provides JointPositionInsight, WindSpeedInsight, TrajectoryAdherenceInsight
]

instance TrajectoryOptimizationService : DTDFVocab:Service [
    base:desc "Generates optimal trajectories using the kinematic model and updates control parameters."
    DTDFVocab:provides UpdateControlParametersAction, OptimizeTrajectoryInsight
]

instance TrajectorySimulationService : DTDFVocab:Service [
    base:desc "Runs trajectory simulations and estimates confidence bounds for path feasibility."
    DTDFVocab:provides SimulationConfidenceBoundsInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares real‑time motion data against generated trajectories to flag deviations."
    DTDFVocab:provides DeviationAlertInsight, TriggerAlertAction
]

// ----------------------------
// 8. Insights
// ----------------------------

instance JointPositionInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of cart and hoist joint positions."
]

instance WindSpeedInsight : DTDFVocab:Insight [
    base:desc "Current wind speed over the gantry crane."
]

instance TrajectoryAdherenceInsight : DTDFVocab:Insight [
    base:desc "Comparison of actual swing‑angle trajectory against planned trajectory."
]

instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alerts operators when trajectory deviations exceed predefined thresholds."
]

instance SimulationConfidenceBoundsInsight : DTDFVocab:Insight [
    base:desc "Displays simulation confidence bounds for planned trajectories."
]

instance LogInspectionInsight : DTDFVocab:Insight [
    base:desc "Provides historical log inspection for post‑hoc analysis."
]

instance OptimizeTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Reports on the optimization process and new trajectory parameters."
]

// ----------------------------
// 9. Actions
// ----------------------------

instance UpdateControlParametersAction : DTDFVocab:Action [
    base:desc "Automatic adjustments of stepper motor control parameters to improve trajectory following."
    DTDFVocab:IsAutomatic true
]

instance TriggerAlertAction : DTDFVocab:Action [
    base:desc "Sends an alert to operators when a trajectory deviation is detected."
    DTDFVocab:IsAutomatic true
]

instance PickContainerAction : DTDFVocab:Action [
    base:desc "Triggers the electromagnet to pick up or release a container."
    DTDFVocab:IsAutomatic false
]

instance OptimizeTrajectoryAction : DTDFVocab:Action [
    base:desc "Computes a new trajectory in response to changing operating conditions."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service publishes optimal trajectory waypoints to the MQTT broker, which the Physical Crane Interface forwards as PWM/step commands to the TMC4671 motor drivers controlling cart and hoist stepper motors in real time."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, high‑frequency operation. Logging and validation occur in real time as the crane moves; data is written to the database on each sensor poll (typically sub‑second). Services execute synchronously with the driver cycle, ensuring real‑time responsiveness for operator feedback and fault detection."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Container architecture: Physical Crane, Physical Crane Interface, Control Application, Logging Application, Human Machine Interface; Digital twin containers: Database (TimescaleDB), Dashboard (Grafana), Trajectory Generator Service, Simulation Service, Continuous Validation Service, MQTT Broker, all orchestrated via docker‑compose."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (CAD models in Fusion360 and kinematic model definition), Manufacturing (assembly of motors, drivers, Arduino shield, PSU, and electromagnet), and Operation (real‑time control, logging, simulation, and validation during use)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous validation compares executed trajectories against simulated ones using Euclidean distance metrics; thresholds trigger operator notifications; simulation provides confidence bounds; kinematic model ensures optimal trajectories with zero residual swing; validation is practical and continuous."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical-to-digital communication via serial/USB from Arduino to Python interface; service-to-service communication over MQTT (Eclipse Mosquitto) on LAN; database access via PostgreSQL/SQL on localhost; dashboard accesses TimescaleDB via Grafana data source."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components run on a developer workstation; Docker containers host DB, MQTT, Grafana; Python services run directly; code packaged as pip module and hosted on GitHub, documentation served via GitHub Pages."
]