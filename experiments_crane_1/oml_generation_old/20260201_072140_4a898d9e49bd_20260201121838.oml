// Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing–angle encoder mounted on the hoist sampling encoder position and timestamp"
    DTDFVocab:producedData SwingAngleTelemetryStream
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer mounted on the hoist measuring wind speed and timestamp"
    DTDFVocab:producedData WindSpeedTelemetryStream
]

instance ElectromagnetStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting electromagnet activity and timestamp from the crane control system"
    DTDFVocab:producedData ElectromagnetStatusTelemetryStream
]

// Data Transmitted
instance SwingAngleTelemetryStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
    base:desc "Telemetry stream of swing‑angle encoder data published via MQTT"
]

instance WindSpeedTelemetryStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
    base:desc "Telemetry stream of wind speed data published via MQTT"
]

instance ElectromagnetStatusTelemetryStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ElectromagnetStatusSensor
    base:desc "Telemetry stream of electromagnet status published via MQTT"
]

// Data
instance SwingAngleTelemetryData : DTDFVocab:Data [
    base:desc "Time‑series data of swing‑angle encoder position and timestamp stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleTelemetryStream
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedTelemetryData : DTDFVocab:Data [
    base:desc "Time‑series data of wind speed measurements and timestamp stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedTelemetryStream
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance ElectromagnetStatusTelemetryData : DTDFVocab:Data [
    base:desc "Time‑series data of electromagnet activity and timestamp stored in TimescaleDB"
    DTDFVocab:fromData ElectromagnetStatusTelemetryStream
    DTDFVocab:inputTo TimescaleDBEnabler
]

// Enablers
instance GantrylibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib library used by control scripts, trajectory generator, and simulation models"
    DTDFVocab:enables ServiceSimulation, ServiceTrajectoryGeneration
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance storing telemetry streams from sensors and motor controllers"
    DTDFVocab:enables ServiceDataLogging, ServiceContinuousValidation
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker publishing telemetry from the Physical Crane Interface to digital twin services"
    DTDFVocab:enables ServiceMQTTTransport
]

instance PhysicalCraneInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Physical Crane Interface translating command signals to and from the cart and hoist motor controllers"
    DTDFVocab:enables ServiceOperatorHMI
]

// Acting Components
instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "Cart motor controller (Trinamic TMC4671 Eval) driven by digital‑twin‑generated command signals via the Physical Crane Interface"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "Hoist motor controller (Trinamic TMC4671 Eval) driven by digital‑twin‑generated command signals via the Physical Crane Interface"
]

// Models
instance Fusion360CADModel : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane built in Autodesk Fusion 360"
    DTDFVocab:inputTo GantrylibEnabler
]

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the trajectory generator to calculate optimal paths for cart and hoist"
    DTDFVocab:inputTo GantrylibEnabler
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of crane dynamics and controllers implemented using gantrylib and telemetry from TimescaleDB"
    DTDFVocab:inputTo GantrylibEnabler
]

instance TimescaleDBSchemaModel : DTDFVocab:Model [
    base:desc "TimescaleDB schema storing telemetry streams from sensors and motor controllers"
    DTDFVocab:inputTo TimescaleDBEnabler
]

// Services
instance ServiceSimulation : DTDFVocab:Service [
    base:desc "Python simulation of crane dynamics using gantrylib and telemetry from TimescaleDB"
]

instance ServiceTrajectoryGeneration : DTDFVocab:Service [
    base:desc "Trajectory generator computing optimal paths for cart and hoist movement"
    DTDFVocab:provides InsightOptimalPathSuggestion
]

instance ServiceContinuousValidation : DTDFVocab:Service [
    base:desc "Continuous validation service computing distance metrics and thresholds, generating alerts fed to Grafana"
    DTDFVocab:provides InsightContinuousValidationAlerts
]

instance ServiceDataLogging : DTDFVocab:Service [
    base:desc "Logs telemetry streams to TimescaleDB for historical analysis"
    DTDFVocab:provides InsightParameterTuning
]

instance ServiceRealTimeVisualization : DTDFVocab:Service [
    base:desc "Grafana dashboards for real‑time status of crane operations"
]

instance ServiceOperatorHMI : DTDFVocab:Service [
    base:desc "Operator HMI providing real‑time status and command interface to control the crane"
    DTDFVocab:provides InsightOperatorDecision
]

instance ServiceMQTTTransport : DTDFVocab:Service [
    base:desc "Handles MQTT publish/subscribe between Physical Crane Interface and other services"
]

instance ServiceFaultClassification : DTDFVocab:Service [
    base:desc "Analyzes telemetry to classify faults and inform future configurations"
    DTDFVocab:provides InsightFaultClassificationModel
]

// Insights
instance InsightContinuousValidationAlerts : DTDFVocab:Insight [
    base:desc "Alerts workers via Grafana dashboard when validation metrics exceed thresholds"
]

instance InsightOptimalPathSuggestion : DTDFVocab:Insight [
    base:desc "Trajectory generator suggests optimal paths for cart and hoist movement"
]

instance InsightParameterTuning : DTDFVocab:Insight [
    base:desc "Analysis of telemetry data for tuning control parameters"
]

instance InsightOperatorDecision : DTDFVocab:Insight [
    base:desc "Operator HMI provides real‑time status enabling decisions on payload handling"
]

instance InsightFaultClassificationModel : DTDFVocab:Insight [
    base:desc "Fault classification models analyze telemetry to classify faults and inform future configurations"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory Generator Service creates optimal movement trajectories and publishes motor command sequences to the Physical Crane Interface, which forwards them to the cart and hoist motor controllers; continuous validation and simulation services may send feedback via MQTT."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time, continuous operation: telemetry sampled and logged at sub‑second cadence; trajectory generation, simulation, and validation performed on‑the‑fly in sync with physical motion; services operate continuously while the system runs."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Cyber‑physical architecture where the physical gantry crane (motors, controllers, sensors) interacts with a digital twin consisting of a Database, MQTT broker, Trajectory Generator, Simulation, Continuous Validation, Dashboard, and operator HMI, orchestrated via Docker containers and Python modules; all components communicate over MQTT and SQL."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital twin models the crane throughout design (CAD, kinematic model), manufacturing (actual assembly), and operation (real‑time monitoring, control, validation); continuous validation and fault detection cover the operated phase, while simulation and trajectory services support the design phase."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Trajectory generator uses analytical kinematic model to create swing‑free trajectories; continuous validation service computes Euclidean distance between executed and simulated trajectories, comparing against user‑defined threshold; alerts trigger when deviation exceeds threshold, allowing fault detection; model verification through comparison with simulation and empirical data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑digital data transferred via USB/serial from Arduino to Python interface, published over MQTT (Eclipse Mosquitto) to services; services communicate over local network via MQTT; database accessed via PostgreSQL interface; visual dashboards connect to TimescaleDB via Grafana’s data source; all processes run on a single PC host."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital twin is containerized using Docker; Docker‑compose orchestrates six containers (TimescaleDB, Grafana, MQTT broker, Trajectory Generator, Simulation, Continuous Validation); all run locally on the same machine that hosts the physical crane; repository includes docker compose file, initial‑setup scripts, and documentation in MkDocs; licensed under MIT."
]