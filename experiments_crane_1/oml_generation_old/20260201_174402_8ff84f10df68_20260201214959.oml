// C2: Acting Components //
instance CraneXAxisMotor : DTDFVocab:ActingComponent [
    base:desc "Electric motor driving the X-axis movement of the lab-scale gantry crane with constrained range for lab-scale operations"
]

instance CraneYAxisMotor : DTDFVocab:ActingComponent [
    base:desc "Electric motor controlling the Y-axis movement of the gantry crane with precise positioning capabilities"
]

instance CraneHoistingMotor : DTDFVocab:ActingComponent [
    base:desc "Motor responsible for vertical lifting mechanism of the crane pucks with safety constraints enforced through continuous validation"
]

instance CraneController : DTDFVocab:ActingComponent [
    base:desc "Embedded controller interfacing with crane actuators and sensors to enable real-time operation and remote control"
]

// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "High-precision encoder measuring the crane's rotational position with high resolution for kinematic validation"
    DTDFVocab:producedData SwingAngleData
]

instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the X/Y position coordinates of the crane cart with high accuracy requirements"
    DTDFVocab:producedData PositionData
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the velocity of crane movement components for dynamic validation"
    DTDFVocab:producedData VelocityData
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor measuring air conditions (though its specific role in crane operations is unspecified)"
    DTDFVocab:producedData EnvironmentalData
]

// C4: Physical-to-Virtual Data Transmission
instance SwingAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance PositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor
]

instance VelocityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocitySensor
]

instance EnvironmentalData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Models/Data
instance CraneGeometricModel : DTDFVocab:Model [
    base:desc "3D CAD-derived geometric representation of the gantry crane structure, cart, and pucks used for visualization and validation"
    DTDFVocab:inputTo CraneSimulationEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Mathematical model representing the crane's motion dynamics including cart movement and hoisting mechanics for trajectory planning"
    DTDFVocab:inputTo ControlValidationEnabler
]

instance SensorDataLog : DTDFVocab:Data [
    base:desc "Time-series database storing raw sensor readings including swing angles, positions, velocities, and environmental measurements"
    DTDFVocab:fromData SwingAngleData, PositionData, VelocityData, EnvironmentalData
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance ModelPredictionData : DTDFVocab:Data [
    base:desc "Digital twin simulation outputs including predicted positions, velocities, and trajectory predictions for continuous validation"
    DTDFVocab:fromData KinematicSimulationData
    DTDFVocab:inputTo ControlValidationEnabler
]

instance KinematicSimulationData : DTDFVocab:Data [
    base:desc "Intermediate data representing simulated kinematic states used for real-time comparison with physical measurements"
    DTDFVocab:fromData CraneKinematicModel
    DTDFVocab:inputTo ControlValidationEnabler
]

// C11: Enablers
instance CraneSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python-based simulation container implementing kinematic models and trajectory planning using CAD-derived geometric representations"
    DTDFVocab:enables OptimalTrajectoryService, VisualizationService
]

instance ControlValidationEnabler : DTDFVocab:Enabler [
    base:desc "Real-time validation service comparing physical sensor data with kinematic model predictions to detect deviations"
    DTDFVocab:enables ContinuousValidationService, FaultDetectionService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database service storing sensor readings, model outputs, and validation metrics with high-frequency logging capabilities"
    DTDFVocab:enables DataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Message broker facilitating bidirectional communication between physical crane controllers and digital twin services"
    DTDFVocab:enables DataIntegrationService
]

instance PythonInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Python-based container serving as interface between physical crane controllers and digital twin components"
    DTDFVocab:enables DataCollectionService, ContinuousValidationService
]

// C6: Services
instance OptimalTrajectoryService : DTDFVocab:Service [
    base:desc "Service computing energy-efficient or time-optimal paths for crane movement using kinematic models and closed-loop control"
    DTDFVocab:provides OptimalTrajectoryInsight, TrajectoryExecutionAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Real-time validation service continuously comparing physical measurements with model predictions to ensure digital-physical alignment"
    DTDFVocab:provides ValidationMetricsInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection service identifying deviations in crane kinematic behavior through data comparison against nominal models"
    DTDFVocab:provides FaultDetectionInsight
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service storing operational data including joint angles, forces, and timestamps for post-mortem analysis"
    DTDFVocab:provides HistoricalDataInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service providing real-time dashboard interface displaying position vs. time traces from CAD models and sensor inputs"
    DTDFVocab:provides VisualizationInsight
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Energy-efficient or time-optimal movement paths calculated for the crane's X/Y axes and lifting mechanism"
]

instance TrajectoryExecutionAction : DTDFVocab:Action [
    base:desc "Automatic execution of optimal trajectories in the physical crane system"
    DTDFVocab:IsAutomatic true
]

instance ValidationMetricsInsight : DTDFVocab:Insight [
    base:desc "Quantitative metrics comparing physical sensor data with digital twin predictions for validation purposes"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identified anomalies in crane kinematic behavior including motor stalls or sensor drift detected through data comparison"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Time-series analysis of crane operational data enabling trend evaluation and post-mortem analysis"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive dashboard displaying real-time crane position, velocity, and trajectory data for intuitive monitoring"
]

// C18: Environments/Components
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Physical environment containing the lab-scale gantry crane system including mechanical structure and embedded controllers"
    base:contains CraneMechanicalStructure, CraneController
]

instance CraneMechanicalStructure : DTDFVocab:Component [
    base:desc "Physical gantry crane structure including X/Y axes and lifting mechanism with scale-down design for lab use"
    base:isContainedIn LabScaleGantryCraneEnvironment
]

instance CraneControlSystem : DTDFVocab:Component [
    base:desc "Embedded control system managing crane actuators and sensors with remote control interfaces"
    base:isContainedIn LabScaleGantryCraneEnvironment
]

