// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures the hoist's swinging motion with high precision for kinematic validation in the lab-scale gantry crane."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Monitors wind speed in the laboratory environment to account for external forces affecting crane dynamics."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CranePositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-frequency encoder measuring the cart's horizontal position along the gantry beam for real-time trajectory tracking."
    DTDFVocab:producedData CartPositionDataTransmitted
]

instance CraneVelocityEncoder : DTDFVocab:SensingComponent [
    base:desc "High-frequency encoder measuring the cart's velocity along the gantry beam for closed-loop control validation."
    DTDFVocab:producedData CartVelocityDataTransmitted
]

instance HoistPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-frequency encoder measuring the hoist's vertical position for payload dynamics monitoring."
    DTDFVocab:producedData HoistPositionDataTransmitted
]

instance HoistVelocityEncoder : DTDFVocab:SensingComponent [
    base:desc "High-frequency encoder measuring the hoist's vertical velocity for real-time force estimation."
    DTDFVocab:producedData HoistVelocityDataTransmitted
]

instance LoadCellSensor : DTDFVocab:SensingComponent [
    base:desc "Measures payload weight and force distribution at the hoist's electromagnet for structural integrity validation."
    DTDFVocab:producedData LoadDataTransmitted
]

instance ArduinoControllerInterface : DTDFVocab:SensingComponent [
    base:desc "Python-programmed Arduino interface capturing actuator commands and system state for bidirectional synchronization."
    DTDFVocab:producedData ControllerStateDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CartPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionEncoder
]

instance CartVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocityEncoder
]

instance HoistPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistPositionEncoder
]

instance HoistVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistVelocityEncoder
]

instance LoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadCellSensor
]

instance ControllerStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoControllerInterface
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "Deterministic CAD-based kinematic model of the gantry crane derived from Autodesk Fusion360, including joint angles, payload dynamics, and structural limits."
    DTDFVocab:inputTo TimescaleDBEnabler, OptimalControlServiceEnabler
]

instance CraneStateData : DTDFVocab:Data [
    base:desc "Continuous time-series data representing the crane's operational state (position, velocity, load) with millisecond precision."
    DTDFVocab:fromData CartPositionDataTransmitted, CartVelocityDataTransmitted, HoistPositionDataTransmitted, HoistVelocityDataTransmitted, LoadDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEnabler
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Real-time environmental factors (wind speed, workspace boundaries) affecting crane operations."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo ContinuousValidationEnabler
]

instance ControllerCommandData : DTDFVocab:Data [
    base:desc "Actuator commands and system state transmitted from the Arduino controller for bidirectional synchronization."
    DTDFVocab:fromData ControllerStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEnabler
]

instance HistoricalOperationData : DTDFVocab:Data [
    base:desc "Archived time-series data of crane operations, performance metrics, and fault patterns for retrospective analysis."
    DTDFVocab:fromData CraneStateData, ControllerCommandData
    DTDFVocab:inputTo HistoricalDataLoggingEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) for high-frequency time-series storage of crane telemetry, actuator commands, and environmental data."
    DTDFVocab:enables HistoricalDataLoggingService, DataVisualizationService, ContinuousValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker facilitating low-latency bidirectional communication between physical crane and DT services."
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana-based HMI for real-time and historical visualization of crane states, sensor traces, and system telemetry."
    DTDFVocab:enables DataVisualizationService
]

instance PythonC4ContainerEnabler : DTDFVocab:Enabler [
    base:desc "Python-based C4 containerized module for DT service orchestration, data processing, and model execution."
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Bidirectional synchronization mechanism cross-validating the digital twin's kinematic model against real-time sensor data."
    DTDFVocab:enables ContinuousValidationService
]

instance HistoricalDataLoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB-backed system for time-series data storage enabling retrospective analysis of crane operations."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance OptimalControlServiceEnabler : DTDFVocab:Enabler [
    base:desc "Kinematic model-based service computing optimal movement trajectories (energy-efficient or high-throughput)."
    DTDFVocab:enables OptimalControlService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service leveraging the kinematic model to compute and enforce optimal movement trajectories while respecting payload dynamics and structural limits."
    DTDFVocab:provides OptimalTrajectoryInsight, EnergyEfficientControlAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service storing and managing time-series data of crane operations, performance metrics, and fault patterns for retrospective analysis."
    DTDFVocab:provides HistoricalPerformanceInsight, FaultPatternInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service providing real-time and historical visualization of crane states, sensor traces, and system telemetry via Grafana dashboard."
    DTDFVocab:provides RealTimeStateInsight, HistoricalTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service ensuring model fidelity through bidirectional synchronization between digital twin and physical crane, detecting anomalies and correcting drift."
    DTDFVocab:provides ModelFidelityInsight, AnomalyDetectionInsight, SensorCalibrationAction
]

// C2: Acting Components
instance HorizontalMovementMotor : DTDFVocab:ActingComponent [
    base:desc "Arduino-controlled DC motor managing the cart's horizontal movement along the gantry beam with position and velocity feedback."
]

instance HoistingMotor : DTDFVocab:ActingComponent [
    base:desc "Arduino-controlled DC motor controlling the vertical hoisting mechanism with position and velocity feedback for payload dynamics."
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist's end for picking up container-like pucks, with force feedback for structural integrity validation."
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Computed optimal movement trajectories minimizing energy consumption or maximizing throughput while respecting kinematic constraints."
]

instance EnergyEfficientControlAction : DTDFVocab:Action [
    base:desc "Automatically enforces energy-efficient trajectories on the physical crane actuators."
    DTDFVocab:IsAutomatic true
]

instance HistoricalPerformanceInsight : DTDFVocab:Insight [
    base:desc "Retrospective analysis of crane operations, performance metrics, and efficiency trends over time."
]

instance FaultPatternInsight : DTDFVocab:Insight [
    base:desc "Identified patterns in operational faults and anomalies from historical data for predictive maintenance."
]

instance RealTimeStateInsight : DTDFVocab:Insight [
    base:desc "Live visualization of crane states (position, velocity, load) and system telemetry with millisecond precision."
]

instance HistoricalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Historical visualization of crane trajectories, sensor traces, and operational events for performance validation."
]

instance ModelFidelityInsight : DTDFVocab:Insight [
    base:desc "Quantified confidence bounds (upper blue, lower yellow) from continuous validation ensuring digital twin accuracy."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Detected discrepancies between digital twin predictions and physical crane behavior indicating potential faults."
]

instance SensorCalibrationAction : DTDFVocab:Action [
    base:desc "Automatically triggers sensor recalibration when anomalies exceed predefined thresholds."
    DTDFVocab:IsAutomatic true
]

// C1: Environment
instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:desc "Controlled laboratory workspace with predefined boundaries, payload capacity constraints, and safety mechanisms."
    base:contains CranePhysicalSystem, SafetyMechanismComponent
]

instance CranePhysicalSystem : DTDFVocab:Component [
    base:desc "Lab-scale gantry crane with modular mechatronic components (mechanical, electrical, control subsystems)."
    base:isContainedIn LaboratoryEnvironment
]

instance SafetyMechanismComponent : DTDFVocab:Component [
    base:desc "Collision avoidance and emergency stop systems enforcing operational domain constraints."
    base:isContainedIn LaboratoryEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The **Control Application** receives trajectory commands from the **Trajectory Generator Service**, which leverages a kinematics model to produce optimal movement trajectories for the crane. These trajectories are designed to eliminate residual swinging motion at the end of execution. The **Control Application** uses the **Physical Crane Interface** to translate these trajectories into control signals for the **Physical Crane**. No explicit command formats, validation/authentication mechanisms, or feedback systems are detailed in the document. Conflict resolution or command execution confirmation processes are not mentioned, nor are specific control message structures (e.g., waypoints, velocity profiles) described."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system architectures are predominantly **ad-hoc**, avoiding commercial frameworks. **GreenhouseDT** integrates an **InfluxDB** time-series database, an **ActiveMQ** message broker, and virtual machines for behavioral adaptation of both the physical greenhouse and its digital twin. **Air Quality Management** leverages **AutomationML** for model-driven engineering, **Microsoft Azure** tools for pipeline implementation, and a Raspberry Pi with sensors for real-time data acquisition. The **lab-scale gantry crane** uses the **C4 Model** for architecture visualization, an **Eclipse Mosquitto MQTT Broker** for message handling, and a **Python-based controller interface** for real-time state logging and validation. Resource management is implicit, with no centralized orchestration layer described; instead, each exemplar relies on lightweight, domain-specific components (e.g., virtual machines, single-board computers) and open-source tools for dissemination."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The **Lab Scale Gantry Crane** implements a **continuous validation service** that compares **executed trajectories** (physical system) with **simulations** (digital twin) by calculating **distance metrics** between them. If the metric exceeds an **acceptable threshold**, operators are notified via a **dashboard**. No uncertainty quantification, error correction mechanisms, or quality assurance processes beyond this threshold-based alerting are documented. The **Air Quality Management** and **GreenhouseDT** exemplars do not specify fidelity or validity considerations in the provided text."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin system employs a **centralized architecture** with a **TimescaleDB** database as the core data repository, storing all system-generated data. Inter-service communication is facilitated by an **MQTT Broker**, which handles signaling between containers (e.g., Trajectory Generator, Simulation, Continuous Validation). The network topology is not explicitly detailed, but the system is deployed on a single personal computer co-located with the physical crane. No specifications for bandwidth, latency, redundancy, or security protocols (e.g., encryption, authentication) are provided in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin system is deployed **on-premise** on a personal computer, co-located with the **Physical Crane**. The **Database (TimescaleDB)**, **MQTT Broker**, and **Dashboard (Grafana)** are containerized using **Docker** for ease of deployment. The **Physical Crane Interface**, **Control Application**, **Logging Application**, and **Human Machine Interface** are implemented as standalone Python applications running on the same host. No cloud or edge deployment is mentioned. Scalability mechanisms, computational/storage requirements, or availability/reliability assurances are not specified beyond the containerized components."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin systems demonstrate **limited external integration**, primarily relying on internal or self-contained components. **GreenhouseDT** uses **InfluxDB** and **ActiveMQ** for internal data storage and messaging, with no explicit dependencies on external enterprise systems. **Air Quality Management** integrates **AutomationML** for model exchange and **Microsoft Azure** for cloud-based pipeline execution, but no broader enterprise interoperability is described. The **lab-scale gantry crane** operates on a **single personal computer** with a **Python interface** to controllers, relying solely on freely available software (e.g., Eclipse Mosquitto MQTT Broker) and **no industrial protocols (e.g., OPC UA)** or cloud services (e.g., Azure IoT Hub). All exemplars prioritize self-sufficiency, with external integration confined to domain-specific tools (e.g., AutomationML, Azure) or minimal sensor/actuator interfaces."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar adheres to:
  - **AutomationML** for digital twin modeling and interoperability.
  - **Microsoft Azure tools** for cloud-based pipeline implementation, implying compliance with Microsoft’s cloud standards (e.g., Azure IoT, Event Hubs).
  GreenhouseDT uses **InfluxDB** (a time-series database standard) and **ActiveMQ** (a JMS-compliant message broker), suggesting alignment with open-source interoperability standards. The gantry crane exemplar lacks explicit standardization details. **No industry-specific certifications or compliance frameworks** (e.g., ISO 27001, IEC 62443) are mentioned."
]