// ------------------------------------------------------------
// C3: Physical sensing components
// ------------------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder mounted on the hoist to measure the crane's swing angle"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer (wind‑speed sensor) attached to the crane frame"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoBoard : DTDFVocab:SensingComponent [
    base:desc "Arduino board that reads the swing‑angle encoder and anemometer and forwards sensor values"
    DTDFVocab:producedData ArduinoSensorDataTransmitted
]

// ------------------------------------------------------------
// C2: Acting components (physical)
// ------------------------------------------------------------
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart along the gantry rails"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist winch for vertical motion"
]

instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval motor controller for the cart stepper motor"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval motor controller for the hoist stepper motor"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist to pick up pucks"
]

// ------------------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// ------------------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance ArduinoSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoBoard
]

// ------------------------------------------------------------
// C10: Data (time‑series stored in TimescaleDB)
// ------------------------------------------------------------
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance ArduinoSensorData : DTDFVocab:Data [
    base:desc "Aggregated sensor data read by the Arduino (encoder + anemometer)"
    DTDFVocab:fromData ArduinoSensorDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// ------------------------------------------------------------
// C10: Models/Data
// ------------------------------------------------------------
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane imported from Fusion360"
    DTDFVocab:inputTo GrafanaEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator for motion planning"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model employed by the Simulation Service to emulate crane dynamics"
    DTDFVocab:inputTo SimulationEngineEnabler
]

// ------------------------------------------------------------
// C11: Enablers (software infrastructure)
// ------------------------------------------------------------
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB PostgreSQL instance used for storing time‑series data"
    DTDFVocab:enables ContinuousDataLoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard connected to TimescaleDB for real‑time visualization"
    DTDFVocab:enables RealTimeVisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python‑based Trajectory Generator service utilizing the kinematic model"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine (e.g., PyBullet) running the dynamic simulation model"
    DTDFVocab:enables CraneSimulationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Continuous Validation Service that compares measured trajectories with simulated ones"
    DTDFVocab:enables ContinuousValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for signalling between services"
    DTDFVocab:enables OptimalControlService
]

// ------------------------------------------------------------
// C6: Services
// ------------------------------------------------------------
instance ContinuousDataLoggingService : DTDFVocab:Service [
    base:desc "Continuously logs sensor readings and motor states into TimescaleDB"
    DTDFVocab:provides ContinuousLoggingInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time dashboards in Grafana for operators"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal motion plans using the kinematic model"
    DTDFVocab:provides TrajectoryPlanInsight
    DTDFVocab:provides MotionControlAction
]

instance CraneSimulationService : DTDFVocab:Service [
    base:desc "Emulates crane dynamics based on the dynamic simulation model"
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Validates live data against simulation; raises alerts when thresholds are breached"
    DTDFVocab:provides ValidationAlertInsight
    DTDFVocab:provides OperatorInterventionAction
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Executes optimal‑control commands derived from trajectory plans"
    DTDFVocab:provides OptimalControlInsight
]

// ------------------------------------------------------------
// C17: Insights / Actions
// ------------------------------------------------------------
instance ContinuousLoggingInsight : DTDFVocab:Insight [
    base:desc "Insight that data are being continuously logged"
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight that operators can monitor crane status in real time via Grafana"
]

instance TrajectoryPlanInsight : DTDFVocab:Insight [
    base:desc "Insight delivering optimal motion plans to the control loop"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight that simulated trajectories are available for comparison"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert raised when measured trajectories deviate beyond validation thresholds"
]

instance OptimalControlInsight : DTDFVocab:Insight [
    base:desc "Insight that optimal‑control commands have been dispatched to the crane actuators"
]

instance OperatorInterventionAction : DTDFVocab:Action [
    base:desc "Operator may intervene to stop or adjust crane operation after a validation alert"
    DTDFVocab:IsAutomatic false
]

instance MotionControlAction : DTDFVocab:Action [
    base:desc "Automatic action sending the generated trajectory to the crane's control loop"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Commands from the DT to the PT are issued by the Control Application, which uses the same Python‑based Physical Crane Interface to send control set‑points to the motor controllers and to the Arduino. The interface thus drives the stepper motors and activates the electromagnet according to trajectories generated by DT services."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "All components are orchestrated via a Docker‑Compose stack on a personal computer: Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface, MQTT broker, TimescaleDB, Grafana dashboard, and the three DT services (trajectory generation, simulation, continuous validation)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the designed stage (CAD models of the crane in Autodesk Fusion360), the manufactured stage (physical hardware as built), and the operated stage (runtime data acquisition, simulation and validation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service computes distance metrics between executed trajectories (measured by the swing‑angle encoder) and simulated trajectories; a configurable threshold triggers operator alerts if the error exceeds acceptable limits. The Trajectory Generator creates swing‑free trajectories to ensure high fidelity between planned and actual motion."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication uses MQTT (Eclipse Mosquitto) for signaling between the Trajectory Generator, Simulation, Continuous Validation services and the dashboard. The Logging Application writes to TimescaleDB using PostgreSQL client protocols. The Physical Crane Interface communicates with the motor controllers and Arduino via the physical connection (e.g., USB/serial) as a Python program, and all Docker containers share a common Docker network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin runs locally on a single PC. Docker containers host TimescaleDB, MQTT broker, and Grafana; Python services run as regular processes after installing the gantrylib package. Deployment is automated with a docker‑compose file and the repository is publicly hosted on GitHub."
]