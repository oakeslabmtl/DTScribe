// Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor mounted on the cart axis controlled via a Trinamic TMC4671 driver"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor mounted on the hoist axis controlled via a Trinamic TMC4671 driver"
]

instance ArduinoMicrocontroller : DTDFVocab:ActingComponent [
    base:desc "Arduino microcontroller handling motor commands and sensor polling"
]

// Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder mounted on the hoist measuring the crane’s swing"
    DTDFVocab:producedData SwingAngleTransmission
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer sensing wind speed affecting crane dynamics"
    DTDFVocab:producedData WindSpeedTransmission
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current feedback from the Trinamic TMC4671 drivers monitoring motor currents"
    DTDFVocab:producedData MotorCurrentTransmission
]

instance MotorVoltageSensor : DTDFVocab:SensingComponent [
    base:desc "Voltage feedback from the Trinamic TMC4671 drivers monitoring motor voltages"
    DTDFVocab:producedData MotorVoltageTransmission
]

instance ElectromagnetPresenceSensor : DTDFVocab:SensingComponent [
    base:desc "Logic sensing the presence of a plastic puck held by the electromagnet end‑effector"
    DTDFVocab:producedData PresenceTransmission
]

// Physical‑to‑Virtual Interaction (Data Transmitted)
instance SwingAngleTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorCurrentTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorVoltageTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorVoltageSensor
]

instance PresenceTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ElectromagnetPresenceSensor
]

// Stored Data
instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Timestamped swing angle value stored in TimescaleDB"
    DTDFVocab:inputTo LoggingApplication, TrajectoryGeneratorEnabler, ContinuousValidationEnabler
    DTDFVocab:fromData SwingAngleTransmission
]

instance WindSpeedMeasurement : DTDFVocab:Data [
    base:desc "Timestamped wind speed value stored in TimescaleDB"
    DTDFVocab:inputTo LoggingApplication, TrajectoryGeneratorEnabler, ContinuousValidationEnabler
    DTDFVocab:fromData WindSpeedTransmission
]

instance MotorCurrentMeasurement : DTDFVocab:Data [
    base:desc "Timestamped motor current value stored in TimescaleDB"
    DTDFVocab:inputTo LoggingApplication, TrajectoryGeneratorEnabler, ContinuousValidationEnabler
    DTDFVocab:fromData MotorCurrentTransmission
]

instance MotorVoltageMeasurement : DTDFVocab:Data [
    base:desc "Timestamped motor voltage value stored in TimescaleDB"
    DTDFVocab:inputTo LoggingApplication, TrajectoryGeneratorEnabler, ContinuousValidationEnabler
    DTDFVocab:fromData MotorVoltageTransmission
]

instance PresenceMeasurement : DTDFVocab:Data [
    base:desc "Timestamped container presence flag stored in TimescaleDB"
    DTDFVocab:inputTo LoggingApplication, TrajectoryGeneratorEnabler, ContinuousValidationEnabler
    DTDFVocab:fromData PresenceTransmission
]

// Models / Data
instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Service enabling Docker‑Compose orchestration for the twin"
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Service enabling the physics‑based simulation component"
]

instance CraneCADModel : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane (nodes and links) stored in Autodesk Fusion360"
    DTDFVocab:inputTo DockerComposeEnabler
] 

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Python kinematic model producing swing‑free trajectory points"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation reproducing motor and controller dynamics"
    DTDFVocab:inputTo SimulationEnabler
]

instance SimulatedTrajectoryPointData : DTDFVocab:Data [
    base:desc "Simulated trajectory points stored for validation comparison"
    DTDFVocab:inputTo ContinuousValidationEnabler
]

instance ValidationMetricData : DTDFVocab:Data [
    base:desc "Euclidean distance between live sensor data and simulated trajectory points"
    DTDFVocab:inputTo ContinuousValidationEnabler
]

// Enablers
instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Python application writing sensor data to TimescaleDB and publishing over Mosquitto"
    DTDFVocab:enables LoggingService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python component generating real‑time trajectory surfaces for the crane"
    DTDFVocab:enables TrajectoryGenerationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Service comparing live telemetry to simulated trajectories and flagging deviations"
    DTDFVocab:enables ContinuousValidationService
]

instance PhysicalInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Interface translating Arduino commands to twin services"
    DTDFVocab:enables PhysicalInterfaceService
]

instance HumanMachineInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Python web interface for manual crane control and configuration"
    DTDFVocab:enables HumanMachineInterfaceService
]

// Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Logs all operational telemetry into TimescaleDB and publishes over MQTT"
    DTDFVocab:provides RealTimeDashboardInsight, ThresholdBreachesAction
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Produces swing‑free motor command trajectories for the crane"
    DTDFVocab:provides TrajectoryDeviationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Computes deviation metrics and triggers fault notifications"
    DTDFVocab:provides FaultDetectionInsight, NotificationInsight
]

instance PhysicalInterfaceService : DTDFVocab:Service [
    base:desc "Receives motor commands from twin and forwards to Arduino"
    DTDFVocab:provides ManualControlAction
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Web dashboard providing real‑time visualisation and operator controls"
    DTDFVocab:provides RealTimeDashboardInsight
]

// Insights/Actions
instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Visualises live versus simulated crane states on Grafana"
]

instance TrajectoryDeviationInsight : DTDFVocab:Insight [
    base:desc "Highlights deviations between commanded and executed crane trajectories"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Indicates faults detected via continuous validation metrics"
]

instance NotificationInsight : DTDFVocab:Insight [
    base:desc "Alarms operators when thresholds are breached"
]

instance ThresholdBreachesAction : DTDFVocab:Action [
    base:desc "Automatically alerts operators to threshold breaches"
    DTDFVocab:IsAutomatic true
]

instance AdjustmentsAction : DTDFVocab:Action [
    base:desc "Allows operators to adjust trajectory parameters or control set‑points"
    DTDFVocab:IsAutomatic false
]

instance ManualControlAction : DTDFVocab:Action [
    base:desc "Provides manual control commands from the human‑machine interface"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service emits optimal position trajectories via MQTT, which are received by the Control Application that forwards the output to the Physical Interface. The Control Application sends motor set‑points back to the Arduino controlling the TMC4671 drivers. Continuous Validation may trigger operator alerts through the Grafana dashboard, but control actions are limited to the generated trajectories."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Services operate continuously during crane operation; data logging and validation happen in real‑time, but no explicit sampling intervals or time‑scales are specified in the document"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin constellation follows a C4‑modelled architecture: the physical system interface (Python module) connects to the Arduino hardware; the Control Application issues trajectory set‑points; the Logging Application streams telemetry into TimescaleDB; the Trajectory, Simulation, and Validation Services operate as separate containers communicating through the MQTT broker; the Grafana Dashboard outputs live visualisations and alerts; all containers are orchestrated by a Docker‑Compose file that defines networking and volume mounts. The Digital Twin services run on a local PC, with the physical hardware interface directly attached to the machine’s serial/USB port."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin is developed through four main phases: (1) design – CAD models in Autodesk Fusion360 and kinematic models; (2) manufacturing – assembly of the physical crane per the BOM; (3) deployment – installation of the twin services on a local PC containerised via Docker; (4) operation – real‑time control, continuous validation and research experiments such as fault classification and twin evolution annotations through DarTwin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin’s fidelity relies on a closed‑loop validation loop that compares live capture against a deterministic simulation. Distance metrics (e.g., mean squared error in position and swing angle) are calculated per sample. If a metric exceeds a user‑defined threshold the Continuous Validation Service flags a warning that is shown in the Grafana dashboard. This approach provides a quantitative low‑fidelity validation while ensuring the continuous data stream remains coherent with the physical behaviour. Fault classification experiments use time‑series models trained on historical telemetry to detect deviations from nominal behaviour, further increasing validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical Crane Interface connects to the Arduino via USB/serial, reads sensor data, writes to TimescaleDB over PostgreSQL protocol, and publishes control commands; MQTT broker (Eclipse Mosquitto) handles inter‑service messaging on a local network"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin is hosted locally on a development machine running a Linux/Windows PC. A single Docker‑Compose YAML file brings up the TimescaleDB, Mosquitto broker, Grafana dashboard, and all twin service containers with one command. The physical interface and control application run as native Python processes on the host; the Arduino firmware is flashed via the Arduino IDE. This local deployment enables instant experimentation and real‑time interaction without external infrastructure."
]