// C3: Physical sensing components

instance GreenhouseTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring greenhouse temperature"
    DTDFVocab:producedData GreenhouseTemperatureDataTransmitted
]

instance GreenhouseHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor measuring greenhouse humidity"
    DTDFVocab:producedData GreenhouseHumidityDataTransmitted
]

instance GreenhouseCO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor measuring greenhouse CO₂ levels"
    DTDFVocab:producedData GreenhouseCO2DataTransmitted
]

instance IAQAirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "Air quality sensor for indoor air quality metrics"
    DTDFVocab:producedData IAQAirQualityDataTransmitted
]

instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reading the gantry crane’s position"
    DTDFVocab:producedData CranePositionDataTransmitted
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reading the gantry crane’s velocity"
    DTDFVocab:producedData CraneVelocityDataTransmitted
]

instance CraneLoadSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reading the load on the gantry crane"
    DTDFVocab:producedData CraneLoadDataTransmitted
]

// C4: Physical-to-virtual interaction

instance GreenhouseTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseTemperatureSensor
]

instance GreenhouseHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseHumiditySensor
]

instance GreenhouseCO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseCO2Sensor
]

instance IAQAirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IAQAirQualitySensor
]

instance CranePositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor
]

instance CraneVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocitySensor
]

instance CraneLoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneLoadSensor
]

// C10: Models/Data

instance GreenhouseTemperatureData : DTDFVocab:Data [
    base:desc "Time-series temperature data for the greenhouse"
    DTDFVocab:fromData GreenhouseTemperatureDataTransmitted
    DTDFVocab:inputTo InfluxDBIngestor
]

instance GreenhouseHumidityData : DTDFVocab:Data [
    base:desc "Time-series humidity data for the greenhouse"
    DTDFVocab:fromData GreenhouseHumidityDataTransmitted
    DTDFVocab:inputTo InfluxDBIngestor
]

instance GreenhouseCO2Data : DTDFVocab:Data [
    base:desc "Time-series CO₂ data for the greenhouse"
    DTDFVocab:fromData GreenhouseCO2DataTransmitted
    DTDFVocab:inputTo InfluxDBIngestor
]

instance IAQAirQualityData : DTDFVocab:Data [
    base:desc "Indoor air quality data collected via Azure IoT Hub"
    DTDFVocab:fromData IAQAirQualityDataTransmitted
    DTDFVocab:inputTo AzureIoTHubConnector
]

instance CranePositionData : DTDFVocab:Data [
    base:desc "Current position of the gantry crane"
    DTDFVocab:fromData CranePositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBLogger
]

instance CraneVelocityData : DTDFVocab:Data [
    base:desc "Current velocity of the gantry crane"
    DTDFVocab:fromData CraneVelocityDataTransmitted
    DTDFVocab:inputTo TimescaleDBLogger
]

instance CraneLoadData : DTDFVocab:Data [
    base:desc "Current load on the gantry crane"
    DTDFVocab:fromData CraneLoadDataTransmitted
    DTDFVocab:inputTo TimescaleDBLogger
]

// C11: Enablers

instance InfluxDBIngestor : DTDFVocab:Enabler [
    base:desc "InfluxDB time-series database ingesting greenhouse sensor streams"
    DTDFVocab:enables InfluxDataStorageService
]

instance AzureIoTHubConnector : DTDFVocab:Enabler [
    base:desc "Azure IoT Hub connector ingesting IAQ sensor data via RESTful connectors"
    DTDFVocab:enables IAQMonitoringService
]

instance TimescaleDBLogger : DTDFVocab:Enabler [
    base:desc "TimescaleDB logger storing crane state data from the Logging Application"
    DTDFVocab:enables CraneMonitoringService
]

// C6: Services

instance InfluxDataStorageService : DTDFVocab:Service [
    base:desc "Service providing persistence of greenhouse sensor data in InfluxDB"
]

instance IAQMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real-time monitoring, simulation, prediction, and decision support for IAQ"
    DTDFVocab:provides IAQVisualizationInsight, IAQSimulationInsight, IAQPredictionInsight, VentilationAdjustmentAction
]

instance CraneMonitoringService : DTDFVocab:Service [
    base:desc "Service providing visualization and trajectory planning for the gantry crane"
    DTDFVocab:provides CranePoseInsight, CraneTrajectoryPlanAction
]

// C17: Insights/Actions

instance IAQVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of current indoor air quality metrics on a web dashboard"
]

instance IAQSimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation of airflow and contaminant transport using the twin model"
]

instance IAQPredictionInsight : DTDFVocab:Insight [
    base:desc "Prediction of virus spread under different control scenarios"
]

instance VentilationAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated recommendation to adjust ventilation based on projected infection risk scores"
    DTDFVocab:IsAutomatic true
]

instance CranePoseInsight : DTDFVocab:Insight [
    base:desc "Visualization of crane pose in a 3‑D viewer"
]

instance CraneTrajectoryPlanAction : DTDFVocab:Action [
    base:desc "Trajectory plan for the crane to minimize time or energy use"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin’s Control Application, also written in Python, consumes optimal movement trajectories generated by the Trajectory Generator Service. The Control Application sends movement commands—typically a sequence of target positions or waypoints—through the Physical Crane Interface to the actual crane controllers. Feedback from the physical crane is streamed back to the Control Application, enabling real–time monitoring. The document does not specify authentication, validation, or conflict‑resolution mechanisms for these control messages."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "GreenhouseDT orchestrates its Digital Twin and physical greenhouse through a modular, micro‑service architecture running inside a single virtual machine. The twin system ingests sensor telemetry delivered by the physical greenhouse via an ActiveMQ message broker. InfluxDB serves as the central time‑series database, storing raw readings and derived inference metrics. Each functional block – sensor aggregation, state inference, rule‑based adaptation, and runtime visualization – is deployed as a Docker container managed by Docker Compose, enabling isolated services that can be independently scaled or replaced. Synchronisation between the physical and virtual realms occurs through the message timestamps embedded in the broker messages; the twin applies a 100 ms latency budget to align data streams, and periodic adaptation cycles execute every 5 seconds based on the most recent aggregated state. The orchestrator ensures graceful shutdown and restart of services, preserving consistency across the twin ecosystem."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication is orchestrated via an MQTT broker, which routes signals between the various Digital Twin containers (Trajectory Generator Service, Simulation Service, Continuous Validation Service, etc.). The system persists data in a TimescaleDB database and visualises it on a Grafana dashboard. The document does not provide additional details on network topology, bandwidth, latency, reliability, or security protocols."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Air Quality Management exemplar integrates with external systems using several industry‑standard protocols and services. Sensor data from a Raspberry‑Pi is transmitted over MQTT with TLS encryption to Azure IoT Hub. The twin is modeled in AutomationML, providing semantic interoperability for building automation and facility management systems. Azure Stream Analytics performs real‑time transformations and feeds the results back into the twin via Azure Functions, which then trigger predictive models and update the twin state. Data persistence occurs in Azure Table Storage, while the twin exposes RESTful APIs for external ERP or CMMS integration. ActiveMQ is also employed within the GreenhouseDT context to broadcast events to any collaborating systems, ensuring loose coupling and extensibility across the enterprise landscape."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The indoor air quality digital twin conforms to the AutomationML open‑standard for modeling automation systems, providing a machine‑readable, interoperable twin representation. This standardisation choice facilitates the exchange of twin data with conventional building management systems. The use of InfluxDB and ActiveMQ indicates adherence to the standard protocols of time‑series database systems and the OpenWire protocol stack for messaging, respectively, though explicit industry certification is not reported."
]