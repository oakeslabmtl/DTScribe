// Acting Components
instance DCMotorActuator : DTDFVocab:ActingComponent [
    base:desc "DC motor actuator driving the X-axis of the lab‑scale gantry crane."
]

instance EndEffectorGripperActuator : DTDFVocab:ActingComponent [
    base:desc "End‑effector gripper used for picking and placing payloads."
]

// Sensing Components
instance MotorPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that reads the DC motor position on the gantry crane."
    DTDFVocab:producedData MotorPositionTransmitted
]

instance ElectromagnetStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that reports the status of the crane’s electromagnet."
    DTDFVocab:producedData ElectromagnetStatusTransmitted
]

// Data Transmitted
instance MotorPositionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionSensor
]

instance ElectromagnetStatusTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ElectromagnetStatusSensor
]

// Persisted Data
instance MotorPositionData : DTDFVocab:Data [
    base:desc "Persisted motor position data recorded by the logging application."
    DTDFVocab:fromData MotorPositionTransmitted
    DTDFVocab:inputTo InfluxDBEnabler
]

instance ElectromagnetStatusData : DTDFVocab:Data [
    base:desc "Persisted electromagnet status data recorded by the logging application."
    DTDFVocab:fromData ElectromagnetStatusTransmitted
    DTDFVocab:inputTo InfluxDBEnabler
]

// Enablers
instance MosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker managing message transport between services."
    DTDFVocab:enables TrajectoryGenerationService, ContinuousValidationService, VisualizationDashboardService
]

instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database storing persistent sensor data."
    DTDFVocab:enables LoggingService, ContinuousValidationService, SimulationEngineService, PredictionService, OptimalControlService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana engine rendering live telemetry and archived traces."
    DTDFVocab:enables VisualizationDashboardService
]

instance PythonKinematicModuleEnabler : DTDFVocab:Enabler [
    base:desc "Python kinematic model interfacing sensor data to compute motion paths."
    DTDFVocab:enables TrajectoryGenerationService, OptimalControlService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker Compose orchestrating all service containers."
    DTDFVocab:enables TrajectoryGenerationService, LoggingService, ContinuousValidationService, VisualizationDashboardService, SimulationEngineService, PredictionService, OptimalControlService
]

// Services
instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Trajectory generation service optimizing crane motion paths to satisfy kinematic constraints and reduce mechanical wear."
    DTDFVocab:provides TrajectoryOptimizationInsight
    DTDFVocab:inputTo PythonKinematicModuleEnabler
]

instance LoggingService : DTDFVocab:Service [
    base:desc "Logging application persistently records crane state (motor positions, electromagnet status) in a time‑series database."
    DTDFVocab:provides LoggingInsight
    DTDFVocab:inputTo InfluxDBEnabler
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service compares real‑time sensor data against the kinematic model, flagging deviations that indicate faults."
    DTDFVocab:provides FaultDetectionAlertAction
    DTDFVocab:inputTo InfluxDBEnabler, MosquittoBrokerEnabler
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Visualization dashboard presenting live telemetry, historical traces, and model‑based predictions."
    DTDFVocab:provides LiveTelemetryInsight
    DTDFVocab:inputTo GrafanaEnabler, MosquittoBrokerEnabler
]

instance SimulationEngineService : DTDFVocab:Service [
    base:desc "Simulation engine computing confidence bounds for future temperature trajectories."
    DTDFVocab:provides TemperatureConfidenceBoundInsight
    DTDFVocab:inputTo InfluxDBEnabler
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Prediction service returning a probabilistic forecast for greenhouse climate variables."
    DTDFVocab:provides GreenhouseForecastInsight
    DTDFVocab:inputTo InfluxDBEnabler
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal control service exposes a REST API for a scheduling engine."
    DTDFVocab:provides ControlSchedulingInsight
    DTDFVocab:inputTo PythonKinematicModuleEnabler, InfluxDBEnabler
]

// Insights & Actions
instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight on optimized motion paths satisfying kinematic constraints."
]

instance FaultDetectionAlertAction : DTDFVocab:Action [
    base:desc "Action triggers an alert to operators via WebSocket upon detecting sensor deviations."
    DTDFVocab:IsAutomatic true
]

instance LiveTelemetryInsight : DTDFVocab:Insight [
    base:desc "Live telemetry of crane state displayed on the dashboard."
]

instance TemperatureConfidenceBoundInsight : DTDFVocab:Insight [
    base:desc "Confidence bounds for projected temperature trajectories."
]

instance GreenhouseForecastInsight : DTDFVocab:Insight [
    base:desc "Probabilistic forecast of greenhouse climate variables."
]

instance ControlSchedulingInsight : DTDFVocab:Insight [
    base:desc "Insight enabling scheduling engine to generate optimal control actions."
]

instance EnergyPlantGrowthTradeoffInsight : DTDFVocab:Insight [
    base:desc "Decision insight weighing energy consumption against plant growth."
]

instance LoggingInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful archival of sensor data by the logging pipeline."
]

// Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains DCMotorActuator, EndEffectorGripperActuator, MotorPositionSensor, ElectromagnetStatusSensor, TrajectoryGenerationService, LoggingService, ContinuousValidationService, VisualizationDashboardService, SimulationEngineService, PredictionService, OptimalControlService, DockerComposeEnabler, MosquittoBrokerEnabler, InfluxDBEnabler, GrafanaEnabler, PythonKinematicModuleEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application is a Python application that consumes trajectories produced by the Trajectory Generator Service and issues control commands to the crane through the Physical Crane Interface. The command payload format, validation, authentication mechanisms, conflict resolution strategies, or execution‑confirmation protocols are not described in the given document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin architecture is realized as a containerized micro‑service stack that runs on a single personal computer. Three core services are deployed as Docker containers: a TimescaleDB database that stores continuous telemetry streams, an Eclipse Mosquitto MQTT broker that relays messages between the physical gantry crane and the twin services, and a Grafana dashboard container that visualises the real‑time state of the system.  The remaining functional components – a Trajectory Generator, a Simulation engine, a Continuous Validation module, and a Temperature Monitoring service – are implemented as Python modules bundled in a shared library called gantrylib.  These modules are executed as separate processes or threads within the twin’s runtime and communicate with the broker via MQTT topics.  The integration relies on a lightweight MQTT message bus; no external enterprise interfaces or interoperability standards are employed beyond the standard MQTT protocol."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "An MQTT broker is deployed as the signaling backbone between the digital twin services (Trajectory Generator, Simulation, Continuous Validation, etc.). No further details are provided regarding the MQTT broker’s configuration, network topology, bandwidth or latency requirements, reliability or redundancy strategies, or security protocols such as TLS or authentication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All containers—including Physical Crane, its interface, the Control, Logging, and Digital Twin services, the TimescaleDB database, the Grafana dashboard, and the MQTT broker—appear to be hosted locally on the same premises as the physical crane. The document does not mention cloud or edge platforms, nor does it provide computational or storage requirements, scalability options, deployment models, or availability guarantees."
]