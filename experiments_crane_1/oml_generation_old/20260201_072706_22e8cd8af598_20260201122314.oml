// C1: Acting Components // Return code: 1 | Stderr:
instance CartStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor driven by a TMC4671 driver."
]

instance HoistStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor driven by a TMC4671 driver."
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet actuator used for picking up and storing puck containers."
]

// C3: Physical Sensing Components
instance SwingAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder that measures the pendulum swing of the crane."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer that measures wind speed across the crane track."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartMotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder on the cart stepper motor providing position and speed feedback."
    DTDFVocab:producedData CartMotorPositionDataTransmitted
]

instance HoistMotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder on the hoist stepper motor providing position and speed feedback."
    DTDFVocab:producedData HoistMotorPositionDataTransmitted
]

// C4: Physical‑to‑Virtual Interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensor
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance CartMotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoderSensor
]

instance HoistMotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoderSensor
]

// C10: Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Precise swing‑angle measurement transmitted at the native sampling rate (~10–350 Hz)."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Real‑time wind‑speed measurement collected by the anemometer."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance CartMotorPositionData : DTDFVocab:Data [
    base:desc "Cart motor encoder position and speed data transmitted in real time."
    DTDFVocab:fromData CartMotorPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance HoistMotorPositionData : DTDFVocab:Data [
    base:desc "Hoist motor encoder position and speed data transmitted in real time."
    DTDFVocab:fromData HoistMotorPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used for optimal trajectory planning of the gantry crane."
    DTDFVocab:inputTo KinematicLibrary
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model used by the Simulation Service to emulate the crane dynamics."
    DTDFVocab:inputTo PhysxEngine
]

instance CADModel : DTDFVocab:Model [
    base:desc "CAD geometric model of the crane, used during virtual commissioning."
    DTDFVocab:inputTo PhysxEngine
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Mosquitto MQTT broker that routes sensor data to the time‑series database."
    DTDFVocab:enables RealTimeDataLoggingService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB PostgreSQL extension for storing time‑series telemetry."
    DTDFVocab:enables RealTimeDataLoggingService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for visualizing real‑time data and alerts."
    DTDFVocab:enables GrafanaVisualizationService
]

instance ArduinoController : DTDFVocab:Enabler [
    base:desc "Arduino microcontroller that aggregates sensor data and publishes via MQTT."
    DTDFVocab:enables RealTimeDataLoggingService
]

instance KinematicLibrary : DTDFVocab:Enabler [
    base:desc "Python library containing the kinematic model for trajectory generation."
    DTDFVocab:enables TrajectoryGeneratorService
]

instance PhysxEngine : DTDFVocab:Enabler [
    base:desc "Physics simulation engine used to emulate crane dynamics in the Simulation Service."
    DTDFVocab:enables SimulationService
]

// C6: Services
instance RealTimeDataLoggingService : DTDFVocab:Service [
    base:desc "Service that stores sensor telemetry in TimescaleDB via MQTT."
]

instance GrafanaVisualizationService : DTDFVocab:Service [
    base:desc "Service that visualizes telemetry and alerts in Grafana."
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service that outputs optimal paths to reduce swing and energy consumption."
    DTDFVocab:provides OptimalTrajectoryInsight, ApplyOptimalTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that simulates crane dynamics using the physics simulation model."
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that compares executed trajectories to simulated ones, generating distance metrics and threshold alerts."
    DTDFVocab:provides ThresholdBreachedInsight, AdjustTrajectoryAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service that classifies fault modes from time‑series data for maintenance planning."
    DTDFVocab:provides FaultDetectionInsight
]

// C17: Insights/Actions
instance ThresholdBreachedInsight : DTDFVocab:Insight [
    base:desc "Alert generated when trajectory execution deviates beyond predefined swing or speed thresholds."
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Generated optimal trajectory for container movement across the gantry track."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating detected fault modes that may affect crane operation."
]

instance AdjustTrajectoryAction : DTDFVocab:Action [
    base:desc "Operator‑intervention action to adjust the elevator and cart trajectory based on validation alerts."
    DTDFVocab:IsAutomatic false
]

instance ApplyOptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatically apply the optimal trajectory generated by the Trajectory Generator Service."
    DTDFVocab:IsAutomatic true
]

// C18: Components and Environment
instance GantryCraneSystem : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane composed of wooden/metal frame, stepper motors, electromagnet, and sensors."
]

instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains GantryCraneSystem, ArduinoController, MQTTBroker, TimescaleDB, GrafanaDashboard, KinematicLibrary, PhysxEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application and Trajectory Generator Service compute and publish trajectory commands (position, velocity profiles) and electromagnet on/off signals to the Physical Crane Interface over MQTT, which then drives the cart and hoist motors through the Arduino and motor drivers."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous data logging and validation occur at the sensor sampling frequency (10–50 Hz). Trajectory generation and simulation are triggered on demand and run on the order of seconds. The entire twin operates in real time, synchronising with the physical crane via MQTT with sub‑second latency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin’s architecture follows a C4 container diagram. Docker‑compose brings up the TimescaleDB, Mosquitto broker, and Grafana. Services (logging, trajectory generator, simulation, continuous validation) publish/subscribe over MQTT. The operator GUI communicates via MQTT; the control and logging applications interact directly with the physical interface over Python."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design: CAD models (Autodesk Fusion 360) and kinematic model. Manufacturing: Build the crane per BOM and firmware on Arduino. Operation: Deploy twin, collect operational data, run continuous validation, and iteratively evolve services such as fault detection."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The kinematic and simulation models are validated against live measurements through the Continuous Validation Service which computes Euclidean distance metrics between simulated and real trajectories and flags deviations beyond a user‑defined threshold, ensuring model fidelity during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical sensors and actuators are interfaced through an Arduino MCU connected to the PC via serial; the Python Physical Crane Interface translates high‑level commands into UART messages. Within the twin, services exchange data via MQTT over TCP/IP; the TimescaleDB instance is accessed via PostgreSQL over TCP/IP port 5432."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin containers run locally on the operator’s personal computer under Docker; the Python gantrylib package is installed via pip. The GitHub repository hosts the source, Docker‑compose file, and documentation (MkDocs). No cloud hosting is used."
]