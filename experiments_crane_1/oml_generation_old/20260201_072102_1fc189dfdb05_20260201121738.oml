// Sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring pendulum swing angle"
    DTDFVocab:producedData SwingAngleDataTX
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTX
]

instance MotorPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Motor driver current/position sensor measuring cart/hoist position"
    DTDFVocab:producedData MotorPositionDataTX
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor driver current sensor monitoring motor current (TMC4671‑Eval)"
    DTDFVocab:producedData MotorCurrentDataTX
]

// Data transmitted over MQTT
instance SwingAngleDataTX : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTX : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MotorPositionDataTX : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionSensor
]

instance MotorCurrentDataTX : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// Telemetry data stored in TimescaleDB
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series swinging angle data"
    DTDFVocab:fromData SwingAngleDataTX
    DTDFVocab:inputTo DataLoggingEnabler, ContinuousValidationEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series wind speed data"
    DTDFVocab:fromData WindSpeedDataTX
    DTDFVocab:inputTo DataLoggingEnabler, ContinuousValidationEnabler
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Time‑series motor position data from cart/hoist"
    DTDFVocab:fromData MotorPositionDataTX
    DTDFVocab:inputTo DataLoggingEnabler, ContinuousValidationEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series motor current data"
    DTDFVocab:fromData MotorCurrentDataTX
    DTDFVocab:inputTo DataLoggingEnabler, ContinuousValidationEnabler
]

// Enablers
instance MQTTBrokerEclipseMosquitto : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for telemetry streaming"
]

instance TimescaleDBInstance : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance for time‑series storage"
]

instance DataLoggingEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib logging application that streams sensor data via MQTT into TimescaleDB"
    DTDFVocab:enables DataLoggingService
]

instance TrajectoryGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Kinematic model based enabler driving optimal trajectory generation"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for motor dynamics simulation"
    DTDFVocab:enables SimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that compares measured telemetry with simulated trajectories"
    DTDFVocab:enables ContinuousValidationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that classifies faults from continuous validation results"
    DTDFVocab:enables FaultDetectionService
]

// Models
instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the gantry crane used for trajectory generation"
    DTDFVocab:inputTo TrajectoryGenerationEnabler
]

instance MotorDynamicsSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of motor dynamics for trajectory execution"
    DTDFVocab:inputTo SimulationEnabler
]

// Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs sensor data into TimescaleDB via MQTT broker"
    DTDFVocab:provides RealTimeTelemetryInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal trajectory plans and confidence bounds"
    DTDFVocab:provides OptimizedTrajectoryInsight, ConfidenceBoundInsight, ControlCommandAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Reproduces motor dynamics simulation for trajectory validation"
    DTDFVocab:provides SimulatedTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates measured versus simulated trajectories and triggers alerts"
    DTDFVocab:provides ValidationAlertInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Classifies faults from validation data and informs operator actions"
    DTDFVocab:provides FaultDetectionInsight
]

// Insights
instance RealTimeTelemetryInsight : DTDFVocab:Insight [
    base:desc "Real‑time telemetry dashboard showing sensor values"
]

instance ConfidenceBoundInsight : DTDFVocab:Insight [
    base:desc "Confidence bounds visualized on trajectory plots"
]

instance OptimizedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimized trajectory plan generated by the twin"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert notification created when continuous validation exceeds thresholds"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Fault classification results informing operator actions"
]

instance SimulatedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Simulated trajectory data used for validation"
]

// Actions
instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Velocity/position commands sent to motor controllers (TMC4671‑Eval) to actuate the crane"
    DTDFVocab:IsAutomatic false
]

// Acting components
instance MotorControllerTMC4671 : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval motor driver board that receives velocity/position commands"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands from the Control Application and Trajectory‑Generator Service are published to the Physical‑Crane Interface via MQTT and executed by the motor drivers to move the cart and hoist, while validation alerts are transmitted back to the Human‑Machine Interface on Grafana."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Five physical containers (Physical Crane, Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface) and six digital twin containers (Database TimescaleDB, MQTT Broker, Grafana Dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service) orchestrated via Docker Compose and communicating over MQTT; the Physical‑Crane Interface bridges the physical and digital worlds."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Designed stage (CAD models in Autodesk Fusion360 and kinematic model), Manufactured stage (physical hardware including motors, encoders, Arduino, PSU), and Operated stage (real‑time operation, continuous monitoring and validation during active use)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation is performed by continuously comparing executed trajectories (sensor data) with simulated trajectories using distance metrics; thresholds define acceptable deviation; simulation uses a physics‑based kinematic model; continuous validation provides runtime verification; uncertainties arise from sensor noise and modeling approximations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Local network connection utilizing MQTT protocol via Eclipse Mosquitto broker; sensor data and control commands are published to topics with QoS 1; all components run on a single personal computer within a Docker network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital twin services are containerized and deployed on a personal computer using Docker Compose; TimescaleDB, Mosquitto, and Grafana run as Docker containers, with the gantrylib Python module installed via pip; the Physical‑Crane Interface runs as a Python process on the host."
]