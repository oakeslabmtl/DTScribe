// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist sway on the gantry crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed near the crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Internal feedback sensor from TMC4671 stepper motor controllers reporting motor current and position"
    DTDFVocab:producedData MotorFeedbackDataTransmitted
]

// C4: Physical-to-virtual interaction – data transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance MotorFeedbackDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorFeedbackSensor
]

// C10: Data (time‑series stored in TimescaleDB)
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance MotorFeedbackTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of motor current and position feedback stored in TimescaleDB"
    DTDFVocab:fromData MotorFeedbackDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C10: Models
instance CraneCADModel : DTDFVocab:Model [
    base:desc "Fusion360 CAD model of the lab‑scale gantry crane"
    DTDFVocab:inputTo GrafanaDashboardEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generation Service to compute optimal motion plans"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance CranePhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model employed by the Simulation Service to predict crane dynamics"
    DTDFVocab:inputTo PhysicsSimulationEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL) container storing time‑series sensor and state data"
    DTDFVocab:enables DataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for publishing sensor data and control commands"
    DTDFVocab:enables DataLoggingService, RealTimeVisualizationService, TrajectoryGenerationService, PhysicsSimulationService, ContinuousValidationService, HumanMachineInterfaceService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana container providing real‑time visualisation dashboards for operators"
    DTDFVocab:enables RealTimeVisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module inside a Docker container generating optimal motion trajectories"
    DTDFVocab:enables TrajectoryGenerationService
]

instance PhysicsSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Dockerised physics simulation engine evaluating crane dynamics against control inputs"
    DTDFVocab:enables PhysicsSimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Service that compares live measurements with simulation outputs and raises alerts"
    DTDFVocab:enables ContinuousValidationService
]

instance HumanMachineInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based HMI allowing operators to adjust parameters and issue commands"
    DTDFVocab:enables HumanMachineInterfaceService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that subscribes to MQTT topics and logs sensor measurements into TimescaleDB"
    DTDFVocab:provides DataLoggedInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Service that reads data from TimescaleDB and streams it to Grafana dashboards"
    DTDFVocab:provides VisualizationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service that computes optimal swing‑reducing motion plans using the kinematic model"
    DTDFVocab:provides OptimalMotionPlanInsight
]

instance PhysicsSimulationService : DTDFVocab:Service [
    base:desc "Service that runs physics‑based simulation of crane motion for validation and prediction"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that measures deviation between live sensor data and simulation predictions, issuing alerts"
    DTDFVocab:provides DeviationAlertInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Service that presents dashboards and accepts operator adjustments, forwarding commands via MQTT"
    DTDFVocab:provides OperatorAdjustmentAction
]

// C17: Insights / Actions
instance DataLoggedInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data has been successfully persisted in TimescaleDB"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visual representation of crane state on operator dashboards"
]

instance OptimalMotionPlanInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory plan that minimizes swing during load movement"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Predicted crane behavior from physics simulation for comparison with live data"
]

instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating model‑real‑world deviation beyond configured thresholds"
]

instance OperatorAdjustmentAction : DTDFVocab:Action [
    base:desc "Operator‑initiated change of motion parameters or emergency stop"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application consumes trajectories or commands from the Trajectory Generator Service (and optionally from the Simulation Service) and sends motion set‑points to the Physical Crane Interface, which forwards them to the motor controllers and electromagnet via the Arduino."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical crane ↔ Python interface ↔ MQTT broker ↔ services (Trajectory Generator, Simulation, Continuous Validation) ↔ TimescaleDB ↔ Grafana dashboard ↔ Human‑Machine Interface; all components run on a single PC and communicate via MQTT and SQL over localhost."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service repeatedly compares executed trajectories (measured via sensors) with simulated trajectories, computes distance metrics, and triggers operator alerts when the metric exceeds a predefined threshold, providing runtime model fidelity checks."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT services uses MQTT (Eclipse Mosquitto) for signaling and command messages; state data is transferred to the digital side via the Python interface and stored in TimescaleDB accessed through standard PostgreSQL SQL over TCP/IP."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital‑twin services (database, MQTT broker, dashboard) are containerized with Docker; deployment is performed on a personal computer using a docker‑compose file that starts and connects the containers automatically."
]