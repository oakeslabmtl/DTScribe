// Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder measuring hoist swing motion"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// Physical acting components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor controlled by TMC4671-Eval motor controller"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor controlled by TMC4671-Eval motor controller"
]

instance ContainerElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet for container handling"
]

// Data transmitted from sensors
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

// Historical time-series data storage
instance HistoricalTimeSeriesData : DTDFVocab:Data [
    base:desc "Historical time-series data from crane system stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted, WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBTool
]

// CAD and kinematic models
instance CADModel : DTDFVocab:Model [
    base:desc "CAD model created in Autodesk Fusion360 for gantry crane system"
    DTDFVocab:inputTo Fusion360Tool, CapellaTool
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model for trajectory optimization of crane movement"
    DTDFVocab:inputTo GantrylibPythonModule
]

// Enablers and tools
instance DockerContainerization : DTDFVocab:Enabler [
    base:desc "Docker for containerization of DT services"
    DTDFVocab:enables TrajectoryGenerationService, HistoricalLoggingService, VisualizationService, CraneSimulationService, ContinuousValidationService
]

instance TimescaleDBTool : DTDFVocab:Enabler [
    base:desc "TimescaleDB for time-series data storage"
    DTDFVocab:enables HistoricalLoggingService, ContinuousValidationService, VisualizationService
]

instance GrafanaVisualization : DTDFVocab:Enabler [
    base:desc "Grafana for visualization of crane status"
    DTDFVocab:enables VisualizationService
]

instance MosquittoMQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter-service communication"
    DTDFVocab:enables HistoricalLoggingService, TrajectoryGenerationService, ContinuousValidationService, VisualizationService, CraneSimulationService
]

instance GantrylibPythonModule : DTDFVocab:Enabler [
    base:desc "Python gantrylib module for control and simulation"
    DTDFVocab:enables TrajectoryGenerationService, CraneSimulationService, ContinuousValidationService
]

instance ArduinoHardware : DTDFVocab:Enabler [
    base:desc "Arduino microcontroller for interfacing physical sensors and actuators"
    DTDFVocab:enables SwingAngleEncoder, WindSpeedAnemometer, CartStepperMotor, HoistStepperMotor, ContainerElectromagnet
]

instance Fusion360Tool : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion360 for CAD modeling"
    DTDFVocab:enables CADModel
]

instance CapellaTool : DTDFVocab:Enabler [
    base:desc "Capella for Model-Based Systems Engineering"
    DTDFVocab:enables CADModel, KinematicModel
]

// DT services
instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Optimal trajectory generation using kinematic model for crane movement"
    DTDFVocab:provides OptimalTrajectoryPlanningAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Logging of historical time-series data to TimescaleDB"
    DTDFVocab:provides HistoricalDataInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Grafana-based visualization of real-time crane status for operator decisions"
    DTDFVocab:provides RealTimeStatusVisualization
]

instance CraneSimulationService : DTDFVocab:Service [
    base:desc "Simulation of crane system dynamics for testing and training"
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation comparing real measurements against simulations for fault detection"
    DTDFVocab:provides FaultDetectionAlert
]

// Insights and actions
instance FaultDetectionAlert : DTDFVocab:Insight [
    base:desc "Continuous validation alerts for system faults"
]

instance OptimalTrajectoryPlanningAction : DTDFVocab:Action [
    base:desc "Optimal trajectory planning for crane movement"
    DTDFVocab:IsAutomatic true
]

instance RealTimeStatusVisualization : DTDFVocab:Insight [
    base:desc "Real-time status visualization for operator decisions"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Crane simulation results for validation"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Historical data logging for analysis"
]

// System environment
instance GantryCraneSystem : DTDFVocab:Environment [
    base:desc "Lab-scale gantry crane system inspired by harbor cranes in Antwerp, moving pucks representing containers between locations"
    base:contains SwingAngleEncoder, WindSpeedAnemometer, CartStepperMotor, HoistStepperMotor, ContainerElectromagnet, CADModel, KinematicModel, HistoricalTimeSeriesData, DockerContainerization, TimescaleDBTool, GrafanaVisualization, MosquittoMQTTBroker, GantrylibPythonModule, ArduinoHardware, Fusion360Tool, CapellaTool, TrajectoryGenerationService, HistoricalLoggingService, VisualizationService, CraneSimulationService, ContinuousValidationService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Optimal trajectory commands generated by Trajectory Generator Service sent to cart and hoist motors through the Physical Crane Interface Python program."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real-time synchronization for data logging and validation checks."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical crane connected to Python-based interfaces, with digital services (database, dashboard, simulation) deployed on a single PC using Docker containers and MQTT for communication."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "As-operated phase, supporting continuous validation and monitoring during crane operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous validation service compares real-time measurements against simulated trajectories, calculating distance metrics against predefined thresholds for system integrity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol for internal service communication; physical hardware interface details unspecified."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployed on a single personal computer using Docker Compose for containerized services (TimescaleDB, Grafana, Mosquitto)."
]