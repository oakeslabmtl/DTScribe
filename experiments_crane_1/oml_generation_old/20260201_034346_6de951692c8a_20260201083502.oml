// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing"
    DTDFVocab:producedData CraneTelemetryTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData CraneTelemetryTransmitted
]

// C2: Acting components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor driven by a TMC4671‑Eval motor controller"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor driven by a TMC4671‑Eval motor controller"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist for picking up containers"
]

// C4: Physical-to-virtual interaction
instance CraneTelemetryTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Telemetry published via MQTT containing sensor values and controller states"
    DTDFVocab:producedFrom SwingAngleEncoder, Anemometer
]

instance CraneStateTimeSeriesData : DTDFVocab:Data [
    base:desc "Full crane state stored as time‑series in TimescaleDB"
    DTDFVocab:fromData CraneTelemetryTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

// C10: Models/Data
instance CraneCADModel : DTDFVocab:Model [
    base:desc "CAD geometry of the crane created with Autodesk Fusion‑360"
    DTDFVocab:inputTo Fusion360Enabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator, defined in Capella Arcadia"
    DTDFVocab:inputTo CapellaArcadiaEnabler
]

instance CranePhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model for the crane dynamics"
    DTDFVocab:inputTo PhysicsEngineEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database used for persisting crane telemetry"
    DTDFVocab:enables DatabaseService, LoggingApplicationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker mediating communication among services"
    DTDFVocab:enables MQTTBrokerService, ControlApplicationService, LoggingApplicationService, HMIService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService, DashboardService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker & Docker‑Compose platform for containerising six primary service containers"
    DTDFVocab:enables DatabaseService, DashboardService, MQTTBrokerService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

instance PythonGantrylibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module providing the Control, Logging and HMI applications"
    DTDFVocab:enables ControlApplicationService, LoggingApplicationService, HMIService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana platform for visualising crane data"
    DTDFVocab:enables DashboardService
]

instance Fusion360Enabler : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion‑360 tool providing access to the CAD model"
    DTDFVocab:enables DashboardService
]

instance CapellaArcadiaEnabler : DTDFVocab:Enabler [
    base:desc "Capella Arcadia modelling environment supplying the kinematic model"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance PhysicsEngineEnabler : DTDFVocab:Enabler [
    base:desc "Physics engine used by the simulation service for dynamic modelling"
    DTDFVocab:enables SimulationService
]

// C6: Services
instance DatabaseService : DTDFVocab:Service [
    base:desc "TimescaleDB container storing operational time‑series data"
    DTDFVocab:provides DataPersistenceInsight
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualising crane telemetry"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Mosquitto MQTT broker container handling publish/subscribe messaging"
    DTDFVocab:provides CommunicationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service generating optimal crane trajectories using the kinematic model"
    DTDFVocab:provides OptimisedTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation service evaluating crane dynamics"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service continuously validating executed trajectories against simulation"
    DTDFVocab:provides ValidationAlertInsight
]

instance LoggingApplicationService : DTDFVocab:Service [
    base:desc "Python logging application persisting full crane state to TimescaleDB"
    DTDFVocab:provides FaultDetectionInsight
]

instance ControlApplicationService : DTDFVocab:Service [
    base:desc "Control application reading controller states and issuing commands"
    DTDFVocab:provides ParameterUpdateAction
]

instance HMIService : DTDFVocab:Service [
    base:desc "Human‑Machine Interface for operator interaction with the crane"
    DTDFVocab:provides OperatorInteractionInsight
]

// C17: Insights
instance DataPersistenceInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful persistence of telemetry data in TimescaleDB"
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time visualisation of crane telemetry on Grafana"
]

instance CommunicationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating healthy MQTT message flow among services"
]

instance OptimisedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimised trajectory generated for the crane to follow"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert when executed trajectory deviates from simulated expectations"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detected fault patterns in time‑series data via classification"
]

instance OperatorInteractionInsight : DTDFVocab:Insight [
    base:desc "Insight reflecting operator actions captured via the HMI"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Result of physics‑based simulation providing predicted crane behavior"
]

// C17: Actions
instance ParameterUpdateAction : DTDFVocab:Action [
    base:desc "Action to update crane control parameters based on optimisation results"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory Generator and Control Application compute optimal motion commands and send set‑points to the Physical Crane Interface, which forwards them to the motor controllers; alerts from Continuous Validation Service are also sent to the operator via the Grafana dashboard."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A C4‑modelled architecture where the Physical Crane connects via a Python interface to a Control Application, Logging Application and HMI; the digital side consists of Dockerised Database, MQTT broker, Grafana dashboard, and three service containers (Trajectory Generator, Simulation, Continuous Validation) communicating over MQTT and sharing data through the database."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans design (CAD models in Autodesk Fusion‑360), manufacturing (physical crane built from the Bill‑of‑Materials), and operation (runtime sensor data, logging, validation and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, checks against a predefined threshold, and triggers operator alerts when the threshold is breached, providing runtime fidelity assessment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication over TCP/IP LAN using MQTT (Eclipse Mosquitto) for command and event signalling; sensor and state data are persisted via SQL queries to TimescaleDB; Python applications act as clients to both MQTT broker and database."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All Dockerised components (TimescaleDB, MQTT broker, Grafana) are launched with a single Docker‑Compose command on a personal computer; Python modules are installed via pip; the entire twin runs on the same host machine for simplicity."
]