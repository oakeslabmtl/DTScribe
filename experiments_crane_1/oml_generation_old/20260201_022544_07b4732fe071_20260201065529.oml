// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the crane payload"
    DTDFVocab:producedData DataTransmittedSwingAngle
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the crane"
    DTDFVocab:producedData DataTransmittedAnemometer
]

instance MotorControllerStatus : DTDFVocab:SensingComponent [
    base:desc "Status messages from the motor controller indicating actuator states"
    DTDFVocab:producedData DataTransmittedMotorStatus
]

// C4: Physical-to-virtual interaction (data transmission)
instance DataTransmittedSwingAngle : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance DataTransmittedAnemometer : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance DataTransmittedMotorStatus : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerStatus
]

// C10: Data objects
instance SensorDataSwingAngle : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurement"
    DTDFVocab:fromData DataTransmittedSwingAngle
    DTDFVocab:inputTo TimescaleDBEnabler, ValidationEngineEnabler
]

instance SensorDataAnemometer : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed measurement from the anemometer"
    DTDFVocab:fromData DataTransmittedAnemometer
    DTDFVocab:inputTo TimescaleDBEnabler, VisualizationEngineEnabler
]

instance SensorDataMotorStatus : DTDFVocab:Data [
    base:desc "Time‑stamped motor‑controller status information"
    DTDFVocab:fromData DataTransmittedMotorStatus
    DTDFVocab:inputTo TimescaleDBEnabler, MonitoringEngineEnabler
]

// C11: Enablers (tooling & processing)
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL‑based) storing high‑frequency temporal data"
    DTDFVocab:enables LoggingService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Engine that validates measured states against the kinematic model predictions"
    DTDFVocab:enables ValidationService
]

instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Engine that renders real‑time crane pose, payload location and performance metrics"
    DTDFVocab:enables VisualizationService
]

instance ControlEngineEnabler : DTDFVocab:Enabler [
    base:desc "Engine that computes optimal control trajectories using the kinematic model"
    DTDFVocab:enables OptimalControlService
]

instance MonitoringEngineEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker streaming operational data from the physical controller to the digital twin"
    DTDFVocab:enables MonitoringStreamingService
]

instance CADVisualizationEngine : DTDFVocab:Enabler [
    base:desc "Visualization engine consuming the CAD model for 3‑D rendering"
    DTDFVocab:enables VisualizationService
]

instance KinematicSimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine executing the kinematic model for prediction and validation"
    DTDFVocab:enables ValidationService, OptimalControlService
]

// C6: Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Historical data logging of sensor readings, command trajectories, and execution timestamps"
    DTDFVocab:provides StoreHistoricalDataAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Real‑time data visualization of crane pose, payload location and performance metrics"
    DTDFVocab:provides UpdateDashboardAction
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Continuous validation of physical motion against the simulated kinematic model"
    DTDFVocab:provides ValidationInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal control of bridge and hoist motions derived from the kinematic model"
    DTDFVocab:provides ExecuteControlAction
]

instance MonitoringStreamingService : DTDFVocab:Service [
    base:desc "Monitoring and streaming of operational data from the physical controller to the digital counterpart for feedback‑driven improvements"
    DTDFVocab:provides OperationalMonitoringInsight
]

// C17: Insights
instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Detects deviations between measured sensor data and kinematic model predictions"
]

instance OperationalMonitoringInsight : DTDFVocab:Insight [
    base:desc "Provides operators with live operational metrics to support feedback‑driven control adjustments"
]

// C17: Actions
instance StoreHistoricalDataAction : DTDFVocab:Action [
    base:desc "Persists time‑stamped sensor and actuator data into TimescaleDB"
    DTDFVocab:IsAutomatic true
]

instance UpdateDashboardAction : DTDFVocab:Action [
    base:desc "Refreshes the real‑time visualization dashboard with the latest crane state"
    DTDFVocab:IsAutomatic true
]

instance ExecuteControlAction : DTDFVocab:Action [
    base:desc "Sends optimal trajectory commands to the crane actuators via the controller"
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance GantryCraneCartActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator driving the horizontal cart movement of the gantry crane"
]

instance GantryCraneHoistActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator driving the hoist mechanism for lifting payloads"
]

instance CraneController : DTDFVocab:ActingComponent [
    base:desc "Dedicated controller that receives optimal‑control commands and drives the crane actuators"
]

// C10: Models
instance CADModel : DTDFVocab:Model [
    base:desc "Detailed 3‑D CAD model of the gantry crane generated by open‑source CAD software"
    DTDFVocab:inputTo CADVisualizationEngine
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model capturing cart and hoist motions derived from the CAD geometry"
    DTDFVocab:inputTo KinematicSimulationEngine, ControlEngineEnabler, ValidationEngineEnabler
]

// Additional tooling enablers (not part of the mandatory data flow)
instance CADSoftwareEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source CAD software used to create the 3‑D geometry"
]

instance KinematicLibEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source kinematic modeling library encoding the motion equations"
]

instance ProgrammingEnvEnabler : DTDFVocab:Enabler [
    base:desc "Python / MATLAB development environment for control and validation algorithms"
]

instance CommunicationProtocolEnabler : DTDFVocab:Enabler [
    base:desc "TCP/UDP protocols used for data exchange between physical controller and digital side"
]

instance ArchitectureModelEnabler : DTDFVocab:Enabler [
    base:desc "C4 modelling approach documenting the system architecture"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal movement trajectories using a kinematics model. These trajectories are supplied to the Control Application, which uses the Physical Crane Interface to send command messages to the crane controllers. Commands are issued as Python calls through the interface to the hardware. Feedback on execution is captured by the Logging Application, enabling the Continuous Validation Service to compare expected versus actual trajectories. The documents do not detail authentication, validation, or explicit command‑execution confirmations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The exemplars adopt an ad‑hoc orchestration model rather than a commercial digital‑twin framework; they employ containerization and virtualization (e.g., virtual‑machine images for GreenhouseDT) to host services such as an InfluxDB time‑series database, an ActiveMQ message broker and Microsoft Azure cloud tools, and the architecture is visualised with the C4 model for the gantry crane."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by continuous validation: the twin computes a distance metric (e.g., Euclidean error) between the predicted state from the kinematic model and the actual measurements from the swing angle encoder and anemometer. If the metric exceeds a predefined threshold, a validation alarm is raised and the offending data point is flagged for correction. Uncertainty sources such as sensor noise and discretization errors are accounted for by maintaining confidence intervals in the TimescaleDB logs. Validation logs are periodically reviewed to verify that model predictions remain within acceptable error bounds, supporting quality assurance and enabling recalibration of the kinematic model when necessary."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital‑twin containers communicate primarily through an MQTT broker that provides publish/subscribe signaling over TCP/IP. The Logging Application writes crane state data to the TimescaleDB database, while the Grafana Dashboard reads from the same database. The components are modeled as containers in a C4 diagram, implying they run on a shared local network with standard IP connectivity. No specific bandwidth, latency, redundancy, or security protocols are mentioned in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital‑twin components (TimescaleDB, MQTT broker, Grafana Dashboard, Trajectory Generator, Simulation, and Continuous Validation services) are packaged as software containers according to the C4 model and executed on a single on‑premise host (a personal computer). The Python applications (Physical Crane Interface, Control Application, Logging Application, HMI) run alongside these containers on the same machine, providing an integrated on‑edge deployment without reliance on cloud infrastructure."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration relies on standard components: GreenhouseDT exchanges data through an ActiveMQ message broker and stores measurements in an InfluxDB database; the Air Quality Management exemplar connects a Raspberry‑Pi sensor node to an AutomationML‑based digital twin and uses Microsoft Azure tools for the twin pipeline; all exemplars use single‑board computers and container/VM technologies to interface with external sensors and cloud services."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplars adopt a largely ad‑hoc integration approach, avoiding commercial digital‑twin frameworks. However, the Air Quality Management twin follows the AutomationML standard for its model representation, enabling exchange of engineering data. Apart from AutomationML, no specific industry standards, certification requirements, or interoperability frameworks are referenced; the implementations rely on open‑source components such as InfluxDB, ActiveMQ, Docker, and Azure services without formal compliance claims."
]