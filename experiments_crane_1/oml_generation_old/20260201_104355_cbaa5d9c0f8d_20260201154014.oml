// C3: Physical Sensing Components
instance GantryBridgePositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder sensor measuring the position of the gantry bridge along its rail, providing high-resolution angular displacement data for kinematic validation."
    DTDFVocab:producedData GantryBridgePositionData
]

instance TrolleyPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder sensor measuring the position of the trolley along the gantry bridge, enabling precise tracking of horizontal movement for trajectory optimization."
    DTDFVocab:producedData TrolleyPositionData
]

instance HoistLoadCell : DTDFVocab:SensingComponent [
    base:desc "Load cell sensor measuring the payload weight suspended by the hoist mechanism, used for dynamic load validation and stability analysis."
    DTDFVocab:producedData HoistLoadData
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor monitoring motor draw for each actuator (bridge, trolley, hoist), enabling energy efficiency analysis and fault detection."
    DTDFVocab:producedData MotorCurrentData
]

instance EnvironmentalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor monitoring ambient conditions affecting crane operation, used for environmental compensation in control algorithms."
    DTDFVocab:producedData EnvironmentalTemperatureData
]

instance CraneOrientationIMU : DTDFVocab:SensingComponent [
    base:desc "Inertial Measurement Unit providing orientation data (roll, pitch, yaw) for the gantry and trolley, critical for residual motion analysis."
    DTDFVocab:producedData CraneOrientationData
]

// C4: Physical-to-Virtual Interaction
instance GantryBridgePositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GantryBridgePositionEncoder
    base:desc "High-frequency position data transmitted via serial/TCP/IP protocol at millisecond-level intervals for real-time trajectory validation."
]

instance TrolleyPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TrolleyPositionEncoder
    base:desc "High-frequency position data transmitted via serial/TCP/IP protocol at millisecond-level intervals for real-time trajectory validation."
]

instance HoistLoadData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistLoadCell
    base:desc "Load measurement data transmitted at 100Hz for dynamic stability analysis and payload validation."
]

instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
    base:desc "Motor current telemetry transmitted at 1kHz for fault detection and energy consumption monitoring."
]

instance EnvironmentalTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalTemperatureSensor
    base:desc "Environmental data transmitted at 1Hz for control algorithm compensation."
]

instance CraneOrientationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneOrientationIMU
    base:desc "Orientation data transmitted at 100Hz for residual motion analysis and stability validation."
]

instance ControllerTelemetryData : DTDFVocab:DataTransmitted [
    base:desc "Aggregated controller data including encoder readings, actuator commands, and sensor feedback transmitted via MQTT broker for synchronization."
    DTDFVocab:producedFrom GantryBridgePositionEncoder, TrolleyPositionEncoder, MotorCurrentSensor, CraneOrientationIMU
]

// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Mathematical formulation of the gantry crane's joint trajectories, payload constraints, and inverse kinematics derived using SymPy for motion planning and validation."
    DTDFVocab:inputTo KinematicSimulationEnabler
]

instance DynamicLoadModel : DTDFVocab:Model [
    base:desc "Dynamic model simulating payload effects on crane stability, incorporating load cell data and environmental factors for trajectory optimization."
    DTDFVocab:inputTo ControlOptimizationEnabler
]

instance TrajectoryExecutionMetrics : DTDFVocab:Data [
    base:desc "Real-time metrics including actual path deviations, residual swinging motion, and timing data used for continuous validation against simulated trajectories."
    DTDFVocab:fromData GantryBridgePositionData, TrolleyPositionData, CraneOrientationData
    DTDFVocab:inputTo ValidationEnabler
]

instance HistoricalSensorData : DTDFVocab:Data [
    base:desc "Time-series sensor data stored in TimescaleDB for post-mortem analysis, trend detection, and benchmarking against digital twin predictions."
    DTDFVocab:fromData GantryBridgePositionData, TrolleyPositionData, HoistLoadData, MotorCurrentData, EnvironmentalTemperatureData
    DTDFVocab:inputTo DataLoggingEnabler
]

instance ControllerTelemetryDataProcessed : DTDFVocab:Data [
    base:desc "Processed controller telemetry including filtered sensor readings and validated actuator commands for real-time control adjustments."
    DTDFVocab:fromData ControllerTelemetryData
    DTDFVocab:inputTo ControlOptimizationEnabler
]

// C11: Enablers
instance KinematicSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python-based kinematic simulation engine using SciPy for forward/inverse kinematics calculations and trajectory generation."
    DTDFVocab:enables KinematicModelingService, TrajectoryValidationService
]

instance ControlOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimization framework using Pyomo for trajectory optimization and CasADi for real-time control policy generation."
    DTDFVocab:enables OptimalControlService, ClosedLoopControlService
]

instance DataLoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB-based logging system optimized for high-frequency time-series data storage with automatic retention policies."
    DTDFVocab:enables HistoricalDataLoggingService, DataVisualizationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation service implementing Euclidean distance metrics and dynamic time warping for trajectory comparison."
    DTDFVocab:enables ContinuousValidationService, FaultDetectionService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating asynchronous messaging between Physical Crane Interface, Logging Application, and Simulation Service."
    DTDFVocab:enables DataSynchronizationService
]

instance PhysicalCraneInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Python program interfacing with crane actuators/sensors, implementing noise filtering and data validation before transmission."
    DTDFVocab:enables DataAcquisitionService, PreprocessingService
]

// C6: Services
instance KinematicModelingService : DTDFVocab:Service [
    base:desc "Service providing high-fidelity 3D representations and kinematic simulations of the gantry crane for visualization and motion planning."
    DTDFVocab:provides CraneGeometryInsight, MotionTrajectoryInsight
]

instance TrajectoryValidationService : DTDFVocab:Service [
    base:desc "Service comparing executed trajectories with simulated trajectories using distance metrics to assess deviations."
    DTDFVocab:provides TrajectoryAccuracyInsight, ResidualMotionInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service computing energy-efficient or time-optimal paths for the crane's end-effector with jerk minimization."
    DTDFVocab:provides EnergyEfficientPathAction, TimeOptimalPathAction
]

instance ClosedLoopControlService : DTDFVocab:Service [
    base:desc "Service integrating digital twin predictions with physical controller to adjust actuator commands in real-time."
    DTDFVocab:provides AdaptiveControlAction, PIDTuningAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service logging sensor data, actuator commands, and environmental conditions for long-term monitoring and analytics."
    DTDFVocab:provides DataRetentionInsight, TrendDetectionInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service providing real-time dashboards with 3D animations, telemetry plots, and anomaly highlighting."
    DTDFVocab:provides RealTimeDashboardInsight, AnomalyHighlightingInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service ensuring synchronization between physical and digital twins through state comparison and residual analysis."
    DTDFVocab:provides SynchronizationStatusInsight, ValidationAccuracyInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service identifying discrepancies such as sensor drift or actuator failures using Kalman filtering and machine learning."
    DTDFVocab:provides FaultDetectionInsight, CorrectiveActionRecommendation
]

instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Service handling high-frequency data acquisition from crane sensors and actuators with noise filtering."
    DTDFVocab:provides SensorDataInsight, DataQualityInsight
]

instance DataSynchronizationService : DTDFVocab:Service [
    base:desc "Service managing asynchronous data exchange between physical and virtual components via MQTT broker."
    DTDFVocab:provides DataConsistencyInsight, SynchronizationLatencyInsight
]

instance PreprocessingService : DTDFVocab:Service [
    base:desc "Service validating and filtering sensor readings before transmission to ensure data quality."
    DTDFVocab:provides DataValidationInsight, NoiseReductionInsight
]

// C17: Insights/Actions
instance CraneGeometryInsight : DTDFVocab:Insight [
    base:desc "Virtual representation of the gantry crane's geometry including movable bridge, trolley, and hoist mechanism for visualization."
]

instance MotionTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Mathematical formulation of joint trajectories and payload constraints for motion planning and validation."
]

instance TrajectoryAccuracyInsight : DTDFVocab:Insight [
    base:desc "Comparison metrics between executed and simulated trajectories using Euclidean distance or dynamic time warping."
]

instance ResidualMotionInsight : DTDFVocab:Insight [
    base:desc "Analysis of residual swinging motion and path deviations during crane operation."
]

