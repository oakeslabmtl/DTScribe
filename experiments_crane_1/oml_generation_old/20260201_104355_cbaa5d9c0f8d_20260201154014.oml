]

instance SensorDataInsight : DTDFVocab:Insight [
    base:desc "High-frequency sensor data from crane actuators and environmental conditions."
]

instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Assessment of data quality including noise levels and validation status."
]

instance DataConsistencyInsight : DTDFVocab:Insight [
    base:desc "Verification of data consistency between physical and virtual components."
]

instance SynchronizationLatencyInsight : DTDFVocab:Insight [
    base:desc "Measurement of latency in data synchronization between physical and digital twin."
]

instance DataValidationInsight : DTDFVocab:Insight [
