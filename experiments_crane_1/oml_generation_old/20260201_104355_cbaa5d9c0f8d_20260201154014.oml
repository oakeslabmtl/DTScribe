    base:desc "Computation of time-optimal paths with jerk minimization for crane operations."
    DTDFVocab:IsAutomatic true
]

instance AdaptiveControlAction : DTDFVocab:Action [
    base:desc "Real-time adjustment of actuator commands based on digital twin predictions."
    DTDFVocab:IsAutomatic true
]

instance PIDTuningAction : DTDFVocab:Action [
    base:desc "Dynamic tuning of PID controllers based on digital twin validation results."
    DTDFVocab:IsAutomatic true
]

