    base:desc "Long-term storage of sensor data and actuator commands for post-mortem analysis."
]

instance TrendDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of operational trends and performance benchmarks against digital twin predictions."
]

instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Graphical display of crane state including 3D animations and telemetry plots."
]

instance AnomalyHighlightingInsight : DTDFVocab:Insight [
    base:desc "Visual indicators for deviations between physical and digital twin states."
]

instance SynchronizationStatusInsight : DTDFVocab:Insight [
    base:desc "Real-time assessment of synchronization between physical and digital twin states."
]

instance ValidationAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantitative metrics of validation accuracy between physical and digital twin operations."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of sensor drift, actuator failures, or other operational anomalies."
]

instance CorrectiveActionRecommendation : DTDFVocab:Action [
    base:desc "Recommendations for corrective actions based on detected faults or deviations."
