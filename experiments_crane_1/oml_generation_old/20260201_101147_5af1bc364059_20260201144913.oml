// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder measuring hoist pendulum motion"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-Virtual Interaction – Data Transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Models/Data – Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Swing angle data from crane"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Wind speed data from crane"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB for time-series storage"
    DTDFVocab:enables RealTimeDataLoggingService
]

instance PythonGantrylibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module for crane dynamics"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine for crane dynamics"
    DTDFVocab:enables SimulationExecutionService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation engine comparing measurements to simulation"
    DTDFVocab:enables ValidationAnalysisService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana for visualization of metrics"
    DTDFVocab:enables DashboardVisualizationService
]

instance ControlInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Control interface for operator commands"
    DTDFVocab:enables ControlCommandService
]

// C6: Services
instance RealTimeDataLoggingService : DTDFVocab:Service [
    base:desc "Logs real-time sensor data into TimescaleDB"
    DTDFVocab:provides DataLoggingInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal trajectories ensuring zero residual swing"
    DTDFVocab:provides TrajectoryOptimizationInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Simulates crane dynamics and provides confidence bounds"
    DTDFVocab:provides SimulationConfidenceBoundsInsight
]

instance ValidationAnalysisService : DTDFVocab:Service [
    base:desc "Compares measured vs simulated trajectories and alerts on threshold breaches"
    DTDFVocab:provides ValidationAlertInsight
    DTDFVocab:provides FaultDetectionInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Visualizes metrics in Grafana dashboards"
    DTDFVocab:provides DashboardVisualizationInsight
]

instance ControlCommandService : DTDFVocab:Service [
    base:desc "Processes operator commands and controls actuators"
    DTDFVocab:provides OperatorCommandAction
    DTDFVocab:provides ElectromagnetActivationAction
]

// C17: Insights
instance ExcessSwingInsight : DTDFVocab:Insight [
    base:desc "Detection of excess swinging or waveform deviations in crane motion"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of potential faults through time-series classification"
]

instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory suggestions without commanding the crane"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alerts when measured vs simulated trajectories deviate beyond thresholds"
]

instance SimulationConfidenceBoundsInsight : DTDFVocab:Insight [
    base:desc "Simulation output providing confidence bounds for crane dynamics"
]

instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Real-time sensor data stored in TimescaleDB"
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Metrics visualized via Grafana dashboards"
]

// C17: Actions
instance MaintenanceAction : DTDFVocab:Action [
    base:desc "Maintenance performed based on insights"
    DTDFVocab:IsAutomatic false
]

instance ElectromagnetActivationAction : DTDFVocab:Action [
    base:desc "Activates or deactivates the electromagnet on the hoist to pick up containers"
    DTDFVocab:IsAutomatic false
]

instance OperatorCommandAction : DTDFVocab:Action [
    base:desc "Operator command to move crane or control actuators"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance CartStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor powered by Trinamic TMC4671 Eval motor driver"
]

instance HoistStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor powered by Trinamic TMC4671 Eval motor driver"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet on the hoist to pick up containers"
]

// C4: Physical Components
instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Interface polls Arduino for sensor data and commands actuators"
]

instance ControlApplication : DTDFVocab:Component [
    base:desc "Control application handling operator commands and trajectory generation"
]

instance LoggingApplication : DTDFVocab:Component [
    base:desc "Logging application streams sensor data to TimescaleDB via MQTT"
]

instance DashboardComponent : DTDFVocab:Component [
    base:desc "Grafana dashboard component visualizing metrics"
]

instance TimescaleDBComponent : DTDFVocab:Component [
    base:desc "TimescaleDB database storing time-series sensor logs"
]

instance MqttBrokerComponent : DTDFVocab:Component [
    base:desc "Eclipse Mosquitto MQTT broker for inter-service signaling"
]

instance TrajectoryGeneratorComponent : DTDFVocab:Component [
    base:desc "Trajectory generator service component"
]

instance SimulationComponent : DTDFVocab:Component [
    base:desc "Simulation service component"
]

instance ContinuousValidationComponent : DTDFVocab:Component [
    base:desc "Continuous validation service component"
]

// C4: Environment
instance LabScaleGantryEnvironment : DTDFVocab:Environment [
    base:contains PhysicalCraneInterface, ControlApplication, LoggingApplication, DashboardComponent, TimescaleDBComponent, MqttBrokerComponent, TrajectoryGeneratorComponent, SimulationComponent, ContinuousValidationComponent, CartStepperMotorActuator, HoistStepperMotorActuator, ElectromagnetActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application receives trajectory commands generated by the Trajectory Generator Service and forwards motor setpoints to the Physical Crane Interface, which then issues corresponding control signals to the stepper motors and electromagnet through the Arduino.
"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All twin services operate continuously; logging and validation run in real time with every control loop iteration (data sampled at the same rate as the crane’s motor controller, typically sub‑second). Trajectory generation is triggered on-demand but its output is consumed immediately by the control loop. The system’s architecture therefore supports continuous, near‑real‑time synchronization between physical and virtual worlds."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated web of services: Physical Crane Interface bridging hardware and services; Data Logging; Trajectory Generation; Simulation; Continuous Validation; Dashboard; MQTT broker; TimescaleDB; all coordinated through Docker compose and the gantrylib Python library."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design – CAD models in Fusion360 and a kinematic model; Manufacturing – assembly guided by the BOM; Operation – runtime data logging, continuous validation, and control. The twin’s software evolves through iterative research releases and teaching extensions.
"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous validation compares measured sensor data against simulated trajectories, computing a distance metric and checking against a predefined threshold; threshold breaches trigger operator alerts; simulation model substantiated by manufacturing kinematic data; no formal formal model‑checking reported."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical control uses serial/USB communication between the Python Physical Crane Interface and the Arduino board. Service coordination occurs over MQTT topics; data persistence accesses TimescaleDB via SQL queries. All communications stay within the local machine’s network.
"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin services are containerised with Docker and orchestrated by docker‑compose on a single personal computer; TimescaleDB, MQTT broker, Grafana each run in separate containers; gantrylib installed via pip; no cloud deployment."
]