// ------------------------------------------------------
// C2: Acting Components
// ------------------------------------------------------
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart axis, controlled via TMC4671‑Eval"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist axis, controlled via TMC4671‑Eval"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist used to pick up loads, driven via TMC4671‑Eval"
]

// ------------------------------------------------------
// C3: Physical Sensing Components
// ------------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring crane swing angle at the hoist"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorControllerFeedback : DTDFVocab:SensingComponent [
    base:desc "Feedback from TMC4671‑Eval motor controllers providing motor position and speed"
    DTDFVocab:producedData MotorStateDataTransmitted
]

// ------------------------------------------------------
// C4: Data Transmission (DataTransmitted)
// ------------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerFeedback
]

// ------------------------------------------------------
// C5: Data (Measured Time‑Series)
// ------------------------------------------------------
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurements streamed from the swing‑angle encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed measurements from the anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance MotorStateData : DTDFVocab:Data [
    base:desc "Time‑stamped motor position and speed data from the motor controllers"
    DTDFVocab:fromData MotorStateDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

// ------------------------------------------------------
// C10: Models
// ------------------------------------------------------
instance CADAssemblyModel : DTDFVocab:Model [
    base:desc "3‑D CAD assembly of the gantry crane created in Autodesk Fusion 360"
    DTDFVocab:inputTo VisualizationService
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator to compute swing‑free paths"
    DTDFVocab:inputTo TrajectoryGeneratorService
]

instance DynamicCraneModel : DTDFVocab:Model [
    base:desc "Dynamic model of crane and controllers used by the Simulation Service"
    DTDFVocab:inputTo SimulationService
]

// ------------------------------------------------------
// C11: Enablers (Tools & Infrastructure)
// ------------------------------------------------------
instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB PostgreSQL extension used for time‑series data logging"
    DTDFVocab:enables DataLoggingService, ContinuousValidationService, SimulationService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana instance visualizing time‑series data from TimescaleDB"
    DTDFVocab:enables VisualizationService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service messaging"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, FaultDetectionService
]

// ------------------------------------------------------
// C6: Services
// ------------------------------------------------------
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that receives sensor data from the Physical Crane Interface and writes records into TimescaleDB"
    DTDFVocab:provides DataLoggingAction
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes optimal swing‑free trajectories using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares measured trajectories with simulated ones and raises alerts when validation metrics exceed thresholds"
    DTDFVocab:provides ValidationAlertInsight, ReTuneControlParametersAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults from time‑series classification of sensor data"
    DTDFVocab:provides FaultDetectionInsight, OperatorInterventionAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Emulates crane dynamics using the dynamic model"
    DTDFVocab:provides SimulationResultInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualizing logged sensor data and computed trajectories"
    DTDFVocab:provides VisualizationInsight
]

// ------------------------------------------------------
// C17: Insights
// ------------------------------------------------------
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight offering optimal swing‑free trajectory recommendations for the crane"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert triggered when validation metrics exceed preset thresholds"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Signal indicating a detected fault that requires operator attention"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulated trajectory data used for validation and planning"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of crane sensor data and computed trajectories"
]

// ------------------------------------------------------
// C17: Actions
// ------------------------------------------------------
instance DataLoggingAction : DTDFVocab:Action [
    base:desc "Automatic ingestion of sensor data into TimescaleDB"
    DTDFVocab:IsAutomatic true
]

instance ReTuneControlParametersAction : DTDFVocab:Action [
    base:desc "Automatic re‑tuning of control parameters based on validation feedback"
    DTDFVocab:IsAutomatic true
]

instance OperatorInterventionAction : DTDFVocab:Action [
    base:desc "Guides operator to intervene or adjust control settings"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application and the Trajectory Generator Service send motion set‑points and electromagnet activation commands to the Physical Crane Interface, which transmits them to the motor controllers to drive the cart, hoist and electromagnet; operator commands from the Human Machine Interface follow the same path."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A hybrid architecture where the physical crane is connected to a PC running four Python applications (Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface); these interact with six Docker‑container services (Database, Dashboard, MQTT broker, Trajectory Generator, Simulation, Continuous Validation) via MQTT and SQL, forming the complete digital twin constellation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the design stage (CAD models of the crane), the manufacturing/assembly stage (hardware components listed), and the operation stage where runtime data are logged, simulated and validated."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously computes distance metrics between executed trajectories (from sensor data) and simulated trajectories, compares them against a predefined threshold, and notifies operators via the Grafana dashboard; simulation confidence bounds are visualised alongside measured data to assess model fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication uses MQTT (Eclipse Mosquitto) for event signalling; data persistence uses SQL over TimescaleDB; the Physical Crane Interface communicates with motor controllers likely via serial/USB (Python library); all Docker containers share a virtual network defined by Docker Compose."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software runs on a single personal computer; Docker containers (Database, MQTT broker, Dashboard) are launched with a Docker‑compose file; the Python modules are installed via pip; the source code, Docker files, CAD models and documentation are hosted publicly on a GitHub repository (Cosys‑Lab)."
]