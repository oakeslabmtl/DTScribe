// C3: Physical sensing components
instance MotorPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reading the motor positions of the gantry crane"
    DTDFVocab:producedData MotorPositionDataTx
]

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the crane load"
    DTDFVocab:producedData SwingAngleDataTx
]

instance AnemometerWindSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the crane"
    DTDFVocab:producedData WindSpeedDataTx
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorPositionDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionSensor
]

instance SwingAngleDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerWindSpeedSensor
]

// C10: Data
instance MotorPositionData : DTDFVocab:Data [
    base:desc "Time‑series of motor position measurements"
    DTDFVocab:fromData MotorPositionDataTx
    DTDFVocab:inputTo LoggingApplication, ControlEngine
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle encoder readings"
    DTDFVocab:fromData SwingAngleDataTx
    DTDFVocab:inputTo LoggingApplication, ControlEngine
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements from the anemometer"
    DTDFVocab:fromData WindSpeedDataTx
    DTDFVocab:inputTo LoggingApplication, ControlEngine
]

// C10: Models/Data
instance GeometricCADModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the gantry crane structure"
    DTDFVocab:inputTo ValidationEngine
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model representing joint motions and payload dynamics, consumes sensor data to update its state"
    DTDFVocab:inputTo ControlEngine, ValidationEngine
]

// C11: Enablers
instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Python logging service that reads sensor data via the Physical Crane Interface and writes time‑series into TimescaleDB"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database storing historical crane data"
    // (No direct service enablement required for the current flow)
]

instance ControlEngine : DTDFVocab:Enabler [
    base:desc "Engine that uses the kinematic model to compute optimal motion commands for the crane"
    DTDFVocab:enables OptimalControlService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Engine that renders crane state, motion trajectories and logged data for users"
    DTDFVocab:enables DataVisualizationService
]

instance ValidationEngine : DTDFVocab:Enabler [
    base:desc "Component that compares real‑time behavior with CAD and kinematic models to detect deviations"
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Records sensor and actuator data over time for analysis"
    DTDFVocab:provides HistoricalDataLoggingInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes and sends efficient motion commands to the crane controller using the kinematic model"
    DTDFVocab:provides OptimalControlAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Renders crane state, motion trajectories and logged data for users"
    DTDFVocab:provides DataVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares physical behavior with models to detect deviations and support model improvement"
    DTDFVocab:provides ContinuousValidationInsight
]

// C17: Insights / Actions
instance HistoricalDataLoggingInsight : DTDFVocab:Insight [
    base:desc "Provides archived time‑series data for downstream analytics"
]

instance OptimalControlAction : DTDFVocab:Action [
    base:desc "Automatically issues motion commands to the crane controller"
    DTDFVocab:IsAutomatic true
]

instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of crane state and trajectories"
]

instance ContinuousValidationInsight : DTDFVocab:Insight [
    base:desc "Identifies deviations between observed behavior and model predictions"
]

// C5: System Under Study (optional component representation)
instance GantryCraneSystem : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane consisting of a mechanical gantry, motorized winch, and electronic controller for moving small pucks"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, implemented in Python, sends command messages (e.g., motion set‑points for the cart and hoist, electromagnet activation) to the Physical Crane Interface, which then communicates with the crane’s motor controllers and Arduino I/O through the hardware controllers. Commands are issued as native controller instructions over the same local TCP/serial links used by the interface; the system does not describe additional authentication or confirmation mechanisms beyond the Python interface implementation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The gantry‑crane digital twin follows a modular, service‑oriented architecture expressed with the C4 model. The physical crane is accessed via a Python 'Physical Crane Interface' that connects to the crane controllers. Core twin services—Trajectory Generator, Simulation, and Continuous Validation—are realised as separate containers that communicate asynchronously through an MQTT broker, providing loose coupling and scalable message exchange. All runtime data are persisted in a TimescaleDB instance, which is visualised by a Grafana dashboard. Additional Python applications (Control Application, Logging Application, Human‑Machine Interface) read from and write to the same database and publish/subscribe to the MQTT broker. The whole stack runs on virtual machines and is reproducible from the publicly available GitHub repository, constituting an ad‑hoc orchestration rather than a commercial DT framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin supports continuous validation where the kinematic model’s predictions are regularly compared with logged sensor data to detect deviations. Validation methods from prior research (continuous validation, fault detection) are applied to ensure model fidelity, and any identified errors trigger corrective actions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin relies on an MQTT broker (Eclipse Mosquitto) for signalling between the Trajectory Generator, Simulation, Continuous Validation services, and other components. All containers (TimescaleDB, Grafana, MQTT broker) are launched together via Docker Compose on a single host, using the host’s TCP/IP stack. No explicit bandwidth, latency, redundancy or security protocol details (e.g., TLS) are provided in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire twin stack is deployed on a personal computer (edge/on‑premise). The Python containers are packaged in the pip‑installable module gantrylib, while the Database (TimescaleDB), MQTT broker (Eclipse Mosquitto) and Dashboard (Grafana) are containerised with Docker. Deployment is managed with a Docker‑Compose file that automates container startup, database initialisation, and dashboard configuration, enabling reproducible installation on a single machine."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external components is achieved through standard, open‑source protocols: the twin talks to the physical crane via a Python API, intra‑twin services exchange messages via MQTT, and persistent data are stored in TimescaleDB (a PostgreSQL‑compatible time‑series database) accessed through SQL queries. Visualization is provided by Grafana over HTTP(S). Although the exemplar does not describe direct connections to enterprise systems, the exposed MQTT topics and the SQL interface of TimescaleDB enable straightforward integration with other data platforms or enterprise middleware if required."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management digital twin is built on an AutomationML‑based model, indicating compliance with the AutomationML standard for digital twin representation. No other industry standards or certification requirements are mentioned."
]