// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing-angle encoder measuring the swinging motion of the hoist on the lab‑scale gantry crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed for the gantry crane environment"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reading motor states (cart stepper and hoist stepper) from the Arduino"
    DTDFVocab:producedData MotorStateDataTransmitted
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStateSensor
]

// C10: Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series log of swing‑angle measurements stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ValidationEnabler, SimulationEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series log of wind speed measurements stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ValidationEnabler, SimulationEnabler
]

instance MotorStateData : DTDFVocab:Data [
    base:desc "Time‑series log of motor state feedback (cart and hoist) stored in TimescaleDB"
    DTDFVocab:fromData MotorStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ValidationEnabler, SimulationEnabler
]

instance GeneratedTrajectoryData : DTDFVocab:Data [
    base:desc "Optimal trajectory data produced by TrajectoryGenerationService"
    DTDFVocab:inputTo GrafanaEnabler, ValidationEnabler
]

instance ValidationMetricData : DTDFVocab:Data [
    base:desc "Distance metric comparing measured and simulated trajectories, used for alerts"
    DTDFVocab:inputTo GrafanaEnabler, FaultLocalisationEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database containerised with Docker for persisting sensor logs and generated data"
    DTDFVocab:enables DataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker container that transports data from the Arduino to the database and services"
    DTDFVocab:enables DataLoggingService, ContinuousValidationService, SimulationService, TrajectoryGenerationService, FaultLocalisationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard container visualising data from TimescaleDB"
    DTDFVocab:enables VisualizationService
]

instance DataLoggingEnabler : DTDFVocab:Enabler [
    base:desc "Logging application publishing MQTT messages and storing them in TimescaleDB"
    DTDFVocab:enables DataLoggingService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python service using the kinematic model to compute optimal crane trajectories"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python simulation service employing the dynamic crane model to emulate crane dynamics"
    DTDFVocab:enables SimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation service that compares measured and simulated trajectories and raises alerts"
    DTDFVocab:enables ContinuousValidationService
]

instance FaultLocalisationEnabler : DTDFVocab:Enabler [
    base:desc "Fault localisation service performing time‑series classification to pinpoint faults"
    DTDFVocab:enables FaultLocalisationService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuous data logging service that ingests MQTT messages and stores them in TimescaleDB"
    DTDFVocab:provides DataLoggingInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization service delivering Grafana dashboards to operators"
    DTDFVocab:provides RealTimeVisualizationInsight, AdjustLoggerConfigurationAction
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Trajectory generation service that computes optimal crane paths using the kinematic model"
    DTDFVocab:provides GenerateOptimalTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service that emulates crane dynamics based on the dynamic model"
    DTDFVocab:provides SimulatedDynamicsInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service that compares measured trajectories with simulated ones and raises alerts"
    DTDFVocab:provides ValidationAlertInsight
]

instance FaultLocalisationService : DTDFVocab:Service [
    base:desc "Fault localisation service that classifies time‑series sensor data to identify faults"
    DTDFVocab:provides FaultLocalizationAction
]

// C17: Insights / Actions
instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Insight that the system is continuously logging sensor measurements"
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight that operators can see live crane status on Grafana dashboards"
]

instance AdjustLoggerConfigurationAction : DTDFVocab:Action [
    base:desc "Operator adjusts logger configuration via Human‑Machine Interface"
    DTDFVocab:IsAutomatic false
]

instance GenerateOptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Service generates an optimal trajectory to reduce crane swing"
    DTDFVocab:IsAutomatic true
]

instance SimulatedDynamicsInsight : DTDFVocab:Insight [
    base:desc "Insight providing simulated crane dynamics for comparison with real data"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert raised when validation distance metric exceeds predefined threshold"
]

instance FaultLocalizationAction : DTDFVocab:Action [
    base:desc "Automatic fault localisation based on time‑series classification"
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "3‑D CAD geometry of the lab‑scale gantry crane"
    DTDFVocab:inputTo GrafanaEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used for trajectory generation"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of crane and its controllers"
    DTDFVocab:inputTo SimulationEnabler
]

// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor with TMC4671‑Eval motor controller driving the crane carriage"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor with TMC4671‑Eval controller moving the load vertically"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist used to pick up and release pucks"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal motion trajectories and sends them through the MQTT broker to the Control Application, which uses the Physical Crane Interface to issue velocity/position commands to the cart and hoist motor controllers; the Dashboard can also send control commands (e.g., homing, zeroing) to the crane via the same path."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall constellation consists of the physical crane and its controller, a Python‑based Physical Crane Interface, a Control Application, a Logging Application, an MQTT broker, a TimescaleDB database, a Grafana dashboard, and the three DT services (Trajectory Generator, Simulation, Continuous Validation) forming a tightly coupled cyber‑physical system deployed on a single PC."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the design stage (CAD models of the crane in Autodesk Fusion360 and the kinematic model) and the operation stage (real‑time sensor data, execution of trajectories, and validation); the manufacturing stage is represented indirectly by the Bill‑of‑Materials but not modelled as a separate twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by the Continuous Validation Service, which continuously compares measured trajectories with simulated ones, computes distance metrics, and checks them against predefined thresholds; violations trigger operator alerts on the dashboard, enabling corrective action."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses MQTT (Eclipse Mosquitto) for event and command messages, and SQL/REST interfaces to TimescaleDB for data retrieval; all components run on the same host machine and connect via a Docker‑provided virtual network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The database, MQTT broker and Grafana dashboard are Docker containers managed by Docker‑Compose; the remaining Python services and applications run directly on the host PC after installing the gantrylib package via pip; the entire setup can be started with a single Docker‑Compose command."
]