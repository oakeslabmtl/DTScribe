// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cartesian stepper motor of the gantry crane used for horizontal movement"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor of the gantry crane used for vertical lifting"
]

instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval controller driving the cart stepper motor"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval controller driving the hoist stepper motor"
]

instance EndEffectorElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist for picking up containers"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// C10: Models/Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance CraneCADModel : DTDFVocab:Model [
    base:desc "3‑D CAD model of the gantry crane created in Autodesk Fusion360"
    DTDFVocab:inputTo GrafanaEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used to compute swing‑free trajectories"
    DTDFVocab:inputTo PythonGantryLibEnabler, SimulationEngineEnabler
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of the crane and its motor controllers"
    DTDFVocab:inputTo SimulationEngineEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) for time‑series storage"
    DTDFVocab:enables DataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for publish/subscribe messaging"
    DTDFVocab:enables ContinuousValidationService, SimulationService, TrajectoryGeneratorService
]

instance PythonGantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module (installed via pip) and runtime environment"
    DTDFVocab:enables TrajectoryGeneratorService, DataLoggingService, ContinuousValidationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana platform for visualizing operational data"
    DTDFVocab:enables GrafanaDashboardService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑containerised simulation engine executing the crane simulation model"
    DTDFVocab:enables SimulationService, TrajectoryGeneratorService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that logs sensor streams into TimescaleDB"
    DTDFVocab:provides OperationalDataStoredInsight, StoreDataAction
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualising logged time‑series data"
    DTDFVocab:provides VisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free trajectories using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight, GenerateOptimalTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs runtime simulation of crane dynamics and controller behavior"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories with simulated ones, raises alerts, and classifies faults"
    DTDFVocab:provides ValidationAlertInsight, RaiseValidationAlertAction, FaultClassificationInsight, SuggestMaintenanceAction
]

// C17: Insights
instance OperationalDataStoredInsight : DTDFVocab:Insight [
    base:desc "Operational data successfully stored for later analysis"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of crane performance metrics"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal swing‑free trajectory computed for the current task"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation output indicating expected crane motion and controller response"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Detected deviation between executed and simulated trajectories exceeding thresholds"
]

instance FaultClassificationInsight : DTDFVocab:Insight [
    base:desc "Fault classification result identifying probable cause of abnormal behaviour"
]

// C17: Actions
instance StoreDataAction : DTDFVocab:Action [
    base:desc "Automatically write incoming sensor data to TimescaleDB"
    DTDFVocab:IsAutomatic true
]

instance GenerateOptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatically generate and transmit the optimal trajectory to the motion controller"
    DTDFVocab:IsAutomatic true
]

instance RaiseValidationAlertAction : DTDFVocab:Action [
    base:desc "Issue an alert to the operator when validation detects a breach"
    DTDFVocab:IsAutomatic true
]

instance SuggestMaintenanceAction : DTDFVocab:Action [
    base:desc "Recommend maintenance actions based on fault classification"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends motion commands via the Physical Crane Interface to the motor controllers, and the Human Machine Interface (Python front‑end) allows an operator to issue commands that are transmitted through the same interface to the physical crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A personal computer hosts all software components; Docker containers provide the database, MQTT broker and dashboard, while Python modules implement the crane interface, control, logging, trajectory generation, simulation and continuous validation. The physical crane connects via USB/serial to the PC where the Python interface communicates with the Arduino and motor controllers."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, checks them against predefined thresholds, and generates operator alerts when thresholds are exceeded, ensuring the digital twin remains a faithful representation of the physical crane."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses a Python‑based Physical Crane Interface over USB/serial to the Arduino and motor controllers; MQTT (Eclipse Mosquitto) is used for event‑driven messaging between services; TimescaleDB is accessed via standard PostgreSQL SQL queries; all Docker containers share a virtual network defined by Docker‑Compose."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT services run on a single personal computer; Docker containers for the database, MQTT broker and Grafana are launched with Docker‑Compose; the gantrylib Python module is installed via pip; the system can be started and stopped with a single compose command."
]