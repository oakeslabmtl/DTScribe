// C3: Physical sensing components
instance GantryPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the horizontal carriage position of the gantry crane"
    DTDFVocab:producedData PositionDataTransmitted
]

instance GantryVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the velocity of the gantry trolley along the rail"
    DTDFVocab:producedData VelocityDataTransmitted
]

instance GantryLoadSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the load (weight) being lifted by the hoist"
    DTDFVocab:producedData LoadDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GantryPositionSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GantryVelocitySensor
]

instance LoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GantryLoadSensor
]

// C10: Data
instance PositionData : DTDFVocab:Data [
    base:desc "Time‑series of gantry horizontal position values"
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance VelocityData : DTDFVocab:Data [
    base:desc "Time‑series of gantry trolley velocity values"
    DTDFVocab:fromData VelocityDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance LoadData : DTDFVocab:Data [
    base:desc "Time‑series of hoist load measurements"
    DTDFVocab:fromData LoadDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

// C11: Enablers (tooling and infrastructure)
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT publish‑subscribe middleware used for streaming sensor data and command messages"
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database that stores all sensor and actuation measurements"
    DTDFVocab:enables HistoricalLoggingService
]

instance DockerContainerOptimalControl : DTDFVocab:Enabler [
    base:desc "Docker container that hosts the OptimalControlService"
    DTDFVocab:enables OptimalControlService
]

instance DockerContainerHistoricalLogging : DTDFVocab:Enabler [
    base:desc "Docker container that hosts the HistoricalLoggingService"
    DTDFVocab:enables HistoricalLoggingService
]

instance DockerContainerVisualization : DTDFVocab:Enabler [
    base:desc "Docker container that hosts the VisualizationService"
    DTDFVocab:enables VisualizationService
]

instance DockerContainerValidation : DTDFVocab:Enabler [
    base:desc "Docker container that hosts the ContinuousValidationService"
    DTDFVocab:enables ContinuousValidationService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana web dashboard used for real‑time visualization and alert presentation"
    DTDFVocab:enables VisualizationService
]

// C10: Models
instance CraneCADModel : DTDFVocab:Model [
    base:desc "Geometric model of the gantry crane created in Autodesk Fusion 360"
    DTDFVocab:inputTo VisualizationService
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Python‑based kinematic model that computes crane motions and predicts states"
    DTDFVocab:inputTo ContinuousValidationService, OptimalControlService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes optimal motion commands for the crane and sends them to the physical controller"
    DTDFVocab:provides TrajectoryOptimizationInsight, SendOptimalMotionCommand
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Records all sensor and actuation data into TimescaleDB for later analysis"
    DTDFVocab:provides HistoricalDataInsight, ArchiveHistoricalDataAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Renders real‑time crane state and historical data using the CAD and kinematic models"
    DTDFVocab:provides RealTimeVisualizationInsight, Render3DModelAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares live sensor data with the kinematic model to generate validation metrics"
    DTDFVocab:provides ValidationMetricInsight, TriggerDashboardAlert
]

// C17: Insights
instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight describing the optimal trajectory computed for a given container relocation"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing trends and patterns extracted from archived crane sensor data"
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight presenting the current crane pose and load status on the dashboard"
]

instance ValidationMetricInsight : DTDFVocab:Insight [
    base:desc "Insight reporting deviation metrics between physical measurements and the kinematic model"
]

// C17: Actions
instance SendOptimalMotionCommand : DTDFVocab:Action [
    base:desc "Automatically sends the computed optimal motion commands to the crane controller via MQTT"
    DTDFVocab:IsAutomatic true
]

instance ArchiveHistoricalDataAction : DTDFVocab:Action [
    base:desc "Writes incoming sensor streams into TimescaleDB for long‑term storage"
    DTDFVocab:IsAutomatic true
]

instance Render3DModelAction : DTDFVocab:Action [
    base:desc "Updates the 3‑D CAD representation in Grafana with the latest crane state"
    DTDFVocab:IsAutomatic true
]

instance TriggerDashboardAlert : DTDFVocab:Action [
    base:desc "Generates a threshold‑based alert on the dashboard when validation metrics exceed limits"
    DTDFVocab:IsAutomatic true
]

instance OperatorFeedbackAction : DTDFVocab:Action [
    base:desc "Allows operators to acknowledge alerts and submit corrective commands through the dashboard"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are issued from the Control Application, a Python application that uses the Physical Crane Interface to communicate with the crane controllers and drive the physical crane. The command types (e.g., movement trajectories) are generated by services such as the Trajectory Generator Service and sent through the Python interface; the documents do not specify command message formats, validation, authentication, or acknowledgment mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The gantry crane digital twin adopts an ad‑hoc orchestration approach rather than a commercial digital‑twin framework. Integration of the twin's software components is achieved through containerization, as mentioned in the discussion of similar design choices (e.g., use of containers for easy dissemination). The system architecture is described using the C4 model, providing context and container diagrams that capture the physical crane, the digital‑twin services, and their interaction points. Resource management and coordination rely on standard container techniques rather than a dedicated DT platform."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by a Continuous Validation Service that runs in parallel with the physical crane. After each executed trajectory, the service retrieves the corresponding simulated trajectory from the kinematic model, computes a distance metric (e.g., Euclidean deviation over time) between the measured sensor trace and the simulated trace, and compares the result against a predefined acceptable threshold. Deviations beyond the threshold trigger alerts and may initiate model parameter recalibration. Uncertainty sources such as sensor noise, encoder quantisation error, and simplifications in the kinematic equations are accounted for by the threshold setting and by periodic calibration of the sensors. This validation loop provides ongoing verification of both the model's accuracy and the integrity of the incoming data, forming the core of the Twin's quality‑assurance process."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital‑twin services (Trajectory Generator, Simulation, Continuous Validation) are organized as separate containers that exchange messages via an MQTT broker, which provides the signaling backbone for inter‑service communication. The Database (TimescaleDB) and Dashboard (Grafana) are also part of the container set. No explicit network topology, bandwidth, latency, redundancy, or security protocol details are given beyond the use of MQTT for internal messaging."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system is composed of multiple logical containers (Physical Crane Interface, Control Application, Logging Application, Human Machine Interface, Database, Dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service, MQTT Broker) implemented as Python applications and a TimescaleDB instance. The documents do not mention cloud, edge, or on‑premise hosting platforms, nor do they provide quantitative computational or storage requirements, scalability mechanisms, or availability guarantees."
]