// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures swinging motion of the load at the end of the hoist, providing real-time angular displacement feedback for crane stability and trajectory accuracy."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Measures wind speed influencing crane stability and trajectory accuracy, deployed in the external environment."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Data Transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Python-based kinematic model derived from CAD geometry simulating the gantry crane's 3DoF motion dynamics (horizontal/vertical translation and rotation)."
    DTDFVocab:inputTo KinematicSimulationEnabler, ContinuousValidationEnabler
]

instance CraneGeometricModel : DTDFVocab:Model [
    base:desc "High-fidelity 3D CAD representation of the gantry crane structure and payload pucks created in Autodesk Fusion 360."
    DTDFVocab:inputTo VisualizationEnabler
]

instance RealTimeTrajectoryData : DTDFVocab:Data [
    base:desc "Continuously logged operational data including puck positions, trajectory execution metrics, and system states from the Physical Crane Interface."
    DTDFVocab:fromData SwingAngleDataTransmitted, WindSpeedDataTransmitted
    DTDFVocab:inputTo ContinuousValidationEnabler, HistoricalLoggingEnabler
]

instance SimulatedTrajectoryData : DTDFVocab:Data [
    base:desc "Generated trajectories from the kinematic model used for comparison against executed trajectories in the Continuous Validation Service."
    DTDFVocab:fromData CraneKinematicModel
    DTDFVocab:inputTo ContinuousValidationEnabler
]

// C11: Enablers
instance KinematicSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python-based module executing the kinematic model to generate simulated trajectories for validation purposes."
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Service comparing real-time measurements with simulated trajectories using Euclidean distance metrics, triggering alerts for deviations."
    DTDFVocab:enables ContinuousValidationService
]

instance HistoricalLoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB-based system storing operational data for long-term analysis and retrospective validation."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard integrated with TimescaleDB for real-time and historical data visualization of system states."
    DTDFVocab:enables DataVisualizationService
]

instance MQTTCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "Mosquitto broker facilitating lightweight publish-subscribe messaging between physical components and digital twin services."
    DTDFVocab:enables OptimalControlService, ContinuousValidationService, DataVisualizationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Generates real-time trajectories and optimizes actuator commands using kinematic models to ensure precise crane motion execution."
    DTDFVocab:provides OptimalTrajectoryInsight, ActuatorCommandAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Implements real-time comparison between physical measurements and simulated trajectories to detect discrepancies and classify anomalies."
    DTDFVocab:provides SystemFidelityInsight, FaultDetectionAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Stores operational data in TimescaleDB for performance benchmarking and retrospective validation."
    DTDFVocab:provides HistoricalPerformanceInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Provides Grafana-based dashboard for monitoring sensor readings, actuator commands, and system state trends in real-time."
    DTDFVocab:provides RuntimeVisualizationInsight
]

// C2: Acting Components
instance HorizontalCartMotor : DTDFVocab:ActingComponent [
    base:desc "Controls the cart's horizontal movement along the gantry beam with precise positioning capabilities."
]

instance HoistingMotor : DTDFVocab:ActingComponent [
    base:desc "Manages the vertical hoisting movement of the payload with controlled acceleration/deceleration."
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Integrated at the hoist end for container pickup and release operations via electromagnetic force."
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Real-time trajectory optimization insights derived from kinematic models to ensure precise payload manipulation."
]

instance ActuatorCommandAction : DTDFVocab:Action [
    base:desc "Automatically generated actuator commands sent to motors and electromagnet for precise crane operation."
    DTDFVocab:IsAutomatic true
]

instance SystemFidelityInsight : DTDFVocab:Insight [
    base:desc "Quantitative assessment of digital twin fidelity through continuous comparison of executed vs simulated trajectories."
]

instance FaultDetectionAction : DTDFVocab:Action [
    base:desc "Automated anomaly detection triggering alerts when trajectory deviations exceed acceptable thresholds."
    DTDFVocab:IsAutomatic true
]

instance HistoricalPerformanceInsight : DTDFVocab:Insight [
    base:desc "Long-term performance trends and operational benchmarks derived from historical TimescaleDB data."
]

instance RuntimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of system states including sensor readings, actuator commands, and trajectory execution metrics."
]

// C1: Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Closed-loop kinematic system with 3 degrees of freedom (horizontal/vertical translation and rotation) in a controlled laboratory setting."
    base:contains CraneKinematicModel, CraneGeometricModel,
            HorizontalCartMotor, HoistingMotor, CraneElectromagnet,
            SwingAngleEncoder, Anemometer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The **Trajectory Generator Service** computes optimal movement trajectories for the crane using a kinematics model, ensuring trajectories terminate with **no residual swinging motion**. These trajectories are transmitted to the **Control Application**, which interfaces with the **Physical Crane Interface** to issue control commands to the crane’s hardware. The **Human Machine Interface (HMI)** allows operators to configure and override crane operations, though explicit details on command formats (e.g., message structures) or protocols (e.g., TCP/UDP) are absent. The **Continuous Validation Service** indirectly validates trajectory execution by comparing real-world performance against simulations, but no pre-execution validation of commands (e.g., threshold checks) is described. Feedback loops exist implicitly through the **Dashboard**, which notifies operators of discrepancies between executed and simulated trajectories, enabling corrective actions. Confirmation of command execution is inferred through the validation process, though no explicit acknowledgment mechanism is documented."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin systems in the documents follow an **ad-hoc, lightweight orchestration approach** without reliance on commercial frameworks. The **GreenhouseDT** exemplar uses **InfluxDB (time-series database) + ActiveMQ (message broker)** for **event-driven coordination** between the physical greenhouse and its digital twin, enabling **behavioral adaptation** of both systems. The **Air Quality Management** exemplar employs **Microsoft Azure tools** for pipeline implementation, with **AutomationML-based digital twin modeling** and **three example applications (runtime visualization, simulation, and prediction)**, suggesting a **modular, service-oriented constellation** but no explicit orchestration protocol. The **gantry crane** system (logistics domain) is designed using **C4 Model architecture**, implying a **containerized or virtualized deployment** (similar to other exemplars) but lacks details on **resource management** or **system-wide coordination mechanisms**. **No centralized controller or distributed consensus protocol** (e.g., Kafka, MQTT, or blockchain) is mentioned."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin’s fidelity is ensured through a **Continuous Validation Service**, which performs real-time comparisons between **physical measurements** (e.g., Swing Angle Encoder, Anemometer) and **simulated trajectories** using **distance metrics**. If the calculated deviation exceeds an **acceptable threshold**, the system **notifies operators**, who can then take **appropriate action** (e.g., manual intervention, system adjustments). The documents do not specify **uncertainty quantification methods**, **error correction algorithms**, or **quality assurance processes** (e.g., periodic model recalibration, sensor validation protocols). Validation relies on **threshold-based anomaly detection** rather than probabilistic or statistical error modeling."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin system employs a **centralized MQTT Broker** for inter-service communication, enabling asynchronous messaging between containers (e.g., Trajectory Generator, Simulation Service, Logging Application). The **TimescaleDB** database, built on PostgreSQL, stores time-series data generated by the system, with no explicit mention of replication or redundancy mechanisms. The architecture is containerized, with services deployed as isolated units (e.g., Dashboard, Simulation Service) but lacks details on network topology (e.g., LAN/WAN) or quality-of-service (QoS) guarantees. Security protocols, bandwidth requirements, or latency constraints are not specified, though the system operates on a **personal computer** (on-premise), implying local network isolation. No details on network redundancy or failover mechanisms are provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin system is deployed **on-premise** on a **personal computer**, with all services (Database, MQTT Broker, Dashboard, Trajectory Generator, Simulation Service, Continuous Validation Service) containerized for modularity. The **TimescaleDB** database is optimized for time-series data storage, though no details on hardware specifications (e.g., CPU, memory) or scalability mechanisms (e.g., horizontal scaling) are provided. The system does not explicitly support cloud or edge deployment, and no mention of high-availability configurations (e.g., database replication) or continuous integration/deployment (CI/CD) pipelines is made. Availability and reliability are not quantified, and the architecture suggests a single-node deployment without redundancy or failover capabilities."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin systems demonstrate **limited horizontal integration** with external systems, relying on **ad-hoc or domain-specific protocols**. The **GreenhouseDT** exemplar integrates with **InfluxDB (time-series storage) and ActiveMQ (message broker)**, but no interoperability standards (e.g., OPC UA, FIWARE, or Industry 4.0 protocols) are specified for external system communication. The **Air Quality Management** exemplar uses **AutomationML** for digital twin modeling and **Microsoft Azure tools** for pipeline execution, indicating **cloud-based integration** but no explicit data exchange protocols with other Digital Twins or enterprise systems. The **gantry crane** system (logistics domain) lacks documented dependencies on external systems, though its **C4 Model architecture** suggests potential for **modular integration** with other cyber-physical systems. **No mention of APIs, web services, or standardized interfaces** (e.g., REST, gRPC) for cross-system communication is provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin exemplars demonstrate **partial standardization** with the following technical adherence:
  - **AutomationML**: The Air Quality Management exemplar explicitly uses **AutomationML** for DT modeling, a standard for engineering data exchange in automation systems, ensuring interoperability with other tools (e.g., PLCs, SCADA).
  - **Industry Standards**: No explicit mention of **certification requirements** (e.g., ISO 27001, IEC 62443) or **compliance frameworks** (e.g., GDPR for data handling). However, the use of **Microsoft Azure** in the Air Quality Management pipeline implies adherence to **Microsoft’s compliance standards** (e.g., Azure Security Benchmark).
  - **Interoperability**: The exemplars rely on **open-source technologies** (e.g., InfluxDB, ActiveMQ, Raspberry Pi) and **containerization/virtualization**, which align with **IEEE/ISO interoperability standards** for distributed systems. The ad-hoc approach limits formal compliance but ensures flexibility.
  - **Domain-Specific Standards**: The GreenhouseDT and Air Quality Management exemplars target **agricultural** and **construction engineering** domains, respectively, but no domain-specific DT standards (e.g., NIST DT Framework) are referenced.
  - **Data Standards**: InfluxDB (time-series database) and AutomationML suggest adherence to **data modeling standards**, though no explicit mention of **semantic standards** (e.g., OWL, JSON-LD) for ontology-based DT representation."
]