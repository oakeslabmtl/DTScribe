// C3: Physical sensing components
instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor on the gantry crane’s motion controller, streaming real‑time position data."
    DTDFVocab:producedData CranePositionDataTransmitted
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Velocity sensor attached to the crane’s linear rail system, delivering continuous velocity measurements."
    DTDFVocab:producedData CraneVelocityDataTransmitted
]

instance CraneActuatorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Actuator status sensor monitoring hoist and jaw motor states in real‑time."
    DTDFVocab:producedData CraneActuatorStatusDataTransmitted
]

// C4: Physical-to-virtual interaction
instance CranePositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor
    base:desc "Binary tuple transmitted over the local network via PostgreSQL wire protocol, containing position data."
]

instance CraneVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocitySensor
    base:desc "Binary tuple transmitted over the local network via PostgreSQL wire protocol, containing velocity data."
]

instance CraneActuatorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneActuatorStatusSensor
    base:desc "Binary tuple transmitted over the local network via PostgreSQL wire protocol, containing actuator status data."
]

// C10: Data
instance CranePositionData : DTDFVocab:Data [
    base:desc "Timestamped position data extracted from the transmitted tuple."
    DTDFVocab:fromData CranePositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBIngestion, AzureIoTHubIngestion
]

instance CraneVelocityData : DTDFVocab:Data [
    base:desc "Timestamped velocity data extracted from the transmitted tuple."
    DTDFVocab:fromData CraneVelocityDataTransmitted
    DTDFVocab:inputTo TimescaleDBIngestion, AzureIoTHubIngestion
]

instance CraneActuatorStatusData : DTDFVocab:Data [
    base:desc "Timestamped actuator status data extracted from the transmitted tuple."
    DTDFVocab:fromData CraneActuatorStatusDataTransmitted
    DTDFVocab:inputTo TimescaleDBIngestion, AzureIoTHubIngestion
]

// C11: Enablers
instance TimescaleDBIngestion : DTDFVocab:Enabler [
    base:desc "Ingestion service writing sensor data into TimescaleDB via PostgreSQL wire protocol for historical logging."
    DTDFVocab:enables HistoricalDataLoggingService, ContinuousMonitoringService, ContinuousValidationService
]

instance AzureIoTHubIngestion : DTDFVocab:Enabler [
    base:desc "Medium that forwards sensor streams to Azure IoT Hub for remote access and telemetry."
    DTDFVocab:enables ContinuousMonitoringService
]

instance PlotlyVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Python wrapper enabling interactive 3‑D CAD model rendering and real‑time time‑series plots using Plotly."
    DTDFVocab:enables InteractiveVisualizationService
]

instance MatplotlibVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Python wrapper for static time‑series plotting using Matplotlib, used in internal analysis."
    DTDFVocab:enables PredictiveAnalyticsService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Kinematic model enabler interfacing with Azure Machine Learning to perform trajectory optimisation."
    DTDFVocab:enables OptimalControlService
]

instance ModelValidationEnabler : DTDFVocab:Enabler [
    base:desc "Comparison engine synchronising live measurements with the CAD‑based kinematic model to detect drift."
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance ContinuousMonitoringService : DTDFVocab:Service [
    base:desc "Monitors real‑time sensor streams and uses live data to detect anomalies in crane operation."
    DTDFVocab:provides AnomalyDetectionInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Model‑based trajectory optimisation that reduces energy consumption and wear on the crane."
    DTDFVocab:provides CraneTrajectoryOptimizationInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Logs all sensor outputs with timestamps for later retrospective analysis."
    DTDFVocab:provides HistoricalDataInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Renders 3‑D CAD models and displays interactive time‑series plots through a web interface."
    DTDFVocab:provides DataVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Validates live sensor measurements against the kinematic model to detect drift or faults."
    DTDFVocab:provides ModelDriftInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Simulates airflow scenarios and predicts future indoor air quality for virus spread prevention."
    DTDFVocab:provides VirusSpreadPredictionInsight, AirQualityTrendInsight
]

// C17: Insights and Actions
instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight into anomalous crane behaviour detected by Continuous Monitoring Service."
]

instance CraneTrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory recommendation generated by Optimal Control Service."
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Historical sensor data overview provided by Historical Data Logging Service."
]

instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Dynamic visualization of 3‑D models and sensor plots delivered by Interactive Visualization Service."
]

instance ModelDriftInsight : DTDFVocab:Insight [
    base:desc "Model drift detection insight from Continuous Validation Service."
]

instance VirusSpreadPredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive insight for virus spread prevention through airflow scenario simulation."
]

instance AirQualityTrendInsight : DTDFVocab:Insight [
    base:desc "Real‑time trend of indoor air quality derived from predictive analytics."
]

instance VentilationScheduleAdjustment : DTDFVocab:Action [
    base:desc "Operator action to adjust ventilation or occupancy schedules based on predictive analytics insights."
    DTDFVocab:IsAutomatic false
]

// C10: Environment and Component (system under study)
instance GantryCraneComponent : DTDFVocab:Component [
    base:desc "Laboratory‑scale gantry crane with linear rails, hoist, jaw, and electronic motion controller."
]

instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains GantryCraneComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate in the Control Application, which takes operator orders from the Human Machine Interface. Commands are encoded as high‑level movement trajectories and passed through the Physical Crane Interface to the physical crane controllers via a Python API over TCP. The Digital Twin issues these commands without explicit authentication or verification steps, and the Physical Crane Interface forwards them to the hardware where they are executed. No explicit feedback loop or command‑execution confirmation mechanism is described in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration is built around containerization or virtualization for easy deployment. In GreenhouseDT, the stack consists of a virtual‑machine image that bundles an InfluxDB time‑series database for sensor data and an ActiveMQ message broker for real‑time data flow. Air Quality Management leverages Microsoft Azure services (IoT Hub, Azure Functions, and Azure Stream Analytics) to ingest sensor streams from a Raspberry‑Pi and drive an AutomationML‐based Digital Twin model; the same pattern uses a cloud‑hosted message bus (Service Bus) for cross‑service communication. The gantry crane example references containerized deployment but does not specify a concrete orchestration platform. Overall, the system employs a central message bus (ActiveMQ or Azure Service Bus), persistent data stores (InfluxDB or Azure Table/Blob), and containerized application components running on virtual machines or cloud instances."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the Digital Twin is orchestrated by an MQTT broker, which publishes and subscribes to topics for coordination between the Trajectory Generator, Simulation, Continuous Validation, and Dashboard services. The Physical Crane Interface and Logging Application communicate over the local network using TCP, with data persisted through PostgreSQL’s wire protocol to TimescaleDB. The documents do not specify bandwidth, latency, redundancy, or security protocols beyond the use of MQTT and TCP."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All Digital Twin containers (Python services, TimescaleDB, Grafana dashboard, MQTT broker) are deployed on the same on‑premises host that houses the physical crane, as indicated by the direct use of local network connections and a single TimescaleDB instance. No explicit cloud or edge deployment, scalability strategy, or availability mechanisms are mentioned in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is performed primarily via message passing protocols: ActiveMQ for on‑premises instrumentation in GreenhouseDT, Azure IoT Hub/Service Bus for Azure‑based ingestion in Air Quality Management, and AutomationML as an interoperability standard for semantic modeling. Data is exchanged in JSON or binary formats over MQTT/AMQP, and the Digital Twins expose REST/HTTPS APIs for platform integration. The dashboards and simulation engines consume the published data streams; no direct integration with third‑party enterprise systems is described beyond the cloud services and message brokers cited."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplar adopts the AutomationML standard for modeling the plant environment and the twin representation. Other components rely on common industry protocols (e.g., MQTT for message brokering inferred from the ActiveMQ mention in GreenhouseDT, time‑series database InfluxDB, and containerisation via Docker or virtual machines). No explicit certification or compliance framework is referenced."
]