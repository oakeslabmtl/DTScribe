// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures angular displacement of the swinging motion during lifting operations. Mounted on the hoist mechanism of the gantry crane."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Monitors wind speed in the operational environment to assess potential impact on crane stability. Positioned externally to capture ambient conditions."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
    base:desc "Real-time angular displacement data transmitted from the SwingAngleEncoder via direct sensor-to-broker communication."
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
    base:desc "Real-time wind speed data transmitted from the Anemometer via direct sensor-to-broker communication."
]

instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalCraneInterface
    base:desc "Event-driven operational state data (e.g., movement initiation, trajectory completion) transmitted from the PhysicalCraneInterface to the LoggingApplication."
]

// C10: Models/Data
instance CraneGeometricModel : DTDFVocab:Model [
    base:desc "3D CAD representation of the gantry crane structure and container pucks, created using Autodesk Fusion 360. Serves as the geometric foundation for kinematic simulations."
    DTDFVocab:inputTo PythonGantryLib
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Behavioral/kinematic model simulating motion trajectories including cart movement, hoisting, and swinging dynamics. Derived from the CraneGeometricModel."
    DTDFVocab:inputTo PythonGantryLib
]

instance CraneTrajectorySimulation : DTDFVocab:Model [
    base:desc "Simulation model predicting trajectories based on kinematic constraints and real-time sensor feedback."
    DTDFVocab:inputTo PythonGantryLib
]

instance CraneHistoricalData : DTDFVocab:Data [
    base:desc "Time-series storage of sensor measurements, system states, and executed trajectories with millisecond precision."
    DTDFVocab:fromData CraneStateDataTransmitted, SwingAngleDataTransmitted, WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance RealTimeCraneStateData : DTDFVocab:Data [
    base:desc "Continuously updated operational data (e.g., joint angles, payload position, actuator states) for real-time synchronization."
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo PythonGantryLib
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Lightweight publish-subscribe protocol (Eclipse Mosquitto) enabling real-time bidirectional communication between physical sensors/actuators and digital twin services."
    DTDFVocab:enables TrajectoryGeneratorService, StateLoggingApplication, ContinuousValidationService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "Time-series database optimized for high-write-throughput scenarios, storing historical crane data with millisecond precision."
    DTDFVocab:enables StateLoggingApplication, ContinuousValidationService, DataVisualizationDashboard
]

instance PythonGantryLib : DTDFVocab:Enabler [
    base:desc "Custom Python library for kinematic modeling, control logic, and service orchestration. Acts as middleware for data processing and service integration."
    DTDFVocab:enables TrajectoryGeneratorService, ContinuousValidationService, FaultDetectionService
]

instance DockerContainerization : DTDFVocab:Enabler [
    base:desc "Containerization framework ensuring modularity, portability, and consistent environments for deployed services (e.g., trajectory generator, validation engine)."
    DTDFVocab:enables TrajectoryGeneratorService, ContinuousValidationService, DataVisualizationDashboard
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Real-time and historical visualization tool for monitoring crane metrics (e.g., joint positions, payload states, validation errors)."
    DTDFVocab:enables DataVisualizationDashboard
]

// C2: Acting Components
instance HorizontalMovementStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor governing the horizontal movement of the cart along the gantry beam. Interfaced with Arduino-based control system."
]

instance VerticalHoistingStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor controlling the vertical hoisting mechanism for lifting and lowering containers. Interfaced with Arduino-based control system."
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet integrated at the end of the hoist to securely grip and release container-like pucks during material handling."
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes and provides optimal trajectories for the crane's motion, ensuring minimal residual swinging and smooth payload transport. Integrates real-time feedback from the physical system."
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance StateLoggingApplication : DTDFVocab:Service [
    base:desc "Continuously records operational data (e.g., joint angles, payload position, actuator states) into TimescaleDB for post-processing and validation."
    DTDFVocab:provides CraneStateLogInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares real-time measurements from the physical crane with simulated predictions from the digital twin's kinematic model. Discrepancies trigger alerts or corrective actions."
    DTDFVocab:provides ModelValidationInsight, TrajectoryDeviationAlert
]

instance DataVisualizationDashboard : DTDFVocab:Service [
    base:desc "Provides real-time graphical interface for monitoring crane states, historical data trends, and validation metrics via Grafana."
    DTDFVocab:provides CranePerformanceVisualization
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Identifies deviations from expected behavior (e.g., actuator failures, sensor drift) by leveraging digital twin's data streams."
    DTDFVocab:provides FaultDetectionAlert
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Generated trajectory ensuring minimal residual swinging and smooth payload transport, validated against real-time sensor feedback."
]

instance CraneStateLogInsight : DTDFVocab:Insight [
    base:desc "Structured historical record of crane operational states for trend analysis and validation purposes."
]

instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Comparison results between simulated and actual trajectories using Euclidean distance metrics with predefined deviation thresholds."
]

instance TrajectoryDeviationAlert : DTDFVocab:Action [
    base:desc "Automated alert triggered when simulated and executed trajectories exceed predefined deviation thresholds."
    DTDFVocab:IsAutomatic true
]

instance CranePerformanceVisualization : DTDFVocab:Insight [
    base:desc "Real-time and historical visualization of crane metrics including joint positions, payload states, and validation errors."
]

instance FaultDetectionAlert : DTDFVocab:Action [
    base:desc "Automated alert triggered upon detection of actuator failures or sensor drift based on digital twin data streams."
    DTDFVocab:IsAutomatic true
]

// C1: System Under Study
instance LabScaleGantryCrane : DTDFVocab:Component [
    base:desc "Cyber-physical system designed for research and educational purposes, comprising a scaled-down mechanical gantry crane with linear motion along rails."
]

instance CraneController : DTDFVocab:Component [
    base:desc "Dedicated hardware/software system interfacing with the crane's actuators (motors, encoders) to execute motion commands and enforce operational constraints."
]

instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Python program acting as the primary data acquisition layer, interfacing directly with the physical crane's controllers to extract real-time operational data."
]

instance DigitalTwinGantryCrane : DTDFVocab:Component [
    base:desc "Digital representation integrating geometric and kinematic models to simulate crane motion trajectories and validate real-time operations."
]

instance OperationalEnvironment : DTDFVocab:Environment [
    base:desc "Closed-loop, real-time control environment where the crane operates under predefined kinematic and safety constraints."
    base:contains LabScaleGantryCrane, CraneController, PhysicalCraneInterface, DigitalTwinGantryCrane
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the **Control Application**, which leverages the **Trajectory Generator Service** to compute optimal movement trajectories (e.g., swing-free paths) based on a kinematics model. These trajectories are translated into executable commands via the **Physical Crane Interface**, which interfaces with the crane’s controllers. The **Control Application** directly uses the crane interface to issue control instructions, while the **Trajectory Generator Service** ensures trajectories are dynamically generated without residual swinging. No explicit command formats (e.g., JSON/Protobuf), validation/authentication mechanisms, or low-level instructions (e.g., PWM signals) are described. Feedback systems are implied through the **Continuous Validation Service**, which compares executed trajectories against simulations and alerts operators via the **Dashboard** if discrepancies exceed thresholds. Command execution confirmation is not explicitly detailed, though the system’s design suggests closed-loop validation through trajectory comparison."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin systems described adopt a **lightweight, ad-hoc orchestration approach** rather than relying on commercial frameworks. GreenhouseDT employs **virtual machines (VMs) with pre-recorded data** and an **InfluxDB database** for time-series storage, alongside **ActiveMQ for message brokering**, enabling loose coupling between physical and digital components. The Air Quality Management exemplar uses **Microsoft Azure tools** for pipeline implementation, integrating **Raspberry Pi-based sensor networks** with an **AutomationML-based Digital Twin**, suggesting a **hybrid cloud-edge architecture**. The gantry crane system (logistics/cyber-physical domain) follows similar principles, using **containerization/virtualization** for dissemination but lacks explicit orchestration details. Coordination mechanisms are **implicitly event-driven** (e.g., sensor-triggered updates) with no centralized controller, relying instead on **modular, domain-specific services** (e.g., runtime visualization, simulation, prediction)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The **Continuous Validation Service** is the primary mechanism for ensuring model fidelity, employing **distance metrics** (e.g., Euclidean distance) to compare executed trajectories (derived from sensor data) with simulated trajectories (generated by kinematic models). A predefined **threshold** is used to flag deviations exceeding acceptable error margins, triggering corrective actions such as recalibration or model updates. Uncertainty sources include **sensor noise** (e.g., Swing Angle Encoder drift), **environmental factors** (e.g., wind-induced perturbations), and **model approximations** (e.g., simplified kinematic assumptions). Validation is performed in **real-time** during crane operation, with historical data stored in **TimescaleDB** for offline analysis. Quality assurance processes involve **automated threshold checks** and **manual review** of critical trajectories, ensuring alignment between physical and digital representations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin system relies on an **MQTT broker** for inter-service communication, facilitating signaling between containers (e.g., **Trajectory Generator Service**, **Simulation Service**, **Continuous Validation Service**). The network topology is localized, with all software components (including the **Physical Crane Interface**, **Control Application**, and digital twin services) deployed on the same host computer, implying a **local-area network (LAN)** setup. No explicit bandwidth, latency, or redundancy mechanisms are specified, though the use of MQTT suggests lightweight, publish-subscribe messaging optimized for low-overhead communication. Security protocols are not detailed beyond the implicit isolation of services within the containerized environment. The **TimescaleDB database** and **Grafana Dashboard** are accessed via unspecified protocols, but the system assumes secure, containerized deployment."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin system is deployed **on-premise** on a single host computer, with all software components (physical and digital twin containers) running locally. The physical crane can operate independently of the digital twin, indicating a **decoupled architecture** where the digital twin is an optional enhancement. Services are containerized (implied by the C4 model’s container abstraction), though Docker is not explicitly mentioned. No details are provided on computational/storage requirements, scalability mechanisms, or availability/reliability assurances beyond the system’s ability to function autonomously without the digital twin. The **TimescaleDB database** stores all generated data, but no specifics on storage optimization, backups, or redundancy are included. Deployment is static, with no indication of cloud/edge hybrid models or dynamic scaling."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin exemplars demonstrate **limited horizontal integration** with external systems, primarily focusing on **internal data flows** between physical assets and their Digital Twin counterparts. GreenhouseDT integrates with **InfluxDB (time-series database)** and **ActiveMQ (message broker)** for internal synchronization but lacks explicit mention of enterprise system or third-party Digital Twin interoperability. The Air Quality Management exemplar uses **AutomationML** for model exchange but relies on **Microsoft Azure tools** for cloud-based pipeline execution, with no details on external system dependencies. The gantry crane system (logistics domain) is described using **C4 Model architecture diagrams**, implying potential integration with **cyber-physical logistics platforms**, but no specific protocols (e.g., OPC UA, MQTT) or standards are mentioned. All exemplars avoid commercial Digital Twin frameworks, suggesting **ad-hoc, domain-specific integration** rather than standardized horizontal scalability."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin exemplars demonstrate **partial standardization** with:
  - **Air Quality Management**: Adopts **AutomationML** for digital twin modeling, a **de facto standard** in industrial automation and engineering, ensuring interoperability with other AutomationML-compliant systems. Uses **Microsoft Azure tools**, which may align with **ISO/IEC 25010** (software quality) and **IEC 62264** (enterprise-control system integration) indirectly.
  - **GreenhouseDT**: Relies on **InfluxDB** (time-series database standard) and **ActiveMQ** (JMS-compliant message broker), but lacks explicit adherence to digital twin-specific standards (e.g., **ISO 23227** for digital twins in manufacturing).
  - **Gantry Crane**: No standardization details are provided; the **C4 Model** is a software architecture notation, not an industry standard.
  **Interoperability** is achieved via **open-source dissemination** (GitHub) and **containerization/virtualization**, but **certification requirements** or **compliance frameworks** (e.g., ISO 19443 for digital twins) are not mentioned. The ad-hoc approach limits formal compliance tracking."
]