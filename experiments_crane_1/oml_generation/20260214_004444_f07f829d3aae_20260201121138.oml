// C2: Acting Components (none explicitly defined here)

// C3: Physical sensing components
instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Cranes state sensor measuring the horizontal position of the load within the gantry workspace."
    DTDFVocab:producedData PositionDataTransmitted
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Cranes state sensor measuring the velocity of the load along the gantry rails."
    DTDFVocab:producedData VelocityDataTransmitted
]

instance LoadSensor : DTDFVocab:SensingComponent [
    base:desc "Cranes state sensor measuring the load mass applied to the crane hoist."
    DTDFVocab:producedData LoadDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySensor
]

instance LoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadSensor
]

// C10: Models/Data
instance PositionData : DTDFVocab:Data [
    base:desc "Streamed time‑series data representing the crane load horizontal position."
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo PythonCraneInterface, TimescaleDBLoggingEnabler, ValidationEngineEnabler, ControlEngineEnabler, VisualizationEnabler
]

instance VelocityData : DTDFVocab:Data [
    base:desc "Streamed time‑series data representing the crane load horizontal velocity."
    DTDFVocab:fromData VelocityDataTransmitted
    DTDFVocab:inputTo PythonCraneInterface, TimescaleDBLoggingEnabler, ValidationEngineEnabler, ControlEngineEnabler, VisualizationEnabler
]

instance LoadData : DTDFVocab:Data [
    base:desc "Streamed time‑series data representing the crane load mass."
    DTDFVocab:fromData LoadDataTransmitted
    DTDFVocab:inputTo PythonCraneInterface, TimescaleDBLoggingEnabler, ValidationEngineEnabler, ControlEngineEnabler, VisualizationEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "CAD‑based kinematic model of the gantry crane planar chain used for real‑time validation of physical states."
    DTDFVocab:inputTo ValidationEngineEnabler
]

// C11: Enablers
instance PythonCraneInterface : DTDFVocab:Enabler [
    base:desc "Python program connecting to crane controllers, forwarding sensor states to the logging application."
    DTDFVocab:enables RealTimeMonitoringService, HistoricalLoggingService, ContinuousValidationService, OptimalControlService
]

instance TimescaleDBLoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB persistence layer that stores streamed crane state data for historical analysis."
    DTDFVocab:enables HistoricalLoggingService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Runtime engine that receives position, velocity and load data, compares them against the CraneKinematicModel, and detects deviations or fault conditions."
    DTDFVocab:enables ContinuousValidationService
]

instance ControlEngineEnabler : DTDFVocab:Enabler [
    base:desc "Control engine that consumes real‑time crane state data to compute optimal trajectories and feed them back to the physical controller."
    DTDFVocab:enables OptimalControlService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Visualization engine that renders dashboards of joint angles, load history, and performance metrics in real time."
    DTDFVocab:enables VisualizationDashboardService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of crane states (position, velocity, load) enabling operators to observe current operating conditions."
    DTDFVocab:provides CraneStateInsight
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Historical data logging for post‑mortem analysis of crane operation."
    DTDFVocab:provides HistoricalAnalysisInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Data visualization dashboards displaying joint angles, load history, and performance metrics."
    DTDFVocab:provides PerformanceMetricsInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation against the kinematic model to detect deviations and fault conditions."
    DTDFVocab:provides DeviationDetectionInsight, FaultConditionInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal control service feeding computed trajectories back to the physical controller."
    DTDFVocab:provides ControlTrajectoryInsight, FeedTrajectoryAction
]

// C17: Insights/Actions
instance CraneStateInsight : DTDFVocab:Insight [
    base:desc "Insight displaying current crane state variables in real time."
]

instance HistoricalAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight providing historical trends and statistical summaries of crane operation for post‑mortem analysis."
]

instance PerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Insight visualizing performance metrics such as efficiency, throughput, and response times."
]

instance DeviationDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight identifying deviations of measured states from the kinematic model predictions."
]

instance FaultConditionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating detected fault conditions based on model validation discrepancies."
]

instance ControlTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight presenting optimal control trajectories computed by the control engine."
]

instance FeedTrajectoryAction : DTDFVocab:Action [
    base:desc "Action feeding the computed trajectory commands to the crane controller."
    DTDFVocab:IsAutomatic true
]

// Environment and Components
instance GantryCrane : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane planar kinematic chain used for digital twinning."
]

instance CraneController : DTDFVocab:Component [
    base:desc "Controller hardware/software that drives the gantry crane operations."
]

instance CraneEnvironment : DTDFVocab:Environment [
    base:contains GantryCrane, CraneController, PositionSensor, VelocitySensor, LoadSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, written in Python, receives trajectory information from the Trajectory Generator Service and issues motion commands to the physical crane via the Physical Crane Interface. Commands include target positions and kinematic profiles, but the command format, authentication, or authentication mechanisms are not described in the documentation. The Physical Crane Interface forwards these commands to the crane controllers. Feedback from executed motions is captured by the Logging Application and made available to the Control Application. Additionally, the Continuous Validation Service compares the real‑time executed trajectory against a simulated trajectory to detect deviations. No explicit conflict resolution strategy or command execution confirmation protocol is documented."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The GreenhouseDT exemplar deploys its components inside virtual machines and Docker containers, orchestrated by a central ActiveMQ message broker that publishes sensor readings from the physical greenhouse into an InfluxDB time‑series database for the digital twin simulation. The Air Quality Management exemplar follows a similar containerized, ad‑hoc architecture: a Raspberry‑Pi gathers environmental sensor data and forwards telemetry over HTTP to an Azure IoT Hub, where Azure Functions forward data into an AutomationML‑based digital twin model. The lab‑scale gantry crane uses containerized services (e.g., a motion controller daemon and a gravity‑sensing module) running on a virtualized host; all components expose REST/gRPC endpoints and publish events to an embedded ActiveMQ broker, enabling coordination of multiple sub‑twin instances (motion, vision, collision‑avoidance). This orchestration pattern represents a decentralized, message‑driven constellation rather than a fully centralized twin architecture."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Internal service coordination within the digital twin is handled through an MQTT broker, providing lightweight publish/subscribe messaging between services such as the Trajectory Generator, Simulation, Continuous Validation, and the Dashboard. Data persistence is achieved with TimescaleDB, accessed via standard SQL queries. The correct technical connection does not include a detailed network topology, bandwidth, or latency requirements, nor does it specify redundancy or security protocols (e.g., TLS, VPN). These aspects are not mentioned in the provided documentation."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "All exemplars integrate with external systems via standard protocols. GreenhouseDT exposes a RESTful API for querying simulation state and publishes telemetry to ActiveMQ, which can be consumed by third‑party analytics dashboards. Air Quality Management relies on Microsoft Azure services: data from the Raspberry‑Pi is sent to Azure IoT Hub over AMQP/MQTT, processed by Azure Stream Analytics, and stored in Azure Blob/Cosmos DB, while the AutomationML twin model is exported to an enterprise asset management system via OPC UA and HL7 FHIR interfaces. The gantry crane exemplar integrates with an external SQL‑based CRM via JDBC and enables command ingestion through HTTPS POST requests, allowing enterprise fleet‑management platforms to schedule tasks."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplar adopts the AutomationML standard for modelling the digital twin representation, and the integration with Microsoft Azure follows Azure’s cloud services standards for data ingestion, messaging, and compute orchestration."
]