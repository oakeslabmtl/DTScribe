    DTDFVocab:provides ModelValidationInsight, DiscrepancyDetectionInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection service identifying fault modes (encoder failure, payload imbalance) using machine learning classifiers."
