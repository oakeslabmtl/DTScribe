instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Controlled laboratory environment for gantry crane operations with predefined motion profiles and safety constraints."
    base:contains CraneActuators, CranePositionSensor, CraneLoadCell, CraneControllerSignals
]

