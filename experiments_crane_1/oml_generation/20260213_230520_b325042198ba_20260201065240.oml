// Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring crane swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// Data transmitted from sensors
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// Data stored in the twin
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBContainer
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBContainer
]

instance OperationalTimeSeriesData : DTDFVocab:Data [
    base:desc "Aggregated operational data (positions, sensor values) stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBContainer
]

instance TrajectorySimulationData : DTDFVocab:Data [
    base:desc "Simulated trajectory data produced by the Simulation Service"
    DTDFVocab:inputTo SimulationContainer
]

// Physical acting components
instance CartMotorStepper : DTDFVocab:ActingComponent [
    base:desc "Cart motor (stepper) driven by Trinamic TMC4671‑Eval controller"
]

instance HoistMotorStepper : DTDFVocab:ActingComponent [
    base:desc "Hoist motor (stepper) driven by Trinamic TMC4671‑Eval controller"
]

instance ElectromagnetEndEffector : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted at the end of the hoist for pallet handling"
]

// Models
instance CraneCADModel : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane created in Autodesk Fusion360"
    DTDFVocab:inputTo GrafanaContainer
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator Service"
    DTDFVocab:inputTo TrajectoryGeneratorContainer
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model used by the Simulation Service"
    DTDFVocab:inputTo SimulationContainer
]

// Enablers (Docker containers)
instance TimescaleDBContainer : DTDFVocab:Enabler [
    base:desc "Docker container running TimescaleDB for time‑series storage"
    DTDFVocab:enables DataLoggingService
]

instance GrafanaContainer : DTDFVocab:Enabler [
    base:desc "Docker container running Grafana for data visualization"
    DTDFVocab:enables DataVisualizationService
]

instance TrajectoryGeneratorContainer : DTDFVocab:Enabler [
    base:desc "Docker container hosting the optimal trajectory generation service"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationContainer : DTDFVocab:Enabler [
    base:desc "Docker container hosting the crane simulation service"
    DTDFVocab:enables SimulationService
]

instance ValidationContainer : DTDFVocab:Enabler [
    base:desc "Docker container running the continuous validation service"
    DTDFVocab:enables ContinuousValidationService
]

instance MQTTBrokerContainer : DTDFVocab:Enabler [
    base:desc "Docker container running Eclipse Mosquitto MQTT broker for inter‑service signaling"
    DTDFVocab:enables MQTTBrokerService
]

instance PythonGantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module providing the Physical Crane Interface and HMI logic"
    DTDFVocab:enables HumanMachineInterfaceService
]

instance ArduinoFirmwareEnabler : DTDFVocab:Enabler [
    base:desc "Arduino firmware that acquires encoder and anemometer data"
    DTDFVocab:enables DataLoggingService
]

// Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logging application that streams crane state (positions, swing angle, wind speed) to TimescaleDB"
    DTDFVocab:provides StoreCraneStateAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualizing real‑time crane metrics"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service that computes optimal motion plans to reduce swing"
    DTDFVocab:provides OptimalMotionPlanInsight, AdjustControlSetpointAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs physics‑based simulations of the crane and its controllers"
    DTDFVocab:provides SimulationResultInsight, UpdateModelParametersAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that compares measured trajectories with simulated ones and raises alerts"
    DTDFVocab:provides SwingAngleMismatchAlert, WindSpeedImpactAlert, OperatorInterventionAction
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "MQTT broker used for publishing crane state and validation events"
    DTDFVocab:provides PublishEventAction
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "HMI allowing operators to issue commands and receive alerts"
    DTDFVocab:provides OperatorCommandAction
]

// Insights
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live visual representation of crane positions, swing angle, and wind speed"
]

instance OptimalMotionPlanInsight : DTDFVocab:Insight [
    base:desc "Computed optimal trajectory that minimizes swing while satisfying task constraints"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Result of the simulation indicating expected motion and forces"
]

instance SwingAngleMismatchAlert : DTDFVocab:Insight [
    base:desc "Real‑time alert when measured swing angle deviates from simulated prediction"
]

instance WindSpeedImpactAlert : DTDFVocab:Insight [
    base:desc "Alert when wind speed exceeds threshold affecting trajectory safety"
]

instance PostHocAnalysisInsight : DTDFVocab:Insight [
    base:desc "Post‑hoc analysis of logged data for parameter tuning and model refinement"
]

instance DTEvolutionInsight : DTDFVocab:Insight [
    base:desc "Insight about the evolution of the digital twin across research iterations"
]

// Actions
instance StoreCraneStateAction : DTDFVocab:Action [
    base:desc "Automatically store incoming sensor data into TimescaleDB"
    DTDFVocab:IsAutomatic true
]

instance AdjustControlSetpointAction : DTDFVocab:Action [
    base:desc "Adjust motor set‑points based on optimal trajectory output"
    DTDFVocab:IsAutomatic true
]

instance OperatorInterventionAction : DTDFVocab:Action [
    base:desc "Prompt operator to intervene when validation detects a mismatch"
    DTDFVocab:IsAutomatic false
]

instance PublishEventAction : DTDFVocab:Action [
    base:desc "Publish crane state or validation event on MQTT topics"
    DTDFVocab:IsAutomatic true
]

instance OperatorCommandAction : DTDFVocab:Action [
    base:desc "Operator issues manual command via the HMI"
    DTDFVocab:IsAutomatic false
]

instance UpdateModelParametersAction : DTDFVocab:Action [
    base:desc "Update simulation model parameters based on latest measurements"
    DTDFVocab:IsAutomatic true
]

instance PerformPostHocAnalysisAction : DTDFVocab:Action [
    base:desc "Run post‑hoc analysis to tune control gains and model parameters"
    DTDFVocab:IsAutomatic false
]

instance ExtendSimulationScopeAction : DTDFVocab:Action [
    base:desc "Add harbor‑level simulations and ship models to the twin"
    DTDFVocab:IsAutomatic false
]

// Environment and component definitions
instance CranePhysicalEnvironment : DTDFVocab:Environment [
    base:contains CartMotorStepper, HoistMotorStepper, ElectromagnetEndEffector, SwingAngleEncoder, Anemometer
]

instance DockerHostComponent : DTDFVocab:Component [
    base:desc "Single host machine running all Docker containers"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends motion commands (cart displacement, hoist displacement, electromagnet activation) to the Physical Crane Interface, which forwards set‑points to the motor controllers; trajectory sets generated by the Trajectory Generator Service are delivered to the Control Application for execution on the crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical crane ↔ Python interface ↔ Control & Logging applications; MQTT broker mediates signals between services; TimescaleDB stores sensor and command logs; Grafana visualizes data; Trajectory Generator, Simulation, and Continuous Validation services consume data via MQTT and DB, providing optimized trajectories and validation alerts; all components orchestrated on a PC via Docker Compose."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares executed trajectories with simulated counterparts, computes distance metrics, checks against a predefined threshold, and raises operator alerts when the threshold is exceeded, providing a runtime validation loop for model fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange between PT and DT uses MQTT (Eclipse Mosquitto) for event signaling and PostgreSQL/TimescaleDB (SQL) for bulk state storage; Python APIs over TCP/IP connect the Physical Crane Interface with control and logging applications."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT services (database, MQTT broker, Grafana) are Docker‑containerized and deployed on a personal computer via a Docker‑Compose file; Python modules run locally; the repository provides scripts for first‑time setup and automatic initialization of containers."
]