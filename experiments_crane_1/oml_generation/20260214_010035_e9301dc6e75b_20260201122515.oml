// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder monitoring hoist oscillation"
    DTDFVocab:producedData SwingAngleStream
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedStream
]

instance MotorPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Motor position sensor providing cart and hoist position data"
    DTDFVocab:producedData CartHoistMotorPositionStream
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Motor status sensor providing motor current and control state"
    DTDFVocab:producedData CartHoistMotorStatusStream
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance CartHoistMotorPositionStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionSensor
]

instance CartHoistMotorStatusStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance SwingAngleStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// Additional DataTransmitted for simulator outputs
instance SimulationOutputStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance ValidationMetricStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

// C10: Models/Data
instance MotorPositionTimeseries : DTDFVocab:Data [
    base:desc "TimescaleDB timeseries data of motor positions"
    DTDFVocab:fromData CartHoistMotorPositionStream
    DTDFVocab:inputTo LoggingEnabler
]

instance MotorStatusTimeseries : DTDFVocab:Data [
    base:desc "TimescaleDB timeseries data of motor status and currents"
    DTDFVocab:fromData CartHoistMotorStatusStream
    DTDFVocab:inputTo LoggingEnabler
]

instance SwingAngleTimeseries : DTDFVocab:Data [
    base:desc "TimescaleDB timeseries data of swing angle"
    DTDFVocab:fromData SwingAngleStream
    DTDFVocab:inputTo LoggingEnabler
]

instance WindSpeedTimeseries : DTDFVocab:Data [
    base:desc "TimescaleDB timeseries data of wind speed"
    DTDFVocab:fromData WindSpeedStream
    DTDFVocab:inputTo LoggingEnabler
]

instance SimulationOutputTimeseries : DTDFVocab:Data [
    base:desc "Simulation output timeseries capturing dynamic states"
    DTDFVocab:fromData SimulationOutputStream
    DTDFVocab:inputTo ValidationServiceEnabler
]

instance ValidationMetricTimeseries : DTDFVocab:Data [
    base:desc "Validation metrics comparing measured and simulated trajectories"
    DTDFVocab:fromData ValidationMetricStream
    DTDFVocab:inputTo DashboardEnabler
]

instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry exported from Autodesk Fusion360"
    DTDFVocab:inputTo DashboardEnabler
]

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Python–based kinematic model for optimal motion planning"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance SimulationDynamicModel : DTDFVocab:Model [
    base:desc "Discrete‑time simulation model of motor controllers and dynamics"
    DTDFVocab:inputTo SimulationServiceEnabler
]

// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart motor stepper driven via Trinamic TMC4671 controller"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist motor stepper driven via Trinamic TMC4671 controller"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet actuator for container pickup"
]

instance CraneInterfacePythonModule : DTDFVocab:ActingComponent [
    base:desc "Python module linking crane hardware to controller stacks"
]

// C11: Enablers
instance LoggingEnabler : DTDFVocab:Enabler [
    base:desc "Python‑based logging application persisting telemetry to TimescaleDB"
    DTDFVocab:enables DataLoggingService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python‑based trajectory generator using kinematic model"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationServiceEnabler : DTDFVocab:Enabler [
    base:desc "Real‑time simulation service for crane dynamics and control"
    DTDFVocab:enables SimulationService
]

instance ValidationServiceEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation service comparing measured and simulated trajectories"
    DTDFVocab:enables ContinuousValidationService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana–based visualization dashboard using TimescaleDB data"
    DTDFVocab:enables DashboardService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service communication"
    DTDFVocab:enables MQTTBrokerService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service for continuous timeseries persistence in TimescaleDB"
    DTDFVocab:provides DataLoggerStatusInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service providing optimal motion plan generation"
    DTDFVocab:provides TrajectoryPlanningInsight, ParameterTuningAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Real‑time simulation of crane dynamics and controller logic"
    DTDFVocab:provides SimulationPerformanceInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service performing distance‑metric validation between measured and simulated trajectories"
    DTDFVocab:provides RealTimeTrajectoryPerformanceMetrics, SwingingMotionIndicators, FaultProbabilityMetrics, ReplanTrajectoryAction, MaintenanceSchedulingAction
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Grafana‑based visualization of telemetry and validation metrics"
    DTDFVocab:provides VisualizationInsight
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "MQTT broker facilitating surface‑level event propagation"
    DTDFVocab:provides MessagePropagationInsight
]

// C17: Insights
instance RealTimeTrajectoryPerformanceMetrics : DTDFVocab:Insight [
    base:desc "Real‑time metrics of trajectory execution performance"
]

instance SwingingMotionIndicators : DTDFVocab:Insight [
    base:desc "Indicators of crane swing motion derived from encoder data"
]

instance FaultProbabilityMetrics : DTDFVocab:Insight [
    base:desc "Fault probability estimates from continuous validation thresholds"
]

instance DataLoggerStatusInsight : DTDFVocab:Insight [
    base:desc "Health status of the data logging application"
]

instance TrajectoryPlanningInsight : DTDFVocab:Insight [
    base:desc "Information on planned trajectories and their optimization context"
]

instance SimulationPerformanceInsight : DTDFVocab:Insight [
    base:desc "Performance metrics of the real‑time simulation engine"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of telemetry, simulation, and validation data"
]

instance MessagePropagationInsight : DTDFVocab:Insight [
    base:desc "Status of MQTT message propagation across services"
]

// C17: Actions
instance ReplanTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatically replan trajectory based on validation feedback"
    DTDFVocab:IsAutomatic true
]

instance MaintenanceSchedulingAction : DTDFVocab:Action [
    base:desc "Schedule maintenance when fault thresholds are exceeded"
    DTDFVocab:IsAutomatic true
]

instance ParameterTuningAction : DTDFVocab:Action [
    base:desc "Adjust operational parameters based on trend analysis"
    DTDFVocab:IsAutomatic false
]

// C5: Environment (holds system component)
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains LabScaleGantryCrane, CartStepperMotor, HoistStepperMotor, ElectromagnetActuator, CraneInterfacePythonModule
]

// C10: Main system component
instance LabScaleGantryCrane : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane digital twin exemplar, combining physical hardware and digital counterpart providing CAD models, kinematics, logging, visualization, trajectory generation, simulation, and validation"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory waypoints and control commands produced by the Trajectory Generator Service are transmitted over the Crane Interface to the motor controllers via serial/USB connections. Notifications (e.g., fault alerts) are sent to the operator through the Grafana dashboard. MQTT broker also conveys command and status messages between twin services and the physical interface."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in near real‑time; data is logged at the system’s physical command rate, trajectory generation and validation produce outputs within the same cycle, ensuring low‑latency feedback loops suitable for live operation and monitoring."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A Docker‑based microservice constellation orchestrated with docker‑compose: the TimescaleDB container, Mosquitto MQTT broker, Grafana dashboard; Python application containers (logging, trajectory, simulation, validation, crane interface); all co‑located on a single personal computer forming a cohesive, real‑time twin ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin lifecycle covers the as‑designed phase (CAD kinematic and control models), as‑manufactured phase (physical assembly and firmware integration), and as‑operated phase (runtime logging, continuous validation, and evolutionary updates)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service computes distance metrics between measured accelerations/positions and simulated counterparts, comparing them against predefined thresholds to trigger alerts. Validation relies on real‑world sensor data versus high‑fidelity simulation to assess model fidelity. No explicit uncertainty quantification beyond thresholding is reported."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical–digital communication via serial/USB to Arduino controllers; inter‑service messaging over MQTT (Eclipse Mosquitto); database access over PostgreSQL/SQL; docker networking provides isolated networks between containers. Data types include position, velocity, encoder counts, trajectory waypoints, and validation metrics."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Full codebase and required artefacts are hosted on GitHub (https://github.com/Cosys-Lab/lab-scale-gantry-crane). The Python gantrylib module is distributed via pip, the database, MQTT broker, and Grafana dashboards are containerised and deployed locally with docker‑compose on any Linux/Windows PC with Docker, enabling immediate local testing without additional infrastructure."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "No explicit integration with external digital twins or enterprise systems is described; all interactions are confined within the internal twin services and the local operator interface. Data export capabilities are available via TimescaleDB queries or Grafana dashboards."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The project adheres to open‑source standards: MQTT for messaging, TimescaleDB (PostgreSQL extension) for timeseries, Eclipse Mosquitto as the MQTT broker, and the GNU GPL‑like MIT license for source code. No formal industry‑level twin standards (e.g., ISA‑95, Asset Administration Shell) are referenced."
]