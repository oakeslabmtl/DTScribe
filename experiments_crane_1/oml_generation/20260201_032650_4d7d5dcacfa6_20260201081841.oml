// ------------------------------------------------------------
// Physical Sensing Components
// ------------------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder mounted on the crane hoist measuring the swinging motion of the load."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed near the gantry crane."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// ------------------------------------------------------------
// Data Transmitted (MQTT streams)
// ------------------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// ------------------------------------------------------------
// Persisted Data (TimescaleDB)
// ------------------------------------------------------------
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, GrafanaEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of ambient wind‑speed measurements."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, GrafanaEnabler
]

// ------------------------------------------------------------
// Acting Components (Physical Actuators)
// ------------------------------------------------------------
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the crane cart, controlled via TMC4671‑Eval motor controller."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist, controlled via TMC4671‑Eval motor controller."
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist end used to pick up containers."
]

// ------------------------------------------------------------
// Enablers (Tools & Infrastructure)
// ------------------------------------------------------------
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL‑based time‑series database) used to persist sensor and state data."
    DTDFVocab:enables DataLoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana instance for rendering dashboards from TimescaleDB data."
    DTDFVocab:enables GrafanaDashboardService
]

instance MosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for streaming sensor data to DT services."
    DTDFVocab:enables DataLoggingService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

instance GantryLibPythonEnabler : DTDFVocab:Enabler [
    base:desc "Python 'gantrylib' module providing APIs for the physical crane interface, trajectory generation and validation."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

// ------------------------------------------------------------
// Services (Digital Twin Functionality)
// ------------------------------------------------------------
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Python logging application that records incoming sensor streams and writes them to TimescaleDB."
    DTDFVocab:provides PersistDataAction
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana service visualising time‑series data from TimescaleDB for operators."
    DTDFVocab:provides DashboardVisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free trajectories based on the kinematic model."
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs a virtual crane/controller simulation using the kinematic and controller models."
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares measured trajectories against simulated ones and raises alerts on deviations."
    DTDFVocab:provides ModelMeasurementDeviationAlert, RaiseAlertAction
]

// ------------------------------------------------------------
// Insights & Actions
// ------------------------------------------------------------
instance PersistDataAction : DTDFVocab:Action [
    base:desc "Persist incoming sensor measurements into TimescaleDB."
    DTDFVocab:IsAutomatic true
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides real‑time visualization of swing angle, wind speed and motor states."
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal motion trajectories that minimise swing for a given load."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Provides simulated crane behaviour for comparison with real measurements."
]

instance ModelMeasurementDeviationAlert : DTDFVocab:Insight [
    base:desc "Alert indicating significant deviation between measured and simulated trajectories."
]

instance RaiseAlertAction : DTDFVocab:Action [
    base:desc "Notify operators about model‑measurement deviation."
    DTDFVocab:IsAutomatic true
]

// ------------------------------------------------------------
// Logical Container / Service Deployment Descriptions
// ------------------------------------------------------------
instance DatabaseContainer : DTDFVocab:Component [
    base:desc "Docker container running TimescaleDB for time‑series persistence."
]

instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Docker container running Eclipse Mosquitto MQTT broker."
]

instance GrafanaContainer : DTDFVocab:Component [
    base:desc "Docker container running Grafana for dashboard visualisation."
]

instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the Trajectory Generator Service."
]

instance SimulationContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the Simulation Service."
]

instance ContinuousValidationContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the Continuous Validation Service."
]

instance DataLoggingContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the Data Logging Service."
]

// ------------------------------------------------------------
// Environment (Logical Hosting)
// ------------------------------------------------------------
instance GantryCraneTwinEnvironment : DTDFVocab:Environment [
    base:contains DatabaseContainer, MQTTBrokerContainer, GrafanaContainer,
                 TrajectoryGeneratorContainer, SimulationContainer,
                 ContinuousValidationContainer, DataLoggingContainer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application and the Human‑Machine Interface (HMI) generate motion set‑points, trajectory commands and actuator commands (e.g., start/stop, electromagnet on/off). These commands are sent through the Physical Crane Interface to the motor controllers and the Arduino, which actuate the cart motor, hoist motor and electromagnet accordingly."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical crane ↔ Python interface ↔ Control, Logging, and HMI applications; services (trajectory, simulation, validation) communicate via MQTT; all persistent data stored in TimescaleDB; visualisation through Grafana; all components orchestrated on a single PC with Docker‑hosted database, broker and dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans design (CAD models of the crane), manufacture (BOM‑specified physical crane) and operation (real‑time data acquisition, continuous validation), providing a live as‑operated representation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares executed trajectories with simulated ones, computes distance metrics, checks against a predefined threshold, and notifies operators when the threshold is exceeded, ensuring model fidelity during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication uses MQTT (Eclipse Mosquitto) for signalling. The TimescaleDB database is accessed via standard PostgreSQL SQL connections over the local host network. The Physical Crane Interface communicates with the motor controllers and Arduino via Python (specific protocol not detailed in the document). Logging writes directly to the database; control commands are sent from the Control Application/HMI through the same interface to the hardware."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Docker containers host the TimescaleDB database, MQTT broker, and Grafana dashboard; the remaining Python applications run on the same host PC; deployment managed via a Docker‑Compose file; source code hosted publicly on GitHub."
]