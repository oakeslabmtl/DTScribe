// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoMeasurementShield : DTDFVocab:SensingComponent [
    base:desc "Arduino‑based shield providing motor state read‑backs"
    DTDFVocab:producedData MotorStateDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoMeasurementShield
]

// C10: Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of crane swing angle"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of wind speed"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance MotorStateData : DTDFVocab:Data [
    base:desc "Current, position, and state of cart and hoist stepper motors"
    DTDFVocab:fromData MotorStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance SimulationData : DTDFVocab:Data [
    base:desc "Simulated trajectory data generated by the Simulation Service"
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB PostgreSQL time‑series database used for logging sensor and state data"
    DTDFVocab:enables DataLoggingService, GrafanaDashboardService, ContinuousValidationService, SimulationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for service coordination and optional data streaming"
    DTDFVocab:enables DataLoggingService, ContinuousValidationService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Python Physical Crane Interface continuously reads controllers and sensors, publishing crane state to TimescaleDB and optionally via MQTT"
    DTDFVocab:provides DataRecordingInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana visualization dashboard displays live and historical sensor and state data"
    DTDFVocab:provides DashboardVisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free crane trajectories using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight, AdjustTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates crane dynamics based on the kinematic and physical models"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares measured trajectories with simulated ones and raises alerts on excessive deviation"
    DTDFVocab:provides RealTimeAlertInsight, AlertOperatorAction
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Human‑Machine Interface allows operator control and displays decision‑support insights"
    DTDFVocab:provides OperatorDecisionSupportInsight
]

// C17: Insights
instance DataRecordingInsight : DTDFVocab:Insight [
    base:desc "Indicates successful recording of crane state data into TimescaleDB"
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Shows historical and live data trends to support operator decisions"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Provides optimal swing‑free trajectory for container movement"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Delivers simulated crane motion data for validation and planning"
]

instance RealTimeAlertInsight : DTDFVocab:Insight [
    base:desc "Real‑time alerts when measured vs simulated trajectory deviation exceeds thresholds"
]

instance OperatorDecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Consolidated recommendation for operator based on validation alerts and trajectory options"
]

// C17: Actions
instance AlertOperatorAction : DTDFVocab:Action [
    base:desc "Automatically notifies operator of validation deviation via UI"
    DTDFVocab:IsAutomatic true
]

instance AdjustTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatically updates planned trajectory to stay within safe swing limits"
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart movement stepper motor controlled by TMC4671‑Eval controller"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist movement stepper motor controlled by TMC4671‑Eval controller"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist end used to pick up containers"
]

// C1: System under study (environment)
instance GantryCraneSystem : DTDFVocab:Environment [
    base:contains CartStepperMotor, HoistStepperMotor, ElectromagnetActuator, SwingAngleEncoder, Anemometer, ArduinoMeasurementShield
]

// C10: Models
instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator for optimal paths"
]

instance CADCraneModel : DTDFVocab:Model [
    base:desc "Autodesk Fusion 360 CAD model of the gantry crane"
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model producing predicted crane motion"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control Application and Trajectory Generator Service send motion commands (desired trajectories, start/stop signals) through the Physical Crane Interface to the motor controllers; the Continuous Validation Service can trigger operator alerts via the dashboard, influencing manual interventions."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A tightly coupled architecture where the physical crane is interfaced by a Python program, producing data stored in a TimescaleDB; services communicate via MQTT; the dashboard visualises data; trajectory generation and simulation services consume the model and database; continuous validation compares simulation output with logged measurements, all orchestrated on a single PC using Docker‑Compose."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service computes distance metrics between executed trajectories (logged from PT) and simulated trajectories (from the Simulation Service) and checks against a predefined threshold; breaches generate operator notifications, providing runtime fidelity assessment of the kinematic model."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between services uses MQTT ( Eclipse Mosquitto ) for signalling; the Physical Crane Interface accesses motor controllers and sensors via a Python program (likely serial/USB); data persistence uses SQL over TimescaleDB; dashboard accesses data via Grafana’s data source plugins."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All virtual components (database, MQTT broker, Grafana) are containerised with Docker and launched together via a Docker‑Compose file on a personal computer; the Python modules run natively; the entire stack is hosted on a GitHub repository with MIT licensing."
]