// Environment
instance LaboratoryScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains GantryAssembly, LinearActuatorRailDrive, LoadCarriage, GantryCraneController
]

// Components
instance GantryAssembly : DTDFVocab:Component [
    base:desc "Mechanical gantry assembly providing horizontal positioning structure"
]
instance LinearActuatorRailDrive : DTDFVocab:Component [
    base:desc "Linear actuator (rail drive) that moves the load carriage along the gantry"
]
instance LoadCarriage : DTDFVocab:Component [
    base:desc "Load carriage that propagates the payload along the rail"
]
instance GantryCraneController : DTDFVocab:Component [
    base:desc "Controller that manages actuator commands and overall crane operation"
]

// Sensing Component
instance PhysicalCraneInterface : DTDFVocab:SensingComponent [
    base:desc "Data interface that collects real-time state (position, speed, load, status) of the crane"
    DTDFVocab:producedData CraneStateDataTransmitted
]

// Data Transmitted
instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalCraneInterface
]

// Data
instance CraneStateData : DTDFVocab:Data [
    base:desc "Collected crane state data including pose, speed, load, and operational status"
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo KinematicModelingFrameworkEnabler, InfluxDBEnabler, TimescaleDBEnabler
]

// Models
instance ForwardKinematicsModel : DTDFVocab:Model [
    base:desc "Forward kinematics model that computes crane pose from actuator positions"
    DTDFVocab:inputTo KinematicModelingFrameworkEnabler
]
instance InverseKinematicsModel : DTDFVocab:Model [
    base:desc "Inverse kinematics model that determines actuator commands for desired pose"
    DTDFVocab:inputTo KinematicModelingFrameworkEnabler
]

// Enablers
instance CADToolEnabler : DTDFVocab:Enabler [
    base:desc "CAD tools used to generate the geometric representation of the crane"
    DTDFVocab:enables CADModelGenerationService
]
instance KinematicModelingFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Open-source kinematic modelling framework deriving forward and inverse kinematics"
    DTDFVocab:enables RealTimeMonitoringService, OptimalControlService
]
instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time-series database that stores real-time state data for monitoring and validation"
    DTDFVocab:enables RealTimeMonitoringService, ContinuousValidationService
]
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database that logs historical crane state for post-processing"
    DTDFVocab:enables HistoricalDataLoggingService
]
instance PythonDataVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Python-based data visualization library enabling dashboard creation"
    DTDFVocab:enables DataVisualizationService
]
instance ControlAlgorithmLibraryEnabler : DTDFVocab:Enabler [
    base:desc "Library containing optimal control algorithms for actuator command computation"
    DTDFVocab:enables OptimalControlService
]
instance SerialTCPProtocolEnabler : DTDFVocab:Enabler [
    base:desc "Serial or TCP/IP protocol stack facilitating communication between physical controller and digital twin"
    DTDFVocab:enables RealTimeMonitoringService, ContinuousValidationService
]

// Services
instance CADModelGenerationService : DTDFVocab:Service [
    base:desc "Service that generates CAD geometric models of the crane"
    DTDFVocab:provides CADModelInsight
]
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service that offers real-time monitoring of crane pose and load via dashboards"
    DTDFVocab:provides PoseMonitoringInsight, LoadMonitoringInsight
]
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal control module computing actuator commands to improve efficiency or reduce motion time"
    DTDFVocab:provides ControlCommandAdjustmentAction
]
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that logs historical crane state data for post-processing and analysis"
    DTDFVocab:provides HistoricalDataInsight
]
instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service that presents kinematic states and performance metrics through data visualization dashboards"
    DTDFVocab:provides VisualizationDashboardInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously validates simulated vs measured behavior, detecting drift or faults"
    DTDFVocab:provides DriftDetectionInsight, FaultDetectionAction
]

// Insights
instance PoseMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight into real-time accuracy of crane pose"
]
instance LoadMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight into load value and its dynamics during crane operation"
]
instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight derived from logged historical data for analysis"
]
instance VisualizationDashboardInsight : DTDFVocab:Insight [
    base:desc "Insight presented through visualization dashboards"
]
instance DriftDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight on drift between simulated and measured behavior indicating potential faults"
]
instance CADModelInsight : DTDFVocab:Insight [
    base:desc "Insight into generated CAD models of the crane"
]

// Actions
instance ControlCommandAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust actuator commands for optimal efficiency"
    DTDFVocab:IsAutomatic true
]
instance FaultDetectionAction : DTDFVocab:Action [
    base:desc "Action to trigger fault handling routines upon detecting deviations"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control Application receives trajectory commands from the Trajectory Generator Service and sends execution commands to the Physical Crane through the Python Physical Crane Interface. The Physical Crane executes these commands via its controller hardware. Feedback from the crane is read by the Physical Crane Interface and relayed back to the Control Application for monitoring."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All services communicate over a local network; an MQTT broker is used for inter-service messaging (e.g., between Simulation Service, Continuous Validation Service, and the Dashboard). The TimescaleDB database and Grafana dashboard also connect via standard database connections (e.g., PostgreSQL wire protocol). No explicit bandwidth, latency, or topology details are provided in the document."
]