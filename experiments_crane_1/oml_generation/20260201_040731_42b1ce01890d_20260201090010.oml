instance PhysicalCraneInterface : DTDFVocab:SensingComponent [
    base:desc "Python program that collects crane state data from physical crane"
    DTDFVocab:producedData CraneStateData
]

instance CraneStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalCraneInterface
]

instance CraneStateDataInTimescaleDB : DTDFVocab:Data [
    base:desc "Crane state data stored in TimescaleDB"
    DTDFVocab:fromData CraneStateData
    DTDFVocab:inputTo TimescaleDB
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB database for storing crane state data"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT message broker for communication between services"
    DTDFVocab:enables HistoricalDataLoggingService, RealTimeDataVisualizationService
]

instance LoggingApplication : DTDFVocab:Component [
    base:desc "Software application for logging crane data to TimescaleDB"
]

instance GantryCraneSystem : DTDFVocab:Environment [
    base:desc "Lab-scale gantry crane system serving as a CPS exemplar for digital twin research"
    base:contains PhysicalCrane, CraneController, LoggingApplication, PhysicalCraneInterface
]

instance PhysicalCrane : DTDFVocab:Component [
    base:desc "Physical component of the gantry crane system"
]

instance CraneController : DTDFVocab:Component [
    base:desc "Controller for the physical gantry crane"
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Provides optimal control for system optimization"
    DTDFVocab:provides SystemOptimization
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Logs crane state data to TimescaleDB for traceability"
    DTDFVocab:provides Traceability
]

instance RealTimeDataVisualizationService : DTDFVocab:Service [
    base:desc "Real-time data visualization for system monitoring"
    DTDFVocab:provides RuntimeVisualization
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation to ensure model accuracy against physical data"
    DTDFVocab:provides Simulation, Prediction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection to identify anomalies in the system"
    DTDFVocab:provides FaultDetection
]

instance SystemOptimization : DTDFVocab:Insight [
    base:desc "Optimal control for system optimization"
]

instance Traceability : DTDFVocab:Insight [
    base:desc "Traceability through historical data logging for system audit and analysis"
]

instance RuntimeVisualization : DTDFVocab:Insight [
    base:desc "Runtime visualization application for indoor air quality management in virus spread prevention context"
]

instance Simulation : DTDFVocab:Insight [
    base:desc "Simulation application for indoor air quality management in virus spread prevention context"
]

instance Prediction : DTDFVocab:Insight [
    base:desc "Prediction application for indoor air quality management in virus spread prevention context"
]

instance FaultDetection : DTDFVocab:Insight [
    base:desc "Fault detection to identify anomalies in the system"
]

instance GreenhouseSystemBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model of the actual greenhouse system"
    DTDFVocab:inputTo InfluxDB, ActiveMQ
]

instance DigitalTwinBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model of the digital twin"
    DTDFVocab:inputTo InfluxDB, ActiveMQ
]

instance InfluxDB : DTDFVocab:Enabler [
    base:desc "InfluxDB database for storing system data"
    DTDFVocab:enables DataStorageService
]

instance ActiveMQ : DTDFVocab:Enabler [
    base:desc "ActiveMQ message broker for data processing"
    DTDFVocab:enables DataProcessingService
]

instance VirtualMachines : DTDFVocab:Enabler [
    base:desc "Virtual machines hosting prerecorded data for deployment"
    DTDFVocab:enables DeploymentService
]

instance GitHub : DTDFVocab:Enabler [
    base:desc "GitHub for version control of digital twin models"
    DTDFVocab:enables ModelVersioningService
]

instance AutomationML : DTDFVocab:Enabler [
    base:desc "AutomationML for digital twin modeling"
    DTDFVocab:enables ModelCreationService
]

instance AzureTools : DTDFVocab:Enabler [
    base:desc "Microsoft Azure tools for digital twin pipeline implementation"
    DTDFVocab:enables DigitalTwinPipelineService
]

instance ModelVersioningService : DTDFVocab:Service [
    base:desc "Model versioning using GitHub"
    DTDFVocab:provides ModelVersioningInsight
]

instance ModelCreationService : DTDFVocab:Service [
    base:desc "Model creation using AutomationML"
    DTDFVocab:provides ModelCreationInsight
]

instance DigitalTwinPipelineService : DTDFVocab:Service [
    base:desc "Digital twin pipeline implementation using Azure tools"
    DTDFVocab:provides PipelineInsight
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Data storage using InfluxDB"
    DTDFVocab:provides DataStorageInsight
]

instance DataProcessingService : DTDFVocab:Service [
    base:desc "Data processing using ActiveMQ"
    DTDFVocab:provides DataProcessingInsight
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Deployment using virtual machines"
    DTDFVocab:provides DeploymentInsight
]

instance ModelVersioningInsight : DTDFVocab:Insight [
    base:desc "Version control of digital twin models using GitHub"
]

instance ModelCreationInsight : DTDFVocab:Insight [
    base:desc "Model creation using AutomationML"
]

instance PipelineInsight : DTDFVocab:Insight [
    base:desc "Digital twin pipeline implementation using Microsoft Azure tools"
]

instance DataStorageInsight : DTDFVocab:Insight [
    base:desc "Data storage in InfluxDB"
]

instance DataProcessingInsight : DTDFVocab:Insight [
    base:desc "Data processing via ActiveMQ message broker"
]

instance DeploymentInsight : DTDFVocab:Insight [
    base:desc "Deployment of data using virtual machines"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands from the Human Machine Interface (HMI) are processed by the Control Application, which utilizes the Physical Crane Interface to control the physical crane. Specific command types, message formats, validation, authentication, feedback systems, conflict resolution, and command execution confirmation mechanisms are not detailed in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Architecture visualized using the C4 Model context and container diagrams with an ad-hoc implementation utilizing containerization and virtualization technologies for component integration and resource management."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol facilitates inter-service communication via the MQTT Broker. TimescaleDB serves as the data storage layer, and Grafana is used for visualization. Network topology is centralized around the MQTT Broker. Specific bandwidth, latency, reliability, redundancy, and security protocols are not detailed in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems via Microsoft Azure tools for digital twin pipeline implementation, AutomationML standard for model-based interoperability, and ActiveMQ message broker for data exchange between physical sensors and digital twin components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with AutomationML standard for digital twin modeling as referenced in [14]."
]