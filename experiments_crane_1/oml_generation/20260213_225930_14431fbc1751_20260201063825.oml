// C2: Acting Components
instance StepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist mechanism, controlled via TMC4671‑Eval motor controller"
]

instance TMC4671EvalMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval motor controller providing current, speed, and position commands to the stepper motor"
]

instance GantryCraneMechanics : DTDFVocab:ActingComponent [
    base:desc "Physical crane framework including rails, trolley, winch, and load handling mechanisms"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the crane payload"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring ambient wind speed that may affect payload swing"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorStateFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Feedback sensor providing real‑time motor state (current, speed, position) from the stepper driver"
    DTDFVocab:producedData MotorStateDataTransmitted
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStateFeedbackSensor
]

// C10: Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurement from the encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed measurement from the anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, TimescaleDBEnabler
]

instance MotorStateData : DTDFVocab:Data [
    base:desc "Time‑stamped motor state (position, speed, current) feedback"
    DTDFVocab:fromData MotorStateDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, TimescaleDBEnabler
]

// C10: Models
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the gantry crane used to compute zero‑swing trajectories"
    DTDFVocab:inputTo TrajectoryEngineEnabler
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model reproducing crane and controller behaviour for what‑if analysis"
    DTDFVocab:inputTo SimulationEngineEnabler
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for real‑time streaming of sensor data and service messages"
    DTDFVocab:enables InterServiceCoordinationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB container providing PostgreSQL time‑series persistence for logged crane data"
    DTDFVocab:enables LoggingService
]

instance TrajectoryEngineEnabler : DTDFVocab:Enabler [
    base:desc "Software component executing the trajectory‑generation algorithm"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs the crane dynamic model"
    DTDFVocab:enables SimulationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Engine that compares live measurements with simulated trajectories and computes validation metrics"
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates swing‑free movement trajectories using the crane kinematic model"
    DTDFVocab:provides OptimalSwingFreeTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs the crane simulation model to predict dynamics for given trajectories"
    DTDFVocab:provides PredictedCraneBehaviorInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares measured trajectories against simulated ones and raises alerts on deviations"
    DTDFVocab:provides ValidationAlertInsight, SendValidationAlertAction
]

instance LoggingService : DTDFVocab:Service [
    base:desc "Continuously records sensor data into TimescaleDB for historical analysis"
    DTDFVocab:provides StoreHistoricalDataAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Displays real‑time measured vs. simulated trajectories on Grafana dashboards"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Accepts motion commands from the HMI and forwards them to the Physical Crane Interface"
    DTDFVocab:provides ExecuteMotionCommandAction
]

instance InterServiceCoordinationService : DTDFVocab:Service [
    base:desc "Coordinates inter‑service messaging via MQTT topics"
    DTDFVocab:provides AdjustTrajectoryAction
]

// C17: Insights
instance OptimalSwingFreeTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Computed optimal trajectory that eliminates residual swing during crane moves"
]

instance PredictedCraneBehaviorInsight : DTDFVocab:Insight [
    base:desc "Predicted crane dynamics and controller response for a given trajectory"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating that measured trajectory deviates beyond configured threshold from simulation"
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of measured versus simulated trajectories with confidence bounds"
]

// C17: Actions
instance StoreHistoricalDataAction : DTDFVocab:Action [
    base:desc "Persist time‑stamped sensor measurements into the TimescaleDB database"
    DTDFVocab:IsAutomatic true
]

instance ExecuteMotionCommandAction : DTDFVocab:Action [
    base:desc "Send motion command (position, speed) to the stepper motor via the Physical Crane Interface"
    DTDFVocab:IsAutomatic false
]

instance SendValidationAlertAction : DTDFVocab:Action [
    base:desc "Publish validation alert to MQTT and display it on the Grafana dashboard"
    DTDFVocab:IsAutomatic true
]

instance AdjustTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatically modify planned trajectory based on validation feedback to reduce swing"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin generates control commands through several services. The Trajectory Generator Service computes optimal movement trajectories (kinematic model, swing‑free) and forwards them to the Control Application. The Control Application uses the same Physical Crane Interface to transmit set‑point commands to the Arduino‑controlled motor controllers (cart and hoist) – presumably as serial command messages. Operators can also issue commands via the Human‑Machine Interface, which routes them through the Control Application. The Continuous Validation Service monitors execution and, when a threshold is breached, notifies the operator via the Grafana dashboard. No explicit command format, authentication, or confirmation protocol is described in the documents; the interaction assumes trusted local execution on the same host."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a container‑based microservice architecture orchestrated with Docker‑compose. Core services (Trajectory Generator, Simulation, Continuous Validation) communicate via an MQTT broker (publish‑subscribe) and share state through a TimescaleDB time‑series database. Results are visualized on a Grafana dashboard. Python applications implement the Physical Crane Interface, Control Application, Logging Application, and Human‑Machine Interface. This pattern provides a service‑oriented architecture with a central messaging bus and a shared data store for coordination and resource management."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through a Continuous Validation Service that continuously compares measured trajectory data from the physical crane with the simulated trajectories generated by the Simulation Service, computing distance metrics and checking them against a predefined acceptance threshold; violations trigger operator alerts via the Grafana dashboard. The trajectory generator’s requirement for zero residual swing defines a high‑fidelity kinematic constraint, and the validation process constitutes the primary verification method described for the twin’s analytical and behavioral models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All twin services are deployed as Docker containers on a single personal computer, forming a local Docker network. Communication among services uses: • MQTT (Eclipse Mosquitto) over TCP for signalling and data streaming; • PostgreSQL protocol for TimescaleDB access; • HTTP/HTTPS (Grafana dashboard) to query the database. The documents do not detail network topology beyond the single‑host Docker setup, nor do they specify bandwidth, latency, redundancy, or security mechanisms such as TLS or authentication for MQTT or database connections."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The exemplar runs on‑premise on a personal computer. Core components (TimescaleDB, Grafana, Eclipse Mosquitto) are containerised with Docker and orchestrated via a Docker‑Compose file that handles first‑time initialization. The Python‑based control, logging, and service applications are installed from the pip‑distributed gantrylib module and run directly on the host OS. Storage requirements are driven by TimescaleDB for time‑series logs; compute requirements are modest (a typical workstation can host all containers). Scalability is limited to adding more services or scaling containers manually; no cloud or auto‑scaling features are mentioned. Availability relies on Docker’s container lifecycle management, but explicit redundancy or high‑availability strategies are not described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external components is realized through standard tools and protocols: MQTT is used as the lightweight publish‑subscribe protocol for inter‑service communication; TimescaleDB (PostgreSQL extension) stores time‑series data; Grafana provides data visualization; Docker‑compose manages container deployment. No explicit coupling to external enterprise systems or other digital twins is documented."
]