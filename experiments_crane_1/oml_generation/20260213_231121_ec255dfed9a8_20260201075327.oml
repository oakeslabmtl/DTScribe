// ==============================
// C3: Physical sensing components
// ==============================
instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the horizontal position of the gantry crane trolley"
    DTDFVocab:producedData PositionDataTransmitted
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the velocity of the gantry crane motion"
    DTDFVocab:producedData VelocityDataTransmitted
]

instance CraneLoadSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the load carried by the crane hoist"
    DTDFVocab:producedData LoadDataTransmitted
]

// ==============================
// C4: Physical-to-virtual interaction (Data transmission)
// ==============================
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocitySensor
]

instance LoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneLoadSensor
]

// ==============================
// C10: Models / Data
// ==============================
instance PositionData : DTDFVocab:Data [
    base:desc "Time‑series of trolley position values"
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo DockerContainer_OptimalControl
]

instance VelocityData : DTDFVocab:Data [
    base:desc "Time‑series of crane velocity values"
    DTDFVocab:fromData VelocityDataTransmitted
    DTDFVocab:inputTo DockerContainer_OptimalControl
]

instance LoadData : DTDFVocab:Data [
    base:desc "Time‑series of hoist load values"
    DTDFVocab:fromData LoadDataTransmitted
    DTDFVocab:inputTo DockerContainer_Validation
]

instance CraneCADModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the gantry crane created in Autodesk Fusion 360"
    DTDFVocab:inputTo DockerContainer_Visualization
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Python‑based kinematic model representing the crane's motion dynamics"
    DTDFVocab:inputTo DockerContainer_OptimalControl
    DTDFVocab:inputTo DockerContainer_Validation
]

// ==============================
// C11: Enablers (tools / middleware)
// ==============================
instance MqttBroker : DTDFVocab:Enabler [
    base:desc "MQTT publish‑subscribe broker used to stream sensor data and control commands"
    DTDFVocab:enables OptimalControlService
    DTDFVocab:enables DataVisualizationService
    DTDFVocab:enables ContinuousValidationService
]

instance TimescaleDatabase : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance storing all time‑series measurements"
    DTDFVocab:enables HistoricalLoggingService
    DTDFVocab:enables ContinuousValidationService
]

instance DockerContainer_OptimalControl : DTDFVocab:Enabler [
    base:desc "Docker container hosting the Optimal Control Service"
    DTDFVocab:enables OptimalControlService
]

instance DockerContainer_HistoricalLogging : DTDFVocab:Enabler [
    base:desc "Docker container hosting the Historical Logging Service"
    DTDFVocab:enables HistoricalLoggingService
]

instance DockerContainer_Visualization : DTDFVocab:Enabler [
    base:desc "Docker container hosting the Data Visualization Service and Grafana dashboard"
    DTDFVocab:enables DataVisualizationService
]

instance DockerContainer_Validation : DTDFVocab:Enabler [
    base:desc "Docker container hosting the Continuous Validation Service"
    DTDFVocab:enables ContinuousValidationService
]

// ==============================
// C6: Services
// ==============================
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes optimal motion commands for the crane and sends them to the controller"
    DTDFVocab:provides OptimalTrajectoryInsight
    DTDFVocab:provides SendControlCommandAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Records sensor and actuation data over time into TimescaleDB for later analysis"
    DTDFVocab:provides HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Renders real‑time and historic crane state using the CAD and kinematic models via Grafana"
    DTDFVocab:provides RealTimeVisualizationInsight
    DTDFVocab:provides TriggerAlertAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares live crane measurements with the kinematic model and produces validation metrics"
    DTDFVocab:provides ValidationMetricInsight
    DTDFVocab:provides TriggerAlertAction
    DTDFVocab:provides NotifyOperatorAction
]

// ==============================
// C17: Insights / Actions
// ==============================
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight that provides the computed optimal trajectory for moving containers"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing historic sensor and actuator data for post‑hoc analysis"
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight delivering live visual representation of crane state on the dashboard"
]

instance ValidationMetricInsight : DTDFVocab:Insight [
    base:desc "Insight delivering validation metrics that quantify deviation between physical and simulated behavior"
]

instance SendControlCommandAction : DTDFVocab:Action [
    base:desc "Action that transmits computed control commands to the programmable crane controller"
    DTDFVocab:IsAutomatic true
]

instance TriggerAlertAction : DTDFVocab:Action [
    base:desc "Action that raises an alert on the dashboard when a validation metric exceeds its threshold"
    DTDFVocab:IsAutomatic true
]

instance NotifyOperatorAction : DTDFVocab:Action [
    base:desc "Action that notifies a human operator to take corrective measures"
    DTDFVocab:IsAutomatic false
]

// ==============================
// System under study: Physical components and environment
// ==============================
instance GantryFrame : DTDFVocab:Component [
    base:desc "Structural frame of the laboratory‑scale gantry crane"
]

instance Trolley : DTDFVocab:Component [
    base:desc "Mobile carriage that moves horizontally along the gantry frame"
]

instance Hoist : DTDFVocab:Component [
    base:desc "Vertical lifting mechanism driven by a motor"
]

instance ProgrammableController : DTDFVocab:Component [
    base:desc "On‑board controller that drives actuators based on received commands"
]

instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains GantryFrame, Trolley, Hoist, ProgrammableController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are issued from the Control Application, a Python application that uses the Physical Crane Interface to communicate with the crane controllers and drive the physical crane. The command types (e.g., movement trajectories) are generated by services such as the Trajectory Generator Service and sent through the Python interface; the documents do not specify command message formats, validation, authentication, or acknowledgment mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The gantry crane digital twin adopts an ad‑hoc orchestration approach rather than a commercial digital‑twin framework. Integration of the twin's software components is achieved through containerization, as mentioned in the discussion of similar design choices (e.g., use of containers for easy dissemination). The system architecture is described using the C4 model, providing context and container diagrams that capture the physical crane, the digital‑twin services, and their interaction points. Resource management and coordination rely on standard container techniques rather than a dedicated DT platform."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by a Continuous Validation Service that runs in parallel with the physical crane. After each executed trajectory, the service retrieves the corresponding simulated trajectory from the kinematic model, computes a distance metric (e.g., Euclidean deviation over time) between the measured sensor trace and the simulated trace, and compares the result against a predefined acceptable threshold. Deviations beyond the threshold trigger alerts and may initiate model parameter recalibration. Uncertainty sources such as sensor noise, encoder quantisation error, and simplifications in the kinematic equations are accounted for by the threshold setting and by periodic calibration of the sensors. This validation loop provides ongoing verification of both the model's accuracy and the integrity of the incoming data, forming the core of the Twin's quality‑assurance process."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital‑twin services (Trajectory Generator, Simulation, Continuous Validation) are organized as separate containers that exchange messages via an MQTT broker, which provides the signaling backbone for inter‑service communication. The Database (TimescaleDB) and Dashboard (Grafana) are also part of the container set. No explicit network topology, bandwidth, latency, redundancy, or security protocol details are given beyond the use of MQTT for internal messaging."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system is composed of multiple logical containers (Physical Crane Interface, Control Application, Logging Application, Human Machine Interface, Database, Dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service, MQTT Broker) implemented as Python applications and a TimescaleDB instance. The documents do not mention cloud, edge, or on‑premise hosting platforms, nor do they provide quantitative computational or storage requirements, scalability mechanisms, or availability guarantees."
]