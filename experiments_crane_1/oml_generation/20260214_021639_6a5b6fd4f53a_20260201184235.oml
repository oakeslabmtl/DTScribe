// C2: Acting Components
instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671-Eval controller for the crane's horizontal cart motor, interfacing with Arduino-based hardware for real-time actuation"
]

instance CartMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the horizontal movement of the crane's cart"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671-Eval controller for the crane's vertical hoist motor, interfacing with Arduino-based hardware for real-time actuation"
]

instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor controlling vertical lifting of the crane's hoist"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Mechanism that picks up and releases pucks (container analogs) for crane operations"
]

// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures angular position of the hoist swing for motion dynamics feedback"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Measures wind speed contributing to environmental data logging"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoMeasurementSystem : DTDFVocab:SensingComponent [
    base:desc "Arduino-based hardware collecting sensor data (swing angle, wind speed) and interfacing with crane controller"
    DTDFVocab:producedData CombinedSensorDataTransmitted
]

// C4: Data Transmission
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CombinedSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
    DTDFVocab:producedFrom ArduinoMeasurementSystem
]

// C10: Models/Data
instance CADModels : DTDFVocab:Model [
    base:desc "Autodesk Fusion 360 models representing the crane frame and components for structural representation"
    DTDFVocab:inputTo TimescaleDB
]

instance KinematicModels : DTDFVocab:Model [
    base:desc "Used by Trajectory Generator Service to compute optimal movement paths minimizing residual swinging motion"
]

instance SimulationModels : DTDFVocab:Model [
    base:desc "Implemented in Simulation Service to replicate crane dynamics for validation purposes"
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Current sensor readings (swing angle, wind speed) collected in real-time"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:fromData CombinedSensorDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance TrajectoryExecutionLogs : DTDFVocab:Data [
    base:desc "Logs of trajectory execution and validation metrics"
    DTDFVocab:fromData CombinedSensorDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance HistoricalData : DTDFVocab:Data [
    base:desc "Comprehensive time-series data archive including real-time sensor data and trajectory logs"
    DTDFVocab:fromData RealTimeSensorData
    DTDFVocab:fromData TrajectoryExecutionLogs
    DTDFVocab:inputTo TimescaleDB
]

// C11: Enablers
instance PythonGantryLib : DTDFVocab:Enabler [
    base:desc "Open-source Python module containing modular services for crane twin operations (logging, trajectory generation)"
    DTDFVocab:enables LoggingApplication, TrajectoryGeneratorService, SimulationService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "PostgreSQL-based TimescaleDB instance storing all logged data and serving as backbone for data retrieval"
    DTDFVocab:enables HistoricalData, TrajectoryExecutionLogs
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Data visualization platform displaying real-time and historical crane data with simulated confidence bounds"
]

instance EclipseMosquitto : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating inter-service communication between decentralized service containers"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, MQTTBrokerService, DashboardService
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal movement paths using kinematic models to minimize residual swinging motion"
    DTDFVocab:provides OptimalTrajectoryGeneration
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Replicates crane dynamics for validation against real-world performance"
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares real-world crane performance with simulations, triggering alerts for deviations"
    DTDFVocab:provides TrajectoryValidation
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Manages inter-service communication via MQTT protocol for decentralized service containers"
    DTDFVocab:provides MQTTSignaling
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Provides real-time and historical data visualization interface for operators"
    DTDFVocab:provides DataVisualization
]

instance LoggingApplication : DTDFVocab:Service [
    base:desc "Handles real-time sensor data collection and storage in TimescaleDB"
    DTDFVocab:provides HistoricalDataLogging
]

// C17: Insights/Actions
instance OptimalTrajectoryGeneration : DTDFVocab:Insight [
    base:desc "Suggests optimal paths minimizing residual motion (e.g., swing angle deviations)"
]

instance FaultDetection : DTDFVocab:Insight [
    base:desc "Uses time-series classification to localize system faults (e.g., motor issues)"
]

instance OperationalAlerts : DTDFVocab:Action [
    base:desc "Notifies operators of threshold breaches (e.g., unexpected wind speed affecting crane stability)"
    DTDFVocab:IsAutomatic true
]

instance HistoricalAnalysis : DTDFVocab:Insight [
    base:desc "Enables offline analysis of past operations (e.g., identifying recurring faults or inefficiencies)"
]

instance TrajectoryValidation : DTDFVocab:Action [
    base:desc "Compares real-world performance with simulated trajectories for continuous validation"
    DTDFVocab:IsAutomatic true
]

// C12: Environment
instance CraneLabEnvironment : DTDFVocab:Environment [
    base:contains SwingAngleEncoder, Anemometer, ArduinoMeasurementSystem,
        CartMotorController, CartMotor, HoistMotorController, HoistMotor,
        Electromagnet, CADModels, KinematicModels, SimulationModels
]

instance PortOfAntwerpSimulator : DTDFVocab:Environment [
    base:desc "Digital twin environment inspired by harbor cranes in the port of Antwerp"
    base:contains CraneLabEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin interacts with the physical system through:
  - **Trajectory Generation Service**: Sends optimized movement trajectories (kinematics-based) to the **Control Application**, which executes them via the crane's motor controllers.
  - **Continuous Validation Service**: Compares real-time sensor data with simulated trajectories to detect deviations; alerts operators via the **Dashboard** if thresholds are breached.
  - **Simulation Service**: Provides virtual simulations of crane behavior to validate control strategies before physical execution."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twinning time scale is **real-time to near-real-time**:
  - **Data logging frequency**: Continuous (sensor data sampled at unspecified but high intervals, likely sub-second).
  - **Trajectory generation and validation**: Executed in real-time during operation, with validation metrics updated dynamically.
  - **Simulation synchronization**: Aligned with physical execution; validation thresholds are checked per trajectory segment."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation is structured as follows:
  - **Physical Twin (PT)**: The lab-scale gantry crane hardware (frame, motors, controllers, sensors).
  - **Digital Twin (DT) Core**:
    - **Data Layer**: **TimescaleDB** database storing all logged data.
    - **Service Layer**:
      - **Trajectory Generator Service** (kinematic model-based).
      - **Simulation Service** (virtual crane dynamics).
      - **Continuous Validation Service** (real-time deviation detection).
      - **MQTT Broker** (inter-service communication).
    - **Visualization Layer**: **Grafana Dashboard** for operator monitoring.
  - **Human Interface**: **Human Machine Interface (HMI)** for operator control and configuration."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin covers the following lifecycle stages of its physical counterpart:
  - **As Designed**: Kinematic models and CAD models (Autodesk Fusion 360) represent idealized crane behavior.
  - **As Manufactured**: Physical hardware components (motors, controllers, Arduino) are validated via the **Continuous Validation Service** during operation.
  - **As Operated**: Real-time data logging, trajectory optimization, and fault detection occur during runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are addressed through:
  - **Model Validation**: The **Continuous Validation Service** compares real-world crane data with simulated trajectories, using distance metrics to quantify deviations.
  - **Uncertainty Handling**: Simulation models are used to predict confidence bounds (e.g., trajectory execution errors) displayed on the dashboard.
  - **Verification/Validation Methods**:
    - Kinematic models ensure optimal trajectory generation.
    - Historical data logging enables offline validation of control strategies.
  - **Threshold-Based Alerts**: Operators are notified if real-world performance breaches predefined thresholds (e.g., swing angle deviations)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Technical connections between the physical and digital twin are established via:
  - **Network Protocols**:
    - **MQTT** for inter-service communication between DT services.
    - **HTTP/REST** for database queries (TimescaleDB).
  - **Physical Interface**: Python-based **Physical Crane Interface** connects Arduino sensors/controllers to the Python services via serial communication.
  - **Real-Time Synchronization**: Data streams are synchronized with physical execution timelines, ensuring real-time alignment."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is hosted and deployed on:
  - **Single-Personal-Computer Setup**: All services (Python containers, database, MQTT broker) run on a single machine via Docker containers.
  - **Docker Compose**: Automates container startup/shutdown with a single command; initializes database and dashboard configurations.
  - **Open-Source Tools**: No proprietary frameworks are used; relies on:
    - **Python** (gantrylib module).
    - **TimescaleDB** (PostgreSQL-based).
    - **Grafana** (visualization).
    - **Eclipse Mosquitto** (MQTT broker)."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration with external systems is **not explicitly documented** in the provided context. The exemplar focuses solely on the lab-scale gantry crane and its immediate digital twin services."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership is **not explicitly defined** in the documents. The digital twin logs data to **TimescaleDB**, which is presumably owned by the system operator (University of Antwerp). Privacy considerations are not addressed; the exemplar uses open-source tools and does not mention encryption or access controls."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplar follows **ad-hoc standardization** rather than formal digital twin frameworks:
  - **No Industry Standards**: Uses open-source tools (Python, TimescaleDB, Grafana, MQTT) without adherence to frameworks like Eclipse Ditto or BaSyx.
  - **Custom Protocols**: MQTT is used for inter-service communication, but no standardized digital twin protocols are enforced.
  - **Model-Based Systems Engineering**: Capella models (Arcadia folder) are used for system architecture visualization but are not standardized for digital twin use."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety considerations include:
  - **Remote Operation**: The digital twin can execute commands remotely (e.g., trajectory generation) on the physical crane, but **no explicit safety protocols** are mentioned for human-in-the-loop operations (e.g., emergency stops).
  - **Data Integrity**: Continuous validation ensures model fidelity, but **no encryption** is described for data in transit or at rest.
  - **Fault Isolation**: The **Continuous Validation Service** detects deviations, but **no fail-safes** are specified for critical failures (e.g., motor overload)."
]