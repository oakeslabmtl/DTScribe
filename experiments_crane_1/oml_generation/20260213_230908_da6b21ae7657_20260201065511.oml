// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring the crane’s pendulum angle"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer recording ambient wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: DataTransmitted from sensors
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C5: Data instances derived from DataTransmitted
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Timestamped swing angle measurements forwarded by Arduino to MQTT broker"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Timestamped wind speed measurements forwarded by Arduino to MQTT broker"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C2: Acting component
instance GantryCraneActuator : DTDFVocab:ActingComponent [
    base:desc "Controller‑driven actuators that move the gantry crane along predefined tracks"
]

// C6: Physical‑to‑virtual interaction (crane state logging)
instance PhysicalCraneInterface : DTDFVocab:SystemComponent [
    base:desc "Python program that connects to crane controllers and provides the physical crane state"
]

instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalCraneInterface
]

instance CraneStateData : DTDFVocab:Data [
    base:desc "Raw sensor and status information from crane controllers (position, velocity) collected by the Physical Crane Interface"
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database storing historical sensor and actuator data"
    DTDFVocab:enables LoggingService
]

instance DockerRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Docker container runtime hosting the digital‑twin services and models"
    DTDFVocab:enables OptimalControlService, RealTimeVisualizationService, ContinuousValidationService, PredictionService
]

// C6: Services and associated insights / actions
instance LoggingService : DTDFVocab:Service [
    base:desc "Historical data logging service that persists sensor and actuator streams into TimescaleDB"
    DTDFVocab:provides DataStorageInsight
]

instance DataStorageInsight : DTDFVocab:Insight [
    base:desc "Stored time‑series data can be queried for analysis and model calibration"
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal control service that computes motion commands for the crane and sends them to the controller"
    DTDFVocab:provides ControlInsight
]

instance ControlInsight : DTDFVocab:Insight [
    base:desc "Computed optimal motion trajectories for the gantry crane"
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization service displaying the crane’s pose and trajectories on web dashboards"
    DTDFVocab:provides RuntimeVisualizationInsight
]

instance RuntimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live visualisation of sensor streams and crane trajectories for operators"
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service that checks runtime data against the kinematic model and flags deviations"
    DTDFVocab:provides ValidationInsight
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Reports mismatches between observed crane behaviour and the kinematic model"
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Prediction service that forecasts key variables and triggers operator alerts"
    DTDFVocab:provides PredictionInsight, PreventiveOperatorAction
]

instance PredictionInsight : DTDFVocab:Insight [
    base:desc "Predicts future crane states to support preventive decision making"
]

instance PreventiveOperatorAction : DTDFVocab:Action [
    base:desc "Automatic alert prompting operator intervention when predicted thresholds are exceeded"
    DTDFVocab:IsAutomatic true
]

// C10: Models/Data
instance CadGeometryModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the laboratory‑scale gantry crane"
    DTDFVocab:inputTo DockerRuntimeEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Physics‑based kinematic model used for simulation and validation of crane motion"
    DTDFVocab:inputTo DockerRuntimeEnabler
]

// C13: Physical components and environment
instance GantryCraneMechanism : DTDFVocab:SystemComponent [
    base:desc "Physical gantry crane mechanism with motorised drives and miniature container pucks"
]

instance ArduinoBoard : DTDFVocab:SystemComponent [
    base:desc "Arduino board interfacing swing‑angle encoder and anemometer, timestamping and publishing measurements via MQTT"
]

instance LabGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains GantryCraneMechanism, ArduinoBoard, PhysicalCraneInterface, GantryCraneActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, also a Python program, receives control commands (e.g., movement trajectories generated by the Trajectory Generator Service or issued by the Human‑Machine Interface) and forwards them to the Physical Crane Interface, which transmits the commands to the crane controllers to actuate the hardware. Commands are represented as trajectory parameters derived from the crane’s kinematics model. The documents do not detail the exact command message format, validation, authentication, conflict‑resolution, or acknowledgment mechanisms for command execution."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The exemplars adopt an ad‑hoc orchestration built on containerization or virtual‑machine deployment. Measurements are stored in an InfluxDB time‑series database and exchanged via an ActiveMQ message broker. The air‑quality exemplar additionally uses Microsoft Azure tools to implement its pipeline, while the greenhouse exemplar runs on virtual machines supplied with prerecorded data. No dedicated commercial digital‑twin framework is employed; the system consists of independently deployed components that communicate through the broker and shared database."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The gantry‑crane digital‑twin follows an ad‑hoc lifecycle that starts with an initial prototype where the physical crane and a CAD geometry model are created. A subsequent stage introduces an Arcadia behavioural model to capture motion logic. The twin is then containerised (Docker) and synchronised with the physical system via an ActiveMQ broker. Each phase is version‑controlled on GitHub, allowing transition management by updating the Docker image and the associated model artefacts. Governance is informal, relying on the repository’s commit history and issue tracking to coordinate development and deployment."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin includes a continuous validation service that compares live data from the crane against the CAD and kinematic models to assess model fidelity. Historical data logging supports post‑run verification and error analysis. The exemplar has been employed in research on validation methods, fault detection, and system evolution notation, indicating that model verification and uncertainty assessment are integral parts of the twin, though specific validation procedures or quantitative fidelity thresholds are not detailed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital‑twin services (Trajectory Generator, Simulation, Continuous Validation, MQTT broker, dashboard, database) run as separate containers/processes on the same host and communicate via an MQTT broker using a publish/subscribe pattern for inter‑service signaling (e.g., trajectory requests, validation results). No further information is provided about network topology, bandwidth, latency requirements, redundancy, or security protocols for the communication infrastructure."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system consists of multiple Python applications (Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface) and services (Trajectory Generator, Simulation, Continuous Validation, MQTT broker) together with a TimescaleDB database and a Grafana dashboard, deployed as containers or local processes on a single host. The documents do not specify whether the host is cloud, edge, or on‑premise, nor do they describe scalability mechanisms, deployment models, or availability/reliability guarantees."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Physical sensor data are acquired by a Raspberry‑Pi (air‑quality exemplar) or greenhouse sensors and transmitted to the digital twin through an ActiveMQ message broker. The twin persists the data in an InfluxDB time‑series database. The air‑quality twin model is defined using AutomationML, providing a standardized model‑exchange format. Microsoft Azure services are employed to host parts of the pipeline, enabling cloud‑based integration. All code and configuration are released on GitHub, facilitating reuse and integration with other open‑source tools."
]