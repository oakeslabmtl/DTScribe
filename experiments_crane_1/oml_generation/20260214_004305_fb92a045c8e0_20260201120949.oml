// C3: Physical sensing components
instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Reads real‑time position of the crane from the embedded controller."
    DTDFVocab:producedData PositionDataTransmitted
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Reads real‑time velocity of the crane from the embedded controller."
    DTDFVocab:producedData VelocityDataTransmitted
]

instance LoadSensor : DTDFVocab:SensingComponent [
    base:desc "Reads real‑time load metrics of the crane from the embedded controller."
    DTDFVocab:producedData LoadDataTransmitted
]

// C4: Physical-to-virtual interaction
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySensor
]

instance LoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadSensor
]

// C10: Models/Data
instance PositionData : DTDFVocab:Data [
    base:desc "Position time‑series stored in TimescaleDB."
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo MonitoringEnabler, OptimizationEnabler, ValidationEnabler
]

instance VelocityData : DTDFVocab:Data [
    base:desc "Velocity time‑series stored in TimescaleDB."
    DTDFVocab:fromData VelocityDataTransmitted
    DTDFVocab:inputTo MonitoringEnabler, OptimizationEnabler, ValidationEnabler
]

instance LoadData : DTDFVocab:Data [
    base:desc "Load metric time‑series stored in TimescaleDB."
    DTDFVocab:fromData LoadDataTransmitted
    DTDFVocab:inputTo MonitoringEnabler, ValidationEnabler
]

// C11: Enablers
instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Python logging application that persists sensor streams into TimescaleDB."
    DTDFVocab:enables RealTimeMonitoringService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Kinematic model execution engine that solves crane equations for trajectory plans."
    DTDFVocab:enables TrajectoryOptimizationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Validation engine that compares live sensor data against the CAD/kinematic model."
    DTDFVocab:enables ContinuousValidationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3‑D viewer that renders the crane pose and simulation results."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continually logs crane state data for historical analysis and real‑time monitoring."
    DTDFVocab:provides MonitoringInsight
]

instance TrajectoryOptimizationService : DTDFVocab:Service [
    base:desc "Computes optimized trajectory plans that minimize time or energy use."
    DTDFVocab:provides GenerateTrajectoryPlanAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Detects discrepancies between sensor measurements and the kinematic model."
    DTDFVocab:provides FaultDetectionInsight, TriggerFaultAlertAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Renders the crane pose and simulation outcomes in a 3‑D viewer for users."
    DTDFVocab:provides PoseVisualizationInsight
]

// C17: Insights/Actions
instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Provides historical analysis of crane state logs."
]

instance GenerateTrajectoryPlanAction : DTDFVocab:Action [
    base:desc "Automatically generates a trajectory plan for the crane."
    DTDFVocab:IsAutomatic true
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects faults by comparing live data with the CAD/kinematic model."
]

instance TriggerFaultAlertAction : DTDFVocab:Action [
    base:desc "Triggers an alert when a fault is detected."
    DTDFVocab:IsAutomatic true
]

instance PoseVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualizes the current pose of the crane in real-time."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin’s Control Application, also written in Python, consumes optimal movement trajectories generated by the Trajectory Generator Service. The Control Application sends movement commands—typically a sequence of target positions or waypoints—through the Physical Crane Interface to the actual crane controllers. Feedback from the physical crane is streamed back to the Control Application, enabling real–time monitoring. The document does not specify authentication, validation, or conflict‑resolution mechanisms for these control messages."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "GreenhouseDT orchestrates its Digital Twin and physical greenhouse through a modular, micro‑service architecture running inside a single virtual machine. The twin system ingests sensor telemetry delivered by the physical greenhouse via an ActiveMQ message broker. InfluxDB serves as the central time‑series database, storing raw readings and derived inference metrics. Each functional block – sensor aggregation, state inference, rule‑based adaptation, and runtime visualization – is deployed as a Docker container managed by Docker Compose, enabling isolated services that can be independently scaled or replaced. Synchronisation between the physical and virtual realms occurs through the message timestamps embedded in the broker messages; the twin applies a 100 ms latency budget to align data streams, and periodic adaptation cycles execute every 5 seconds based on the most recent aggregated state. The orchestrator ensures graceful shutdown and restart of services, preserving consistency across the twin ecosystem."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication is orchestrated via an MQTT broker, which routes signals between the various Digital Twin containers (Trajectory Generator Service, Simulation Service, Continuous Validation Service, etc.). The system persists data in a TimescaleDB database and visualises it on a Grafana dashboard. The document does not provide additional details on network topology, bandwidth, latency, reliability, or security protocols."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Air Quality Management exemplar integrates with external systems using several industry‑standard protocols and services. Sensor data from a Raspberry‑Pi is transmitted over MQTT with TLS encryption to Azure IoT Hub. The twin is modeled in AutomationML, providing semantic interoperability for building automation and facility management systems. Azure Stream Analytics performs real‑time transformations and feeds the results back into the twin via Azure Functions, which then trigger predictive models and update the twin state. Data persistence occurs in Azure Table Storage, while the twin exposes RESTful APIs for external ERP or CMMS integration. ActiveMQ is also employed within the GreenhouseDT context to broadcast events to any collaborating systems, ensuring loose coupling and extensibility across the enterprise landscape."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The indoor air quality digital twin conforms to the AutomationML open‑standard for modeling automation systems, providing a machine‑readable, interoperable twin representation. This standardisation choice facilitates the exchange of twin data with conventional building management systems. The use of InfluxDB and ActiveMQ indicates adherence to the standard protocols of time‑series database systems and the OpenWire protocol stack for messaging, respectively, though explicit industry certification is not reported."
]