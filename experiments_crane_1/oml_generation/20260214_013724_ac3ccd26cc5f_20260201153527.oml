    DTDFVocab:provides FaultDetectionInsight, PredictiveMaintenanceAction
]

instance GantryCraneSystemEvolutionService : DTDFVocab:Service [
    base:desc "Service tracking evolutionary changes to the digital twin using DarTwin notation for model versioning, rollbacks, and impact analysis."
    DTDFVocab:provides SystemEvolutionInsight, ModelUpdateAction
]

instance GantryCranePhysicalToVirtualInteractionService : DTDFVocab:Service [
    base:desc "Service managing real-time data transmission from physical crane to digital twin via MQTT broker with millisecond-level latency for synchronization."
