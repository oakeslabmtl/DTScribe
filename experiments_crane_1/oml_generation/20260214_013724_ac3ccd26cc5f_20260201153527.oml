]

instance ROSControlFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "ROS Control framework for real-time execution of optimal control algorithms (LQR, MPC) on the gantry crane with sub-100ms latency."
    DTDFVocab:enables GantryCraneOptimalControlService, GantryCraneFaultDetectionService
]

instance TimescaleDBStorageEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time-series database for storing high-frequency crane operation logs with SQL capabilities for complex query optimization."
