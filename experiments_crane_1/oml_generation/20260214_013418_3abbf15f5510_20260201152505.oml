// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder to measure hoist sway on the gantry crane"
    DTDFVocab:producedData SwingAngleTelemetry
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer for measuring wind speed around the crane platform"
    DTDFVocab:producedData WindSpeedTelemetry
]

instance CartMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder for the cart motor used in horizontal X/Y motion"
    DTDFVocab:producedData CartPositionTelemetry
]

instance HoistMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder for the hoist motor used in vertical motion"
    DTDFVocab:producedData HoistPositionTelemetry
]

// C2: Acting components
instance CartMotor : DTDFVocab:ActingComponent [
    base:desc "Electric cart motor driven by a TMC4671‑Eval stepper driver"
]

instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Electric hoist motor driven by a TMC4671‑Eval stepper driver"
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance SwingAngleTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CartPositionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoder
]

instance HoistPositionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoder
]

// C4: Data
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series database record of swing‑angle measurements"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData SwingAngleTelemetry
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series database record of wind‑speed readings"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData WindSpeedTelemetry
]

instance CartPositionTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series database record of cart position and speed"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData CartPositionTelemetry
]

instance HoistPositionTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series database record of hoist position and speed"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData HoistPositionTelemetry
]

// C10: Models/Data
instance CADGeometricCraneModel : DTDFVocab:Model [
    base:desc "Autodesk Fusion 360 CAD geometric model of the gantry crane used for kinematic calculations"
    DTDFVocab:inputTo PythonEnvironmentEnabler
]

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the trajectory generator to calculate optimal paths"
    DTDFVocab:inputTo PythonEnvironmentEnabler
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model for off‑line dynamics prediction of the crane"
    DTDFVocab:inputTo PythonEnvironmentEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL‑based) used for persistent time‑series storage"
    DTDFVocab:enables DataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker that relays sensor events among services"
    DTDFVocab:enables DataLoggingService, ControlApplicationService
]

instance PythonEnvironmentEnabler : DTDFVocab:Enabler [
    base:desc "Python (gantrylib) runtime environment hosting trajectory generation and simulation services"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ControlApplicationService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard runtime that visualizes time‑series data from TimescaleDB"
    DTDFVocab:enables RealTimeVisualizationService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs real‑time sensor and actuator states to TimescaleDB and publishes updates via MQTT"
    DTDFVocab:provides DataRecordingInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal crane trajectories using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs off‑line physics‑based simulations to predict crane dynamics"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates executed trajectories against simulation results"
    DTDFVocab:provides ValidationDeviationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults by comparing cart/hoist positions to thresholds using time‑series classification"
    DTDFVocab:provides FaultAlertInsight
]

instance ControlApplicationService : DTDFVocab:Service [
    base:desc "Translates trajectory commands into motor step pulses for the cart and hoist"
    DTDFVocab:provides ExecuteControlCommandAction
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Publishes real‑time visualizations of sensor data and system performance via Grafana"
    DTDFVocab:provides PerformanceDashboardInsight
]

// C17: Insights/Actions
instance DataRecordingInsight : DTDFVocab:Insight [
    base:desc "Confirmation that data has been persisted to TimescaleDB"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Suggestion of an optimal trajectory for moving pucks between predefined locations"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Result of off‑line physical simulation of crane dynamics"
]

instance ValidationDeviationInsight : DTDFVocab:Insight [
    base:desc "Deviation metrics between executed trajectories and simulated ones for continuous validation"
]

instance FaultAlertInsight : DTDFVocab:Insight [
    base:desc "Alert that a fault has been detected based on threshold‑based distance metrics"
]

instance PerformanceDashboardInsight : DTDFVocab:Insight [
    base:desc "Statistical dashboard of crane performance generated by Grafana"
]

instance ExecuteControlCommandAction : DTDFVocab:Action [
    base:desc "Automatic forwarding of trajectory control commands to the cart and hoist motors"
    DTDFVocab:IsAutomatic true
]

instance ThresholdAlertAction : DTDFVocab:Action [
    base:desc "Automatic real‑time alert for threshold breaches in swing angle or wind speed"
    DTDFVocab:IsAutomatic true
]

instance FaultAlertAction : DTDFVocab:Action [
    base:desc "Automatic real‑time fault alert triggered by the FaultDetectionService"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control Application publishes motion commands (e.g., desired cart/hoist trajectories) to the Physical Crane Interface via MQTT or direct API calls; the Trajectory Generator Service produces optimal swing‑free trajectories that are sent to the Control Application for execution."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates in near real‑time, with sensor loops at roughly 10 Hz. Trajectory generation, simulation, and validation run on each command cycle or per trajectory event, typically within milliseconds to reach to tens of milliseconds. Data logging and visualization are instantaneously reflected in Grafana; alerting is immediate (within one processing cycle)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is orchestrated via Docker Compose: ten containers (Database, MQTT Broker, Dashboard, Trajectory Generator, Simulation, Continuous Validation, Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface) interconnected through the Docker network; physical side uses a Python interface to the Arduino‑based controller."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Designed phase – CAD models (Autodesk Fusion 360) and kinematic model; Manufactured phase – physical assembly of crane components; Operated phase – live logging, simulation and continuous validation during crane operation; the DT encompasses all three phases by mirroring the physical counterpart at each lifecycle stage."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service computes distance metrics between measured and simulated trajectories, comparing to an acceptable threshold; deviations trigger dashboard notifications; the kinematic model is validated against CAD geometry; all models are open‑source for peer verification."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical → Digital: UART/USB serial communication between Arduino controller and PC Python interface, with data packaged and written to TimescaleDB; Digital → Physical: MQTT topics (published by DT services) consumed by Control Application; internal DT services communicate via Docker networking; timeseries queries use PostgreSQL protocol."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT services are containerized and deployed locally on a personal computer via Docker Compose; the entire stack is hosted in a public GitHub repository with open‑source licensing (MIT)."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not documented; the exemplar focuses on a stand‑alone system without external DT or enterprise integration."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not documented; no explicit statement on data ownership or privacy policies."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Not explicitly referenced. The tools used (Docker, MQTT, TimescaleDB, Grafana, Python) are open standards but the crane model does not adhere to any industrial digital‑twin standard such as Eclipse Ditto or Basyx."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Not explicitly documented; the system is locally deployed, but no mention of remote execution safety or cybersecurity measures beyond standard MQTT broker usage."
]