// ----------------------------------------------------------
// C3: Physical sensing components
// ----------------------------------------------------------

instance SwingAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder mounted on the crane to measure payload sway."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer that records ambient airflow affecting crane dynamics."
    DTDFVocab:producedData AnemometerDataTransmitted
]

instance ElectromagnetStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting the on/off state of the crane electromagnet."
    DTDFVocab:producedData ElectromagnetStateDataTransmitted
]

// ----------------------------------------------------------
// C4: Physical-to-virtual interaction (DataTransmitted)
// ----------------------------------------------------------

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensor
]

instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance ElectromagnetStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ElectromagnetStateSensor
]

// ----------------------------------------------------------
// C10: Data (sensor measurements)
// ----------------------------------------------------------

instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Angular position measurements of the payload swing (degrees)."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance AnemometerMeasurement : DTDFVocab:Data [
    base:desc "Airflow speed readings (m·s⁻¹) captured by the anemometer."
    DTDFVocab:fromData AnemometerDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance ElectromagnetStateMeasurement : DTDFVocab:Data [
    base:desc "Binary state (on/off) of the electromagnet."
    DTDFVocab:fromData ElectromagnetStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// ----------------------------------------------------------
// C2: Acting components
// ----------------------------------------------------------

instance XAxisStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the X‑axis movement of the gantry, sub‑millimetre precision."
]

instance YAxisStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the Y‑axis movement of the gantry, sub‑millimetre precision."
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end‑effector used to pick up and release payloads."
]

// ----------------------------------------------------------
// C10: Models
// ----------------------------------------------------------

instance CADModelGantryCrane : DTDFVocab:Model [
    base:desc "Geometric CAD model of the lab‑scale gantry crane."
    DTDFVocab:inputTo DockerContainerEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model capturing the crane’s motion for validation and control."
    DTDFVocab:inputTo DockerContainerEnabler, TimescaleDBEnabler
]

// ----------------------------------------------------------
// C11: Enablers
// ----------------------------------------------------------

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance that stores streamed sensor and actuation data."
    DTDFVocab:enables HistoricalDataLoggingService,
                     ContinuousValidationService,
                     DataVisualizationService
]

instance DockerContainerEnabler : DTDFVocab:Enabler [
    base:desc "Docker container runtime hosting the twin’s micro‑services."
    DTDFVocab:enables OptimalControlService,
                     SimulationService,
                     PredictionService
]

instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database used by the prediction module."
    DTDFVocab:enables PredictionService
]

// ----------------------------------------------------------
// C6: Services
// ----------------------------------------------------------

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that records sensor and actuation data into TimescaleDB."
    DTDFVocab:provides LoggingInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously compares real‑time measurements with the kinematic model to detect deviations."
    DTDFVocab:provides ValidationInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service that displays live sensor readings and system state on a web‑based dashboard."
    DTDFVocab:provides VisualizationDashboardInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service that computes optimal motion commands and sends them to the crane controller."
    DTDFVocab:provides AdjustActuatorAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that executes what‑if scenarios using the CAD and kinematic models."
    DTDFVocab:provides SimulationInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Service that extrapolates future environmental conditions based on historical data in InfluxDB."
    DTDFVocab:provides PredictionInsight
]

// ----------------------------------------------------------
// C17: Insights
// ----------------------------------------------------------

instance LoggingInsight : DTDFVocab:Insight [
    base:desc "Insight that historical data have been successfully persisted for later analysis."
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Insight that the continuous‑validation service detected a deviation between measured and modelled motion."
]

instance VisualizationDashboardInsight : DTDFVocab:Insight [
    base:desc "Insight provided by the dashboard displaying live sensor readings and crane state to operators."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight generated by the simulation component when executing what‑if scenarios."
]

instance PredictionInsight : DTDFVocab:Insight [
    base:desc "Insight delivering forecasted environmental conditions derived from historical sensor data."
]

// ----------------------------------------------------------
// C17: Actions
// ----------------------------------------------------------

instance AdjustActuatorAction : DTDFVocab:Action [
    base:desc "Action to adjust crane actuators (stepper motors or electromagnet) based on service recommendations."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, a Python program, issues motion commands to the crane via the Physical Crane Interface. Command types include trajectory execution directives generated by the Trajectory Generator Service. Commands are sent directly to the crane controllers; the documents do not detail command message format, authentication, conflict resolution, or execution confirmation mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The exemplars adopt an ad‑hoc orchestration based on containerization or virtualization. GreenhouseDT runs on virtual machines that host an InfluxDB time‑series database and an ActiveMQ message broker; the digital twin and physical greenhouse components communicate via the broker. The Air Quality Management exemplar uses a Raspberry‑Pi for sensing, an AutomationML‑based twin, and Microsoft Azure tools to host the twin pipeline, again employing messaging services. Overall the system follows a loosely coupled architecture where each service (data acquisition, storage, twin logic) is packaged in containers/VMs and linked through the broker and cloud services."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin includes a continuous validation service that compares predictions of the kinematic model with runtime data from the physical crane to monitor model fidelity. The exemplar has been employed in research on continuous validation methods and fault detection, but explicit validation procedures, uncertainty quantification, or error‑correction mechanisms are not described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin relies on an MQTT broker for signaling between components (Trajectory Generator Service, Simulation Service, Continuous Validation Service, etc.). The database (TimescaleDB) and dashboard (Grafana) are accessed over standard client‑server connections, but the specific network protocols, topology, bandwidth, latency, redundancy, or security measures are not described in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The architecture is described as a set of logical containers (Physical Crane, Physical Crane Interface, Control Application, Logging Application, Human Machine Interface, Database, Dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service, MQTT Broker). The documents do not state the physical hosting environment (cloud, edge, on‑premise), nor the computational or storage requirements, scalability mechanisms, deployment models, or availability/reliability provisions."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through standard open‑source protocols and interfaces. The twin exchanges data with the physical crane and any other cooperating services via MQTT topics, supporting loosely coupled, network‑agnostic connectivity. Persistent data are exposed through TimescaleDB’s PostgreSQL‑compatible SQL interface, which can be queried by external analytics tools or other digital twins. Grafana provides HTTP‑based dashboard access for operators and can be embedded in larger enterprise monitoring portals. No proprietary enterprise middleware is required; the stack relies on MQTT, SQL/HTTP, and Docker, facilitating interoperability with other IoT platforms or digital twin ecosystems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architectural description of the gantry‑crane digital twin follows the C4 Model, a widely adopted notation for software architecture, as stated in the documents."
]