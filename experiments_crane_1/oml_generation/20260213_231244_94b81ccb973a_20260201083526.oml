// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing angle on the gantry crane"
    DTDFVocab:producedData SwingAngleTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting crane operation"
    DTDFVocab:producedData WindSpeedTransmitted
]

// C4: Physical-to-virtual interaction (data transmission)
instance SwingAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Data (time‑series)
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements recorded by the encoder"
    DTDFVocab:fromData SwingAngleTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEnabler
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements recorded by the anemometer"
    DTDFVocab:fromData WindSpeedTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEnabler
]

// C2: Acting components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor driven by a TMC4671‑Eval controller for horizontal movement"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor driven by a TMC4671‑Eval controller for vertical lifting"
]

instance ElectromagnetGripper : DTDFVocab:ActingComponent [
    base:desc "Electromagnet used to grip pucks during transport"
]

// C10: Models (CAD, kinematic, simulation)
instance CadGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane created in Autodesk Fusion‑360"
    DTDFVocab:inputTo SimulationEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used for swing‑free trajectory generation"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the crane and its controllers"
    DTDFVocab:inputTo SimulationEnabler
]

// C11: Enablers (tools/platforms)
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL) storing operational time‑series data"
    DTDFVocab:enables LoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker facilitating messaging between services"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService,
                 ContinuousValidationService, VisualizationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard visualising data stored in TimescaleDB"
    DTDFVocab:enables VisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "gantrylib library executing kinematic calculations"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine running the crane dynamic model"
    DTDFVocab:enables SimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation module comparing executed trajectories with planned ones"
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Data logging service persisting sensor streams into TimescaleDB"
    DTDFVocab:provides InsightDataPersisted
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Data visualization service presenting operational metrics via Grafana"
    DTDFVocab:provides InsightOperationalDashboard
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Optimal trajectory generation service producing swing‑free motion plans"
    DTDFVocab:provides InsightOptimalTrajectory, ActionExecuteTrajectory
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service evaluating crane dynamics against generated trajectories"
    DTDFVocab:provides InsightSimulationResult
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service flagging deviations between planned and actual trajectories"
    DTDFVocab:provides InsightDeviationDetected, InsightFaultClassification,
                 ActionNotifyOperator, ActionFaultInvestigation
]

// C17: Insights
instance InsightDataPersisted : DTDFVocab:Insight [
    base:desc "Operational measurements are successfully stored in TimescaleDB"
]

instance InsightOperationalDashboard : DTDFVocab:Insight [
    base:desc "Real‑time operational data are visualised on the Grafana dashboard"
]

instance InsightOptimalTrajectory : DTDFVocab:Insight [
    base:desc "Generated trajectories minimise swing and satisfy move objectives"
]

instance InsightSimulationResult : DTDFVocab:Insight [
    base:desc "Simulation confirms feasibility and safety of the planned trajectory"
]

instance InsightDeviationDetected : DTDFVocab:Insight [
    base:desc "Validation detects deviation between executed and planned trajectory"
]

instance InsightFaultClassification : DTDFVocab:Insight [
    base:desc "Time‑series classification identifies potential system faults"
]

// C17: Actions
instance ActionExecuteTrajectory : DTDFVocab:Action [
    base:desc "Execute the generated swing‑free trajectory on the physical crane"
    DTDFVocab:IsAutomatic false
]

instance ActionNotifyOperator : DTDFVocab:Action [
    base:desc "Notify operator about trajectory deviation for corrective action"
    DTDFVocab:IsAutomatic true
]

instance ActionFaultInvestigation : DTDFVocab:Action [
    base:desc "Initiate fault investigation workflow based on classification result"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends motion commands and trajectory set‑points, generated by the Trajectory Generator Service, to the Physical Crane Interface via MQTT; the interface translates them to controller commands for the cart and hoist motors and activates the electromagnet."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A C4‑model based architecture linking the Physical Crane, Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface with digital services (Database, MQTT broker, Dashboard, Trajectory Generator, Simulation, Continuous Validation) orchestrated via Docker Compose on a single workstation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans design (CAD models in Autodesk Fusion‑360, kinematic model), manufacturing (physical crane assembly), and operation (real‑time monitoring, logging, validation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, checks against predefined thresholds and alerts operators via the dashboard; model validation methods are reused from prior work to ensure twin accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual data conveyed via a Python interface over serial/USB to the Arduino and motor controllers; MQTT (Eclipse Mosquitto) used for signalling between services; all components communicate over localhost network within Docker Compose."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software runs on a personal computer; Docker containers host the TimescaleDB, MQTT broker and Grafana dashboard; Python modules and applications run as processes; deployment is automated with a Docker Compose file."
]