namespace base = "http://www.w3.org/2000/01/rdf-schema#"
namespace DTDFVocab = "http://example.com/dtdf"

class DTDFVocab:ActingComponent [ base:subClassOf base:Class ]
class DTDFVocab:SensingComponent [ base:subClassOf base:Class ]
class DTDFVocab:Component [ base:subClassOf base:Class ]
class DTDFVocab:DataTransmitted [ base:subClassOf base:Class ]
class DTDFVocab:Enabler [ base:subClassOf base:Class ]
class DTDFVocab:Service [ base:subClassOf base:Class ]
class DTDFVocab:Insight [ base:subClassOf base:Class ]
class DTDFVocab:Action [ base:subClassOf base:Class ]
class DTDFVocab:Model [ base:subClassOf base:Class ]
class DTDFVocab:Data [ base:subClassOf base:Class ]
class DTDFVocab:Environment [ base:subClassOf base:Class ]

property DTDFVocab:contains [ base:domain DTDFVocab:Environment, base:range DTDFVocab:Component ]
property DTDFVocab:isContainedIn [ base:domain DTDFVocab:Component, base:range DTDFVocab:Environment ]

instance XAxisMotor : DTDFVocab:ActingComponent [
    base:desc "Controls cart movement along X-axis",
    DTDFVocab:isContainedIn LaboratoryEnvironment
]

instance ZAxisMotor : DTDFVocab:ActingComponent [
    base:desc "Controls hoisting movement along Z-axis",
    DTDFVocab:isContainedIn LaboratoryEnvironment
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Handles container at hoist end using electromagnetic force",
    DTDFVocab:isContainedIn LaboratoryEnvironment
]

instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Python program collecting data from physical crane and interfacing with MQTT broker",
    DTDFVocab:isContainedIn LaboratoryEnvironment
]

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures hoist swing dynamics in real-time",
    DTDFVocab:producedData SwingAngleDataTransmitted,
    DTDFVocab:isContainedIn LaboratoryEnvironment
]

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Monitors ambient wind speed for environmental data",
    DTDFVocab:producedData WindSpeedDataTransmitted,
    DTDFVocab:isContainedIn LaboratoryEnvironment
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "Time-series database for historical logging and analysis",
    DTDFVocab:enables HistoricalDataLoggingService, ContinuousValidationService, RealTimeVisualizationService
]

instance Grafana : DTDFVocab:Enabler [
    base:desc "Interactive data visualization and dashboarding tool",
    DTDFVocab:enables RealTimeVisualizationService
]

instance EclipseMosquitto : DTDFVocab:Enabler [
    base:desc "MQTT broker for lightweight communication between physical and digital components",
    DTDFVocab:enables HistoricalDataLoggingService, RealTimeVisualizationService, SimulationService, ContinuousValidationService
]

instance Docker : DTDFVocab:Enabler [
    base:desc "Containerization platform for consistent deployment across systems",
    DTDFVocab:enables OptimalControlService, HistoricalDataLoggingService, RealTimeVisualizationService, SimulationService, ContinuousValidationService
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimizes crane system performance through control algorithms",
    DTDFVocab:provides OptimalControlAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Continuously logs crane operational metrics for historical analysis",
    DTDFVocab:provides HistoricalDataAccess
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real-time monitoring and visualization of crane operations",
    DTDFVocab:provides RealTimeMonitoring
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Implements crane controller logic and trajectory execution via simulation",
    DTDFVocab:provides ScenarioTesting, PredictiveInsights
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Ensures model accuracy by validating against physical system data",
    DTDFVocab:provides ModelAccuracyValidation
]

instance RealTimeMonitoring : DTDFVocab:Insight [
    base:desc "Real-time monitoring of crane operations for immediate oversight"
]

instance ScenarioTesting : DTDFVocab:Insight [
    base:desc "Testing various operational scenarios through simulation"
]

instance PredictiveInsights : DTDFVocab:Insight [
    base:desc "Data-driven predictions for system behavior and performance"
]

instance OptimalControlAction : DTDFVocab:Action [
    base:desc "Automated adjustment of crane parameters for optimal performance",
    DTDFVocab:IsAutomatic true
]

instance HistoricalDataAccess : DTDFVocab:Insight [
    base:desc "Access to historical operational data for analysis and reporting"
]

instance ModelAccuracyValidation : DTDFVocab:Insight [
    base:desc "Validation of digital twin model accuracy against physical system data"
]

instance CraneSwingData : DTDFVocab:Data [
    base:desc "Time-series data of hoist swing dynamics",
    DTDFVocab:fromData SwingAngleDataTransmitted,
    DTDFVocab:inputTo TimescaleDB, Grafana
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time-series data of ambient wind speed",
    DTDFVocab:fromData WindSpeedDataTransmitted,
    DTDFVocab:inputTo TimescaleDB, Grafana
]

instance CADModel : DTDFVocab:Model [
    base:desc "Geometric representation of the gantry crane structure",
    DTDFVocab:inputTo SimulationService
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Model representing motion dynamics of the crane",
    DTDFVocab:inputTo SimulationService
]

instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:desc "Controlled laboratory environment for research and educational applications",
    DTDFVocab:contains XAxisMotor, ZAxisMotor, Electromagnet, SwingAngleEncoder, Anemometer, PhysicalCraneInterface
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service creates movement trajectories using a kinematic model. The Control Application executes these commands via the Physical Crane Interface. The Continuous Validation Service compares executed trajectories against simulations for discrepancies but does not explicitly confirm command execution. Specific command formats, validation mechanisms, and transmission protocols are not detailed in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system employs the C4 Model for architectural visualization, utilizing context and container diagrams to define system boundaries, components, and their interactions within the gantry crane architecture."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A continuous validation service compares executed trajectory measurements with simulated trajectories, calculating distance metrics and comparing against an acceptable threshold to ensure model fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT Broker is used for inter-service signaling. TimescaleDB (PostgreSQL-based) stores data, and Grafana Dashboard visualizes database data. No details on network topology, bandwidth, latency, redundancy, or security protocols are provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "System runs on a personal computer. Database, MQTT Broker, and Dashboard containers are deployed using Docker. Other components are not specified as containerized. No details on scalability, reliability mechanisms, or backup procedures are mentioned."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar uses AutomationML as a standard for digital twin modeling, and the Lab Scale Gantry Crane uses the C4 Model for architecture visualization. However, most exemplars adopt an ad-hoc approach rather than commercial digital twin frameworks, indicating limited adherence to industry-wide standards beyond specific modeling tools."
]