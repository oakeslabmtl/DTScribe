]

instance GreenhouseDigitalTwin : DTDFVocab:Component [
    base:desc "Behavioral adaptation model for the greenhouse digital twin enabling self-optimization of environmental parameters based on sensor-driven feedback."
    base:isContainedIn GreenhouseEnvironment
]

instance IndoorAirQualityEnvironment : DTDFVocab:Environment [
    base:desc "Indoor environment with Raspberry Pi-based air quality monitoring system and AutomationML digital twin enabling predictive analytics and visualization."
    base:contains AirQualitySensorSystem, AirQualityDigitalTwin
]

instance AirQualitySensorSystem : DTDFVocab:Component [
    base:desc "Raspberry Pi-based sensor suite measuring CO2, particulate matter, temperature, and humidity transmitted to Azure cloud processing."
