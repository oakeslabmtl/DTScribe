// C1: Environments/Components
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Controlled lab environment housing the lab-scale gantry crane cyber-physical system enabling bidirectional data flow between physical and digital counterparts."
    base:contains GantryCraneMechanicalStructure, GantryCraneController, GantryCraneDigitalTwin
]

instance GantryCraneMechanicalStructure : DTDFVocab:Component [
    base:desc "Physical gantry crane structure with articulated joints and load-bearing mechanisms for transporting pucks/containers in the lab environment."
    base:isContainedIn LabScaleGantryCraneEnvironment
]

instance GantryCraneController : DTDFVocab:Component [
    base:desc "Embedded controller hardware/software interface for the gantry crane enabling real-time operation and communication with the digital twin system."
    base:isContainedIn LabScaleGantryCraneEnvironment
]

instance GantryCraneDigitalTwin : DTDFVocab:Component [
    base:desc "Digital representation of the gantry crane including kinematic models, simulation services, and validation components enabling real-time synchronization."
    base:isContainedIn LabScaleGantryCraneEnvironment
]

instance GreenhouseEnvironment : DTDFVocab:Environment [
    base:desc "Controlled greenhouse environment with self-adaptive digital twin enabling behavioral optimization of temperature and humidity conditions."
    base:contains GreenhousePhysicalSystem, GreenhouseDigitalTwin
]

instance GreenhousePhysicalSystem : DTDFVocab:Component [
    base:desc "Physical greenhouse infrastructure with environmental control systems enabling bidirectional data exchange with the adaptive digital twin."
