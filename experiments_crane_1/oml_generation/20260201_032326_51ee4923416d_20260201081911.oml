// C2: Acting Components
instance CartMotorStepper : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart, controlled by a Trinamic TMC4671‑Eval controller"
]

instance HoistMotorStepper : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist, controlled by a Trinamic TMC4671‑Eval controller"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist used to pick up and release small pucks (container analogues)"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the hoist cable"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed near the crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartMotorFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Feedback sensor (built‑in encoder) providing cart motor position and speed"
    DTDFVocab:producedData CartMotorPosDataTransmitted
]

instance HoistMotorFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Feedback sensor (built‑in encoder) providing hoist motor position and speed"
    DTDFVocab:producedData HoistMotorPosDataTransmitted
]

instance ArduinoSensorInterface : DTDFVocab:SensingComponent [
    base:desc "Arduino‑based board aggregating swing‑angle, wind, and motor feedback measurements"
    DTDFVocab:producedData ArduinoSensorDataTransmitted
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance CartMotorPosDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorFeedbackSensor
]

instance HoistMotorPosDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorFeedbackSensor
]

instance ArduinoSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoSensorInterface
]

// C10: Data (time‑series)
instance SwingAngleTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of hoist swing‑angle measurements (degrees) recorded at 100 Hz"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of wind speed measurements (m/s) recorded at 10 Hz"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance CartMotorPosTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of cart motor position (steps) and speed (steps/s) logged during trajectory execution"
    DTDFVocab:fromData CartMotorPosDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HoistMotorPosTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of hoist motor position (steps) and speed (steps/s) logged during trajectory execution"
    DTDFVocab:fromData HoistMotorPosDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance ArduinoSensorTimeSeriesData : DTDFVocab:Data [
    base:desc "Aggregated time‑series of all Arduino‑acquired sensor values (swing, wind, motor feedback)"
    DTDFVocab:fromData ArduinoSensorDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) storing all operational time‑series data"
    DTDFVocab:enables DataLoggingService, ContinuousValidationService, SimulationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana instance visualizing data from TimescaleDB on dashboards"
    DTDFVocab:enables GrafanaDashboardService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for inter‑service signaling and event alerts"
    DTDFVocab:enables MQTTBrokerService, ContinuousValidationService
]

instance PythonCraneInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Python‑based Physical Crane Interface that reads controller data and forwards it to the logging application"
    DTDFVocab:enables DataLoggingService
]

instance GantryLibEnabler : DTDFVocab:Enabler [
    base:desc "gantrylib Python module (installed via pip) providing kinematic calculations and swing‑free trajectory planning"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that continuously writes motor positions, sensor readings, and trajectory metrics into TimescaleDB"
    DTDFVocab:provides DataLoggingInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualizing real‑time crane state and historic performance"
    DTDFVocab:provides DashboardVisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service that computes optimal swing‑free trajectories using gantrylib kinematic model"
    DTDFVocab:provides TrajectoryPlanningInsight, OptimalTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation of the crane and its controllers for validation and what‑if analysis"
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares executed trajectories with simulated ones, issuing alerts when deviations exceed thresholds"
    DTDFVocab:provides TrajectoryDeviationInsight, OperatorInterventionAction
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Service that publishes MQTT messages to signal events (e.g., alerts) to other DT services"
    DTDFVocab:provides MqttSignalInsight
]

// C17: Insights
instance TrajectoryDeviationInsight : DTDFVocab:Insight [
    base:desc "Alert generated when executed trajectory deviates from the simulated optimal trajectory beyond defined thresholds"
]

instance SwingReductionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that a newly computed trajectory reduces swing compared to previous executions"
]

instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor and actuator data have been successfully persisted in TimescaleDB"
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of crane state (positions, swing angle, wind) on Grafana dashboard"
]

instance TrajectoryPlanningInsight : DTDFVocab:Insight [
    base:desc "Result of trajectory generation indicating optimal motion parameters for swing‑free operation"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Outcome of physics‑based simulation providing expected sensor readings for a given command set"
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Statistical summary of validation results across multiple runs"
]

instance MqttSignalInsight : DTDFVocab:Insight [
    base:desc "Notification that an MQTT event (e.g., alert) has been published to subscribed services"
]

// C17: Actions
instance OperatorInterventionAction : DTDFVocab:Action [
    base:desc "Operator manually pauses or modifies the crane trajectory in response to a validation alert"
    DTDFVocab:IsAutomatic false
]

instance OptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatic upload of an optimal swing‑free trajectory to the crane controller"
    DTDFVocab:IsAutomatic true
]

instance MqttSignalAction : DTDFVocab:Action [
    base:desc "Publish MQTT message signalling a validation alert or system event"
    DTDFVocab:IsAutomatic true
]

// C1: Environment (optional aggregate)
instance CraneLabEnvironment : DTDFVocab:Environment [
    base:contains CartMotorStepper, HoistMotorStepper, ElectromagnetActuator,
                    SwingAngleEncoder, AnemometerSensor, CartMotorFeedbackSensor,
                    HoistMotorFeedbackSensor, ArduinoSensorInterface
]

// C0: Generic Components (optional)
instance CraneControllerBoard : DTDFVocab:Component [
    base:desc "Arduino‑based measurement and control board that interfaces with motors, sensors, and the Python crane interface"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital Twin services such as the Trajectory Generator Service compute optimal motion trajectories and send command sequences via the Control Application and Physical Crane Interface to the motor controllers; the Human‑Machine Interface can issue homing, zeroing and manual motion commands that are relayed to the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical crane ↔ Physical Crane Interface ↔ Control Application ↔ Logging Application ↔ TimescaleDB ↔ Grafana Dashboard; supporting services (Trajectory Generator, Simulation, Continuous Validation) communicate via MQTT broker; all services are orchestrated on a single PC using Docker containers and a Python module library."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT supports the design stage (CAD models in Autodesk Fusion360), the manufacturing/assembly stage (kinematic model derived from the CAD), and the operational stage (real‑time monitoring, validation and control during crane use)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectory data with simulated trajectories, computes distance metrics, checks against predefined thresholds, and raises operator alerts; the Trajectory Generator ensures swing‑free end states, providing a fidelity criterion for motion planning."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT components uses MQTT (Eclipse Mosquitto) over TCP/IP for signaling, and direct Python API calls for control and logging; sensor data is transmitted via the Arduino serial link to the Python interface."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT software runs on a personal computer; Docker containers host TimescaleDB, MQTT broker, and Grafana; the remaining Python services run as processes installed via pip from the gantrylib package; deployment is automated with a Docker‑Compose file."
]