// C2: Acting Components // Return code: 1 | Stderr:
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Step motor controlling the cart's horizontal motion via a Trinamic TMC4671-Eval board."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Step motor controlling the hoist vertical motion via a Trinamic TMC4671-Eval board."
]

instance ElectromagnetOnHoist : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist for picking up container pucks."
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder mounted on the hoist, providing angular position data."
    DTDFVocab:producedData SwingAngleDTO
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed that may affect crane dynamics."
    DTDFVocab:producedData WindSpeedDTO
]

instance ArduinoMeasurementSuite : DTDFVocab:SensingComponent [
    base:desc "Arduino-based suite that reads motor encoders and other sensor channels."
    DTDFVocab:producedData MotorEncoderDTO
]

// C4: Physical-to-virtual interaction
instance SwingAngleDTO : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDTO : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance MotorEncoderDTO : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoMeasurementSuite
]

// C10: Models/Data
instance CadModel : DTDFVocab:Model [
    base:desc "Fusion360 CAD assets defining the physical geometry of the lab-scale gantry crane."
    DTDFVocab:inputTo TrajectoryGenerationService, SimulationService
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Mathematically defined kinematic model used for trajectory optimization."
    DTDFVocab:inputTo TrajectoryGenerationService
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Physics-based model that emulates motor currents and crane dynamics."
    DTDFVocab:inputTo SimulationService
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Snapshot of swing angle captured by the hoist encoder."
    DTDFVocab:fromData SwingAngleDTO
    DTDFVocab:inputTo TimescaleDBEnabler, SimulatorEnabler, ValidationEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Timestamped wind speed readings from the anemometer."
    DTDFVocab:fromData WindSpeedDTO
    DTDFVocab:inputTo TimescaleDBEnabler, SimulatorEnabler, ValidationEnabler
]

instance MotorEncoderData : DTDFVocab:Data [
    base:desc "Motor encoder values read by the Arduino measurement suite."
    DTDFVocab:fromData MotorEncoderDTO
    DTDFVocab:inputTo TimescaleDBEnabler, SimulatorEnabler, ValidationEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB used to store telemetry and derived metrics."
    DTDFVocab:enables LoggingService, SimulationService, ValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter-service signaling."
    DTDFVocab:enables CommunicationService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Docker-based Grafana instance providing real-time trajectory plots."
    DTDFVocab:enables VisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the kinematic trajectory generation service."
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulatorEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the physics simulation service."
    DTDFVocab:enables SimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for continuous validation, comparing executed vs simulated trajectories."
    DTDFVocab:enables ValidationService
]

instance HMIServicEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the human-machine interface service."
    DTDFVocab:enables HMIServicService
]

// C6: Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Python logging application that reads sensor data and writes state into TimescaleDB."
    DTDFVocab:provides LoggingDataInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboard service providing real-time trajectory plots and validation alerts."
    DTDFVocab:provides TrajectoryPlotInsight, ValidationAlertInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Kinematic model-based optimal trajectory generator."
    DTDFVocab:provides TrajectoryFeasibilityInsight, AdjustSetpointAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Python simulator emulating crane dynamics based on the simulation model."
    DTDFVocab:provides SimulationOutputData
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Service comparing executed vs simulated trajectories, computing distance metrics."
    DTDFVocab:provides ValidationAlertInsight, FaultClassificationInsight
]

instance HMIServicService : DTDFVocab:Service [
    base:desc "Human-machine interface for operator control and trajectory parameter setting."
    DTDFVocab:provides OperatorCommandInsight, OperatorAdjustAction
]

instance CommunicationService : DTDFVocab:Service [
    base:desc "Service for inter-service signaling via MQTT topics."
]

// C17: Insights/Actions
instance TrajectoryFeasibilityInsight : DTDFVocab:Insight [
    base:desc "Insight indicating whether planned trajectory respects hardware constraints."
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert when continuous validation detects execution-simulation deviation beyond threshold."
]

instance TrajectoryPlotInsight : DTDFVocab:Insight [
    base:desc "Real-time trajectory plot displayed on Grafana dashboard."
]

instance LoggingDataInsight : DTDFVocab:Insight [
    base:desc "Insight representing logged telemetry data entries."
]

instance FaultClassificationInsight : DTDFVocab:Insight [
    base:desc "Insight gained from fault-mode classification studies."
]

instance OperatorCommandInsight : DTDFVocab:Insight [
    base:desc "Insight reflecting operator trajectory and control commands."
]

instance AdjustSetpointAction : DTDFVocab:Action [
    base:desc "Automatically adjusts setpoints when trajectory feasibility is compromised."
    DTDFVocab:IsAutomatic true
]

instance OperatorAdjustAction : DTDFVocab:Action [
    base:desc "Allows operator to manually adjust trajectory or control setpoints."
    DTDFVocab:IsAutomatic false
]

instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Simulated kinematic and dynamic state data generated by the simulation service."
    DTDFVocab:inputTo ValidationEnabler
]

// Components
instance CranePhysicalContainer : DTDFVocab:Component [
    base:desc "Physical crane hardware consisting of motors, actuators, and sensors."
]

instance LoggerContainer : DTDFVocab:Component [
    base:desc "Container running the logging application as a Python process."
]

instance HMIContainer : DTDFVocab:Component [
    base:desc "Container hosting the human-machine interface."
]

instance DatabaseContainer : DTDFVocab:Component [
    base:desc "Docker container running TimescaleDB."
]

instance BrokerContainer : DTDFVocab:Component [
    base:desc "Docker container running Eclipse Mosquitto MQTT broker."
]

instance DashboardContainer : DTDFVocab:Component [
    base:desc "Docker container running Grafana for visualization."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory endpoints produced by the Trajectory Generator Service are consumed by the Control Application. The Control Application speaks the Python API of the Physical Crane Interface, which forwards position setpoints to the TMC4671 motor controllers, thereby generating the desired motion in the physical crane."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Logging and continuous validation are executed continuously in real‑time: as fresh sensor samples become available the logger writes them and the validation service evaluates them immediately. Trajectory generation requests are issued on demand by the operator via the Control Application and HMI. The services therefore operate on a continuous timescale for data collection and validation, and on an on‑demand timescale for trajectory planning."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation includes a physical crane (hardware + electronics), a Crane Interface module, a Control Application, a Logging Application, an HMI, a database container, a dashboard container, a trajectory generator service container, a simulation service container, a continuous validation service container, and an MQTT broker, all interconnected via MQTT and SQL networking within a single Docker‑compose stack."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Twin covers the entire lifecycle of the crane: design (CAD models and capella arcadia models), fabrication (BOM and hardware assembly), and operation (real‑time control, logging, validation). The repository also hosts teaching extensions and research artifacts that build on the core Twin, demonstrating evolution from design to operational testing and fault‑mode classification."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Physical measurements (motor encoders, swing encoder, anemometer) provide ground truth; simulation accuracy is checked against these measurements; the continuous validation service computes distance metrics between executed and simulated trajectories and triggers alerts if errors exceed a configurable threshold, ensuring model validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical sensors and actuators connect to the PC via a custom Arduino board on a USB or serial link. Sensor data is written to TimescaleDB via the Python logging application using the PostgreSQL driver. Virtual services communicate over MQTT topics using Eclipse Mosquitto. Grafana queries TimescaleDB using its PostgreSQL data source. All components communicate over the local network of the host machine."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All subsystem containers are hosted on a local personal computer; Docker Compose orchestrates: TimescaleDB container, Mosquitto broker, Grafana; Python applications run as native services; docker‑compose manages network isolation and startup/shutdown commands; the codebase is hosted publicly on GitHub."
]