// C2: Acting Components
instance HorizontalMovementMotor : DTDFVocab:ActingComponent [
    base:desc "Motor responsible for horizontal movement of the gantry crane, controlled via ControlApplication to execute motion commands and enforce operational constraints."
]

instance VerticalMovementMotor : DTDFVocab:ActingComponent [
    base:desc "Motor responsible for vertical movement of the hoist, controlled via ControlApplication to execute lifting and lowering operations with payload handling."
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist for precise container (puck) manipulation, tied to vertical positioning for pickup and release operations."
]

instance ControlApplication : DTDFVocab:ActingComponent [
    base:desc "Dedicated hardware/software system interfacing with crane actuators (motors, electromagnet) to execute motion commands and enforce operational constraints."
]

// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures swinging motion of the hoist during container transport, providing feedback for dynamic stabilization of the crane load."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Monitors wind speed affecting crane stability, integrated into the physical system for environmental condition monitoring."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ControlApplication
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "Geometric and kinematic model of the gantry crane, leveraging Autodesk Fusion360 CAD models to ensure precise positioning and trajectory generation."
    DTDFVocab:inputTo GantryLibEnabler
]

instance TrajectoryData : DTDFVocab:Data [
    base:desc "Structured trajectory representations generated by TrajectoryGeneratorService, including planned vs. executed paths for continuous validation."
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo GantryLibEnabler, TimescaleDBEnabler
]

instance HistoricalOperationData : DTDFVocab:Data [
    base:desc "Time-series data storage for crane operations, including sensor data (position, velocity, load force) and control inputs for post-mortem analysis."
    DTDFVocab:fromData SwingAngleDataTransmitted, WindSpeedDataTransmitted, CraneStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance SimulationTrajectoryData : DTDFVocab:Data [
    base:desc "Simulated trajectories generated by SimulationService, validated against real-world measurements for continuous validation."
    DTDFVocab:fromData TrajectoryData
    DTDFVocab:inputTo GantryLibEnabler
]

// C11: Enablers
instance GantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python-based module encapsulating digital twin logic, including kinematic simulations, control algorithms, and service interfaces for the gantry crane."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database storing historical operational data with high temporal resolution, enabling efficient querying and analysis of crane trajectories and sensor logs."
    DTDFVocab:enables HistoricalDataLoggingService, ContinuousValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker facilitating bidirectional communication between physical crane and digital twin for real-time data exchange."
    DTDFVocab:enables TrajectoryGeneratorService, DataVisualizationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Customizable dashboards for real-time monitoring of crane state, trajectory validation, and system performance visualization."
    DTDFVocab:enables DataVisualizationService
]

instance Fusion360Enabler : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion360 used to create high-fidelity CAD models serving as the foundation for the kinematic model of the gantry crane."
    DTDFVocab:enables KinematicModel
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes optimal trajectories for crane movements leveraging geometric and kinematic models, generating control signals for the crane's controller."
    DTDFVocab:provides OptimalTrajectoryInsight, TrajectoryCorrectionAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Replicates crane behavior in a virtual environment using behavioral models to predict system responses under varying conditions."
    DTDFVocab:provides SimulationValidationInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Logs time-series data for crane operations, storing sensor data and control inputs in a structured database for post-mortem analysis."
    DTDFVocab:provides HistoricalPerformanceInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Provides real-time and historical dashboarding via Grafana, displaying trajectory traces, sensor telemetry, and system health metrics."
    DTDFVocab:provides RealTimeMonitoringInsight, InteractiveExplorationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares measurements of executed trajectories with simulated trajectories to detect divergences and trigger corrective actions."
    DTDFVocab:provides ModelPlantComparisonInsight, SystemRecalibrationAction
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Generated optimal control signals for crane's controller based on kinematic models and physical constraints to eliminate residual swinging motion."
]

instance TrajectoryCorrectionAction : DTDFVocab:Action [
    base:desc "Dynamically enforces trajectory corrections by integrating with the physical crane's controller."
    DTDFVocab:IsAutomatic true
]

instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Validation of simulated trajectories against real-world measurements to ensure digital twin accuracy."
]

instance HistoricalPerformanceInsight : DTDFVocab:Insight [
    base:desc "Post-mortem analysis of crane behavior for fault diagnosis, wear prediction, and long-term performance studies."
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Runtime visualization of system states and operational traces via Grafana dashboard, including trajectory traces and sensor telemetry."
]

instance InteractiveExplorationInsight : DTDFVocab:Insight [
    base:desc "Interactive exploration of logged data for debugging or educational purposes."
]

instance ModelPlantComparisonInsight : DTDFVocab:Insight [
    base:desc "Real-time comparison of executed trajectories (physical crane sensors) with simulated trajectories (digital twin) to detect divergences."
]

instance SystemRecalibrationAction : DTDFVocab:Action [
    base:desc "Triggers recalibration or alerts via Grafana dashboard when deviations between physical and simulated trajectories exceed predefined thresholds."
    DTDFVocab:IsAutomatic true
]

// C1: Physical Twin System
instance LabScaleGantryCrane : DTDFVocab:Component [
    base:desc "Lab-scale cyber-physical system designed for research and educational purposes, comprising modular components with kinematic constraints for payload handling and motion control."
    base:isContainedIn ControlledLabEnvironment
]

instance ControlledLabEnvironment : DTDFVocab:Environment [
    base:desc "Controlled laboratory environment enabling real-time interaction with the Digital Twin for validation, fault detection, and optimization experiments."
    base:contains LabScaleGantryCrane
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The **virtual-to-physical interaction** in the Digital Twin system is mediated by the **Control Application**, **Physical Crane Interface**, and **Human Machine Interface (HMI)**. The **Control Application**, a Python-based module, generates **control commands** (e.g., movement trajectories) using inputs from the **Trajectory Generator Service** or direct operator instructions via the **HMI**. These commands are transmitted through the **Physical Crane Interface**, a Python program acting as a bridge to the **Physical Crane’s controllers**. The **HMI** allows operators to configure and override crane operations manually. No explicit details are provided about **command types** (e.g., velocity profiles, acceleration limits), **message formats** (e.g., binary vs. structured text), or **validation/authentication mechanisms** for control signals. **Feedback systems** are implied through the **Continuous Validation Service**, which monitors executed trajectories against simulations, though this is primarily for post-execution analysis rather than real-time feedback. **Conflict resolution** and **command execution confirmation** are not explicitly described, but the system’s architecture suggests a unidirectional flow from digital (Control Application) to physical (Physical Crane) with no explicit acknowledgment mechanism. The **MQTT Broker** facilitates signaling between services but does not appear to handle bidirectional control confirmation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin systems described in the documents exhibit varied temporal characteristics. **GreenhouseDT** relies on virtual machine images with **prerecorded data**, indicating a **static/batch time scale** for offline analysis rather than real-time synchronization. **Air Quality Management** exemplifies **real-time capabilities** through runtime visualization, simulation, and prediction, leveraging a **Raspberry Pi with sensors** for continuous data acquisition. The **Gantry Crane system** features a **Logging Application** that **continuously logs the crane’s state to the database**, enabling **real-time status updates** via the **Human Machine Interface (HMI)**. No explicit synchronization frequencies or latency requirements are specified, but the use of **InfluxDB (time-series database)** and **ActiveMQ (message broker)** in GreenhouseDT suggests **event-driven, near-real-time data exchange** with configurable granularity. The **Air Quality Management** exemplar’s reliance on **Microsoft Azure tools** implies cloud-based processing with potential for **low-latency interactions** due to its focus on virus spread prediction and simulation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin systems described adopt a **lightweight, modular, and ad-hoc orchestration pattern** rather than a unified commercial framework. Key components include:
  - **GreenhouseDT**: Uses **InfluxDB (time-series database)**, **ActiveMQ (message broker)**, and **virtual machines (VMs)** for **behavioral adaptation** of both physical and digital systems. The architecture is **service-oriented**, with **prerecorded data** enabling offline or batch processing.
  - **Air Quality Management**: Implements a **pipeline on Microsoft Azure**, integrating **AutomationML-based digital twin models** with **Raspberry Pi sensor data**. The system supports **runtime visualization, simulation, and prediction**, indicating a **pipeline-driven orchestration** with **Azure tools** (e.g., IoT Hub, Stream Analytics) for coordination.
  - **Gantry Crane**: Described using the **C4 Model** (context/container diagrams), implying a **software-centric architecture** with **cyber-physical system (CPS) integration**. The orchestration is **domain-specific**, tailored for logistics use cases, and lacks explicit mention of cross-twin coordination.
  **Resource management** is handled via **containerization/virtualization** (e.g., VMs, Raspberry Pi), while **system-wide coordination** relies on **message brokers (ActiveMQ)** or **cloud-based pipelines (Azure)**. No formal **orchestration framework** (e.g., Kubernetes, Apache Kafka) is referenced, reinforcing the **ad-hoc approach** across exemplars."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The system employs a **Continuous Validation Service** that compares real-time sensor measurements (e.g., Swing Angle Encoder data) with simulated predictions from the Simulation Service, calculating **distance metrics** between them. If the discrepancy exceeds an **acceptable threshold value**, the system triggers a notification to alert operators or initiate corrective actions. While the documents highlight **fault detection methods** as a research focus, no explicit details on uncertainty quantification, error correction algorithms, or formal quality assurance processes (e.g., model calibration protocols, sensor calibration routines) are provided. The validation mechanism relies on threshold-based anomaly detection rather than probabilistic or statistical error modeling."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** of the Digital Twin system relies on a **containerized architecture** deployed via Docker, with services communicating through an **MQTT Broker** for inter-service signaling. The **TimescaleDB database** (a time-series extension of PostgreSQL) stores all system-generated data, including logs and trajectory measurements. The **MQTT Broker** enables asynchronous messaging between containers, such as the **Trajectory Generator Service**, **Simulation Service**, and **Continuous Validation Service**. No explicit details are provided regarding **communication protocols** (e.g., TCP/IP, UDP), **network topology** (e.g., star, mesh), or **bandwidth/latency requirements**. **Reliability and redundancy mechanisms** are not mentioned, though the use of a centralized database and broker suggests some fault tolerance. **Security protocols** (e.g., encryption, authentication) are not described, nor are hardware-specific protocols (e.g., Modbus, OPC UA) for interfacing with the **Physical Crane**. The system assumes an **on-premise** deployment with local network connectivity."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **hosting and deployment infrastructure** for the Digital Twin is **on-premise**, executed on a **personal computer** using **Docker** for containerization. The system employs **Docker Compose** to orchestrate the six Digital Twin containers (Database, Dashboard, Trajectory Generator, Simulation, Continuous Validation, MQTT Broker) and five physical system containers (Physical Crane, Physical Crane Interface, Control Application, Logging Application, HMI). Computational requirements are not quantified, but the use of Python-based services and TimescaleDB suggests moderate resource demands. Scalability mechanisms are not explicitly supported; the system is designed for a **single-node deployment** with no mention of horizontal or vertical scaling. Availability and reliability are not formally assured beyond the **Continuous Validation Service**, which monitors trajectory accuracy but does not address infrastructure uptime or failover strategies. Deployment is static, with no dynamic scaling or cloud/edge hybrid models referenced."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin systems exhibit **limited but domain-specific horizontal integration** with external systems, relying on **open standards and lightweight protocols**:
  - **GreenhouseDT**: Integrates with **InfluxDB (time-series database)** and **ActiveMQ (message broker)** for **internal data exchange**, but no explicit external system dependencies are documented. The use of **virtual machines with prerecorded data** suggests **offline or batch-oriented integration** with potential third-party tools.
  - **Air Quality Management**: Leverages **AutomationML** for **model-driven interoperability**, enabling integration with **construction engineering tools** (e.g., CAD/BIM systems). **Microsoft Azure tools** (e.g., IoT Hub, Stream Analytics) facilitate **cloud-based data exchange**, while the **Raspberry Pi sensors** provide **real-time physical system connectivity**. No enterprise system dependencies (e.g., ERP, MES) are mentioned.
  - **Gantry Crane**: Designed for **logistics/cyber-physical systems**, with **C4 Model architecture** implying **modular integration** but no specific protocols or standards. The system likely relies on **industrial communication protocols** (e.g., OPC UA, MQTT) for external system interactions, though these are not explicitly stated.
  **Interoperability standards** are limited to **AutomationML (Air Quality Management)** and **Azure cloud services**, with no evidence of **cross-Digital Twin integration** or **enterprise-wide data exchange**. Dependencies are **domain-specific** (e.g., sensors, simulation tools) rather than generalized."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adopts an **ad-hoc architectural approach** without adherence to proprietary digital twin frameworks. Architectural documentation is standardized using the **C4 Model** for context and container diagrams, though this is primarily for visualization rather than compliance. No industry-specific standards (e.g., AutomationML, ISO/IEC 45020) or certification frameworks are referenced. Interoperability is implicitly supported through **MQTT** for message brokering and **Docker** for containerization, but no formal interoperability standards (e.g., OPC UA, FDT) are explicitly adopted. The reliance on open-source tools (e.g., Grafana, InfluxDB) and custom Python modules suggests a focus on flexibility over standardization."
]