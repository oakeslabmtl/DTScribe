// -------------------------------------------------
// C3: Physical sensing components
// -------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swinging motion of the crane hoist"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// -------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// -------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// -------------------------------------------------
// C10: Data (time‑series measurements)
// -------------------------------------------------
instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Time‑series swing‑angle measurements from the encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance WindSpeedMeasurement : DTDFVocab:Data [
    base:desc "Time‑series wind‑speed measurements from the anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

// -------------------------------------------------
// C11: Enablers (tools & infrastructure)
// -------------------------------------------------
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for publishing sensor streams and service messages"
    DTDFVocab:enables LoggingService, TrajectoryGeneratorService,
                 SimulationService, ContinuousValidationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database for persisting measurement data"
    DTDFVocab:enables LoggingService, ContinuousValidationService,
                 SimulationService, GrafanaDashboardService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestrates the containerised digital‑twin services"
    DTDFVocab:enables LoggingService, GrafanaDashboardService,
                 TrajectoryGeneratorService, SimulationService,
                 ContinuousValidationService
]

instance GantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module providing APIs for trajectory generation, simulation and validation"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService,
                 ContinuousValidationService
]

// -------------------------------------------------
// C6: Services
// -------------------------------------------------
instance LoggingService : DTDFVocab:Service [
    base:desc "Data logging service that consumes MQTT sensor streams and stores them in TimescaleDB"
    DTDFVocab:provides DataStoredInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualisation service reading persisted data from TimescaleDB"
    DTDFVocab:provides VisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free trajectories for crane motion planning"
    DTDFVocab:provides OptimalTrajectoryInsight, AdjustSetPointAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Virtual crane/controller simulation using kinematic and controller models"
    DTDFVocab:provides SimulatedTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares measured trajectories against simulated ones and raises alerts on deviations"
    DTDFVocab:provides DeviationAlertInsight, AlertAction
]

// -------------------------------------------------
// C17: Insights
// -------------------------------------------------
instance DataStoredInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor measurements have been persisted in TimescaleDB"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualisation of crane states and sensor data in Grafana"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal swing‑free trajectory suggested by the Trajectory Generator"
]

instance SimulatedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Simulated crane trajectory generated by the Simulation Service"
]

instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when measured trajectory deviates from simulated trajectory"
]

// -------------------------------------------------
// C17: Actions
// -------------------------------------------------
instance AlertAction : DTDFVocab:Action [
    base:desc "Notify operator of a trajectory deviation"
    DTDFVocab:IsAutomatic false
]

instance AdjustSetPointAction : DTDFVocab:Action [
    base:desc "Operator adjusts crane set‑points based on the optimal trajectory insight"
    DTDFVocab:IsAutomatic false
]

// -------------------------------------------------
// C10: Models (digital representations)
// -------------------------------------------------
instance CADModelFusion360 : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane created in Autodesk Fusion360"
    DTDFVocab:inputTo GantryLibEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator for motion planning"
    DTDFVocab:inputTo GantryLibEnabler
]

instance ControllerSimulationModel : DTDFVocab:Model [
    base:desc "Controller‑level simulation model used by the Simulation Service"
    DTDFVocab:inputTo GantryLibEnabler
]

// -------------------------------------------------
// C2: Acting components (for completeness)
// -------------------------------------------------
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the gantry cart, controlled via TMC4671‑Eval controller"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist, controlled via TMC4671‑Eval controller"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist end for picking up containers"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application and the Human‑Machine Interface (HMI) generate motion set‑points, trajectory commands and actuator commands (e.g., start/stop, electromagnet on/off). These commands are sent through the Physical Crane Interface to the motor controllers and the Arduino, which actuate the cart motor, hoist motor and electromagnet accordingly."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical crane ↔ Python interface ↔ Control, Logging, and HMI applications; services (trajectory, simulation, validation) communicate via MQTT; all persistent data stored in TimescaleDB; visualisation through Grafana; all components orchestrated on a single PC with Docker‑hosted database, broker and dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans design (CAD models of the crane), manufacture (BOM‑specified physical crane) and operation (real‑time data acquisition, continuous validation), providing a live as‑operated representation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares executed trajectories with simulated ones, computes distance metrics, checks against a predefined threshold, and notifies operators when the threshold is exceeded, ensuring model fidelity during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication uses MQTT (Eclipse Mosquitto) for signalling. The TimescaleDB database is accessed via standard PostgreSQL SQL connections over the local host network. The Physical Crane Interface communicates with the motor controllers and Arduino via Python (specific protocol not detailed in the document). Logging writes directly to the database; control commands are sent from the Control Application/HMI through the same interface to the hardware."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Docker containers host the TimescaleDB database, MQTT broker, and Grafana dashboard; the remaining Python applications run on the same host PC; deployment managed via a Docker‑Compose file; source code hosted publicly on GitHub."
]