// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor responsible for horizontal movement (cart) of the gantry crane, controlled via Trinamic TMC4671-Eval motor driver with precise position feedback."
    base:isContainedIn PhysicalCraneSystem
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor responsible for vertical movement (hoist) of the gantry crane, controlled via Trinamic TMC4671-Eval motor driver with swing angle feedback."
    base:isContainedIn PhysicalCraneSystem
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist end used for picking up and releasing pucks (simulating container transport), controlled via Arduino-based system."
    base:isContainedIn PhysicalCraneSystem
]

instance ArduinoControlUnit : DTDFVocab:ActingComponent [
    base:desc "Arduino-based measurement and control unit integrating sensors, motor controllers, and electromagnet via custom KiCad-designed shield."
    base:isContainedIn PhysicalCraneSystem
]

// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures angular displacement of the hoist to provide real-time feedback on swinging motion for trajectory validation."
    DTDFVocab:producedData SwingAngleDataTransmitted
    base:isContainedIn PhysicalCraneSystem
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Measures environmental wind speed which influences the crane's dynamic behavior and trajectory stability."
    DTDFVocab:producedData WindSpeedDataTransmitted
    base:isContainedIn PhysicalCraneSystem
]

instance MotorPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded sensors in Trinamic TMC4671-Eval controllers providing real-time feedback on motor current, speed, and position."
    DTDFVocab:producedData MotorPositionDataTransmitted
    base:isContainedIn PhysicalCraneSystem
]

instance ElectromagnetStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring electromagnet activation status for puck pickup/release operations."
    DTDFVocab:producedData ElectromagnetStatusDataTransmitted
    base:isContainedIn PhysicalCraneSystem
]

// C4: Physical-to-Virtual Data Transmission
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
    DTDFVocab:fromData SwingAngleDataTransmitted
    base:isContainedIn DigitalTwinSystem
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
    DTDFVocab:fromData WindSpeedDataTransmitted
    base:isContainedIn DigitalTwinSystem
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionSensor
    DTDFVocab:fromData MotorPositionDataTransmitted
    base:isContainedIn DigitalTwinSystem
]

instance ElectromagnetStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ElectromagnetStatusSensor
    DTDFVocab:fromData ElectromagnetStatusDataTransmitted
    base:isContainedIn DigitalTwinSystem
]

instance MQTTEventDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneControlApplication
    DTDFVocab:fromData MQTTEventDataTransmitted
    base:isContainedIn DigitalTwinSystem
]

// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Mathematical representation of the crane's movement dynamics used by the Trajectory Generator Service to compute optimal paths minimizing residual swinging motion."
    DTDFVocab:inputTo TrajectoryGenerationService
    DTDFVocab:inputTo SimulationService
    base:isContainedIn DigitalTwinSystem
]

instance CraneCADModel : DTDFVocab:Model [
    base:desc "3D model created in Fusion360 for visualization and structural analysis of the physical crane components."
    DTDFVocab:inputTo GrafanaDashboardService
    base:isContainedIn DigitalTwinSystem
]

instance ArcadiaMBSEModel : DTDFVocab:Model [
    base:desc "Capella-based Model-Based Systems Engineering models detailing system architecture and behavior for educational purposes."
    DTDFVocab:inputTo EducationalService
    base:isContainedIn DigitalTwinSystem
]

instance TimescaleDBDatabase : DTDFVocab:Data [
    base:desc "Time-series database optimized for crane operational data storage, supporting SQL and time-series queries for historical analysis."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:fromData ElectromagnetStatusDataTransmitted
    DTDFVocab:inputTo HistoricalDataLoggingService
    DTDFVocab:inputTo ContinuousValidationService
    base:isContainedIn DigitalTwinSystem
]

instance SimulationData : DTDFVocab:Data [
    base:desc "Synthetic data generated for testing validation methods and fault detection algorithms in offline scenarios."
    DTDFVocab:inputTo SimulationService
    DTDFVocab:inputTo ContinuousValidationService
    base:isContainedIn DigitalTwinSystem
]

instance MQTTTopicConfiguration : DTDFVocab:Data [
    base:desc "Definition of data channels for real-time communication including /crane/sensor and /crane/trajectory topics."
    DTDFVocab:inputTo MQTTBrokerService
    base:isContainedIn DigitalTwinSystem
]

// C11: Enablers
instance PythonCoreServices : DTDFVocab:Enabler [
    base:desc "Core Python-based services including control, logging, and validation implemented in the gantrylib module."
    DTDFVocab:enables TrajectoryGenerationService
    DTDFVocab:enables HistoricalDataLoggingService
    DTDFVocab:enables ContinuousValidationService
    DTDFVocab:enables SimulationService
    base:isContainedIn DigitalTwinSystem
]

instance DockerContainerization : DTDFVocab:Enabler [
    base:desc "Containerization framework using Docker and Docker Compose for deploying database, MQTT broker, and Grafana dashboard services."
    DTDFVocab:enables TimescaleDBDeployment
    DTDFVocab:enables MQTTBrokerService
    DTDFVocab:enables GrafanaDashboardService
    base:isContainedIn DigitalTwinSystem
]

instance TimescaleDBDeployment : DTDFVocab:Enabler [
    base:desc "TimescaleDB deployment optimized for time-series data storage with PostgreSQL compatibility."
    DTDFVocab:enables TimescaleDBDatabase
    base:isContainedIn DigitalTwinSystem
]

instance MQTTBrokerService : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker enabling event-driven communication between physical crane and digital twin services."
    DTDFVocab:enables MQTTEventDataTransmitted
    DTDFVocab:enables ContinuousValidationService
    base:isContainedIn DigitalTwinSystem
]

instance GrafanaDashboardService : DTDFVocab:Enabler [
    base:desc "Grafana-based visualization platform displaying real-time and historical data with trajectory traces and confidence bounds."
    DTDFVocab:enables DataVisualizationService
    base:isContainedIn DigitalTwinSystem
]

instance ArduinoSensorIntegration : DTDFVocab:Enabler [
    base:desc "Custom KiCad-designed Arduino shield integrating all physical sensors and motor controllers for unified data acquisition."
    DTDFVocab:enables SwingAngleDataTransmitted
    DTDFVocab:enables WindSpeedDataTransmitted
    DTDFVocab:enables MotorPositionDataTransmitted
    DTDFVocab:enables ElectromagnetStatusDataTransmitted
    base:isContainedIn DigitalTwinSystem
]

// C6: Services
instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Uses kinematic model to compute optimal trajectories minimizing residual swinging motion, reducing energy consumption and improving efficiency."
    DTDFVocab:provides OptimalTrajectoryInsight
    DTDFVocab:provides EnergyEfficiencyAction
    base:isContainedIn DigitalTwinSystem
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Continuously logs crane state (motor positions, swing angles, wind speed) into TimescaleDB for post-processing and analysis."
    DTDFVocab:provides HistoricalAnalysisInsight
    DTDFVocab:provides DataStorageAction
    base:isContainedIn DigitalTwinSystem
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Visualizes real-time and historical data including trajectory traces with confidence bounds derived from simulations."
    DTDFVocab:provides VisualizationInsight
    DTDFVocab:provides DashboardAlertAction
    base:isContainedIn DigitalTwinSystem
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories with simulated ones using distance metrics, alerting operators if deviations exceed predefined thresholds."
    DTDFVocab:provides ValidationInsight
    DTDFVocab:provides DeviationAlertAction
    base:isContainedIn DigitalTwinSystem
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Enables offline testing of control strategies and fault detection by simulating crane behavior without physical interaction."
    DTDFVocab:provides SimulationInsight
    DTDFVocab:provides OfflineTestingAction
    base:isContainedIn DigitalTwinSystem
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Provides web-based interface for operators to configure logging, monitor status, and manually control the crane."
    DTDFVocab:provides OperatorControlAction
    DTDFVocab:provides ConfigurationInsight
    base:isContainedIn DigitalTwinSystem
]

instance EducationalService : DTDFVocab:Service [
    base:desc "Supports harbor system extensions including container identification and buoyancy modeling for systems engineering education."
    DTDFVocab:provides EducationalInsight
    DTDFVocab:provides TeachingAction
    base:isContainedIn DigitalTwinSystem
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Identifies optimal paths that minimize residual swinging motion based on kinematic model calculations."
    base:isContainedIn DigitalTwinSystem
]

instance EnergyEfficiencyAction : DTDFVocab:Action [
    base:desc "Adjusts motor parameters to reduce energy consumption by optimizing trajectory paths."
    DTDFVocab:IsAutomatic true
    base:isContainedIn DigitalTwinSystem
]

instance HistoricalAnalysisInsight : DTDFVocab:Insight [
    base:desc "Provides historical trends in crane operation including swing patterns, energy consumption, and environmental factors."
    base:isContainedIn DigitalTwinSystem
]

instance DataStorageAction : DTDFVocab:Action [
    base:desc "Persists all operational data into TimescaleDB for long-term analysis and retrieval."
    DTDFVocab:IsAutomatic true
    base:isContainedIn DigitalTwinSystem
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Displays real-time and historical data visualizations including trajectory traces with confidence intervals."
    base:isContainedIn DigitalTwinSystem
]

instance DashboardAlertAction : DTDFVocab:Action [
    base:desc "Triggers visual alerts in Grafana dashboard when operational thresholds are exceeded."
    DTDFVocab:IsAutomatic true
    base:isContainedIn DigitalTwinSystem
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Quantifies deviations between executed and simulated trajectories using distance metrics."
    base:isContainedIn DigitalTwinSystem
]

instance DeviationAlertAction : DTDFVocab:Action [
    base:desc "Sends alerts to operators when trajectory deviations exceed predefined acceptable thresholds."
    DTDFVocab:IsAutomatic true
    base:isContainedIn DigitalTwinSystem
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Provides synthetic data and simulation results for offline testing of control strategies."
    base:isContainedIn DigitalTwinSystem
]

instance OfflineTestingAction : DTDFVocab:Action [
    base:desc "Executes control strategy simulations without physical interaction for validation purposes."
    DTDFVocab:IsAutomatic true
    base:isContainedIn DigitalTwinSystem
]

instance OperatorControlAction : DTDFVocab:Action [
    base:desc "Allows manual override of crane operations through web interface."
    DTDFVocab:IsAutomatic false
    base:isContainedIn DigitalTwinSystem
]

instance ConfigurationInsight : DTDFVocab:Insight [
    base:desc "Provides current system configuration parameters visible to operators."
    base:isContainedIn DigitalTwinSystem
]

instance EducationalInsight : DTDFVocab:Insight [
    base:desc "Demonstrates harbor crane operations including container identification and buoyancy modeling."
    base:isContainedIn DigitalTwinSystem
]

instance TeachingAction : DTDFVocab:Action [
    base:desc "Facilitates educational demonstrations of systems engineering concepts using the digital twin."
    DTDFVocab:IsAutomatic false
    base:isContainedIn DigitalTwinSystem
]

// C1: Environment
instance LabEnvironment : DTDFVocab:Environment [
    base:desc "Controlled laboratory environment simulating harbor crane operations for research and educational purposes."
    base:contains PhysicalCraneSystem
    base:contains DigitalTwinSystem
]

instance PhysicalCraneSystem : DTDFVocab:Component [
    base:desc "Lab-scale gantry crane with frame, motors, controllers, sensors, and electromagnet for container simulation."
    base:isContainedIn LabEnvironment
]

instance DigitalTwinSystem : DTDFVocab:Component [
    base:desc "Centralized digital twin providing real-time monitoring, control, and validation services for the physical crane."
    base:isContainedIn LabEnvironment
]

// C5: Data Transmission Protocols
instance SerialCommunication : DTDFVocab:DataTransmitted [
    base:desc "Arduino-based serial communication protocol for high-frequency sensor data transmission."
    DTDFVocab:producedFrom ArduinoSensorIntegration
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:fromData ElectromagnetStatusDataTransmitted
    base:isContainedIn DigitalTwinSystem
]

instance MQTTProtocol : DTDFVocab:DataTransmitted [
    base:desc "Eclipse Mosquitto MQTT protocol for event-driven communication between services."
    DTDFVocab:producedFrom MQTTBrokerService
    DTDFVocab:fromData MQTTEventDataTransmitted
    base:isContainedIn DigitalTwinSystem
]

instance HighFrequencyTransmission : DTDFVocab:Data [
    base:desc "Configurable high-frequency data transmission rate for sensor data logging."
    DTDFVocab:inputTo ArduinoSensorIntegration
    base:isContainedIn DigitalTwinSystem
]

instance ContinuousTransmission : DTDFVocab:Data [
    base:desc "Continuous data transmission for real-time validation services."
    DTDFVocab:inputTo ContinuousValidationService
    base:isContainedIn DigitalTwinSystem
]

// Add missing instance for CraneControlApplication
instance CraneControlApplication : DTDFVocab:Enabler [
    base:desc "Python-based control application integrating all crane control logic and interfaces with physical components."
    DTDFVocab:enables ArduinoSensorIntegration
    DTDFVocab:enables MQTTEventDataTransmitted
    base:isContainedIn DigitalTwinSystem
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The virtual-to-physical interaction is facilitated through the following services:
  - **Trajectory Generator Service** computes optimal movement trajectories for the crane using a kinematic model, ensuring minimal residual swinging at the target location. These trajectories are sent to the **Control Application** as reference paths.
  - **Simulation Service** generates synthetic data for testing and validation, which can be injected into the physical system for offline or virtual commissioning.
  - **Human Machine Interface (HMI)** allows operators to configure and control the crane remotely, sending commands (e.g., move cart, hoist, or electromagnet) to the **Control Application**.
  - **Continuous Validation Service** triggers alerts via the **Dashboard** (Grafana) if physical behavior deviates from simulated expectations, prompting manual intervention or corrective actions.
  The interaction is mediated by the **MQTT broker** for real-time signaling and **TimescaleDB** for storing and retrieving trajectory data."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twinning time-scale is **real-time and event-driven**, with the following characteristics:
  - **Data logging frequency**: Configurable (not explicitly stated in the document, but implied to be high-frequency due to time-series optimization in TimescaleDB).
  - **Trajectory validation**: Performed continuously during operation, with metrics computed at intervals aligned with crane movement cycles (e.g., per trajectory execution).
  - **MQTT messaging**: Enables low-latency communication between services, with publish-subscribe patterns for real-time updates (e.g., sensor readings, trajectory commands).
  - **Simulation updates**: Occur asynchronously when needed for validation or offline testing, with no strict real-time constraint.
  The system supports **synchronous** (e.g., trajectory execution) and **asynchronous** (e.g., logging, validation) operations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation is organized as follows:
  - **Physical Layer**: Comprises the gantry crane (frame, motors, sensors, Arduino) and its controller.
  - **Interface Layer**: The **Physical Crane Interface** (Python) bridges the physical and digital layers via serial communication.
  - **Digital Twin Layer**:
    - **Services Layer**: Decoupled Python modules (Trajectory Generator, Simulation, Validation) communicating via MQTT.
    - **Data Layer**: Centralized **TimescaleDB** storing all operational data.
    - **Visualization Layer**: **Grafana dashboard** for real-time monitoring and alerting.
  - **Orchestration**: Managed via **Docker Compose** for containerized services and a single Python module (gantrylib) for local execution.
  The constellation follows a **service-oriented architecture (SOA)** with loose coupling between components, enabling modular extensions (e.g., adding new validation algorithms)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin covers the **as-operated** lifecycle stage of the physical system, with the following representations:
  - **As-designed**: Represented by the **CAD models** (Fusion360) and **kinematic model** used for trajectory planning.
  - **As-manufactured**: Not explicitly modeled; the physical crane is assumed to be built to specifications without deviations.
  - **As-operated**: Fully represented by the digital twin, including real-time sensor data, historical logs, and validation services.
  The twin is primarily used for **operational monitoring, optimization, and fault detection**, with extensions (e.g., harbor simulations) explored for educational purposes. The **DarTwin notation** was used to document the evolution of the twin system over time, capturing changes in requirements and services."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
  - **Model Accuracy**:
    - The **kinematic model** is validated against real-world trajectories to ensure trajectory generation aligns with physical behavior.
    - **Simulation Service** generates synthetic data for offline validation, allowing comparison with physical measurements.
  - **Verification and Validation**:
    - **Continuous validation** uses distance metrics to compare executed trajectories with simulated ones; thresholds trigger alerts if deviations exceed acceptable bounds.
    - **Fault detection** employs time-series classification (e.g., isolation forests) to identify anomalies in operational data.
  - **Uncertainty Handling**:
    - **Confidence bounds** (visualized in Grafana) represent the uncertainty range of simulated trajectories, aiding in interpreting deviations.
    - **Wind speed measurements** (via anemometer) are incorporated into the model to account for environmental factors affecting crane dynamics.
  - **Error Mitigation**:
    - **Operator alerts** via the dashboard enable manual intervention for unresolved discrepancies.
    - **Trajectory optimization** minimizes residual swinging, reducing the impact of modeling errors."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection between the physical twin (PT) and digital twin (DT) includes:
  - **Communication Protocols**:
    - **Serial communication** (Arduino ↔ PC) for sensor data acquisition.
    - **MQTT (Eclipse Mosquitto)** for asynchronous messaging between services (e.g., crane interface → trajectory generator).
    - **SQL queries** (TimescaleDB) for structured data storage and retrieval.
  - **Network Architecture**:
    - **Local network**: All components (crane, PC, Docker containers) are connected via a single local network.
    - **No cloud dependency**: The system operates entirely on a personal computer with containerized services.
  - **Data Flow**:
    - **PT → DT**: Sensor data → Logging Application → TimescaleDB → MQTT topics.
    - **DT → PT**: Trajectory commands → Control Application → Crane Interface → Motor controllers.
  - **Latency**: Low-latency requirements are met via MQTT and direct Python communication for critical control loops."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is hosted and deployed as follows:
  - **Physical Hosting**:
    - Runs entirely on a **personal computer** with all services (Python modules, Docker containers) deployed locally.
    - **No cloud infrastructure** is used; the system is designed for on-premises operation.
  - **Containerization**:
    - **Docker Compose** manages the deployment of:
      - **TimescaleDB** (PostgreSQL-based time-series database).
      - **Eclipse Mosquitto** (MQTT broker).
      - **Grafana** (dashboard).
    - Containers are isolated and communicate via a custom Docker network.
  - **Setup**:
    - **Automated first-time setup**: Docker Compose handles database initialization, dashboard configuration, and network setup.
    - **Python module (gantrylib)**: Installed via pip for local execution of services (e.g., trajectory generation, validation).
  - **Scalability**: The architecture supports horizontal scaling of services (e.g., adding more validation instances) but is not designed for distributed deployment."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The digital twin supports limited horizontal integration with external systems:
  - **No explicit integration** with other digital twins or external information systems is documented.
  - **Potential extensions** (not implemented) could include:
    - **APIs** for connecting to enterprise resource planning (ERP) systems for logistics optimization.
    - **Cloud-based analytics** for aggregating data from multiple cranes (not currently supported).
  - **Current scope**: The system is designed for standalone use in research and education, with no dependencies on external data sources or systems."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership and privacy considerations are as follows:
  - **Data Ownership**: The digital twin and its data are owned by the **Cosys-Lab & Flanders Make** team, published under the **MIT License** for open-source use.
  - **Privacy**:
    - No sensitive or personal data is collected; the system operates in a controlled lab environment.
    - **No explicit privacy policies** are mentioned; the focus is on research and educational use.
    - **Data access**: Limited to authorized users (e.g., researchers, operators) via the Grafana dashboard and Python APIs.
  - **Ethical Use**: The exemplar is intended for **academic and research purposes only**, with no commercial or industrial deployment implied."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The following standards and frameworks are referenced or implied:
  - **No formal standards compliance** is explicitly stated, but the following are used:
    - **AutomationML**: Mentioned in the Air Quality Management exemplar (related work) but not adopted here.
    - **Model-Based Systems Engineering (MBSE)**: Supported via **Capella (Arcadia)** models for educational purposes.
    - **Open-source tools**: TimescaleDB, Grafana, Eclipse Mosquitto, and Python are widely adopted but not standardized for digital twins.
    - **MQTT Protocol**: Industry-standard for IoT messaging, used for inter-service communication.
  - **Ad-hoc Approach**: The system avoids proprietary frameworks (e.g., Eclipse Ditto, BaSyx) in favor of modular, open-source components."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety considerations include:
  - **Security**:
    - **No explicit security measures** are documented (e.g., authentication, encryption) for the local network deployment.
    - **Docker containers** are isolated but not hardened for production use; the system is designed for research/education.
    - **MQTT broker (Mosquitto)** runs locally with default security settings (no TLS/SSL or user authentication).
  - **Safety**:
    - **No remote operation risks**: The crane operates in a controlled lab environment with no human exposure to hazardous conditions.
    - **Alert mechanisms**: The **Continuous Validation Service** notifies operators of deviations, enabling manual intervention to prevent failures.
    - **Physical safeguards**: The electromagnet and motors are designed for lab-scale use with no risk of injury or property damage.
  - **Limitations**:
    - **No cybersecurity hardening**: The system is not suitable for industrial deployment where security is critical.
    - **Manual override**: All critical operations require operator confirmation via the HMI, mitigating automated safety risks."
]