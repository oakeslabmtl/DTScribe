// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring the hoist swinging motion on the physical crane."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed near the crane."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoBoard : DTDFVocab:SensingComponent [
    base:desc "Arduino measurement and control board that reads the swing‑angle encoder and anemometer and provides status feedback from motor drivers."
    DTDFVocab:producedData ArduinoStatusDataTransmitted
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance ArduinoStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoBoard
]

// C10: Data objects
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurements streamed to TimescaleDB."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ValidationEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed measurements stored in TimescaleDB."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ValidationEnabler
]

instance ArduinoStatusData : DTDFVocab:Data [
    base:desc "Status feedback from motor drivers and Arduino, logged with timestamps."
    DTDFVocab:fromData ArduinoStatusDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ValidationEnabler
]

// C2: Acting components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the crane cart along the gantry."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor raising and lowering the hoist."
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist used to pick up pucks (containers)."
]

// C10: Models
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "Fusion 360 CAD geometry of the gantry crane used for visualization."
    DTDFVocab:inputTo GrafanaEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model employed by the Trajectory Generator to compute swing‑free trajectories."
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the crane and its controllers used for real‑time simulation and validation."
    DTDFVocab:inputTo SimulationEnabler, ValidationEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database container storing sensor measurements and system states."
    DTDFVocab:enables DataLoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard container visualizing logged data and insights."
    DTDFVocab:enables DataVisualizationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker facilitating publish/subscribe communication between DT services."
    DTDFVocab:enables MQTTSignalingService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python ‘gantrylib’ module component that generates optimal swing‑free trajectories."
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Real‑time simulation engine (Python) executing the dynamic model of the crane."
    DTDFVocab:enables RealTimeSimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation component comparing executed trajectories with simulated ones and raising alerts."
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuously streams crane state (motor positions, sensor readings, timestamps) to TimescaleDB."
    DTDFVocab:provides DataLoggingInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Visualizes system performance on a Grafana dashboard, enabling operators to monitor metrics."
    DTDFVocab:provides DashboardVisualizationInsight, ParameterAdjustmentAction
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal, swing‑free trajectories using the kinematic model."
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance RealTimeSimulationService : DTDFVocab:Service [
    base:desc "Runs a real‑time simulation of the crane and its controllers based on the dynamic model."
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares measured motion with simulated trajectories and raises real‑time validation alerts."
    DTDFVocab:provides SwingFreeAlertInsight, HaltOperationAction
]

instance MQTTSignalingService : DTDFVocab:Service [
    base:desc "Publishes and subscribes to MQTT topics for inter‑service signaling and command distribution."
    DTDFVocab:provides MQTTSignalInsight
]

// C17: Insights
instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Record of all sensor and actuator states persisted in TimescaleDB."
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live visual representation of crane performance and KPI trends on Grafana."
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Computed optimal trajectory that minimizes swing for a given pick‑and‑place operation."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation output showing predicted crane dynamics for a proposed trajectory."
]

instance SwingFreeAlertInsight : DTDFVocab:Insight [
    base:desc "Real‑time alert when measured swing exceeds model‑predicted limits."
]

instance MQTTSignalInsight : DTDFVocab:Insight [
    base:desc "Notification of published MQTT messages for service coordination."
]

// C17: Actions
instance ParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Operator can adjust control parameters via the Human‑Machine Interface."
    DTDFVocab:IsAutomatic false
]

instance HaltOperationAction : DTDFVocab:Action [
    base:desc "Automatically halt crane operation when a swing‑free alert is raised."
    DTDFVocab:IsAutomatic true
]

// C16: Environment & Components
instance PowerSupplyUnit : DTDFVocab:Component [
    base:desc "Power supply unit providing electricity to motor drivers and Arduino board."
]

instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains SwingAngleEncoder, Anemometer, ArduinoBoard, CartStepperMotor, HoistStepperMotor, ElectromagnetActuator, PowerSupplyUnit
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control Application (and the Human‑Machine Interface) send motion set‑points, trajectory commands, and electromagnet activation signals to the Physical Crane Interface, which translates them to controller commands that drive the stepper motors and electromagnet on the crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of the physical crane linked to a Python Interface, a Control Application, a Logging Application and an HMI on the physical side; these communicate through MQTT with the digital side composed of the database, dashboard, trajectory generator, simulator, and continuous‑validation services, all running on a single PC and containerized for easy deployment."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the design stage (CAD models of the crane in Autodesk Fusion 360), the manufacturing/implementation stage (physical frame, motors, Arduino board), and the operation stage (runtime data logging, simulation, validation, and trajectory planning)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, and checks them against a predefined threshold; violations trigger operator alerts on the Grafana dashboard, providing on‑line verification of model fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between services uses MQTT (Eclipse Mosquitto) for signaling; sensor and state data are written to TimescaleDB via standard PostgreSQL SQL; the HMI and other applications retrieve data from the database using Grafana’s data source plug‑ins."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All Dockerized components (TimescaleDB, MQTT broker, Grafana) are launched on a personal computer via a Docker‑Compose file. The Python modules run natively on the same host. The entire stack is open‑source and publicly available on GitHub."
]