// C2: Acting Components
instance GantryCartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor responsible for moving the cart along the gantry beam. Interfaced via Trinamic TMC4671-Eval motor controller and controlled by Arduino-based system."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor responsible for vertical hoisting of the load. Interfaced via Trinamic TMC4671-Eval motor controller and controlled by Arduino-based system."
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist for picking up and releasing pucks (containers). Controlled via Arduino-based system."
]

instance GantryCranePowerSupply : DTDFVocab:ActingComponent [
    base:desc "Power Supply Unit (PSU) providing electrical power to the Arduino control system, motor controllers, and electromagnet."
]

instance ArduinoControlSystem : DTDFVocab:ActingComponent [
    base:desc "Arduino-based control system interfacing with motor controllers, electromagnet, and sensors to execute movements and control logic based on digital twin commands."
]

instance TrinamicTMC4671CartController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671-Eval motor controller for the gantry cart stepper motor, interfaced with Arduino."
]

instance TrinamicTMC4671HoistController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671-Eval motor controller for the hoist stepper motor, interfaced with Arduino."
]

// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures swinging motion of the hoist during load movement to provide feedback for trajectory validation."
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Measures wind speed affecting crane dynamics (e.g., swinging motion) for real-time environmental compensation."
]

// C4: Physical-to-Virtual Interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
]

instance TrajectoryExecutionDataTransmitted : DTDFVocab:DataTransmitted [
]

// C10: Models/Data
instance CraneCADModel : DTDFVocab:Model [
    base:desc "Geometric representation of the gantry crane (gantry frame, motors, electromagnet) created in Autodesk Fusion 360 for visualization and simulation."
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Mathematical representation of the crane's motion dynamics used by the Trajectory Generator Service to compute optimal swing-free trajectories."
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Replicates crane behavior and controller responses for offline testing and validation of new trajectories."
]

instance ArcadiaSystemArchitectureModel : DTDFVocab:Model [
    base:desc "Model-Based Systems Engineering (MBSE) representation of the crane system architecture and requirements created in Capella for educational purposes."
]

instance HistoricalTrajectoryData : DTDFVocab:Data [
    base:desc "Stored trajectories from past crane operations used for comparison with real-time data during continuous validation."
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "High-frequency time-series data from swing angle encoder, anemometer, and motor position sensors logged in TimescaleDB."
]

instance OptimalTrajectoryData : DTDFVocab:Data [
    base:desc "Computed swing-free trajectories generated by the Trajectory Generator Service for execution by the physical crane."
]

// C11: Enablers
instance PythonEnabler : DTDFVocab:Enabler [
    base:desc "Python-based implementation of all digital twin services including gantrylib module for control, logging, and validation. Containerized via Docker."
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "PostgreSQL-based time-series database for storing high-frequency sensor data and historical trajectories with efficient time-based queries."
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Data visualization platform for real-time and historical crane data including trajectory traces, confidence bounds, and alerts."
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter-service communication and event-based synchronization between physical and virtual components."
]

instance DockerEnabler : DTDFVocab:Enabler [
    base:desc "Containerization platform for deploying TimescaleDB, MQTT broker, and Grafana dashboard via docker-compose for reproducible deployment."
]

instance ArduinoEnabler : DTDFVocab:Enabler [
    base:desc "Arduino-based hardware platform for sensor interfacing, motor control, and real-time execution of crane movements."
]

instance KiCadShieldEnabler : DTDFVocab:Enabler [
    base:desc "Custom KiCad-designed shield for Arduino sensor connectivity including swing angle encoder and anemometer interfaces."
]

instance Fusion360Enabler : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion 360 CAD tool for creating geometric models of the gantry crane components."
]

instance CapellaEnabler : DTDFVocab:Enabler [
    base:desc "Capella MBSE tool for modeling system architecture and requirements following Arcadia methodology."
]

instance MkDocsEnabler : DTDFVocab:Enabler [
    base:desc "Documentation generator for creating technical documentation hosted on GitHub Pages."
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Uses kinematic model of the crane to compute swing-free trajectories for cart and hoist movements, minimizing residual motion at trajectory endpoints."
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates crane behavior and controller responses for offline testing or validation of new trajectories without affecting physical system."
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed physical trajectories with simulated virtual trajectories using distance metrics, triggering alerts when deviations exceed thresholds."
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Extends continuous validation with time-series classification techniques to localize faults in physical system (e.g., motor malfunctions, sensor failures)."
]

instance LoggingService : DTDFVocab:Service [
    base:desc "Continuously logs crane state data (motor positions, swing angles, wind speed) into TimescaleDB database for post-analysis."
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Provides Grafana dashboard for real-time and historical data visualization including trajectory traces, confidence bounds, and alerts."
]

instance DocumentationService : DTDFVocab:Service [
    base:desc "Generates and hosts technical documentation using MkDocs on GitHub Pages for public accessibility."
]

instance PhysicalCraneInterface : DTDFVocab:Service [
    base:desc "Python-based communication layer between physical crane and digital twin, handling data streaming from sensors and command execution."
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Generated swing-free trajectories that minimize residual motion at trajectory endpoints for precise load placement."
]

instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results comparing simulated trajectories with offline test scenarios to ensure controller robustness."
]

instance TrajectoryDeviationInsight : DTDFVocab:Insight [
    base:desc "Distance metrics quantifying deviations between executed physical trajectories and simulated virtual trajectories."
]

instance FaultLocalizationInsight : DTDFVocab:Insight [
    base:desc "Identified specific faults in physical system (e.g., motor jamming, sensor drift) with root cause analysis."
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Time-series data of crane operations including motor positions, swing angles, and environmental conditions for trend analysis."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time and historical visualization of crane performance metrics, trajectory traces, and system alerts via Grafana dashboard."
]

instance DocumentationInsight : DTDFVocab:Insight [
    base:desc "Technical documentation including system architecture, API references, and deployment instructions hosted on GitHub Pages."
]

instance TrajectoryOptimizationAction : DTDFVocab:Action [
    base:desc "Automatically suggests improved trajectories to reduce swinging motion or energy consumption based on kinematic analysis."
    DTDFVocab:IsAutomatic true
]

instance FaultNotificationAction : DTDFVocab:Action [
    base:desc "Triggers alerts in Grafana dashboard when trajectory deviations exceed predefined thresholds, notifying operators of potential issues."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Provides proactive maintenance recommendations based on fault detection results and historical wear-and-tear indicators."
]

instance PhysicalVirtualSyncAction : DTDFVocab:Action [
    base:desc "Synchronizes physical crane state with digital twin by streaming sensor data and executing control commands in real-time."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The virtual-to-physical interaction involves commands and control signals generated by the digital twin's services and transmitted to the physical crane via the **Control Application** and **Physical Crane Interface**. Key interactions include:
  - **Optimal trajectory commands** generated by the **Trajectory Generator Service** (using kinematic models) and sent to the **Control Application** to execute precise, swing-free movements.
  - **Control signals** for motor actuation (cart/hoist movement) and electromagnet activation (picking/releasing pucks), relayed through the **Physical Crane Interface** to the Arduino and motor controllers.
  - **Configuration parameters** (e.g., logging intervals, database settings) adjusted via the **Human Machine Interface (HMI)** and propagated to the **Logging Application**.
  The interaction is facilitated by a **Python-based control loop** that translates digital twin outputs into executable actions for the physical system."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin operates on **real-time and continuous** time scales:
    - **Continuous logging**: The **Logging Application** records crane state at high frequency (exact rate unspecified but implied to be high-resolution for validation).
    - **Continuous validation**: The **Continuous Validation Service** runs in real-time, comparing executed trajectories with simulations as they occur.
    - **On-demand services**: The **Trajectory Generator** and **Simulation Service** operate in response to operator commands or validation requests, with no explicit latency constraints mentioned beyond the need for synchronization with physical operations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation is organized as a **Cyber-Physical System (CPS)** with clear separation between physical and virtual components, interconnected via data flows and services:
  - **Physical Layer**:
    - The **Physical Crane** (hardware) interacts with the **Physical Crane Interface** (Python) to exchange commands and sensor data.
  - **Virtual Layer**:
    - The **Database** (TimescaleDB) acts as the central repository for all logged data.
    - The **MQTT Broker** (Eclipse Mosquitto) enables asynchronous communication between services (e.g., Trajectory Generator → Control Application).
    - The **Dashboard** (Grafana) provides a unified view of system state and alerts.
    - The **Trajectory Generator**, **Simulation**, and **Continuous Validation Services** operate independently but collaboratively to ensure accurate control and fault detection.
  - **Human Interaction**:
    - The **Human Machine Interface (HMI)** allows operators to configure the crane and monitor its status.
  The constellation is **modular**, with services designed to be **replaceable or extensible** (e.g., swapping the Trajectory Generator for a more advanced algorithm)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin covers the following lifecycle stages of the physical system:
    - **As Designed**: Represented by **CAD models (Autodesk Fusion 360)** and **kinematic models** used for trajectory generation and simulation.
    - **As Manufactured/Operated**: Validated through **continuous comparison** of executed trajectories with simulations, ensuring the physical system behaves as designed. The **Continuous Validation Service** uses distance metrics to detect deviations, implying a focus on operational fidelity.
    - **Evolution**: The system supports **DarTwin notation** for documenting and managing digital twin evolution over time, including future extensions like harbor simulations and ship buoyancy models."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
  - **Model Accuracy**:
    - The **kinematic model** in the Trajectory Generator Service is validated by comparing simulated trajectories with real-world executions. Deviations are quantified using **distance metrics** (e.g., Euclidean distance between paths).
    - The **Simulation Service** replicates crane dynamics, including effects like swinging motion and wind disturbances (measured by the anemometer).
  - **Validation Mechanisms**:
    - **Continuous Validation Service**: Monitors the difference between physical and virtual trajectories in real-time. If the distance metric exceeds a threshold, operators are alerted via the Grafana dashboard.
    - **Fault Detection**: Uses time-series classification to identify anomalies (e.g., sudden motor speed drops, sensor noise) and localize faults to specific components.
  - **Uncertainty Handling**:
    - **Confidence Bounds**: Simulated trajectories include upper/lower bounds (visualized in Grafana) to account for uncertainties like wind speed variations.
    - **Threshold Tuning**: Acceptable deviation thresholds are empirically determined based on experimental data.
  - **Verification**:
    - The system has been validated in multiple publications (e.g., [4], [5], [6]) for continuous validation, fault detection, and digital twin evolution."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection between the physical and digital twins relies on:
    - **Python-based interfaces**: The **Physical Crane Interface** connects to the Arduino via unspecified protocols (likely **UART/USB**), forwarding sensor data to the digital twin services.
    - **MQTT Protocol**: The **Eclipse Mosquitto broker** enables asynchronous communication between services (e.g., Logging Application → Database, Trajectory Generator → Control Application).
    - **Database Integration**: The **Logging Application** writes time-series data to **TimescaleDB**, which is queried by the **Dashboard** and **Continuous Validation Service**.
    - **No explicit latency constraints** are documented, but the system implies **real-time synchronization** for validation purposes. The **Docker network** facilitates inter-container communication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is hosted and deployed as follows:
  - **Physical Deployment**:
    - The **Physical Crane** and **Arduino** are connected to a **personal computer** running the digital twin services.
    - All Python-based services (e.g., Control Application, Logging Application) are bundled in the `gantrylib` module and installed via `pip`.
  - **Virtual Deployment**:
    - **Database (TimescaleDB)**, **MQTT Broker (Eclipse Mosquitto)**, and **Dashboard (Grafana)** are containerized using **Docker**.
    - A `docker-compose.yml` file automates the setup, including first-time initialization of the database and dashboard.
    - Services communicate over a **local network** (e.g., Docker's internal bridge network).
  - **Accessibility**:
    - The entire system is **open-source** and hosted on **GitHub** ([Cosys-Lab/lab-scale-gantry-crane](https://github.com/Cosys-Lab/lab-scale-gantry-crane)).
    - Documentation is generated with **MkDocs** and hosted on GitHub Pages for easy access."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "The digital twin exemplar is published under an **MIT license**, indicating open-source ownership. However, the document does not specify:
    - **Data ownership**: Whether data generated by the system belongs to the PT owner, DT service provider, or is shared openly.
    - **Privacy considerations**: No mention of sensitive data handling, encryption, or access controls.
    - **User data**: The system is designed for research/education, with no explicit privacy policies or compliance requirements (e.g., GDPR) discussed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin adheres to the following standards and tools:
    - **Software Standards**:
      - **Python** (no explicit PEP compliance mentioned).
      - **MQTT Protocol** (Eclipse Mosquitto).
      - **Docker** for containerization.
    - **Database Standards**:
      - **TimescaleDB** (PostgreSQL-compatible, optimized for time-series data).
    - **Modeling Standards**:
      - **Autodesk Fusion 360** (CAD).
      - **Capella** (Arcadia models for MBSE, aligned with **ISO/IEC 20922** or similar MBSE standards, though not explicitly stated).
    - **Licensing**: **MIT License** for open-source distribution.
    The approach is **ad-hoc**, avoiding proprietary digital twin frameworks like **Eclipse Ditto** or **Eclipse BaSyx** in favor of modular, open-source components."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety and security considerations are implicitly addressed through:
    - **Operator Notification**: The **Continuous Validation Service** alerts operators via the dashboard if physical-virtual discrepancies exceed thresholds, enabling corrective action.
    - **Human Machine Interface (HMI)**: Provides controlled access for operators to configure and monitor the crane.
    - **No explicit security mechanisms** are documented (e.g., MQTT encryption, authentication, or network segmentation). The system assumes a trusted environment for research/education purposes.
    - **Safety**: The design prioritizes **real-time validation** and **fault detection** to prevent unsafe operations, but no formal safety standards (e.g., **ISO 13849**) or risk assessments are mentioned."
]