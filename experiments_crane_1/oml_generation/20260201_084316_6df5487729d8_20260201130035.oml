// Physical Components
instance GantryFrame : DTDFVocab:Component [
    base:desc "Steel gantry frame that supports the horizontal trolley rail and vertical lifting column."
]

instance TrolleyRail : DTDFVocab:Component [
    base:desc "Horizontal rail guiding the cart along the gantry for precise positioning."
]

instance LiftingColumn : DTDFVocab:Component [
    base:desc "Vertical column carrying the crane boom and providing the structure for hoist movement."
]

instance CraneBoom : DTDFVocab:Component [
    base:desc "Rotating boom extending the crane’s reach for load handling."
]

instance CraneController : DTDFVocab:Component [
    base:desc "Controller that receives motion commands and drives stepper motors for cart and hoist."
]

// Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor that moves the cart horizontally along the trolley rail."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor that controls vertical hoist movement."
]

// Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the trolley to capture angular swing deviation during crane operation."
    DTDFVocab:producedData SwingAngleTransmission
]

instance CartPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder that measures horizontal displacement of the cart along the trolley rail."
    DTDFVocab:producedData CartPositionTransmission
]

instance HoistLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor indicating vertical lift position of the hoist for precise height control."
    DTDFVocab:producedData HoistLevelTransmission
]

// Data Transmitted
instance SwingAngleTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance CartPositionTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartPositionEncoder
]

instance HoistLevelTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistLevelSensor
]

// Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Swing angle of the crane trolley, expressed in radians, collected by SwingAngleEncoder."
    DTDFVocab:inputTo LoggingApplication
    DTDFVocab:fromData SwingAngleTransmission
]

instance CartPositionData : DTDFVocab:Data [
    base:desc "Cartesian position of the cart along the horizontal rail, expressed in meters, collected by CartPositionEncoder."
    DTDFVocab:inputTo LoggingApplication
    DTDFVocab:fromData CartPositionTransmission
]

instance HoistLevelData : DTDFVocab:Data [
    base:desc "Vertical lift position of the hoist, expressed in meters, collected by HoistLevelSensor."
    DTDFVocab:inputTo LoggingApplication
    DTDFVocab:fromData HoistLevelTransmission
]

// Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker that publishes sensor telemetry and receives control commands via MQTT topics."
    DTDFVocab:enables RealTimeMonitoringService, OptimalControlService, VisualizationDashboardService
]

instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Python logging application that aggregates telemetry from the physical system and persists it into a TimescaleDB database."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Open‑source simulation engine that ingests real‑time sensor streams from the MQTT broker and executes the behavioral model."
    DTDFVocab:enables SimulationService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service that continuously validates the crane’s state against real‑time sensor data for accurate monitoring."
    DTDFVocab:provides ContinuousValidationInsight, RealTimeAlertInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service that computes optimal control trajectories for the gantry crane using the kinematic model."
    DTDFVocab:provides TrajectoryExecutionInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that saves all telemetry and state information into TimescaleDB for long‑term analysis."
    DTDFVocab:provides DataStorageInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs online simulation of cart and hoist dynamics to predict future states."
    DTDFVocab:provides SimulationInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Service that visualizes real‑time telemetry and historical data using Grafana dashboards connected to the MQTT broker."
    DTDFVocab:provides DataVisualizationInsight
]

// Insights and Actions
instance ContinuousValidationInsight : DTDFVocab:Insight [
    base:desc "Insight that indicates continuous validation of the crane’s performance against expected behavior."
]

instance RealTimeAlertInsight : DTDFVocab:Insight [
    base:desc "Insight that triggers real‑time alerts when key metrics such as payload velocity or acceleration deviate beyond predefined thresholds."
]

instance DataStorageInsight : DTDFVocab:Insight [
    base:desc "Insight that represents successful persistence of telemetry and state data in TimescaleDB."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight that provides predictions from the simulation model for future crane states."
]

instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight that enables interactive visualization of telemetry and historical data via Grafana dashboards."
]

instance TrajectoryExecutionInsight : DTDFVocab:Action [
    base:desc "Action that executes optimal control trajectories commanded by the control service."
    DTDFVocab:IsAutomatic true
]

// Model
instance CartHoistBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral simulation model of the cart and hoist subsystems that ingests real‑time sensor streams."
    DTDFVocab:inputTo SimulationEngine
]

// Environment
instance LabEnvironment : DTDFVocab:Environment [
    base:contains GantryFrame, TrolleyRail, LiftingColumn, CraneBoom, CraneController, CartStepperMotor, HoistStepperMotor, SwingAngleEncoder, CartPositionEncoder, HoistLevelSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends motion commands to the Physical Crane Interface, which translates them into controller‑specific instructions and forwards them to the crane hardware. Feedback from the hardware is received by the Physical Crane Interface, passed to the Logging Application, and stored in TimescaleDB, allowing operators and validation services to confirm execution. The Digital Twin services (Trajectory Generator, Simulation, Continuous Validation) provide optimal trajectory or motion plans that the Control Application consumes and sends as commands to the crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows a C4 container model. Containers include: (1) Physical Crane – the physical hardware with controller; (2) Control Application – a Python microservice orchestrating operations; (3) Trajectory Generator Service – a Python microservice generating trajectories and communicating via MQTT; (4) Database – a TimescaleDB (or PostgreSQL) instance for continuous logging; (5) MQTT Broker – mediating message exchange between services; (6) Logging Application – a Python component that continuously records crane state; (7) Continuous Validation Service – a Python component that continuously compares sensor measurements to the digital model; and (8) Human‑Machine Interface – a web dashboard presenting real‑time status. All components are containerized or virtualised, using container orchestration for scalability, and the Digital Twin orchestrates interactions via the MQTT broker, coordinating control flow, data persistence, and validation across the system."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A Continuous Validation Service runs continuously, comparing real‑time sensor measurements with the simulation’s predicted state. It computes general distance metrics between measured and simulated values; if a threshold is exceeded, it notifies operators. The service thus provides ongoing model validation by ensuring the twin’s behavior stays within acceptable bounds."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All Digital Twin components communicate via an MQTT broker that acts as the central message bus. This broker supports publish–subscribe interactions between the Trajectory Generator, Simulation, Continuous Validation, Logging, and Dashboard services. The document does not specify further details on network topology, bandwidth, latency, reliability, or security protocols beyond the use of MQTT."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All Python components (Physical Crane Interface, Control Application, Logging Application, Trajectory Generator Service, Simulation Service, Continuous Validation Service, Dashboard) are bundled into a single Python module named gantrylib for deployment simplicity. For ease of deployment, the TimescaleDB, MQTT broker, and Grafana Dashboard are containerized with Docker and run locally on the operator’s environment (no explicit cloud or edge deployment is described). Computational resource requirements are not quantified in the document; scalability, reliability, and availability mechanisms are not mentioned beyond the inference that Docker containers provide isolation for the database, broker, and dashboard.
"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adopts open‑source industry standards: MQTT for publish/subscribe communication, TimescaleDB (PostgreSQL) for time‑series storage, Docker containers for deployment portability, and RESTful HTTP interfaces for service access. No formal certification or additional interoperability standards beyond MQTT are reported."
]