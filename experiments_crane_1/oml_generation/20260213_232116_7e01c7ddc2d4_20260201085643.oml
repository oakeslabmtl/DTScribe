instance CraneStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors embedded in the lab-scale gantry crane for real-time state data acquisition"
    DTDFVocab:producedData CraneStateDataTransmitted
]

instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneStateSensor
]

instance CraneStateData : DTDFVocab:Data [
    base:desc "Operational metrics of the gantry crane collected continuously for persistent storage and analysis"
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, OptimalControlEnabler, ContinuousValidationEnabler, DataVisualizationEnabler
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database for persistent storage of crane operational metrics"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance OptimalControlEnabler : DTDFVocab:Enabler [
    base:desc "Kinematic model-based enabler for trajectory optimization in optimal control service"
    DTDFVocab:enables OptimalControlService
]

instance DataVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "C4 Model-based visualization enabler for interactive real-time monitoring"
    DTDFVocab:enables DataVisualizationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Model comparison enabler for continuous validation service"
    DTDFVocab:enables ContinuousValidationService
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model for trajectory optimization in optimal control service"
    DTDFVocab:inputTo OptimalControlEnabler
]

instance C4Model : DTDFVocab:Model [
    base:desc "C4 Model for architectural visualization of the digital twin"
    DTDFVocab:inputTo DataVisualizationEnabler
]

instance GeneralModel : DTDFVocab:Model [
    base:desc "Digital twin model used for comparing physical system behavior during continuous validation"
    DTDFVocab:inputTo ContinuousValidationEnabler
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal control service using kinematic models for trajectory optimization to support research and education"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Historical data logging service for persistent storage of operational metrics"
    DTDFVocab:provides HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Data visualization service for interactive real-time monitoring of crane states"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service comparing physical system behavior against digital model predictions"
    DTDFVocab:provides ModelValidationInsight
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory recommendations for crane control based on kinematic model optimization"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Persistent storage of operational metrics for historical analysis and educational purposes"
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Interactive real-time visualization of crane states for educational demonstrations"
]

instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Validation insights from comparing physical system behavior against digital model predictions"
]

instance PhysicalCrane : DTDFVocab:Component [
    base:desc "Lab-scale gantry crane mechanical structure and embedded controller operating in controlled laboratory environment"
]

instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Python program interface transmitting crane state data to digital twin systems"
]

instance CraneLabEnvironment : DTDFVocab:Environment [
    base:contains PhysicalCrane, PhysicalCraneInterface
]

instance GitHubVersionControlEnabler : DTDFVocab:Enabler [
    base:desc "GitHub repository for version control of digital twin development"
    DTDFVocab:enables OptimalControlService, HistoricalDataLoggingService, DataVisualizationService, ContinuousValidationService
]

instance ContainerizationEnabler : DTDFVocab:Enabler [
    base:desc "Containerization technologies for dissemination of digital twin components"
    DTDFVocab:enables OptimalControlService, HistoricalDataLoggingService, DataVisualizationService, ContinuousValidationService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (Python) sends commands via the Physical Crane Interface to control the physical crane. The document does not specify command types, message formats, validation/authentication mechanisms, feedback systems, conflict resolution, or command execution confirmation details."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system's architecture is visualized using the C4 Model with context and container diagrams, employing containerization for deployment and an ad-hoc implementation approach without a commercial digital twin framework."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system uses an MQTT broker for inter-service signaling between containers such as the Trajectory Generator Service, Simulation Service, and Continuous Validation Service. Specific network topology details beyond MQTT pub/sub, bandwidth and latency requirements, reliability and redundancy mechanisms, and security protocols are not provided in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar utilizes AutomationML for digital twin modeling. The C4 Model is used for architectural visualization. No additional industry standards or interoperability frameworks beyond these are specified."
]