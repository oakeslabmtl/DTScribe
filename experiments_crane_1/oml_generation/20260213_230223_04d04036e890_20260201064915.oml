// =====================
// C3: Physical sensing components
// =====================

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist sway"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// =====================
// C4: Physical‑to‑virtual interaction (data transmitted)
// =====================

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// =====================
// C10: Data objects
// =====================

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurements from the encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed measurements from the anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance OperationalTelemetryData : DTDFVocab:Data [
    base:desc "Time‑stamped motor states, commands and trajectory points logged by the Python control interface"
    DTDFVocab:inputTo MQTTBroker
]

// =====================
// C2: Acting components
// =====================

instance StepperMotorCart : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart axis, controlled by TMC4671‑Eval controller"
]

instance StepperMotorHoist : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist axis, controlled by TMC4671‑Eval controller"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist end for picking up pucks"
]

// =====================
// C10: Models / Data
// =====================

instance CADModel : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane (Autodesk Fusion360)"
    DTDFVocab:inputTo SimulationEngine
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator"
    DTDFVocab:inputTo TrajectoryEngine
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of crane and its motor controllers"
    DTDFVocab:inputTo SimulationEngine
]

// =====================
// C11: Enablers
// =====================

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service messaging"
    DTDFVocab:enables DataLoggingService,
                    DataVisualizationService,
                    ContinuousValidationService,
                    SimulationService,
                    TrajectoryGenerationService,
                    HumanMachineInterfaceService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine running the digital replica of the crane and controllers"
    DTDFVocab:enables SimulationService
]

instance TrajectoryEngine : DTDFVocab:Enabler [
    base:desc "Kinematics engine used for trajectory planning"
    DTDFVocab:enables TrajectoryGenerationService
]

// =====================
// C6: Services
// =====================

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuous state logging service storing time‑stamped data in TimescaleDB"
    DTDFVocab:provides LoggingInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboard service visualising operational data in real time"
    DTDFVocab:provides VisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous Validation Service issues real‑time alerts when trajectory deviations exceed thresholds"
    DTDFVocab:provides AlertInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service provides a predictive replica of crane behaviour"
    DTDFVocab:provides SimulationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Trajectory Generator delivers optimized motion plans that reduce residual swing"
    DTDFVocab:provides TrajectoryOptimizationInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "HMI allows operators to monitor alerts and intervene in crane operation"
    DTDFVocab:provides OperatorInterventionAction
]

// =====================
// C17: Insights / Actions
// =====================

instance LoggingInsight : DTDFVocab:Insight [
    base:desc "Persisted archival of all sensor and actuator states for later analysis"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time dashboards of sensor readings, motor commands and trajectories"
]

instance AlertInsight : DTDFVocab:Insight [
    base:desc "Real‑time alerts when measured trajectory deviates beyond predefined thresholds"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Predictive assessment of upcoming crane states based on current commands"
]

instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized motion plan that minimizes swing and reduces cycle time"
]

instance OperatorInterventionAction : DTDFVocab:Action [
    base:desc "Operator can manually pause, modify or abort the current trajectory"
    DTDFVocab:IsAutomatic false
]

// =====================
// C8: Environment (optional for completeness)
// =====================

instance LabGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains StepperMotorCart,
                    StepperMotorHoist,
                    Electromagnet,
                    SwingAngleEncoder,
                    Anemometer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control Application (and Trajectory Generator Service) send motion set‑points and trajectory commands over the same MQTT broker to the Physical Crane Interface, which forwards them to the motor controllers to drive the cart and hoist motors and to actuate the electromagnet."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A set of C4‑model containers: Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface (all Python), MQTT broker, TimescaleDB, Grafana dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service; connected via a local Docker network and communicating primarily through MQTT topics."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares executed trajectory measurements with simulated trajectories, computes distance metrics, and checks them against a predefined acceptable threshold; violations trigger operator alerts on the Grafana dashboard."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication relies on MQTT (Eclipse Mosquitto) for signaling; the Physical Crane Interface connects to the Arduino and motor controllers over serial/USB, while higher‑level services interact via MQTT topics and direct database queries to TimescaleDB."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components run on a personal computer; the database, MQTT broker, and Grafana dashboard are containerised with Docker, started together via a Docker‑compose file; Python services are installed via pip from the gantrylib package."
]