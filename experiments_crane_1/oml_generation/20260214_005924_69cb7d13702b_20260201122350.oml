// C2: Acting Components
instance CartStepStepper : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor driven by a TMC4671‑Eval controller, controlled through the Python ‘Physical Crane Interface’ communicating with the Arduino"
]

instance HoistStepStepper : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor driven by a TMC4671‑Eval controller, controlled through the Python ‘Physical Crane Interface’ communicating with the Arduino"
]

instance CartElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet on the hoist for container pick‑up, driven by the Arduino"
]

// C3: Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring pendulum motion"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder on the cart stepper motor"
    DTDFVocab:producedData CartMotorEncoderDataTransmitted
]

instance CartCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor on the cart stepper motor"
    DTDFVocab:producedData CartCurrentDataTransmitted
]

instance HoistMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder on the hoist stepper motor"
    DTDFVocab:producedData HoistMotorEncoderDataTransmitted
]

instance HoistCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor on the hoist stepper motor"
    DTDFVocab:producedData HoistCurrentDataTransmitted
]

// C4: Physical-to-Virtual Interaction (Data Transmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CartMotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoder
]

instance CartCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartCurrentSensor
]

instance HoistMotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoder
]

instance HoistCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistCurrentSensor
]

// C10: Models/Data
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "CAD geometric model of the lab‑scale gantry crane created in Autodesk Fusion360"
    DTDFVocab:inputTo CADEnabler
]

instance KinematicPythonModel : DTDFVocab:Model [
    base:desc "Kinematic model implemented in Python for the crane"
    DTDFVocab:inputTo KinematicEnabler
]

instance SimulationControllerModel : DTDFVocab:Model [
    base:desc "Simulation model of the crane controller for predictive outcomes"
    DTDFVocab:inputTo SimulationEnabler
]

instance TrajectoryGeneratorAlgorithm : DTDFVocab:Model [
    base:desc "Optimal kinematic path planner with no residual swing"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance ValidationDistanceMetricModel : DTDFVocab:Model [
    base:desc "Continuous validation distance‑metric model for executed vs. simulated trajectories"
    DTDFVocab:inputTo ValidationEnabler
]

// C10: Data instances that receive sensor telemetry
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Real‑time swing‐angle telemetry from the swing‑angle encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Real‑time wind‑speed telemetry from the anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
]

instance CartMotorPositionData : DTDFVocab:Data [
    base:desc "Real‑time position telemetry from the cart motor encoder"
    DTDFVocab:fromData CartMotorEncoderDataTransmitted
]

instance CartMotorCurrentData : DTDFVocab:Data [
    base:desc "Real‑time current telemetry from the cart current sensor"
    DTDFVocab:fromData CartCurrentDataTransmitted
]

instance HoistMotorPositionData : DTDFVocab:Data [
    base:desc "Real‑time position telemetry from the hoist motor encoder"
    DTDFVocab:fromData HoistMotorEncoderDataTransmitted
]

instance HoistMotorCurrentData : DTDFVocab:Data [
    base:desc "Real‑time current telemetry from the hoist current sensor"
    DTDFVocab:fromData HoistCurrentDataTransmitted
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB container for time‑series data persistence, orchestrated by Docker Compose"
    DTDFVocab:enables DataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service signalling"
    DTDFVocab:enables ContinuousValidationService, SimulationService, TrajectoryGeneratorService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana container for dashboard visualization, orchestrated by Docker Compose"
    DTDFVocab:enables GrafanaDashboardService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker Compose orchestrator for the Digital Twin container environment"
]

instance GantrylibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module facilitating crane control and trajectory generation"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Containerized simulation environment for predictive outcomes"
    DTDFVocab:enables SimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Containerized continuous validation service computing distance metrics"
    DTDFVocab:enables ContinuousValidationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Containerized optimal trajectory generator service"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance CADEnabler : DTDFVocab:Enabler [
    base:desc "Container handling CAD model storage and retrieval"
]

instance KinematicEnabler : DTDFVocab:Enabler [
    base:desc "Container providing the kinematic Python model for simulation"
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Data logging service persisting all telemetry streams into TimescaleDB for historical analysis"
    DTDFVocab:provides OperatorNotificationInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Visualisation service rendering real‑time telemetry and history in Grafana dashboards"
    DTDFVocab:provides DeviationAlertInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Trajectory generation service providing optimal kinematic paths with zero residual swing"
    DTDFVocab:provides TrajectoryOptimizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service modeling the crane controller for predictive outcomes"
    DTDFVocab:provides ValidationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service computing distance metrics between executed and simulated trajectories, triggering threshold‑based alerts"
    DTDFVocab:provides DeviationAlertInsight, FaultLocalizationInsight
]

// C17: Insights
instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight into optimal trajectory parameters, informing controller tuning and maintenance scheduling"
]

instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Real‑time deviation alerts generated when trajectory execution diverges from planned path"
]

instance FaultLocalizationInsight : DTDFVocab:Insight [
    base:desc "Fault classification insights identifying underlying causes of anomalous behaviour"
]

instance OperatorNotificationInsight : DTDFVocab:Insight [
    base:desc "Operator notification generated by data logging to inform about system state and historical events"
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Insight into validation of simulated versus executed trajectories for simulation service"
]

// C17: Actions
instance OperatorNotificationAction : DTDFVocab:Action [
    base:desc "Automatic action notifying operators of significant telemetry or faults"
    DTDFVocab:IsAutomatic true
]

instance MaintenanceScheduleAction : DTDFVocab:Action [
    base:desc "Automatic action to schedule maintenance based on trajectory optimization and fault insights"
    DTDFVocab:IsAutomatic true
]

// C10: Environment & Components
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains CartStepStepper, HoistStepStepper, CartElectromagnet,
    SwingAngleEncoder, Anemometer, CartMotorEncoder, CartCurrentSensor,
    HoistMotorEncoder, HoistCurrentSensor
]

instance DockerCompositeContainer : DTDFVocab:Component [
    base:desc "Docker Compose orchestrated container environment hosting TimescaleDB, Mosquitto, Grafana, Simulation, TrajectoryGenerator, and Validation services"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory commands and control signals generated by the Trajectory Generator Service are sent via MQTT to the Control Application, which forwards them to the physical crane drivers; the Continuous Validation Service publishes alerts to the dashboard when deviations exceed thresholds; operators can adjust commands through the Human Machine Interface."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in near real‑time: Sensor data is logged at the native sampling rate of the Arduino (typically 10–100 Hz), the Continuous Validation Service processes data continuously, and trajectory generation updates are performed on demand as users command new starts; the entire set of operations is synchronized via the MQTT broker."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A container‑based constellation where data flows from the Physical Crane Interface to the Logging Service via MQTT, aggregates in TimescaleDB, is visualized through Grafana, receives trajectory commands from the Trajectory Generator, and validates operations via the Continuous Validation Service; all services communicate over MQTT and share a shared database."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design phase: CAD models in Autodesk Fusion360 and kinematic model defined in the software; Manufacturing phase: the physical crane is assembled from the BOM and firmware deployed to microcontrollers; Operated phase: the twin runs in parallel during crane operation, providing continuous validation and live visualization."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service compares real‑time sensor traces against simulated trajectories using distance metrics and thresholds; model validation trust is established through repeated comparison with measured data, and time‑series classification is employed to localize faults, ensuring fidelity of both kinematic and control models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical interface communicates with Arduino over serial (e.g., UART/USB); data from Arduino to DT services is published to an Eclipse Mosquitto MQTT broker using standard JSON payloads; services read/write to TimescaleDB via PostgreSQL‑compatible SQL; the Human Machine Interface connects to the broker and database through HTTPS to Grafana."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All Docker containers (Database, MQTT broker, Grafana dashboard, Logging, Trajectory Generator, Simulator, Validation) are orchestrated with Docker Compose on a local personal computer; Python modules are pip‑installable; documentation is served via MkDocs on GitHub Pages."
]