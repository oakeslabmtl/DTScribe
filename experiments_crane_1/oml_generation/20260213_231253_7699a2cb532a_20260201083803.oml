// =============================
// Physical Acting Components
// =============================

instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cartesian stepper motor driving the gantry motion, controlled by a Trinamic TMC4671‑Eval motor controller"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor lifting the load, driven by a Trinamic TMC4671‑Eval motor controller"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist used to pick up and release pucks"
]

// =============================
// Physical Sensing Components
// =============================

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder attached to the hoist, measuring crane swing in degrees"
    DTDFVocab:producedData SwingAngleTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed in m/s"
    DTDFVocab:producedData WindSpeedTransmitted
]

// =============================
// Data Transmission (Physical → Virtual)
// =============================

instance SwingAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// =============================
// Virtual Data (Stored / Processed)
// =============================

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements produced by SwingAngleEncoder"
    DTDFVocab:fromData SwingAngleTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements produced by Anemometer"
    DTDFVocab:fromData WindSpeedTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance TrajectoryData : DTDFVocab:Data [
    base:desc "Optimal motion‑plan trajectories generated by TrajectoryGeneratorService"
    DTDFVocab:inputTo TrajectoryPlannerEnabler
]

instance SimulatedTrajectoryData : DTDFVocab:Data [
    base:desc "Physics‑based simulated crane trajectories produced by SimulationService"
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance ValidationResultData : DTDFVocab:Data [
    base:desc "Comparison results between measured and simulated trajectories used by ContinuousValidationService"
    DTDFVocab:inputTo ValidationEngineEnabler
]

// =============================
// Models / Artefacts
// =============================

instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane in Autodesk Fusion 360"
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model describing the joint relations of the crane frame, cart, and hoist"
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model used to predict crane dynamics under given control inputs"
    DTDFVocab:inputTo SimulationEngineEnabler
]

// =============================
// Enablers (Tools / Infrastructure)
// =============================

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) container storing time‑series operational data"
    DTDFVocab:enables ContinuousLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for message exchange between services"
    DTDFVocab:enables DataVisualizationService
    DTDFVocab:enables TrajectoryGeneratorService
    DTDFVocab:enables SimulationService
    DTDFVocab:enables ContinuousValidationService
    DTDFVocab:enables FaultDetectionService
]

instance PythonGantrylibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module (installed via pip) providing high‑level crane control APIs"
    DTDFVocab:enables TrajectoryGeneratorService
    DTDFVocab:enables SimulationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana container rendering dashboards from data stored in TimescaleDB"
    DTDFVocab:enables DataVisualizationService
]

instance TrajectoryPlannerEnabler : DTDFVocab:Enabler [
    base:desc "Software component that receives trajectory data and forwards it to the crane controller"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Physics simulation engine (Dockerised) that consumes CAD, kinematic, and physics models"
    DTDFVocab:enables SimulationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation engine that compares measured data against simulated trajectories"
    DTDFVocab:enables ContinuousValidationService
]

// =============================
// Services (Logical Containers)
// =============================

instance ContinuousLoggingService : DTDFVocab:Service [
    base:desc "Service that continuously logs sensor measurements into TimescaleDB"
    DTDFVocab:provides OperationalDataLoggedInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Grafana‑based dashboard visualizing performance metrics for operator decision‑making"
    DTDFVocab:provides OperationalMetricsInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal crane motion plans that minimise swing"
    DTDFVocab:provides OptimalTrajectoryInsight
    DTDFVocab:provides TrajectoryData
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation of crane dynamics and controllers"
    DTDFVocab:provides SimulatedTrajectoryInsight
    DTDFVocab:provides SimulatedTrajectoryData
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates measured trajectories against simulated ones, raising alerts when distance‑metric thresholds are exceeded"
    DTDFVocab:provides OperatorAlertInsight
    DTDFVocab:provides ValidationResultData
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults in sensor streams and actuator responses based on deviation patterns"
    DTDFVocab:provides FaultDetectedInsight
]

// =============================
// Insights / Actions
// =============================

instance OperationalDataLoggedInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data has been successfully persisted in the time‑series database"
]

instance OperationalMetricsInsight : DTDFVocab:Insight [
    base:desc "Dashboard visualizations of swing angle, wind speed, motor currents, and trajectory errors for operational decision‑making"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal motion‑plan trajectory that reduces residual swing for the upcoming move"
]

instance SimulatedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Predicted crane trajectory generated by the physics simulation for a given control input"
]

instance OperatorAlertInsight : DTDFVocab:Insight [
    base:desc "Alert raised when measured trajectory deviates beyond configured thresholds from the simulated trajectory"
]

instance FaultDetectedInsight : DTDFVocab:Insight [
    base:desc "Detection of abnormal sensor or actuator behavior indicating a potential fault"
]

// =============================
// Environment & Physical Components
// =============================

instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains CraneFrameComponent, CartStepperMotor, HoistStepperMotor, ElectromagnetActuator, SwingAngleEncoder, Anemometer, ArduinoBoardComponent
]

instance CraneFrameComponent : DTDFVocab:Component [
    base:desc "Structural frame of the lab‑scale gantry crane"
]

instance ArduinoBoardComponent : DTDFVocab:Component [
    base:desc "Arduino microcontroller that reads SwingAngleEncoder and Anemometer and forwards measurements via MQTT"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends motion commands (e.g., speed set‑points, electromagnet activation) to the Physical Crane Interface, which translates them to the motor controllers and Arduino; trajectory commands are produced by the Trajectory Generator Service and delivered through MQTT to the control stack."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A hybrid architecture where the physical crane is attached to a PC; software components run as Docker containers (DB, MQTT, Grafana) and native Python processes (Physical Interface, Control App, Logging App, HMI). Services communicate via MQTT and the shared TimescaleDB, forming a coherent digital twin ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the designed stage (CAD and kinematic models) and the operated stage (real‑time sensor acquisition, control and validation during crane operation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares executed trajectories recorded from the physical crane with simulated trajectories, computes distance metrics, checks against a predefined threshold and raises alerts on the Grafana dashboard when the threshold is exceeded."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication uses MQTT (Eclipse Mosquitto) for signaling between services and the Physical Crane Interface, and a Python‑based TCP/serial link to the Arduino controllers; persistent data exchange uses PostgreSQL/TimescaleDB over standard SQL connections."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All Dockerized components (TimescaleDB, MQTT broker, Grafana) are hosted on the same personal computer using Docker Compose; the Python modules run directly on the host OS and are installed via pip; the entire system can be started with a single 'docker compose up' command."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture is modeled using the C4 model (context, container diagrams); containerization follows Docker standards; data storage follows PostgreSQL/TimescaleDB standards."
]