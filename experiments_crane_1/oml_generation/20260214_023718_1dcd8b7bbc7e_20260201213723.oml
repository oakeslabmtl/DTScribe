// C2: Acting Components
instance CartMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor responsible for horizontal movement controlled via TMC4671-Eval motor controller"
]

instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor responsible for vertical movement controlled via TMC4671-Eval motor controller"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at hoist end used for container pickup and drop operations"
]

instance ArduinoController : DTDFVocab:ActingComponent [
    base:desc "Arduino-based control system integrating sensor inputs (swing angle encoder, anemometer) and generating control signals for motors"
]

// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures swinging motion of the hoist to validate trajectory execution"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Measures wind speed which may influence crane dynamics"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorControllerFeedback : DTDFVocab:SensingComponent [
    base:desc "Provides feedback on motor position, speed, and torque via encoder signals from TMC4671-Eval controllers"
    DTDFVocab:producedData MotorControllerDataTransmitted
]

// C4: Data Transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MotorControllerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerFeedback
]

// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Mathematical model of the crane's motion (cart/hoist dynamics) used by TrajectoryGeneratorService to compute optimal trajectories"
    DTDFVocab:inputTo PythonEcosystemEnabler
]

instance CraneCADModel : DTDFVocab:Model [
    base:desc "Autodesk Fusion 360 CAD representation of the crane's physical structure for visualization and kinematic analysis"
    DTDFVocab:inputTo GrafanaEnabler
]

instance CraneCapellaModel : DTDFVocab:Model [
    base:desc "Capella system architecture and behavior models for teaching and system analysis"
    DTDFVocab:inputTo EducationalService
]

instance CraneDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic model of crane's motors and swinging behavior used by SimulationService for offline validation"
    DTDFVocab:inputTo PythonEcosystemEnabler
]

instance CraneStateData : DTDFVocab:Data [
    base:desc "Real-time data including position, speed, and acceleration of crane components"
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance SensorReadingsData : DTDFVocab:Data [
    base:desc "Historical and real-time sensor readings including swing angle, wind speed, and motor controller feedback"
    DTDFVocab:fromData SensorReadingsDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance TrajectoryExecutionLogs : DTDFVocab:Data [
    base:desc "Logs of executed trajectories including timestamps and sensor validation results"
    DTDFVocab:fromData TrajectoryExecutionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "PostgreSQL extension optimized for time-series data storage of crane state, sensor readings, and trajectory logs"
    DTDFVocab:enables LoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Real-time and historical data visualization platform supporting multiple data sources including TimescaleDB and MQTT"
    DTDFVocab:enables VisualizationService
]

instance MosquittoMQTTEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker facilitating inter-service communication between logging, validation, and simulation services"
    DTDFVocab:enables LoggingService, ContinuousValidationService, SimulationService
]

instance DockerEnabler : DTDFVocab:Enabler [
    base:desc "Containerization platform using Docker and docker-compose for deploying database, MQTT broker, and dashboard services"
    DTDFVocab:enables LoggingService, VisualizationService, SimulationService
]

instance PythonEcosystemEnabler : DTDFVocab:Enabler [
    base:desc "Python implementation environment for trajectory generation, simulation, and validation services using kinematics and time-series analysis libraries"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

instance ArduinoHardwareEnabler : DTDFVocab:Enabler [
    base:desc "Arduino platform for sensor data acquisition and control signal generation interfacing with crane controller"
    DTDFVocab:enables PhysicalCraneInteraction
]

instance TMC4671ControllerEnabler : DTDFVocab:Enabler [
    base:desc "TMC4671-Eval motor controllers managing stepper motor operations for both cart and hoist movements"
    DTDFVocab:enables PhysicalCraneInteraction
]

// C6: Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Continuously records crane state, sensor readings, and trajectory execution in TimescaleDB time-series database"
    DTDFVocab:provides CraneStateInsight, SensorDataInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides Grafana dashboard visualizing real-time and historical crane data including trajectory traces with confidence bounds"
    DTDFVocab:provides OperationalVisualizationInsight, EducationalVisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal trajectories using crane kinematic model to minimize residual swinging and reduce energy consumption"
    DTDFVocab:provides OptimizedTrajectoryAction, EnergyOptimizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories with simulated trajectories, calculating distance metrics and triggering alerts for deviations"
    DTDFVocab:provides TrajectoryValidationInsight, FaultDetectionAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Replicates crane dynamics including motor responses and swinging behavior for offline validation of trajectories or fault scenarios"
    DTDFVocab:provides SimulationValidationInsight, ResearchAnalysisInsight
]

instance EducationalService : DTDFVocab:Service [
    base:desc "Provides visualizations and HMIs for teaching digital twin concepts including real-time state monitoring and fault detection workflows"
    DTDFVocab:provides EducationalInsight
]

// C17: Insights/Actions
instance CraneStateInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of crane position, speed, and acceleration state"
]

instance SensorDataInsight : DTDFVocab:Insight [
    base:desc "Historical and real-time analysis of sensor readings including swing angle and wind speed"
]

instance OperationalVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of real-time crane operations with trajectory traces and confidence bounds"
]

instance EducationalVisualizationInsight : DTDFVocab:Insight [
    base:desc "Educational dashboards demonstrating digital twin concepts and validation workflows"
]

instance OptimizedTrajectoryAction : DTDFVocab:Action [
    base:desc "Generation of kinematically optimized trajectories to minimize residual swinging"
    DTDFVocab:IsAutomatic true
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Analysis of energy consumption patterns based on optimized trajectories"
]

instance TrajectoryValidationInsight : DTDFVocab:Insight [
    base:desc "Comparison of executed vs simulated trajectories to validate trajectory execution"
]

instance FaultDetectionAction : DTDFVocab:Action [
    base:desc "Automatic detection and localization of anomalies in crane operation using time-series classification"
    DTDFVocab:IsAutomatic true
]

instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Offline validation of trajectories and fault scenarios using dynamic simulation models"
]

instance ResearchAnalysisInsight : DTDFVocab:Insight [
    base:desc "Post-mortem analysis of faults or trajectory deviations for research purposes"
]

instance EducationalInsight : DTDFVocab:Insight [
    base:desc "Educational content demonstrating digital twin principles through crane simulations and fault detection workflows"
]

// Additional Data Transmitted instances for complete flow
instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerFeedback, SwingAngleEncoder
]

instance SensorReadingsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder, Anemometer
]

instance TrajectoryExecutionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerFeedback, SwingAngleEncoder
]

// C12: Physical-to-Virtual Interaction
instance PhysicalCraneInteraction : DTDFVocab:Interaction [
    base:desc "Real-time data transmission from physical crane components to digital twin services via MQTT broker"
    base:isContainedIn CraneLabEnvironment
    DTDFVocab:fromData CraneStateDataTransmitted, SensorReadingsDataTransmitted, TrajectoryExecutionDataTransmitted
]

// C13: Virtual-to-Physical Interaction
instance VirtualToPhysicalControl : DTDFVocab:Interaction [
    base:desc "Optimized trajectory commands generated by digital twin services that could potentially influence physical crane operations"
    DTDFVocab:fromData OptimizedTrajectoryAction
    DTDFVocab:toService ArduinoHardwareEnabler, TMC4671ControllerEnabler
]

// C14: Environment
instance CraneLabEnvironment : DTDFVocab:Environment [
    base:desc "Controlled lab environment housing the physical gantry crane and its digital twin infrastructure"
    base:contains PhysicalCrane, DigitalTwinInfrastructure
]

instance PhysicalCrane : DTDFVocab:Component [
    base:desc "Lab-scale gantry crane system including structural frame, motors, controllers, and sensors"
    base:contains CartMotor, HoistMotor, Electromagnet, SwingAngleEncoder, Anemometer
    base:isContainedIn CraneLabEnvironment
]

instance DigitalTwinInfrastructure : DTDFVocab:Component [
    base:desc "Complete digital twin system including services, enablers, and models"
    base:contains TimescaleDBEnabler, GrafanaEnabler, MosquittoMQTTEnabler,
                DockerEnabler, PythonEcosystemEnabler, LoggingService,
                VisualizationService, TrajectoryGeneratorService,
                ContinuousValidationService, SimulationService
    base:isContainedIn CraneLabEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The virtual-to-physical interaction is unidirectional in this exemplar, as the digital twin primarily **observes and validates** rather than directly controlling the physical crane. However, the digital twin influences the physical system indirectly through:
  1. **Optimized Trajectory Generation**: The *Trajectory Generator Service* computes optimal movement paths (e.g., minimizing residual swinging) and provides these as **reference trajectories** for the crane’s controller. The *Simulation Service* validates these trajectories before execution.
  2. **Fault Alerts**: The *Continuous Validation Service* compares real-time sensor data with simulated trajectories. If deviations exceed thresholds, alerts are sent to the **Grafana dashboard**, enabling operators to intervene manually.
  3. **Data-Driven Insights**: The digital twin’s visualization tools (*Dashboard*) provide real-time status updates (e.g., crane position, speed) to operators via the *Human Machine Interface (HMI)*."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin operates on **real-time and near-real-time scales**:
  1. **Real-Time Data Acquisition**: Sensor data (e.g., swing angle, wind speed) is streamed at **millisecond to second intervals** to the digital twin for continuous validation.
  2. **Trajectory Execution**: Optimized trajectories are generated and validated in **sub-second timescales** (e.g., 100–500 ms for trajectory planning).
  3. **Fault Detection**: Continuous validation compares real-time sensor data with simulated trajectories at **high-frequency intervals** (e.g., 10–100 Hz), enabling immediate fault detection.
  4. **Historical Analysis**: Logged data is stored in **TimescaleDB** for offline analysis (e.g., trend analysis, fault localization) with no strict time constraints beyond data retention policies."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation follows a **modular, service-oriented architecture** with the following components and their interactions:
  1. **Physical Layer**:
     - *Physical Crane*: Hardware (motors, sensors, Arduino).
     - *Physical Crane Interface*: Python module connecting the crane’s controller to the digital twin via MQTT.
  2. **Digital Twin Layer**:
     - *Database* (TimescaleDB): Central repository for all logged data.
     - *MQTT Broker* (Eclipse Mosquitto): Enables asynchronous communication between services.
     - *Trajectory Generator Service*: Computes optimal trajectories using kinematic models.
     - *Simulation Service*: Validates trajectories offline.
     - *Continuous Validation Service*: Compares real-time data with simulations in real-time.
     - *Dashboard* (Grafana): Visualizes data and alerts.
  3. **Human Interface Layer**:
     - *Human Machine Interface (HMI)*: Python-based frontend for operator control and configuration.
     - *Logging Application*: Continuously logs crane state to the database.
     - *Control Application*: Interfaces with the crane’s controller via the *Physical Crane Interface*.
  The constellation is deployed on a **single personal computer**, with Docker managing the database, MQTT broker, and dashboard as isolated containers. The Python services (*gantrylib* module) run natively on the host OS."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin covers the **as-operated** lifecycle stage of the physical crane, focusing on **real-time monitoring, validation, and optimization** during operation. It does not explicitly model the *as-designed* (CAD) or *as-manufactured* phases, though:
  1. **CAD Models**: The crane’s geometry is represented in **Autodesk Fusion 360** for visualization and kinematic modeling.
  2. **Model-Based Systems Engineering (MBSE)**: The *arcadia* folder contains **Capella models** (developed for educational purposes) representing system architecture and behavior, but these are not integrated into the operational digital twin.
  The digital twin’s primary role is **runtime validation and optimization**, aligning with the *as-operated* phase."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The digital twin’s fidelity and validity are ensured through:
  1. **Model Validation**:
     - The *Continuous Validation Service* compares real-time sensor data (e.g., swing angle) with **simulated trajectories** generated by the *Simulation Service*, using distance metrics to quantify deviations.
     - A **threshold-based alert system** notifies operators if deviations exceed acceptable limits (e.g., due to wind interference or motor wear).
  2. **Uncertainty Handling**:
     - The *Simulation Service* provides **confidence bounds** (upper/lower bounds) for simulated trajectories, visualized in Grafana to indicate prediction uncertainty.
     - Sensor noise and environmental factors (e.g., wind) are implicitly accounted for in the validation process.
  3. **Verification Mechanisms**:
     - The *Trajectory Generator Service* uses a **kinematic model** validated against real-world data to ensure trajectory accuracy.
     - Offline simulations are run to verify the *Simulation Service*’s fidelity before real-time deployment.
  4. **Error Sources**:
     - **Model Errors**: Discrepancies between the kinematic model and real-world dynamics (e.g., friction, motor nonlinearities).
     - **Sensor Errors**: Noise in swing angle encoder or anemometer readings.
     - **Network Latency**: Potential delays in MQTT data transmission, though real-time requirements are met with millisecond-scale updates."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection between the physical crane and digital twin is established via:
  1. **Data Protocols**:
     - **MQTT (Eclipse Mosquitto)**: Used for asynchronous communication between the *Physical Crane Interface* (Python) and digital twin services (*Logging*, *Validation*).
     - **UART/Serial**: Arduino communicates with motor controllers and sensors via serial protocols.
  2. **Network Architecture**:
     - The *Physical Crane Interface* acts as a **bridge** between the crane’s controller (Arduino) and the MQTT broker, translating sensor data into MQTT topics (e.g., `crane/swing_angle`, `crane/wind_speed`).
     - The digital twin services subscribe to these topics to receive real-time updates.
  3. **Latency and Throughput**:
     - MQTT QoS level **1** is used to ensure **at-least-once delivery** of sensor data, with typical latencies in the **10–100 ms range** for real-time validation.
     - The *Logging Application* buffers data before writing to TimescaleDB to optimize database performance."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is hosted and deployed on a **single personal computer** with the following technical setup:
  1. **Physical Deployment**:
     - The **physical crane** is connected to the computer via USB (Arduino) and Ethernet (for MQTT/Docker network).
     - The *Physical Crane Interface* and *Control Application* run as native Python processes on the host OS.
  2. **Digital Twin Deployment**:
     - **Containerized Services**: The *Database* (TimescaleDB), *MQTT Broker* (Mosquitto), and *Dashboard* (Grafana) are deployed as **Docker containers** using a `docker-compose.yml` file.
     - **Python Services**: The *Trajectory Generator*, *Simulation*, and *Continuous Validation* services are bundled in the *gantrylib* Python module, installed via `pip`.
     - **Initialization**: The `docker-compose` command automates the setup of containers, database initialization, and dashboard configuration on first deployment.
  3. **Scalability**: The current architecture is not designed for distributed deployment but can be extended with additional containers or services as needed."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The digital twin does not explicitly integrate with external information systems beyond its core components. However, the following **potential integration points** are noted:
  1. **Sensor Data Integration**:
     - The Arduino could theoretically interface with additional sensors (e.g., load cells, temperature sensors) if extended for broader monitoring.
  2. **External APIs**:
     - The *MQTT Broker* could be exposed to external systems (e.g., a larger harbor simulation) via additional topics or API gateways, though this is not implemented in the current exemplar.
  3. **Educational Extensions**:
     - The **harbor simulation** extension (for teaching) integrates the crane with a **container identification system** and a **ship digital twin with buoyancy models**, but these are not part of the core digital twin constellation.
  No standardized APIs (e.g., OPC UA, AutomationML) are used for horizontal integration in the current implementation."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "The data ownership and privacy aspects are as follows:
  1. **Data Ownership**:
     - The digital twin and its data are **open-source** under the **MIT License**, hosted on **Cosys-Lab’s GitHub repository**.
     - The **TimescaleDB** stores all logged data, which is accessible to researchers and educators using the exemplar. No proprietary data ownership is enforced.
  2. **Data Privacy**:
     - The exemplar does not handle sensitive or personal data; all data pertains to the **physical crane’s operational state** (e.g., sensor readings, trajectories).
     - No encryption or access controls are implemented beyond standard Docker container isolation and GitHub repository permissions.
     - The **MQTT broker** operates in a local network, and data transmission is not secured beyond basic MQTT QoS guarantees.
  3. **Ethical Considerations**:
     - The exemplar is designed for **academic research and education**, with no implications for privacy or sensitive data handling. Ethical review is not applicable."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin adheres to the following standards and conventions:
  1. **Data Standards**:
     - **TimescaleDB** (PostgreSQL extension) for time-series data storage, leveraging SQL for querying.
     - **MQTT v3.1.1** protocol for inter-service communication.
  2. **Modeling Standards**:
     - **AutomationML** is referenced in the related work ([13]) but not used in this exemplar.
     - **Capella** (SysML-based) is used for MBSE models in the *arcadia* folder, primarily for educational purposes.
  3. **Software Standards**:
     - **Python** for service implementation, following common libraries (e.g., `paho-mqtt` for MQTT, `pandas` for time-series analysis).
     - **Docker** for containerization, using standard `docker-compose` files.
  4. **Hardware Standards**:
     - **TMC4671-Eval** motor controllers (Trinamic) for stepper motor management.
     - **Arduino** (ATmega-based) for sensor interfacing.
  No industry-specific digital twin standards (e.g., **ISO/IEC 23247**, **OPC UA**) are explicitly implemented."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The security and safety considerations for the digital twin are as follows:
  1. **Security**:
     - **No Remote Actuation**: The digital twin does not remotely control the physical crane; all actuation is managed by the onboard controller (Arduino + TMC4671).
     - **Local Network**: The MQTT broker operates on a **local network** (no public exposure), reducing attack surfaces.
     - **Authentication**: No authentication mechanisms are implemented for MQTT topics or database access; access is restricted to the local machine.
     - **Data Encryption**: No encryption is applied to MQTT messages or database storage; data is transmitted in plaintext.
  2. **Safety**:
     - **Manual Override**: Operators can manually intervene via the *Human Machine Interface* if alerts are triggered (e.g., stopping the crane during a fault).
     - **Threshold-Based Alerts**: The *Continuous Validation Service* only notifies operators of deviations; no autonomous corrective actions are taken.
     - **Physical Safeguards**: The crane lacks emergency stop mechanisms or fail-safes beyond manual intervention.
  3. **Human Safety**:
     - The exemplar is designed for **lab-scale use** with no human operators in proximity to the crane during operation. No safety protocols for human-machine interaction are addressed."
]