// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring payload swing angle on the gantry crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed near the gantry crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C11: Data (time‑series stored in TimescaleDB)
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of payload swing angle values logged in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of wind speed measurements logged in TimescaleDB"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C10: Models/Data
instance CADModelFusion360 : DTDFVocab:Model [
    base:desc "3‑D CAD model of the gantry crane created in Autodesk Fusion‑360"
    DTDFVocab:inputTo DockerComposeEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generation service to compute swing‑free paths"
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model of the crane and its controllers"
    DTDFVocab:inputTo SimulationServiceEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) for time‑series storage"
    DTDFVocab:enables DataLoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana instance for visualising operational data"
    DTDFVocab:enables GrafanaDashboardService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime with gantrylib package for generating optimal trajectories"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationServiceEnabler : DTDFVocab:Enabler [
    base:desc "Docker container executing the physics‑based crane simulation"
    DTDFVocab:enables SimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Python scripts that compare executed trajectories against simulated ones"
    DTDFVocab:enables ContinuousValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for message exchange between physical and virtual sides"
    DTDFVocab:enables MQTTBrokerService
]

instance PythonRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Standard Python 3.x runtime used by many DT services"
    DTDFVocab:enables TrajectoryGenerationService, SimulationService, ContinuousValidationService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestration for one‑click deployment of all containers"
    DTDFVocab:enables DataLoggingService, GrafanaDashboardService, TrajectoryGenerationService, SimulationService, ContinuousValidationService, MQTTBrokerService
]

instance GantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source gantrylib Python package providing crane kinematics and controller abstraction"
    DTDFVocab:enables TrajectoryGenerationService, SimulationService
]

instance ArduinoFirmwareEnabler : DTDFVocab:Enabler [
    base:desc "Arduino firmware that acquires encoder and anemometer signals and publishes via MQTT"
    DTDFVocab:enables MQTTBrokerService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Collects sensor streams and stores them as time‑series in TimescaleDB"
    DTDFVocab:provides DataLoggingInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Displays real‑time status and historic trends for operators"
    DTDFVocab:provides OperationalVisualizationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free trajectories for the crane using the kinematic model"
    DTDFVocab:provides OptimalSwingFreePathInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs physics‑based simulation of crane motion and controller behavior"
    DTDFVocab:provides SimulatedTrajectoryDataInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories with simulated ones and raises alerts on deviations"
    DTDFVocab:provides TrajectoryDeviationAlertInsight, AdjustControlParametersAction
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Message broker that transports sensor data and control commands using MQTT"
    DTDFVocab:provides MQTTMessageTransportInsight
]

// C17: Insights
instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Successful persistence of sensor data enables later analysis"
]

instance OperationalVisualizationInsight : DTDFVocab:Insight [
    base:desc "Operators can monitor real‑time crane status and historic trends"
]

instance OptimalSwingFreePathInsight : DTDFVocab:Insight [
    base:desc "Provides optimal swing‑free paths for payload movement"
]

instance SimulatedTrajectoryDataInsight : DTDFVocab:Insight [
    base:desc "Simulation yields expected trajectory data for validation"
]

instance TrajectoryDeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when executed trajectory deviates from simulated reference"
]

instance MQTTMessageTransportInsight : DTDFVocab:Insight [
    base:desc "Reliable transmission of sensor readings and commands via MQTT"
]

// C17: Actions
instance AdjustControlParametersAction : DTDFVocab:Action [
    base:desc "Operator or automated system adjusts PID or speed settings to correct trajectory"
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the crane cart, controlled by a Trinamic TMC4671‑Eval board"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist winch, controlled by a Trinamic TMC4671‑Eval board"
]

instance ElectromagnetEndEffector : DTDFVocab:ActingComponent [
    base:desc "Electromagnet used to pick up and release pucks"
]

// C13: Physical components (environment)
instance PhysicalCrane : DTDFVocab:Component [
    base:desc "Physical gantry crane assembly with frame, motors, and end‑effector"
]

instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Python program mediating Arduino MQTT messages to higher‑level services"
]

instance ControlApplication : DTDFVocab:Component [
    base:desc "Software controlling the stepper motors and electromagnet based on trajectory commands"
]

instance LoggingApplication : DTDFVocab:Component [
    base:desc "Application that subscribes to MQTT topics and writes data into TimescaleDB"
]

instance HumanMachineInterface : DTDFVocab:Component [
    base:desc "Web UI (Grafana) allowing operators to view status and intervene"
]

instance TimescaleDBContainer : DTDFVocab:Component [
    base:desc "Docker container running TimescaleDB for time‑series storage"
]

instance GrafanaContainer : DTDFVocab:Component [
    base:desc "Docker container running Grafana for dashboards"
]

instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Container executing the Trajectory Generation service"
]

instance SimulationServiceContainer : DTDFVocab:Component [
    base:desc "Container executing the Crane Simulation service"
]

instance ContinuousValidationServiceContainer : DTDFVocab:Component [
    base:desc "Container executing the Continuous Validation service"
]

instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Container running Eclipse Mosquitto MQTT broker"
]

instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains PhysicalCrane, PhysicalCraneInterface, ControlApplication, LoggingApplication, HumanMachineInterface,
                TimescaleDBContainer, GrafanaContainer, TrajectoryGeneratorContainer, SimulationServiceContainer,
                ContinuousValidationServiceContainer, MQTTBrokerContainer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends motion commands (e.g., optimal trajectories generated by the Trajectory Generator Service) through the Physical Crane Interface to the motor controllers; the HMI also allows operators to issue commands that are relayed similarly via MQTT."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous (real‑time) operation: the Logging Application records state continuously, and the Continuous Validation Service runs continuously to compare live measurements with simulations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical sensors feed data via the Arduino to a Python interface that publishes to MQTT; services (trajectory generation, simulation, validation) subscribe to MQTT, read/write state from the TimescaleDB, and publish results to the Grafana dashboard; the Control Application consumes trajectory outputs to command the motors, closing the loop."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin spans the design stage (CAD models of the crane), the manufacturing/assembly stage (physical crane hardware), and the operational stage (runtime data acquisition, simulation, and validation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service computes distance metrics between measured trajectories and simulated trajectories, compares them against a predefined threshold, and raises alerts on the dashboard when the threshold is exceeded, thereby providing runtime fidelity checks."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication is performed over MQTT (Eclipse Mosquitto); data persistence uses TimescaleDB accessed via standard SQL; all containers share a Docker network; Python applications communicate with the Arduino via serial links."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software runs on a single personal computer; Docker containers host the database, MQTT broker, and Grafana dashboard; the gantrylib Python module is installed with pip; Docker‑Compose starts and stops the entire stack with a single command."
]