// C1: Physical Acting Components
instance GantryFrame : DTDFVocab:ActingComponent [
    base:desc "The physical hardware structure of the lab-scale gantry crane system inspired by harbor cranes in the port of Antwerp"
]

instance CartMotorController : DTDFVocab:Actuator [
    base:desc "TMC4671-Eval controller for stepper motor driving horizontal movement of the crane cart"
]

instance HoistMotorController : DTDFVocab:Actuator [
    base:desc "TMC4671-Eval controller for stepper motor driving vertical hoist movement"
]

instance SwingElectromagnet : DTDFVocab:Actuator [
    base:desc "Electromagnet at the hoist end for picking up small pucks (container replicas)"
]

instance ArduinoCraneInterface : DTDFVocab:Actuator [
    base:desc "Arduino board controlling all crane actuators and interfacing with sensors"
]

// C2: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures swinging motion of the hoist using an encoder to track angle position"
    DTDFVocab:producedData SwingAngleDataStream
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Measures wind speed in the crane's operational environment"
    DTDFVocab:producedData WindSpeedDataStream
]

instance ArduinoSensorInterface : DTDFVocab:SensingComponent [
    base:desc "Arduino board measuring and interfacing electromagnet status, swing angle, and wind speed"
    DTDFVocab:producedData ElectromagnetStatusDataStream, SwingAngleDataStream, WindSpeedDataStream
]

// C3: Data Transmission Streams
instance SwingAngleDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance ElectromagnetStatusDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoSensorInterface
]

// C4: Data Storage
instance OperationalMetricsDatabase : DTDFVocab:Data [
    base:desc "TimescaleDB database storing continuous operational metrics (trajectory execution, residual motion) for analysis"
    DTDFVocab:fromData SwingAngleDataStream, WindSpeedDataStream, ElectromagnetStatusDataStream
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance SimulationResultsDatabase : DTDFVocab:Data [
    base:desc "TimescaleDB database storing simulation results for comparison with real-world execution"
    DTDFVocab:fromData KinematicTrajectoryDataStream
]

instance TrajectoryExecutionLog : DTDFVocab:Data [
    base:desc "Log of actual trajectory execution metrics for performance analysis"
    DTDFVocab:fromData SwingAngleDataStream, WindSpeedDataStream
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C5: Models
instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Mathematical kinematic model for generating optimal crane trajectories with minimal residual swinging motion"
    DTDFVocab:inputTo PythonKinematicsLibrary
]

instance CADStructureModel : DTDFVocab:Model [
    base:desc "Autodesk Fusion 360 CAD models representing the physical gantry crane structure and components"
    DTDFVocab:inputTo CADVisualizationEnabler
]

instance ArcadiaSystemModel : DTDFVocab:Model [
    base:desc "Capella Arcadia model demonstrating Model-Based Systems Engineering for crane control systems"
    DTDFVocab:inputTo MBSEEnabler
]

instance OptimalTrajectoryGenerator : DTDFVocab:Model [
    base:desc "Python-based implementation of optimal trajectory generation algorithm using kinematic models"
    DTDFVocab:inputTo gantrylibModule
]

// C6: Enablers/Tools
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "PostgreSQL-based TimescaleDB for time-series data logging and storage of operational metrics"
    DTDFVocab:enables OperationalMetricsDatabase, SimulationResultsDatabase, TrajectoryExecutionLog
]

instance PythonKinematicsLibrary : DTDFVocab:Enabler [
    base:desc "Python libraries implementing kinematic models for trajectory generation and optimization"
    DTDFVocab:enables OptimalTrajectoryGenerator
]

instance gantrylibModule : DTDFVocab:Enabler [
    base:desc "Open-source Python module providing crane control and digital twin services with modular architecture"
    DTDFVocab:enables OptimalTrajectoryGenerator, ContinuousValidationService
]

instance DockerContainerization : DTDFVocab:Enabler [
    base:desc "Docker containerization for deploying all digital twin services with consistent deployment environments"
    DTDFVocab:enables DashboardService, TrajectoryGeneratorService, ContinuousValidationService, MQTTBrokerService
]

instance GrafanaVisualization : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for real-time and historical data visualization of crane operations"
    DTDFVocab:enables RealTimeDashboard
]

instance EclipseMQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker facilitating service-to-service communication in containerized environment"
    DTDFVocab:enables MQTTBrokerService
]

instance ArduinoInterface : DTDFVocab:Enabler [
    base:desc "Arduino hardware and software for interfacing with physical sensors and actuators"
    DTDFVocab:enables PhysicalCraneInterface
]

instance OpenSourceDocumentation : DTDFVocab:Enabler [
    base:desc "Open-source tools (Docker Compose, MkDocs) for documentation and deployment management"
    DTDFVocab:enables DeploymentManagementService
]

// C7: Digital Twin Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service generating optimal trajectories using kinematic models to eliminate residual swinging motion"
    DTDFVocab:provides OptimalTrajectoryPlanningInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service continuously comparing real-world execution with simulations to detect faults and ensure accuracy"
    DTDFVocab:provides FaultDetectionAlertsAction
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service responsible for logging operational metrics into TimescaleDB database"
    DTDFVocab:provides HistoricalDataLoggingInsight
]

instance RealTimeDashboard : DTDFVocab:Service [
    base:desc "Human-Machine Interface showing real-time and simulated trajectory traces for operator monitoring"
    DTDFVocab:provides OperatorMonitoringInsight
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Service orchestrating MQTT communication between digital twin components"
    DTDFVocab:provides ServiceCommunicationAction
]

instance DeploymentManagementService : DTDFVocab:Service [
    base:desc "Service managing container deployment and documentation using open-source tools"
    DTDFVocab:provides DeploymentValidationInsight
]

// C8: Insights/Actions
instance OptimalTrajectoryPlanningInsight : DTDFVocab:Insight [
    base:desc "Insight that reduces residual motion and improves crane efficiency through optimal trajectory planning"
]

instance FaultDetectionAlertsAction : DTDFVocab:Action [
    base:desc "Automatic action that alerts operators to faults (e.g., motor issues) via dashboard notifications"
    DTDFVocab:IsAutomatic true
]

instance HistoricalDataLoggingInsight : DTDFVocab:Insight [
    base:desc "Insight enabling performance analysis and predictive maintenance through historical data logging"
]

instance OperatorMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight providing real-time monitoring capabilities for crane operators through the HMI"
]

instance DeploymentValidationInsight : DTDFVocab:Insight [
    base:desc "Insight ensuring reliable deployment and validation of digital twin components"
]

// C9: Physical Crane Interface
instance PhysicalCraneInterface : DTDFVocab:Environment [
    base:contains ArduinoCraneInterface, SwingAngleEncoder, AnemometerSensor
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains TrajectoryGeneratorService, ContinuousValidationService, DataLoggingService,
              RealTimeDashboard, MQTTBrokerService, DeploymentManagementService
]

instance CombinedCraneEnvironment : DTDFVocab:Environment [
    base:contains PhysicalCraneInterface, DigitalTwinEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "['Optimal trajectory generation service sends movement commands to the crane\u2019s controller via the Control Application.', 'Simulation service provides virtual trajectories for continuous validation, which are compared against real-world execution.', 'Continuous validation service notifies operators of deviations via the dashboard if thresholds are breached, triggering manual intervention.']"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real-time synchronization between physical and digital systems, with validation metrics updated dynamically during operation. The system supports near-instantaneous data flow and validation checks during execution."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "['Physical Crane (hardware) + Physical Crane Interface (Python) + Control Application (Python) + Logging Application (Python) + HMI (Python) form the physical system.', 'Digital Twin: Database (TimescaleDB) \u2194 Dashboard (Grafana) \u2194 Trajectory Generator Service \u2194 Simulation Service \u2194 Continuous Validation Service \u2194 MQTT Broker (Eclipse Mosquitto).', 'Containerized deployment via Docker Compose for orchestration and network management.']"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "['As designed (ideal): CAD models and kinematic models for trajectory planning.', 'As manufactured: Physical crane hardware with actual motor controllers and sensors.', 'As operated: Real-time operation with continuous validation and fault detection.']"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "['Verification: Kinematic models and simulation services validate digital twin accuracy against real-world data.', 'Validation: Continuous validation service compares real-world execution with simulations using distance metrics and thresholds.', 'Uncertainty: Wind speed measurements (via anemometer) and encoder readings are used for real-time adjustments.', 'Errors: Fault detection methods (time-series classification) identify deviations from expected behavior.']"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "['MQTT protocol for real-time service communication between digital twin components.', 'Networked via Docker containers on a single personal computer for simplicity.', 'Database (TimescaleDB) and dashboard (Grafana) communicate via RESTful APIs or direct database queries.']"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "['Hosted on a single personal computer with Docker containers for services (Database, MQTT Broker, Dashboard).', 'Docker Compose file automates deployment and initialization of services.', 'Open-source tools (Python, Docker, TimescaleDB, Grafana, Mosquitto) ensure accessibility.', 'GitHub repository provides installation instructions and documentation.']"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "['Not explicitly detailed in the documents, but could include integration with external systems like container identification or buoyancy models for harbor-scale simulations (mentioned in teaching extensions).']"
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "['Data is owned by the physical system operator (crane lab) as the exemplar is open-source and freely available.', 'No explicit mention of privacy safeguards, but operational data is logged in a time-series database (TimescaleDB) for research and educational use.']"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "['Open-source tools (Python, Docker, TimescaleDB, Grafana) are widely adopted but not tailored for digital twins.', 'CAD models use Autodesk Fusion 360 (proprietary), but Arcadia models (Capella) are for MBSE and not standardized for digital twins.', 'No mention of industry-specific digital twin frameworks (e.g., Eclipse Ditto, BaSyx).']"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "['Remote operation is not explicitly enabled; the system is designed for local use on a personal computer.', 'No mention of cybersecurity protocols (e.g., encryption, authentication) for data transmission.', 'Safety: Continuous validation ensures real-time monitoring of system deviations, but no explicit human-in-the-loop safety protocols for remote operations are described.']"
]