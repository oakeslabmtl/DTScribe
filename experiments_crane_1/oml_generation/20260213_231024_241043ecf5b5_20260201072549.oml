// 1. Acting Components
instance HorizontalCartMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Electric motor driving the horizontal cart along the track, controlled via motor controller."
]

instance VerticalHoistMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Electric motor actuating the vertical hoist, controlled via motor controller."
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist used as a payload release mechanism."
]

// 2. Sensing Components
instance SwingAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring angular displacement of the hoist payload in degrees, interfaced via Arduino.",
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed in m·s⁻¹, interfaced via Arduino.",
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// 3. Data Transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensor
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// 4. Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle values (degrees) from the encoder.",
    DTDFVocab:fromData SwingAngleDataTransmitted,
    DTDFVocab:inputTo MQTTBrokerEnabler,
    DTDFVocab:inputTo TimescaleDBEnabler,
    DTDFVocab:inputTo KinematicEngineEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements (m·s⁻¹) from the anemometer.",
    DTDFVocab:fromData WindSpeedDataTransmitted,
    DTDFVocab:inputTo MQTTBrokerEnabler,
    DTDFVocab:inputTo TimescaleDBEnabler,
    DTDFVocab:inputTo KinematicEngineEnabler
]

// 5. Enablers (Tooling & Infrastructure)
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for bi‑directional streaming between physical controllers and digital services.",
    DTDFVocab:enables OptimalControlService,
    DTDFVocab:enables ContinuousValidationService,
    DTDFVocab:enables DataVisualizationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance for persistent storage of historical sensor and actuator data.",
    DTDFVocab:enables HistoricalLoggingService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboards for interactive visualization of crane state, trajectories, and confidence bounds.",
    DTDFVocab:enables DataVisualizationService
]

instance KinematicEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python‑based kinematic simulation engine encapsulated in a Docker container.",
    DTDFVocab:enables ContinuousValidationService,
    DTDFVocab:enables OptimalControlService
]

// 6. Models / Data Artifacts
instance GantryCraneCADModel : DTDFVocab:Model [
    base:desc "Detailed CAD geometry of the lab‑scale gantry crane used for visualization and collision checking.",
    DTDFVocab:inputTo GrafanaDashboardEnabler
]

instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Mathematical kinematic model describing cart and hoist motion, used for optimal control and validation.",
    DTDFVocab:inputTo KinematicEngineEnabler,
    DTDFVocab:inputTo OptimalControlService
]

// 7. Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes optimal motion commands for the crane based on current twin state and sends them to the controller.",
    DTDFVocab:provides ControlRecommendationInsight,
    DTDFVocab:provides CommandMotorAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Records sensor and actuator data over time into TimescaleDB for later analysis.",
    DTDFVocab:provides HistoricalDataLoggingInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Renders crane state, trajectories and simulation confidence bounds on Grafana dashboards.",
    DTDFVocab:provides CraneStateVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Runs parallel kinematic simulations, compares predictions with real‑time measurements, and alerts on deviations.",
    DTDFVocab:provides DeviationAlertInsight,
    DTDFVocab:provides ConfidenceBoundInsight
]

// 8. Insights
instance ControlRecommendationInsight : DTDFVocab:Insight [
    base:desc "Provides optimal control actions (speed, direction, electromagnet activation) for the crane."
]

instance HistoricalDataLoggingInsight : DTDFVocab:Insight [
    base:desc "Aggregated historical sensor/actuator logs enabling trend analysis."
]

instance CraneStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of current crane configuration and payload trajectory."
]

instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alerts operators when simulated kinematics deviate beyond predefined thresholds."
]

instance ConfidenceBoundInsight : DTDFVocab:Insight [
    base:desc "Shows confidence bounds derived from post‑processing of simulation results."
]

// 9. Actions
instance CommandMotorAction : DTDFVocab:Action [
    base:desc "Sends motor speed and direction commands to the horizontal or vertical motor controllers.",
    DTDFVocab:IsAutomatic true
]

instance ActivateElectromagnetAction : DTDFVocab:Action [
    base:desc "Activates or deactivates the electromagnet to release or pick up payload.",
    DTDFVocab:IsAutomatic true
]

// 10. Environment (Physical Twin)
instance PhysicalCraneEnvironment : DTDFVocab:Environment [
    base:contains HorizontalCartMotorActuator,
                VerticalHoistMotorActuator,
                ElectromagnetActuator,
                SwingAngleEncoderSensor,
                AnemometerSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the Control Application, a Python application that uses the Physical Crane Interface to issue actuation commands to the crane hardware. Operator configuration entered through the Human Machine Interface is passed to the Control Application, which then communicates with the physical crane via the interface. The document provides no details on command formats, validation/authentication, feedback loops, conflict resolution, or execution confirmation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The gantry crane digital twin follows an ad‑hoc architecture that relies on containerisation and virtualization technologies, and does not employ a commercial digital‑twin framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin includes a continuous validation service that checks model behavior against incoming data; the exemplar has been used to demonstrate continuous validation methods and fault detection, but specific validation metrics or uncertainty quantification are not detailed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital‑twin services exchange messages through an MQTT broker that provides publish/subscribe signaling between components such as the Trajectory Generator Service, Simulation Service, and Continuous Validation Service. The broker uses the MQTT protocol; no further information on network topology, bandwidth, latency, reliability/redundancy, or security protocols is given."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software components (Python applications, TimescaleDB, Grafana, MQTT broker) are deployed as a set of local containers as described by the C4 model. The deployment is on‑premise (no cloud or edge platform is mentioned) on a single host that runs the database, broker, and services. The document does not detail scalability mechanisms, specific computational or storage sizing, or availability/reliability provisions."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplar adopts an ad‑hoc architecture and does not employ a commercial digital‑twin framework or any cited industry standards such as AutomationML or IEC specifications. No certification requirements, compliance frameworks, or interoperability standards are mentioned."
]