// --- Sensing Components ---
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder that reports the lateral angle of the hoist"
    DTDFVocab:producedData SwingAngleDataTransmission
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer that measures wind speed near the crane"
    DTDFVocab:producedData AnemometerDataTransmission
]

// --- Data Transmitted Instances ---
instance SwingAngleDataTransmission : DTDFVocab:DataTransmitted [
    base:desc "Telemetry data transmitted from the swing‑angle encoder via the MQTT broker"
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerDataTransmission : DTDFVocab:DataTransmitted [
    base:desc "Telemetry data transmitted from the anemometer via the MQTT broker"
    DTDFVocab:producedFrom Anemometer
]

// --- Stored Telemetry Data ---
instance SwingAngleTelemetryRecord : DTDFVocab:Data [
    base:desc "Timestamped swing‑angle telemetry stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData SwingAngleDataTransmission
]

instance AnemometerTelemetryRecord : DTDFVocab:Data [
    base:desc "Timestamped wind‑speed telemetry stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData AnemometerDataTransmission
]

// --- Acting Components ---
instance CartMotorActingComponent : DTDFVocab:ActingComponent [
    base:desc "Single‑axis cart motor driven by a stepper motor controlled by a TMC4671‑Eval board"
]

instance HoistMotorActingComponent : DTDFVocab:ActingComponent [
    base:desc "Hoist motor driven by a stepper motor controlled by a TMC4671‑Eval board"
]

// --- Models ---
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane created in Autodesk Fusion 360"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:inputTo PythonGantryLibEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model implementing gantry equations, implemented in Python gantrylib"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:inputTo PythonGantryLibEnabler
]

// --- Stored Model Data ---
instance StoredCADData : DTDFVocab:Data [
    base:desc "Serialized CAD geometry stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance StoredKinematicData : DTDFVocab:Data [
    base:desc "Serialized kinematic model stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
]

// --- Enablers ---
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database that stores logged telemetry, CAD and kinematic data"
    DTDFVocab:enables HistoricalDataLoggingService
    DTDFVocab:enables ContinuousValidationService
    DTDFVocab:enables DashboardService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker that mediates bi‑directional data exchange between sensors and services"
    DTDFVocab:enables TrajectoryGeneratorService
    DTDFVocab:enables ContinuousValidationService
    DTDFVocab:enables DashboardService
]

instance PythonGantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib library used to run kinematic simulations of the gantry crane"
    DTDFVocab:enables SimulationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana visualization tool that renders live and historical data for the Digital Twin dashboard"
    DTDFVocab:enables DashboardService
]

// --- Services ---
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service that computes optimal pick‑and‑place paths for the gantry crane and publishes them to the MQTT broker"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that performs real‑time kinematic simulation, updates collision metrics every 100 ms, and compares velocity‑overshoot against adaptive safety thresholds"
    DTDFVocab:provides RealTimeRiskAssessmentInsight
    DTDFVocab:provides ConfidenceBoundsInsight
    DTDFVocab:provides EmitMQTTAlertAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that records sensor streams and actuator states continuously in TimescaleDB for post‑hoc analysis"
    DTDFVocab:provides DataLoggingInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that executes simulator‑based runs of the kinematic model using python gantrylib"
    DTDFVocab:provides SimulationInsight
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Micro‑frontend UI that aggregates metrics, visualization heatmaps, and thresholds, served over HTTPS with JWT authentication"
    DTDFVocab:provides OperatorDecisionSupportInsight
    DTDFVocab:provides AlertUIAction
]

// --- Insights ---
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory plan computed by the TrajectoryGeneratorService"
]

instance RealTimeRiskAssessmentInsight : DTDFVocab:Insight [
    base:desc "Real‑time assessment of collision risk and velocity‑overshoot by the ContinuousValidationService"
]

instance ConfidenceBoundsInsight : DTDFVocab:Insight [
    base:desc "Confidence bounds derived from a Monte Carlo model of actuation uncertainty"
]

instance OperatorDecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Aggregated KPI heatmaps and alerts presented to operators for immediate corrective action"
]

instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Metadata indicating continuous logging of sensor and actuator data in TimescaleDB"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation outputs from the kinematic model run by the SimulationService"
]

// --- Actions ---
instance EmitMQTTAlertAction : DTDFVocab:Action [
    base:desc "MQTT alert emitted by the ContinuousValidationService when thresholds are breached"
    DTDFVocab:IsAutomatic true
]

instance AlertUIAction : DTDFVocab:Action [
    base:desc "UI notification triggered by the DashboardService to prompt operator intervention"
    DTDFVocab:IsAutomatic false
]

instance ReevaluateStagingAction : DTDFVocab:Action [
    base:desc "Action suggesting operators re‑evaluate staging or abort operation in response to alerts"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, which sits in the digital twin, issues movement commands to the Physical Crane Interface. These commands (derived from trajectories generated by the Trajectory Generator Service) are sent to the crane controllers to execute movements. The document does not specify the message format, validation steps, or acknowledgement mechanisms used beyond the fact that the Control Application depends on the interface to communicate with the hardware."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "GreenhouseDT adopts an ad‑hoc microservice architecture, where the digital twin logic and the data collection pipeline are hosted on a set of virtual machines. Within each VM, distinct components—the InfluxDB time‑series database, an ActiveMQ broker, and a data ingestion service—are launched as separate processes. Communication between the greenhouse physical plant and the twin is carried out via ActiveMQ topics that carry sensor readings cast into JSON messages. The ingestion service subscribes to these topics, writes the data to InfluxDB, and triggers the behavioral adaptation logic that times the greenhouse control loops. The entire stack is bootstrapped using a simple shell script that pulls the VM images, installs the required packages, and starts the services in order. Resource constraints are enforced at the VM level (e.g., 2 vCPU, 4 GiB RAM per VM), and each component uses a dedicated port to avoid conflicts. Because the exemplar is intentionally ad‑hoc, there is no central orchestrator beyond the VM bootstrap script, and all coordination is via the publish/subscribe mechanism provided by ActiveMQ."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service continuously compares in‑field measurements of executed trajectories with simulated trajectories, calculating a spatial distance metric between the two. Deviations that exceed a pre‑defined tolerance trigger alerts, enabling self‑adaptation of the digital twin. The service performs on‑line checks at regular intervals, ensuring that the digital twin remains a faithful representation of the physical system during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin is performed via an MQTT broker, which provides a lightweight publish/subscribe channel for signaling among the Trajectory Generator Service, Simulation Service, Continuous Validation Service, Logging Application, and Dashboard. The document does not describe additional network topology, bandwidth or latency requirements, or the physical communication protocols used between the crane hardware and the Physical Crane Interface."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The complete system is deployed on an on‑premises edge PC that interfaces directly with the physical crane. The TimescaleDB, MQTT broker, and Grafana dashboard are docker‑containerized and orchestrated via docker‑compose. The Python services – Control Application, Trajectory Generator Service, Simulation Service, Continuous Validation Service, Logging Application – are distributed as a single Python package ('gantrylib') and run natively on the host. The deployment model supports local scaling through container replication, but explicit computational, storage, or reliability guarantees are not specified."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The system’s integration points are local: sensor data from the greenhouse plant is transmitted over the network to the ActiveMQ broker; the broker forwards JSON messages to the ingestion service on the same VM. InfluxDB remains the sole downstream persistence engine. For external visibility, a lightweight HTTP API exposed by the ingestion service allows dashboards or external analytics tools to query data from InfluxDB via the InfluxDB line protocol. No other enterprise systems such as cloud services or standards are used in this exemplar."
]