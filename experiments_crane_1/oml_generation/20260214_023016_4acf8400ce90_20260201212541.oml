// C3: Physical Sensing Components
instance PositionEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder sensor for tracking the gantry crane's position with high spatial resolution, integrated with the physical crane's mechanical joints."
    DTDFVocab:producedData PositionDataTransmitted
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "IMU-based velocity sensor measuring the crane's linear and angular velocity with ±1% accuracy, mounted on the moving platform."
    DTDFVocab:producedData VelocityDataTransmitted
]

instance LoadCellSensor : DTDFVocab:SensingComponent [
    base:desc "Load cell sensor measuring the crane's payload weight with 0.1% accuracy, connected to the crane's load-bearing mechanism."
    DTDFVocab:producedData LoadDataTransmitted
]

instance CraneControllerInterface : DTDFVocab:SensingComponent [
    base:desc "Embedded controller interface providing telemetry data including operational status, control signals, and error codes from the crane's programmable logic controller."
    DTDFVocab:producedData ControllerDataTransmitted
]

// C4: Data Transmitted
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionEncoderSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySensor
]

instance LoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadCellSensor
]

instance ControllerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneControllerInterface
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "Forward/inverse kinematic model simulating the gantry crane's multi-axis movement dynamics using mathematical transformations derived from CAD geometry."
    DTDFVocab:inputTo KinematicSimulationEngine
]

instance ControlAlgorithmModel : DTDFVocab:Model [
    base:desc "PID-based control algorithm model optimizing crane trajectory planning and velocity control with adaptive gain tuning capabilities."
    DTDFVocab:inputTo ControlOptimizationEngine
]

instance OperationalData : DTDFVocab:Data [
    base:desc "Structured time-series operational data including position, velocity, load, and control signals stored in TimescaleDB with millisecond precision timestamps."
    DTDFVocab:fromData PositionDataTransmitted, VelocityDataTransmitted, LoadDataTransmitted, ControllerDataTransmitted
    DTDFVocab:inputTo DataProcessingPipeline
]

instance HistoricalTrajectoryData : DTDFVocab:Data [
    base:desc "Preprocessed historical trajectory data used for baseline comparison and validation against real-time measurements, stored in SQLite database."
    DTDFVocab:fromData OperationalData
    DTDFVocab:inputTo ValidationService
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Low-latency MQTT broker facilitating asynchronous communication between physical crane interface and logging application with QoS level 2 guarantees."
    DTDFVocab:enables DataLoggingService, ContinuousValidationService
]

instance DataProcessingPipeline : DTDFVocab:Enabler [
    base:desc "Python-based data preprocessing pipeline performing normalization, validation, and timestamp synchronization for incoming sensor data."
    DTDFVocab:enables MonitoringService, OptimizationService
]

instance KinematicSimulationEngine : DTDFVocab:Enabler [
    base:desc "Open-source kinematic modeling software implementing forward/inverse kinematics for real-time trajectory simulation and error estimation."
    DTDFVocab:enables VisualizationService
]

instance ControlOptimizationEngine : DTDFVocab:Enabler [
    base:desc "MATLAB-based optimization engine implementing PID tuning and trajectory planning algorithms for crane control optimization."
    DTDFVocab:enables OptimizationService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "Time-series database optimized for high-frequency operational data storage with sub-second query performance for real-time analytics."
    DTDFVocab:enables MonitoringService, ValidationService
]

instance CADVisualizationEngine : DTDFVocab:Enabler [
    base:desc "Blender-based 3D visualization engine rendering the crane's CAD model with real-time data overlays for kinematic analysis."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time operational monitoring service tracking crane kinematic states, load conditions, and control performance with historical data logging capabilities."
    DTDFVocab:provides CraneOperationalInsight, DataConsistencyInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Control parameter optimization service providing trajectory planning and energy-efficient movement strategies for the gantry crane."
    DTDFVocab:provides OptimalTrajectoryAction, EnergyEfficiencyInsight
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service comparing simulated trajectories against real-time measurements to ensure digital twin accuracy within ±0.5% error margin."
    DTDFVocab:provides SynchronizationStatusInsight, FaultDetectionAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization service rendering the crane's kinematic state with real-time sensor data overlays for operational analysis."
    DTDFVocab:provides KinematicVisualizationInsight, CADIntegrationInsight
]

instance SystemEvolutionService : DTDFVocab:Service [
    base:desc "System evolution tracking service documenting changes to the physical and digital twin systems using DarTwin notation for version control."
    DTDFVocab:provides EvolutionDocumentationInsight
]

// C17: Insights/Actions
instance CraneOperationalInsight : DTDFVocab:Insight [
    base:desc "Real-time operational status of the gantry crane including position, velocity, and load conditions with millisecond precision timestamps."
]

instance DataConsistencyInsight : DTDFVocab:Insight [
    base:desc "Validation metrics comparing real-time sensor data against historical patterns to detect anomalies in data transmission or sensor performance."
]

instance OptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Automated trajectory optimization recommendations for crane movements to minimize travel time while respecting safety constraints."
    DTDFVocab:IsAutomatic true
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Energy consumption analysis of crane operations providing recommendations for power-efficient movement patterns."
]

instance SynchronizationStatusInsight : DTDFVocab:Insight [
    base:desc "Continuous synchronization status between physical crane and digital twin with error margin reporting for validation purposes."
]

instance FaultDetectionAction : DTDFVocab:Action [
    base:desc "Automated fault detection triggering alerts for mechanical or control system anomalies based on deviation thresholds."
    DTDFVocab:IsAutomatic true
]

instance KinematicVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization of the crane's kinematic state with real-time trajectory overlays for operational analysis and debugging."
]

instance CADIntegrationInsight : DTDFVocab:Insight [
    base:desc "Seamless integration of CAD models with real-time operational data for comprehensive system visualization and analysis."
]

instance EvolutionDocumentationInsight : DTDFVocab:Insight [
    base:desc "Documentation of system changes using DarTwin notation to track modifications to both physical and digital twin components over time."
]

// C2: Acting Components
instance CraneController : DTDFVocab:ActingComponent [
    base:desc "Embedded programmable logic controller managing the gantry crane's movement, positioning, and operational logic with PID control capabilities."
]

instance ActuatorSystem : DTDFVocab:ActingComponent [
    base:desc "Stepper motor-based actuation system controlling the crane's linear and rotational movements with ±0.1mm positional accuracy."
]

// C1: Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Research laboratory environment hosting the gantry crane system with controlled temperature and humidity conditions for precise experimentation."
    base:contains PhysicalGantryCrane, DigitalTwinSystem
]

instance PhysicalGantryCrane : DTDFVocab:Environment [
    base:contains CraneController, ActuatorSystem, PositionEncoderSensor, VelocitySensor, LoadCellSensor, CraneControllerInterface
]

instance DigitalTwinSystem : DTDFVocab:Environment [
    base:contains KinematicModel, ControlAlgorithmModel, OperationalData, HistoricalTrajectoryData
]

// C5: Components
instance RaspberryPiInterface : DTDFVocab:Component [
    base:desc "Raspberry Pi-based interface module handling data acquisition from sensors and transmission via MQTT protocol to the digital twin system."
]

instance DataLoggingApplication : DTDFVocab:Component [
    base:desc "Python-based logging application processing sensor data and storing it in TimescaleDB with timestamp synchronization capabilities."
]

// Relationships
instance DataFlow1 : DTDFVocab:DataFlow [
    DTDFVocab:from PositionDataTransmitted
    DTDFVocab:to OperationalData
]

instance DataFlow2 : DTDFVocab:DataFlow [
    DTDFVocab:from VelocityDataTransmitted
    DTDFVocab:to OperationalData
]

instance DataFlow3 : DTDFVocab:DataFlow [
    DTDFVocab:from LoadDataTransmitted
    DTDFVocab:to OperationalData
]

instance DataFlow4 : DTDFVocab:DataFlow [
    DTDFVocab:from ControllerDataTransmitted
    DTDFVocab:to OperationalData
]

instance DataFlow5 : DTDFVocab:DataFlow [
    DTDFVocab:from OperationalData
    DTDFVocab:to DataProcessingPipeline
]

instance DataFlow6 : DTDFVocab:DataFlow [
    DTDFVocab:from HistoricalTrajectoryData
    DTDFVocab:to ValidationService
]

instance DataFlow7 : DTDFVocab:DataFlow [
    DTDFVocab:from KinematicModel
    DTDFVocab:to KinematicSimulationEngine
]

instance DataFlow8 : DTDFVocab:DataFlow [
    DTDFVocab:from ControlAlgorithmModel
    DTDFVocab:to ControlOptimizationEngine
]

instance DataFlow9 : DTDFVocab:DataFlow [
    DTDFVocab:from DataProcessingPipeline
    DTDFVocab:to MonitoringService
]

instance DataFlow10 : DTDFVocab:DataFlow [
    DTDFVocab:from ControlOptimizationEngine
    DTDFVocab:to OptimizationService
]

instance DataFlow11 : DTDFVocab:DataFlow [
