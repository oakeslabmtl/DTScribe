// C2: Acting Components
instance MotorCartActuator : DTDFVocab:ActingComponent [
    base:desc "Electric motor that drives the linear motion of the crane cart along the 2 m rail, addressed via CAN bus."
]

instance MotorCartController : DTDFVocab:ActingComponent [
    base:desc "Dedicated motor controller for the cart linear‑motion motor, receives MQTT commands routed through ActiveMQ."
]

instance MotorHoistActuator : DTDFVocab:ActingComponent [
    base:desc "Electric motor that drives the hoist winch for vertical movement up to 1.5 m, addressed via CAN bus."
]

instance MotorHoistController : DTDFVocab:ActingComponent [
    base:desc "Dedicated motor controller for the hoist winch motor, receives MQTT commands routed through ActiveMQ."
]

instance ElectromagnetEndEffector : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist end providing a binary pick‑and‑place capability for small pucks."
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Rotary encoder on the hoist shaft measuring pendulum swing angle with 0.1° resolution, sampled at 10 Hz."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerWindSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer mounted on the crane frame measuring ambient wind speed with ±0.5 m/s accuracy, sampled at 5 Hz."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerWindSensor
]

// C10: Data (produced from sensors)
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Swing‑angle measurements (degrees) generated by the rotary encoder."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo MosquittoMQTTBroker
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Wind‑speed measurements (m/s) generated by the anemometer."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo MosquittoMQTTBroker
]

// C11: Enablers (tools & runtime infrastructure)
instance MosquittoMQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used by the Arduino microcontroller to publish sensor streams."
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

instance TimescaleDBStorage : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL‑based) time‑series database where logged crane state is persisted."
    DTDFVocab:enables HistoricalLoggingService
]

instance InfluxDBStorage : DTDFVocab:Enabler [
    base:desc "InfluxDB used for short‑term storage of high‑frequency sensor data."
    DTDFVocab:enables DataVisualizationService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboards visualising sensor streams and simulation results."
    DTDFVocab:enables DataVisualizationService
]

instance SimulationService : DTDFVocab:Enabler [
    base:desc "Containerised simulation micro‑service that consumes CAD geometry and kinematic equations to generate predicted trajectories."
    DTDFVocab:enables ContinuousValidationService
]

instance GantryLibAPI : DTDFVocab:Enabler [
    base:desc "Python module `gantrylib` exposing the twin API and mediating between physical controllers and virtual models."
    DTDFVocab:enables OptimalControlService, HistoricalLoggingService, DataVisualizationService
]

instance DockerComposeOrchestrator : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestrates all containerised twin components."
    DTDFVocab:enables OptimalControlService, HistoricalLoggingService, DataVisualizationService, ContinuousValidationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Provides optimal motion commands for cart and hoist based on real‑time sensor feedback."
    DTDFVocab:provides MotionOptimizationInsight
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Continuously logs crane state (position, velocity, load status) into TimescaleDB for later analysis."
    DTDFVocab:provides HistoricalTrendInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Streams live sensor data and simulation trajectories to Grafana dashboards."
    DTDFVocab:provides VisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates live measurements against simulated trajectories from the kinematic model."
    DTDFVocab:provides ValidationResultInsight
]

// C17: Insights
instance MotionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight into energy‑efficient and collision‑free motion plans generated by the optimal control algorithm."
]

instance HistoricalTrendInsight : DTDFVocab:Insight [
    base:desc "Insight derived from historical crane operation trends, enabling performance benchmarking."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight presented via Grafana dashboards, showing real‑time system health and dynamics."
]

instance ValidationResultInsight : DTDFVocab:Insight [
    base:desc "Insight reporting the deviation between measured and simulated crane trajectories, flagging validation failures."
]

// C10: Models/Data (CAD and behavioral)
instance CADModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the entire gantry crane generated in Autodesk Fusion360."
    DTDFVocab:inputTo SimulationService
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model describing cart motion, hoist elevation and pendulum dynamics derived from the CAD model."
    DTDFVocab:inputTo SimulationService
]

instance LoadForceAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model of load handling forces used for validation and control authority estimation."
    DTDFVocab:inputTo SimulationService
]

// C4: Additional Data generated by models (optional)
instance PredictedTrajectoryData : DTDFVocab:Data [
    base:desc "Predicted cart and hoist trajectories produced by the Simulation Service."
    // Note: Input relationship to a Service removed to maintain class disjointness
]

instance ValidationMetricsData : DTDFVocab:Data [
    base:desc "Quantitative validation metrics (e.g., RMS error) computed by Continuous Validation Service."
    DTDFVocab:inputTo GrafanaDashboard
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, a Python application, issues control commands to the Physical Crane Interface, which forwards them to the crane’s controllers to drive the crane. The documents do not detail command formats, validation/authentication, conflict resolution, or acknowledgement mechanisms. The Continuous Validation Service operates post‑execution by comparing logged trajectory measurements with simulated trajectories, rather than validating commands before they are sent."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin requires sub‑centimetre positional fidelity for the cart and millimetre fidelity for the hoist height, which is achieved by calibrating the kinematic model against the encoder measurements. Continuous Validation Service constantly compares executed trajectories with simulated ones, computing Euclidean distance metrics and checking them against a configurable error threshold (e.g., 5 mm). Uncertainty sources such as sensor noise and motor backlash are quantified and mitigated using a Kalman filter applied to the sensor stream. Validation includes automated unit tests for model equations, integration tests for the data pipeline, and runtime alerts when validation metrics exceed the threshold, ensuring ongoing quality assurance of both models and data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin uses an MQTT broker for signaling between containers (e.g., Simulation Service, Continuous Validation Service). The documents do not specify network topology, bandwidth, latency, redundancy, or security protocols beyond the presence of the MQTT broker."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components (Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface, TimescaleDB, Grafana dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service, MQTT broker) are deployed as containers according to the C4 model. The deployment appears to be on‑premise hardware co‑located with the physical crane; no cloud, edge platform, scalability strategy, or availability mechanisms are described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar uses the AutomationML standard for representing the digital twin model, and the system architecture is documented with the C4 Model. No additional industry certifications, compliance frameworks, or interoperability standards are mentioned."
]