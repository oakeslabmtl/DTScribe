// C1: Physical Components
instance GantryCraneStructure : DTDFVocab:PhysicalComponent [
    base:desc "The main structural framework of the lab-scale gantry crane"
]

instance CraneControllerSystem : DTDFVocab:PhysicalComponent [
    base:desc "Controller system for operation of the lab-scale gantry crane"
]

instance CraneMechanicalComponents : DTDFVocab:PhysicalComponent [
    base:desc "Mechanical components including motors, actuators, and linkages for the lab-scale gantry crane"
]

instance PhysicalCraneInterface : DTDFVocab:PhysicalComponent [
    base:desc "Python program collecting real-time operational data from crane hardware controllers"
]

// C2: Acting Components
instance HorizontalMotor : DTDFVocab:ActingComponent [
    base:desc "Motor responsible for horizontal positioning of the crane's puck"
]

instance VerticalMotor : DTDFVocab:ActingComponent [
    base:desc "Motor responsible for vertical positioning of the crane's puck"
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet used for container manipulation in the crane's operation"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the crane arm"
    DTDFVocab:producedData CranePositionData
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring environmental airflow for the crane system"
    DTDFVocab:producedData AirflowData
]

instance ArduinoMeasurementUnit : DTDFVocab:SensingComponent [
    base:desc "Embedded Arduino device collecting additional sensor data from crane components"
    DTDFVocab:producedData EmbeddedSensorData
]

// C4: Physical-to-virtual interaction
instance CranePositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AirflowData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance EmbeddedSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoMeasurementUnit
]

instance RawCraneData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalCraneInterface
    DTDFVocab:producedFrom SwingAngleEncoder
    DTDFVocab:producedFrom ArduinoMeasurementUnit
]

instance TrajectoryExecutionStatus : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalCraneInterface
]

instance OperationalMetrics : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalCraneInterface
    DTDFVocab:producedFrom HorizontalMotor
    DTDFVocab:producedFrom VerticalMotor
    DTDFVocab:producedFrom CraneElectromagnet
]

// C5: Data
instance CranePositionDataStore : DTDFVocab:Data [
    base:desc "Time-series database storing crane position metrics (position, velocity, acceleration)"
    DTDFVocab:fromData CranePositionData
    DTDFVocab:inputTo TimescaleDBInstance
]

instance AirflowDataStore : DTDFVocab:Data [
    base:desc "Time-series database storing environmental airflow measurements"
    DTDFVocab:fromData AirflowData
    DTDFVocab:inputTo TimescaleDBInstance
]

instance EmbeddedSensorDataStore : DTDFVocab:Data [
    base:desc "Time-series database storing embedded sensor measurements from Arduino units"
    DTDFVocab:fromData EmbeddedSensorData
    DTDFVocab:inputTo TimescaleDBInstance
]

instance RawOperationDataStore : DTDFVocab:Data [
    base:desc "Time-series database storing raw operational data from crane interface"
    DTDFVocab:fromData RawCraneData
    DTDFVocab:inputTo TimescaleDBInstance
]

instance TrajectoryStatusStore : DTDFVocab:Data [
    base:desc "Time-series database storing trajectory execution status metrics"
    DTDFVocab:fromData TrajectoryExecutionStatus
    DTDFVocab:inputTo TimescaleDBInstance
]

instance OperationalMetricsStore : DTDFVocab:Data [
    base:desc "Time-series database storing operational metrics (load, energy consumption, etc.)"
    DTDFVocab:fromData OperationalMetrics
    DTDFVocab:inputTo TimescaleDBInstance
]

instance HistoricalTrajectoryData : DTDFVocab:Data [
    base:desc "Pre-recorded virtual machine data used for initial model calibration"
    DTDFVocab:inputTo SimulationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Service for historical data logging of crane operations and continuous validation against real-time data"
    DTDFVocab:provides ContinuousValidationInsight
    DTDFVocab:provides HistoricalDataInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service for optimal control of crane performance and efficiency improvement"
    DTDFVocab:provides OptimalControlAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service continuously validating digital twin against real-time physical data"
    DTDFVocab:provides ValidationThresholdAlert
    DTDFVocab:provides DataSynchronizationInsight
]

instance ControlIntegrationService : DTDFVocab:Service [
    base:desc "Service integrating digital twin with physical crane controller for real-time adjustments"
    DTDFVocab:provides RealTimeAdjustmentAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service providing data visualization tools for real-time and historical operational data"
    DTDFVocab:provides InteractiveDashboardInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service generating optimal trajectories for crane operations"
    DTDFVocab:provides OptimalTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service running kinematic models derived from CAD for simulation purposes"
    DTDFVocab:provides SimulationResultsInsight
]

// C7: Models
instance KinematicModel : DTDFVocab:Model [
    base:desc "3D kinematic model derived from CAD models representing crane structure and motion"
    DTDFVocab:inputTo SimulationService
    DTDFVocab:inputTo TrajectoryGeneratorService
]

instance StructuralModel : DTDFVocab:Model [
    base:desc "Structural model representing physical crane components and their interactions"
    DTDFVocab:inputTo SimulationService
]

instance TrajectorySimulationModel : DTDFVocab:Model [
    base:desc "Model simulating crane trajectory execution and validation against real-time data"
    DTDFVocab:inputTo ContinuousValidationService
]

// C8: Enablers
instance PythonGantryLib : DTDFVocab:Enabler [
    base:desc "Core Python library encapsulating crane kinematics, control algorithms, and service interfaces"
    DTDFVocab:enables MonitoringService
    DTDFVocab:enables ControlIntegrationService
    DTDFVocab:enables TrajectoryGeneratorService
]

instance TimescaleDBInstance : DTDFVocab:Enabler [
    base:desc "TimescaleDB database for high-frequency time-series data storage of crane operations"
    DTDFVocab:enables CranePositionDataStore
    DTDFVocab:enables AirflowDataStore
    DTDFVocab:enables EmbeddedSensorDataStore
    DTDFVocab:enables RawOperationDataStore
    DTDFVocab:enables TrajectoryStatusStore
    DTDFVocab:enables OperationalMetricsStore
]

instance MQTTBrokerInstance : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating inter-service communication between Logging Application and digital twin components"
    DTDFVocab:enables MonitoringService
    DTDFVocab:enables ContinuousValidationService
    DTDFVocab:enables VisualizationService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Interactive visualization platform for presenting real-time and historical operational data"
    DTDFVocab:enables VisualizationService
]

instance DockerContainerization : DTDFVocab:Enabler [
    base:desc "Containerization framework (Docker) for modular deployment of database, MQTT broker, and dashboard components"
    DTDFVocab:enables MonitoringService
    DTDFVocab:enables ContinuousValidationService
    DTDFVocab:enables VisualizationService
]

instance CapellaSystemModel : DTDFVocab:Enabler [
    base:desc "System architecture modeling tool (Capella) for defining crane digital twin structure"
    DTDFVocab:enables KinematicModel
    DTDFVocab:enables SimulationService
]

instance Fusion360CAD : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion360 for 3D geometry modeling of the crane structure"
    DTDFVocab:enables KinematicModel
    DTDFVocab:enables StructuralModel
]

// C9: Insights/Actions
instance ContinuousValidationInsight : DTDFVocab:Insight [
    base:desc "Continuous validation results comparing real-time physical measurements with simulated trajectories"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Historical data logging and analysis of crane operations for performance benchmarking"
]

instance OptimalControlAction : DTDFVocab:Action [
    base:desc "Recommendations for optimal control parameters to improve crane performance and efficiency"
    DTDFVocab:IsAutomatic true
]

instance ValidationThresholdAlert : DTDFVocab:Action [
    base:desc "Alert triggered when operational thresholds are breached during continuous validation"
    DTDFVocab:IsAutomatic true
]

instance DataSynchronizationInsight : DTDFVocab:Insight [
    base:desc "Analysis of synchronization quality between physical and digital models"
]

instance RealTimeAdjustmentAction : DTDFVocab:Action [
    base:desc "Real-time adjustments made to the physical crane controller based on digital twin insights"
    DTDFVocab:IsAutomatic true
]

instance InteractiveDashboardInsight : DTDFVocab:Insight [
    base:desc "Interactive visualizations of real-time and historical operational data presented through Grafana dashboard"
]

instance OptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Generated optimal trajectory paths for crane operations"
    DTDFVocab:IsAutomatic true
]

instance SimulationResultsInsight : DTDFVocab:Insight [
    base:desc "Results from kinematic simulations used for model validation and performance prediction"
]

instance OperatorControlInterface : DTDFVocab:Action [
    base:desc "Python-based Human-Machine Interface allowing operators to configure and control the crane"
    DTDFVocab:IsAutomatic false
]

// C12: Environment
instance ResearchEducationalEnvironment : DTDFVocab:Environment [
    base:contains GantryCraneStructure
    base:contains CraneControllerSystem
    base:contains CraneMechanicalComponents
    base:contains PhysicalCraneInterface
    base:contains SwingAngleEncoder
    base:contains Anemometer
    base:contains ArduinoMeasurementUnit
    base:contains MonitoringService
    base:contains ContinuousValidationService
    base:contains VisualizationService
    base:contains KinematicModel
    base:contains SimulationService
    base:contains PythonGantryLib
    base:contains TimescaleDBInstance
    base:contains MQTTBrokerInstance
    base:contains GrafanaDashboard
    base:contains DockerContainerization
    base:contains CapellaSystemModel
    base:contains Fusion360CAD
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "
The **Virtual to Physical Interaction** occurs through the **Control Application** and **Human-Machine Interface (HMI)**, which send **movement trajectories** and **operator commands** to the **Physical Crane Interface** via the Python program. Command types include high-level trajectory instructions (e.g., container puck movements) and direct operator inputs (e.g., manual overrides). Validation and authentication mechanisms are not explicitly detailed, but the **Continuous Validation Service** ensures feedback by comparing executed trajectories with simulations and notifying operators via the **Dashboard** if discrepancies exceed predefined thresholds.

Feedback systems operate passively: the **Dashboard** visualizes real-time state deviations, while the **Continuous Validation Service** triggers alerts when thresholds are breached. Conflict resolution is implicit—operators intervene manually via the HMI. No explicit confirmation mechanisms (e.g., acknowledgment signals) are documented for command execution.
"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The **GreenhouseDT** exemplar employs **InfluxDB** for time-series data storage and **ActiveMQ** as a message broker, facilitating real-time synchronization between the physical greenhouse and its digital twin. The system leverages pre-recorded data in virtual machine images, implying a hybrid approach where real-time adaptation is supported alongside historical data replay. However, the documents do not specify exact synchronization frequencies (e.g., latency or update intervals), leaving the temporal granularity and latency requirements unspecified. For **Air Quality Management**, the use of **Azure tools** and **AutomationML** suggests a runtime-focused pipeline with runtime visualization, simulation, and prediction capabilities, but no explicit synchronization timings are provided. The **Lab Scale Gantry Crane** does not mention temporal aspects in the provided context, hence **twinning_time_scale is not documented** for this exemplar."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "
  The **GreenhouseDT** system adopts a **hybrid, self-adaptive constellation** leveraging **InfluxDB** (data storage) and **ActiveMQ** (message broker) for real-time synchronization. The **virtual machine images** with pre-recorded data imply a **pre-configured, containerized deployment** without commercial frameworks, relying on **ad-hoc orchestration** for twin adaptation. No explicit orchestration patterns (e.g., microservices, event-driven workflows) are described.

  The **Air Quality Management** exemplar uses an **AutomationML-based digital twin** integrated with **Microsoft Azure**, enabling **model-driven engineering** for twin construction and runtime prediction. The constellation includes:
  - **Edge devices (Raspberry-Pi)** for sensor data collection.
  - **Cloud orchestration** via Azure for simulation/prediction workflows.
  - **Interoperability via AutomationML** (standardized for construction engineering).
  The system lacks explicit mention of **resource management** (e.g., load balancing) or **system-wide coordination** beyond Azure’s built-in services.

  The **lab-scale gantry crane** exemplar’s constellation is inferred to follow a **C4 Model-based architecture**, with **context diagrams** suggesting a **centralized twin** for containerized crane segments. The absence of detailed orchestration implies **ad-hoc integration** (e.g., containerized components communicating via network protocols), with no commercial frameworks or explicit coordination mechanisms.

  **Not in Document** for specific orchestration patterns or resource management beyond implied containerization.
  "
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "
  **Lifecycle Phases of the Lab Scale Gantry Crane Digital Twin:**
  - **Development Phase**:
    - The physical system consists of a lab-scale gantry crane with a controller and kinematic model, while the digital twin is derived from CAD models and simulation frameworks.
    - The digital side includes services for optimal control, historical data logging, and continuous validation, implemented via containerized components.
    - **Representation Types**: CAD models, kinematic models, and containerized microservices (Docker containers) for the digital twin.
    - **Transition Management**: The development pipeline integrates physical system data (e.g., sensor inputs) into the digital twin through containerized middleware (e.g., MQTT broker and database).

  - **Usage Phase (Operations/Evolution)**:
    - **Usage in Publications**: The system is documented for research purposes, emphasizing its role in cyber-physical systems and decision support.
    - **Usage in Teaching**: The digital twin is deployed for educational demonstrations, leveraging its real-time visualization (Grafana dashboard) and operator interfaces (Python HMI).
    - **Lifecycle Governance**: The C4 Model (Context/Container diagrams) is used to document architecture, ensuring traceability between physical and digital components. No explicit governance framework (e.g., CMMI, Agile) is mentioned, but containerization (Docker) enables modular updates and scalability.
  "
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
The **GreenhouseDT** system incorporates:
- **Behavioral adaptation** (self-modifying digital twin to match physical system dynamics).
- **No explicit validation/verification methods** mentioned; inferred as part of **ad-hoc model-driven adaptation**.

The **Air Quality Management** exemplar includes:
- **Model-driven validation** (AutomationML-based pipeline for runtime simulation/prediction).
- **Microsoft Azure tools** for cloud-based validation (e.g., data consistency checks, prediction accuracy).

For the **Lab Scale Gantry Crane**:
- **Continuous Validation Service** (compares executed trajectories with simulations in real-time).
- **Grafana dashboard** for visualization of validation results.
- **No explicit fidelity requirements** (e.g., geometric/high-fidelity models) or uncertainty quantification methods mentioned.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "
The **Digital Twin’s Technical Connection** relies on an **MQTT broker** for inter-service communication, enabling real-time signaling between containers (e.g., Logging Application, Trajectory Generator Service, Continuous Validation Service). The system operates on a **single-node architecture** where all software components (Database, MQTT Broker, Dashboard) are containerized using **Docker** (as implied by the C4 Model’s container abstraction). No explicit network topology or bandwidth/latency requirements are specified, but the system’s deployment is constrained to a **personal computer** environment with minimal redundancy.

Security protocols are not mentioned, and reliability is assumed to be inherent to the single-node setup. The **TimescaleDB database** and **Grafana Dashboard** are the primary endpoints for data exchange, with no mention of encryption (e.g., TLS) or failover mechanisms.
"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "
The **Digital Twin Hosting Deployment** is **on-premise and single-node**, consisting of:
- **Hosting Platform**: A **personal computer** running all software components (as per the context diagram and container diagram).
- **Computational/Storage Requirements**: Not specified; assumed to be minimal (e.g., sufficient for a lab-scale system with Docker containers for **TimescaleDB**, **MQTT Broker**, and **Dashboard**).
- **Scalability Mechanisms**: Not applicable; the system is designed for a single operational instance (no sharding, clustering, or horizontal scaling mentioned).
- **Deployment Models Supported**: **Containerized deployment** using **Docker Compose** (as implied by the container diagram and mention of Docker containers for services like the database and MQTT broker).
- **Availability/Reliability Assurance**: Not detailed; assumed to depend on the host PC’s uptime (no explicit guarantees like 99.9% availability or redundancy).
"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The **GreenhouseDT** system integrates with **InfluxDB** (internal time-series database) and **ActiveMQ** (message broker) for real-time data exchange between the physical greenhouse and its digital twin. The documents do not specify external system dependencies or interoperability standards. The **Air Quality Management** exemplar integrates with **Azure tools** (e.g., cloud services) and **AutomationML** for interoperability with construction engineering systems, enabling runtime visualization, simulation, and prediction. The system’s integration relies on Microsoft Azure’s ecosystem but does not explicitly mention IoT Hub or other protocols. The **Lab Scale Gantry Crane** integrates via **MQTT broker** (as a container for signaling) to coordinate between physical components (e.g., crane, pucks) and digital twin services. The crane’s digital twin is containerized (likely Docker/Kubernetes), ensuring interoperability with other cyber-physical systems in logistics domains, but no explicit enterprise integration standards (e.g., OPC UA, ROS) are mentioned."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "
  **Standardization and Compliance for the Lab Scale Gantry Crane Digital Twin:**
  - **Industry Standards**:
    - **Architecture Standard**: The **C4 Model** (Context/Container diagrams) is used to document the system’s architecture, ensuring clarity and interoperability between physical and digital components.
    - **Open-Source Specifications**: Docker containers and the C4 Model are open-source tools, though no explicit compliance with proprietary standards (e.g., ISO 15926) is mentioned.
  - **Compliance Frameworks**:
    - No explicit compliance certifications (e.g., ISO 27001, IEC 62443) are referenced, but the system’s modular design (Docker) aligns with cybersecurity best practices for isolated component updates.
  - **Interoperability Standards**:
    - **AutomationML**: Not applicable (not mentioned for the Lab Scale Gantry Crane).
    - **MQTT Protocol**: Implied for real-time data exchange between sensors, digital twin services, and dashboard (no explicit MQTT standard compliance stated).
    - **Database Standard**: InfluxDB (mentioned in GreenhouseDT, not the Lab Scale Gantry Crane) is not referenced; the Lab Scale Gantry Crane uses a generic database containerized with Docker.
  "
]