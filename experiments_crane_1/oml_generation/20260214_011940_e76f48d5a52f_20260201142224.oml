// Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the crane counterweight"
    DTDFVocab:producedData CraneTelemetryTransmitted
]
instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting crane operation"
    DTDFVocab:producedData CraneTelemetryTransmitted
]
instance CartMotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the cart axis stepper motor reporting cart position"
    DTDFVocab:producedData CraneTelemetryTransmitted
]
instance HoistMotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the hoist axis stepper motor reporting hoist height"
    DTDFVocab:producedData CraneTelemetryTransmitted
]

// Data Transmission
instance CraneTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder, AnemometerSensor, CartMotorPositionEncoder, HoistMotorPositionEncoder
]

// Telemetry Data
instance CraneTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series telemetry of motor positions, swing angle, wind speed, and timestamps"
    DTDFVocab:inputTo PhysicalCraneInterfaceEnabler
    DTDFVocab:fromData CraneTelemetryTransmitted
]

// Enablers
instance PhysicalCraneInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Python Physical Crane Interface that streams telemetry to the MQTT broker"
    DTDFVocab:enables MQTTPublisherService
]
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for real‑time data distribution"
    DTDFVocab:enables LoggingIngestionService
]
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance that stores historical telemetry"
    DTDFVocab:enables DataStorageService
]
instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana instance that visualizes time‑series data for operator dashboards"
    DTDFVocab:enables DashboardVisualizationService
]
instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Service enabling trajectory generation using kinematic models"
    DTDFVocab:enables TrajectoryGenerationService
]
instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Physics engine enabling trajectory simulation and confidence bounds"
    DTDFVocab:enables SimulationService
]
instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Service that compares simulated trajectories to logged data and triggers alerts"
    DTDFVocab:enables ContinuousValidationService
]
instance DesignVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that loads CAD models into the graphical interface for design review"
    DTDFVocab:enables DesignVisualizationService
]

// Services
instance MQTTPublisherService : DTDFVocab:Service [
    base:desc "Publishes CraneTimeSeriesData to the MQTT broker via the Physical Crane Interface"
    DTDFVocab:provides MQTTPublishingInsight
]
instance LoggingIngestionService : DTDFVocab:Service [
    base:desc "Subscribes to MQTT topics and writes received telemetry into TimescaleDB"
    DTDFVocab:provides LogCreationInsight
]
instance DataStorageService : DTDFVocab:Service [
    base:desc "Handles persistence of time‑series telemetry in TimescaleDB"
    DTDFVocab:provides DataPersistedInsight
]
instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of trajectory adherence, joint positions, and wind speed on Grafana dashboards"
    DTDFVocab:provides RealTimeVisualizationInsight
]
instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal trajectories based on current state and kinematic models"
    DTDFVocab:provides TrajectoryGenerationInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Runs trajectory simulations and calculates confidence bounds for validation"
    DTDFVocab:provides TrajectorySimulationInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares simulated trajectories against logged data and alerts operators on deviations"
    DTDFVocab:provides TrajectoryValidationInsight
]
instance DesignVisualizationService : DTDFVocab:Service [
    base:desc "Provides visual representation of CAD models to inspectors"
    DTDFVocab:provides CADModelInsight
]

// Insights
instance MQTTPublishingInsight : DTDFVocab:Insight [
    base:desc "Indicates successful data publication to the MQTT broker"
]
instance LogCreationInsight : DTDFVocab:Insight [
    base:desc "Records that a telemetry log entry has been created in TimescaleDB"
]
instance DataPersistedInsight : DTDFVocab:Insight [
    base:desc "Confirms that the telemetry data has been persisted in the database"
]
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Dashboard reflects current state of the crane in real time"
]
instance TrajectoryGenerationInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory has been generated using the kinematic model"
]
instance TrajectorySimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation of trajectory and associated confidence bounds completed"
]
instance TrajectoryValidationInsight : DTDFVocab:Insight [
    base:desc "Deviation between simulated and logged trajectory has been evaluated"
]
instance CADModelInsight : DTDFVocab:Insight [
    base:desc "Indicates CAD model has been visualized"
]

// Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart axis, controlled via a TMC4671‑Eval driver"
]
instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist axis, controlled via a TMC4671‑Eval driver"
]
instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet for picking up small containers"
]

// Models
instance CADFusion360Model : DTDFVocab:Model [
    base:desc "CAD model of physical crane components created in Fusion 360"
    DTDFVocab:inputTo DesignVisualizationEnabler
]
instance KinematicMotionModel : DTDFVocab:Model [
    base:desc "Kinematic motion model used for trajectory generation"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]
instance TrajectoryAlgorithm : DTDFVocab:Model [
    base:desc "Algorithm that optimizes crane trajectory based on current state"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]
instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulation model used to validate trajectories and compute confidence bounds"
    DTDFVocab:inputTo SimulationEngineEnabler
]

// Historical Data
instance HistoricalTimeSeriesData : DTDFVocab:Data [
    base:desc "Historical telemetry logs stored in TimescaleDB for analysis and validation"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData CraneTelemetryTransmitted
]

// Environments
instance PhysicalLayerEnvironment : DTDFVocab:Environment [
    base:contains PhysicalCraneComponent, PhysicalCraneInterfaceComponent, ControlApplicationComponent, LoggingApplicationComponent, HumanMachineInterfaceComponent
]
instance VirtualLayerEnvironment : DTDFVocab:Environment [
    base:contains TimescaleDBContainer, GrafanaDashboardContainer, TrajectoryGeneratorContainer, SimulationEngineContainer, ContinuousValidationContainer, MQTTBrokerContainer, DesignVisualizationContainer
]

// Components
instance PhysicalCraneComponent : DTDFVocab:Component [
    base:desc "Laboratory‑scale gantry crane physical structure made of steel"
]
instance PhysicalCraneInterfaceComponent : DTDFVocab:Component [
    base:desc "Component connecting the Arduino controller to virtual services via the Python Physical Crane Interface"
]
instance ControlApplicationComponent : DTDFVocab:Component [
    base:desc "Application that processes sensor data and commands actuators"
]
instance LoggingApplicationComponent : DTDFVocab:Component [
    base:desc "Application that logs telemetry data into TimescaleDB after subscribing to MQTT topics"
]
instance HumanMachineInterfaceComponent : DTDFVocab:Component [
    base:desc "Human‑machine interface for operator control and monitoring"
]
instance TimescaleDBContainer : DTDFVocab:Component [
    base:desc "TimescaleDB container storing all time‑series telemetry"
]
instance GrafanaDashboardContainer : DTDFVocab:Component [
    base:desc "Grafana container visualizing real‑time telemetry"
]
instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Container hosting the trajectory generator service"
]
instance SimulationEngineContainer : DTDFVocab:Component [
    base:desc "Container hosting the simulation service"
]
instance ContinuousValidationContainer : DTDFVocab:Component [
    base:desc "Container hosting the continuous validation service"
]
instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Eclipse Mosquitto container providing MQTT service"
]
instance DesignVisualizationContainer : DTDFVocab:Component [
    base:desc "Container hosting the design visualization service for CAD models"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service publishes optimal trajectory waypoints to the MQTT broker, which the Physical Crane Interface forwards as PWM/step commands to the TMC4671 motor drivers controlling cart and hoist stepper motors in real time."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, high‑frequency operation. Logging and validation occur in real time as the crane moves; data is written to the database on each sensor poll (typically sub‑second). Services execute synchronously with the driver cycle, ensuring real‑time responsiveness for operator feedback and fault detection."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Container architecture: Physical Crane, Physical Crane Interface, Control Application, Logging Application, Human Machine Interface; Digital twin containers: Database (TimescaleDB), Dashboard (Grafana), Trajectory Generator Service, Simulation Service, Continuous Validation Service, MQTT Broker, all orchestrated via docker‑compose."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (CAD models in Fusion360 and kinematic model definition), Manufacturing (assembly of motors, drivers, Arduino shield, PSU, and electromagnet), and Operation (real‑time control, logging, simulation, and validation during use)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous validation compares executed trajectories against simulated ones using Euclidean distance metrics; thresholds trigger operator notifications; simulation provides confidence bounds; kinematic model ensures optimal trajectories with zero residual swing; validation is practical and continuous."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical-to-digital communication via serial/USB from Arduino to Python interface; service-to-service communication over MQTT (Eclipse Mosquitto) on LAN; database access via PostgreSQL/SQL on localhost; dashboard accesses TimescaleDB via Grafana data source."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components run on a developer workstation; Docker containers host DB, MQTT, Grafana; Python services run directly; code packaged as pip module and hosted on GitHub, documentation served via GitHub Pages."
]