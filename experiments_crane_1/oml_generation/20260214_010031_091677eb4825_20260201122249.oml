// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder to measure the hoist’s swinging motion"
    DTDFVocab:producedData SwingAngleEncoderTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer to sense wind speed affecting crane dynamics"
    DTDFVocab:producedData AnemometerTransmitted
]

instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor measuring cart location along the gantry rail"
    DTDFVocab:producedData PositionSensorTransmitted
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Velocity sensor measuring cart speed during trajectory execution"
    DTDFVocab:producedData VelocitySensorTransmitted
]

// C4: Data transmitted from sensors
instance SwingAngleEncoderTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance PositionSensorTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

instance VelocitySensorTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySensor
]

// C10: Models/Data
instance CADModel : DTDFVocab:Model [
    base:desc "CAD geometric model of the gantry crane created in Autodesk Fusion360"
    DTDFVocab:inputTo CADToolEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model describing motion constraints of the crane"
    DTDFVocab:inputTo GantryLibEnabler
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of the crane and controller dynamics"
    DTDFVocab:inputTo GantryLibEnabler
]

instance ContinuousValidationModel : DTDFVocab:Model [
    base:desc "Model used for continuous validation comparing actual and simulated trajectories"
    DTDFVocab:inputTo GantryLibEnabler
]

// C10: Data instances
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series data of swing‑angle readings from the encoder"
    DTDFVocab:fromData SwingAngleEncoderTransmitted
    DTDFVocab:inputTo TimeSeriesDBEnabler
]

instance AnemometerData : DTDFVocab:Data [
    base:desc "Time‑series data of wind speed measurements"
    DTDFVocab:fromData AnemometerTransmitted
    DTDFVocab:inputTo TimeSeriesDBEnabler
]

instance PositionData : DTDFVocab:Data [
    base:desc "Time‑series data of cart position along the gantry rail"
    DTDFVocab:fromData PositionSensorTransmitted
    DTDFVocab:inputTo TimeSeriesDBEnabler
]

instance VelocityData : DTDFVocab:Data [
    base:desc "Time‑series data of cart velocity during motion"
    DTDFVocab:fromData VelocitySensorTransmitted
    DTDFVocab:inputTo TimeSeriesDBEnabler
]

instance TrajectoryCommandLogData : DTDFVocab:Data [
    base:desc "Log of planned and executed trajectory commands"
    DTDFVocab:inputTo TimeSeriesDBEnabler
]

instance SimulationPredictionData : DTDFVocab:Data [
    base:desc "Predicted trajectory and state from the simulation model"
    DTDFVocab:inputTo TimeSeriesDBEnabler
]

instance DistanceMetricData : DTDFVocab:Data [
    base:desc "Distance metric comparing executed trajectory with simulation"
    DTDFVocab:inputTo TimeSeriesDBEnabler
]

instance FaultDetectionScoreData : DTDFVocab:Data [
    base:desc "Scores produced by time‑series classification fault detection"
    DTDFVocab:inputTo TimeSeriesDBEnabler
]

// C2: Acting components
instance CartMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor driven by the TMC4671‑Eval controller"
]

instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval controller managing cart motor drive"
]

instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor driven by the TMC4671‑Eval controller"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval controller managing hoist motor drive"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet used to pick up container (puck) between positions"
]

// C11: Enablers
instance GantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module providing core control logic and kinematic calculations"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, FaultDetectionService, HistoricalLoggingService, DataManagementService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service messaging"
    DTDFVocab:enables ContinuousValidationService, FaultDetectionService
]

instance TimeSeriesDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database for storing time‑series sensor and simulation data"
    DTDFVocab:enables HistoricalLoggingService, DataManagementService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana for real‑time visualization of crane state and analytics"
    DTDFVocab:enables VisualizationService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker Compose orchestrator managing separate service containers"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, FaultDetectionService, HistoricalLoggingService, VisualizationService, DataManagementService
]

instance CADToolEnabler : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion360 engine for CAD model generation"
]

instance ArcadiaCapellaEnabler : DTDFVocab:Enabler [
    base:desc "Arcadia Capella model‑based systems engineering tool"
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Optimal trajectory generation using the kinematic model of the crane"
    DTDFVocab:provides TrajectoryAdjustmentRecommendationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of crane dynamics and controller response"
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Comparison of executed trajectories with simulation outputs using distance metrics"
    DTDFVocab:provides ValidationAlertInsight, AutomatedAlertAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Time‑series classification for fault detection in crane operation"
    DTDFVocab:provides FaultIdentificationInsight, AutomatedAlertAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Logging of historical sensor and command data for trend analysis"
    DTDFVocab:provides TrendAnalysisInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of crane state on Grafana dashboard"
    DTDFVocab:provides VisualizationInsight
]

instance DataManagementService : DTDFVocab:Service [
    base:desc "Management of data ingestion into TimescaleDB and schema maintenance"
    DTDFVocab:provides DataManagementInsight
]

// C17: Insights and Actions
instance TrajectoryAdjustmentRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation to adjust trajectory based on continuous validation results"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Results of crane dynamics simulation used for performance evaluation"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Automated alert when validation distance metric exceeds defined threshold"
]

instance TrendAnalysisInsight : DTDFVocab:Insight [
    base:desc "Historical trend analysis of crane performance identifying patterns over time"
]

instance FaultIdentificationInsight : DTDFVocab:Insight [
    base:desc "Identification of faults through time‑series classification of sensor data"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of crane operation and analytics on Grafana"
]

instance DataManagementInsight : DTDFVocab:Insight [
    base:desc "Insight into data quality and schema compliance within TimescaleDB"
]

instance AutomatedAlertAction : DTDFVocab:Action [
    base:desc "Automated alert action triggered when a validation threshold is violated, notifying operators"
    DTDFVocab:IsAutomatic true
]

// C10: Environment
instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains CartMotor, CartMotorController, HoistMotor, HoistMotorController, Electromagnet, SwingAngleEncoder, Anemometer, PositionSensor, VelocitySensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin generates optimal trajectories and sends motion commands through the MQTT broker to the Control Application, which drives the cart and hoist motors via the motor controllers; notification messages are also published to the operator dashboard."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in real time: sensor data is logged continuously at the sampling rate of the controllers, trajectory generation and validation run synchronously with the crane operation, and alerts are raised immediately when validation thresholds are breached."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is an orchestrated ensemble of the physical crane (hardware and controller), the Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface, and the twin side comprising the TimescaleDB database, Grafana dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service, and MQTT broker—all deployed via Docker Compose and communicating over TCP/IP and MQTT."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin encompasses the as‑designed phase (CAD and kinematic models), the as‑manufactured phase (physical crane built from BOM), and the as‑operated phase (runtime data, validation, and maintenance monitoring during operation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous validation compares measured trajectory data with simulation predictions using distance metrics; thresholds trigger alerts; simulation uses kinematic model validated against real motion to achieve swing‑free trajectories; time‑series classification is applied to detect faults; all models are open‑source and periodically verified through research publications."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the physical system and the digital twin uses a Python interface that streams sensor data and commands over TCP/IP sockets to the MQTT broker (Eclipse Mosquitto) and to a TimescaleDB database; all containers communicate over Docker networking; the controller is connected via serial or USB to the host PC."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin runs locally on a personal computer, with all services containerized in Docker; deployment is managed by a docker‑compose file that automatically bootstraps the TimescaleDB, MQTT broker, and Grafana dashboard; the repository is hosted on GitHub and documentation is served via MkDocs on GitHub Pages."
]