// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart axis, controlled via Trinamic TMC4671‑Eval driver"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor for raising/lowering the hoist, driven by Trinamic TMC4671‑Eval driver"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist end used to pick up container mock‑ups, switched by Arduino outputs"
]

instance ArduinoController : DTDFVocab:ActingComponent [
    base:desc "Arduino board that reads swing‑angle encoder and anemometer and commands motors and electromagnet"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the hoist",
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed",
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

// C5: Data (from sensors)
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing angle value in degrees",
    DTDFVocab:fromData SwingAngleDataTransmitted
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind speed value in metres per second",
    DTDFVocab:fromData WindSpeedDataTransmitted
]

// C10: Models/Data
instance CraneCADModel : DTDFVocab:Model [
    base:desc "Fusion360 CAD model of the lab‑scale gantry crane frame"
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator for motion planning"
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of crane mechanics and controller loops"
]

// C11: Enablers (tooling & infrastructure)
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "PostgreSQL‑based TimescaleDB container storing time‑series sensor and actuator data",
    DTDFVocab:enables DataLoggingService,
    DTDFVocab:hasInput SwingAngleData, WindSpeedData
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for real‑time data distribution between Arduino and DT services",
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, HMIFrontEndService,
    DTDFVocab:hasInput SwingAngleData, WindSpeedData
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard container visualizing logged data and service health",
    DTDFVocab:enables DataVisualizationService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestrator launching all micro‑service containers",
    DTDFVocab:enables DataLoggingService, DataVisualizationService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService, HMIFrontEndService,
    DTDFVocab:hasInput CraneCADModel
]

instance PythonGantrylibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module providing kinematic calculations and physical crane interface",
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService,
    DTDFVocab:hasInput KinematicModel
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuously logs sensor readings and actuator states to TimescaleDB",
    DTDFVocab:provides SensorLoggingInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboards for real‑time visualization of crane state and KPI charts",
    DTDFVocab:provides VisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal motion trajectories using the kinematic model",
    DTDFVocab:provides OptimalTrajectoryInsight, TrajectoryCommandAction,
    DTDFVocab:hasInput KinematicModel
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs dynamic simulation of crane and controllers for what‑if analysis",
    DTDFVocab:provides BaselinePerformanceInsight,
    DTDFVocab:hasInput DynamicSimulationModel
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories against simulated ones and raises alerts on deviation thresholds",
    DTDFVocab:provides TrajectoryFidelityInsight, DeviationAlertAction
]

instance HMIFrontEndService : DTDFVocab:Service [
    base:desc "Web‑based Human‑Machine Interface for operator control and configuration",
    DTDFVocab:provides OperatorControlAction
]

// C17: Insights
instance SensorLoggingInsight : DTDFVocab:Insight [
    base:desc "Assures that raw sensor streams are persisted for historical analysis"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Shows current crane state, sensor trends, and service health in Grafana dashboards"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Suggests energetically optimal cart and hoist motion profiles for a given payload"
]

instance BaselinePerformanceInsight : DTDFVocab:Insight [
    base:desc "Delivers expected performance metrics (e.g., swing reduction) from simulation runs"
]

instance TrajectoryFidelityInsight : DTDFVocab:Insight [
    base:desc "Quantifies fidelity between executed and simulated trajectories using distance metrics"
]

// C17: Actions
instance DeviationAlertAction : DTDFVocab:Action [
    base:desc "Raises an operator alert when trajectory deviation exceeds configured threshold",
    DTDFVocab:IsAutomatic true
]

instance TrajectoryCommandAction : DTDFVocab:Action [
    base:desc "Sends generated trajectory commands to the Arduino controller",
    DTDFVocab:IsAutomatic true
]

instance OperatorControlAction : DTDFVocab:Action [
    base:desc "Allows operator to start/stop crane motion, adjust parameters, and acknowledge alerts",
    DTDFVocab:IsAutomatic false
]

// C20: Environment & Physical Components
instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains CartStepperMotor, HoistStepperMotor, ElectromagnetActuator, SwingAngleEncoder, WindSpeedAnemometer, ArduinoController, PowerSupplyUnit
]

instance PowerSupplyUnit : DTDFVocab:Component [
    base:desc "Regulated power‑supply delivering voltage to motor drivers and the Arduino"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital‑twin services (e.g., Trajectory Generator, Simulation, Control Application) send motion commands and electromagnet activation signals via the Python Physical Crane Interface and MQTT broker to the Arduino and motor drivers, thereby moving the cart, hoisting load, or activating the electromagnet."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture consists of the physical crane linked via a Python Physical Crane Interface to a Control Application, Logging Application, and HMI. Supporting services (Trajectory Generator, Simulation, Continuous Validation) communicate through an MQTT broker, store data in TimescaleDB, and are visualised in Grafana. All non‑physical components are orchestrated with Docker‑Compose on a single PC."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the designed stage (CAD models of the crane in Autodesk Fusion360), the manufactured stage (the physical hardware assembled as described), and the operated stage (real‑time operation with logging, simulation, and validation during use in research and teaching)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service continuously compares measured trajectories with simulated ones, calculates distance metrics, and checks them against a predefined acceptable threshold; breaches trigger operator alerts on the Grafana dashboard. The Trajectory Generator uses a kinematic model to produce swing‑free optimal trajectories, ensuring high fidelity between planned and executed motion."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT components is realized via a local TCP/IP network: sensor data and commands are exchanged through MQTT (Eclipse Mosquitto) and through the Python Physical Crane Interface, while persistent data is written to TimescaleDB via standard PostgreSQL SQL connections."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital‑twin software runs on a personal computer. The TimescaleDB, MQTT broker, and Grafana dashboard are Docker containers; the remaining Python applications are installed via pip from the gantrylib package. Deployment and lifecycle management are handled with a Docker‑Compose file that starts and stops the entire stack with a single command."
]