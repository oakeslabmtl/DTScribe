// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing"
    DTDFVocab:producedData SwingAngleDataTx
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTx
]

// C4: Physical-to-virtual interaction (data transmission)
instance SwingAngleDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Data produced from sensors
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series swing angle measurements from the encoder"
    DTDFVocab:fromData SwingAngleDataTx
    DTDFVocab:inputTo PythonGanryLib, LoggingService
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series wind speed measurements from the anemometer"
    DTDFVocab:fromData WindSpeedDataTx
    DTDFVocab:inputTo PythonGanryLib, LoggingService
]

// C11: Enablers
instance PythonGanryLib : DTDFVocab:Enabler [
    base:desc "Python 'gantrylib' module (installed via pip) that parses sensor streams and formats MQTT messages"
    DTDFVocab:enables LoggingService, MQTTBrokerService
]

instance DockerCompose : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestrates container deployment for all digital‑twin services"
    DTDFVocab:enables TimescaleDBService, GrafanaDashboardService, TrajectoryGeneratorService,
                 SimulationService, ContinuousValidationService, MQTTBrokerService,
                 LoggingService, FaultDetectionService
]

instance GitHubRepository : DTDFVocab:Enabler [
    base:desc "Open‑source GitHub repository version‑controlling all artefacts"
    DTDFVocab:enables DockerCompose
]

instance KiCadShieldDesign : DTDFVocab:Enabler [
    base:desc "KiCad design for custom Arduino shield"
    DTDFVocab:enables ArduinoBoard
]

// C6: Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Continuous data logging service that writes sensor and trajectory records into TimescaleDB"
    DTDFVocab:provides OperationalLogInsight
]

instance TimescaleDBService : DTDFVocab:Service [
    base:desc "TimescaleDB time‑series database storing operational data"
    DTDFVocab:provides DataStorageInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualizing performance metrics for operator decision making"
    DTDFVocab:provides DashboardInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal motion plans that minimize swing for the gantry crane"
    DTDFVocab:provides OptimalTrajectoryInsight, SwingReductionAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation of crane kinematics and controller dynamics"
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares measured vs. simulated trajectories, raises operator alerts when thresholds are exceeded"
    DTDFVocab:provides OperatorAlertInsight, ValidationAction
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Eclipse Mosquitto MQTT broker mediating messages between containers"
    DTDFVocab:provides MessagingInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults by analysing sensor deviations and simulation mismatches"
    DTDFVocab:provides FaultDetectionInsight
]

// C17: Insights
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Generated trajectory reduces residual swing compared to baseline"
]

instance OperatorAlertInsight : DTDFVocab:Insight [
    base:desc "Alert to operator when measured swing exceeds validation thresholds"
]

instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Dashboard visualizations of key performance indicators for operational decisions"
]

instance DataStorageInsight : DTDFVocab:Insight [
    base:desc "Confirmation that operational data have been persisted in TimescaleDB"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Result of physics‑based simulation providing predicted crane behavior"
]

instance MessagingInsight : DTDFVocab:Insight [
    base:desc "Message flow status within MQTT broker"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detected fault condition based on sensor‑simulation discrepancy"
]

instance OperationalLogInsight : DTDFVocab:Insight [
    base:desc "Log entry confirming successful write of sensor/trajectory data"
]

// C17: Actions
instance SwingReductionAction : DTDFVocab:Action [
    base:desc "Command sent to stepper motors to execute swing‑minimising trajectory"
    DTDFVocab:IsAutomatic true
]

instance ValidationAction : DTDFVocab:Action [
    base:desc "Triggers re‑planning of trajectory after validation failure"
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving horizontal cart motion, controlled by Trinamic TMC4671‑Eval"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving vertical hoist motion, controlled by Trinamic TMC4671‑Eval"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at end of hoist used to pick up pucks"
]

// C10: Physical components
instance ArduinoBoard : DTDFVocab:Component [
    base:desc "Arduino electronics reading encoder and anemometer and forwarding values"
]

instance CraneFrame : DTDFVocab:Component [
    base:desc "Structural frame of the lab‑scale gantry crane"
]

// C9: Environment
instance PhysicalCraneEnvironment : DTDFVocab:Environment [
    base:contains CraneFrame, CartStepperMotor, HoistStepperMotor,
                 ElectromagnetActuator, SwingAngleEncoder, Anemometer, ArduinoBoard
]

// Additional software components
instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Python program that reads controller and sensor data and publishes MQTT messages"
]

instance ControlApplication : DTDFVocab:Component [
    base:desc "Application issuing motion commands to stepper motor controllers"
]

instance HumanMachineInterface : DTDFVocab:Component [
    base:desc "Operator GUI for monitoring dashboard and acknowledging alerts"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends motion commands (e.g., speed set‑points, electromagnet activation) to the Physical Crane Interface, which translates them to the motor controllers and Arduino; trajectory commands are produced by the Trajectory Generator Service and delivered through MQTT to the control stack."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A hybrid architecture where the physical crane is attached to a PC; software components run as Docker containers (DB, MQTT, Grafana) and native Python processes (Physical Interface, Control App, Logging App, HMI). Services communicate via MQTT and the shared TimescaleDB, forming a coherent digital twin ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the designed stage (CAD and kinematic models) and the operated stage (real‑time sensor acquisition, control and validation during crane operation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares executed trajectories recorded from the physical crane with simulated trajectories, computes distance metrics, checks against a predefined threshold and raises alerts on the Grafana dashboard when the threshold is exceeded."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication uses MQTT (Eclipse Mosquitto) for signaling between services and the Physical Crane Interface, and a Python‑based TCP/serial link to the Arduino controllers; persistent data exchange uses PostgreSQL/TimescaleDB over standard SQL connections."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All Dockerized components (TimescaleDB, MQTT broker, Grafana) are hosted on the same personal computer using Docker Compose; the Python modules run directly on the host OS and are installed via pip; the entire system can be started with a single 'docker compose up' command."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture is modeled using the C4 model (context, container diagrams); containerization follows Docker standards; data storage follows PostgreSQL/TimescaleDB standards."
]