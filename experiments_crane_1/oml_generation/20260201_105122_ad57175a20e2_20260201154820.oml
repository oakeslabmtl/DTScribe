// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor responsible for cart movement on the gantry crane, controlled via TMC4671-Eval motor controller. Executes trajectories generated by the Trajectory Generator Service."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor responsible for hoisting movement of the crane, controlled via TMC4671-Eval motor controller. Executes trajectories generated by the Trajectory Generator Service."
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet used for gripping and releasing pucks (representing containers) during crane operations. Controlled via Arduino-based system."
]

instance ArduinoControlSystem : DTDFVocab:ActingComponent [
    base:desc "Arduino-based control system interfacing with stepper motors, electromagnet, and sensors. Acts as the primary hardware controller for the physical crane system."
]

// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures swinging motion of the hoist during crane operations to enable trajectory optimization and validation."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Measures wind speed affecting crane operations, used for environmental compensation in trajectory generation."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorPositionFeedback : DTDFVocab:SensingComponent [
    base:desc "Position and status feedback from TMC4671-Eval motor controllers for both cart and hoist stepper motors."
    DTDFVocab:producedData MotorPositionDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionFeedback
]

instance TrajectoryExecutionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalCraneInterfaceService
]

// C10: Models/Data
instance CraneCADModel : DTDFVocab:Model [
    base:desc "Autodesk Fusion 360 CAD model representing the physical structure of the gantry crane, used for visualization and simulation."
    DTDFVocab:inputTo TimescaleDBEnabler, GrafanaDashboardEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the crane used by the Trajectory Generator Service to compute swing-free trajectories for cart and hoist movements."
    DTDFVocab:inputTo TrajectoryGeneratorService
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model used by the Simulation Service for offline trajectory testing and validation."
    DTDFVocab:inputTo SimulationService
]

instance ArcadiaMBSEModel : DTDFVocab:Model [
    base:desc "Capella-based Arcadia models for Model-Based Systems Engineering (MBSE) documentation of the crane system."
]

instance TimeSeriesSensorData : DTDFVocab:Data [
    base:desc "Historical time-series data including swing angle, wind speed, motor positions, and trajectory execution metrics stored in TimescaleDB."
    DTDFVocab:fromData SwingAngleDataTransmitted, WindSpeedDataTransmitted, MotorPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance TrajectoryExecutionData : DTDFVocab:Data [
    base:desc "Real-time data comparing executed trajectories with simulated trajectories for continuous validation purposes."
    DTDFVocab:fromData TrajectoryExecutionDataTransmitted
    DTDFVocab:inputTo ContinuousValidationService
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "PostgreSQL-based TimescaleDB instance optimized for high-frequency time-series data storage and querying."
    DTDFVocab:enables LoggingService, ContinuousValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker facilitating lightweight asynchronous messaging between DT services with low latency."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, DashboardService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana visualization platform displaying real-time and historical crane data with support for multiple data sources."
    DTDFVocab:enables DashboardService
]

instance DockerContainerization : DTDFVocab:Enabler [
    base:desc "Docker and docker-compose setup for containerizing TimescaleDB, MQTT Broker, and Dashboard services."
    DTDFVocab:enables TimescaleDBEnabler, MQTTBrokerEnabler, GrafanaDashboardEnabler
]

instance PythonControlFramework : DTDFVocab:Enabler [
    base:desc "Python-based framework for Control Application, Physical Crane Interface, Logging Application, and gantrylib module."
    DTDFVocab:enables ControlApplicationService, PhysicalCraneInterfaceService, LoggingService
]

instance ArduinoInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Arduino-based hardware interface for sensor and actuator communication with the physical crane system."
    DTDFVocab:enables PhysicalCraneInterfaceService
]

instance KiCadHardwareDesign : DTDFVocab:Enabler [
    base:desc "KiCad toolchain used for designing custom hardware shields and PCB layouts for the crane system."
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimized swing-free trajectories for cart and hoist movements using the crane's kinematic model."
    DTDFVocab:provides TrajectoryOptimizationInsight
    DTDFVocab:inputTo CraneKinematicModel
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Models crane behavior for offline trajectory testing and validation using the simulation model."
    DTDFVocab:provides SimulationValidationInsight
    DTDFVocab:inputTo CraneSimulationModel
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories with simulated trajectories, calculating distance metrics and alerting operators of deviations."
    DTDFVocab:provides RealTimeValidationInsight, FaultLocalizationInsight
    DTDFVocab:inputTo TrajectoryExecutionData
]

instance LoggingService : DTDFVocab:Service [
    base:desc "Records crane state data including motor positions, swing angles, wind speed, and trajectory execution metrics into TimescaleDB."
    DTDFVocab:provides HistoricalDataLoggingInsight
    DTDFVocab:inputTo TimeSeriesSensorData
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Visualizes real-time and historical crane data including trajectory traces with simulated confidence bounds."
    DTDFVocab:provides DataVisualizationInsight
    DTDFVocab:inputTo GrafanaDashboardEnabler
]

instance ControlApplicationService : DTDFVocab:Service [
    base:desc "Sends commands to the Physical Crane Interface to execute movements via Arduino and motor controllers."
    DTDFVocab:provides PhysicalSystemControlAction
    DTDFVocab:inputTo PythonControlFramework
]

instance PhysicalCraneInterfaceService : DTDFVocab:Service [
    base:desc "Python program acting as bridge between Arduino and DT services, collecting sensor data and executing commands."
    DTDFVocab:provides SensorDataCollectionAction
    DTDFVocab:inputTo ArduinoInterfaceEnabler, PythonControlFramework
]

// C17: Insights/Actions
instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Provides swing-free movement trajectories to improve crane efficiency and reduce residual swinging motion."
]

instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Offline validation of trajectories against simulation models to identify potential issues before physical execution."
]

instance RealTimeValidationInsight : DTDFVocab:Insight [
    base:desc "Alerts operators when trajectory deviations exceed predefined thresholds during crane operation."
]

instance FaultLocalizationInsight : DTDFVocab:Insight [
    base:desc "Identifies specific faults in the physical system using time-series classification techniques on logged data."
]

instance HistoricalDataLoggingInsight : DTDFVocab:Insight [
    base:desc "Maintains comprehensive historical records of crane operations for trend analysis and performance monitoring."
]

instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides real-time and historical visualization of crane operations including trajectory traces and system metrics."
]

instance PhysicalSystemControlAction : DTDFVocab:Action [
    base:desc "Executes movement commands on the physical crane system via Arduino and motor controllers."
    DTDFVocab:IsAutomatic true
]

instance SensorDataCollectionAction : DTDFVocab:Action [
    base:desc "Collects real-time sensor data from the physical crane system for DT processing."
    DTDFVocab:IsAutomatic true
]

// C1: Physical System Components
instance CraneFrame : DTDFVocab:Component [
    base:desc "Structural hardware component of the gantry crane providing mechanical support for all moving parts."
]

instance PowerSupplyUnit : DTDFVocab:Component [
    base:desc "Provides electrical power to all crane components including motors, electromagnet, and Arduino control system."
]

instance TMC4671EvalController : DTDFVocab:Component [
    base:desc "Motor controller unit for both cart and hoist stepper motors, providing position feedback and control signals."
]

instance PhysicalCraneEnvironment : DTDFVocab:Environment [
    base:desc "Lab-scale environment containing all physical components of the gantry crane system."
    base:contains CraneFrame, CartStepperMotor, HoistStepperMotor, CraneElectromagnet,
               SwingAngleEncoder, WindSpeedAnemometer, PowerSupplyUnit, TMC4671EvalController,
               ArduinoControlSystem
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT influences the physical system through the following interactions: **1) The Control Application** receives optimized trajectories from the **Trajectory Generator Service** and sends commands to the **Physical Crane Interface** to execute movements via the Arduino and motor controllers. **2) The Simulation Service** provides pre-computed trajectories for validation, which are compared against real-time data to ensure accuracy. **3) The Continuous Validation Service** triggers alerts via the **Dashboard** if discrepancies exceed thresholds, prompting manual intervention. The **Human Machine Interface (HMI)** allows operators to configure and control the crane directly, with commands routed through the **Control Application**."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates on **real-time and near-real-time scales** for synchronization and validation. **1) Data Logging**: Sensor data is logged continuously at high frequency (not specified but implied to be millisecond-level for motor control). **2) Trajectory Validation**: Executed trajectories are compared against simulations in near-real-time to detect deviations. **3) Operator Interaction**: The **Human Machine Interface** and **Dashboard** provide immediate feedback (e.g., alerts for threshold breaches). The **MQTT Broker** ensures low-latency messaging between services, with the **Trajectory Generator Service** providing pre-computed trajectories for immediate execution."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation consists of **11 containers** (5 physical + 6 digital) organized into a **C4 Model architecture**. The **Physical System** includes: **Physical Crane** (hardware), **Physical Crane Interface** (Python), **Control Application** (Python), **Logging Application** (Python), and **Human Machine Interface** (Python front-end). The **Digital Twin** includes: **TimescaleDB** (database), **Grafana Dashboard**, **Trajectory Generator Service**, **Simulation Service**, **Continuous Validation Service**, and **MQTT Broker**. The **Database** and **MQTT Broker** act as central hubs, while services like **Trajectory Generation** and **Simulation** operate independently. The **Deployment Diagram** shows all components running on a single personal computer, with Docker managing the **Database**, **MQTT Broker**, and **Dashboard**."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the **as-operated** lifecycle phase of the physical system, focusing on real-time monitoring, control, and validation during operation. It does not explicitly model the **as-designed** (ideal) or **as-manufactured** phases, though CAD models (Autodesk Fusion 360) are provided for structural representation. The DT’s primary role is to **continuously validate** the physical system’s behavior against simulated models, enabling fault detection and adaptive control. The **DarTwin notation** was used to document the DT’s evolution, including planned extensions like harbor system integration and ship buoyancy modeling."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT employs **continuous validation** to ensure fidelity, where the **Continuous Validation Service** compares executed trajectories with simulated ones using distance metrics. **1) Validation Metrics**: Distance-based thresholds are set to detect deviations between real and simulated trajectories. **2) Uncertainty Handling**: The **Simulation Service** provides confidence bounds for trajectories, visualized in Grafana. **3) Verification**: The **Trajectory Generator Service** uses a kinematic model validated against real-world data. **4) Fault Detection**: Time-series classification techniques (e.g., in [6]) are used to pinpoint system faults. The **Logging Application** ensures high-fidelity data collection for retrospective analysis, while the **Dashboard** provides immediate feedback for operator intervention."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT connects to the physical system via **1) Serial Communication** (Arduino to Python interface) for sensor and actuator control, **2) MQTT Protocol** for lightweight, asynchronous messaging between services (e.g., **Logging Application** → **Database**, **Trajectory Generator** → **Control Application**), and **3) Direct Python API Calls** for real-time control commands. The **Physical Crane Interface** acts as a middleware, translating high-level commands from the **Control Application** into low-level signals for the Arduino. The **MQTT Broker** ensures decoupled communication, while the **Database** and **Dashboard** rely on standard SQL queries and HTTP APIs for data access."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted on a **single personal computer**, with the following deployment strategy: **1) Physical System**: Arduino and motor controllers are connected directly to the computer. **2) Digital Twin Services**: The **Control Application**, **Logging Application**, and **Human Machine Interface** run as Python modules installed via **pip**. **3) Containerized Services**: The **TimescaleDB Database**, **MQTT Broker (Eclipse Mosquitto)**, and **Grafana Dashboard** are deployed using **Docker**, managed via a **docker-compose** file for automated setup. The **Trajectory Generator**, **Simulation Service**, and **Continuous Validation Service** run as standalone Python services on the host machine."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT does not explicitly describe horizontal integration with external systems beyond its core components. However, the **MQTT Broker** and **TimescaleDB** are designed to support extensibility. Future work mentions integrating the crane into a **larger harbor system** (e.g., container identification and ship buoyancy modeling), which would require interoperability with external sensors, logistics software, or other DTs. The **open-source nature** of the exemplar suggests potential for integration with third-party tools via standard protocols (e.g., MQTT, SQL)."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "The exemplar does not explicitly address data ownership or privacy. However, the **MIT License** under which the exemplar is published implies open access to all code and data. The **TimescaleDB** stores operational data, which could include sensitive information if deployed in industrial settings. No encryption or access control mechanisms are mentioned for the database or MQTT broker. The **open-source and educational focus** suggests that data ownership likely resides with the system operator (e.g., researchers or educators), but no formal policies are defined in the provided documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT adheres to the following standards and conventions: **1) C4 Model** for architecture visualization. **2) MQTT Protocol** for messaging. **3) TimescaleDB (PostgreSQL-compatible)** for time-series data. **4) Grafana** for visualization (supports multiple data sources). **5) Docker** for containerization. **6) Python** for application development. **7) MIT License** for open-source distribution. **8) Arcadia/Capella** for Model-Based Systems Engineering (MBSE) documentation. The exemplar avoids proprietary digital twin frameworks, opting for open-source tools tailored to specific needs (e.g., kinematic modeling for trajectory generation)."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The documents do not explicitly detail security or safety mechanisms for remote operations. However, the following considerations are implied: **1) Local Deployment**: The DT runs on a single computer connected to the physical crane, reducing exposure to remote attacks. **2) MQTT Broker**: While lightweight, it lacks explicit authentication or encryption in the provided setup. **3) Operator Intervention**: The **Continuous Validation Service** triggers alerts for manual review, suggesting a safety-first approach. **4) Hardware Redundancy**: The crane’s critical components (motors, controllers) are not explicitly redundant, but the **Arduino** provides real-time monitoring. **5) Future Work**: Mentions integrating a **physical simulator** for virtual commissioning, which could include safety checks before real-world deployment. No details are provided on fail-safes for human safety during remote operations."
]