// C2: Acting Components
instance MotorHorizontal : DTDFVocab:ActingComponent [
    base:desc "Electric motor driving horizontal movement of the cart along the gantry, controlled via dedicated motor controller."
]
instance MotorVertical : DTDFVocab:ActingComponent [
    base:desc "Electric motor driving the vertical hoist, controlled via dedicated motor controller."
]
instance ElectromagnetHoist : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted at the hoist end for picking up and releasing container pucks, commanded over ActiveMQ."
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution encoder mounted on the hoist measuring pendulum swing angle with sub‑degree resolution."
    DTDFVocab:producedData SwingAngleDataTransmitted
]
instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer placed near the crane recording ambient wind speed with ±0.1 m/s accuracy."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Data transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Data entities
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Timestamped swing‑angle measurements streamed via MQTT/ActiveMQ to the time‑series store."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimeSeriesDB, SimulationEngine
]
instance WindSpeedData : DTDFVocab:Data [
    base:desc "Timestamped wind‑speed readings streamed via MQTT/ActiveMQ to the time‑series store."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimeSeriesDB, SimulationEngine
]

// C10: Models
instance CADModelGantryCrane : DTDFVocab:Model [
    base:desc "Geometric CAD representation of the gantry crane structure used for visualization and collision checking."
    DTDFVocab:inputTo SimulationEngine
]
instance KinematicModelGantryCrane : DTDFVocab:Model [
    base:desc "Kinematic model describing Cartesian motion of the cart and hoist for trajectory prediction."
    DTDFVocab:inputTo SimulationEngine, ValidationEngine
]
instance BehavioralModelSwingDynamics : DTDFVocab:Model [
    base:desc "Behavioral model capturing swing dynamics and load handling behavior of the crane."
    DTDFVocab:inputTo SimulationEngine, ValidationEngine
]

// C11: Enablers
instance TimeSeriesDB : DTDFVocab:Enabler [
    base:desc "InfluxDB/TimescaleDB time‑series database storing sensor and actuator data."
    DTDFVocab:enables HistoricalDataLoggingService, DataVisualizationService, ContinuousValidationService
]
instance ControlMessageBroker : DTDFVocab:Enabler [
    base:desc "ActiveMQ broker transporting control commands from the Optimal Control Service to motor controllers."
    DTDFVocab:enables OptimalControlService
]
instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation service consuming CAD, kinematic and behavioral models to generate predicted trajectories."
    DTDFVocab:enables ContinuousValidationService, OptimalControlService
]
instance ValidationEngine : DTDFVocab:Enabler [
    base:desc "Engine that compares live measurements with simulated predictions to detect deviations."
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes optimal control actions for the crane based on current state and model predictions."
    DTDFVocab:provides ControlAction, ValidationInsight
]
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Records sensor and actuator measurements into the time‑series database for persistent storage."
    DTDFVocab:provides HistoricalInsight
]
instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Renders runtime visualisations of crane state and performance metrics for operators."
    DTDFVocab:provides VisualizationInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates live data against model predictions and raises alerts when thresholds are breached."
    DTDFVocab:provides ValidationAlert, ValidationInsight
]

// C17: Insights
instance HistoricalInsight : DTDFVocab:Insight [
    base:desc "Provides aggregated historical trends of crane operation for analysis."
]
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Offers real‑time visual representation of crane position, swing angle and load."
]
instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Indicates deviation magnitude between measured and predicted crane behavior."
]

// C17: Actions
instance ControlAction : DTDFVocab:Action [
    base:desc "Executes computed control commands to drive horizontal and vertical motors and activate electromagnet."
    DTDFVocab:IsAutomatic true
]
instance ValidationAlert : DTDFVocab:Action [
    base:desc "Generates an alert when swing angle or other measured values exceed configured thresholds, prompting operator correction."
    DTDFVocab:IsAutomatic true
]

// Environment (optional context)
instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains MotorHorizontal, MotorVertical, ElectromagnetHoist, SwingAngleEncoder, Anemometer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, a Python program, uses the Physical Crane Interface to issue control commands to the crane hardware. The Trajectory Generator Service can produce optimal movement trajectories that are consumed by the Control Application for execution. The documents do not detail command formats, validation, authentication, or acknowledgement mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The gantry crane Digital Twin follows an ad‑hoc architecture modelled with the C4 approach and uses containerization to package its software components, deploying them on virtual machines without a commercial DT framework; component coordination is handled within this container‑based deployment."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by a Continuous Validation Service that continuously compares live sensor measurements of executed trajectories against simulated trajectories generated by the kinematic model. The service computes distance metrics (e.g., RMS error) and flags deviations exceeding a predefined threshold, triggering alerts or model re‑calibration. Validation incorporates uncertainty quantification from sensor noise and actuator tolerances, and employs automated error‑correction loops to update model parameters, ensuring the digital twin remains a trustworthy representation of the physical gantry crane."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin relies on an MQTT broker for signaling between services (Trajectory Generator, Simulation, Continuous Validation, etc.). The broker operates over standard MQTT/TCP. All components (Python applications, TimescaleDB, Grafana) are modeled as logical containers in the C4 diagram and are assumed to run on the same host network; the documents do not specify network topology, bandwidth, latency, redundancy, or additional security protocols."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system consists of several logical containers: Physical Crane, Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface, plus twin containers (TimescaleDB database, Grafana dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service, MQTT Broker). Deployment is on‑premise (no cloud or edge platform is mentioned) using container‑style abstraction rather than Docker containers. Computational and storage requirements are not quantified; scalability is limited to the described set of services, and no explicit availability or reliability provisions are detailed."
]