// C2: Acting Components
instance XAxisStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the X‑axis linear rail of the gantry crane"
]

instance YAxisStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the Y‑axis linear rail of the gantry crane"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet that holds and releases the load on the crane arm"
]

instance ArduinoNanoController : DTDFVocab:ActingComponent [
    base:desc "ARM‑based Arduino Nano controller interfaced via serial/USB for motor control and data acquisition"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder mounted on the crane arm providing precise arm angle measurements"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the gantry structure"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Models/Data
instance CADModel : DTDFVocab:Model [
    base:desc "Autodesk Fusion360 CAD model of the gantry crane geometry"
    DTDFVocab:inputTo PythonControlScripts
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model describing the motion of the linear and rotational axes"
    DTDFVocab:inputTo PythonControlScripts
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing angle data for the crane arm"
    DTDFVocab:inputTo TimescaleDBDatabase
    DTDFVocab:fromData SwingAngleDataTransmitted
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind speed data gathered by the anemometer"
    DTDFVocab:inputTo TimescaleDBDatabase
    DTDFVocab:fromData WindSpeedDataTransmitted
]

instance ExecutedTrajectoryData : DTDFVocab:Data [
    base:desc "Executed trajectory logs including position and velocity of the crane axes"
    DTDFVocab:inputTo TimescaleDBDatabase
]

// C11: Enablers
instance MosquittoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker handling publish/subscribe messaging between physical and digital twin"
    DTDFVocab:enables OptimalControlService, HistoricalDataLoggingService, VisualizationDashboardService, ContinuousValidationService
]

instance TimescaleDBDatabase : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database persisting all sensor trajectories and actuator states"
    DTDFVocab:enables HistoricalDataLoggingService, ContinuousValidationService
]

instance PythonControlScripts : DTDFVocab:Enabler [
    base:desc "Python scripts executing control logic, data ingestion, and numerical simulation"
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboards visualizing real‑time sensor data and simulation results"
    DTDFVocab:enables VisualizationDashboardService
]

instance Fusion360CADTool : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion360 used for creating CAD geometrical models of the crane"
]

instance CapellaArchitectureTool : DTDFVocab:Enabler [
    base:desc "Capella formal system architecture modeling tool"
]

instance DockerComposeContainer : DTDFVocab:Enabler [
    base:desc "Docker Compose orchestrating all Docker containers for the digital twin stack"
]

// C17: Insights/Actions
instance TrajectoryPlanInsight : DTDFVocab:Insight [
    base:desc "Generated trajectory plan for the crane axes"
]

instance HistoricalDataLoggedInsight : DTDFVocab:Insight [
    base:desc "Confirmation that motion and actuator states have been logged"
]

instance ConfidenceBoundInsight : DTDFVocab:Insight [
    base:desc "Confidence bounds derived from simulation comparisons to detect discrepancies"
]

instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of sensor data and simulation results"
]

instance TriggerCorrectiveAction : DTDFVocab:Action [
    base:desc "Allows operators to trigger corrective actions directly from the dashboard"
    DTDFVocab:IsAutomatic false
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal control and trajectory planning interfacing directly with the physical controller"
    DTDFVocab:provides TrajectoryPlanInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Real‑time historical data logging of motion and actuator states"
    DTDFVocab:provides HistoricalDataLoggedInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation loops comparing live sensor data against the CAD‑based kinematic model"
    DTDFVocab:provides ConfidenceBoundInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Interactive data visualization dashboards for monitoring system performance"
    DTDFVocab:provides RealTimeDashboardInsight, TriggerCorrectiveAction
]

// C3: Components
instance GantryFrame : DTDFVocab:Component [
    base:desc "Steel gantry frame fitted at Cosys‑Lab & Flanders Make University"
]

// C17: Environment
instance CosysLabEnvironment : DTDFVocab:Environment [
    base:contains GantryFrame, XAxisStepperMotor, YAxisStepperMotor, Electromagnet, SwingAngleEncoder, Anemometer, ArduinoNanoController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are issued by the Control Application, which consumes trajectory commands generated by the Trajectory Generator Service.  These high‑level commands are passed to the Physical Crane Interface through a Python method call interface.  The Physical Crane Interface then translates the high‑level target positions and motion profiles into low‑level motor commands that are sent to the crane controllers.  Feedback from the physical machine (e.g., current position, velocity or error status) is routed back through the same interface to the Control Application for realtime monitoring, but the document does not describe additional authentication or acknowledgment protocols."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system employs containerized components such as an InfluxDB time‑series database and an ActiveMQ message broker, each deployed on pre‑configured virtual machine images that also host the physical environment (greenhouse or Raspberry‑Pi). The architecture is ad‑hoc, with no dedicated orchestration layer or central registry; each digital twin instance maintains its own state locally. For the Air Quality Management exemplar, Microsoft Azure services are used for data processing and visualization, while the GreenhouseDT exemplar remains on‑premises. Communication between physical sensors and digital twin services is performed over ActiveMQ topics, with data persisted in InfluxDB."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A Continuous Validation Service continuously compares the measurements obtained during crane motion against the trajectories simulated by the digital twin. For each executed trajectory the service computes a distance metric between the measured and simulated positions and flags a mismatch when the metric exceeds a predefined threshold, thereby enabling automated detection of model‑discrepancy and ensuring that the digital twin remains a valid representation of the physical system."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin relies on an MQTT broker (Eclipse Mosquitto) that mediates publish/subscribe messaging among the Trajectory Generator, Simulation, and Continuous Validation services.  Data persistence is handled by a TimescaleDB instance accessed by all services.  The document does not detail the underlying network topology, bandwidth, or reliability mechanisms beyond the use of these software components."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital twin containers—including the MQTT broker, TimescaleDB, Grafana dashboard, Trajectory Generator, Simulation, Continuous Validation, and control interfaces—are provisioned as logical containers on a single physical host or node.  The document does not specify a cloud, edge, or on‑premises distinction, nor does it provide hardware or scalability parameters, beyond the abstract notion that the system can be deployed in a containerized environment."
]