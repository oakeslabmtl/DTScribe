// C2: Acting Components
instance GantryCraneController : DTDFVocab:ActingComponent [
    base:desc "Embedded microcontroller (likely Arduino/Raspberry Pi) interfacing the gantry crane with PLC or external systems for real-time motion control"
]

instance VentilationActuator : DTDFVocab:Actuator [
    base:desc "Motorized dampers controlling airflow in indoor air quality systems (e.g., for virus-spread mitigation)"
]

instance ClimateRegulatorActuator : DTDFVocab:Actuator [
    base:desc "Automated environmental control actuators (fans, heaters, irrigation systems) triggered by the greenhouse digital twin's behavioral model"
]

instance HEPAFilterActuator : DTDFVocab:Actuator [
    base:desc "Indoor air purification system components (HEPA filters, UV-C disinfection units) controlled via AutomationML-based commands"
]

// C3: Physical sensing components
instance PositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures gantry crane's X/Y/Z coordinates and velocity/acceleration metrics via encoder readings"
    DTDFVocab:producedData PositionData
]

instance LoadCellSensor : DTDFVocab:SensingComponent [
    base:desc "Detects payload weight and environmental load parameters for crane operations"
    DTDFVocab:producedData EnvironmentalParams
]

instance TemperatureHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Monitors greenhouse environmental parameters (temperature, humidity) via DHT22/BME280 sensors"
    DTDFVocab:producedData TemperatureData, HumidityData
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry-Pi mounted CO₂ sensors (SCD30/MQ-135) for indoor air quality monitoring"
    DTDFVocab:producedData CO2Measurement
]

instance AirflowVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Measures airflow dynamics and dispersion patterns in air quality systems"
    DTDFVocab:producedData AirflowVelocity
]

instance FrictionCoefficientSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors measuring mechanical friction coefficients for crane kinematic modeling"
    DTDFVocab:producedData FrictionCoefficient
]

instance SafetyLimitSensor : DTDFVocab:SensingComponent [
    base:desc "Threshold breach detectors for emergency stop conditions in crane operations"
    DTDFVocab:producedData SafetyThreshold
]

// C4: Physical-to-virtual interaction
instance PositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionEncoder
]

instance VelocityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionEncoder
]

instance AccelerationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionEncoder
]

instance TrajectoryLog : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionEncoder
]

instance EnvironmentalParams : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadCellSensor
]

instance ControllerState : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GantryCraneController
]

instance TemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureHumiditySensor
]

instance HumidityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureHumiditySensor
]

instance CO2Measurement : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance AirflowVelocity : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirflowVelocitySensor
]

instance FrictionCoefficient : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FrictionCoefficientSensor
]

instance SafetyThreshold : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SafetyLimitSensor
]

// C10: Models/Data
instance GantryKinematicModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink-based kinematic model defining the gantry crane's moving carriage, overhead beam, and supporting frame dynamics"
    DTDFVocab:inputTo PositionEncoder, FrictionCoefficientSensor
]

instance EnvironmentalBehaviorModel : DTDFVocab:Model [
    base:desc "InfluxDB-based time-series model for greenhouse environmental adaptation (temperature/humidity regulation)"
    DTDFVocab:inputTo TemperatureData, HumidityData
]

instance AirQualitySimulationModel : DTDFVocab:Model [
    base:desc "AutomationML-based simulation model for CO₂ dispersion and airflow dynamics in air quality systems"
    DTDFVocab:inputTo CO2Measurement, AirflowVelocity
]

instance HistoricalDataArchive : DTDFVocab:Data [
    base:desc "SQLite/MySQL database storing time-series operational metrics (position, velocity, torque) for post-hoc analysis"
    DTDFVocab:fromData PositionData, VelocityData, AccelerationData, TrajectoryLog, EnvironmentalParams, ControllerState
    DTDFVocab:inputTo PythonDataProcessing
]

instance RealTimeDataBuffer : DTDFVocab:Data [
    base:desc "Redis in-memory database for low-latency processing of real-time sensor streams"
    DTDFVocab:fromData PositionData, VelocityData, AccelerationData, TrajectoryLog, EnvironmentalParams, ControllerState, TemperatureData, HumidityData, CO2Measurement, AirflowVelocity, FrictionCoefficient, SafetyThreshold
    DTDFVocab:inputTo InfluxDBDatabase
]

instance AutomationMLModel : DTDFVocab:Model [
    base:desc "Standardized AutomationML model defining physical layout (sensor placements, airflow paths) and operational workflows"
    DTDFVocab:inputTo AzureIoTHub, PythonDataProcessing
]

instance PredictiveFailureModel : DTDFVocab:Model [
    base:desc "Machine learning pipeline (Azure ML) for predicting imminent crane failures based on operational trends"
    DTDFVocab:inputTo HistoricalDataArchive, RealTimeDataBuffer
]

instance KinematicValidationModel : DTDFVocab:Model [
    base:desc "Custom MATLAB/Simulink model validating digital kinematic models against physical encoder readings"
    DTDFVocab:inputTo PositionEncoder, GantryKinematicModel
]

// C11: Enablers
instance MATLABSimulinkEnvironment : DTDFVocab:Enabler [
    base:desc "Development environment for control algorithm design, simulation, and prototyping of gantry crane dynamics"
    DTDFVocab:enables GantryKinematicModel, KinematicValidationModel
]

instance SolidWorksCAD : DTDFVocab:Enabler [
    base:desc "CAD tool creating 3D geometry for both physical gantry crane and digital twin models"
    DTDFVocab:enables AutomationMLModel
]

instance OpenModelica : DTDFVocab:Enabler [
    base:desc "Open-source modeling language for defining mechanical dynamics (joints, payloads, friction effects) in crane kinematics"
    DTDFVocab:enables GantryKinematicModel
]

instance InfluxDBDatabase : DTDFVocab:Enabler [
    base:desc "Time-series database for real-time data storage and querying of environmental parameters in greenhouse DT"
    DTDFVocab:enables EnvironmentalBehaviorModel, HistoricalDataArchive
]

instance ActiveMQMessageBroker : DTDFVocab:Enabler [
    base:desc "Asynchronous message broker facilitating decoupled communication between physical system and digital twin"
    DTDFVocab:enables RealTimeDataBuffer, AutomationMLModel
]

instance PythonDataProcessing : DTDFVocab:Enabler [
    base:desc "Python (Pandas, NumPy, SciPy) framework for data analysis, preprocessing, and historical logging"
    DTDFVocab:enables HistoricalDataArchive, RealTimeDataBuffer
]

instance AzureIoTHub : DTDFVocab:Enabler [
    base:desc "Microsoft Azure service for centralized data ingestion and processing of air quality sensor data"
    DTDFVocab:enables AutomationMLModel, PredictiveFailureModel
]

instance DockerContainerization : DTDFVocab:Enabler [
    base:desc "Containerization platform (Docker/Kubernetes) for modular deployment and scalability of digital twin services"
    DTDFVocab:enables MonitoringService, OptimizationService, PredictionService, ControlService, VisualizationService
]

instance DarTwinNotation : DTDFVocab:Enabler [
    base:desc "System evolution notation for managing changes in digital twin architecture (control algorithms, sensor models)"
    DTDFVocab:enables ContinuousValidationService
]

instance ContinuousValidationService : DTDFVocab:Enabler [
    base:desc "Custom algorithms (Kalman filters, particle filters) validating digital twin accuracy against physical measurements"
    DTDFVocab:enables KinematicValidationModel
]

// C6: Services
instance RealTimeKinematicValidation : DTDFVocab:Service [
    base:desc "Continuous comparison between physical crane movements and digital kinematic models to detect discrepancies"
    DTDFVocab:provides PositionalDiscrepancyInsight
]

instance FaultDetectionService : DTDFVocab:Service [
