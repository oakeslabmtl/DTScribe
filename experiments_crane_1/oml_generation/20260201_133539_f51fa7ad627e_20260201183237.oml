]

instance ParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatically adjusts digital model parameters for improved accuracy"
    DTDFVocab:IsAutomatic true
]

instance StatePredictionInsight : DTDFVocab:Insight [
    base:desc "Future state predictions (position, acceleration) enabling proactive maintenance"
]

instance FailureWarningAction : DTDFVocab:Action [
    base:desc "Issues warnings for imminent failures based on operational trends"
