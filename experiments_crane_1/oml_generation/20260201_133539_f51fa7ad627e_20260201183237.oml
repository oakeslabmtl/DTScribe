instance PositionalDiscrepancyInsight : DTDFVocab:Insight [
    base:desc "Detected mismatches between physical encoder readings and digital kinematic model predictions"
]

instance AnomalyAlertAction : DTDFVocab:Action [
    base:desc "Triggered alerts for physical system anomalies (motor overload, actuator failure)"
