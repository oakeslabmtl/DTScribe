    DTDFVocab:provides StatePredictionInsight
]

instance FailurePredictionService : DTDFVocab:Service [
    base:desc "Predicts imminent failures (bearing wear) based on operational trends"
    DTDFVocab:provides FailureWarningAction
]

instance ClosedLoopControlBridge : DTDFVocab:Service [
    base:desc "Bridge between physical crane controllers and external digital services for supervisory control logic"
    DTDFVocab:provides ControlCommandAction
]

instance SafetyValidationService : DTDFVocab:Service [
