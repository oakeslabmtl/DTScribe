// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Arduino‑connected swing‑angle encoder measuring crane swing angle"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Arduino‑connected anemometer measuring wind speed influencing crane motion"
    DTDFVocab:producedData AnemometerDataTransmitted
]

instance ActuatorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reading actuator statuses (motor currents, command acknowledgements) from the crane controller"
    DTDFVocab:producedData ActuatorStatusDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance ActuatorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ActuatorStatusSensor
]

// C10: Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Timestamped swing‑angle measurements streamed continuously to TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted
]

instance AnemometerData : DTDFVocab:Data [
    base:desc "Timestamped wind‑speed measurements stored in TimescaleDB"
    DTDFVocab:fromData AnemometerDataTransmitted
]

instance ActuatorStatusData : DTDFVocab:Data [
    base:desc "Timestamped actuator‑status records persisted in TimescaleDB"
    DTDFVocab:fromData ActuatorStatusDataTransmitted
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Centralized TimescaleDB time‑series database used for persisting sensor and actuator data"
    DTDFVocab:enables HistoricalLoggingService, SimulationService, ContinuousValidationService, DataVisualizationService, MonitoringService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker that routes data streams and commands between services"
    DTDFVocab:enables SimulationService, ContinuousValidationService, DataVisualizationService, OptimalControlService, MonitoringService
]

// C10: Models
instance CraneCADModel : DTDFVocab:Model [
    base:desc "3‑D CAD model of the lab‑scale gantry crane used for visualization in the dashboard"
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Analytical kinematic model describing crane motion for trajectory generation, simulation and validation"
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes optimal motion commands using the kinematic model and publishes them to the crane controller"
    DTDFVocab:provides ControlAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Continuously writes timestamped sensor and actuator data into TimescaleDB"
    DTDFVocab:provides DataArchiveInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualizes stored data and the CAD model of the crane in real time"
    DTDFVocab:provides VisualInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Emulates crane behaviour for received trajectories using the kinematic model"
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares live logged data with simulated trajectories triggers alerts when distance‑metric threshold is exceeded"
    DTDFVocab:provides AnomalyInsight, AlertAction
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time observation of crane state to researchers and operators"
    DTDFVocab:provides RealTimeStateInsight
]

// C17: Insights / Actions
instance ControlAction : DTDFVocab:Action [
    base:desc "Optimal control commands transmitted to the crane controller"
    DTDFVocab:IsAutomatic true
]

instance DataArchiveInsight : DTDFVocab:Insight [
    base:desc "Historical archive of crane sensor and actuator data available for offline analysis"
]

instance VisualInsight : DTDFVocab:Insight [
    base:desc "Interactive visualization of crane pose, trajectories and logged data"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Predicted crane behaviour for a given trajectory generated by the simulation service"
]

instance AnomalyInsight : DTDFVocab:Insight [
    base:desc "Detection of deviations between physical crane behaviour and the kinematic model"
]

instance AlertAction : DTDFVocab:Action [
    base:desc "Publishes MQTT alert to the dashboard when validation threshold is exceeded"
    DTDFVocab:IsAutomatic true
]

instance RealTimeStateInsight : DTDFVocab:Insight [
    base:desc "Live state of the crane (position, velocity, swing angle) presented to users"
]

// C5: Physical components
instance PhysicalCrane : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane consisting of a motor‑driven carriage, controller unit and interchangeable pucks"
]

instance GantryStructure : DTDFVocab:Component [
    base:desc "Static gantry frame supporting the moving carriage"
]

instance MotorDrivenCarriage : DTDFVocab:Component [
    base:desc "Carriage that moves along the gantry driven by an electric motor"
]

instance ControllerUnit : DTDFVocab:Component [
    base:desc "Embedded controller interfacing with sensors, actuators and the Python Physical Crane Interface"
]

instance InterchangeablePuck : DTDFVocab:Component [
    base:desc "Modular container surrogate moved by the crane between predefined locations"
]

// C16: Environment
instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains PhysicalCrane, GantryStructure, MotorDrivenCarriage, ControllerUnit, InterchangeablePuck
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, implemented in Python, receives trajectory commands from the Trajectory Generator Service. It translates the optimal trajectory into low‑level motion commands and sends them to the Physical Crane Interface, which communicates with the crane’s motor controllers (via the Arduino) to drive cart movement and hoisting. The command flow is bi‑directional: after each command the crane reports its updated state, which is logged as described above. No explicit command format, authentication or conflict‑resolution mechanisms are detailed in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The lab‑scale gantry crane twin operates in (near) real‑time: a Logging Application continuously streams the crane’s state to a TimescaleDB database, and the Continuous Validation Service continuously compares measured trajectories with those simulated by the Simulation Service, generating alerts via the Grafana dashboard when a threshold is exceeded. No explicit synchronization interval or latency bound is specified in the documentation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration follows a container‑based architecture described with the C4 model. Core components are implemented in Python and communicate via an MQTT broker for event‑driven signaling. Persistent data are stored in a TimescaleDB instance, visualized in Grafana. The Trajectory‑Generator produces optimal motion plans, the Simulation Service evaluates them, and the Continuous Validation Service assesses deviation, all orchestrated by the MQTT broker and the shared database, constituting a tightly coupled, service‑oriented constellation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by a Continuous Validation Service that continuously compares the measurements of executed trajectories (obtained from the physical crane) with the corresponding simulated trajectories generated by the Simulation Service. The service computes distance metrics between the two data streams, checks them against a predefined acceptable threshold, and triggers operator alerts via the Grafana dashboard when the threshold is breached. This validation loop provides ongoing verification of the kinematic model’s accuracy and enables detection and correction of modeling errors."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication relies on an MQTT broker (Eclipse Mosquitto) for publish/subscribe signaling and on PostgreSQL‑compatible SQL connections to the TimescaleDB database. All Dockerized components (TimescaleDB, MQTT broker, Grafana dashboard) run on the same host machine and communicate over the host’s loopback network. The Python services communicate locally via the MQTT broker and direct database connections. No specific bandwidth, latency, redundancy or security protocols beyond the use of MQTT and standard database authentication are mentioned."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire system is deployed on a single personal computer. Docker containers host the TimescaleDB database, the Eclipse Mosquitto MQTT broker, and the Grafana dashboard, orchestrated with a docker‑compose file. The remaining services (Physical Crane Interface, Control Application, Logging Application, Trajectory Generator, Simulation, Continuous Validation) are provided as a Python package (gantrylib) installed with pip and run as standard processes on the host. Deployment is therefore on‑premise, with scalability limited to the resources of the host PC; the open‑source components allow replication on any comparable hardware."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external software is achieved through standard open protocols: state data are published to the TimescaleDB using its native SQL/TSDB interface, real‑time messages are exchanged over MQTT, and visualisation is provided through Grafana dashboards. No explicit enterprise‑level standards (e.g., AutomationML) are used in this exemplar, and the twin does not depend on external cloud platforms; all components run locally on the provided virtual‑machine images."
]