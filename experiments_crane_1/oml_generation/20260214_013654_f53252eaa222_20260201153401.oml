// C3: Physical sensing components
instance TemperatureHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor for greenhouse climate parameters including temperature and humidity monitoring in GreenhouseDT exemplar. Part of low-cost embedded sensing infrastructure with real-time monitoring capabilities."
    DTDFVocab:producedData GreenhouseClimateDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor measuring CO2 levels in Air Quality Management exemplar for real-time indoor air quality monitoring. Deployed as part of Raspberry Pi-based sensor array with high-frequency sampling."
    DTDFVocab:producedData AirQualityDataTransmitted
]

instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring real-time position of gantry crane components (bridge, hoist, puck) using encoders or vision systems. Part of lab-scale gantry crane's data-generating infrastructure."
    DTDFVocab:producedData CraneKinematicDataTransmitted
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring real-time velocity of gantry crane components (bridge, hoist, puck) using encoders or IMUs. Critical for dynamic motion analysis in digital twin validation."
    DTDFVocab:producedData CraneKinematicDataTransmitted
]

instance CraneLoadSensor : DTDFVocab:SensingComponent [
    base:desc "Load cell sensor measuring payload weight and distribution on gantry crane. Provides real-time operational data for safety-critical applications."
    DTDFVocab:producedData CraneOperationalDataTransmitted
]

instance CraneControllerStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring controller status signals including motor commands and operational modes of gantry crane. Enables bidirectional interaction between physical and virtual systems."
    DTDFVocab:producedData CraneControlDataTransmitted
]

// C4: Physical-to-virtual interaction
instance GreenhouseClimateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureHumiditySensor
    base:desc "Real-time climate data transmitted from greenhouse environmental sensors. Used for bidirectional synchronization between physical greenhouse and digital twin."
]

instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
    base:desc "High-frequency air quality metrics including CO2 levels transmitted from Raspberry Pi-based sensor nodes. Enables real-time monitoring for virus spread prevention."
]

instance CraneKinematicDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor, CraneVelocitySensor
    base:desc "Real-time kinematic data (position, velocity) from gantry crane sensors transmitted via proprietary industrial protocols. Critical for digital twin synchronization."
]

instance CraneOperationalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneLoadSensor
    base:desc "Operational telemetry including payload measurements transmitted from load cells. Used for safety monitoring and performance validation."
]

instance CraneControlDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneControllerStatusSensor
    base:desc "Controller status signals including motor commands and operational modes transmitted from physical crane to digital twin interface."
]

// C10: Models/Data
instance GreenhouseBehavioralModel : DTDFVocab:Model [
    base:desc "Self-adaptive behavioral model for greenhouse climate control integrating pre-recorded sensor data from VMs and real-time InfluxDB data. Enables dynamic environmental adjustments."
    DTDFVocab:inputTo InfluxDBEnabler
]

instance AirQualityPredictiveModel : DTDFVocab:Model [
    base:desc "Analytical model for air quality prediction using Microsoft Azure tools. Enables 'what-if' scenario testing for ventilation system optimization and virus spread prevention."
    DTDFVocab:inputTo AzureCloudEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Mathematical representation of gantry crane motion using Denavit-Hartenberg parameters and forward/inverse kinematics implemented in Python. Provides high-fidelity digital twin replication."
    DTDFVocab:inputTo PythonSimulationEnabler
]

instance CraneControlModel : DTDFVocab:Model [
    base:desc "Control logic model for gantry crane operations including trajectory planning and adaptive control algorithms. Enables bidirectional interaction with physical controller."
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance GreenhouseClimateData : DTDFVocab:Data [
    base:desc "Structured time-series data representing greenhouse climate parameters (temperature, humidity) stored in InfluxDB. Used for historical analysis and real-time synchronization."
    DTDFVocab:fromData GreenhouseClimateDataTransmitted
    DTDFVocab:inputTo InfluxDBEnabler
]

instance AirQualityMeasurementData : DTDFVocab:Data [
    base:desc "High-frequency air quality measurements including CO2 levels and particulate matter stored in time-series database. Enables runtime visualization and predictive analytics."
    DTDFVocab:fromData AirQualityDataTransmitted
    DTDFVocab:inputTo InfluxDBEnabler, AzureCloudEnabler
]

instance CraneOperationalTelemetry : DTDFVocab:Data [
    base:desc "Time-series operational data including crane positions, velocities, and payload measurements stored in TimescaleDB. Supports historical analysis and compliance logging."
    DTDFVocab:fromData CraneKinematicDataTransmitted, CraneOperationalDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance CraneControlSignals : DTDFVocab:Data [
    base:desc "Controller status signals including motor commands and operational modes stored in database. Enables bidirectional control synchronization between physical and virtual systems."
    DTDFVocab:fromData CraneControlDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ROS2MiddlewareEnabler
]

// C11: Enablers
instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database for storing and querying high-frequency operational data from digital twin systems. Supports both real-time monitoring and historical analysis."
    DTDFVocab:enables GreenhouseDataLoggingService, AirQualityVisualizationService, CraneDataLoggingService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database optimized for high-write workloads storing crane operational telemetry and control signals. Enables continuous validation and fault detection services."
    DTDFVocab:enables CraneDataLoggingService, FaultDetectionService
]

instance AzureCloudEnabler : DTDFVocab:Enabler [
    base:desc "Microsoft Azure cloud services for implementing air quality management digital twin pipeline including predictive analytics and runtime visualization."
    DTDFVocab:enables AirQualityPredictionService, AirQualityVisualizationService
]

instance PythonSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python-based simulation environment using PyRobot or PyBullet for implementing crane kinematic models and offline testing of control algorithms."
    DTDFVocab:enables CraneSimulationService, OptimalControlService
]

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "Robot Operating System 2 middleware for interoperability between heterogeneous components including sensors, controllers, and digital twin services."
    DTDFVocab:enables CraneControlService, FaultDetectionService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Message broker facilitating asynchronous communication between digital twin services including data dissemination from logging applications to dashboards."
    DTDFVocab:enables GreenhouseDataLoggingService, AirQualityVisualizationService, CraneDataLoggingService
]

instance DockerContainerizationEnabler : DTDFVocab:Enabler [
    base:desc "Docker containerization platform for isolating digital twin services including control optimizers and visualization dashboards. Enables modular deployment and reproducibility."
    DTDFVocab:enables GreenhouseDataLoggingService, CraneSimulationService
]

