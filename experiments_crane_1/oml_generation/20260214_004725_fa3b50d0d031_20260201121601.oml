// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder mounted on the hoist, read by the Arduino"
    DTDFVocab:producedData SwingAngleDataTransmitted
]
instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer for wind speed measurement, read by the Arduino"
    DTDFVocab:producedData WindSpeedDataTransmitted
]
instance CartWheelEncoder : DTDFVocab:SensingComponent [
    base:desc "Wheel encoder of the cart motor, read by the Arduino"
    DTDFVocab:producedData CartPositionDataTransmitted
]
instance StepperMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Internal encoder of the stepper motors, read by the Arduino"
    DTDFVocab:producedData StepperEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]
instance CartPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartWheelEncoder
]
instance StepperEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StepperMotorEncoder
]

// C10: Models/Data
instance CADModelFusion360 : DTDFVocab:Model [
    base:desc "Autodesk Fusion360 CAD file of the gantry crane frame"
    DTDFVocab:inputTo SimulationEnabler
]
instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator Service"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]
instance ArcadiaModel : DTDFVocab:Model [
    base:desc "Arcadia/Capella model for educational use"
    DTDFVocab:inputTo SimulationEnabler
]

instance SwingAngleTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series logs of swing‑angle measurements stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo LoggingAppEnabler
]
instance WindSpeedTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series logs of wind speed measurements stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo LoggingAppEnabler
]
instance CartPositionTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series logs of cart position measurements stored in TimescaleDB"
    DTDFVocab:fromData CartPositionDataTransmitted
    DTDFVocab:inputTo LoggingAppEnabler
]
instance StepperEncoderTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series logs of stepper encoder measurements stored in TimescaleDB"
    DTDFVocab:fromData StepperEncoderDataTransmitted
    DTDFVocab:inputTo LoggingAppEnabler
]

// C11: Enablers
instance LoggingAppEnabler : DTDFVocab:Enabler [
    base:desc "Logging application that stores time‑series data into TimescaleDB and publishes via MQTT"
    DTDFVocab:enables LogsService, DashboardService
]
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database for time‑series storage"
    DTDFVocab:enables LogsService, DashboardService
]
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for downstream data distribution"
    DTDFVocab:enables DashboardService, ContinuousValidationService
]
instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Docker container for Trajectory Generator Service"
    DTDFVocab:enables TrajectoryGeneratorService
]
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Docker container for Physics‑based Simulator Service"
    DTDFVocab:enables SimulationService
]
instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Docker container for Continuous Validation Service"
    DTDFVocab:enables ContinuousValidationService
]
instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Docker container for Fault Classification Service"
    DTDFVocab:enables FaultClassificationService
]

// C6: Services
instance LogsService : DTDFVocab:Service [
    base:desc "Provides continuous gathering of state data"
    DTDFVocab:provides LogAuditInsight
]
instance DashboardService : DTDFVocab:Service [
    base:desc "Grafana visualization of time‑series with confidence bounds"
    DTDFVocab:provides RealTimeStatusInsight, OperatorNotificationAction
]
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Kinematic‑model based optimal swing‑free trajectory generation"
    DTDFVocab:provides EnergyEfficiencyInsight, GenerateOptimalTrajectoryAction
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulator for planned trajectories"
    DTDFVocab:provides SimulationAccuracyInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Real‑time distance metric comparing executed vs. simulated trajectories with threshold alerts"
    DTDFVocab:provides ValidationErrorInsight, TrajectoryDeviationAlertAction
]
instance FaultClassificationService : DTDFVocab:Service [
    base:desc "Time‑series classification for fault detection"
    DTDFVocab:provides FaultDetectionInsight, FaultClassifierAction
]

// C17: Insights/Actions
instance LogAuditInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing log data trends for operator reviews"
]
instance RealTimeStatusInsight : DTDFVocab:Insight [
    base:desc "Real‑time visual status of the crane system via Grafana dashboards"
]
instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating energy‑efficient swing‑free trajectories"
]
instance SimulationAccuracyInsight : DTDFVocab:Insight [
    base:desc "Insight assessing simulation fidelity against logged data"
]
instance ValidationErrorInsight : DTDFVocab:Insight [
    base:desc "Insight reporting trajectory deviation beyond validation threshold"
]
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight highlighting abnormal time‑series patterns for fault detection"
]

instance OperatorNotificationAction : DTDFVocab:Action [
    base:desc "Automatic operator notification via Grafana alerts when validation error exceeds threshold"
    DTDFVocab:IsAutomatic true
]
instance GenerateOptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatic generation of optimal swing‑free trajectory for planning"
    DTDFVocab:IsAutomatic true
]
instance TrajectoryDeviationAlertAction : DTDFVocab:Action [
    base:desc "Automatic alert sent when trajectory deviation exceeds threshold"
    DTDFVocab:IsAutomatic true
]
instance FaultClassifierAction : DTDFVocab:Action [
    base:desc "Automatic classification of fault types based on time‑series patterns"
    DTDFVocab:IsAutomatic true
]

// H: Physical environment and components
instance PhysicalEnvironment : DTDFVocab:Environment [
    base:contains CraneFrame, CartStepperMotor, HoistStepperMotor, Electromagnet, ArduinoController
]
instance CraneFrame : DTDFVocab:Component [
    base:desc "Wooden gantry crane frame"
]
instance CartStepperMotor : DTDFVocab:Component [
    base:desc "Brushless stepper motor driving the cart, controlled by Trinamic TMC4671 Eval driver"
]
instance HoistStepperMotor : DTDFVocab:Component [
    base:desc "Brushless stepper motor driving the hoist, controlled by Trinamic TMC4671 Eval driver"
]
instance Electromagnet : DTDFVocab:Component [
    base:desc "Electromagnet at the hoist end for picking up containers"
]
instance ArduinoController : DTDFVocab:Component [
    base:desc "Arduino-based controller that reads wheel encoder, swing‑angle encoder and wind speed"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Services such as Trajectory Generator and Continuous Validation publish target motor positions or speed requests to the MQTT broker; the Physical Crane Interface subscribes, translates them into serial commands, and forwards them to the TMC4671 motor drivers, thereby actuating the cart and hoist motors. Sensor feedback may also be queried from the physical hardware via the Interface."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate on a continuous, real‑time time‑scale: logging and validation run at the update frequency of the physical sensors (typically tens of Hz), trajectory generation and simulation are invoked on operator commands or at a scheduled interval, and the MQTT broker delivers messages with negligible latency (< 100 ms) within the local Docker network."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation includes the physical crane with its controller, a Python Physical Crane Interface, Control and Logging applications, human‑machine interface, a TimescaleDB container, an MQTT broker, a Grafana dashboard container, and two twin service containers (Trajectory Generator & Simulation) plus a Continuous Validation container, all orchestrated by Docker‑Compose and connected over a virtual bridge network."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin lifecycle covers design (CAD models and kinematic model), implementation (Python module gantrylib, database, dashboards), operation (real‑time monitoring and control), validation (continuous comparison), and education/research (iterative extension)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity relies on a kinematic representation of the crane and a physics‑based simulator; validation is performed by continuous monitoring of executed trajectories against simulation using a distance metric and a predefined threshold. Fault detection uses supervised time‑series classification to flag deviations, thereby maintaining model validity during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The physical system communicates with the twin via a USB serial connection to the Arduino; the Physical Crane Interface publishes data over MQTT (TCP) and writes to a TimescaleDB database (PostgreSQL protocol). The internal services communicate over MQTT on the same Docker network; the Grafana dashboard queries TimescaleDB over the database port. All connections use unencrypted TCP within the local machine."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin services are deployed as Docker containers on a single host (personal computer). Docker‑Compose manages container lifecycle, image build, and network configuration. The repository is hosted on GitHub, while documentation is served via MkDocs on GitHub Pages."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The twin employs open‑source standards: MQTT (IEEE 802.15.4 analogue for messaging), PostgreSQL for time‑series storage, Docker for containerization, Grafana for monitoring, Autodesk Fusion 360 for CAD, Arcadia/Capella for MBSE modeling, KiCad for PCB design, Arduino for firmware. No specific twin standard is adhered to, but the architecture follows the C4 model and MBSE practices."
]