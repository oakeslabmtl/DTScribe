instance AutomationMLAirQualityModel : DTDFVocab:Model [
    base:desc "AutomationML-based digital twin model for runtime visualization, simulation, and predictive analytics of indoor air quality dynamics."
    DTDFVocab:inputTo AzureCloudProcessing
]

