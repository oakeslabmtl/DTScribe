// C4: Physical-to-Virtual Interaction
instance AirQualitySensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CarbonDioxideSensor, ParticulateMatterSensor, HumiditySensor, TemperatureSensor
    base:desc "Real-time environmental data transmitted directly from Raspberry Pi-based sensors to cloud processing via Microsoft Azure."
]

instance GreenhouseEnvironmentalData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseEnvironmentalSensor
    base:desc "Environmental data transmitted from embedded greenhouse sensors to the digital twin via ActiveMQ for offline/batch processing."
]

