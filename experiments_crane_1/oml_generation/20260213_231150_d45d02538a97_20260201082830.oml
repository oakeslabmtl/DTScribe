// -----------------------------------------------------
// C3: Physical sensing components
// -----------------------------------------------------

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing on the physical gantry crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoMotorStatusReader : DTDFVocab:SensingComponent [
    base:desc "Arduino‑based board reading motor controller status (stepper motor state, driver feedback) and exposing it"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

// -----------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// -----------------------------------------------------

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoMotorStatusReader
]

// -----------------------------------------------------
// C10: Data instances
// -----------------------------------------------------

instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle readings streamed from the encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance WindSpeedMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed values streamed from the anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance MotorStatusMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped motor controller state (stepper command, driver alarms) read by the Arduino board"
    DTDFVocab:fromData MotorStatusDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

// -----------------------------------------------------
// C10: Model instances
// -----------------------------------------------------

instance CraneCADModel : DTDFVocab:Model [
    base:desc "Full 3‑D CAD geometry of the lab‑scale gantry crane"
    DTDFVocab:inputTo GrafanaEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used for trajectory generation and physics simulation"
    DTDFVocab:inputTo TrajectoryEngineEnabler, SimulationEngineEnabler
]

instance CraneControllerModel : DTDFVocab:Model [
    base:desc "Controller model (control law, PID parameters) used in the simulation service"
    DTDFVocab:inputTo SimulationEngineEnabler
]

// -----------------------------------------------------
// C11: Enablers (tools/technologies)
// -----------------------------------------------------

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database storing all sensor streams and generated data"
    DTDFVocab:enables DataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for event notifications and data streaming to DT services"
    DTDFVocab:enables ContinuousValidationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard visualising logged data and simulation results"
    DTDFVocab:enables GrafanaDashboardService
]

instance TrajectoryEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python‑based trajectory generation engine (gantrylib) running in Docker"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Physics‑based simulation service (Python) using the kinematic and controller models"
    DTDFVocab:enables SimulationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation engine comparing measured trajectories with simulated ones"
    DTDFVocab:enables ContinuousValidationService
]

instance HMIEnabler : DTDFVocab:Enabler [
    base:desc "Human‑Machine Interface (web UI) allowing operators to adjust parameters and view dashboards"
    DTDFVocab:enables HumanMachineInterfaceService
]

// -----------------------------------------------------
// C6: Service instances
// -----------------------------------------------------

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuously logs sensor streams and motor commands into TimescaleDB"
    DTDFVocab:provides DataLoggedInsight, StoreDataAction
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Provides interactive Grafana visualisations of logged and simulated data"
    DTDFVocab:provides VisualisationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free motion plans using the crane kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight, GenerateOptimalTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs physics‑based simulation of crane motion using kinematic and controller models"
    DTDFVocab:provides SimulatedTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates measured trajectories against simulation outputs and raises alerts"
    DTDFVocab:provides ValidationAlertInsight, RaiseValidationAlertAction
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "HMI for operators to visualise data, receive alerts and manually adjust control parameters"
    DTDFVocab:provides OperatorDecisionInsight, AdjustControlParametersAction
]

// -----------------------------------------------------
// C17: Insight and Action instances
// -----------------------------------------------------

instance DataLoggedInsight : DTDFVocab:Insight [
    base:desc "Indicates that a sensor reading has been successfully persisted in TimescaleDB"
]

instance StoreDataAction : DTDFVocab:Action [
    base:desc "Writes incoming measurement into the time‑series database"
    DTDFVocab:IsAutomatic true
]

instance VisualisationInsight : DTDFVocab:Insight [
    base:desc "Dashboard visualisation shows up‑to‑date sensor trends and simulation results"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Generated trajectory satisfies swing‑free constraints and is optimal for the current task"
]

instance GenerateOptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Computes and returns an optimal motion plan for the crane"
    DTDFVocab:IsAutomatic true
]

instance SimulatedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Simulation service provides predicted crane motion for a given command set"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Validation service detected that fidelity metrics exceed predefined thresholds"
]

instance RaiseValidationAlertAction : DTDFVocab:Action [
    base:desc "Automatically raises an alert to the HMI when validation fails"
    DTDFVocab:IsAutomatic true
]

instance OperatorDecisionInsight : DTDFVocab:Insight [
    base:desc "Operator reviews validation alerts and decides on corrective actions"
]

instance AdjustControlParametersAction : DTDFVocab:Action [
    base:desc "Operator manually adjusts control parameters (e.g., speed limits, swing damping) via the HMI"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application uses the Physical Crane Interface to transmit command messages (velocity/position set‑points, electromagnet activation) to the motor controllers, and the Trajectory Generator Service provides optimal trajectory set‑points that are executed on the crane in real time."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall constellation consists of a physical crane linked via a Python interface to control, logging and HMI applications; virtual services run as Docker containers communicating through MQTT, persisting data in TimescaleDB, and exposing visualisations through Grafana, forming a tightly coupled cyber‑physical loop."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the as‑designed stage (CAD models of the crane in Autodesk Fusion360), the as‑built stage (kinematic model derived from the physical hardware), and the as‑operated stage (real‑time sensor data, logged trajectories and validation results)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by the Continuous Validation Service, which continuously compares measured trajectories with simulated ones using distance metrics and predefined thresholds; violations trigger operator notifications on the dashboard, providing a runtime validation loop."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑component communication uses TCP/IP‑based MQTT (Eclipse Mosquitto) for signaling and PostgreSQL protocol for TimescaleDB access; the Python interfaces exchange JSON‑like messages over the local network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software runs on a single personal computer; the database, MQTT broker and Grafana are containerised with Docker, started via a Docker‑Compose file; the Python modules are installed with pip; the complete repository is hosted publicly on GitHub under an MIT licence."
]