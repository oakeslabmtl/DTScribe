// --------------------------
// Physical sensing components
// --------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder monitoring hoist swing angle"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed impacting the crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// --------------------------
// Data transmitted from physical sensors
// --------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// --------------------------
// Data generated in the digital twin
// --------------------------
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Swing angle sensor reading stream"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo LoggingEnabler, SimulationEnabler, ValidationEnabler, VisualizationEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Wind speed sensor reading stream"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo LoggingEnabler, SimulationEnabler, ValidationEnabler, VisualizationEnabler
]

// --------------------------
// Enablers
// --------------------------
instance LoggingEnabler : DTDFVocab:Enabler [
    base:desc "Python logging application pushing state to TimescaleDB over PostgreSQL"
    DTDFVocab:enables DataLoggingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana reading TimescaleDB for real‑time data visualization via dashboards"
    DTDFVocab:enables RealTimeVizService
]

instance TrajectoryEnabler : DTDFVocab:Enabler [
    base:desc "Python service generating optimal crane trajectories using a kinematic model"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python simulation of crane dynamics modelling the system behaviour"
    DTDFVocab:enables SimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation of executed vs simulated trajectories, generating alerts"
    DTDFVocab:enables ContinuousValidationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Time‑series classification for fault detection in sensor data"
    DTDFVocab:enables FaultDetectionService
]

// --------------------------
// Services
// --------------------------
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs state (positions, velocities, swing angle, wind speed) to TimescaleDB"
    DTDFVocab:provides LoggingInsight
]

instance RealTimeVizService : DTDFVocab:Service [
    base:desc "Real‑time data visualization via Grafana dashboards"
    DTDFVocab:provides VisualizationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal crane trajectories"
    DTDFVocab:provides TrajectoryGenerationOutput
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates crane dynamics"
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed vs simulated trajectories and alerts operators on deviations"
    DTDFVocab:provides ContinuousValidationAlert
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults using time‑series classification"
    DTDFVocab:provides FaultDetectionDiagnostic
]

// --------------------------
// Insights and Actions
// --------------------------
instance LoggingInsight : DTDFVocab:Insight [
    base:desc "Acknowledgement of successful data logging to TimescaleDB"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time dashboard visualisation snapshot"
]

instance TrajectoryGenerationOutput : DTDFVocab:Action [
    base:desc "Provides optimal trajectory for crane motion"
    DTDFVocab:IsAutomatic true
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results of crane dynamics"
]

instance ContinuousValidationAlert : DTDFVocab:Insight [
    base:desc "Alert when trajectory deviation exceeds threshold"
]

instance FaultDetectionDiagnostic : DTDFVocab:Insight [
    base:desc "Diagnostic report of detected faults in sensor data"
]

// --------------------------
// Physical acting components
// --------------------------
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor (TMC4671-Eval) controlled via the Physical Crane Interface"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor (TMC4671-Eval) controlled via the Physical Crane Interface"
]

// --------------------------
// Environment and system under study
// --------------------------
instance LabScaleGantryCrane : DTDFVocab:Environment [
    base:contains CartStepperMotor, HoistStepperMotor, SwingAngleEncoder, Anemometer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory Generator Service produces optimal motion trajectories (no residual swing) and publishes them to a MQTT topic consumed by the Control Application, which sends motor commands to the Physical Crane Interface, thereby actuating the cart and hoist motors."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate continuously during crane operation: the Logging Application writes data in real‑time, validation runs in parallel, and trajectory generation is triggered as needed. No specific sample rates are specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A containerized architecture with six digital twin containers (Database, Dashboard, MQTT Broker, Trajectory Generator, Simulation, Continuous Validation) communicating via MQTT; logging samples from PT pushed to database; trajectory plans published to control interface; validation compares logs with simulations."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design/ideal phase: CAD models and kinematic models; Manufacturing/realization: assembly of hardware and PCB; Operated/field phase: live operation, data collection, validation, and evolution via research studies."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service calculates Euclidean‐distance metrics between logged (actual) and simulated trajectories for both cart position and hoist position. If the distance exceeds a pre‑defined threshold (configurable per experiment), an alert is raised on Grafana. Simulation validates the kinematic model by ensuring that generated trajectories achieve zero residual swing angle at the end point. Fault‑classification models use labelled time‑series from the log database to detect deviations beyond the normal operating envelope."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data flows from the physical crane to the twin via a Python interface that publishes sensor readings to a TimescaleDB database and to MQTT topics; the twin services subscribe to these topics or query the database. Low‑level transmission details are not specified in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All Docker containers (TimescaleDB, Mosquitto, Grafana) and Python modules deployed on a single personal computer; repository hosted on GitHub; docker compose file initializes database and dashboards automatically at first run; documentation and examples provided via MkDocs and GitHub Pages."
]