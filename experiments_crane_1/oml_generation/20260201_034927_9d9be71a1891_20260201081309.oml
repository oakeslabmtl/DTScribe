// C3: Physical sensing components
instance PositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Linear position encoders mounted on the gantry crane trolley provide high‑resolution position feedback."
    DTDFVocab:producedData PositionEncoderDataTransmitted
]

// C4: Physical‑to‑virtual interaction (data transmitted)
instance PositionEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionEncoder
]

// C10: Data (stored in TimescaleDB)
instance CraneTelemetryData : DTDFVocab:Data [
    base:desc "Timestamped position, velocity and command data of the crane trolley generated by the PositionEncoder and logged by the Physical Crane Interface."
    DTDFVocab:fromData PositionEncoderDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler,
                 OptimalControlEngineEnabler,
                 ValidationEngineEnabler,
                 VisualizationEngineEnabler
]

// C11: Enablers (software / platform components)
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source TimescaleDB instance used for time‑series storage of crane telemetry."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance OptimalControlEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python‑based optimal‑control engine running inside a Docker container, computes control commands from live telemetry."
    DTDFVocab:enables OptimalControlService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation engine that compares real‑time telemetry with the kinematic model to compute distance metrics."
    DTDFVocab:enables ContinuousValidationService
]

instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard (deployed via Docker) visualising live crane state and historic logs."
    DTDFVocab:enables DataVisualizationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes optimal control commands that improve the crane’s motion performance."
    DTDFVocab:provides TrajectoryOptimizationInsight,
                 ControlCommandAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Records sensor and command data over time for later analysis."
    DTDFVocab:provides HistoricalPerformanceInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates real‑time sensor measurements against the kinematic model to detect deviations."
    DTDFVocab:provides DeviationDetectionInsight,
                 OperatorNotificationAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Renders the crane state and logged data for human operators via an interactive dashboard."
    DTDFVocab:provides RealTimeVisualizationInsight,
                 OperatorNotificationAction
]

// C17: Insights
instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Provides recommendations for optimal pallet trajectories based on model predictions."
]

instance HistoricalPerformanceInsight : DTDFVocab:Insight [
    base:desc "Enables analysis of past crane motions to identify performance trends and faults."
]

instance DeviationDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects when the actual trajectory deviates beyond a configured threshold from the planned path."
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Shows live crane position, velocity and command signals on the operator dashboard."
]

// C17: Actions
instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Sends computed control commands to the crane controller."
    DTDFVocab:IsAutomatic true
]

instance OperatorNotificationAction : DTDFVocab:Action [
    base:desc "Notifies operators via the dashboard when a validation metric exceeds the threshold."
    DTDFVocab:IsAutomatic false
]

// C2: Acting components (physical actuator)
instance LinearActuator : DTDFVocab:ActingComponent [
    base:desc "Motorized linear actuator that moves the trolley along the gantry rail."
]

// C9: Physical components
instance CraneFrame : DTDFVocab:Component [
    base:desc "Static steel frame of the laboratory‑scale gantry crane."
]

instance CraneTrolley : DTDFVocab:Component [
    base:desc "Mobile trolley that carries the payload and is driven by the LinearActuator."
]

instance CraneController : DTDFVocab:Component [
    base:desc "Embedded controller that receives commands from the OptimalControlEngine and drives the LinearActuator."
]

// C8: Environment
instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains CraneFrame, CraneTrolley, LinearActuator, CraneController, PositionEncoder
]

// C1: Tooling & Enablers (development infrastructure)
instance DockerContainerEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑style containerisation used to package the Python logging app, control engine and visualization stack."
    DTDFVocab:enables OptimalControlEngineEnabler,
                 VisualizationEngineEnabler,
                 HistoricalDataLoggingService,
                 ContinuousValidationService
]

instance PythonLoggingAppEnabler : DTDFVocab:Enabler [
    base:desc "Python program (Physical Crane Interface) that collects encoder data and publishes it to TimescaleDB."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance Fusion360CADModel : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion360 CAD geometry of the crane used to generate the kinematic model."
    DTDFVocab:enables OptimalControlEngineEnabler,
                 ValidationEngineEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the Control Application (a Python program) and passed through the Physical Crane Interface to the crane’s controllers, allowing the operator or automated services to move the crane. The document does not detail command formats, validation, authentication, feedback loops, conflict resolution, or execution acknowledgements."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The lab‑scale gantry crane digital twin follows an ad‑hoc orchestration approach that relies on containerisation (e.g., Docker) for deploying its components. Its architecture is described using the C4 modelling notation, and no commercial digital‑twin framework is employed, implying that integration and coordination of the twin’s services are handled manually within the containerised environment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication is based on an MQTT broker that provides publish/subscribe signaling among the Python services (Trajectory Generator, Simulation, Continuous Validation, Control, Logging). The broker runs as a Docker container on the same PC. The TimescaleDB database and Grafana dashboard are also Dockerized and accessed locally via standard client protocols (SQL over TCP for TimescaleDB, HTTP for Grafana). All containers share a Docker bridge network, resulting in a single‑host, star‑topology where each service connects to the MQTT broker and database. No bandwidth, latency, redundancy, or security protocol details are provided in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software components run on a single personal computer (edge/on‑premise). The Database, MQTT Broker, and Grafana Dashboard are packaged as Docker containers and started together with a Docker‑Compose file, providing a lightweight, reproducible deployment. Computational resources are those required to run Python applications, TimescaleDB, and Grafana; storage is provided by the TimescaleDB instance. The document mentions containerisation for ease of deployment but does not detail scaling beyond Docker‑Compose, nor any cloud or high‑availability setups."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin’s architecture is described using the **C4 Model**, a recognized standard for software architecture documentation. Additionally, the repository contains **Arcadia** models created with **Capella**, conforming to the Arcadia MBSE methodology. Employing these standardized modelling approaches facilitates interoperability with other model‑based engineering tools and supports traceability across the development lifecycle."
]