// Acting Components
instance CartMotor : DTDFVocab:ActingComponent [
    base:desc "Horizontal linear motor driven by Trinamic TMC4671‑Eval motor controller, commanded by a Python interface."
]
instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Vertical lift motor driven by Trinamic TMC4671‑Eval motor controller, commanded by a Python interface."
]
instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted at hoist end that can pick up or release containers."
]

// Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder measuring pendulum motion of the crane."
    DTDFVocab:producedData SwingAngleDataTransmitted
]
instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the gantry."
    DTDFVocab:producedData AnemometerDataTransmitted
]
instance CartPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder for the horizontal cart position."
    DTDFVocab:producedData CartPositionDataTransmitted
]
instance HoistPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder for the vertical hoist position."
    DTDFVocab:producedData HoistPositionDataTransmitted
]
instance CartMotorVoltageSensor : DTDFVocab:SensingComponent [
    base:desc "Voltage sensor for the cart motor."
    DTDFVocab:producedData CartMotorVoltageDataTransmitted
]
instance CartMotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor for the cart motor."
    DTDFVocab:producedData CartMotorCurrentDataTransmitted
]
instance HoistMotorVoltageSensor : DTDFVocab:SensingComponent [
    base:desc "Voltage sensor for the hoist motor."
    DTDFVocab:producedData HoistMotorVoltageDataTransmitted
]
instance HoistMotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor for the hoist motor."
    DTDFVocab:producedData HoistMotorCurrentDataTransmitted
]

// Data Transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]
instance CartPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartPositionEncoder
]
instance HoistPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistPositionEncoder
]
instance CartMotorVoltageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorVoltageSensor
]
instance CartMotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorCurrentSensor
]
instance HoistMotorVoltageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorVoltageSensor
]
instance HoistMotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorCurrentSensor
]

// Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "High‑frequency time‑series of swing angle measurements."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance AnemometerData : DTDFVocab:Data [
    base:desc "High‑frequency time‑series of wind speed measurements."
    DTDFVocab:fromData AnemometerDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance CartPositionData : DTDFVocab:Data [
    base:desc "High‑frequency time‑series of cart position measurements."
    DTDFVocab:fromData CartPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance HoistPositionData : DTDFVocab:Data [
    base:desc "High‑frequency time‑series of hoist position measurements."
    DTDFVocab:fromData HoistPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance CartMotorVoltageData : DTDFVocab:Data [
    base:desc "High‑frequency time‑series of cart motor voltage."
    DTDFVocab:fromData CartMotorVoltageDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance CartMotorCurrentData : DTDFVocab:Data [
    base:desc "High‑frequency time‑series of cart motor current."
    DTDFVocab:fromData CartMotorCurrentDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance HoistMotorVoltageData : DTDFVocab:Data [
    base:desc "High‑frequency time‑series of hoist motor voltage."
    DTDFVocab:fromData HoistMotorVoltageDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance HoistMotorCurrentData : DTDFVocab:Data [
    base:desc "High‑frequency time‑series of hoist motor current."
    DTDFVocab:fromData HoistMotorCurrentDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance for real‑time high‑frequency data logging."
    DTDFVocab:enables LoggingService
]
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service messaging."
    DTDFVocab:enables LoggingService, DashboardService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]
instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana instance for visualization of logged data and system insights."
    DTDFVocab:enables DashboardService
]
instance KinematicModelEnabler : DTDFVocab:Enabler [
    base:desc "Analytical kinematic model used by the trajectory generator."
    DTDFVocab:enables TrajectoryGeneratorService
]
instance SimulationModelEnabler : DTDFVocab:Enabler [
    base:desc "Discrete‑time simulation model reproducing the crane’s dynamic response."
    DTDFVocab:enables SimulationService
]

// Insights
instance EventPublishing : DTDFVocab:Insight [
    base:desc "Publishes sensor data events on MQTT topics."
]
instance TrajectoryPlotInsight : DTDFVocab:Insight [
    base:desc "Visual representation of planned and executed trajectories with simulation confidence bounds."
]
instance SwingWindOverlayInsight : DTDFVocab:Insight [
    base:desc "Overlay of real‑time swing‑angle measurements and wind speed on trajectory plots."
]
instance FaultAlertTableInsight : DTDFVocab:Insight [
    base:desc "Table of classified faults and corresponding alerts."
]
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of deviations between executed and simulated trajectories."
]
instance TrajectoryPlanningInsight : DTDFVocab:Insight [
    base:desc "Optimized trajectory plans generated by the kinematic model."
]
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation outputs of crane dynamics for planned trajectories."
]

// Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Logs high‑frequency sensor data to TimescaleDB and publishes events on MQTT topics."
    DTDFVocab:provides EventPublishing
]
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes optimal trajectories using the crane’s kinematic model."
    DTDFVocab:provides TrajectoryPlanningInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates crane response to planned trajectories using a discrete‑time model."
    DTDFVocab:provides SimulationResultInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates executed trajectories against simulated ones and triggers alerts when deviation exceeds threshold."
    DTDFVocab:provides FaultDetectionInsight, MaintenanceSchedulingAction
]
instance DashboardService : DTDFVocab:Service [
    base:desc "Provides real‑time dashboards with trajectory plots, swing‑angle and wind‑speed overlays, and fault‑alert tables."
    DTDFVocab:provides TrajectoryPlotInsight, SwingWindOverlayInsight, FaultAlertTableInsight, TrajectoryAdjustmentAction, GripperOperationAction
]

// Actions
instance MaintenanceSchedulingAction : DTDFVocab:Action [
    base:desc "Schedules maintenance activities based on fault categorization and deviation metrics."
    DTDFVocab:IsAutomatic true
]
instance TrajectoryAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjusts planned trajectory parameters in response to real‑time swing or wind conditions."
    DTDFVocab:IsAutomatic true
]
instance GripperOperationAction : DTDFVocab:Action [
    base:desc "Controls the electromagnet to pick up or release containers."
    DTDFVocab:IsAutomatic false
]

// Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains CartMotor, HoistMotor, Electromagnet, SwingAngleEncoder, Anemometer, CartPositionEncoder, HoistPositionEncoder, CartMotorVoltageSensor, CartMotorCurrentSensor, HoistMotorVoltageSensor, HoistMotorCurrentSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The trajectory‑generator service produces optimal joint trajectories; the control application subscribes to these trajectories and translates them into motor step pulses sent to the motor drivers via the Python interface; the continuous‑validation service publishes alerts to the Grafana dashboard when measurement‑simulation divergence exceeds a predefined threshold; the operator can manually issue override commands through the GUI that are routed back to the control application."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time operation: services run concurrently as the crane moves, trajectory generation and validation occur in sync with the moves, and logging updates the database continuously."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A Docker‑Compose orchestrated stack consisting of the physical crane (Python interface and Arduino), the twin’s database, MQTT broker, dashboard, trajectory generator, simulation, and continuous validation services, all connected via a local network and sharing the same data store."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design‑phase: CAD models in Autodesk Fusion360 and kinematic model in the Trajectory Generator; Manufacturing‑phase: physical Arduino, motor drivers, encoders, electromagnet, shuttle assembly; Operation‑phase: runtime state logging, real‑time trajectory execution, continuous validation and fault detection; each phase is represented in the twin through either static models or dynamic data streams."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation is achieved by continuously comparing executed trajectory data with the simulation model using distance metrics; alerts trigger when deviations exceed predefined thresholds, ensuring that the twin’s representation remains valid; the simulation’s fidelity depends on the accuracy of the kinematic model and sensor calibration."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The twin employs MQTT (Eclipse Mosquitto) for service‑to‑service messaging, TimescaleDB (PostgreSQL) for storing time‑series data, and a serial/USB connection between the Python control interface and the Arduino; all services communicate over Docker networking on a single host."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin components are containerised and deployed via Docker Compose on a single Linux workstation; database and dashboard volumes persist data, and the physical interface runs directly on the host, with the Arduino connected over USB."
]