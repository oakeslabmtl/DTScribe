// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart motor step‑stepper motor driven by a TMC4671‑Eval controller."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist motor step‑stepper motor driven by a TMC4671‑Eval controller."
]

instance ElectromagnetSet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet set powered by a custom Arduino shield that manages activation and readouts."
]

// C3: Physical sensing components
instance SwingAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring the hoist swing."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder position sensor for the cart stepper motor."
    DTDFVocab:producedData CartMotorPositionDataTransmitted
]

instance HoistMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder position sensor for the hoist stepper motor."
    DTDFVocab:producedData HoistMotorPositionDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleSensor
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance CartMotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoder
]

instance HoistMotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoder
]

// C10: Models/Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Swing‑angle measurements stored in TimescaleDB."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBStorage
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Wind‑speed measurements stored in TimescaleDB."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBStorage
]

instance CartMotorPositionData : DTDFVocab:Data [
    base:desc "Cart motor position stored in TimescaleDB."
    DTDFVocab:fromData CartMotorPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBStorage
]

instance HoistMotorPositionData : DTDFVocab:Data [
    base:desc "Hoist motor position stored in TimescaleDB."
    DTDFVocab:fromData HoistMotorPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBStorage
]

// C11: Enablers
instance GantryLibModule : DTDFVocab:Enabler [
    base:desc "Python gantrylib module used for trajectory generation, simulation, continuous validation, and fault detection."
    DTDFVocab:enables TrajectoryGenerationService, SimulationService, ContinuousValidationService, FaultDetectionService
]

instance DockerContainerization : DTDFVocab:Enabler [
    base:desc "Docker used to containerize each microservice."
]

instance DockerComposeOrchestration : DTDFVocab:Enabler [
    base:desc "Docker Compose orchestrates the hub structure of the microservices."
    DTDFVocab:enables DataLoggingService, TrajectoryGenerationService, SimulationService, ContinuousValidationService, FaultDetectionService, MQTTSignalingService
]

instance TimescaleDBStorage : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance for time-series storage of sensor readings."
    DTDFVocab:enables DataLoggingService
]

instance MosquittoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker enabling inter-service communication."
    DTDFVocab:enables MQTTSignalingService
]

instance ArduinoInterface : DTDFVocab:Enabler [
    base:desc "Custom Arduino shield for interfacing with the physical system."
]

instance KiCadDesign : DTDFVocab:Enabler [
    base:desc "KiCad used for custom shield design."
]

instance GitHubRepository : DTDFVocab:Enabler [
    base:desc "GitHub repository hosts the code and models."
]

instance MkDocsDocumentation : DTDFVocab:Enabler [
    base:desc "MkDocs generates documentation for the twin."
]

instance CapellaModelTool : DTDFVocab:Enabler [
    base:desc "Capella Arcadia used for modelling the system behaviour."
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuous data logging application storing sensor readings."
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Optimal trajectory generation with zero‑swing algorithm."
    DTDFVocab:provides OptimalTrajectorySuggestion, AdjustTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "High‑fidelity simulation of the crane and its controllers."
    DTDFVocab:provides PerformanceMetricsInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation comparing real execution to simulation with distance metrics and thresholds."
    DTDFVocab:provides RealTimeTrajectoryDeviationAlert
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection through time-series classification."
    DTDFVocab:provides FaultClassificationInsight, ResetFaultAction
]

instance MQTTSignalingService : DTDFVocab:Service [
    base:desc "MQTT-based signaling infrastructure for inter-service communication."
]

// C17: Insights/Actions
instance RealTimeTrajectoryDeviationAlert : DTDFVocab:Insight [
    base:desc "Real‑time alerts for trajectory deviations."
]

instance FaultClassificationInsight : DTDFVocab:Insight [
    base:desc "Fault detection via time-series classification."
]

instance OptimalTrajectorySuggestion : DTDFVocab:Insight [
    base:desc "Optimal trajectory suggestions."
]

instance PerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Performance metrics plotted in Grafana."
]

instance AdjustTrajectoryAction : DTDFVocab:Action [
    base:desc "Operator can adjust trajectory parameters."
    DTDFVocab:IsAutomatic false
]

instance ResetFaultAction : DTDFVocab:Action [
    base:desc "Operator can reset fault state."
    DTDFVocab:IsAutomatic false
]

// C10 (additional): Environment
instance LabScaleGanRidgeCraneEnvironment : DTDFVocab:Environment [
    base:desc "Lab‑scale gantry crane system comprising cart and hoist motors, electromagnet, swing‑angle sensor, wind‑speed anemometer, motor encoders, Arduino interface, TMC4671Eval controllers, custom shield, PSU, and PC."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin’s Trajectory Generator Service computes optimal, swing‑free motion trajectories and forwards them to the Control Application. The Control Application sends motor commands to the Physical Crane Interface, which transmits them to the TMC4671‑Eval controllers and the electromagnet driver on the physical crane."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in real‑time, processing data as it streams from the physical system. The Logging Application writes sensor data continuously, the Trajectory Generator schedules new trajectories on demand, and the Continuous Validation Service evaluates the executed trajectory immediately after completion. The infrastructure is designed for continuous, low‑latency interaction, although explicit timing specifications are not given in the documentation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated by a Docker‑Compose stack on a single workstation; services communicate over local network via MQTT; data flows from sensors to database, visualized in Grafana; trajectory generation and simulation run within dedicated containers receiving state from the database and publishing results back to the broker."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The exemplar covers the design stage with CAD models (Autodesk Fusion360) and Arcadia/Capella models, the manufacturing stage where the physical crane is built from the BOM, and the operation stage where the system runs in real‑time for research or teaching. It is regularly updated for research papers and educational modules, reflecting iterative development and evolution."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service compares measured versus simulated trajectory positions using distance metrics; a user‑defined threshold triggers alerts if limits are breached. Simulation provides confidence bounds plotted against real traces. Validation relies on consistent sensor data and accurate kinematic modelling; no explicit uncertainty quantification is reported but threshold‑based checks serve as a pragmatic validation mechanism."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual communication occurs via the Arduino (likely USB/serial) to the Physical Crane Interface and then to the Logging Application, which writes to TimescaleDB. Virtual‑to‑physical actions are transmitted via the Physical Crane Interface to the Arduino, which drives the TMC4671‑Eval controllers. Inter‑service communication within the twin uses MQTT over a local network. All components run on a single PC with Docker networking."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire twin stack is deployed locally on a Linux PC using Docker and Docker Compose. The database, MQTT broker, Grafana, and all Python services are containerized. Source code and container images are available on GitHub, and the twin can be brought up with a single compose command. The system is distributed under the MIT license."
]