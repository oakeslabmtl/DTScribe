// Environment containing all physical components
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains SwingAngleEncoder, AnemometerWindSpeed, CartMotorEncoderFeedback, HoistMotorEncoderFeedback, ArduinoMeasurementBoard,
              CartMotorController, HoistMotorController, ElectromagnetAtHoistBase
]

// Acting Components
instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "Cart motor controller (TMC4671–Eval) commanded by the digital twin via the Physical Crane Interface"
]
instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "Hoist motor controller (TMC4671–Eval) commanded by the digital twin via the Physical Crane Interface"
]
instance ElectromagnetAtHoistBase : DTDFVocab:ActingComponent [
    base:desc "Electromagnet positioned at the hoist base, controlled by the digital twin"
]

// Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder monitoring the crane's swing motion"
    DTDFVocab:producedData SwingAngleDataTransmitted
]
instance AnemometerWindSpeed : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed acting on the crane structure"
    DTDFVocab:producedData AnemometerWindSpeedDataTransmitted
]
instance CartMotorEncoderFeedback : DTDFVocab:SensingComponent [
    base:desc "Motor encoder feedback for the cart motor, accessed via the controller"
    DTDFVocab:producedData CartMotorEncoderDataTransmitted
]
instance HoistMotorEncoderFeedback : DTDFVocab:SensingComponent [
    base:desc "Motor encoder feedback for the hoist motor, accessed via the controller"
    DTDFVocab:producedData HoistMotorEncoderDataTransmitted
]
instance ArduinoMeasurementBoard : DTDFVocab:SensingComponent [
    base:desc "Arduino measurement board reading additional sensor data and feeding the logging pipeline"
    DTDFVocab:producedData ArduinoAdditionalSensorDataTransmitted
]

// DataTransmitted for sensors
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance AnemometerWindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerWindSpeed
]
instance CartMotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoderFeedback
]
instance HoistMotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoderFeedback
]
instance ArduinoAdditionalSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoMeasurementBoard
]

// Models
instance CADModelFusion360 : DTDFVocab:Model [
    base:desc "CAD model of the crane produced in Autodesk Fusion 360"
    DTDFVocab:inputTo TimescaleDBContainerEnabler
]
instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Deterministic kinematic model generating swing‑free trajectory plans"
    DTDFVocab:inputTo TrajectoryGeneratorContainerEnabler
]
instance MotorDynamicsSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of motor dynamics and controllers"
    DTDFVocab:inputTo SimulationContainerEnabler
]

// DataTransmitted for model outputs
instance KinematicModelOutputTransmitted : DTDFVocab:DataTransmitted [
    // producedFrom removed to avoid type mismatch
]
instance SimulationModelOutputTransmitted : DTDFVocab:DataTransmitted [
    // producedFrom removed to avoid type mismatch
]

// Data instances for model outputs
instance TrajectoryPlanData : DTDFVocab:Data [
    base:desc "Computed trajectory plan for swing‑free crane motion"
    DTDFVocab:fromData KinematicModelOutputTransmitted
    DTDFVocab:inputTo TrajectoryGeneratorContainerEnabler
]
instance SimulationResultData : DTDFVocab:Data [
    base:desc "Simulation result of crane motion and controller behavior"
    DTDFVocab:fromData SimulationModelOutputTransmitted
    DTDFVocab:inputTo SimulationContainerEnabler
]

// Enablers
instance TimescaleDBContainerEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB Docker container enabling data logging and validation"
    DTDFVocab:enables DataLoggingService, ContinuousValidationService
]
instance MQTTBrokerContainerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker Docker container"
    DTDFVocab:enables MQTTBrokerService, ContinuousValidationService
]
instance TrajectoryGeneratorContainerEnabler : DTDFVocab:Enabler [
    base:desc "Trajectory generator Docker container enabled by the kinematic model"
    DTDFVocab:enables OptimalTrajectoryGenerationService
]
instance SimulationContainerEnabler : DTDFVocab:Enabler [
    base:desc "Simulation container Docker enabling the simulation service"
    DTDFVocab:enables SimulationService
]
instance GrafanaContainerEnabler : DTDFVocab:Enabler [
    base:desc "Grafana Docker container for dashboard visualization"
    DTDFVocab:enables DataVisualizationService
]

// Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuous time‑series capture of sensor data and recording into TimescaleDB"
    DTDFVocab:provides DataLoggedInsight
]
instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboards for real‑time visualization of crane telemetry"
    DTDFVocab:provides DashboardViewInsight
]
instance OptimalTrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal, swing‑free trajectory plans using the kinematic model"
    DTDFVocab:provides TrajectoryPlanInsight, PlanTrajectoryAction
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates crane motions and controller behavior using the motor dynamics model"
    DTDFVocab:provides SimulatedMotionInsight, RunSimulationAction
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares real sensor logs from TimescaleDB with simulated data via MQTT to compute residuals and detect deviations beyond thresholds"
    DTDFVocab:provides DeviationDetectedInsight, GenerateAlertAction
]
instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Eclipse Mosquitto broker handling inter‑service MQTT communication"
    DTDFVocab:provides MQTTCommunicationInsight
]

// Insights
instance DataLoggedInsight : DTDFVocab:Insight [
    base:desc "Observation that sensor data has been logged into TimescaleDB"
]
instance DashboardViewInsight : DTDFVocab:Insight [
    base:desc "Real‑time dashboard view of crane telemetry is available"
]
instance TrajectoryPlanInsight : DTDFVocab:Insight [
    base:desc "Generated swing‑free trajectory plan for the crane"
]
instance SimulatedMotionInsight : DTDFVocab:Insight [
    base:desc "Simulated motion matches the kinematic expectations"
]
instance DeviationDetectedInsight : DTDFVocab:Insight [
    base:desc "Deviations between real and simulated motion exceed defined thresholds"
]
instance MQTTCommunicationInsight : DTDFVocab:Insight [
    base:desc "MQTT broker facilitates inter‑service communication"
]

// Actions
instance PlanTrajectoryAction : DTDFVocab:Action [
    base:desc "Plan and command the optimal trajectory to the digital twin"
    DTDFVocab:IsAutomatic true
]
instance RunSimulationAction : DTDFVocab:Action [
    base:desc "Execute simulation of crane dynamics and controllers"
    DTDFVocab:IsAutomatic true
]
instance GenerateAlertAction : DTDFVocab:Action [
    base:desc "Generate an alert when deviations are detected during continuous validation"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control Application and Trajectory‑Generator Service compute desired motor trajectories and issue actuation commands through the Physical Crane Interface, which translates these commands into the cranes’ motor‑controller protocols to drive the cart, hoist and electromagnet."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation: sensor data are streamed continuously, trajectory generation and control commands are issued per command, and validation runs concurrently – thresholds are checked immediately as new data arrive; explicit latency figures are not reported"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Docker‑Compose orchestrated cluster containing TimescaleDB, Mosquitto, Grafana, Trajectory Generator Service, Simulation Service, Continuous Validation Service, all connected via a private network; the physical system connects through the Physical Crane Interface to controllers and sensors"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design phase (CAD drawings, kinematic model), manufacturing phase (construction of the physical crane), operational phase (real‑time logging, continuous validation, fault detection); the exemplar is also used for education and research extensions"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous validation compares measured trajectories to simulated ones using distance metrics and thresholds for residual swing; fault classification uses time‑series methods; model validation relies on logged data but explicit accuracy metrics or formal verification are not specified"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Physical Crane is physically plugged into a PC (USB/serial not specified); the Python interface uses a USB serial connection to the Arduino; the twin’s services communicate over a local MQTT broker and a TimescaleDB PostgreSQL instance; inter‑service data exchange uses JSON over MQTT and SQL queries."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Local deployment on a personal computer; all services launched via Docker Compose; Python services packaged as gantrylib module retrievable by pip; no cloud hosting is described"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "No reported integration with external systems or other digital twins; the exemplar remains self‑contained"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Uses open‑source tools; MQTT is a standard messaging protocol, TimescaleDB extends PostgreSQL (SQL standard); no industrial twin standards such as OPC‑UA or DDS are employed"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "No explicit safety or security measures are documented; deployment is local with no TLS on MQTT and no remote execution safeguards"
]