// ---------- Sensing Components ----------
instance SwingAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder that reports the lateral angle of the hoist"
    DTDFVocab:producedData SwingAngleEncodedDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer that measures wind speed near the crane"
    DTDFVocab:producedData AnemometerEncodedDataTransmitted
]

// ---------- Data Transmitted ----------
instance SwingAngleEncodedDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Data transmitted by the swing angle encoder"
    DTDFVocab:producedFrom SwingAngleEncoderSensor
]

instance AnemometerEncodedDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Data transmitted by the anemometer"
    DTDFVocab:producedFrom AnemometerSensor
]

// ---------- Data ----------
instance SwingAngleTelemetryDataForValidation : DTDFVocab:Data [
    base:desc "Swing angle telemetry data for real‑time validation"
    DTDFVocab:fromData SwingAngleEncodedDataTransmitted
    DTDFVocab:inputTo PythonGantryLibEnabler
]

instance SwingAngleTelemetryDataForLogging : DTDFVocab:Data [
    base:desc "Swing angle telemetry data for historical logging"
    DTDFVocab:fromData SwingAngleEncodedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance AnemometerTelemetryDataForDashboard : DTDFVocab:Data [
    base:desc "Anemometer telemetry data for dashboard display"
    DTDFVocab:fromData AnemometerEncodedDataTransmitted
    DTDFVocab:inputTo GrafanaEnabler
]

instance AnemometerTelemetryDataForLogging : DTDFVocab:Data [
    base:desc "Anemometer telemetry data for historical logging"
    DTDFVocab:fromData AnemometerEncodedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// ---------- Acting Components ----------
instance CartStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Single‑axis cart motor driven by a stepper motor, controlled by a TMC4671‑Eval board"
]

instance HoistStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Hoist motor driven by a stepper motor, controlled by a TMC4671‑Eval board"
]

// ---------- Environment and Physical Components ----------
instance HorizontalRailComponent : DTDFVocab:Component [
    base:desc "Horizontal rail of the gantry crane"
]

instance VerticalElevatorArmComponent : DTDFVocab:Component [
    base:desc "Vertical elevator arm of the gantry crane"
]

instance TrolleyCarriageComponent : DTDFVocab:Component [
    base:desc "Trolley carriage moving along the horizontal rail"
]

instance IntegratedControllerComponent : DTDFVocab:Component [
    base:desc "Integrated controller module that coordinates the crane’s actuators"
]

instance LabScaleGantryEnvironment : DTDFVocab:Environment [
    base:contains HorizontalRailComponent, VerticalElevatorArmComponent, TrolleyCarriageComponent, IntegratedControllerComponent
]

// ---------- Models ----------
instance CADModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane generated in Autodesk Fusion 360"
    DTDFVocab:inputTo CADModelEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model describing the crane’s motion constraints"
    DTDFVocab:inputTo KinematicModelEnabler
]

// ---------- Enablers ----------
instance PythonGantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib – a lightweight Python library that implements the gantry’s kinematic equations"
    DTDFVocab:enables ContinuousValidationService, SimulationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB – time‑series database that stores the logged telemetry"
    DTDFVocab:enables LoggingService
]

instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB – time‑series database storing the path cost matrix for trajectory optimization"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance MosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto – MQTT broker that mediates bi‑directional data exchange"
    DTDFVocab:enables ContinuousValidationService, SimulationService, DashboardService, TrajectoryGeneratorService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana – open‑source visualization tool that renders live and historical data"
    DTDFVocab:enables DashboardService
]

instance KinematicModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that supplies the kinematic model to the Simulation Service"
    DTDFVocab:enables SimulationService
]

instance CADModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that supplies the CAD model to the Simulation Service"
    DTDFVocab:enables SimulationService
]

// ---------- Services ----------
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Trajectory Generator Service that computes optimal pick‑and‑place paths for the gantry crane"
    DTDFVocab:provides TrajectoryPlanInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous Validation Service that performs real‑time kinematic simulation and monitors safety metrics"
    DTDFVocab:provides ValidationAlertInsight
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Dashboard micro‑frontend that aggregates metrics and presents live heatmaps and KPIs over HTTPS"
    DTDFVocab:provides DashboardInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation Service that executes simulator‑based runs of the kinematic model"
    DTDFVocab:provides SimulationResultInsight
]

instance LoggingService : DTDFVocab:Service [
    base:desc "Historical data logging service that records sensor streams and actuator states"
    DTDFVocab:provides HistoricalTelemetryInsight
]

// ---------- Insights ----------
instance TrajectoryPlanInsight : DTDFVocab:Insight [
    base:desc "Insight that provides an optimal pick‑and‑place trajectory plan for the gantry crane"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Insight alerting operators when safety thresholds are breached during operation"
]

instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Insight displaying live heatmaps and key performance indicators for the gantry crane"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight providing simulation outputs of the crane’s kinematic model"
]

instance HistoricalTelemetryInsight : DTDFVocab:Insight [
    base:desc "Insight enabling post‑hoc analysis of historical telemetry data"
]

// ---------- Actions ----------
instance ReevaluateStagingAction : DTDFVocab:Action [
    base:desc "Action prompting operators to re‑evaluate staging or abort the operation when validation thresholds are breached"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, which sits in the digital twin, issues movement commands to the Physical Crane Interface. These commands (derived from trajectories generated by the Trajectory Generator Service) are sent to the crane controllers to execute movements. The document does not specify the message format, validation steps, or acknowledgement mechanisms used beyond the fact that the Control Application depends on the interface to communicate with the hardware."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "GreenhouseDT adopts an ad‑hoc microservice architecture, where the digital twin logic and the data collection pipeline are hosted on a set of virtual machines. Within each VM, distinct components—the InfluxDB time‑series database, an ActiveMQ broker, and a data ingestion service—are launched as separate processes. Communication between the greenhouse physical plant and the twin is carried out via ActiveMQ topics that carry sensor readings cast into JSON messages. The ingestion service subscribes to these topics, writes the data to InfluxDB, and triggers the behavioral adaptation logic that times the greenhouse control loops. The entire stack is bootstrapped using a simple shell script that pulls the VM images, installs the required packages, and starts the services in order. Resource constraints are enforced at the VM level (e.g., 2 vCPU, 4 GiB RAM per VM), and each component uses a dedicated port to avoid conflicts. Because the exemplar is intentionally ad‑hoc, there is no central orchestrator beyond the VM bootstrap script, and all coordination is via the publish/subscribe mechanism provided by ActiveMQ."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service continuously compares in‑field measurements of executed trajectories with simulated trajectories, calculating a spatial distance metric between the two. Deviations that exceed a pre‑defined tolerance trigger alerts, enabling self‑adaptation of the digital twin. The service performs on‑line checks at regular intervals, ensuring that the digital twin remains a faithful representation of the physical system during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin is performed via an MQTT broker, which provides a lightweight publish/subscribe channel for signaling among the Trajectory Generator Service, Simulation Service, Continuous Validation Service, Logging Application, and Dashboard. The document does not describe additional network topology, bandwidth or latency requirements, or the physical communication protocols used between the crane hardware and the Physical Crane Interface."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The complete system is deployed on an on‑premises edge PC that interfaces directly with the physical crane. The TimescaleDB, MQTT broker, and Grafana dashboard are docker‑containerized and orchestrated via docker‑compose. The Python services – Control Application, Trajectory Generator Service, Simulation Service, Continuous Validation Service, Logging Application – are distributed as a single Python package ('gantrylib') and run natively on the host. The deployment model supports local scaling through container replication, but explicit computational, storage, or reliability guarantees are not specified."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The system’s integration points are local: sensor data from the greenhouse plant is transmitted over the network to the ActiveMQ broker; the broker forwards JSON messages to the ingestion service on the same VM. InfluxDB remains the sole downstream persistence engine. For external visibility, a lightweight HTTP API exposed by the ingestion service allows dashboards or external analytics tools to query data from InfluxDB via the InfluxDB line protocol. No other enterprise systems such as cloud services or standards are used in this exemplar."
]