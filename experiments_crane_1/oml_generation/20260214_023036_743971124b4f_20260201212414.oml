instance CraneMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Closed-loop electric motor with PID controller for precise position and velocity control of the gantry crane mechanism."
]

instance CraneHookMechanism : DTDFVocab:ActingComponent [
    base:desc "Electromagnetic hook system with position feedback for payload engagement and release operations."
]

// C1: Environment
instance CraneLaboratoryEnvironment : DTDFVocab:Environment [
    base:desc "Controlled laboratory setting with temperature/humidity regulation, vibration isolation, and electromagnetic shielding."
    base:contains CranePhysicalSystem
]

instance CranePhysicalSystem : DTDFVocab:Component [
    base:desc "Lab-scale gantry crane system including mechanical structure, electric motors, sensors, and embedded controller."
    base:isContainedIn CraneLaboratoryEnvironment
]

// C12: Data Transmission Protocols
instance MQTTProtocol : DTDFVocab:Component [
    base:desc "MQTT broker facilitating bidirectional communication between physical crane components and digital twin services with QoS level 2."
    base:isContainedIn CranePhysicalSystem
]

instance OPCUAProtocol : DTDFVocab:Component [
    base:desc "OPC UA server enabling standardized industrial communication between crane controllers and digital twin services."
    base:isContainedIn CranePhysicalSystem
]

