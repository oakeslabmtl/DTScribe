// C3: Physical Sensing Components
instance CranePositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution encoder measuring the gantry crane's linear position with sub-millimeter precision for real-time kinematic tracking."
    DTDFVocab:producedData CranePositionDataTransmitted
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Tachometer-based sensor measuring the crane's velocity profile with 100Hz sampling rate for dynamic response analysis."
    DTDFVocab:producedData CraneVelocityDataTransmitted
]

instance CraneAccelerometer : DTDFVocab:SensingComponent [
    base:desc "3-axis accelerometer measuring structural dynamics and payload disturbances with 1kHz sampling for fault detection analysis."
    DTDFVocab:producedData CraneAccelerationDataTransmitted
]

instance CraneLoadCell : DTDFVocab:SensingComponent [
    base:desc "Strain gauge load cell measuring payload weight with 0.1% accuracy for dynamic load validation during operations."
    DTDFVocab:producedData CraneLoadDataTransmitted
]

instance CraneControllerStatus : DTDFVocab:SensingComponent [
    base:desc "Embedded controller status sensor providing real-time feedback on control algorithm execution, error states, and operational mode."
    DTDFVocab:producedData ControllerStatusDataTransmitted
]

// C4: Physical-to-Virtual Data Transmission
instance CranePositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionEncoder
]

instance CraneVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocitySensor
]

instance CraneAccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneAccelerometer
]

instance CraneLoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneLoadCell
]

instance ControllerStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneControllerStatus
]

// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Forward/inverse kinematic model implemented in Python using SymPy library, representing the 2D/3D crane geometry with joint constraints and payload dynamics."
    DTDFVocab:inputTo CraneKinematicSimulationEnabler
    DTDFVocab:inputTo RealTimeValidationEnabler
    base:isContainedIn CranePhysicalSystem
]

instance CraneDynamicModel : DTDFVocab:Model [
    base:desc "Physics-based dynamic model simulating crane motion under payload variations, wind disturbances, and structural flexibility using SciPy ODE solvers."
    DTDFVocab:inputTo CraneSimulationEnabler
    DTDFVocab:inputTo FaultDetectionEnabler
    base:isContainedIn CranePhysicalSystem
]

instance CraneControlAlgorithmModel : DTDFVocab:Model [
    base:desc "Model predictive control (MPC) algorithm implemented in MATLAB/Simulink with reinforcement learning adaptation layer for real-time trajectory optimization."
    DTDFVocab:inputTo OptimalControlEnabler
    DTDFVocab:inputTo HumanInTheLoopEnabler
    base:isContainedIn CranePhysicalSystem
]

instance CraneHistoricalData : DTDFVocab:Data [
    base:desc "Time-series database storing crane operational logs including position, velocity, torque, and control commands with 1ms timestamp resolution in TimescaleDB."
    DTDFVocab:fromData CranePositionDataTransmitted
    DTDFVocab:fromData CraneVelocityDataTransmitted
    DTDFVocab:fromData CraneAccelerationDataTransmitted
    DTDFVocab:fromData CraneLoadDataTransmitted
    DTDFVocab:fromData ControllerStatusDataTransmitted
    DTDFVocab:inputTo PerformanceAnalysisEnabler
    DTDFVocab:inputTo FaultDetectionEnabler
    base:isContainedIn CranePhysicalSystem
]

instance RealTimeCraneStateData : DTDFVocab:Data [
    base:desc "Fused sensor data stream combining encoder positions, accelerometer readings, and load cell measurements with Kalman filter-based state estimation."
    DTDFVocab:fromData CranePositionDataTransmitted
    DTDFVocab:fromData CraneVelocityDataTransmitted
    DTDFVocab:fromData CraneAccelerationDataTransmitted
    DTDFVocab:fromData CraneLoadDataTransmitted
    DTDFVocab:inputTo RealTimeValidationEnabler
    DTDFVocab:inputTo VisualizationEnabler
    base:isContainedIn CranePhysicalSystem
]

// C11: Enablers
instance CraneKinematicSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python-based kinematic simulation engine using SciPy for forward/inverse kinematics calculations with 10μs latency for real-time validation."
    DTDFVocab:enables KinematicVisualizationService
    DTDFVocab:enables TrajectoryComparisonService
    base:isContainedIn CranePhysicalSystem
]

instance CraneSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Gazebo-based physics simulation environment with ROS integration for off-line testing of crane dynamics under various failure scenarios."
    DTDFVocab:enables FailureScenarioSimulationService
    DTDFVocab:enables RobustnessAnalysisService
    base:isContainedIn CranePhysicalSystem
]

instance RealTimeValidationEnabler : DTDFVocab:Enabler [
    base:desc "Custom Python implementation of residual analysis and statistical process control (SPC) for real-time validation with 100ms latency."
    DTDFVocab:enables ContinuousValidationService
    DTDFVocab:enables FaultDetectionService
    base:isContainedIn CranePhysicalSystem
]

instance OptimalControlEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink implementation of model predictive control (MPC) with reinforcement learning adaptation for energy-efficient trajectory optimization."
    DTDFVocab:enables RealTimeTrajectoryOptimizationService
    DTDFVocab:enables AdaptiveControlFeedbackService
    base:isContainedIn CranePhysicalSystem
]

instance HumanInTheLoopEnabler : DTDFVocab:Enabler [
    base:desc "Python-based human-in-the-loop validation interface with 50Hz refresh rate for operator-controlled testing of advanced control algorithms."
    DTDFVocab:enables HumanInTheLoopValidationService
    base:isContainedIn CranePhysicalSystem
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB App Designer interface for 3D/2D kinematic visualization with overlay of physical vs. digital twin trajectories."
    DTDFVocab:enables CraneStateVisualizationService
    DTDFVocab:enables ComparativeAnalyticsService
    base:isContainedIn CranePhysicalSystem
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "TensorFlow-based anomaly detection model trained on historical data with rule-based thresholds for motor stall and sensor drift detection."
    DTDFVocab:enables FaultDetectionService
    base:isContainedIn CranePhysicalSystem
]

instance PerformanceAnalysisEnabler : DTDFVocab:Enabler [
    base:desc "Python-based statistical analysis tool using Pandas for performance benchmarking and retrospective validation of crane operations."
    DTDFVocab:enables PerformanceBenchmarkingService
    base:isContainedIn CranePhysicalSystem
]

instance DarTwinNotationEnabler : DTDFVocab:Enabler [
    base:desc "Graphviz-based implementation of DarTwin notation for formal modeling of system evolution including hardware/software updates."
    DTDFVocab:enables SystemEvolutionService
    base:isContainedIn CranePhysicalSystem
]

instance DataLoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB-based logging system with event-driven and time-driven data ingestion for historical analysis and post-mortem validation."
    DTDFVocab:enables HistoricalDataLoggingService
    base:isContainedIn CranePhysicalSystem
]

// C6: Services
instance RealTimeTrajectoryOptimizationService : DTDFVocab:Service [
    base:desc "Generates energy-efficient or time-optimal paths for crane movement using kinematic constraints and payload dynamics with 100ms latency."
    DTDFVocab:provides EnergyEfficientTrajectoryInsight
    DTDFVocab:provides TimeOptimalTrajectoryAction
]

instance AdaptiveControlFeedbackService : DTDFVocab:Service [
    base:desc "Adjusts control parameters dynamically using model predictive control (MPC) or reinforcement learning for real-time adaptation."
    DTDFVocab:provides ControlParameterAdaptationInsight
    DTDFVocab:provides DynamicFeedbackAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Implements real-time consistency checks between physical crane sensor data and digital twin kinematic model using residual analysis."
    DTDFVocab:provides ValidationConsistencyInsight
    DTDFVocab:provides DiscrepancyDetectionAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects anomalies like motor stalls, sensor drift, or structural fatigue using machine learning models and rule-based thresholds."
    DTDFVocab:provides AnomalyDetectionInsight
    DTDFVocab:provides FaultAlertAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Stores time-series data including position, velocity, torque, and control commands for post-mortem analysis and performance benchmarking."
    DTDFVocab:provides OperationalLogInsight
    DTDFVocab:provides DataRetentionAction
]

instance CraneStateVisualizationService : DTDFVocab:Service [
    base:desc "Renders 3D/2D kinematic visualization of real-time hook position and velocity profiles using CAD models in MATLAB/Python interfaces."
    DTDFVocab:provides VisualRepresentationInsight
]

instance ComparativeAnalyticsService : DTDFVocab:Service [
    base:desc "Overlays physical vs. digital twin trajectories to highlight deviations caused by friction, wind, or control errors."
    DTDFVocab:provides DeviationAnalysisInsight
]

instance FailureScenarioSimulationService : DTDFVocab:Service [
    base:desc "Simulates failure scenarios like motor failure or load imbalance to assess system robustness using physics-based simulation."
    DTDFVocab:provides FailureScenarioInsight
]

instance RobustnessAnalysisService : DTDFVocab:Service [
    base:desc "Evaluates system robustness under hypothetical conditions including payload changes and environmental disturbances."
    DTDFVocab:provides RobustnessEvaluationInsight
]

instance SystemEvolutionService : DTDFVocab:Service [
    base:desc "Enables formal modeling of system evolution using DarTwin notation to track digital twin synchronization over time."
    DTDFVocab:provides EvolutionModelInsight
]

instance KinematicVisualizationService : DTDFVocab:Service [
    base:desc "Provides 3D kinematic visualization of crane mechanics using Blender or Unity for educational and research purposes."
    DTDFVocab:provides VisualizationModelInsight
]

instance TrajectoryComparisonService : DTDFVocab:Service [
    base:desc "Compares planned vs. executed trajectories to quantify control performance and identify optimization opportunities."
    DTDFVocab:provides ComparisonAnalysisInsight
]

instance HumanInTheLoopValidationService : DTDFVocab:Service [
    base:desc "Facilitates human operator validation of advanced control algorithms with real-time feedback and trajectory adjustment."
    DTDFVocab:provides ValidationFeedbackInsight
    DTDFVocab:provides OperatorAdjustmentAction
]

instance PerformanceBenchmarkingService : DTDFVocab:Service [
    base:desc "Compares current crane performance against historical benchmarks to identify degradation patterns or efficiency improvements."
    DTDFVocab:provides BenchmarkComparisonInsight
]

// C17: Insights/Actions
instance EnergyEfficientTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimized path that minimizes energy consumption while maintaining kinematic constraints and payload safety."
]

instance TimeOptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Executes the fastest possible trajectory while respecting dynamic constraints and safety limits."
    DTDFVocab:IsAutomatic true
]

instance ControlParameterAdaptationInsight : DTDFVocab:Insight [
    base:desc "Real-time adjustments to PID gains or MPC parameters based on current operational conditions and model predictions."
]

instance DynamicFeedbackAction : DTDFVocab:Action [
    base:desc "Applies adaptive control corrections to the physical crane based on digital twin predictions."
    DTDFVocab:IsAutomatic true
]

instance ValidationConsistencyInsight : DTDFVocab:Insight [
    base:desc "Statistical measure of agreement between physical sensor data and digital twin model predictions."
]

instance DiscrepancyDetectionAction : DTDFVocab:Action [
    base:desc "Triggers alert when residual analysis exceeds predefined thresholds indicating potential system issues."
    DTDFVocab:IsAutomatic true
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Identified deviations from normal operational patterns including motor stalls, sensor drift, or structural fatigue."
]

instance FaultAlertAction : DTDFVocab:Action [
    base:desc "Generates maintenance alerts with severity classification for detected faults."
    DTDFVocab:IsAutomatic true
]

instance OperationalLogInsight : DTDFVocab:Insight [
    base:desc "Complete historical record of crane operations including all sensor readings and control commands."
]

instance DataRetentionAction : DTDFVocab:Action [
    base:desc "Maintains data integrity and availability for post-mortem analysis and regulatory compliance."
    DTDFVocab:IsAutomatic true
]

instance VisualRepresentationInsight : DTDFVocab:Insight [
    base:desc "3D/2D graphical representation of crane state with real-time updates of position and velocity."
]

instance DeviationAnalysisInsight : DTDFVocab:Insight [
    base:desc "Quantitative comparison between physical and digital twin trajectories highlighting sources of error."
]

instance FailureScenarioInsight : DTDFVocab:Insight [
    base:desc "Simulated failure conditions and their predicted impact on system performance."
]

instance RobustnessEvaluationInsight : DTDFVocab:Insight [
    base:desc "Assessment of system resilience under extreme operational conditions."
]

instance EvolutionModelInsight : DTDFVocab:Insight [
    base:desc "Formal representation of system evolution including hardware/software updates and configuration changes."
]

instance VisualizationModelInsight : DTDFVocab:Insight [
    base:desc "3D kinematic model visualization with interactive exploration capabilities."
]

instance ComparisonAnalysisInsight : DTDFVocab:Insight [
    base:desc "Performance metrics comparing planned trajectories with actual execution results."
]

instance ValidationFeedbackInsight : DTDFVocab:Insight [
    base:desc "Human operator feedback on digital twin predictions and control algorithm performance."
]

instance OperatorAdjustmentAction : DTDFVocab:Action [
    base:desc "Allows human operator to manually adjust control parameters or trajectories during validation."
    DTDFVocab:IsAutomatic false
]

instance BenchmarkComparisonInsight : DTDFVocab:Insight [
    base:desc "Performance metrics comparing current operations against historical benchmarks."
]

