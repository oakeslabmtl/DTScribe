// C2: Acting Components
instance GantryCraneMotionController : DTDFVocab:ActingComponent [
    base:desc "On‑board controller that actuates the gantry crane’s motion (translation of the trolley and lifting) and provides the remote‑operation interface."
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet driven by the Arduino board to grasp and release the surrogate pucks."
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the crane to measure the swing angle of the load during motion."
    DTDFVocab:producedData SwingAngleDataTransmission
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Small anemometer attached to the crane structure to record ambient wind speed."
    DTDFVocab:producedData WindSpeedDataTransmission
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// C10: Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurements streamed from the encoder."
    DTDFVocab:fromData SwingAngleDataTransmission
    DTDFVocab:inputTo TimescaleDBEnabler, ControlEngineEnabler, VisualizationEngineEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed values streamed from the anemometer."
    DTDFVocab:fromData WindSpeedDataTransmission
    DTDFVocab:inputTo TimescaleDBEnabler, VisualizationEngineEnabler
]

// C10: Models/Data
instance CADModelGantryCrane : DTDFVocab:Model [
    base:desc "Geometric CAD representation of the lab‑scale gantry crane used for visualization and collision checks."
    DTDFVocab:inputTo VisualizationEngineEnabler
]

instance KinematicModelGantryCrane : DTDFVocab:Model [
    base:desc "Kinematic (behavioral) model describing the crane’s translational and lifting dynamics, employed for optimal control and validation."
    DTDFVocab:inputTo ControlEngineEnabler, ContinuousValidationEngineEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database that stores all raw sensor measurements and derived data."
    DTDFVocab:enables HistoricalLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for service‑level signalling and alert distribution."
    DTDFVocab:enables ContinuousValidationService
]

instance ControlEngineEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source control engine (e.g., Python‑based optimal‑control library) that consumes sensor data and the kinematic model to compute control commands."
    DTDFVocab:enables OptimalControlService
]

instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Containerised visualization stack (e.g., Plotly/Dash) that renders real‑time crane state and trajectories."
    DTDFVocab:enables RealTimeVisualizationService
]

instance ContinuousValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Software component that continuously compares live sensor data against the kinematic model to detect deviations."
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Provides optimal control commands for the crane based on its kinematic model and live sensor feedback."
    DTDFVocab:provides InsightOptimalTrajectory, ActionAdjustCraneParameters
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Continuously logs time‑stamped sensor and controller data into TimescaleDB for later analysis."
    DTDFVocab:provides InsightHistoricalTrend
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Streams current crane state and trajectory visualisations to the user interface in real time."
    DTDFVocab:provides InsightCurrentStateVisualization
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Validates the physical crane against the digital kinematic model and emits alerts when deviations exceed thresholds."
    DTDFVocab:provides InsightDeviationAlert, ActionTriggerSafetyStop
]

// C17: Insights/Actions
instance InsightOptimalTrajectory : DTDFVocab:Insight [
    base:desc "Optimal motion plan that minimises swing and travel time for a given load transfer."
]

instance InsightHistoricalTrend : DTDFVocab:Insight [
    base:desc "Aggregated trend analysis of swing angle and wind speed over past operation cycles."
]

instance InsightCurrentStateVisualization : DTDFVocab:Insight [
    base:desc "Live visual representation of crane position, load swing, and environmental conditions."
]

instance InsightDeviationAlert : DTDFVocab:Insight [
    base:desc "Detection of abnormal swing or positional error compared to the kinematic model."
]

instance ActionAdjustCraneParameters : DTDFVocab:Action [
    base:desc "Automatically adjusts control gains and motion profiles to reduce predicted swing."
    DTDFVocab:IsAutomatic true
]

instance ActionTriggerSafetyStop : DTDFVocab:Action [
    base:desc "Issues an emergency stop command to the crane controller when safety thresholds are breached."
    DTDFVocab:IsAutomatic true
]

// C13: Physical components (optional for completeness)
instance GantryCraneStructure : DTDFVocab:Component [
    base:desc "Steel frame of the lab‑scale gantry crane, supporting the trolley, hoist, and sensor mounts."
]

instance CranePuck : DTDFVocab:Component [
    base:desc "Small surrogate container (puck) moved by the crane between predefined locations."
]

// C14: Environment
instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains GantryCraneStructure, CranePuck, SwingAngleEncoder, AnemometerSensor, GantryCraneMotionController, ElectromagnetActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (a Python service) issues motion commands to the Physical Crane Interface, which translates them into controller‑level instructions for the two motor controllers and the electromagnet. Command delivery uses the same hardware connection as the interface (e.g., serial/USB) and is mediated by Python code; no explicit message format, authentication, or conflict‑resolution mechanisms are described. The system relies on the HMI for operator confirmation, but the documents do not detail command execution acknowledgments."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The gantry‑crane twin follows a C4‑model based architecture composed of six logical containers. Data from the physical crane are logged by the Logging Application into a TimescaleDB database. Core twin services (Trajectory Generator, Simulation, Continuous Validation) communicate asynchronously via an MQTT broker, enabling decoupled signaling. The Dashboard (Grafana) visualises data from TimescaleDB, while the Human‑Machine Interface provides operator interaction. All containers are implemented as Python programs and are orchestrated as separate processes (not Docker containers), forming a centralized but modular orchestration of the twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The exemplar includes a continuous validation service that monitors the discrepancy between the physical crane’s measured behavior and the kinematic model, supporting research on validation methods. While the document mentions validation and fault‑detection use cases, it does not give explicit fidelity requirements, uncertainty quantification, or quality assurance processes."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital‑twin components are containerised with Docker and orchestrated via a Docker‑Compose file on a single host computer. Core services include a TimescaleDB instance (PostgreSQL‑based time‑series DB), a Grafana dashboard, and an MQTT broker (Eclipse Mosquitto) for inter‑service signalling. Communication between micro‑services uses MQTT; the Python containers interact with the database via standard SQL over the host’s network stack. No specific bandwidth, latency, redundancy, or security (e.g., TLS) requirements are given beyond the use of open‑source components."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire system runs on‑premise on a personal computer. Deployment is achieved with Docker containers for the Database, MQTT Broker, and Dashboard, while the remaining Python services are installed via the pip‑installable *gantrylib* module. Storage requirements are dictated by TimescaleDB (time‑series data), and computational load is modest, suitable for a single‑machine setup. Scalability can be attained by scaling Docker containers, but no cloud or edge platforms are mentioned. Availability is managed through Docker‑Compose scripts that automatically initialise the database and dashboard on first start."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management twin is built on an AutomationML based digital‑twin model, adhering to the AutomationML specification for model‑driven engineering. No other industry standards or certification frameworks are mentioned in the documents."
]