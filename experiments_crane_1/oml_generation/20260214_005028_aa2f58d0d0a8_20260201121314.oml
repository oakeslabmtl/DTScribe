// C3: Physical sensing components – Crane sensors
instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor providing the crane’s real‑time x, y, z coordinates."
]
instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Velocity sensor measuring the crane’s real‑time linear and angular speeds."
]
instance ActuatorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor capturing the actuator electrical currents during operation."
]
instance LoadWeightSensor : DTDFVocab:SensingComponent [
    base:desc "Load weight sensor measuring the weight suspended by the crane."
]
instance AlarmFlagSensor : DTDFVocab:SensingComponent [
    base:desc "Alarm flag sensor reporting operational fault or alarm states."
]

// C3: Physical sensing components – Raspberry Pi environment sensors
instance RpiTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted on the Raspberry Pi platform measuring ambient temperature."
]
instance RpiHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor on the Raspberry Pi measuring ambient relative humidity."
]
instance RpiCO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor on the Raspberry Pi measuring indoor CO₂ concentration."
]
instance RpiParticulateMatterSensor : DTDFVocab:SensingComponent [
    base:desc "Particulate matter sensor on the Raspberry Pi measuring airborne particles."
]

// C4: Data transmitted – Crane state
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor
]
instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocitySensor
]
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ActuatorCurrentSensor
]
instance LoadWeightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadWeightSensor
]
instance AlarmFlagDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AlarmFlagSensor
]

// C4: Data transmitted – Environment
instance TempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RpiTemperatureSensor
]
instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RpiHumiditySensor
]
instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RpiCO2Sensor
]
instance ParticulateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RpiParticulateMatterSensor
]

// C5: Data – Telemetry
instance PositionTelemetryData : DTDFVocab:Data [
    base:desc "Crane position telemetry data stored chronologically."
    DTDFVocab:fromData PositionDataTransmitted
]
instance VelocityTelemetryData : DTDFVocab:Data [
    base:desc "Crane velocity telemetry data stored chronologically."
    DTDFVocab:fromData VelocityDataTransmitted
]
instance CurrentTelemetryData : DTDFVocab:Data [
    base:desc "Actuator current telemetry data stored chronologically."
    DTDFVocab:fromData CurrentDataTransmitted
]
instance LoadWeightTelemetryData : DTDFVocab:Data [
    base:desc "Load weight telemetry data stored chronologically."
    DTDFVocab:fromData LoadWeightDataTransmitted
]
instance AlarmFlagTelemetryData : DTDFVocab:Data [
    base:desc "Alarm flag telemetry data stored chronologically."
    DTDFVocab:fromData AlarmFlagDataTransmitted
]

instance TemperatureTelemetryData : DTDFVocab:Data [
    base:desc "Ambient temperature telemetry data from Raspberry Pi."
    DTDFVocab:fromData TempDataTransmitted
]
instance HumidityTelemetryData : DTDFVocab:Data [
    base:desc "Ambient humidity telemetry data from Raspberry Pi."
    DTDFVocab:fromData HumidityDataTransmitted
]
instance CO2TelemetryData : DTDFVocab:Data [
    base:desc "Indoor CO₂ concentration telemetry data from Raspberry Pi."
    DTDFVocab:fromData CO2DataTransmitted
]
instance ParticulateMatterTelemetryData : DTDFVocab:Data [
    base:desc "Particulate matter telemetry data from Raspberry Pi."
    DTDFVocab:fromData ParticulateDataTransmitted
]

// C10: Models – Kinematic and control
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "AutomatedML‑based kinematic model representing the crane’s motion geometry."
]
instance CraneControlModel : DTDFVocab:Model [
    base:desc "Digital twin control model enabling optimal control algorithms."
]

// C11: Enablers – Data storage, messaging, environment
instance TimescaleDBStorage : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance persisting crane telemetry as a time‑series database."
    DTDFVocab:enables HistoricalDataLoggingService, AnomalyDetectionService, ContinuousValidationService
]
instance InfluxDBStorage : DTDFVocab:Enabler [
    base:desc "InfluxDB instance storing greenhouse environmental telemetry."
    DTDFVocab:enables HistoricalDataLoggingService, AnomalyDetectionService
]
instance ActiveMQBroker : DTDFVocab:Enabler [
    base:desc "ActiveMQ message broker streaming data between virtual components."
    DTDFVocab:enables DataStreamingService
]
instance DockerContainerEnvironment : DTDFVocab:Enabler [
    base:desc "Docker container encapsulating virtual machine images for reproducible experiments."
    DTDFVocab:enables ModelExecutionService
]
instance GitHubRepository : DTDFVocab:Enabler [
    base:desc "GitHub repository maintaining the twin artefacts and source code."
    DTDFVocab:enables ModelExecutionService
]
instance CADModelingTool : DTDFVocab:Enabler [
    base:desc "CAD tool generating 3‑D representations of the crane geometry."
    DTDFVocab:enables InteractiveVisualizationService
]

// C6: Services – Twin functional capabilities
instance ControlAlgorithmService : DTDFVocab:Service [
    base:desc "Service implementing optimal control algorithms for the crane."
    DTDFVocab:provides AdjustControlAction
]
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service enabling real‑time monitoring of crane state."
    DTDFVocab:provides RealTimeVisualizationInsight
]
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service logging crane telemetry for trend analysis and anomaly detection."
    DTDFVocab:provides TrendAnalysisInsight, AnomalyDetectionInsight
]
instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Service that detects anomalies in crane operation."
    DTDFVocab:provides AnomalyDetectionInsight, TriggerAlarmAction
]
instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Service providing interactive 3‑D visualization of the crane’s geometry and motion."
    DTDFVocab:provides RealTimeVisualizationInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service continuously validating simulated behavior against measured sensor data."
    DTDFVocab:provides ValidationInsight
]
instance DataStreamingService : DTDFVocab:Service [
    base:desc "Service streaming data between components via ActiveMQ."
    DTDFVocab:provides DataStreamingInsight
]
instance ModelExecutionService : DTDFVocab:Service [
    base:desc "Service executing simulation and predictive models."
    DTDFVocab:provides ForecastInsight
]

// C17: Insights – Observations from services
instance TrendAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight showing long‑term trends in crane performance."
]
instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating potential faults or drift detected in crane operation."
]
instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Insight comparing simulated behavior with actual sensor data to confirm validity."
]
instance ForecastInsight : DTDFVocab:Insight [
    base:desc "Insight predicting future crane states based on simulation."
]
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight enabling real‑time visual feedback of crane state."
]
instance DataStreamingInsight : DTDFVocab:Insight [
    base:desc "Insight reflecting current status of data streams."
]

// C17: Actions – Executable outcomes
instance TriggerAlarmAction : DTDFVocab:Action [
    base:desc "Automatic action that triggers an alarm when anomaly thresholds are exceeded."
    DTDFVocab:IsAutomatic true
]
instance AdjustControlAction : DTDFVocab:Action [
    base:desc "Automatic action adjusting crane control inputs based on optimal algorithm outputs."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the Software domain (Control Application) and are synthesized by the Trajectory Generator Service, which emits optimal movement trajectories computed by a kinematic model. Trajectory data are passed as Python objects (e.g., dictionaries containing waypoints and control limits) to the Physical Crane Interface, which serializes them into low‑level actuator commands compatible with the crane controllers. Confirmation of command execution is achieved by the Continuous Validation Service, which compares live sensor readings (pulled by the Logging Application) with simulated execution results, computing distance metrics and notifying operators via the Dashboard when thresholds are breached. Authentication and conflict‑resolution mechanisms are not detailed in the document; however, the system design assumes that only authorized services communicate via the MQTT broker, and the Dashboard provides a unified feedback and control point for operator intervention."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin’s orchestration is implemented using containerized components deployed on virtual machines. An ActiveMQ message broker mediates data flow from the physical system to the twin, while sensor telemetry and simulation results are stored in an InfluxDB time‑series database. The architecture follows a loosely coupled, event‑driven pattern, with no commercial twin framework employed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication relies on an MQTT broker for signalling, enabling publish/subscribe messaging between the Trajectory Generator, Simulation Service, Continuous Validation Service, and the Dashboard. The system architecture is a local, edge‑centric network where services are Python processes communicating over MQTT, TCP/IP stacks, and direct database connections to TimescaleDB. Bandwidth and latency requirements are not specified; reliability is implied by the use of an MQTT broker, but redundancy or security protocols (e.g., TLS, authentication) are not mentioned."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin stack is deployed on‑premises (edge) alongside the physical crane hardware, utilizing local compute nodes to run Python services (Control Application, Trajectory Generator, Simulation, Continuous Validation) and a TimescaleDB instance. Data storage is provisioned on the same local infrastructure, with sufficient capacity to archive all time‑series telemetry generated by the Logging Application. Scalability is not explicitly addressed, suggesting a single‑node deployment; availability is supported by continuous logging and live validation feedback, but no redundancy or high‑availability mechanisms for services or database are described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with the physical plant is achieved through a Raspberry‑Pi equipped with sensors that publish telemetry to the ActiveMQ broker; the twin also adopts an AutomationML model for structural representation. Microsoft Azure services (including Azure IoT Hub and related cloud tooling) are used for downstream processing, visualization, simulation, and prediction, thereby establishing dependencies on on‑premise hardware, the message broker, and the Azure cloud stack."
]