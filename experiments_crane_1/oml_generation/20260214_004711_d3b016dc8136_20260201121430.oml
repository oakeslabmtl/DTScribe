// C3: Physical sensing components
instance SwingAngleEncoderSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder sensing the pendulum angle of the crane."
]

instance AnemometerSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Anemometer (wind speed sensor) measuring ambient wind affecting the crane."
]

// C4: Data transmitted from sensors
instance DataTransmittedSwingAngle : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensingComponent
]

instance DataTransmittedAnemometer : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensingComponent
]

// C10: Models/Data
instance CADFusionModel : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane created in Autodesk Fusion."
    DTDFVocab:inputTo CapellaModelEnabler
]

instance KinematicCraneModel : DTDFVocab:Model [
    base:desc "Kinematic model describing the crane geometry and joint constraints."
    DTDFVocab:inputTo CapellaModelEnabler
]

instance ControlLoopSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of the crane control loops."
    DTDFVocab:inputTo CapellaModelEnabler
]

instance TimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series sensor data stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDBEnabler, MosquittoMqttBrokerEnabler
    DTDFVocab:fromData DataTransmittedSwingAngle, DataTransmittedAnemometer
]

instance DistanceMetricsData : DTDFVocab:Data [
    base:desc "Derived distance metrics used for continuous validation."
    DTDFVocab:inputTo MosquittoMqttBrokerEnabler
    DTDFVocab:fromData DataTransmittedSwingAngle
]

// C6: Services
instance RealTimeDataLoggingService : DTDFVocab:Service [
    base:desc "Logs real‑time sensor data into TimescaleDB."
    DTDFVocab:provides DataLoggedInsight
    DTDFVocab:provides DashboardUpdateInsight
]

instance CraneMotionSimulationService : DTDFVocab:Service [
    base:desc "Simulates crane motion using the kinematic and control loop models."
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares measured sensor data with simulation outputs."
    DTDFVocab:provides ValidatedTrajectoryPerformanceMetricsInsight
    DTDFVocab:provides FaultDetectionAlertInsight
]

instance FaultDetectionClassificationService : DTDFVocab:Service [
    base:desc "Detects faults via time‑series classification of sensor data."
    DTDFVocab:provides FaultDetectionAlertInsight
]

instance OptimalTrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal movement trajectories for the crane."
    DTDFVocab:provides OptimalControlPlanInsight
]

instance RealTimeVisualizationGrafanaService : DTDFVocab:Service [
    base:desc "Visualizes real‑time data and insights on Grafana dashboards."
    DTDFVocab:provides DashboardUpdateInsight
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database enabler for storing time‑series data."
    DTDFVocab:enables RealTimeDataLoggingService
]

instance MosquittoMqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker enabling message exchange."
    DTDFVocab:enables ContinuousValidationService,
                CraneMotionSimulationService,
                FaultDetectionClassificationService,
                RealTimeVisualizationGrafanaService,
                OptimalTrajectoryGenerationService
]

instance CapellaModelEnabler : DTDFVocab:Enabler [
    base:desc "Capella/Arcadia model enabler facilitating simulation services."
    DTDFVocab:enables CraneMotionSimulationService
]

// C17: Insights
instance ValidatedTrajectoryPerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Validated trajectory performance metrics comparing measured vs simulated data."
]

instance FaultDetectionAlertInsight : DTDFVocab:Insight [
    base:desc "Fault detection alerts generated from time‑series classification."
]

instance OptimalControlPlanInsight : DTDFVocab:Insight [
    base:desc "Optimal control plan for crane movements."
]

instance DataLoggedInsight : DTDFVocab:Insight [
    base:desc "Indicates that sensor data has been successfully logged to TimescaleDB."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Results of crane motion simulations."
]

instance DashboardUpdateInsight : DTDFVocab:Insight [
    base:desc "Dashboard updates reflecting latest data and insights."
]

// C17: Actions
instance NotifyOperatorAction : DTDFVocab:Action [
    base:desc "Sends notifications to the operator via dashboard."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance MotorControllerActuator : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval motor controller driving cart and hoist stepper motors."
]

instance PythonControlAppActuator : DTDFVocab:ActingComponent [
    base:desc "Python control application sending actuator commands to the physical crane interface."
]

// C5: Physical interface components (optional environment)
instance PhysicalCraneComponent : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane serving as the physical system under study."
]

instance InterfaceComponent : DTDFVocab:Component [
    base:desc "Interface bridging physical controller and digital twin."
]

// C5: Containerized environment
instance ContainerizedTwinEnvironment : DTDFVocab:Environment [
    base:contains PhysicalCraneComponent,
                InterfaceComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The control application generates desired trajectories and publishes command messages via the physical crane interface to the motor controllers; the trajectory generator may send optimal motion plans; continuous validation service can trigger notifications that influence operator actions via the HMI."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real‑time logging and validation (seconds to sub‑seconds sampling); trajectory generation and simulation are performed offline or at the start of a maneuver; continuous validation runs concurrently with physical operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A Docker‑compose orchestrated set of containers: TimescaleDB, Mosquitto MQTT broker, Grafana dashboard; Python modules for physical crane interface, control app, logging app, HMI; services for trajectory generation, simulation, and continuous validation that communicate via MQTT and the shared database."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design phase (CAD and kinematic model development), manufacturing phase (assembling the crane hardware), and operation phase (continuous validation, fault detection, and real‑time control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation through continuous comparison of measured vs simulated trajectories, distance metrics, and thresholds; fault detection via time‑series classification; uncertainty considered by confidence bounds in Grafana; overall reliance on open‑source tools allows reproducibility."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication uses MQTT (Eclipse Mosquitto) over local network; physical interface communicates with motor controllers via serial/CAN (not explicitly specified); data transmission to database uses PostgreSQL protocol."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software components deployed as Docker containers on a single personal computer; GPU/CPU virtualization not required; system is open‑source and available on GitHub; Python modules are pip‑installable."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not specified in the document."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not specified in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "No specific industrial or interoperability standards (e.g., OPC UA, IEC 61850) are referenced; the system relies on open‑source libraries and custom protocols."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "No explicit discussion on cybersecurity or operational safety; the system appears to operate locally with no remote command execution described."
]