// C3: Physical sensing components (derived from description)
instance CraneControllerSensor : DTDFVocab:SensingComponent [
    base:desc "Python interface reads sensor data from crane controllers"
    DTDFVocab:producedData CraneSensorDataTransmitted
]

// C4: Physical-to-virtual interaction – data transmitted
instance CraneSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneControllerSensor
]

// C10: Data (raw sensor data)
instance CraneSensorData : DTDFVocab:Data [
    base:desc "Raw crane sensor readings (position, speed, load) obtained from controllers"
    DTDFVocab:fromData CraneSensorDataTransmitted
    DTDFVocab:inputTo PythonInterfaceEnabler, LoggingApplicationEnabler,
                 DataVisualizationFrameworkEnabler, TrajectoryGeneratorEnabler
]

// C10: Historical data derived from sensor stream
instance HistoricalCraneStateData : DTDFVocab:Data [
    base:desc "Time‑stamped archive of crane sensor readings stored in TimescaleDB"
    DTDFVocab:fromData CraneSensorDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C10: Real‑time data for visualization
instance LiveCraneStateData : DTDFVocab:Data [
    base:desc "Current crane sensor readings streamed to the web dashboard"
    DTDFVocab:fromData CraneSensorDataTransmitted
    DTDFVocab:inputTo DataVisualizationFrameworkEnabler
]

// C10: Optimal trajectory data generated by simulation
instance OptimalTrajectoryData : DTDFVocab:Data [
    base:desc "Computed optimal trajectory with statistical confidence bounds"
    DTDFVocab:fromData CraneSensorDataTransmitted
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

// C11: Enablers – tooling and software components
instance PythonInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Python program that interfaces with crane controllers to acquire sensor data"
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

instance LoggingApplicationEnabler : DTDFVocab:Enabler [
    base:desc "Application that continuously writes crane state into TimescaleDB"
    DTDFVocab:enables HistoricalDataLoggingService, DataVisualizationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance storing historical crane state data"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance KinematicModelingLibraryEnabler : DTDFVocab:Enabler [
    base:desc "Kinematic modeling library representing crane motion for simulation and validation"
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

instance DataVisualizationFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard framework for real‑time and archived crane state visualisation"
    DTDFVocab:enables DataVisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Physics‑based simulation component that generates optimal trajectories"
    DTDFVocab:enables OptimalControlService
]

instance DockerContainerEnabler : DTDFVocab:Enabler [
    base:desc "Docker containers orchestrated via virtual machines for rapid deployment of twin components"
    DTDFVocab:enables OptimalControlService, HistoricalDataLoggingService,
                 DataVisualizationService, ContinuousValidationService
]

instance GitHubRepositoryEnabler : DTDFVocab:Enabler [
    base:desc "GitHub repository hosting source code and model artefacts, supporting CI/CD pipelines"
    DTDFVocab:enables ContinuousValidationService
]

instance DarTwinNotationEnabler : DTDFVocab:Enabler [
    base:desc "DarTwin notation capturing system changes and supporting incremental model updates"
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes and dispatches improved motion commands to the crane"
    DTDFVocab:provides DispatchOptimalMotionAction, TrajectoryRecommendationInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Records sensor and actuator data over time into TimescaleDB"
    DTDFVocab:provides StoreHistoricalDataAction, HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Renders real‑time and archived crane states for users via a web‑based dashboard"
    DTDFVocab:provides RuntimeVisualizationInsight, AlertInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates live sensor data against the kinematic model to detect deviations"
    DTDFVocab:provides ValidationResultInsight, TriggerAlertAction
]

// C17: Insights
instance TrajectoryRecommendationInsight : DTDFVocab:Insight [
    base:desc "Provides optimal motion plans together with statistical confidence bounds"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Aggregated historical crane state data for analysis and trend detection"
]

instance RuntimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Displays live sensor streams, simulation results, and alerts on the dashboard"
]

instance AlertInsight : DTDFVocab:Insight [
    base:desc "Notifies operators of deviations detected by continuous validation"
]

instance ValidationResultInsight : DTDFVocab:Insight [
    base:desc "Shows validation outcomes comparing live sensor data to the kinematic model"
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Delivers decision support by combining visualisation, predictive analytics, and optimal control recommendations"
]

// C17: Actions
instance DispatchOptimalMotionAction : DTDFVocab:Action [
    base:desc "Sends computed optimal trajectory commands to the crane actuators"
    DTDFVocab:IsAutomatic true
]

instance StoreHistoricalDataAction : DTDFVocab:Action [
    base:desc "Writes incoming sensor data into TimescaleDB for archival"
    DTDFVocab:IsAutomatic true
]

instance TriggerAlertAction : DTDFVocab:Action [
    base:desc "Generates an operator alert when validation detects a deviation"
    DTDFVocab:IsAutomatic true
]

// C10: Model
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model representing the gantry crane’s motion used for simulation and validation"
    DTDFVocab:inputTo KinematicModelingLibraryEnabler, ContinuousValidationService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the Trajectory Generator Service (optimal movement trajectories without residual swing) and are passed to the Control Application, a Python program that uses the same Physical Crane Interface to issue actuation commands to the crane controllers. The command messages contain trajectory waypoints (positions, velocities) and are sent over the same interface used for state acquisition. The documents do not describe explicit validation, authentication, or acknowledgment mechanisms, but operators are notified via the Dashboard if the Continuous Validation Service detects deviations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The exemplar adopts an ad‑hoc, container‑based orchestration that is modelled with the C4 architecture notation. Physical components (e.g., greenhouse sensors) are represented as separate containers that exchange data through an ActiveMQ message broker. All runtime services—including data ingestion, model execution, and adaptation logic—run inside virtual‑machine images that contain pre‑recorded data and can be instantiated quickly. State and time‑series measurements are persisted in an InfluxDB database. Coordination among the components relies on asynchronous messaging rather than a commercial digital‑twin framework, and the overall system is packaged using containerization/virtualization to simplify deployment and reproducibility."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital‑twin services (Trajectory Generator Service, Simulation Service, Continuous Validation Service, etc.) communicate via an MQTT broker using the MQTT publish/subscribe protocol, which provides the signaling backbone between the services. The Physical Crane Interface and Control Application are Python programs that connect to the crane controllers, but the document does not specify lower‑level network protocols, topology, bandwidth, latency, redundancy, or security mechanisms."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is modelled as six logical containers (Database, Dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service, MQTT Broker) according to the C4 model. These containers run on the same physical host (the document clarifies that they are not Docker containers) and consist of a TimescaleDB database for storage, a Grafana dashboard for visualization, and Python applications for the services. No specific cloud, edge, or virtualization platform is mentioned; deployment relies on local execution of these components."
]