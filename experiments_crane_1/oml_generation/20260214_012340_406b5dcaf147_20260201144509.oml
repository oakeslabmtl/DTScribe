// Sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring pendulum motion of the gantry crane hoist"
    DTDFVocab:producedData SwingAngleDataTransmitted
]
instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting crane dynamics"
    DTDFVocab:producedData AnemometerDataTransmitted
]
instance CartMotorSignalSensor : DTDFVocab:SensingComponent [
    base:desc "Motor position and velocity signals from the TMC4671 stepper driver controlling the cart"
    DTDFVocab:producedData CartMotorSignalDataTransmitted
]
instance HoistMotorSignalSensor : DTDFVocab:SensingComponent [
    base:desc "Motor position and velocity signals from the TMC4671 stepper driver controlling the hoist"
    DTDFVocab:producedData HoistMotorSignalDataTransmitted
]
instance ArduinoSensorReadout : DTDFVocab:SensingComponent [
    base:desc "Aggregated sensor readouts relayed by the Arduino microcontroller"
    DTDFVocab:producedData ArduinoReadoutDataTransmitted
]

// Data transmitted from sensors
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]
instance CartMotorSignalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorSignalSensor
]
instance HoistMotorSignalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorSignalSensor
]
instance ArduinoReadoutDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoSensorReadout
]

// Time‑series data stored in the database
instance SwingAngleSensorData : DTDFVocab:Data [
    base:desc "Time‑series data of swing‑angle sensor readings stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBInstance, MosquittoMQTTBrokerInstance
]
instance AnemometerSensorData : DTDFVocab:Data [
    base:desc "Time‑series data of anemometer readings stored in TimescaleDB"
    DTDFVocab:fromData AnemometerDataTransmitted
    DTDFVocab:inputTo TimescaleDBInstance, MosquittoMQTTBrokerInstance
]
instance CartMotorSignalData : DTDFVocab:Data [
    base:desc "Motor position and velocity data from cart stepper driver stored in TimescaleDB"
    DTDFVocab:fromData CartMotorSignalDataTransmitted
    DTDFVocab:inputTo TimescaleDBInstance, MosquittoMQTTBrokerInstance
]
instance HoistMotorSignalData : DTDFVocab:Data [
    base:desc "Motor position and velocity data from hoist stepper driver stored in TimescaleDB"
    DTDFVocab:fromData HoistMotorSignalDataTransmitted
    DTDFVocab:inputTo TimescaleDBInstance, MosquittoMQTTBrokerInstance
]
instance ArduinoReadoutData : DTDFVocab:Data [
    base:desc "Aggregated sensor readouts from Arduino stored in TimescaleDB"
    DTDFVocab:fromData ArduinoReadoutDataTransmitted
    DTDFVocab:inputTo TimescaleDBInstance, MosquittoMQTTBrokerInstance
]

// Acting components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driven by TMC4671 Eval controller that moves the cart"
]
instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driven by TMC4671 Eval controller that raises and lowers the hoist"
]
instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet used to pick up and release small pucks at the hoist end"
]

// Platforms (enablers)
instance TimescaleDBInstance : DTDFVocab:Enabler [
    base:desc "Locally hosted TimescaleDB time‑series database that ingests sensor streams via the Python Logging Application and MQTT broker"
    DTDFVocab:enables DataLoggingService, ContinuousValidationService
]
instance MosquittoMQTTBrokerInstance : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker that streams sensor data to downstream services such as Grafana and the kinematic model"
    DTDFVocab:enables RealTimeVisualizationService, TrajectoryGenerationService, SimulationService
]
instance GrafanaDashboardInstance : DTDFVocab:Enabler [
    base:desc "Grafana dashboard that visualises real‑time sensor data and validation metrics from TimescaleDB"
    DTDFVocab:enables RealTimeVisualizationService
]
instance PythonLoggingApplicationInstance : DTDFVocab:Enabler [
    base:desc "Python application that reads sensor data from Arduino, validates, and logs to TimescaleDB"
    DTDFVocab:enables DataLoggingService, ContinuousValidationService
]
instance TrajectoryGeneratorInstance : DTDFVocab:Enabler [
    base:desc "Python‑implemented kinematic model that generates optimal trajectories for the gantry crane"
    DTDFVocab:enables TrajectoryGenerationService
]
instance SimulationEngineInstance : DTDFVocab:Enabler [
    base:desc "Simulation engine that computes crane dynamics and produces confidence‑bound outputs"
    DTDFVocab:enables SimulationService
]
instance ContinuousValidationInstance : DTDFVocab:Enabler [
    base:desc "Continuous validation engine that compares executed trajectories against simulation and performs fault classification"
    DTDFVocab:enables ContinuousValidationService
]

// Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that persists sensor data streams in TimescaleDB"
    DTDFVocab:provides SensorDataLoggingInsight
]
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Service that renders live sensor data and validation metrics on Grafana dashboards"
    DTDFVocab:provides OperatorDashboardInsight
]
instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service that generates optimal trajectories based on the kinematic model"
    DTDFVocab:provides TrajectoryGenerationInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Service that simulates crane dynamics and outputs trajectory confidence bounds"
    DTDFVocab:provides SimulationOutputInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that validates executed motion against simulation and flags faults"
    DTDFVocab:provides ValidationMetricsInsight, FaultClassificationInsight, AdjustParametersAction
]

// Insights
instance SensorDataLoggingInsight : DTDFVocab:Insight [
    base:desc "Insight reporting that sensor data streams have been successfully logged to TimescaleDB"
]
instance OperatorDashboardInsight : DTDFVocab:Insight [
    base:desc "Insight presenting live operator dashboard metrics on crane operation"
]
instance TrajectoryGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful generation of optimal trajectories"
]
instance SimulationOutputInsight : DTDFVocab:Insight [
    base:desc "Insight on crane dynamics simulation outputs with confidence bounds"
]
instance ValidationMetricsInsight : DTDFVocab:Insight [
    base:desc "Insight describing continuous validation metrics between executed and simulated trajectories"
]
instance FaultClassificationInsight : DTDFVocab:Insight [
    base:desc "Insight classifying detected faults in crane operation"
]

// Actions
instance AdjustParametersAction : DTDFVocab:Action [
    base:desc "Action to adjust crane control parameters based on validation results"
    DTDFVocab:IsAutomatic false
]
instance TrajectoryOptimizationAction : DTDFVocab:Action [
    base:desc "Action to re‑optimise trajectories in response to changing operational conditions"
    DTDFVocab:IsAutomatic false
]
instance FaultInvestigationAction : DTDFVocab:Action [
    base:desc "Action to investigate identified faults via detailed log analysis"
    DTDFVocab:IsAutomatic false
]

// Physical components of the crane
instance CartFrameComponent : DTDFVocab:Component [
    base:desc "Steel cart frame that moves horizontally along the gantry rail"
]
instance HoistAssemblyComponent : DTDFVocab:Component [
    base:desc "Hoist assembly consisting of vertical rail, trolley, and electromagnet pickup mechanism"
]
instance ElectromagnetComponent : DTDFVocab:Component [
    base:desc "Electromagnet attached to hoist trolley for pickup and release of pucks"
]

// Physical environment containing all crane subsystems
instance EnvironmentLabGantryCrane : DTDFVocab:Environment [
    base:contains CartFrameComponent, HoistAssemblyComponent, ElectromagnetComponent,
    CartStepperMotor, HoistStepperMotor, Electromagnet,
    SwingAngleEncoder, Anemometer, CartMotorSignalSensor,
    HoistMotorSignalSensor, ArduinoSensorReadout
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service publishes optimal motor trajectories (position, velocity, acceleration profiles) over MQTT to the Physical Crane Interface, which translates them into stepper‑driver commands sent to the cart and hoist motors; continuous validation may also trigger corrective notifications sent to operators via the dashboard."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All exchanges are continuous and real‑time: the Logging Application records telemetry in real time; trajectory commands are issued in real time; validation and fault detection run per trajectory execution, with no discrete batch windows."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A containerised pipeline where the Physical Crane Interface consumes sensor streams from the Arduino, publishes control commands over MQTT, the Logging Application writes to TimescaleDB, the Trajectory Generator and Simulation services compute trajectories and compare against logged data, and the Dashboard presents results; all services communicate via the local MQTT broker and shared data volumes."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design phase (CAD models and kinematic model), Manufacturing phase (construction of the physical crane), and Operation phase (runtime monitoring, validation, optimization); the exemplar has been used throughout all three stages, with continuous validation spanning from design to operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service computes distance metrics between executed and simulated trajectories, triggering operator alerts when thresholds are exceeded; the kinematic model is validated against real motion data; simulation confidence bounds implicitly account for wind and encoder noise, ensuring model fidelity and empirical validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT (Eclipse Mosquitto) over TCP/IP on localhost (port 1883) is used for inter‑service signalling; TimescaleDB is accessed by the Logging Application via PostgreSQL port 5432. The Physical Crane Interface communicates with the Arduino over a serial (USB) connection, relaying commands and sensor data. All Docker containers share a virtual network defined by Docker‑Compose, ensuring isolated but interconnected operation on a single host."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Docker‑Compose orchestrates all six containers on a local PC or server; persistent volumes are created for TimescaleDB data and Grafana dashboards; gantrylib is installed via pip on the host's Python environment. The entire digital twin stack can be launched with a single 'docker-compose up', automatically provisioning database, broker, dashboard, and services."
]