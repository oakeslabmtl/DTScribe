// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart axis of the gantry crane"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist (vertical) axis of the gantry crane"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist for picking up containers"
]

instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval controller for the cart stepper motor"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval controller for the hoist stepper motor"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Incremental encoder measuring the swing angle of the crane trolley"
    DTDFVocab:producedData SwingAngleTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer providing wind speed measurements in the lab"
    DTDFVocab:producedData WindSpeedTransmitted
]

instance CartMotorFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Feedback signal (current/position) from the cart motor controller"
    DTDFVocab:producedData CartMotorFeedbackTransmitted
]

instance HoistMotorFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Feedback signal (current/position) from the hoist motor controller"
    DTDFVocab:producedData HoistMotorFeedbackTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance SwingAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance CartMotorFeedbackTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorFeedbackSensor
]

instance HoistMotorFeedbackTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorFeedbackSensor
]

// C5: Data (time‑series)
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements"
    DTDFVocab:fromData SwingAngleTransmitted
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements"
    DTDFVocab:fromData WindSpeedTransmitted
]

instance CartMotorFeedbackData : DTDFVocab:Data [
    base:desc "Time‑series of cart motor feedback (position/current)"
    DTDFVocab:fromData CartMotorFeedbackTransmitted
]

instance HoistMotorFeedbackData : DTDFVocab:Data [
    base:desc "Time‑series of hoist motor feedback (position/current)"
    DTDFVocab:fromData HoistMotorFeedbackTransmitted
]

// C6: Enablers (software / infrastructure)
instance PythonPhysicalCraneInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module that ingests sensor streams and drives actuators"
    DTDFVocab:enables DataLoggingService, ContinuousValidationService, HumanMachineInterfaceService, ControlApplicationService
    DTDFVocab:hasInput SwingAngleData, WindSpeedData, CartMotorFeedbackData, HoistMotorFeedbackData
]

instance MqttBrokerMosquittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for event distribution among twin services"
    DTDFVocab:enables TrajectoryGenerationService, CraneSimulationService, ContinuousValidationService
    DTDFVocab:hasInput SwingAngleData, WindSpeedData, CartMotorFeedbackData, HoistMotorFeedbackData
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance storing operational time‑series data"
    DTDFVocab:enables DataLoggingService, GrafanaDashboardService
    DTDFVocab:hasInput OperationalTimeSeriesData
]

instance TrajectoryEngineEnabler : DTDFVocab:Enabler [
    base:desc "Container providing the optimal trajectory generation algorithm"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Container running the dynamic simulation model of the crane"
    DTDFVocab:enables CraneSimulationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Container executing the continuous validation logic (measured vs simulated trajectories)"
    DTDFVocab:enables ContinuousValidationService
]

instance DockerComposeOrchestratorEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestration that launches all twin containers"
    DTDFVocab:enables DataLoggingService, GrafanaDashboardService, TrajectoryGenerationService, CraneSimulationService, ContinuousValidationService, HumanMachineInterfaceService, ControlApplicationService
]

// C7: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that records incoming sensor data into TimescaleDB"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboards visualising real‑time and historical crane data"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal movement trajectories using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance CraneSimulationService : DTDFVocab:Service [
    base:desc "Runs the dynamic simulation model to predict crane behaviour"
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares measured trajectories with simulated ones and raises alerts"
    DTDFVocab:provides ModelMeasurementDiscrepancyInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Web UI (Grafana) allowing operators to monitor and intervene"
    DTDFVocab:provides OperatorAdjustmentAction
]

instance ControlApplicationService : DTDFVocab:Service [
    base:desc "Direct control application for manual crane operation"
    DTDFVocab:provides AutomaticControlAction
]

// C8: Insights
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides operators with live visualisation of sensor streams and actuator states"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Presents the computed optimal trajectory for a given pick‑and‑place task"
]

instance ModelMeasurementDiscrepancyInsight : DTDFVocab:Insight [
    base:desc "Alert indicating significant deviation between measured and simulated crane trajectories"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Shows simulated crane states for validation and planning"
]

// C9: Actions
instance OperatorAdjustmentAction : DTDFVocab:Action [
    base:desc "Operator manually adjusts parameters or halts the crane via the UI"
    DTDFVocab:IsAutomatic false
]

instance AutomaticControlAction : DTDFVocab:Action [
    base:desc "Automatic execution of the optimal trajectory on the physical crane"
    DTDFVocab:IsAutomatic true
]

// C10: Models / Data used by Enablers
instance CADModel : DTDFVocab:Model [
    base:desc "3‑D CAD model of the gantry crane (Autodesk Fusion360)"
    DTDFVocab:inputTo DockerComposeOrchestratorEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the trajectory generator"
    DTDFVocab:inputTo TrajectoryEngineEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the crane and its controllers"
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance OperationalTimeSeriesData : DTDFVocab:Data [
    base:desc "Historical operational time‑series stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application and Trajectory Generator Service send motion commands and electromagnet activation signals through the Python Physical Crane Interface to the motor controllers; command messages are also routed via the MQTT broker to the interface."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A cyber‑physical system where the physical crane is interfaced by a Python program to a set of services (control, logging, trajectory generation, simulation, validation) that communicate via MQTT and share data in a TimescaleDB; operators interact through a Grafana dashboard and a Python HMI."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectory data with simulated trajectories, computes distance metrics, checks against predefined thresholds, and raises alerts on the dashboard when the model fidelity falls below acceptable limits."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol (Eclipse Mosquitto) for signalling between services, SQL/TimescaleDB connections for data storage and retrieval, HTTP APIs used by Grafana, and Python‑based socket/serial communication between the Physical Crane Interface and the Arduino controllers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital‑twin services are containerised with Docker and orchestrated via Docker‑Compose on a personal computer; the Python modules run directly on the host OS; the full system is hosted in a GitHub repository with installation scripts and documentation."
]