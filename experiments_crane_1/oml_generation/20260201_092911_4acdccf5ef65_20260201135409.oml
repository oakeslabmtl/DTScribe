// C2: Acting Components
instance HorizontalStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor assembly driving the horizontal cart rail, controlled via GPIO from a Raspberry‑Pi."
]

instance VerticalHoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor assembly driving the vertical hoist rail, controlled via GPIO from a Raspberry‑Pi."
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the gripper, switched on through a relay to pick up small puck payloads."
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder that measures the relative angle between the cart and the gantry structure, sampling at 10 Hz."
    DTDFVocab:producedData SwingAngleEncoderTelemetry
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer recording ambient airflow, streamed to the twin with a nominal 10 Hz frequency."
    DTDFVocab:producedData AnemometerTelemetry
]

// C4: Physical‑to‑virtual interaction
instance SwingAngleEncoderTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Models/Data
instance GantryKinematicModel : DTDFVocab:Model [
    base:desc "Discrete‑time kinematic model representing the gantry crane as a four‑degree‑of‑freedom planar system."
    DTDFVocab:inputTo KinematicSimulationEnabler
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle samples stored in TimescaleDB, published via MQTT."
    DTDFVocab:inputTo LoggingEnabler, ControlEnabler, ValidationEnabler
    DTDFVocab:fromData SwingAngleEncoderTelemetry
]

instance AnemometerData : DTDFVocab:Data [
    base:desc "Time‑stamped anemometer readings stored in TimescaleDB, published via MQTT."
    DTDFVocab:inputTo LoggingEnabler
    DTDFVocab:fromData AnemometerTelemetry
]

// C11: Enablers
instance LoggingEnabler : DTDFVocab:Enabler [
    base:desc "Dockerized service interfacing with TimescaleDB to persist all sensor telemetry for post‑hoc analysis."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance ControlEnabler : DTDFVocab:Enabler [
    base:desc "Closed‑loop controller coordinator that consumes swing‑angle data to compute actuator position commands via the simulation engine."
    DTDFVocab:enables OptimalControlService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous Validation Service that compares live swing‑angle measurements against simulated states to detect drift and provide confidence scores."
    DTDFVocab:enables ValidationService
]

instance KinematicSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Runs the kinematic model equations in a Docker container, translating models to runtime behaviour."
    DTDFVocab:enables SimulationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Transformation pipeline that renders 3D visualisations of the digital twin synchronized with real‑time sensor data."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring service that publishes actuator positions, velocities, and payload state to Grafana dashboards."
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal trajectory generation service that computes efficient paths for the gantry and offers routes to operators for decision support."
    DTDFVocab:provides OptimalTrajectoryInsight, GenerateOptimalTrajectoryAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Historical data logging service that records all positional and velocity data points into TimescaleDB for post‑hoc analysis."
    DTDFVocab:provides HistoricalAnalysisInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D data visualization service that renders the digital twin matching real‑time sensor data, visualised via Grafana and 3D web libraries."
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service that compares simulated states against live measurements, issuing anomaly alerts and confidence scores."
    DTDFVocab:provides ValidationInsight, AnomalyAlertAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service that executes the kinematic model within Docker to provide simulated twin state."
    DTDFVocab:provides SimulatedStateInsight
]

// C17: Insights / Actions
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight showing real‑time actuator positions, velocities, and payload state in Grafana dashboards."
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight providing optimal paths for gantry movement calculated by the trajectory generator."
]

instance GenerateOptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatically commands the crane controllers to follow an optimised trajectory derived by the optimal control service."
    DTDFVocab:IsAutomatic true
]

instance HistoricalAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight summarising historical positional and velocity data for post‑hoc performance evaluation."
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight presenting a synchronized 3D rendering of the gantry crane based on live sensor telemetry."
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating any divergence between simulated states and live measurements, including confidence scores."
]

instance AnomalyAlertAction : DTDFVocab:Action [
    base:desc "Action that alerts operators when planned trajectories deviate significantly from expected performance thresholds."
    DTDFVocab:IsAutomatic true
]

instance SimulatedStateInsight : DTDFVocab:Insight [
    base:desc "Insight displaying simulated kinematic state of the gantry as computed by the simulation service."
]

// C10: Environment
instance GantryLaboratoryEnvironment : DTDFVocab:Environment [
    base:contains HorizontalStepperMotor, VerticalHoistStepperMotor, Electromagnet, SwingAngleEncoder, Anemometer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, itself a Python program, uses the same crane interface to transmit control commands to the physical crane. Command validation, authentication, or conflict resolution procedures are not described in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin’s architecture is provisioned with Docker Compose as a six‑container constellation: (1) InfluxDB for long‑term telemetry storage, (2) Mosquitto MQTT broker for intra‑service signalling, (3) Web‑based Dashboard serving the HMI, (4) Trajectory Generator Service exposing a REST API to compute optimal path plans, (5) Command Service publishing movement commands to the crane via MQTT topics, and (6) Logging Application that aggregates sensor streams. This modular container pattern enables loose coupling between services; components communicate through publish/subscribe topics over a shared Docker network, while database access is volume‑mounted for persistence. Resource limits (CPU and memory) are specified per container to ensure bounded utilisation on a single host, and Docker Compose orchestrates startup, health checks, and inter‑container networking, providing a cohesive, container‑centric coordination mechanism for the digital twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A continuous validation service compares the real sensor states with the predictions of the kinematic model. When discrepancies exceed a predefined tolerance, the service logs the mismatch and emits an alert on the operator dashboard. This comparison is performed during runtime, providing real‑time model‑verification without explicit algorithmic thresholds beyond the absolute tolerance used for alerting."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin is built on an MQTT broker for intra‑service signaling. No further details on network topology, bandwidth, latency, or redundancy are provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components – Python control and logging applications, TimescaleDB database, Grafana dashboard, and MQTT broker – are implemented as software modules and appear to run on local, on‑premises hardware. Specific deployment platforms, scalability mechanisms or reliability guarantees are not detailed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation uses an open‑source stack: Python for the core logic, Docker for containerisation, TimescaleDB for time‑series storage, and Grafana for visualization. The project is released under the MIT license. No industry‑specific standards or certification requirements are adopted; interoperability relies on standard open protocols implemented within the Dockerised services."
]