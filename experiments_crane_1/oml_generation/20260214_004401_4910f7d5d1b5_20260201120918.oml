// Greenhouse Sensors
instance GreenhouseTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor monitoring greenhouse ambient temperature"
    DTDFVocab:producedData GreenhouseTemperatureDataTransmitted
]

instance GreenhouseHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor measuring greenhouse relative humidity"
    DTDFVocab:producedData GreenhouseHumidityDataTransmitted
]

instance GreenhouseCO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor capturing greenhouse CO₂ concentration"
    DTDFVocab:producedData GreenhouseCO2DataTransmitted
]

instance GreenhouseLightIntensitySensor : DTDFVocab:SensingComponent [
    base:desc "Light intensity sensor measuring greenhouse illumination levels"
    DTDFVocab:producedData GreenhouseLightIntensityDataTransmitted
]

// Crane Sensors
instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor collecting gantry trolley position data"
    DTDFVocab:producedData CranePositionDataTransmitted
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Velocity sensor measuring gantry trolley velocity"
    DTDFVocab:producedData CraneVelocityDataTransmitted
]

instance CraneActuatorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Actuator status sensor reporting crane actuator health"
    DTDFVocab:producedData CraneActuatorStatusDataTransmitted
]

// Greenhouse Data Transmitted
instance GreenhouseTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseTemperatureSensor
]

instance GreenhouseHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseHumiditySensor
]

instance GreenhouseCO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseCO2Sensor
]

instance GreenhouseLightIntensityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseLightIntensitySensor
]

// Crane Data Transmitted
instance CranePositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor
]

instance CraneVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocitySensor
]

instance CraneActuatorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneActuatorStatusSensor
]

// Greenhouse Data
instance GreenhouseTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series temperature data captured from greenhouse"
    DTDFVocab:fromData GreenhouseTemperatureDataTransmitted
    DTDFVocab:inputTo GreenhouseInfluxDBPersistenceEnabler
]

instance GreenhouseHumidityData : DTDFVocab:Data [
    base:desc "Time‑series humidity data captured from greenhouse"
    DTDFVocab:fromData GreenhouseHumidityDataTransmitted
    DTDFVocab:inputTo GreenhouseInfluxDBPersistenceEnabler
]

instance GreenhouseCO2Data : DTDFVocab:Data [
    base:desc "Time‑series CO₂ concentration data captured from greenhouse"
    DTDFVocab:fromData GreenhouseCO2DataTransmitted
    DTDFVocab:inputTo GreenhouseInfluxDBPersistenceEnabler
]

instance GreenhouseLightIntensityData : DTDFVocab:Data [
    base:desc "Time‑series light intensity data captured from greenhouse"
    DTDFVocab:fromData GreenhouseLightIntensityDataTransmitted
    DTDFVocab:inputTo GreenhouseInfluxDBPersistenceEnabler
]

// Crane Data
instance CranePositionData : DTDFVocab:Data [
    base:desc "Time‑series gantry position data captured from physical controller"
    DTDFVocab:fromData CranePositionDataTransmitted
    DTDFVocab:inputTo CraneTimescaleDBPersistenceEnabler
]

instance CraneVelocityData : DTDFVocab:Data [
    base:desc "Time‑series gantry velocity data captured from physical controller"
    DTDFVocab:fromData CraneVelocityDataTransmitted
    DTDFVocab:inputTo CraneTimescaleDBPersistenceEnabler
]

instance CraneActuatorStatusData : DTDFVocab:Data [
    base:desc "Time‑series actuator status data captured from physical controller"
    DTDFVocab:fromData CraneActuatorStatusDataTransmitted
    DTDFVocab:inputTo CraneTimescaleDBPersistenceEnabler
]

// Models
instance GreenhouseAirQualityAutomationMLModel : DTDFVocab:Model [
    base:desc "AutomationML based model representing greenhouse air quality processes"
    DTDFVocab:inputTo GreenhouseAirQualityModelEnabler
]

instance GreenhouseGeometricModel : DTDFVocab:Model [
    base:desc "Geometric representation of greenhouse CAD model"
    DTDFVocab:inputTo GreenhouseAirQualityModelEnabler
]

instance CraneKinematicCADModel : DTDFVocab:Model [
    base:desc "CAD model of gantry crane kinematic structure"
    DTDFVocab:inputTo CraneKinematicModelEnabler
]

// Enablers
instance GreenhouseInfluxDBPersistenceEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB persistence layer for greenhouse sensor data"
    DTDFVocab:enables GreenhouseHistoricalDataLoggingService, GreenhouseContinuousValidationService
]

instance GreenhouseActiveMQMessagingEnabler : DTDFVocab:Enabler [
    base:desc "ActiveMQ broker enabling greenhouse control and visualization services"
    DTDFVocab:enables GreenhouseOptimalControlService, GreenhouseDataVisualizationService
]

instance GreenhouseAirQualityModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that supplies the air quality model to control and validation services"
    DTDFVocab:enables GreenhouseOptimalControlService, GreenhouseContinuousValidationService
]

instance CraneTimescaleDBPersistenceEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB persistence layer for crane telemetry data"
    DTDFVocab:enables CraneHistoricalDataLoggingService, CraneContinuousValidationService
]

instance CraneKinematicModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that supplies the kinematic model to control and validation services"
    DTDFVocab:enables CraneOptimalControlService, CraneContinuousValidationService
]

// Services
instance GreenhouseOptimalControlService : DTDFVocab:Service [
    base:desc "Rule‑based control service computing ventilation adjustments to maintain greenhouse setpoints"
    DTDFVocab:provides VentilationAdjustmentAction
]

instance GreenhouseHistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Historical logging service storing greenhouse sensor and actuator telemetry"
    DTDFVocab:provides HistoricalDataInsight
]

instance GreenhouseDataVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time and historical visualization of greenhouse states using the CAD model"
    DTDFVocab:provides RealTimeEnvironmentalMetricVisualizationInsight
]

instance GreenhouseContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service synchronizing model with physical greenhouse and detecting deviations"
    DTDFVocab:provides DecisionConfidenceInsight
]

instance CraneOptimalControlService : DTDFVocab:Service [
    base:desc "Optimal control service computing crane actuator commands for load‑handling tasks"
    DTDFVocab:provides ControlCommandAction
]

instance CraneHistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Historical logging service storing crane telemetry data"
    DTDFVocab:provides HistoricalDataInsight
]

instance CraneDataVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time and historical visualization of crane states using the CAD model"
    DTDFVocab:provides RealTimeStateInsight
]

instance CraneContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service synchronizing crane model with physical system and detecting faults"
    DTDFVocab:provides DeviationDetectionInsight
]

// Insights
instance RealTimeEnvironmentalMetricVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of real‑time temperature, humidity, CO₂ and light intensity in the greenhouse"
]

instance DecisionConfidenceInsight : DTDFVocab:Insight [
    base:desc "Decision confidence level inferred from the magnitude of deviations from target thresholds"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Time‑stamped record of all logged sensor and actuator data for audit and analysis"
]

instance RealTimeStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time portrayal of crane position, velocity and actuator status"
]

instance DeviationDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection alert for deviations or faults between the crane digital twin and physical hardware"
]

// Actions
instance VentilationAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjust ventilation system to meet CO₂ and temperature setpoints"
    DTDFVocab:IsAutomatic true
]

instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Emit motor control command to enact desired crane motion"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service produces optimal movement trajectories (position, velocity, acceleration profiles) that are consumed by the Control Application. The Control Application uses the Python Physical Crane Interface to publish command messages to the crane hardware controllers. Commands are in the form of high‑level motion primitives (e.g., move to point, set speed) and are sent over the same Python process that talks directly to the physical interface. Feedback from the physical crane (current state) is returned to the Logging Application for persistence and to the Simulation Service for validation. The Continuous Validation Service compares the executed trajectory with the simulated one and, if deviations exceed a threshold, notifies operators via the Dashboard."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The GreenhouseDT system orchestrates data flow across a middleware architecture composed of an ActiveMQ message broker that receives sensor events from the physical greenhouse; an InfluxDB time‑series database for persistent storage of sensor readings; virtual machine instances that host the digital twin simulation and adaptation logic; and containerized services (via Docker) for modular deployment and replication. Coordination between these layers is achieved through message queues and scheduled jobs, enabling the twin to process real‑time streams and prerecorded data for offline simulation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin communication backbone relies on an MQTT broker for inter‑service signaling (e.g., publish/subscribe of trajectory, telemetry, and validation events). The Logging Application and other services access the TimescaleDB database over standard PostgreSQL/TimescaleSQL connections (TCP). The network topology is a local area network with the services residing on separate containers or VMs, but all communication uses reliable TCP streams. Security protocols are not explicitly defined in the document; however, the typical MQTT connections are assumed to be over TLS, and database connections use password authentication."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration between the physical system, the digital twin, and external cloud services is achieved by using ActiveMQ as the inter‑component messaging backbone (AMQP/OpenWire) to stream sensor data from Raspberry‑Pi devices to the twin; the twin writes to InfluxDB, exposing data via its HTTP API; Microsoft Azure tools are employed to run the digital twin pipeline in the cloud; and AutomationML is used as the standardized description format for the twin to interoperate with other engineering tools. Standard HTTP/REST and AMQP communication patterns are used to integrate with enterprise systems."
]