// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor governing the horizontal movement of the crane's cart along its rail, controlled via direct motor controller interface."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor managing vertical lifting and lowering of the load, integrated with the crane's hoist mechanism."
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet positioned at the end of the hoist to securely grip and release container-like pucks during transport operations."
]

// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures angular displacement of the hoist during swinging motion, providing real-time feedback for kinematic validation."
    DTDFVocab:producedData SwingAngleData
]

instance CraneAnemometer : DTDFVocab:SensingComponent [
    base:desc "Captures real-time wind speed data affecting crane stability, interfaced via Arduino-based microcontroller."
    DTDFVocab:producedData WindSpeedData
]

instance CraneControllerInterface : DTDFVocab:SensingComponent [
    base:desc "Python-based interface connecting to crane controllers, transmitting real-time kinematic and dynamic state data."
    DTDFVocab:producedData CraneStateData
]

// C4: Physical-to-Virtual Interaction
instance SwingAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneAnemometer
]

instance CraneStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneControllerInterface
]

// C10: Models/Data
instance GeometricCADModel : DTDFVocab:Model [
    base:desc "Static 3D representation of the crane's structural components (beams, cart, hoist) created using CAD modeling software."
    DTDFVocab:inputTo CADModelEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Mathematical model defining motion relationships between crane components (cart, hoist, electromagnet) using Denavit-Hartenberg parameters."
    DTDFVocab:inputTo KinematicModelEnabler
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Virtual replica of crane operations enabling predictive and comparative analyses of motion dynamics and control strategies."
    DTDFVocab:inputTo SimulationEnabler
]

instance TimeseriesSensorData : DTDFVocab:Data [
    base:desc "Time-series operational data including sensor readings (position, velocity, load status) stored in TimescaleDB for historical analysis."
    DTDFVocab:fromData SwingAngleData, WindSpeedData, CraneStateData
    DTDFVocab:inputTo TimeseriesDatabaseEnabler
]

instance ControlAlgorithmData : DTDFVocab:Data [
    base:desc "Optimized control parameters (PID, model-predictive control) derived from real-time digital twin feedback for crane motion optimization."
    DTDFVocab:fromData CraneStateData
    DTDFVocab:inputTo ControlSystemEnabler
]

// C11: Enablers
instance CADModelEnabler : DTDFVocab:Enabler [
    base:desc "Open-source CAD tools (FreeCAD, SolidWorks) enabling creation and integration of 3D geometric models for digital twin representation."
    DTDFVocab:enables GeometricVisualizationService
]

instance KinematicModelEnabler : DTDFVocab:Enabler [
    base:desc "Mathematical modeling tools (Python, MATLAB) for developing and validating crane kinematic relationships."
    DTDFVocab:enables KinematicSimulationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engines for executing virtual crane operations, enabling predictive and comparative analyses."
    DTDFVocab:enables ContinuousValidationService
]

instance TimeseriesDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database optimized for storing and querying time-series operational data from physical crane sensors."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance ControlSystemEnabler : DTDFVocab:Enabler [
    base:desc "Control system design tools (MATLAB/Simulink, Python) for implementing and optimizing crane motion control algorithms."
    DTDFVocab:enables OptimalControlService
]

instance OpenSourceDevelopmentEnabler : DTDFVocab:Enabler [
    base:desc "Open-source philosophy ensuring reproducibility and accessibility of the digital twin system through free tools and documentation."
]

instance RealTimeDataStreamingEnabler : DTDFVocab:Enabler [
    base:desc "Real-time data streaming protocols (MQTT, ROS) facilitating bidirectional communication between physical crane and digital twin."
    DTDFVocab:enables ContinuousValidationService, FaultDetectionService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Implements advanced control algorithms (PID, model-predictive control) for crane motion optimization with real-time parameter adjustment."
    DTDFVocab:provides OptimizedTrajectoryInsight, ControlParameterAdjustmentAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Stores time-series data from physical crane (position, velocity, load, sensor readings) for post-hoc performance evaluation."
    DTDFVocab:provides CraneOperationHistoryInsight, FaultDiagnosisInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Provides real-time 3D visualization of crane state (CAD models, kinematic trajectories) with comparative validation capabilities."
    DTDFVocab:provides CraneStateVisualizationInsight, PhysicalDigitalComparisonInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Automated comparison of physical and digital twin states to detect discrepancies (model drift, sensor errors) with fault detection integration."
    DTDFVocab:provides SynchronizationStatusInsight, AnomalyDetectionAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Monitors crane operation for deviations from expected behavior (actuator failures, structural stress) with alert triggering capabilities."
    DTDFVocab:provides FaultDetectionInsight, CorrectiveActionTriggerAction
]

instance KinematicSimulationService : DTDFVocab:Service [
    base:desc "Executes virtual kinematic simulations of crane movements for trajectory validation and dynamic behavior analysis."
    DTDFVocab:provides KinematicValidationInsight, MotionOptimizationAction
]

instance GeometricVisualizationService : DTDFVocab:Service [
    base:desc "Renders 3D geometric representations of crane components for spatial validation and operational monitoring."
    DTDFVocab:provides StructuralVisualizationInsight, ComponentPositioningAction
]

// C17: Insights/Actions
instance OptimizedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Real-time optimized path planning for crane movements based on digital twin feedback and environmental conditions."
]

instance ControlParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of control parameters (PID gains, predictive horizon) based on digital twin validation results."
    DTDFVocab:IsAutomatic true
]

instance CraneOperationHistoryInsight : DTDFVocab:Insight [
    base:desc "Historical record of crane operations enabling performance trend analysis and operational pattern identification."
]

instance FaultDiagnosisInsight : DTDFVocab:Insight [
    base:desc "Post-hoc analysis of sensor data to identify potential faults or performance degradation in crane components."
]

instance CraneStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time 3D visualization of crane's current state including position, velocity, and load status."
]

instance PhysicalDigitalComparisonInsight : DTDFVocab:Insight [
    base:desc "Comparative visualization showing alignment between physical crane state and digital twin simulation."
]

instance SynchronizationStatusInsight : DTDFVocab:Insight [
    base:desc "Continuous assessment of synchronization quality between physical system and digital twin, highlighting discrepancies."
]

instance AnomalyDetectionAction : DTDFVocab:Action [
    base:desc "Automatic detection of operational anomalies through pattern recognition in sensor data streams."
    DTDFVocab:IsAutomatic true
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of potential faults in crane actuators, sensors, or structural components through real-time monitoring."
]

instance CorrectiveActionTriggerAction : DTDFVocab:Action [
    base:desc "Automatic triggering of corrective measures (e.g., motor shutdown, emergency braking) upon fault detection."
    DTDFVocab:IsAutomatic true
]

instance KinematicValidationInsight : DTDFVocab:Insight [
    base:desc "Validation of crane kinematic behavior against expected motion models through simulation comparison."
]

instance MotionOptimizationAction : DTDFVocab:Action [
    base:desc "Automatic optimization of crane trajectories based on kinematic simulation results."
    DTDFVocab:IsAutomatic true
]

instance StructuralVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization of crane's structural components with real-time position and orientation data."
]

instance ComponentPositioningAction : DTDFVocab:Action [
    base:desc "Manual or automated adjustment of crane component positions for operational optimization."
    DTDFVocab:IsAutomatic false
]

// C1: System Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Indoor lab setting designed for demonstration, research, and educational use cases in cyber-physical systems."
    base:contains PhysicalGantryCraneComponent, CraneControllerComponent
]

instance PhysicalGantryCraneComponent : DTDFVocab:Component [
    base:desc "Lab-scale mechanical gantry crane system consisting of structural beams, hoist mechanism, and payload carriage."
]

instance CraneControllerComponent : DTDFVocab:Component [
    base:desc "Embedded or software-based controller managing crane actuators (motors, sensors) for motion control."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control flows from the digital twin to the physical gantry crane are managed by the **Control Application**, which uses the **Physical Crane Interface** to send commands to the crane’s controllers. The **Trajectory Generator Service** computes optimal movement trajectories (e.g., swing-free paths) and forwards these to the **Control Application**, which translates them into executable commands. The **Simulation Service** and **Continuous Validation Service** indirectly influence control by validating trajectories against real-world execution, but no explicit command formats (e.g., JSON, binary), validation/authentication mechanisms, or feedback systems (e.g., acknowledgment signals) are detailed. The document does not specify conflict resolution strategies, command execution confirmation protocols, or emergency stop signals. The **Human Machine Interface (HMI)** allows operators to configure and override crane operations, but its interaction with the control loop remains abstract."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system exemplars adopt a **lightweight, ad-hoc orchestration pattern** without relying on commercial digital twin frameworks. The **GreenhouseDT** exemplar integrates **InfluxDB (time-series database)**, **ActiveMQ (message broker)**, and **virtual machines** to enable behavioral adaptation, suggesting a **service-oriented architecture** with loose coupling between data storage, messaging, and virtualized twin components. The **Air Quality Management** exemplar uses **AutomationML** for the digital twin model and **Microsoft Azure tools** for pipeline implementation, indicating a **hybrid architecture** combining **model-driven engineering (MDE)** with cloud-based services. Both exemplars lack explicit orchestration frameworks but rely on **containerization/virtualization** (e.g., virtual machines, Raspberry Pi) for deployment. The **gantry crane system** (logistics domain) follows a similar **ad-hoc integration** approach, with no centralized coordination layer documented. **Resource management** is implicit via virtualization (e.g., VMs) and sensor-based data acquisition (e.g., Raspberry Pi), but no dynamic scaling or distributed resource allocation mechanisms are described."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin employs a **Continuous Validation Service** to ensure fidelity by dynamically comparing **executed trajectories** (derived from sensor data) with **simulated trajectories** (generated by the kinematic model). This service calculates **distance metrics** (e.g., Euclidean or positional error) between the two and evaluates them against an **acceptable threshold** to detect deviations. Uncertainty sources are mitigated through **sensor calibration routines** (e.g., encoder zeroing) and **model parameter tuning** (e.g., kinematic corrections). Error detection mechanisms include **real-time anomaly detection** in sensor streams and **post-mortem analysis** of trajectory discrepancies. Quality assurance is enforced via **automated validation pipelines** that trigger alerts or corrective actions (e.g., recalibration commands) when thresholds are exceeded. The system leverages **time-series database optimizations** (TimescaleDB) to maintain data integrity and enable efficient querying for validation purposes."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin system is designed to operate on a **single personal computer**, with all software containers (e.g., **Database**, **Trajectory Generator Service**, **MQTT Broker**) deployed locally. The **MQTT Broker** facilitates signaling between services, but no specific network topology (e.g., LAN, WAN), bandwidth requirements, or latency constraints are mentioned. The document does not describe redundancy mechanisms, security protocols (e.g., TLS, OAuth), or QoS levels for MQTT communication. The **Physical Crane Interface** connects the physical crane to the computer, but the exact communication protocol (e.g., serial, Ethernet) and data transmission specifics are unspecified. The system’s architecture implies minimal network complexity, as all components are co-located."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin system is hosted entirely on a **personal computer**, with no distinction between edge, cloud, or on-premise deployment. The **TimescaleDB database**, **Grafana Dashboard**, and service containers (e.g., **Trajectory Generator Service**, **Simulation Service**) are deployed locally, likely using Docker for containerization. Computational and storage requirements are not quantified, nor are scalability mechanisms (e.g., sharding, horizontal scaling) described. The system’s availability and reliability depend on the personal computer’s hardware and software stability, with no explicit redundancy or failover strategies mentioned. The **Physical Crane** operates independently of the digital twin but can be integrated via the **Physical Crane Interface** without requiring distributed infrastructure."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The **GreenhouseDT** exemplar demonstrates **horizontal integration** through **InfluxDB (time-series database)** and **ActiveMQ (message broker)** for data exchange, but no external system dependencies or interoperability standards (e.g., OPC UA, MQTT) are explicitly mentioned. The **Air Quality Management** exemplar integrates with **Microsoft Azure tools**, implying cloud-based data processing and storage, but lacks details on **standardized protocols** (e.g., OPC UA, REST APIs) for external system communication. The **gantry crane system** (logistics domain) does not reference any external integrations in the provided documents. All exemplars avoid commercial digital twin frameworks, relying instead on **ad-hoc solutions** (e.g., AutomationML for modeling, Raspberry Pi for sensor data). No evidence of **enterprise system integration** (e.g., ERP, MES) or **cross-Digital Twin coordination** is documented."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The **Lab Scale Gantry Crane** Digital Twin system adheres to **ad-hoc interoperability standards**, primarily relying on **MQTT** (implied by the use of lightweight IoT protocols in similar exemplars) and **Docker** for containerization. The **Air Quality Management** exemplar explicitly uses **AutomationML** for Digital Twin modeling, ensuring compliance with **construction engineering standards** for indoor air quality systems. The **GreenhouseDT** exemplar employs **InfluxDB** (a time-series database) and **ActiveMQ** (a JMS/AMQP-compliant message broker) for data exchange, though no formal certification requirements are mentioned. The system avoids commercial Digital Twin frameworks, opting instead for **open-source tools** and **GitHub-hosted repositories** for dissemination. No explicit mention of **IEC 62714** or other formal Digital Twin standards is provided in the documents."
]