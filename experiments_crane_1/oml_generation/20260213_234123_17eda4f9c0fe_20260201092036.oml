// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor controlled by TMC4671-Eval motor controller for horizontal movement"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor controlled by TMC4671-Eval motor controller for vertical movement"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet for container pickup and release"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder measuring hoist swing motion"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmission)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Models/Data
instance TimeSeriesCraneData : DTDFVocab:Data [
    base:desc "Time-series crane state data including swing angle and wind speed"
    DTDFVocab:fromData SwingAngleDataTransmitted, WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance CraneStructureCADModel : DTDFVocab:Model [
    base:desc "CAD model of crane structure for spatial representation"
    DTDFVocab:inputTo AutodeskFusion360
]

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Kinematic model for trajectory generation calculations"
    DTDFVocab:inputTo PythonGantrylibModule
]

instance CraneDynamicsSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of crane dynamics for motion prediction"
    DTDFVocab:inputTo PythonGantrylibModule
]

// C11: Enablers
instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB time-series database for data storage and retrieval"
    DTDFVocab:enables HistoricalDataLoggingService, RealTimeDataVisualizationService, ContinuousValidationService
]

instance Grafana : DTDFVocab:Enabler [
    base:desc "Grafana visualization platform for dashboard rendering"
    DTDFVocab:enables RealTimeDataVisualizationService
]

instance EclipseMosquittoMQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for real-time data transmission"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance Docker : DTDFVocab:Enabler [
    base:desc "Docker containerization platform for service deployment"
    DTDFVocab:enables CraneDynamicsSimulationService
]

instance PythonGantrylibModule : DTDFVocab:Enabler [
    base:desc "Python gantrylib module for sensor control and trajectory calculations"
    DTDFVocab:enables OptimalTrajectoryGenerationService, CraneDynamicsSimulationService
]

instance Arduino : DTDFVocab:Enabler [
    base:desc "Arduino platform for sensor control and low-level hardware interfacing"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance TMC4671EvalMotorController : DTDFVocab:ConnectionComponent [
    base:desc "TMC4671-Eval motor controller for stepper motor precision driving"
]

instance AutodeskFusion360 : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion360 for CAD modeling and structural analysis"
]

instance Capella : DTDFVocab:Enabler [
    base:desc "Capella for Model-Based Systems Engineering"
]

// C6: Services
instance OptimalTrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service generating optimal trajectories for crane motion planning"
    DTDFVocab:provides OptimalTrajectoryRecommendation
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service for continuous logging of crane operational data"
    DTDFVocab:provides TimeSeriesCraneData
]

instance RealTimeDataVisualizationService : DTDFVocab:Service [
    base:desc "Service providing real-time dashboard visualizations via Grafana"
    DTDFVocab:provides RealTimeDashboardVisualization
]

instance CraneDynamicsSimulationService : DTDFVocab:Service [
    base:desc "Service simulating crane dynamics for predictive analysis"
    DTDFVocab:provides CraneDynamicsSimulationResults
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service comparing real-time measurements against simulations for validation"
    DTDFVocab:provides FaultDetectionAlert
]

// C17: Insights/Actions
instance RealTimeDashboardVisualization : DTDFVocab:Insight [
    base:desc "Real-time dashboard visualizations of crane state data"
]

instance FaultDetectionAlert : DTDFVocab:Action [
    base:desc "Automated fault detection alerts when validation thresholds are breached"
    DTDFVocab:IsAutomatic true
]

instance OptimalTrajectoryRecommendation : DTDFVocab:Action [
    base:desc "Optimal trajectory recommendations for crane operation based on simulation"
    DTDFVocab:IsAutomatic false
]

instance CraneDynamicsSimulationResults : DTDFVocab:Insight [
    base:desc "Simulation results for crane motion dynamics analysis"
]

// Environment
instance LabScaleGantryCraneSystem : DTDFVocab:Environment [
    base:desc "Lab-scale gantry crane system inspired by Antwerp harbor cranes for container movement"
    base:contains CartStepperMotor, HoistStepperMotor, Electromagnet, SwingAngleEncoder, Anemometer, TMC4671EvalMotorController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands for movement trajectories generated by Trajectory Generator Service transmitted via Physical Crane Interface to control physical motors."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous synchronization with real-time data logging and validation, where measurements are compared against simulations in near real-time."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "C4 Model-based architecture with physical components (crane, interface, control app, logging app, HMI) and digital services (DB, dashboard, trajectory gen, simulation, validation, MQTT broker) interconnected via MQTT and database, deployed on a single PC using Docker."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational phase (as-operated), used for fault detection and continuous validation during crane operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous validation service calculates distance metrics between measured and simulated trajectories, comparing against predefined thresholds to ensure model accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol via Eclipse Mosquitto broker for inter-service communication and data exchange."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Docker containerized services (TimescaleDB, MQTT broker, Grafana) deployed on a personal computer with gantrylib Python module installed via pip."
]