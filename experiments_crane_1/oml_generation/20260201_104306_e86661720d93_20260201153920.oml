// C1: Environment and Components
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Controlled indoor lab environment for gantry crane research and digital twin validation."
    base:contains PhysicalGantryCrane, CraneController
]

instance PhysicalGantryCrane : DTDFVocab:Component [
    base:desc "Physical gantry crane system used for material handling or testing in a controlled lab environment."
    base:isContainedIn LabScaleGantryCraneEnvironment
]

instance CraneController : DTDFVocab:Component [
    base:desc "Embedded or programmable logic controller managing crane operations, including motion control and safety mechanisms."
    base:isContainedIn LabScaleGantryCraneEnvironment
]

