// ------------------------------------------------------------
// Physical Sensing Components
// ------------------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder measuring pendulum motion of the gantry crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting the crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoMotorStatusEncoder : DTDFVocab:SensingComponent [
    base:desc "Arduino-derived motor status and encoder readouts"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

instance TMC4671EvalMotorCurrentFeedback : DTDFVocab:SensingComponent [
    base:desc "Motor current feedback from TMC4671-Eval controller"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance TMC4671EvalMotorPositionFeedback : DTDFVocab:SensingComponent [
    base:desc "Motor position feedback from TMC4671-Eval controller"
    DTDFVocab:producedData MotorPositionDataTransmitted
]

// ------------------------------------------------------------
// Data Transmitted Components
// ------------------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoMotorStatusEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TMC4671EvalMotorCurrentFeedback
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TMC4671EvalMotorPositionFeedback
]

// ------------------------------------------------------------
// Data Objects
// ------------------------------------------------------------
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time-series data of swing angle measured by encoder"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData SwingAngleDataTransmitted
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time-series data of wind speed measured by anemometer"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData WindSpeedDataTransmitted
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Time-series data of motor status and encoder readouts from Arduino"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData MotorStatusDataTransmitted
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time-series data of motor current from TMC4671-Eval controller"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData MotorCurrentDataTransmitted
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Time-series data of motor position from TMC4671-Eval controller"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData MotorPositionDataTransmitted
]

// ------------------------------------------------------------
// Enablers
// ------------------------------------------------------------
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database, PostgreSQL extension for time-series storage"
    DTDFVocab:enables ServiceLoggingApplication, ServiceContinuousValidation
]

instance PythonRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime used to implement services and physical interfaces"
    DTDFVocab:enables ServiceTrajectoryGenerator, ServiceSimulation, ServiceLoggingApplication, ServiceContinuousValidation
]

instance DockerContainerizationEnabler : DTDFVocab:Enabler [
    base:desc "Docker containerization to package each service or component"
    DTDFVocab:enables ServiceLoggingApplication, ServiceContinuousValidation, ServiceTrajectoryGenerator, ServiceSimulation, ServiceDashboard, ServiceMQTTBroker
]

instance DockerComposeOrchestrationEnabler : DTDFVocab:Enabler [
    base:desc "Docker Compose orchestration for multi-container deployment"
    DTDFVocab:enables ServiceLoggingApplication, ServiceContinuousValidation, ServiceTrajectoryGenerator, ServiceSimulation, ServiceDashboard, ServiceMQTTBroker
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboards for real-time visualization of time-series data"
    DTDFVocab:enables ServiceDashboard
]

instance EclipseMosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter-service messaging"
    DTDFVocab:enables ServiceMQTTBroker
]

instance CapellaArcadiaModelEnabler : DTDFVocab:Enabler [
    base:desc "Capella Arcadia MBSE models for design and analysis"
]

// ------------------------------------------------------------
// Models
// ------------------------------------------------------------
instance CADFusion360Model : DTDFVocab:Model [
    base:desc "CAD model of the laboratory-scale gantry crane created in Autodesk Fusion 360"
    DTDFVocab:inputTo CapellaArcadiaModelEnabler
]

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator Service for optimal trajectory planning"
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics simulation model of crane dynamics used by the Simulation Service"
    DTDFVocab:inputTo PythonRuntimeEnabler
]

// ------------------------------------------------------------
// Services
// ------------------------------------------------------------
instance ServiceLoggingApplication : DTDFVocab:Service [
    base:desc "Logging Application continuously records crane state into TimescaleDB"
    DTDFVocab:provides InsightStateRecording
]

instance ServiceContinuousValidation : DTDFVocab:Service [
    base:desc "Continuous Validation Service compares executed trajectory measurements with simulated ones to compute distance metrics and threshold alerts"
    DTDFVocab:provides InsightValidationMetrics, InsightFaultAlerts
]

instance ServiceTrajectoryGenerator : DTDFVocab:Service [
    base:desc "Trajectory Generator Service uses kinematic model to compute optimal trajectory plans"
    DTDFVocab:provides InsightTrajectoryPlan
]

instance ServiceSimulation : DTDFVocab:Service [
    base:desc "Simulation Service performs physics simulation of crane dynamics"
    DTDFVocab:provides InsightPhysicsSimulation
]

instance ServiceDashboard : DTDFVocab:Service [
    base:desc "Dashboard Service displays real-time trajectory plots, sensor streams, and validation alerts via Grafana"
    DTDFVocab:provides InsightRealtimeVisualization
]

instance ServiceMQTTBroker : DTDFVocab:Service [
    base:desc "MQTT Broker (Eclipse Mosquitto) provides inter-service messaging"
    DTDFVocab:provides InsightMessagingSupport
]

// ------------------------------------------------------------
// Insights
// ------------------------------------------------------------
instance InsightStateRecording : DTDFVocab:Insight [
    base:desc "Continuous state recording of crane variables into TimescaleDB"
]

instance InsightValidationMetrics : DTDFVocab:Insight [
    base:desc "Distance metrics and threshold alerts computed by Continuous Validation Service"
]

instance InsightFaultAlerts : DTDFVocab:Insight [
    base:desc "Alerting enabled by continuous validation to detect fault conditions"
]

instance InsightTrajectoryPlan : DTDFVocab:Insight [
    base:desc "Optimal trajectory plans generated by Trajectory Generator Service"
]

instance InsightPhysicsSimulation : DTDFVocab:Insight [
    base:desc "Physics simulation results of crane dynamics"
]

instance InsightRealtimeVisualization : DTDFVocab:Insight [
    base:desc "Real-time visualization of trajectory plots, sensor streams, and validation alerts via Grafana"
]

instance InsightMessagingSupport : DTDFVocab:Insight [
    base:desc "Embedded MQTT messaging support between services"
]

// ------------------------------------------------------------
// Actions
// ------------------------------------------------------------
instance ActionScheduleMaintenance : DTDFVocab:Action [
    base:desc "Schedule maintenance based on validation metric thresholds"
    DTDFVocab:IsAutomatic true
]

instance ActionTuneController : DTDFVocab:Action [
    base:desc "Tune controller parameters based on trajectory quality metrics"
    DTDFVocab:IsAutomatic false
]

instance ActionHandleFault : DTDFVocab:Action [
    base:desc "Proactive fault handling triggered by validation alerts"
    DTDFVocab:IsAutomatic true
]

// ------------------------------------------------------------
// Physical Components
// ------------------------------------------------------------
instance PhysicalCraneComponent : DTDFVocab:Component [
    base:desc "Laboratory-scale gantry crane inspired by harbor cranes in Antwerp"
]

instance CartStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling cart stepper motor via Crane Interface"
]

instance HoistStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling hoist stepper motor via Crane Interface"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for activating electromagnet to pick up containers"
]

instance CraneInterfaceActuator : DTDFVocab:ActingComponent [
    base:desc "Digital twin interface that sends control commands to cart and hoist motors and receives state from physical crane"
]

// ------------------------------------------------------------
// Environment
// ------------------------------------------------------------
instance EnvironmentLaboratoryScaleGantryCrane : DTDFVocab:Environment [
    base:contains PhysicalCraneComponent, CartStepperMotorActuator, HoistStepperMotorActuator, ElectromagnetActuator, CraneInterfaceActuator, SwingAngleEncoder, Anemometer, ArduinoMotorStatusEncoder, TMC4671EvalMotorCurrentFeedback, TMC4671EvalMotorPositionFeedback
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal, swing‑free motion trajectories using the crane’s kinematic model. These trajectories are passed to the Control Application, which dispatches motion commands to the crane interface, driving the motors and electromagnet. Upon threshold breaches, the Continuous Validation Service triggers visual alerts on the Grafana dashboard, giving operators the opportunity to intervene manually; no automated actuator adjustments are performed by the twin."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All twin services operate in continuous real‑time, engaging at the same sampling cadence as the control loop (order of milliseconds to seconds). Data acquisition, logging and validation run concurrently with crane operation, enabling immediate feedback and operator intervention."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical Crane – physical hardware; Crane Interface – Python program connecting to hardware controllers; Control Application – Python app that drives the crane; Logging Application – logs state to TimescaleDB; MQTT Broker – messaging backbone; Database – TimescaleDB; Dashboard – Grafana; Trajectory Generator Service – generates movement plans; Simulation Service – simulates crane dynamics; Continuous Validation Service – compares execution against simulation; all orchestrated via Docker containers and local networking"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design – CAD and Arcadia models developed in Autodesk Fusion360 and Capella/Arcadia. Manufacturing – BOM and Arduino shield fabricated in KiCad, parts assembled into the crane. Operated – the assembled crane is connected via USB/serial to a PC; the gantrylib Python module runs the interface, control, logging and HMI, with Docker‑managed services for DB, broker and dashboard."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service compares real‑world sensor data with simulated trajectory outputs, computes distance metrics and flags deviations exceeding predefined thresholds, ensuring model validity; the kinematic model and simulation provide faithful representation of crane physics"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical crane connects to the host PC via USB serial to the Arduino; the Python interface communicates over serial to the Arduino; inter‑service communication occurs through MQTT (TCP) and local database writes via PostgreSQL drivers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All Digital Twin services containerized using Docker and orchestrated with Docker‑Compose, running locally on a personal computer; the physical crane is connected to the same host via serial or USB; database, MQTT broker and Grafana dashboard run in separate Docker containers"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "No explicit adherence to industry or interoperability standards is referenced; the twin relies on open‑source tools and a C4 model for architectural description."
]