// C3: Physical sensing components
instance PositionSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Position sensor providing real‑time crane position measurements"
    DTDFVocab:producedData PositionDataTransmitted
]

instance SpeedSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Speed sensor providing real‑time crane speed measurements"
    DTDFVocab:producedData SpeedDataTransmitted
]

instance AccelerationSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Acceleration sensor measuring crane acceleration"
    DTDFVocab:producedData AccelerationDataTransmitted
]

instance LoadSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Load sensor measuring payload weight on crane"
    DTDFVocab:producedData LoadDataTransmitted
]

// C4: Physical‑to‑virtual interaction
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensingComponent
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SpeedSensingComponent
]

instance AccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AccelerationSensingComponent
]

instance LoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadSensingComponent
]

// C10: Models/Data
instance PositionTelemetry : DTDFVocab:Data [
    base:desc "Time‑series telemetry of crane position logged in TimescaleDB via TCP PostgreSQL"
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance SpeedTelemetry : DTDFVocab:Data [
    base:desc "Time‑series telemetry of crane speed logged in TimescaleDB"
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance AccelerationTelemetry : DTDFVocab:Data [
    base:desc "Time‑series telemetry of crane acceleration logged in TimescaleDB"
    DTDFVocab:fromData AccelerationDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance LoadTelemetry : DTDFVocab:Data [
    base:desc "Time‑series telemetry of crane load logged in TimescaleDB"
    DTDFVocab:fromData LoadDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB enabler ingesting telemetry via TCP PostgreSQL connection"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker enabler publishing telemetry to local MQTT broker"
    DTDFVocab:enables ContinuousValidationWorkflowService, DataVisualizationDashboardService
]

// C6: Services
instance OptimalMotionControlService : DTDFVocab:Service [
    base:desc "Optimal motion‑control synthesis for the crane, providing real‑time trajectory planning and speed modulation"
    DTDFVocab:provides PlanTrajectoryAction, TrajectoryInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Historical data logging recording state trajectories, control inputs, and sensor outputs for offline analysis"
    DTDFVocab:provides GenerateHistoricalLogAction, HistoricalDataInsight
]

instance DataVisualizationDashboardService : DTDFVocab:Service [
    base:desc "Data visualization dashboards rendering live and archived kinematic and operational metrics"
    DTDFVocab:provides RenderDashboardAction, DashboardMetricsInsight
]

instance ContinuousValidationWorkflowService : DTDFVocab:Service [
    base:desc "Continuous validation workflows comparing real‑time measurements with the kinematic model to detect deviations and faults"
    DTDFVocab:provides ValidateRealTimeAction, DeviationDetectionInsight
]

// C11: Actions
instance PlanTrajectoryAction : DTDFVocab:Action [
    base:desc "Action to plan optimal trajectory based on current state"
    DTDFVocab:IsAutomatic true
]

instance GenerateHistoricalLogAction : DTDFVocab:Action [
    base:desc "Action to generate and store historical logs of state trajectories"
    DTDFVocab:IsAutomatic true
]

instance RenderDashboardAction : DTDFVocab:Action [
    base:desc "Action to render live and archived metrics in dashboards"
    DTDFVocab:IsAutomatic true
]

instance ValidateRealTimeAction : DTDFVocab:Action [
    base:desc "Action to validate real‑time measurements against model predictions to detect faults"
    DTDFVocab:IsAutomatic true
]

// C11: Insights
instance TrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight into optimal trajectory and speed modulation for crane operation"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight derived from historical logs of state trajectories and control inputs"
]

instance DashboardMetricsInsight : DTDFVocab:Insight [
    base:desc "Insight into live and archived kinematic and operational metrics from dashboards"
]

instance DeviationDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight into deviations detected by continuous validation workflows"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are issued by the Control Application, which uses the Physical Crane Interface to send movement instructions directly to the crane controllers. Commands are represented as plain Python dictionaries containing target joint positions, velocities, and trajectory parameters, serialized as JSON and transmitted over the same TCP interface used for sensing. The physical hardware acknowledges each command via status flags returned in the next sensor poll. While no explicit authentication or access control mechanisms are detailed, the Control Application operates locally on the operator’s workstation. Conflict resolution is delegated to the crane’s built‑in safety interlocks."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "GreenhouseDT orchestrates its digital twin through an event‑driven architecture, where sensor readings and twin model updates are passed via an ActiveMQ JMS broker and persisted in an InfluxDB time‑series database. Each component—sensor interface, model logic, adaptation engine—is packaged in a separate virtual machine image, simplifying deployment and isolation. The Air Quality Management exemplar uses a Raspberry‑Pi host for physical sensors, models the plant via AutomationML for formal description, and pipelines data through Microsoft Azure services (IoT Hub, Azure Functions) for runtime visualization, simulation and prediction. The lab‑scale gantry crane adopts a similar ad‑hoc composition; its control logic and twin representations are containerised, and inter‑service communication is mediated by message queues (ActiveMQ in GreenhouseDT; Azure Event Grid in Air‑Quality). No centralized twin orchestration framework is employed, and coordination between instances relies on the broker and explicit messaging contracts."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT services communicate through a local MQTT broker (e.g., Mosquitto) running over TCP for publish/subscribe messaging between services such as the Trajectory Generator, Simulation Service, and Continuous Validation Service. Database interactions use the PostgreSQL protocol over TCP to a TimescaleDB instance, while Grafana dashboards connect over HTTP/HTTPS to visualize data queried from TimescaleDB. The network topology is a flat local‑host or LAN configuration with low latency (<1 ms). Reliability is supported by MQTT persistent sessions and TimescaleDB’s inherent replication features, though explicit redundancy mechanisms are not specified."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is performed through standard protocols and cloud services. In GreenhouseDT, sensor firmware on Raspberry‑Pi devices publishes data to ActiveMQ, which forwards it to InfluxDB; external stakeholders can subscribe to the broker or query the time‑series database. The Air Quality Management prototype exposes its twin via a Microsoft Azure IoT Hub, delivering telemetry to Azure Functions and Azure Machine Learning for real‑time prediction, thereby enabling integration with other Azure‑based digital twins or enterprise systems. The gantry crane case, while not explicitly detailed, follows a containerised approach that can expose RESTful APIs or message queues to upstream logistics or SCADA systems, enabling interoperability via HTTP/REST and JMS. The exemplars rely on standard open‑source tools rather than proprietary integration layers, ensuring interoperability across heterogeneous environments."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital‑twin modelling layer in the Air‑Quality Management exemplar is expressed in AutomationML, an ISO‑based interchange format for plant and automation systems (ISO 11782). The exemplar also relies on Microsoft Azure’s IoT Hub and Stream Analytics services, which adhere to Azure’s reference architecture for the Internet of Things and comply with Azure Industrial IoT security guidelines. No other industry certification or interoperability framework is mentioned."
]