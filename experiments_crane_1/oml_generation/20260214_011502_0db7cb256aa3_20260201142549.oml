// Acting Components
instance CartMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Cartesian cart motor driven by a Trinamic TMC4671‑Eval controller"
]
instance HoistMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Hoist motor driven by a Trinamic TMC4671‑Eval controller and coupled to an electromagnet"
]
instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet powered by the hoist motor that physically moves the container via its magnetic field"
]

// Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder mounted on the hoist to track residual oscillation"
    DTDFVocab:producedData SwingAngleDataTrans
]
instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed"
    DTDFVocab:producedData AnemometerDataTrans
]
instance CartMotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder output from the cart motor reporting position and velocity"
    DTDFVocab:producedData CartMotorEncoderDataTrans
]
instance HoistMotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder output from the hoist motor reporting position and velocity"
    DTDFVocab:producedData HoistMotorEncoderDataTrans
]

// Data Transmitted
instance SwingAngleDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance AnemometerDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]
instance CartMotorEncoderDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoderSensor
]
instance HoistMotorEncoderDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoderSensor
]

// Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series data of swing angle measurements from the hoist"
    DTDFVocab:fromData SwingAngleDataTrans
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance AnemometerData : DTDFVocab:Data [
    base:desc "Time‑series data of ambient wind speed from the anemometer"
    DTDFVocab:fromData AnemometerDataTrans
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance CartMotorEncoderData : DTDFVocab:Data [
    base:desc "Time‑series data of cart motor encoder outputs"
    DTDFVocab:fromData CartMotorEncoderDataTrans
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance HoistMotorEncoderData : DTDFVocab:Data [
    base:desc "Time‑series data of hoist motor encoder outputs"
    DTDFVocab:fromData HoistMotorEncoderDataTrans
    DTDFVocab:inputTo TimescaleDBEnabler
]

// Models
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "3‑D CAD geometry of the crane used for rendering and collision detection"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]
instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model applying a swing‑free motion profile for trajectory generation"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]
instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model used by the continuous validation service to compare against real trajectories"
    DTDFVocab:inputTo ContinuousValidationEnabler
]

// Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database instance enabling time‑series data storage for logging"
    DTDFVocab:enables LoggingService
]
instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Mosquitto MQTT broker enabling real‑time telemetry publish/subscribe for validation and simulation"
    DTDFVocab:enables ContinuousValidationService, SimulationService, TrajectoryGeneratorService
]
instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana analytics dashboard enabling real‑time visualization of telemetry and alerts"
    DTDFVocab:enables VisualizationService
]
instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Enabler providing simulation of the kinematic model for generating optimized trajectories"
    DTDFVocab:enables TrajectoryGeneratorService
]
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler executing the physics‑simulation model for trajectory comparison"
    DTDFVocab:enables SimulationService
]
instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler running the continuous validation process using sensor telemetry and simulation model"
    DTDFVocab:enables ContinuousValidationService
]

// Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Service that streams crane telemetry to a local TimescaleDB instance for long‑term archiving"
    DTDFVocab:provides DataLoggedInsight, ArchiveAction
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that compares executed trajectories against simulated replicas, computing distance metrics and flagging threshold breaches"
    DTDFVocab:provides TrajectoryDeviationAlert, TakeCorrectiveAction
]
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service that applies the kinematic model to produce optimal, swing‑free motion profiles"
    DTDFVocab:provides OptimizedMotionInsight, AdjustMotorCommands
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Service that reproduces the crane’s motion for a given plan using the physics‑based simulation model"
    DTDFVocab:provides SimulationResultInsight
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboard service providing real‑time plots, confidence bounds, and alert panels"
    DTDFVocab:provides VisualizationReadyInsight
]

// Insights
instance DataLoggedInsight : DTDFVocab:Insight [
    base:desc "Indicator that telemetry data has been successfully archived in TimescaleDB"
]
instance TrajectoryDeviationAlert : DTDFVocab:Insight [
    base:desc "Alert indicating that a trajectory deviation exceeded predefined thresholds"
]
instance OptimizedMotionInsight : DTDFVocab:Insight [
    base:desc "Insight that an optimized motion plan has been generated"
]
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight presenting results from the physics simulation"
]
instance VisualizationReadyInsight : DTDFVocab:Insight [
    base:desc "Indicates that the Grafana dashboard is updated with current telemetry and alerts"
]

// Actions
instance ArchiveAction : DTDFVocab:Action [
    base:desc "Automatic action to archive telemetry data into TimescaleDB"
    DTDFVocab:IsAutomatic true
]
instance TakeCorrectiveAction : DTDFVocab:Action [
    base:desc "Automatic action for operators to take corrective measures when trajectory deviations are detected"
    DTDFVocab:IsAutomatic true
]
instance AdjustMotorCommands : DTDFVocab:Action [
    base:desc "Automatic action to adjust cart and hoist motor commands to follow the optimized trajectory"
    DTDFVocab:IsAutomatic true
]

// Components (Physical and Virtual Containers)
instance PhysicalCraneContainer : DTDFVocab:Component [
    base:desc "Physical lab‑scale gantry crane moving small pucks between defined locations"
]
instance CraneInterfaceContainer : DTDFVocab:Component [
    base:desc "Hardware interface linking the physical crane to the control electronics"
]
instance ControlApplicationContainer : DTDFVocab:Component [
    base:desc "Python application running on the Arduino crate that reads sensors and exposes data to the control interface"
]
instance LoggingApplicationContainer : DTDFVocab:Component [
    base:desc "Container running the LoggingService to stream telemetry to TimescaleDB"
]
instance HMIDContainer : DTDFVocab:Component [
    base:desc "Human‑Machine Interface providing operator controls and status displays"
]
instance TimescaleDBContainer : DTDFVocab:Component [
    base:desc "TimescaleDB database instance handling time‑series telemetry storage"
]
instance GrafanaContainer : DTDFVocab:Component [
    base:desc "Grafana dashboard container for real‑time visualization"
]
instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Container running the TrajectoryGeneratorService"
]
instance SimulationContainer : DTDFVocab:Component [
    base:desc "Container running the SimulationService"
]
instance ContinuousValidationContainer : DTDFVocab:Component [
    base:desc "Container running the ContinuousValidationService"
]
instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Mosquitto MQTT broker container for telemetry publish/subscribe"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, executed in Python, generates trajectory commands (desired cart and hoist positions) and forwards them through the Crane Interface to the physical motor controllers; operator‑initiated commands from the HMI are also routed via the Control Application to the interface. MQTT is used solely for inter‑service signalling."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates continuously; data are ingested as frequently as the physical sensors sample, and services such as validation, trajectory planning, and simulation are triggered by incoming data or by explicit operator requests. No fixed time‑step is defined in the documentation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin is orchestrated by a Docker Compose stack consisting of the database, MQTT broker, dashboard, trajectory generator, simulation, and continuous validation containers.  The physical side runs a Python control application, interface, and logging modules, all interconnected through MQTT and database writes, achieving a coherent cyber‑physical system."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (CAD models in Autodesk Fusion360 and Capella/Arcadia models), Manufacturing (BOM and Arduino shield design in KiCad), Operation (real‑time data logging, trajectory execution, continuous validation, and visualization)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by a continuous‑validation service that compares real‑time sensor data against the simulation’s expected trajectory, computing a distance metric and flagging deviations beyond a preset threshold; no formal model verification is reported; validity is maintained through runtime comparison."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The physical hardware communicates with the twin via a local serial/USB interface (Arduino and TMC4671‑Eval drivers). Data and control commands are routed through Python processes; inter‑service messages are exchanged over a local Mosquitto MQTT broker; data visualisation retrieves entries via Grafana’s native TimescaleDB connector. All components reside on the same personal computer and communicate over the local Docker network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin stack is containerised and deployed via Docker Compose on a single personal computer (host machine).  The GitHub repository hosts configuration files, Dockerfiles, and scripts.  Documentation is served through MkDocs on GitHub Pages.  All components run locally, with no cloud deployment noted."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "No explicit integration with external DTs or enterprise systems is described; the twin operates in isolation using open‑source components."
]