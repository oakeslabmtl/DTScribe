// C2: Acting Components
instance CraneFrame : DTDFVocab:ActingComponent [
    base:desc "Physical structure of the lab-scale gantry crane system inspired by harbor cranes in the port of Antwerp"
]

instance HorizontalCartMotorController : DTDFVocab:Actuator [
    base:desc "Stepper motor (TMC4671-Eval controller) for horizontal movement of the crane cart"
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance VerticalHoistMotorController : DTDFVocab:Actuator [
    base:desc "Stepper motor (TMC4671-Eval controller) for vertical movement of the hoist"
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance ElectromagnetPickup : DTDFVocab:Actuator [
    base:desc "Electromagnet at the hoist end for picking up small pucks (representing containers)"
    DTDFVocab:producedFrom ArduinoSensorInterface
]

instance ArduinoControlBoard : DTDFVocab:Actuator [
    base:desc "Arduino board for sensor control, interfacing, and motor coordination in the crane system"
    DTDFVocab:producedFrom SwingAngleEncoder, Anemometer, ArduinoSensorInterface
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swinging motion of the hoist in the lab-scale gantry crane system"
    DTDFVocab:producedData SwingAngleData
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Device measuring wind speed for environmental monitoring in the crane operation"
    DTDFVocab:producedData WindSpeedData
]

instance ArduinoSensorInterface : DTDFVocab:SensingComponent [
    base:desc "Arduino board measuring and interfacing electromagnet status, swing angle, and wind speed"
    DTDFVocab:producedData ArduinoInterfaceData
]

// C4: Physical-to-virtual interaction
instance SwingAngleData : DTDFVocab:Data [
    DTDFVocab:fromData SwingAngleEncoder
]

instance WindSpeedData : DTDFVocab:Data [
    DTDFVocab:fromData Anemometer
]

instance ArduinoInterfaceData : DTDFVocab:Data [
    DTDFVocab:fromData ArduinoSensorInterface
]

// C10: Models/Data
instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "CAD-based kinematic models for trajectory generation and simulation of the crane system"
]

instance OperationalHistoryDatabase : DTDFVocab:Data [
    base:desc "TimescaleDB database storing historical operational data and simulation results for performance analysis"
    DTDFVocab:inputTo TrajectoryExecutionMetrics, EnvironmentalConditionsData
]

instance ArcadiaSystemModel : DTDFVocab:Model [
    base:desc "Capella-based Arcadia models for Model-Based Systems Engineering demonstrations"
]

instance TrajectoryExecutionMetrics : DTDFVocab:Data [
    DTDFVocab:fromData SwingAngleData, ArduinoInterfaceData
]

instance EnvironmentalConditionsData : DTDFVocab:Data [
    DTDFVocab:fromData WindSpeedData
]

// C11: Enablers
instance PythonGantryLibModule : DTDFVocab:Enabler [
    base:desc "Python-based gantrylib module for crane control and digital twin services"
    DTDFVocab:enables TrajectoryOptimizationService, ContinuousValidationService
]

instance DockerContainerization : DTDFVocab:Enabler [
    base:desc "Containerization platform for orchestrating modular services via Docker Compose"
    DTDFVocab:enables TrajectoryOptimizationService, DataLoggingService, ContinuousValidationService, HumanMachineInterfaceService
]

instance TimescaleDBDatabase : DTDFVocab:Enabler [
    base:desc "PostgreSQL-based TimescaleDB for time-series data logging and storage"
    DTDFVocab:inputTo DataLoggingService
]

instance GrafanaVisualization : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for data visualization showing real-time and simulated trajectory traces"
]

instance MosquittoMQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for service communication between digital twin components"
    DTDFVocab:enables TrajectoryOptimizationService, ContinuousValidationService, HumanMachineInterfaceService
]

instance ArduinoHardwareInterface : DTDFVocab:Enabler [
    base:desc "Arduino board for sensor/actuator interfacing with physical crane components"
    DTDFVocab:inputTo SwingAngleData, WindSpeedData, ArduinoInterfaceData
]

instance DockerComposeDeployment : DTDFVocab:Enabler [
    base:desc "Docker Compose configuration for centralized deployment of containerized services"
    DTDFVocab:inputTo DockerContainerization
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Real-time insight from trajectory generation eliminating residual swinging motion and improving efficiency"
]

instance ContinuousValidationInsight : DTDFVocab:Insight [
    base:desc "Continuous validation comparing real-world execution with simulations to detect faults (e.g., motor issues)"
]

instance HistoricalDataAnalysis : DTDFVocab:Insight [
    base:desc "Analysis of historical operational data for performance metrics and predictive maintenance"
]

instance ModelBasedEvolutionInsight : DTDFVocab:Insight [
    base:desc "Support for future system upgrades and adaptations using DarTwin notation for model evolution"
]

instance ResidualMotionReductionAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of trajectory parameters to minimize residual swinging motion"
    DTDFVocab:IsAutomatic true
]

instance FaultDetectionNotification : DTDFVocab:Action [
    base:desc "Dashboard alerts for operators regarding detected faults (e.g., motor issues)"
    DTDFVocab:IsAutomatic false
]

instance PerformanceAnalysisReport : DTDFVocab:Action [
    base:desc "Generated report from historical data for maintenance planning"
    DTDFVocab:IsAutomatic true
]

// C6: Services
instance TrajectoryOptimizationService : DTDFVocab:Service [
    base:desc "Service generating optimal trajectories using kinematic models to eliminate residual swinging motion"
    DTDFVocab:provides OptimalTrajectoryInsight, ResidualMotionReductionAction
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service continuously recording operational metrics into TimescaleDB database"
    DTDFVocab:provides HistoricalDataAnalysis
]

instance VisualizationDashboard : DTDFVocab:Service [
    base:desc "Service providing real-time and simulated trajectory visualization through Grafana"
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service comparing real-world execution with simulations for continuous validation and fault detection"
    DTDFVocab:provides ContinuousValidationInsight, FaultDetectionNotification
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Service enabling operator control and monitoring through HMI"
    DTDFVocab:provides FaultDetectionNotification
]

// C12: Relationships between Enablers and Services
DockerContainerization enables TrajectoryOptimizationService, DataLoggingService, ContinuousValidationService, HumanMachineInterfaceService
PythonGantryLibModule enables TrajectoryOptimizationService, ContinuousValidationService
TimescaleDBDatabase inputTo DataLoggingService
GrafanaVisualization inputTo VisualizationDashboard
MosquittoMQTTBroker enables TrajectoryOptimizationService, ContinuousValidationService, HumanMachineInterfaceService
ArduinoHardwareInterface inputTo SwingAngleData, WindSpeedData, ArduinoInterfaceData
DockerComposeDeployment inputTo DockerContainerization

// C13: Relationships between Services and Insights/Actions
TrajectoryOptimizationService provides OptimalTrajectoryInsight
ContinuousValidationService provides ContinuousValidationInsight
DataLoggingService provides HistoricalDataAnalysis
ContinuousValidationService provides FaultDetectionNotification
HumanMachineInterfaceService provides FaultDetectionNotification

// C14: Environment
instance CraneSystemEnvironment : DTDFVocab:Environment [
    base:contains CraneFrame, HorizontalCartMotorController, VerticalHoistMotorController, ElectromagnetPickup, ArduinoControlBoard
]

instance DigitalTwinServicesEnvironment : DTDFVocab:Environment [
    base:contains TrajectoryOptimizationService, DataLoggingService, VisualizationDashboard, ContinuousValidationService, HumanMachineInterfaceService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "['Optimal trajectory generation service sends movement commands to the crane\u2019s controller via the Control Application.', 'Simulation service provides virtual trajectories for continuous validation, which are compared against real-world execution.', 'Continuous validation service notifies operators of deviations via the dashboard if thresholds are breached, triggering manual intervention.']"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real-time synchronization between physical and digital systems, with validation metrics updated dynamically during operation. The system supports near-instantaneous data flow and validation checks during execution."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "['Physical Crane (hardware) + Physical Crane Interface (Python) + Control Application (Python) + Logging Application (Python) + HMI (Python) form the physical system.', 'Digital Twin: Database (TimescaleDB) \u2194 Dashboard (Grafana) \u2194 Trajectory Generator Service \u2194 Simulation Service \u2194 Continuous Validation Service \u2194 MQTT Broker (Eclipse Mosquitto).', 'Containerized deployment via Docker Compose for orchestration and network management.']"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "['As designed (ideal): CAD models and kinematic models for trajectory planning.', 'As manufactured: Physical crane hardware with actual motor controllers and sensors.', 'As operated: Real-time operation with continuous validation and fault detection.']"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "['Verification: Kinematic models and simulation services validate digital twin accuracy against real-world data.', 'Validation: Continuous validation service compares real-world execution with simulations using distance metrics and thresholds.', 'Uncertainty: Wind speed measurements (via anemometer) and encoder readings are used for real-time adjustments.', 'Errors: Fault detection methods (time-series classification) identify deviations from expected behavior.']"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "['MQTT protocol for real-time service communication between digital twin components.', 'Networked via Docker containers on a single personal computer for simplicity.', 'Database (TimescaleDB) and dashboard (Grafana) communicate via RESTful APIs or direct database queries.']"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "['Hosted on a single personal computer with Docker containers for services (Database, MQTT Broker, Dashboard).', 'Docker Compose file automates deployment and initialization of services.', 'Open-source tools (Python, Docker, TimescaleDB, Grafana, Mosquitto) ensure accessibility.', 'GitHub repository provides installation instructions and documentation.']"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "['Not explicitly detailed in the documents, but could include integration with external systems like container identification or buoyancy models for harbor-scale simulations (mentioned in teaching extensions).']"
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "['Data is owned by the physical system operator (crane lab) as the exemplar is open-source and freely available.', 'No explicit mention of privacy safeguards, but operational data is logged in a time-series database (TimescaleDB) for research and educational use.']"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "['Open-source tools (Python, Docker, TimescaleDB, Grafana) are widely adopted but not tailored for digital twins.', 'CAD models use Autodesk Fusion 360 (proprietary), but Arcadia models (Capella) are for MBSE and not standardized for digital twins.', 'No mention of industry-specific digital twin frameworks (e.g., Eclipse Ditto, BaSyx).']"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "['Remote operation is not explicitly enabled; the system is designed for local use on a personal computer.', 'No mention of cybersecurity protocols (e.g., encryption, authentication) for data transmission.', 'Safety: Continuous validation ensures real-time monitoring of system deviations, but no explicit human-in-the-loop safety protocols for remote operations are described.']"
]