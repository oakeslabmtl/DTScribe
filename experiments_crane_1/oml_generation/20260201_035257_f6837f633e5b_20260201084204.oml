// Digital Twin OML model for a lab‑scale gantry crane

// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the crane cart, controlled by a TMC4671‑Eval controller"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist, controlled by a TMC4671‑Eval controller"
]

instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval controller for the cart stepper motor"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval controller for the hoist stepper motor"
]

instance EndEffectorElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist used to pick up and release containers"
]

// C3: Physical sensing components
instance HoistSwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the hoist"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed that influences crane dynamics"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoBoard : DTDFVocab:SensingComponent [
    base:desc "Arduino board acquiring sensor data and monitoring motor‑controller status"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistSwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoBoard
]

// C10: Data
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of hoist swing‑angle readings"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ValidationEnabler
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements from the anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ValidationEnabler
]

instance MotorStatusTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of motor positions and electromagnet status"
    DTDFVocab:fromData MotorStatusDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ValidationEnabler
]

// C10: Models/Data
instance CraneCADModel : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane (Autodesk Fusion360) used for visualization"
    DTDFVocab:inputTo GrafanaDashboardEnabler
]

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Kinematic model employed by the Trajectory Generator to compute optimal motion plans"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of the crane and its controllers used by the Simulation Service"
    DTDFVocab:inputTo SimulationEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) storing operational time‑series data"
    DTDFVocab:enables DataLoggingService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana container visualizing data from TimescaleDB"
    DTDFVocab:enables VisualizationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service messaging"
    DTDFVocab:enables TrajectoryGenerationService, SimulationService, ContinuousValidationService, HumanMachineInterfaceService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python process running the Trajectory Generator Service"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python process running the Crane Simulation Service"
    DTDFVocab:enables SimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Python process running the Continuous Validation Service"
    DTDFVocab:enables ContinuousValidationService
]

instance HumanMachineInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Human‑Machine Interface enabling operator interaction with the digital twin"
    DTDFVocab:enables HumanMachineInterfaceService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that continuously writes sensor and state data into TimescaleDB"
    DTDFVocab:provides DataLoggingInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Grafana service providing real‑time dashboards of crane status and trajectories"
    DTDFVocab:provides VisualizationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal motion plans using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Executes the virtual crane simulation based on the simulation model"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares measured trajectories with simulated ones and issues deviation alerts"
    DTDFVocab:provides DeviationMetricInsight, OperatorAlertAction
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Human‑Machine Interface allowing operators to approve trajectories and receive alerts"
    DTDFVocab:provides OperatorApproveAction
]

// C17: Insights
instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Persistent storage of time‑series operational data in TimescaleDB"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visual dashboards of crane state, sensor readings and trajectories"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal motion plan generated for the crane to follow"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation results of the virtual crane used for validation"
]

instance DeviationMetricInsight : DTDFVocab:Insight [
    base:desc "Quantitative deviation metrics comparing measured vs. simulated trajectories"
]

// C17: Actions
instance OperatorAlertAction : DTDFVocab:Action [
    base:desc "Alert sent to the operator when deviation exceeds predefined thresholds"
    DTDFVocab:IsAutomatic false
]

instance OperatorApproveAction : DTDFVocab:Action [
    base:desc "Operator approval to dispatch the optimal trajectory to the physical crane"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application uses the Physical Crane Interface to transmit motion commands (trajectory waypoints, speed profiles) and electromagnet activation signals to the motor controllers and Arduino. Trajectories generated by the Trajectory Generator Service are forwarded through the same interface to the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The PT is connected to a Python‑based Physical Crane Interface which feeds sensor data to the Logging Application and receives commands from the Control Application. All digital services (trajectory generation, simulation, validation, visualization) communicate via MQTT and share state through the TimescaleDB. The three core infrastructure containers (database, MQTT broker, dashboard) are Dockerized and orchestrated by Docker Compose on a single personal computer."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured executed trajectories with simulated trajectories, computes distance metrics, and checks them against predefined thresholds. Breaches trigger alerts on the Grafana dashboard for operator intervention, ensuring model fidelity is monitored during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT services uses a Python interface over USB/serial to the Arduino and motor controllers, MQTT (Eclipse Mosquitto) for inter‑service messaging, and SQL over TCP for TimescaleDB access. All components share a Docker‑managed virtual network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital‑twin components are hosted locally on a personal computer. The database, MQTT broker, and Grafana dashboard run as Docker containers; other services run as Python processes within the same host. Deployment is automated with a Docker Compose file that starts and configures the entire stack with a single command."
]