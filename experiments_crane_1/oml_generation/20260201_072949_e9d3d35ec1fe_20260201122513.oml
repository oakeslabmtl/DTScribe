// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder sensor on the crane cart measuring the pendulum angle."
    DTDFVocab:producedData AngleDataTransmitted
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting the crane during operation."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the cart motor measuring rotational position and speed."
    DTDFVocab:producedData CartMotorDataTransmitted
]

instance HoistMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the hoist motor measuring lift position and speed."
    DTDFVocab:producedData HoistMotorDataTransmitted
]

instance ArduinoMicrocontroller : DTDFVocab:SensingComponent [
    base:desc "Arduino microcontroller aggregating sensor data and forwarding via MQTT."
    DTDFVocab:producedData ArduinoTelemetryDataTransmitted
]

// C4: Physical-to-virtual interaction
instance AngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance CartMotorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoder
]

instance HoistMotorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoder
]

instance ArduinoTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoMicrocontroller
]

// Data instances
instance AngleMeasurementData : DTDFVocab:Data [
    base:desc "Recorded swing angle values logged into TimescaleDB."
    DTDFVocab:fromData AngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedMeasurementData : DTDFVocab:Data [
    base:desc "Recorded wind speed values logged into TimescaleDB."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance CartMotorMeasurementData : DTDFVocab:Data [
    base:desc "Recorded cart motor encoder counts and speed logged into TimescaleDB."
    DTDFVocab:fromData CartMotorDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HoistMotorMeasurementData : DTDFVocab:Data [
    base:desc "Recorded hoist motor encoder counts and speed logged into TimescaleDB."
    DTDFVocab:fromData HoistMotorDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance ArduinoTelemetryData : DTDFVocab:Data [
    base:desc "Aggregated telemetry forwarded by Arduino, logged into TimescaleDB."
    DTDFVocab:fromData ArduinoTelemetryDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers
instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestrator coordinating TimescaleDB, MQTT broker, Grafana, Trajectory Generator, Simulation, and Validation services."
    DTDFVocab:enables TrajectoryGenerationService, TrajectoryValidationService, CraneSimulationService, DataLoggingService, GrafanaVisualizationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database for time‑series logging of sensor telemetry."
    DTDFVocab:enables DataLoggingService
]

instance MosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker facilitating inter‑service communication."
    DTDFVocab:enables TrajectoryGenerationService, TrajectoryValidationService, CraneSimulationService
]

instance PythonRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime executing gantrylib scripts for trajectory generation and validation."
    DTDFVocab:enables TrajectoryGenerationService, TrajectoryValidationService, CraneSimulationService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard displaying real‑time crane telemetry and simulation results."
    DTDFVocab:enables GrafanaVisualizationService
]

instance MkDocsEnabler : DTDFVocab:Enabler [
    base:desc "MkDocs documentation generator for twin architecture and API."
]

// C10: Models/Data
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane defining physical dimensions used by simulation."
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the crane used by trajectory generator and simulation for optimal path planning."
    DTDFVocab:inputTo PythonRuntimeEnabler
]

// C6: Services
instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service generating optimal crane trajectories using the kinematic model and input constraints."
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance TrajectoryValidationService : DTDFVocab:Service [
    base:desc "Service validating executed trajectories against recorded telemetry, producing alerts."
    DTDFVocab:provides ValidationAlertInsight, TrajectoryComparisonInsight, FaultClassificationInsight, MaintenanceRecommendationInsight
]

instance CraneSimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation of crane motion using CAD geometry and kinematic model."
    DTDFVocab:provides SimulationInsight
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service recording telemetry data into TimescaleDB for analysis and model updating."
]

instance GrafanaVisualizationService : DTDFVocab:Service [
    base:desc "Service visualizing telemetry, simulation, and validation results on Grafana dashboards."
    DTDFVocab:provides VisualizationInsight
]

// C17: Insights
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the optimal trajectory plan for current task conditions."
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when executed trajectory deviates from planned trajectory."
]

instance TrajectoryComparisonInsight : DTDFVocab:Insight [
    base:desc "Comparison of planned versus actual trajectories for discrepancy analysis."
]

instance FaultClassificationInsight : DTDFVocab:Insight [
    base:desc "Classification of faults detected during validation as sensor, actuator, or control issues."
]

instance MaintenanceRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for preventive maintenance based on fault diagnostics."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Comparison of simulated motion with measured telemetry to assess model fidelity."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing live visual data presented on Grafana dashboards."
]

// C17: Actions
instance AdjustControllerParametersAction : DTDFVocab:Action [
    base:desc "Automatically adjust controller parameters based on continuous validation alerts."
    DTDFVocab:IsAutomatic true
]

instance UpdateTrajectoryPlanAction : DTDFVocab:Action [
    base:desc "Operator manually updates trajectory plan following validation insights."
    DTDFVocab:IsAutomatic false
]

instance PerformPreventiveMaintenanceAction : DTDFVocab:Action [
    base:desc "Operator performs scheduled preventive maintenance as indicated by diagnostics."
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance CartMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling the cart motor of the gantry crane."
]

instance HoistMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling the hoist motor of the gantry crane."
]

// C5: Environment
instance DockerComposeEnvironment : DTDFVocab:Environment [
    base:contains DockerComposeEnabler, TimescaleDBEnabler, MosquittoBrokerEnabler, PythonRuntimeEnabler, GrafanaDashboardEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital twin services generate control commands (e.g., optimal trajectories) which are transmitted via the Control Application to the crane’s motor controllers; continuous validation can alert operators through the dashboard."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All twin services operate in real‑time or near real‑time – continuous telemetry (milliseconds), trajectory planning and validation on demand, and real‑time visualization on the order of seconds."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated constellation of Docker containers (database, broker, dashboard) and Python applications (physical interface, control, logging, simulation, validation, trajectory generator) communicating over MQTT and local TCP, all deployed on a single personal computer."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the manufactured and operated stages: it logs real‑time operational data, validates behaviour against the kinematic model, and is used for fault detection during operation; design‑to‑manufacture validation is not explicitly described."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation involves comparing simulated trajectories with actual logged data using distance metrics and thresholds; the kinematic model’s fidelity and sensor accuracy are implicitly verified by continuous validation, though full physics modelling is pending."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical–digital data flows over USB/serial from Arduino to the physical interface; internal services communicate via MQTT (publish/subscribe) over local TCP; data persistence uses PostgreSQL (TimescaleDB) accessed over TCP."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted locally on a personal PC with Docker Compose managing containers; the codebase is open‑source on GitHub and the documentation is served via GitHub Pages."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "No explicit twin‑specific standards are adopted; the implementation relies on common open‑source tools (Docker, TimescaleDB, Grafana, MQTT) with an ad‑hoc architecture rather than a standardised twin framework."
]