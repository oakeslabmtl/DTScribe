import DTDFVocab

// -------------------------------------------------
// Physical Acting Components
// -------------------------------------------------
instance StepperMotorX : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the X‑axis of the gantry, interfaced via a dedicated stepper motor controller."
]

instance StepperMotorY : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the Y‑axis of the gantry, interfaced via a dedicated stepper motor controller."
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end‑effector used to grip or release lightweight pucks state is binary (on/off)."
]

// -------------------------------------------------
// Physical Sensing Components
// -------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder mounted on the crane to measure payload sway with sufficient angular resolution for validation.",
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer that records ambient airflow, providing disturbance information for the kinematic model.",
    DTDFVocab:producedData AirflowDataTransmitted
]

instance MagnetStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that reports the on/off state of the electromagnet actuator.",
    DTDFVocab:producedData MagnetStateDataTransmitted
]

// -------------------------------------------------
// Data Transmitted (Physical‑to‑Virtual Interaction)
// -------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AirflowDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MagnetStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MagnetStateSensor
]

// -------------------------------------------------
// Data Instances
// -------------------------------------------------
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurement (10‑100 Hz) forwarded to digital‑twin services.",
    DTDFVocab:fromData SwingAngleDataTransmitted,
    DTDFVocab:inputTo TimescaleDBLoggingEnabler,
    DTDFVocab:inputTo ContinuousValidationEnabler,
    DTDFVocab:inputTo WebDashboardEnabler
]

instance AirflowData : DTDFVocab:Data [
    base:desc "Time‑stamped airflow measurement (10‑100 Hz) used for disturbance modelling.",
    DTDFVocab:fromData AirflowDataTransmitted,
    DTDFVocab:inputTo TimescaleDBLoggingEnabler,
    DTDFVocab:inputTo ContinuousValidationEnabler,
    DTDFVocab:inputTo WebDashboardEnabler
]

instance MagnetStateData : DTDFVocab:Data [
    base:desc "Binary state (on/off) of the electromagnet recorded at Arduino sampling rates.",
    DTDFVocab:fromData MagnetStateDataTransmitted,
    DTDFVocab:inputTo TimescaleDBLoggingEnabler,
    DTDFVocab:inputTo ContinuousValidationEnabler,
    DTDFVocab:inputTo WebDashboardEnabler
]

// -------------------------------------------------
// Models
// -------------------------------------------------
instance CadModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the lab‑scale gantry crane used for visualization and simulation.",
    DTDFVocab:inputTo SimulationEngineEnabler,
    DTDFVocab:inputTo WebDashboardEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model capturing the crane’s motion, used by control, validation and simulation services.",
    DTDFVocab:inputTo OptimalControlEnabler,
    DTDFVocab:inputTo ContinuousValidationEnabler,
    DTDFVocab:inputTo SimulationEngineEnabler
]

// -------------------------------------------------
// Enablers (Technical Enablers)
// -------------------------------------------------
instance TimescaleDBLoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance streaming continuous sensor and actuator state measurements for historic logging.",
    DTDFVocab:enables HistoricalDataLoggingService
]

instance InfluxDBPredictionEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series store used by the prediction module to extrapolate future environmental conditions.",
    DTDFVocab:enables PredictionService
]

instance WebDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard (Docker‑containerised) that visualises live sensor data, crane state and simulation results.",
    DTDFVocab:enables DataVisualizationService
]

instance OptimalControlEnabler : DTDFVocab:Enabler [
    base:desc "Control engine (Docker container) that computes optimal motion commands from the kinematic model.",
    DTDFVocab:enables OptimalControlService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Validation engine that continuously compares real‑time measurements with the kinematic model.",
    DTDFVocab:enables ContinuousValidationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs what‑if scenarios using CAD and kinematic models.",
    DTDFVocab:enables SimulationService
]

// -------------------------------------------------
// Services
// -------------------------------------------------
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal‑control service that computes and sends motion commands to the crane controller.",
    DTDFVocab:provides SendMotionCommandAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Historical‑data‑logging service that records sensor and actuation data into TimescaleDB.",
    DTDFVocab:provides LoggingInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Data‑visualisation service that displays live sensor readings, crane state and simulation outputs on a web dashboard.",
    DTDFVocab:provides VisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous‑validation service that compares real‑time measurements against the kinematic model to detect deviations.",
    DTDFVocab:provides ValidationInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Prediction service that extrapolates future airflow conditions and offers insights for greenhouse actuation.",
    DTDFVocab:provides PredictionInsightAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service that executes what‑if scenarios and delivers results as insights.",
    DTDFVocab:provides SimulationWhatIfInsight
]

// -------------------------------------------------
// Insights and Actions
// -------------------------------------------------
instance SendMotionCommandAction : DTDFVocab:Action [
    base:desc "Automatically send computed motion commands to the crane's central controller.",
    DTDFVocab:IsAutomatic true
]

instance LoggingInsight : DTDFVocab:Insight [
    base:desc "Insight that logged data are available for post‑run analysis and model refinement."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing operators with live visual feedback of crane operation and sensor status."
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating whether the crane's real‑time behavior matches the kinematic prediction."
]

instance SimulationWhatIfInsight : DTDFVocab:Insight [
    base:desc "Insight delivering results of what‑if scenarios to support decision making."
]

instance PredictionInsightAction : DTDFVocab:Action [
    base:desc "Extrapolate future airflow conditions and suggest adjustments to greenhouse actuators.",
    DTDFVocab:IsAutomatic false
]

// -------------------------------------------------
// Environment
// -------------------------------------------------
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains StepperMotorX,
    StepperMotorY,
    ElectromagnetActuator,
    SwingAngleEncoder,
    AnemometerSensor,
    MagnetStateSensor,
    CadModel,
    KinematicModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, a Python program, issues motion commands to the crane via the Physical Crane Interface. Command types include trajectory execution directives generated by the Trajectory Generator Service. Commands are sent directly to the crane controllers; the documents do not detail command message format, authentication, conflict resolution, or execution confirmation mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The exemplars adopt an ad‑hoc orchestration based on containerization or virtualization. GreenhouseDT runs on virtual machines that host an InfluxDB time‑series database and an ActiveMQ message broker; the digital twin and physical greenhouse components communicate via the broker. The Air Quality Management exemplar uses a Raspberry‑Pi for sensing, an AutomationML‑based twin, and Microsoft Azure tools to host the twin pipeline, again employing messaging services. Overall the system follows a loosely coupled architecture where each service (data acquisition, storage, twin logic) is packaged in containers/VMs and linked through the broker and cloud services."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin includes a continuous validation service that compares predictions of the kinematic model with runtime data from the physical crane to monitor model fidelity. The exemplar has been employed in research on continuous validation methods and fault detection, but explicit validation procedures, uncertainty quantification, or error‑correction mechanisms are not described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin relies on an MQTT broker for signaling between components (Trajectory Generator Service, Simulation Service, Continuous Validation Service, etc.). The database (TimescaleDB) and dashboard (Grafana) are accessed over standard client‑server connections, but the specific network protocols, topology, bandwidth, latency, redundancy, or security measures are not described in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The architecture is described as a set of logical containers (Physical Crane, Physical Crane Interface, Control Application, Logging Application, Human Machine Interface, Database, Dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service, MQTT Broker). The documents do not state the physical hosting environment (cloud, edge, on‑premise), nor the computational or storage requirements, scalability mechanisms, deployment models, or availability/reliability provisions."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through standard open‑source protocols and interfaces. The twin exchanges data with the physical crane and any other cooperating services via MQTT topics, supporting loosely coupled, network‑agnostic connectivity. Persistent data are exposed through TimescaleDB’s PostgreSQL‑compatible SQL interface, which can be queried by external analytics tools or other digital twins. Grafana provides HTTP‑based dashboard access for operators and can be embedded in larger enterprise monitoring portals. No proprietary enterprise middleware is required; the stack relies on MQTT, SQL/HTTP, and Docker, facilitating interoperability with other IoT platforms or digital twin ecosystems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architectural description of the gantry‑crane digital twin follows the C4 Model, a widely adopted notation for software architecture, as stated in the documents."
]