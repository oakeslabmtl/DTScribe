// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted on Raspberry‑Pi node for indoor air quality monitoring"
    DTDFVocab:producedData TemperatureTelemetry
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor mounted on Raspberry‑Pi node for indoor air quality monitoring"
    DTDFVocab:producedData HumidityTelemetry
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor mounted on Raspberry‑Pi node for indoor air quality monitoring"
    DTDFVocab:producedData CO2Telemetry
]

instance CraneStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor component reading crane position, velocity, and force parameters from PLC controller"
    DTDFVocab:producedData CraneTelemetryTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance CO2Telemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance CraneTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneStateSensor
]

// C10: Models/Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature measurement from indoor air quality sensor, stored as time‑series data"
    DTDFVocab:fromData TemperatureTelemetry
    DTDFVocab:inputTo InfluxDBInstance
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity measurement from indoor air quality sensor, stored as time‑series data"
    DTDFVocab:fromData HumidityTelemetry
    DTDFVocab:inputTo InfluxDBInstance
]

instance CO2Data : DTDFVocab:Data [
    base:desc "CO₂ concentration measurement from indoor air quality sensor, stored as time‑series data"
    DTDFVocab:fromData CO2Telemetry
    DTDFVocab:inputTo InfluxDBInstance
]

instance CraneTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data for crane position, velocity, and force parameters, stored in a time‑series database"
    DTDFVocab:fromData CraneTelemetryTransmitted
    DTDFVocab:inputTo TimescaleDBInstance
]

instance AutomationMLCraneModel : DTDFVocab:Model [
    base:desc "AutomationML model of the laboratory gantry crane with linear rail, rotary actuator, and PLC controller"
    DTDFVocab:inputTo AzureFunctionsInstance
]

instance AutomationMLAirQualityModel : DTDFVocab:Model [
    base:desc "AutomationML based indoor air quality model for simulation of ventilation scenarios"
    DTDFVocab:inputTo AzureStreamAnalyticsInstance
]

instance IndoorAirQualitySimulationModel : DTDFVocab:Model [
    base:desc "Simulation model for indoor air quality scenarios derived from AutomationML model"
    DTDFVocab:inputTo AzureStreamAnalyticsInstance
]

instance IndoorAirQualityPredictionModel : DTDFVocab:Model [
    base:desc "Prediction model for indoor air quality and virus transmission risk using Azure Machine Learning"
    DTDFVocab:inputTo AzureMachineLearningInstance
]

// C11: Enablers
instance InfluxDBInstance : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database for storing indoor air quality sensor data"
]

instance TimescaleDBInstance : DTDFVocab:Enabler [
    base:desc "TimescaleDB database for storing crane telemetry and historical logs"
]

instance AzureStreamAnalyticsInstance : DTDFVocab:Enabler [
    base:desc "Azure Stream Analytics service for real‑time processing of sensor data"
    DTDFVocab:enables AirQualitySimulationService, AirQualityValidationService
]

instance AzureFunctionsInstance : DTDFVocab:Enabler [
    base:desc "Azure Functions for executing control logic, trajectory optimization, and data logging"
    DTDFVocab:enables TrajectoryPlanningService, RealTimeControlService, KinematicValidationService, HistoricalLoggingService
]

instance AzureMachineLearningInstance : DTDFVocab:Enabler [
    base:desc "Azure Machine Learning platform for forecasting indoor air quality and virus spread risk"
    DTDFVocab:enables AirQualityPredictionService
]

instance ActiveMQBroker : DTDFVocab:Enabler [
    base:desc "ActiveMQ message broker for routing telemetry between components"
]

// C6: Services
instance TrajectoryPlanningService : DTDFVocab:Service [
    base:desc "Delivers optimal trajectory planning for the gantry crane"
    DTDFVocab:provides TrajectoryPlanningInsight
]

instance RealTimeControlService : DTDFVocab:Service [
    base:desc "Provides real‑time control guidance for crane operations"
    DTDFVocab:provides RealTimeControlInsight
]

instance PositionMonitoringService : DTDFVocab:Service [
    base:desc "Continuously monitors crane position, velocity, and force parameters"
    DTDFVocab:provides PositionMonitoringInsight
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Logs historical trajectory, telemetry, and sensor data for post‑operation analysis"
    DTDFVocab:provides HistoricalAnalysisInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Interactive visualization dashboards for operators and researchers"
    DTDFVocab:provides VisualizationInsight
]

instance KinematicValidationService : DTDFVocab:Service [
    base:desc "Validates kinematic model against live sensor measurements"
    DTDFVocab:provides KinematicValidationInsight
]

instance AirQualitySimulationService : DTDFVocab:Service [
    base:desc "Simulates indoor air quality scenarios using AutomationML model"
    DTDFVocab:provides SimulationOutcomeInsight
]

instance AirQualityValidationService : DTDFVocab:Service [
    base:desc "Validates simulation outputs against real‑time sensor data"
    DTDFVocab:provides SimulationValidationInsight
]

instance AirQualityPredictionService : DTDFVocab:Service [
    base:desc "Forecasts indoor air quality and virus spread risk using Azure Machine Learning"
    DTDFVocab:provides PredictionInsight
]

instance RuntimeVisualizationService : DTDFVocab:Service [
    base:desc "Runtime visualization of real‑time sensor data via web dashboard"
    DTDFVocab:provides RuntimeMonitoringInsight
]

// C17: Insights
instance TrajectoryPlanningInsight : DTDFVocab:Insight [
    base:desc "Insight on optimal trajectory plans for crane operations"
]

instance RealTimeControlInsight : DTDFVocab:Insight [
    base:desc "Insight on real‑time control guidance effectiveness"
]

instance PositionMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight on crane positional accuracy and stability"
]

instance HistoricalAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight from historical telemetry and trajectory data analysis"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight from interactive visualization dashboards"
]

instance KinematicValidationInsight : DTDFVocab:Insight [
    base:desc "Insight on kinematic model validation results"
]

instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Insight on indoor air quality simulation outcomes"
]

instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Insight on simulation validation against real‑time data"
]

instance PredictionInsight : DTDFVocab:Insight [
    base:desc "Insight on forecasted indoor air quality and virus spread risk"
]

instance RuntimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight on real‑time monitoring data visualization"
]

// C17: Actions
instance TriggerResimulationAction : DTDFVocab:Action [
    base:desc "Operator-triggered re-simulation of indoor air quality scenarios"
    DTDFVocab:IsAutomatic false
]

instance AdjustVentilationAction : DTDFVocab:Action [
    base:desc "Operator adjustment of ventilation settings via dashboard"
    DTDFVocab:IsAutomatic false
]

instance RecordDecisionAction : DTDFVocab:Action [
    base:desc "Logging of control decisions made by operators for audit"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends motion directives through the same Python Crane Interface to the crane’s controllers. The interface transforms the high‑level trajectory commands into controller‑specific messages, dispatching them over the same connection to the physical system, and the updated crane state is subsequently returned and logged."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "GreenhouseDT implements a federated digital twin architecture where real‑time greenhouse sensor streams are collected via InfluxDB and published through an ActiveMQ message broker to a set of virtual machine‑hosted services. Each service (data ingestion, simulation, adaptive control) runs inside its own container and is orchestrated with Docker Compose, providing isolated yet coordinated execution. Resource management is handled at the VM level, with the broker mediating synchronization between the physical greenhouse actuators and the digital twin logic. The architecture also incorporates Microsoft Azure for cloud‑based analytics, demonstrating a hybrid edge‑cloud deployment pattern."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All Digital Twin services communicate via an MQTT broker that serves as the event bus between the Trajectory Generator Service, Simulation Service, Continuous Validation Service, and other components. The broker enables decoupled, asynchronous message passing within the local lab network."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is realized through several protocols and standards: sensor data from the physical greenhouse is transmitted to the ActiveMQ broker using a proprietary lightweight publish/subscribe model; the digital twin interfaces with Microsoft Azure services (e.g., Azure IoT Hub, Azure Machine Learning) via REST and AMQP protocols; AutomationML serves as the semantic modeling language for the Air Quality Management exemplar, enabling interoperability with other engineering tools and systems; all external communication is designed to be extensible, allowing additional enterprise systems such as SCADA or ERP to be connected through standard APIs or message queues."
]