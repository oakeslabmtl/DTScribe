// C3: Physical sensing components (derived from Physical Crane Interface)
instance CraneStateInterface : DTDFVocab:SensingComponent [
    base:desc "Python program that connects to crane controllers and extracts state such as position and motion data from the lab‑scale gantry crane."
    DTDFVocab:producedData CraneStateDataTransmitted
]

// C4: Physical-to-virtual interaction
instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneStateInterface
]

// C10: Data
instance CraneStateData : DTDFVocab:Data [
    base:desc "Time‑stamped position and motion measurements of the gantry crane captured during operation."
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo ControlEnabler, LoggingEnabler, VisualizationEnabler, ValidationEnabler
]

// C10: Models
instance GantryCADModel : DTDFVocab:Model [
    base:desc "Geometric CAD representation of the structural gantry crane used for collision checking and visualization."
    DTDFVocab:inputTo VisualizationEnabler, ValidationEnabler
]

instance GantryKinematicModel : DTDFVocab:Model [
    base:desc "Mathematical kinematic model encoding the motion behavior of the crane for trajectory planning and validation."
    DTDFVocab:inputTo ControlEnabler, ValidationEnabler
]

// C11: Enablers
instance ControlEnabler : DTDFVocab:Enabler [
    base:desc "Software component (e.g., Python control engine) that consumes state data and models to compute optimal control commands."
    DTDFVocab:enables OptimalControlService
]

instance LoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB service that stores incoming state data and deviation metrics for historical analysis."
    DTDFVocab:enables HistoricalLoggingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard stack that renders real‑time crane state and performance metrics."
    DTDFVocab:enables DataVisualizationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation engine that compares real‑time measurements against CAD and kinematic models to compute deviation metrics."
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes and sends control commands to improve crane motion based on the kinematic model and live state data."
    DTDFVocab:provides ControlInsight
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Stores time‑stamped sensor and actuation data in TimescaleDB for later analysis."
    DTDFVocab:provides LoggingInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Provides graphical views of crane state and performance on a Grafana dashboard."
    DTDFVocab:provides VisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Automatically compares real‑time measurements against models to detect deviations and generate alerts."
    DTDFVocab:provides DeviationMetricInsight, TriggerAlertAction
]

// C17: Insights
instance ControlInsight : DTDFVocab:Insight [
    base:desc "Insight that optimal control computed a feasible trajectory improving motion efficiency."
]

instance LoggingInsight : DTDFVocab:Insight [
    base:desc "Insight that historical data has been successfully recorded for post‑run analysis."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight that crane state is visualized in real time on the Grafana dashboard."
]

instance DeviationMetricInsight : DTDFVocab:Insight [
    base:desc "Insight that deviation metrics between actual and planned trajectory exceed defined thresholds."
]

// C17: Actions
instance TriggerAlertAction : DTDFVocab:Action [
    base:desc "Automatically triggers an alert on the dashboard when deviation thresholds are exceeded."
    DTDFVocab:IsAutomatic true
]

instance ReplanTrajectoryAction : DTDFVocab:Action [
    base:desc "Operator‑initiated re‑planning of crane trajectory based on validation feedback."
    DTDFVocab:IsAutomatic false
]

instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Schedules maintenance tasks when persistent deviations are detected."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, also implemented in Python, sends command messages to the Physical Crane Interface, which forwards them to the crane’s controllers to actuate movements. Commands may originate from the Human Machine Interface or other services. The documents do not describe the command syntax, validation, authentication, conflict resolution, or execution acknowledgment mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The gantry crane digital twin architecture is described using the C4 Model, adopting an ad‑hoc approach that employs containerization/virtualization technologies for easy dissemination and deployment of components, as noted for the exemplars."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through a continuous validation service that compares real‑time sensor data from the crane with the predictions of the kinematic model. The exemplar has been employed in research on continuous validation methods and fault detection, using runtime comparison to detect model‑data mismatches, but specific uncertainty quantification or quality‑assurance procedures are not described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Digital‑twin components communicate via an MQTT broker for service‑level signaling (publish/subscribe) and through standard database connections to the TimescaleDB instance. The Grafana dashboard accesses the database over HTTP/TCP. No explicit details on network topology, bandwidth, latency, reliability, redundancy, or security protocols are provided in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system is deployed on a single on‑premise personal computer. The TimescaleDB database, MQTT broker, and Grafana dashboard are containerized with Docker; the remaining Python components (Physical Crane Interface, Control Application, Logging Application, Human Machine Interface, Trajectory Generator, Simulation, Continuous Validation) are packaged in a Python module named gantrylib and run natively on the host. The documentation does not mention cloud or edge hosting, scalability mechanisms, or availability/reliability provisions beyond local Docker deployment."
]