// =============================
// C3: Physical Sensing Components
// =============================

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder that measures hoist swing on the lab‑scale gantry crane"
    DTDFVocab:producedData SwingAngleMQTTMessage
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer that measures wind speed for the gantry crane environment"
    DTDFVocab:producedData WindSpeedMQTTMessage
]

// =============================
// C4: Physical‑to‑Virtual Interaction (Data Transmitted)
// =============================

instance SwingAngleMQTTMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedMQTTMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// =============================
// C5: Data (Time‑Series)
// =============================

instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements streamed through MQTT"
    DTDFVocab:fromData SwingAngleMQTTMessage
    DTDFVocab:inputTo TimescaleDB
    DTDFVocab:inputTo DockerComposeEnvironment
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements streamed through MQTT"
    DTDFVocab:fromData WindSpeedMQTTMessage
    DTDFVocab:inputTo TimescaleDB
    DTDFVocab:inputTo DockerComposeEnvironment
]

// =============================
// C2: Acting Components
// =============================

instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor that drives the gantry trolley along the rails"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor that raises and lowers the electromagnet"
]

instance TrinamicTMC4671EvalController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval motor controller used for both cart and hoist stepper motors"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist for picking up pucks (container analogues)"
]

// =============================
// C10: Models / Data
// =============================

instance Fusion360CADModel : DTDFVocab:Model [
    base:desc "3‑D CAD model of the gantry crane created in Autodesk Fusion360"
    DTDFVocab:inputTo DockerComposeEnvironment
]

instance KinematicCraneModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the trajectory generator to compute swing‑free paths"
    DTDFVocab:inputTo DockerComposeEnvironment
]

instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Physics‑based simulation output data (positions, velocities) used for validation"
    DTDFVocab:inputTo DockerComposeEnvironment
]

// =============================
// C11: Enablers
// =============================

instance MQTTBrokerMosquitto : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker container handling sensor data publication"
    DTDFVocab:enables ContinuousDataLoggingService
    DTDFVocab:enables TrajectoryGenerationService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database (PostgreSQL extension) storing sensor and actuator data"
    DTDFVocab:enables ContinuousDataLoggingService
    DTDFVocab:enables GrafanaVisualizationService
    DTDFVocab:enables TrajectoryGenerationService
    DTDFVocab:enables PhysicsSimulationService
    DTDFVocab:enables ContinuousValidationService
    DTDFVocab:enables FaultDetectionService
    DTDFVocab:enables HumanMachineInterfaceService
]

instance DockerComposeEnvironment : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestration of all containerised DT services"
    DTDFVocab:enables ContinuousDataLoggingService
    DTDFVocab:enables GrafanaVisualizationService
    DTDFVocab:enables TrajectoryGenerationService
    DTDFVocab:enables PhysicsSimulationService
    DTDFVocab:enables ContinuousValidationService
    DTDFVocab:enables FaultDetectionService
    DTDFVocab:enables HumanMachineInterfaceService
]

// =============================
// C6: Services
// =============================

instance ContinuousDataLoggingService : DTDFVocab:Service [
    base:desc "Service that continuously logs incoming sensor and actuator data"
    DTDFVocab:provides OperatorDecisionSupportAction
]

instance GrafanaVisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboards visualising time‑series data from TimescaleDB"
    DTDFVocab:provides OperatorDecisionSupportAction
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal, swing‑free trajectories using the kinematic crane model"
    DTDFVocab:provides OptimalSwingFreeTrajectoryInsight
]

instance PhysicsSimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation of crane motion for comparison with real execution"
    DTDFVocab:provides SimulationOutputData
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates executed trajectories against simulation outputs"
    DTDFVocab:provides ValidationAlertInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Research‑extension service that classifies faults based on sensor/actuator patterns"
    DTDFVocab:provides FaultClassificationInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Web‑based HMI presenting insights and allowing operators to make decisions"
    DTDFVocab:provides OperatorDecisionSupportAction
]

// =============================
// C17: Insights / Actions
// =============================

instance OptimalSwingFreeTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight recommending the optimal swing‑free trajectory for the current payload"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert when executed trajectory deviates from the simulated reference"
]

instance FaultClassificationInsight : DTDFVocab:Insight [
    base:desc "Indicator categorising detected faults (sensor loss, motor stall, etc.)"
]

instance OperatorDecisionSupportAction : DTDFVocab:Action [
    base:desc "Manual action where the operator decides on trajectory execution or corrective steps"
    DTDFVocab:IsAutomatic false
]

// =============================
// C9: Environment (Physical System)
// =============================

instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains SwingAngleEncoder
    base:contains AnemometerSensor
    base:contains CartStepperMotor
    base:contains HoistStepperMotor
    base:contains TrinamicTMC4671EvalController
    base:contains Electromagnet
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal swing‑free trajectories and publishes them via MQTT to the Control Application, which uses the Physical Crane Interface to command the motor controllers and electromagnet; alerts from the Continuous Validation Service are also sent to the Human‑Machine Interface through the dashboard."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of the physical crane, a Python interface to its controllers, a control application, a logging application, an MQTT broker for inter‑service messaging, services (trajectory generation, simulation, continuous validation), a TimescaleDB backend, a Grafana dashboard, and a web‑based HMI, all orchestrated via Docker‑Compose on a single PC."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin incorporates CAD models (design stage) and a kinematic model used during operation, thus covering both the design/ideal representation and the as‑operated stage; manufacturing details are not explicitly modelled."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, checks against a predefined threshold, and raises alerts; model validation methods from prior work are reused to ensure fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT components uses MQTT (Eclipse Mosquitto) for command and event messages, and HTTP/SQL connections from the logging application to the TimescaleDB; all services run on the same Docker network on a personal computer."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT services are containerised with Docker and started with a single Docker‑Compose file; the Python modules run on the host PC; the entire system is hosted on a public GitHub repository with MIT license and documented via MkDocs."
]