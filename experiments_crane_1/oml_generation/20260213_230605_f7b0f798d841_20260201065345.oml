// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor driven by a TMC4671‑Eval cart‑motor controller."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor driven by a TMC4671‑Eval hoist‑motor controller."
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist for picking up experimental pucks."
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder that measures the swinging motion of the hoist."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer that measures wind speed around the crane."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoBoardSensor : DTDFVocab:SensingComponent [
    base:desc "Arduino‑based measurement and control board that reads sensors and reports values to the digital twin."
    DTDFVocab:producedData ArduinoBoardDataTransmitted
]

instance ControllerFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Controller feedback providing motor state and command information."
    DTDFVocab:producedData ControllerFeedbackDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance ArduinoBoardDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoBoardSensor
]

instance ControllerFeedbackDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ControllerFeedbackSensor
]

// C10: Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing angle measurements from the swing‑angle encoder."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of wind speed measurements from the anemometer."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance ArduinoBoardData : DTDFVocab:Data [
    base:desc "Aggregated time‑series of sensor readings reported by the Arduino board."
    DTDFVocab:fromData ArduinoBoardDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance ControllerFeedbackData : DTDFVocab:Data [
    base:desc "Time‑series of motor states and controller commands."
    DTDFVocab:fromData ControllerFeedbackDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB PostgreSQL extension used for time‑series storage of crane state."
    DTDFVocab:enables LoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker that forwards sensor MQTT messages to digital‑twin services."
    DTDFVocab:enables SimulationService, ContinuousValidationService, TrajectoryGeneratorService
]

instance PythonGanryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module providing kinematic calculations and simulation utilities."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard visualizing real‑time data and simulation confidence bounds."
    DTDFVocab:enables VisualizationService
]

instance Fusion360Enabler : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion360 used for creating detailed CAD geometry of the crane."
    DTDFVocab:enables VisualizationService
]

instance KinematicEngineEnabler : DTDFVocab:Enabler [
    base:desc "Kinematic computation engine provided by the gantrylib Python module."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService
]

// C6: Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Logs crane state data to TimescaleDB for historical analysis."
    DTDFVocab:provides DataLoggedInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of crane data via a Grafana dashboard."
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal, swing‑free trajectories using the kinematic model."
    DTDFVocab:provides OptimalTrajectoryInsight, ExecuteTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Emulates crane dynamics and controller behavior for virtual testing."
    DTDFVocab:provides SimulatedTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories with simulated ones and raises alerts when error thresholds are exceeded."
    DTDFVocab:provides ValidationErrorInsight, AlertOperatorAction
]

// C17: Insights
instance DataLoggedInsight : DTDFVocab:Insight [
    base:desc "Indicates that crane state data has been successfully persisted in TimescaleDB."
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Shows up‑to‑date crane state and simulation confidence bounds on the Grafana dashboard."
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Provides the computed optimal trajectory that minimizes swing."
]

instance SimulatedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Represents the virtual execution of a trajectory according to the crane dynamics model."
]

instance ValidationErrorInsight : DTDFVocab:Insight [
    base:desc "Reports deviation metrics between real and simulated trajectories and flags threshold breaches."
]

// C17: Actions
instance ExecuteTrajectoryAction : DTDFVocab:Action [
    base:desc "Command to start execution of the generated optimal trajectory on the physical crane."
    DTDFVocab:IsAutomatic false
]

instance AlertOperatorAction : DTDFVocab:Action [
    base:desc "Raises an operator alert when validation errors exceed predefined limits."
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance CraneCADModel : DTDFVocab:Model [
    base:desc "Detailed CAD geometry of the gantry crane created in Fusion360."
    DTDFVocab:inputTo Fusion360Enabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used for trajectory planning and simulation."
    DTDFVocab:inputTo KinematicEngineEnabler
]

// C5: Logical Containers as Components
instance TimescaleDBContainer : DTDFVocab:Component [
    base:desc "Docker container running the TimescaleDB database."
]

instance GrafanaDashboardContainer : DTDFVocab:Component [
    base:desc "Docker container running the Grafana dashboard."
]

instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Docker container running the Eclipse Mosquitto MQTT broker."
]

instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Docker container running the Trajectory Generator Service."
]

instance SimulationContainer : DTDFVocab:Component [
    base:desc "Docker container running the Simulation Service."
]

instance ValidationContainer : DTDFVocab:Component [
    base:desc "Docker container running the Continuous Validation Service."
]

// C5: Environment
instance CraneTwinEnvironment : DTDFVocab:Environment [
    base:contains TimescaleDBContainer, GrafanaDashboardContainer, MQTTBrokerContainer,
    TrajectoryGeneratorContainer, SimulationContainer, ValidationContainer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands such as trajectory set‑points generated by the Trajectory Generator Service, or manual commands from the Human‑Machine Interface, are sent from the Control Application through the Physical Crane Interface to the motor controllers and electromagnet, effecting motion of the cart and hoist."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall constellation consists of the physical crane linked via a Python interface to a set of digital services. Data flows from the crane to the MQTT broker and TimescaleDB; services (trajectory generation, simulation, validation) subscribe to MQTT topics, process data, and publish results back to the broker or database; the HMI visualises data on Grafana and issues operator commands back to the crane through the same interface."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin covers the design stage (CAD models in Autodesk Fusion360 and a kinematic model), the manufacturing/assembly stage (BOM and hardware components), and the operational stage (runtime data acquisition, monitoring, and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by using a physics‑based kinematic model for trajectory planning and a detailed simulation of crane dynamics; validity is continuously assessed by the Continuous Validation Service, which computes distance metrics between measured trajectories and simulated counterparts, compares them against an acceptable threshold, and notifies operators via the dashboard when the threshold is breached."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT relies on MQTT (Eclipse Mosquitto) for event signalling and Python sockets for the Physical Crane Interface; sensor data and control commands are transmitted over TCP/IP within the local host environment where all containers run."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin’s services (database, MQTT broker, Grafana) are deployed as Docker containers orchestrated by a Docker‑Compose file; the remaining Python applications (gantrylib, control, logging, HMI) run directly on the host PC. The entire system is hosted on a personal computer and distributed via an open‑source GitHub repository."
]