    base:desc "Optimized trajectory recommendations minimizing energy consumption while maintaining payload efficiency and collision avoidance"
]

instance HistoricalPerformanceBenchmarkingInsight : DTDFVocab:Insight [
    base:desc "Performance benchmarking insights comparing digital twin predictions with historical physical system data for validation"
]

instance OperationalMetricsDashboard : DTDFVocab:Insight [
    base:desc "Interactive dashboard showing real-time crane metrics (position, velocity, power draw) and state overlays for operational monitoring"
]

instance KinematicValidationReport : DTDFVocab:Insight [
    base:desc "Validation report comparing predicted vs. actual motion trajectories with error metrics for system accuracy assessment"
]

instance FaultDetectionAlert : DTDFVocab:Insight [
    base:desc "Alert system triggered by anomaly detection algorithms identifying physical system malfunctions or sensor discrepancies"
    DTDFVocab:IsAutomatic true
]

