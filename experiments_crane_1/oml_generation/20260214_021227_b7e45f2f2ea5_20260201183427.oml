]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D/2D visualization service displaying crane kinematics, operational metrics, and real-time state overlays"
    DTDFVocab:provides OperationalMetricsDashboard
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Real-time synchronization service comparing predicted vs. actual motion trajectories for kinematic validation"
    DTDFVocab:provides KinematicValidationReport
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection service using statistical process control and machine learning models to identify discrepancies or malfunctions"
    DTDFVocab:provides FaultDetectionAlert
]

instance AirQualityMonitoringService : DTDFVocab:Service [
    base:desc "Runtime monitoring service for air quality parameters (CO₂, VOCs, humidity) with cloud-based remote adjustments"
