// C2: Acting Components
instance GantryCraneMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Motorized puck transport system for horizontal/vertical movement in lab-scale gantry crane, controlled via containerized PID controllers"
]

instance VentilationFanActuator : DTDFVocab:Actuator [
    base:desc "Ventilation system actuator (fans/CO₂ scrubbers) for air quality management, controlled via Raspberry Pi sensors and Azure IoT Edge"
    DTDFVocab:producedData PositionDataStream
]

instance GreenhouseVentilationActuator : DTDFVocab:Actuator [
    base:desc "Implicitly controlled greenhouse ventilation system for temperature/light adjustments via virtualized simulations (InfluxDB/ActiveMQ feedback loops)"
    DTDFVocab:producedData TemperatureDataStream
]

// C3: Physical Sensing Components
instance PositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-precision encoder measuring puck coordinates and crane arm angles for real-time position tracking (sub-millimeter precision)"
    DTDFVocab:producedData PositionDataStream
]

instance LoadCellSensor : DTDFVocab:SensingComponent [
    base:desc "Force/torque sensor on actuators measuring payload weight and operational constraints"
    DTDFVocab:producedData LoadDataStream
]

instance EnvironmentalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor for environmental monitoring (±1°C accuracy) distributed across greenhouse via IoT devices"
    DTDFVocab:producedData TemperatureDataStream
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor (±2% accuracy) monitoring indoor air conditions for air quality management"
    DTDFVocab:producedData HumidityDataStream
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ concentration sensor (±100 ppm accuracy) measuring air quality metrics via Raspberry Pi interfaces"
    DTDFVocab:producedData CO2DataStream
]

instance CollisionDetectionSensor : DTDFVocab:SensingComponent [
    base:desc "Proximity sensor detecting physical constraints (swing motion, collision avoidance) for safety monitoring"
    DTDFVocab:producedData CollisionDataStream
]

instance AirQualityVOCSensor : DTDFVocab:SensingComponent [
    base:desc "Volatile Organic Compounds sensor for comprehensive air quality monitoring in indoor environments"
    DTDFVocab:producedData VOCDataStream
]

instance VirtualGreenhouseSimulator : DTDFVocab:SensingComponent [
    base:desc "Pre-recorded virtual greenhouse simulation data embedded in containerized VMs for actuator control testing"
    DTDFVocab:producedData VirtualDataStream
]

// C4: Physical-to-Virtual Interaction
instance PositionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionEncoder
]

instance LoadDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadCellSensor
]

instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalTemperatureSensor
]

instance HumidityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance CO2DataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance CollisionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CollisionDetectionSensor
]

instance VOCDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityVOCSensor
]

instance VirtualDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VirtualGreenhouseSimulator
]

// C10: Models/Data
instance GantryKinematicModel : DTDFVocab:Model [
    base:desc "Forward/backward kinematics and inverse dynamics model for gantry crane motion optimization using MATLAB/Simulink"
    DTDFVocab:inputTo MATLABSimulinkEnvironment
]

instance AirQualitySimulationModel : DTDFVocab:Model [
    base:desc "Model-driven air quality simulation incorporating virus spread dynamics and AutomationML-defined control logic"
    DTDFVocab:inputTo AutomationMLStandard
]

instance RealTimeTrajectoryModel : DTDFVocab:Model [
    base:desc "Dynamic trajectory optimization model for real-time adaptive control of crane motion with energy efficiency constraints"
    DTDFVocab:inputTo PythonDataProcessingEnvironment
]

instance HistoricalDataArchive : DTDFVocab:Data [
    base:desc "Time-stamped database of physical system states (position, velocity, torque) for offline analysis via SQL/NoSQL integration"
    DTDFVocab:fromData PositionDataStream, LoadDataStream, CollisionDataStream
    DTDFVocab:inputTo TimescaleDatabase
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "High-frequency (100Hz+) time-series data stream from physical sensors for real-time validation"
    DTDFVocab:fromData PositionDataStream, TemperatureDataStream, HumidityDataStream, CO2DataStream, VOCDataStream
    DTDFVocab:inputTo InfluxDBTimeSeriesDatabase
]

instance VirtualSimulationData : DTDFVocab:Data [
    base:desc "Pre-recorded virtual simulation data from containerized VMs for actuator testing and calibration"
    DTDFVocab:fromData VirtualDataStream
    DTDFVocab:inputTo ContainerizedVirtualMachineEnvironment
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Lightweight publish-subscribe protocol (MQTT) for low-latency real-time data exchange between physical crane and digital twin services"
    DTDFVocab:enables PositionDataStream, LoadDataStream, CollisionDataStream
]

instance InfluxDBTimeSeriesDB : DTDFVocab:Enabler [
    base:desc "Time-series database (InfluxDB) for high-frequency sensor data aggregation and real-time analytics"
    DTDFVocab:enables RealTimeSensorData
]

instance AutomationMLStandard : DTDFVocab:Enabler [
    base:desc "Standardized digital twin modeling language (AMXML) for defining geometric, behavioral, and analytical models of air quality systems"
    DTDFVocab:enables AirQualitySimulationModel
]

instance PythonDataProcessing : DTDFVocab:Enabler [
    base:desc "Python-based ecosystem (NumPy, SciPy, Matplotlib) for data processing, visualization, and machine learning applications"
    DTDFVocab:enables RealTimeTrajectoryModel
]

instance MATLABSimulinkEnvironment : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink platform for kinematic modeling, control loop design, and digital twin validation"
    DTDFVocab:enables GantryKinematicModel
]

instance AzureIoTEdge : DTDFVocab:Enabler [
    base:desc "Azure IoT Edge device for localized processing and actuation coordination in air quality management systems"
    DTDFVocab:enables CO2DataStream, VOCDataStream
]

instance ContainerizedVirtualization : DTDFVocab:Enabler [
    base:desc "Containerized VM deployment for reproducible actuator testing and simulation environments"
    DTDFVocab:enables VirtualSimulationData
]

instance TimescaleDatabase : DTDFVocab:Enabler [
    base:desc "Time-series database extension for TimescaleDB that supports high-frequency data storage and analysis"
    DTDFVocab:enables HistoricalDataArchive
]

instance GitVersionControl : DTDFVocab:Enabler [
    base:desc "Version control system (Git) for collaborative development and reproducibility of digital twin components"
    DTDFVocab:enables AutomationMLStandard, MATLABSimulinkEnvironment
]

// C6: Services
instance RealTimeAdaptiveControlService : DTDFVocab:Service [
    base:desc "Dynamic trajectory optimization service adjusting crane motion to physical constraints (load limits, collision avoidance) via closed-loop feedback"
    DTDFVocab:provides GantryTrajectoryOptimizationInsight
]

instance HistoricalDataAnalysisService : DTDFVocab:Service [
    base:desc "Service for offline analysis of physical system states (position, velocity, torque) for fault reconstruction and performance benchmarking"
