import DTDFVocab from "DTDFVocab.oml"

// ====================
// C3: Physical sensing components
// ====================

instance HoistSwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring the hoist swing angle",
    DTDFVocab:producedData HoistSwingAngleTransmitted
]

instance WindAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed",
    DTDFVocab:producedData WindSpeedTransmitted
]

instance CartMotorFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Stepper‑motor controller feedback (position/velocity) for the cart axis accessed via Arduino",
    DTDFVocab:producedData CartMotorStateTransmitted
]

instance HoistMotorFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Stepper‑motor controller feedback (position/velocity) for the hoist axis accessed via Arduino",
    DTDFVocab:producedData HoistMotorStateTransmitted
]

// ====================
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// ====================

instance HoistSwingAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistSwingAngleEncoder
]

instance WindSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindAnemometer
]

instance CartMotorStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorFeedbackSensor
]

instance HoistMotorStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorFeedbackSensor
]

// ====================
// C10: Data (operational time‑series)
// ====================

instance HoistSwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle values from the hoist encoder",
    DTDFVocab:fromData HoistSwingAngleTransmitted,
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed readings from the anemometer",
    DTDFVocab:fromData WindSpeedTransmitted,
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance CartMotorStateData : DTDFVocab:Data [
    base:desc "Time‑stamped cart motor position and velocity",
    DTDFVocab:fromData CartMotorStateTransmitted,
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HoistMotorStateData : DTDFVocab:Data [
    base:desc "Time‑stamped hoist motor position and velocity",
    DTDFVocab:fromData HoistMotorStateTransmitted,
    DTDFVocab:inputTo TimescaleDBEnabler
]

// ====================
// C2: Acting components
// ====================

instance CartStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart, commanded via Trinamic TMC4671‑Eval controller"
]

instance HoistStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist, commanded via Trinamic TMC4671‑Eval controller"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist for load handling"
]

// ====================
// C11: Enablers (infrastructure / tools)
// ====================

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB PostgreSQL extension storing time‑series sensor and simulated data",
    DTDFVocab:enables DataLoggingService, ContinuousValidationService, SimulationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker handling sensor/status messages and command topics",
    DTDFVocab:enables HumanMachineInterfaceService, ContinuousValidationService
]

instance DockerComposeOrchestrator : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestration that deploys all containerised twin services",
    DTDFVocab:enables DataLoggingService, DashboardService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService, HumanMachineInterfaceService
]

instance GrafanaVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana instance visualising time‑series data from TimescaleDB",
    DTDFVocab:enables DashboardService
]

// ====================
// C6: Services (digital‑twin functional containers)
// ====================

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that writes incoming time‑stamped sensor and simulated records into TimescaleDB",
    DTDFVocab:provides DataPersistenceInsight
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard providing visualisation of crane state and simulation results",
    DTDFVocab:provides VisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes swing‑free trajectories using the kinematic model",
    DTDFVocab:provides GenerateOptimalTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Emulates crane dynamics and controllers based on the dynamic simulation model",
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares measured trajectories with simulated ones, raises alerts on threshold breaches",
    DTDFVocab:provides ValidationAlertInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Web‑based HMI enabling operators to trigger actions and monitor alerts",
    DTDFVocab:provides OperatorControlAction
]

// ====================
// C17: Insights / Actions
// ====================

instance DataPersistenceInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data have been successfully persisted in TimescaleDB"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visual representation of crane operation and simulation overlays"
]

instance GenerateOptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatically generates an optimal swing‑free motion trajectory for a requested cart‑hoist move",
    DTDFVocab:IsAutomatic true
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Provides simulated state trajectories used for validation and operator reference"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert issued when measured and simulated trajectories diverge beyond predefined thresholds"
]

instance OperatorControlAction : DTDFVocab:Action [
    base:desc "Operator‑initiated command (e.g., start/stop motion, engage electromagnet) issued via the HMI",
    DTDFVocab:IsAutomatic false
]

// ====================
// C10: Models (CAD, Kinematic, Dynamic)
// ====================

instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator to compute swing‑free paths",
    DTDFVocab:inputTo DockerComposeOrchestrator
]

instance GantryCraneDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of crane mechanics and controllers used by the Simulation Service",
    DTDFVocab:inputTo DockerComposeOrchestrator
]

instance CADGeometryModel : DTDFVocab:Model [
    base:desc "Fusion 360 CAD geometry of the lab‑scale gantry crane"
]

// ====================
// C15: Environment (physical system under study)
// ====================

instance GantryCraneLabEnvironment : DTDFVocab:Environment [
    base:contains HoistSwingAngleEncoder, WindAnemometer, CartMotorFeedbackSensor, HoistMotorFeedbackSensor,
                CartStepperMotorActuator, HoistStepperMotorActuator, ElectromagnetActuator,
                DataLoggingService, DashboardService, TrajectoryGeneratorService, SimulationService,
                ContinuousValidationService, HumanMachineInterfaceService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service publishes optimal motion set‑points via MQTT; the Control Application subscribes to these messages and, through the Physical Crane Interface, sends command values to the motor controllers and electromagnet, thereby moving the crane in real time."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall constellation comprises the physical crane with its controllers and sensors, a Python interface layer, a Control Application, a Logging Application, an HMI, and on the virtual side the MQTT broker, TimescaleDB, Grafana dashboard, Trajectory Generator, Simulation Service, and Continuous Validation Service, all interconnected via MQTT messages and database queries."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans design (CAD models of the crane in Autodesk Fusion 360), manufacturing (Bill‑of‑Materials and hardware assembly), and operation (real‑time logging, simulation, validation, and trajectory optimisation) phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service calculates distance metrics between measured trajectories and simulated counterparts, compares them against configurable thresholds, and notifies operators when deviations exceed the limits, thereby providing on‑line fidelity assessment of the kinematic and dynamic models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses TCP/IP‑based MQTT (Eclipse Mosquitto) for command and status messages, and PostgreSQL‑compatible SQL over TCP/IP for time‑series data access to TimescaleDB; the Python interface runs on the same host PC as the crane controller."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All virtual components (TimescaleDB, MQTT broker, Grafana) are Dockerised and launched together with Docker‑Compose on a personal computer; the Python services (gantrylib, Control, Logging, HMI) run as native processes on the same machine after pip installation. The source code and Docker files are hosted publicly on GitHub."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture is described using the C4 model (a standardized visual notation), data storage follows the PostgreSQL/TimescaleDB standard, and communication uses the open MQTT protocol; all software components are open‑source and adhere to their respective community standards."
]