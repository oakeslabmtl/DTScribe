// C3: Physical sensing components
instance BridgePositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder attached to the horizontal bridge of the lab‑scale gantry crane."
    DTDFVocab:producedData BridgePositionTelemetry
]

instance TrolleyPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the trolley, providing translational position data."
    DTDFVocab:producedData TrolleyPositionTelemetry
]

instance HoistLoadSensor : DTDFVocab:SensingComponent [
    base:desc "Load‑sensing actuator that measures the tension in the hoist cable."
    DTDFVocab:producedData HoistLoadTelemetry
]

// C4: Data transmitted from physical to virtual environment
instance BridgePositionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BridgePositionEncoder
]

instance TrolleyPositionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TrolleyPositionEncoder
]

instance HoistLoadTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistLoadSensor
]

// C10: Data stored in the virtual platform
instance BridgePositionData : DTDFVocab:Data [
    base:desc "Bridge position telemetry persisted in TimescaleDB for analysis and validation."
    DTDFVocab:fromData BridgePositionTelemetry
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance TrolleyPositionData : DTDFVocab:Data [
    base:desc "Trolley position telemetry persisted in TimescaleDB."
    DTDFVocab:fromData TrolleyPositionTelemetry
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HoistLoadData : DTDFVocab:Data [
    base:desc "Hoist load telemetry persisted in TimescaleDB."
    DTDFVocab:fromData HoistLoadTelemetry
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance that stores raw telemetry and exposes it to digital twin services."
    DTDFVocab:enables RealTimeMonitoringService, OptimalControlService, ValidationService, VisualizationService, ControlAPIService
]

// C6: Digital twin services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service that streams live encoder and load data for real‑time monitoring."
    DTDFVocab:provides LivePositionInsight, LoadDiscrepancyInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service that solves a deterministic kinematic optimization problem to compute lift and trajectory commands."
    DTDFVocab:provides OptimalControlAction
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Service that continuously validates live sensor readings against the kinematic model predictions."
    DTDFVocab:provides KinematicModelValidationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that visualises operational states through a CAD geometry overlay."
    DTDFVocab:provides CADOverlayInsight
]

instance ControlAPIService : DTDFVocab:Service [
    base:desc "Service that exposes an API for injecting control actions into the physical crane."
    DTDFVocab:provides InjectControlCommandAction
]

// C17: Insights
instance LivePositionInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into bridge and trolley positions derived from live encoder data."
]

instance LoadDiscrepancyInsight : DTDFVocab:Insight [
    base:desc "Insight detecting discrepancies between measured load and expected load based on kinematic model."
]

instance KinematicModelValidationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the fidelity of the kinematic model by comparing predictions with live sensor data."
]

instance CADOverlayInsight : DTDFVocab:Insight [
    base:desc "Insight visualising current crane state overlayed on the CAD geometry."
]

// C17: Actions
instance OptimalControlAction : DTDFVocab:Action [
    base:desc "Optimal lift and trajectory commands computed by the deterministic kinematic optimization service."
    DTDFVocab:IsAutomatic true
]

instance InjectControlCommandAction : DTDFVocab:Action [
    base:desc "Action that injects control commands into the physical crane via the API."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application uses the same Physical Crane Interface to issue control commands to the crane. Commands consist of motion primitives derived from trajectories generated by the Trajectory Generator Service; the interface transmits these commands to the crane hardware. The system currently does not detail the exact message format, validation or authentication mechanisms, feedback loops, conflict resolution policies, nor explicit confirmation of command execution received by the physical crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The GreenhouseDT exemplar follows a modular, containerised/virtualised architecture. Sensor data from the physical greenhouse model are encapsulated and transmitted via an ActiveMQ message broker to an InfluxDB time‑series database for persistence. The digital twin logic, which implements behavioural adaptation, runs in a virtual‑machine context that hosts the twin model, the message broker, and the database as separate services, orchestrated through a common virtualisation layer. This pattern decouples data acquisition, messaging and storage while maintaining a single, centrally coordinated twin instance for the physical greenhouse."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The infrastructure relies on an MQTT broker for inter-service signaling within the digital twin stack. Communication between services (such as Trajectory Generator, Simulation, and Continuous Validation) occurs via MQTT topics. Database interactions use standard PostgreSQL clients established over the local network by the Python applications. The document does not provide explicit details on overall network topology, bandwidth or latency requirements, redundancy or reliability mechanisms, or security protocols applied to network communications."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The exemplar leverages Microsoft Azure services for cloud‑based analytics and runtime visualization. The digital twin model is represented in AutomationML, a standard modelling language that facilitates interoperability with building‑automation and engineering tools. Data exchange between on‑premises components and Azure occurs over the ActiveMQ publish/subscribe messaging protocol and Azure Service Bus, enabling a protocol‑agnostic integration pattern with external systems such as cloud dashboards and analytics pipelines."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar employs an AutomationML-based digital twin representation, aligning with the AutomationML industrial interoperability standard, and leverages Microsoft Azure cloud services for data processing and analytics, but the documentation does not specify additional certification or compliance frameworks."
]