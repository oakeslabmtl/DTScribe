// C2: Acting Components
instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor that drives the hoist of the gantry crane"
]

instance TMC4671EvalMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval motor controller board that commands the stepper motor"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the crane payload"
    DTDFVocab:producedData SwingAngleDataTx
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed affecting crane dynamics"
    DTDFVocab:producedData WindSpeedDataTx
]

instance CraneStateSensor : DTDFVocab:SensingComponent [
    base:desc "Collects crane state variables such as position, velocity, and motor currents"
    DTDFVocab:producedData CraneStateDataTx
]

// C4: Physical‑to‑Virtual ProducedData (renamed to DataTransmitted)
instance SwingAngleDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CraneStateDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneStateSensor
]

// C10: Data (Data)
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Swing‑angle measurements from the encoder"
    DTDFVocab:fromData SwingAngleDataTx
    DTDFVocab:inputTo MqttBrokerEnabler, TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Wind‑speed measurements from the anemometer"
    DTDFVocab:fromData WindSpeedDataTx
    DTDFVocab:inputTo MqttBrokerEnabler, TimescaleDBEnabler
]

instance CraneRuntimeData : DTDFVocab:Data [
    base:desc "Runtime state data (position, velocity, motor currents, etc.) from the crane"
    DTDFVocab:fromData CraneStateDataTx
    DTDFVocab:inputTo MqttBrokerEnabler, TimescaleDBEnabler
]

// C11: Enablers
instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker (Eclipse Mosquitto) mediates signaling between services"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database stores all logged state, trajectory and validation data"
    DTDFVocab:enables DatabaseService, DashboardService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard visualises time‑series data, confidence bounds and alerts"
    DTDFVocab:enables DashboardService
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes optimal swing‑free movement trajectories using the analytical kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight, ExecuteTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs a dynamic simulation of the crane and its low‑level controllers to predict behaviour"
    DTDFVocab:provides PredictedBehaviourInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares measured trajectories with simulated ones, computes distance metric and raises alerts if a configurable threshold is exceeded"
    DTDFVocab:provides ValidationAlertInsight, RaiseAlertAction
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Grafana‑based service visualises real‑time and historical data, confidence bounds and validation alerts"
    DTDFVocab:provides VisualizationInsight, VisualizeDataAction
]

instance DatabaseService : DTDFVocab:Service [
    base:desc "Persists all logged state, trajectory and validation data into TimescaleDB"
    DTDFVocab:provides StoreDataAction
]

// C17: Insights
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Swing‑free trajectory computed for the requested crane motion"
]

instance PredictedBehaviourInsight : DTDFVocab:Insight [
    base:desc "Predicted crane dynamics and trajectory behaviour from the simulation"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating measured trajectory deviates beyond the configurable threshold"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of time‑series data, confidence bounds and alerts in Grafana"
]

// C17: Actions
instance ExecuteTrajectoryAction : DTDFVocab:Action [
    base:desc "Send generated trajectory to the control application for execution"
    DTDFVocab:IsAutomatic true
]

instance RaiseAlertAction : DTDFVocab:Action [
    base:desc "Raise alert on Grafana dashboard and HMI when validation fails"
    DTDFVocab:IsAutomatic true
]

instance VisualizeDataAction : DTDFVocab:Action [
    base:desc "Render selected data streams in the Grafana dashboard"
    DTDFVocab:IsAutomatic false
]

instance StoreDataAction : DTDFVocab:Action [
    base:desc "Persist incoming data into TimescaleDB"
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance GeometricCADModel : DTDFVocab:Model [
    base:desc "Geometric CAD representation of the gantry crane structure"
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Analytical kinematic model describing hoist and trolley motion"
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the crane and its low‑level controllers"
]

// C16: Environment (optional aggregation)
instance LabScaleCraneEnvironment : DTDFVocab:Environment [
    base:contains HoistStepperMotor, TMC4671EvalMotorController,
          SwingAngleEncoder, Anemometer, CraneStateSensor,
          MqttBrokerEnabler, TimescaleDBEnabler, GrafanaDashboardEnabler,
          TrajectoryGeneratorService, SimulationService, ContinuousValidationService,
          DashboardService, DatabaseService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, implemented in Python, uses the Physical Crane Interface to issue control commands to the crane controllers based on trajectories generated by the Trajectory Generator Service or decisions from other digital‑twin services. Commands are sent as actuator instructions (e.g., motor speed/position set‑points) over the same Python‑based interface used for data acquisition. The documents do not detail command message formats, authentication, validation, feedback confirmation, or conflict‑resolution mechanisms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data from the physical crane is streamed continuously by the Logging Application into the TimescaleDB; the Continuous Validation Service consumes these measurements in real time and compares them with the output of the Simulation Service. The twin therefore operates in a near‑real‑time (continuous) loop, but the documents do not specify explicit sampling periods, latency budgets, or temporal granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a micro‑service architecture orchestrated with Docker Compose. The Physical Crane Interface and the five Python applications (Control, Logging, HMI) run as separate processes. Twin services communicate via an MQTT broker, store data in a TimescaleDB instance, and present it through a Grafana dashboard. The overall coordination is depicted with the C4 model and relies on containerization for deployment and resource isolation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The gantry‑crane digital twin follows a development‑to‑operation lifecycle. In the development phase CAD models and a kinematic model of the crane are created and packaged together with Python‑based services (Trajectory Generator, Simulation, Continuous Validation) as Docker images. The architecture is described with the C4 model and all artifacts (source code, Dockerfiles, configuration) are stored in a public GitHub repository. Deployment is performed with a single Docker‑Compose command, which starts the physical‑crane interface, control and logging applications, the MQTT broker, TimescaleDB, Grafana, and the twin services. In the operation phase the physical crane is driven by the Control Application while the Logging Application streams state to the TimescaleDB. The Simulation Service reproduces the commanded trajectory, the Trajectory Generator derives optimal swing‑free trajectories, and the Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics and checks them against a predefined threshold. When the threshold is exceeded, the operator is notified via the Grafana dashboard, thereby closing the loop between the physical and virtual representations. Lifecycle governance is implicitly enforced by the Docker‑Compose orchestration which guarantees that the same container versions and configurations are used throughout development, testing and runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by a Continuous Validation Service that continuously compares the measured execution of a trajectory (obtained from the Logging Application) with the corresponding simulated trajectory produced by the Simulation Service. The service computes distance metrics (e.g., positional error) and checks them against a predefined acceptable threshold; violations trigger operator notifications via the Grafana dashboard. The validation pipeline thus provides on‑line verification of the kinematic and dynamic models. The exemplar has been used in research on continuous validation, fault localisation via time‑series classification, and model‑based evolution, indicating that uncertainty is monitored through thresholds and that errors are detected by deviation analysis."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital‑twin services are containerized using Docker and orchestrated with Docker‑compose. The TimescaleDB database, Eclipse Mosquitto MQTT broker, and Grafana dashboard run in separate Docker containers on the same host computer and communicate over the Docker network via standard TCP/IP. The Python‑based Physical Crane Interface and control/logging applications run as processes on the host and interact with the containers through the MQTT broker (for signaling) and direct PostgreSQL connections to TimescaleDB. No explicit bandwidth, latency, redundancy, or security protocols beyond the use of MQTT and container isolation are described."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The exemplar is deployed on‑premise on a single personal computer. Docker is used to host the TimescaleDB, MQTT broker, and Grafana components, while the Python modules (gantrylib) are installed via pip. Docker‑compose provides one‑command startup/shutdown of the containers. The code and documentation are publicly available on GitHub and hosted with MkDocs. No cloud or edge platforms are mentioned, and scalability is limited to the resources of the host machine."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is limited to standard protocols: MQTT is used for inter‑service signaling, TimescaleDB provides an SQL‑compatible storage layer, and Grafana accesses the database over HTTP/HTTPS for visualization. No explicit connections to other enterprise systems, external digital twins, or interoperability standards such as AutomationML are mentioned for this exemplar."
]