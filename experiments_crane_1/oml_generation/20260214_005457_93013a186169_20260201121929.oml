// Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder that measures the hoist’s sway."
    DTDFVocab:producedData SwingAngleMeasurementTopic
]

instance AnemometerWindSpeed : DTDFVocab:SensingComponent [
    base:desc "Anemometer that records wind speed affecting the crane."
    DTDFVocab:producedData WindSpeedMeasurementTopic
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the Arduino that monitors motor positions."
    DTDFVocab:producedData MotorPositionMeasurementTopic
]

instance ElectromagnetStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that monitors the electromagnet status for puck pickup."
    DTDFVocab:producedData ElectromagnetStatusMeasurementTopic
]

// Data Transmitted (MQTT topics)
instance SwingAngleMeasurementTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedMeasurementTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerWindSpeed
]

instance MotorPositionMeasurementTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance ElectromagnetStatusMeasurementTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ElectromagnetStatusSensor
]

// Time‑series Data (stored in TimescaleDB)
instance SwingAngleTimeseries : DTDFVocab:Data [
    base:desc "Time‑series data of swing angles captured by the swing‑angle encoder."
    DTDFVocab:inputTo TimescaleDBContainer, MosquittoBrokerContainer
    DTDFVocab:fromData SwingAngleMeasurementTopic
]

instance WindSpeedTimeseries : DTDFVocab:Data [
    base:desc "Time‑series data of wind speed measured by the anemometer."
    DTDFVocab:inputTo TimescaleDBContainer, MosquittoBrokerContainer
    DTDFVocab:fromData WindSpeedMeasurementTopic
]

instance MotorPositionTimeseries : DTDFVocab:Data [
    base:desc "Time‑series data of motor positions logged by the Arduino encoder."
    DTDFVocab:inputTo TimescaleDBContainer, MosquittoBrokerContainer
    DTDFVocab:fromData MotorPositionMeasurementTopic
]

instance ElectromagnetStatusTimeseries : DTDFVocab:Data [
    base:desc "Time‑series data of the electromagnet status during puck operations."
    DTDFVocab:inputTo TimescaleDBContainer, MosquittoBrokerContainer
    DTDFVocab:fromData ElectromagnetStatusMeasurementTopic
]

// Models
instance CadGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the laboratory‑scale gantry crane, used for visualization and simulation."
    DTDFVocab:inputTo GantrylibPythonContainer
]

instance SymbolicKinematicModel : DTDFVocab:Model [
    base:desc "Symbolic kinematic model implemented in gantrylib for optimal trajectory generation."
    DTDFVocab:inputTo TrajectoryGeneratorContainer
]

instance PhysicsBasedDynamicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based dynamics simulation model used by the Simulation Execution Service."
    DTDFVocab:inputTo SimulationContainer
]

instance TrajectoryRepositoryModel : DTDFVocab:Model [
    base:desc "Repository of precomputed trajectories stored for rapid retrieval during operation."
    DTDFVocab:inputTo TrajectoryGeneratorContainer
]

instance ValidationMetricsModel : DTDFVocab:Model [
    base:desc "Model that stores validation metrics comparing real executions with simulated trajectories."
    DTDFVocab:inputTo ContinuousValidationContainer
]

// Enablers (Docker Containers)
instance TimescaleDBContainer : DTDFVocab:Enabler [
    base:desc "TimescaleDB container for time‑series storage of all sensor data."
    DTDFVocab:enables DataLoggingService
]

instance MosquittoBrokerContainer : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto container acting as the MQTT broker for data publishing."
    DTDFVocab:enables DataLoggingService
]

instance GrafanaDashboardContainer : DTDFVocab:Enabler [
    base:desc "Grafana dashboard container providing real‑time visualizations and alerts."
    DTDFVocab:enables VisualizationService
]

instance TrajectoryGeneratorContainer : DTDFVocab:Enabler [
    base:desc "Python container running the trajectory generator service in the gantrylib module."
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationContainer : DTDFVocab:Enabler [
    base:desc "Container running the full‑scale physics simulation of the crane dynamics."
    DTDFVocab:enables SimulationExecutionService
]

instance ContinuousValidationContainer : DTDFVocab:Enabler [
    base:desc "Container running continuous validation comparing real and simulated trajectories."
    DTDFVocab:enables ContinuousValidationService
]

instance PhysicalCraneInterfaceContainer : DTDFVocab:Enabler [
    base:desc "Container integrating the physical crane interface to feed control commands."
    DTDFVocab:enables SimulationExecutionService
]

instance GantrylibPythonContainer : DTDFVocab:Enabler [
    base:desc "Python runtime container hosting the gantrylib module with kinematic and simulation models."
    DTDFVocab:enables TrajectoryGenerationService, SimulationExecutionService
]

// Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that logs sensor data to TimescaleDB and publishes it via MQTT."
    DTDFVocab:provides DataIntegrityInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that streams data to Grafana for real‑time dashboards and alerting."
    DTDFVocab:provides PerformanceDashboardInsight, TriggerAlertAction
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service that computes optimal trajectories using the symbolic kinematic model."
    DTDFVocab:provides TrajectoryOptimalityInsight, OptimizeTrajectoryAction
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service that runs full‑scale dynamics simulations of the crane."
    DTDFVocab:provides SimulationResultInsight, UpdateControlStrategyAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously validates real executions against simulated trajectories."
    DTDFVocab:provides DeviationMetricInsight, IssueDeviationAlertAction
]

// Insights
instance DataIntegrityInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that logged data remains complete and consistent."
]

instance PerformanceDashboardInsight : DTDFVocab:Insight [
    base:desc "Insight displaying real‑time performance metrics such as swing angle deviations."
]

instance TrajectoryOptimalityInsight : DTDFVocab:Insight [
    base:desc "Insight showing how close executed trajectories are to the optimal plan."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight comparing simulated crane dynamics with real sensor data."
]

instance DeviationMetricInsight : DTDFVocab:Insight [
    base:desc "Insight quantifying deviation between actual and simulated trajectory executions."
]

// Actions
instance TriggerAlertAction : DTDFVocab:Action [
    base:desc "Automatic action that triggers a Grafana alert when deviation exceeds threshold."
    DTDFVocab:IsAutomatic true
]

instance OptimizeTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatic action that updates the trajectory plan to minimize swing angle."
    DTDFVocab:IsAutomatic true
]

instance UpdateControlStrategyAction : DTDFVocab:Action [
    base:desc "Automatic action that adjusts control parameters based on simulation results."
    DTDFVocab:IsAutomatic true
]

instance IssueDeviationAlertAction : DTDFVocab:Action [
    base:desc "Automatic action that issues an alert when deviation metrics exceed safe limits."
    DTDFVocab:IsAutomatic true
]

instance TriggerForensicAnalysisAction : DTDFVocab:Action [
    base:desc "Action that generates forensic data reports for fault classification after an anomaly."
    DTDFVocab:IsAutomatic false
]

// Environment and Components
instance GantryCraneLabEnvironment : DTDFVocab:Environment [
    base:contains PhysicalCraneComponent, CraneControllerComponent, DigitalTwinComponent
]

instance PhysicalCraneComponent : DTDFVocab:Component [
    base:desc "Laboratory‑scale gantry crane with stepper motors and a hoist electromagnet."
]

instance CraneControllerComponent : DTDFVocab:Component [
    base:desc "Embedded controller running on an Arduino that drives motor stepper drivers via TMC4671."
]

instance DigitalTwinComponent : DTDFVocab:Component [
    base:desc "Digital twin infrastructure comprising simulation, logging, visualization, and validation services."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory generation and control commands are produced by the Trajectory Generator Service, then sent via the Physical Crane Interface (Python driver) to the motor controllers and electromagnet; MQTT topics carry real‑time execution updates back to the operator’s HMI."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Services operate in near real‑time: logging occurs at each sensor sample, trajectory generation and validation are performed for each commanded trajectory, and simulation runs concurrently with execution; the TimescaleDB handles high‑frequency time‑series data, while MQTT handles event‑driven messages."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation is an orchestrated set of Docker containers (Database, MQTT broker, Dashboard, Trajectory Generator, Simulation, Continuous Validation) linked via local networking, all coordinated by the gantrylib library running on a single personal computer that also hosts the physical crane interface."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The exemplar spans the design phase (CAD models in Autodesk Fusion360), the manufacturing phase (Bill‑of‑Materials and assembled hardware), and the operational phase (runtime logging, validation, and control during crane operation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation is achieved by continuous comparison of real trajectory data with simulated trajectories; distance metrics are computed and compared against a user‑defined threshold, with alerts emitted upon breach; fault detection research further refines validation by leveraging time‑series classification techniques."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses MQTT (internal signaling), PostgreSQL/TimescaleDB for data storage, and a serial (or USB) Python driver that connects to the Arduino‑based motor controllers; all interfaces are locally hosted on the same PC."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin runs locally on a personal computer; Docker Compose brings up TimescaleDB, Mosquitto, and Grafana in containers, while the Python gantrylib and HMI run natively; code and documentation are publicly available on Cosys‑Lab GitHub under an MIT license."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not explicitly presented in the documents; the exemplar is designed to run independently without external system integration."
]