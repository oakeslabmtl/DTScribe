// ----------------------------------------------------
// C3: Physical sensing components
// ----------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder that measures hoist swing on the gantry crane."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer that measures wind speed for the crane environment."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoSensorHub : DTDFVocab:SensingComponent [
    base:desc "Arduino board that reads swing angle, wind speed and motor driver feedback."
    DTDFVocab:producedData CraneStateDataTransmitted
]

// ----------------------------------------------------
// C4: Physical-to-virtual interaction (Data Transmitted)
// ----------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoSensorHub
]

// ----------------------------------------------------
// C10: Data (measurements)
// ----------------------------------------------------
instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Time‑series swing angle measurements from the encoder."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo DockerContainerLogging, DockerContainerGrafana, DockerContainerContinuousValidation
]

instance WindSpeedMeasurement : DTDFVocab:Data [
    base:desc "Time‑series wind speed measurements from the anemometer."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo DockerContainerLogging, DockerContainerGrafana, DockerContainerContinuousValidation
]

instance CraneStateMeasurement : DTDFVocab:Data [
    base:desc "Aggregated crane state including motor states and electromagnet status."
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo DockerContainerLogging, DockerContainerGrafana, DockerContainerContinuousValidation, DockerContainerFaultLocalization
]

// ----------------------------------------------------
// C10: Models / Data (digital models)
// ----------------------------------------------------
instance Fusion360CADModel : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane created in Autodesk Fusion360."
    DTDFVocab:inputTo DockerContainerCADViewer
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the trajectory generator to compute crane motions."
    DTDFVocab:inputTo DockerContainerTrajectoryGenerator
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model of crane dynamics and controllers."
    DTDFVocab:inputTo DockerContainerSimulation
]

// ----------------------------------------------------
// C11: Enablers (Docker containers & infrastructure)
// ----------------------------------------------------
instance DockerContainerLogging : DTDFVocab:Enabler [
    base:desc "Docker container running TimescaleDB for data logging."
    DTDFVocab:enables DataLoggingService
]

instance DockerContainerGrafana : DTDFVocab:Enabler [
    base:desc "Docker container running Grafana for visualizing crane data."
    DTDFVocab:enables VisualizationService
]

instance DockerContainerMQTTBroker : DTDFVocab:Enabler [
    base:desc "Docker container running Eclipse Mosquitto MQTT broker for inter‑service messaging."
    DTDFVocab:enables TrajectoryGenerationService, SimulationService, ContinuousValidationService, FaultLocalizationService
]

instance DockerContainerTrajectoryGenerator : DTDFVocab:Enabler [
    base:desc "Docker container hosting the trajectory generation service with the kinematic model."
    DTDFVocab:enables TrajectoryGenerationService
]

instance DockerContainerSimulation : DTDFVocab:Enabler [
    base:desc "Docker container hosting the physics‑based crane simulation service."
    DTDFVocab:enables SimulationService
]

instance DockerContainerContinuousValidation : DTDFVocab:Enabler [
    base:desc "Docker container hosting the continuous validation service."
    DTDFVocab:enables ContinuousValidationService
]

instance DockerContainerFaultLocalization : DTDFVocab:Enabler [
    base:desc "Docker container hosting fault localisation via time‑series classification."
    DTDFVocab:enables FaultLocalizationService
]

instance DockerContainerCADViewer : DTDFVocab:Enabler [
    base:desc "Docker container providing CAD model visualization capabilities."
    DTDFVocab:enables VisualizationService
]

// ----------------------------------------------------
// C6: Services
// ----------------------------------------------------
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs sensor measurements into a TimescaleDB database."
    DTDFVocab:provides LoggingInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time dashboards of crane state via Grafana."
    DTDFVocab:provides VisualizationInsight, OperatorInterventionAction
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal crane trajectories using a kinematic model."
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Emulates crane dynamics and controller behavior in a physics‑based simulation."
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories with simulated ones and raises alerts on deviation."
    DTDFVocab:provides RealTimeAlertInsight
]

instance FaultLocalizationService : DTDFVocab:Service [
    base:desc "Classifies time‑series measurement data to locate faults and support maintenance decisions."
    DTDFVocab:provides DiagnosticInsight, MaintenanceDecisionAction
]

// ----------------------------------------------------
// C17: Insights & Actions
// ----------------------------------------------------
instance LoggingInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data has been persisted in TimescaleDB."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of crane state for operator monitoring."
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory recommendations for crane motion."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulated trajectory data used for validation purposes."
]

instance RealTimeAlertInsight : DTDFVocab:Insight [
    base:desc "Real‑time alerts when measured trajectories deviate beyond the set threshold."
]

instance DiagnosticInsight : DTDFVocab:Insight [
    base:desc "Diagnostic insights derived from fault localisation to guide maintenance."
]

instance OperatorInterventionAction : DTDFVocab:Action [
    base:desc "Notifies operator via the dashboard to intervene when alerts occur."
    DTDFVocab:IsAutomatic false
]

instance MaintenanceDecisionAction : DTDFVocab:Action [
    base:desc "Suggests maintenance actions based on diagnostic insights."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application and the Trajectory Generator Service send motion commands (desired trajectories) to the Physical Crane Interface, which forwards them to the motor controllers and Arduino to drive the cart and hoist motors and actuate the electromagnet. The Human Machine Interface can also issue commands through the same path."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture consists of a physical gantry crane connected via a Python Physical Crane Interface to four local Python applications (Control, Logging, HMI, and the interface itself). These applications exchange messages through an MQTT broker. The twin services (trajectory generation, simulation, continuous validation) subscribe/publish via MQTT, store data in TimescaleDB, and visualise results in Grafana. All non‑physical containers run as Docker containers on a single PC."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service continuously compares measured trajectories against simulated ones, computing distance metrics and checking them against a configurable threshold; violations trigger operator alerts on the Grafana dashboard. Additional research extended this with time‑series classification to localise faults, providing higher‑fidelity validation of the twin models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication uses MQTT (Eclipse Mosquitto). The Physical Crane Interface communicates with the Arduino and motor drivers over serial/USB (implicit from Python program). Data persistence uses SQL queries to TimescaleDB. Visualization accesses the database via Grafana's native data source connectors."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software runs on a personal computer. The database, MQTT broker, and Grafana dashboard are Docker‑containerised and launched together with Docker‑Compose. The Python modules are installed via pip from the public GitHub repository. The repository includes Docker files, setup scripts, and documentation hosted on GitHub Pages."
]