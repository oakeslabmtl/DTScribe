// C2: Acting Components
instance HorizontalCartMotor : DTDFVocab:ActingComponent [
    base:desc "Motor that drives the horizontal cart movement along the gantry rail."
]

instance VerticalHoistMotor : DTDFVocab:ActingComponent [
    base:desc "Motor that drives the vertical lift mechanism of the hoist carriage."
]

instance ElectromagnetController : DTDFVocab:ActingComponent [
    base:desc "Controller that operates the electromagnet to pick up and release the container pucks."
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the crane to measure the swinging motion of the hoist carriage."
    DTDFVocab:producedData SwingAngleMeasurementTransmitted
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer that records the wind speed affecting the crane operations."
    DTDFVocab:producedData WindSpeedMeasurementTransmitted
]

// C4: Physical-to-virtual interaction - Data transmitted
instance SwingAngleMeasurementTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedMeasurementTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

// C10: Models/Data - Data source from sensors
instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Beat‑by‑beat swing‑angle sensor reading logged to the database."
    DTDFVocab:inputTo ValidationEngineEnabler, DataStorageEnabler, ControlEngineEnabler
    DTDFVocab:fromData SwingAngleMeasurementTransmitted
]

instance WindSpeedMeasurement : DTDFVocab:Data [
    base:desc "Beat‑by‑beat wind‑speed sensor reading logged to the database."
    DTDFVocab:inputTo ValidationEngineEnabler, DataStorageEnabler, ControlEngineEnabler
    DTDFVocab:fromData WindSpeedMeasurementTransmitted
]

// C10: Models/Data - Simulation outputs
instance SimulatedTrajectory : DTDFVocab:Data [
    base:desc "Expected state trajectories produced by the kinematic simulation."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance ValidationError : DTDFVocab:Data [
    base:desc "Euclidean error between measured and simulated positions used for continuous validation."
    DTDFVocab:inputTo ValidationEngineEnabler
]

// C11: Enablers
instance ControlEngineEnabler : DTDFVocab:Enabler [
    base:desc "Actuator and simulation engine that enables the OptimalControlService."
    DTDFVocab:enables OptimalControlService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Kinematic simulation engine enabling the SimulationService."
    DTDFVocab:enables SimulationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation engine that enables the ContinuousValidationService."
    DTDFVocab:enables ContinuousValidationService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance that stores sensor, simulation, and validation data."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Visualization engine that enables the DataVisualizationService."
    DTDFVocab:enables DataVisualizationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service that computes optimal motion plans based on live sensor input."
    DTDFVocab:provides MotionPlanInsight, MotorAdjustmentAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that ingests planned trajectory commands, runs the kinematic model, and stores simulated trajectories."
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that compares live sensor data against simulated trajectories and flags deviations."
    DTDFVocab:provides DeviationAlertInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that records the crane’s kinematic states to TimescaleDB for future analysis."
    DTDFVocab:provides HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service that renders the CAD model and displays real‑time trajectories."
    DTDFVocab:provides TrajectoryVisualizationInsight
]

// C17: Insights
instance MotionPlanInsight : DTDFVocab:Insight [
    base:desc "Real‑time trajectory plans generated by the optimal control service."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulated state trajectories produced by the kinematic model."
]

instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating when sensor data deviates beyond the configured tolerance."
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Historical logs of crane kinematic states."
]

instance TrajectoryVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of real‑time and simulated crane trajectories."
]

// C17: Actions
instance MotorAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic corrective action that adjusts motor positions during operation."
    DTDFVocab:IsAutomatic true
]

// C3: Physical sensing components (for completeness)
instance CraneStateInterface : DTDFVocab:SensingComponent [
    base:desc "Python interface that reads the crane’s real‑time state and forwards it to the logging application."
    DTDFVocab:producedData CraneStateMeasurementTransmitted
]

instance CraneStateMeasurementTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneStateInterface
]

instance CraneStateMeasurement : DTDFVocab:Data [
    base:desc "Continuous telemetry records of the crane’s real‑time state."
    DTDFVocab:inputTo DataStorageEnabler
    DTDFVocab:fromData CraneStateMeasurementTransmitted
]

// C17: Environment
instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains FloatingRail, LinearActuatorX, LinearActuatorY, HoistCarriage, VerticalLiftMechanism, ControlElectronics, CADModel, KinematicSimulator
]

// C3: Components
instance FloatingRail : DTDFVocab:Component [
    base:desc "Floating rail that supports horizontal motion of the gantry crane."
]

instance LinearActuatorX : DTDFVocab:Component [
    base:desc "Linear actuator providing X‑axis translation along the gantry rail."
]

instance LinearActuatorY : DTDFVocab:Component [
    base:desc "Linear actuator providing Y‑axis translation for the hoist carriage."
]

instance HoistCarriage : DTDFVocab:Component [
    base:desc "Carriage that carries the hoist mechanism along the gantry."
]

instance VerticalLiftMechanism : DTDFVocab:Component [
    base:desc "Vertical lift mechanism for raising and lowering the load."
]

instance ControlElectronics : DTDFVocab:Component [
    base:desc "Embedded controller system interfacing with motors and sensors."
]

instance CADModel : DTDFVocab:Component [
    base:desc "Computer‑aided design model of the gantry crane used for visualization."
]

instance KinematicSimulator : DTDFVocab:Component [
    base:desc "Software component that executes the kinematic model of the crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin system is orchestrated using a container‑based architecture identified by the C4 model. Contextually the system comprises six Docker containers: (i) a sensor ingestion service that streams data from Raspberry‑Pi GPIO via MQTT; (ii) a message broker container running ActiveMQ that routes real‑time telemetry to downstream services; (iii) an InfluxDB container that stores continuous telemetry and back‑filled prerecorded data; (iv) a trajectory‑generation container that computes motion paths for the gantry crane; (v) a simulation engine container that applies a physical model to predict wind‑force effects; and (vi) a visualization container that exposes a web dashboard using a Node.js/React stack. Inter‑container communication follows an asynchronous publish/subscribe pattern over the MQTT broker on port 1883, with canonical topics such as “sensors/temperature”, “commands/move”, and “state/trajectory”. The orchestration layer is implemented through Docker‑Compose locally and a lightweight VM image for easy deployment, ensuring that resource management (CPU, memory) is bounded per container and that scaling happens by adding or removing VM replicas. The containerized approach facilitates reproducibility, self‑containment, and separation of concerns across data acquisition, storage, processing, and UI components."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The digital twin’s Continuous Validation Service compares real‑time measurements from the swing‑angle encoder and hoist position against the outputs of the kinematic simulation.  For each trajectory segment, it computes a distance metric and compares the value to a pre‑configured tolerance threshold; any violation is logged and can trigger controller re‑planning or alerting.  This mechanism provides ongoing model fidelity verification and data integrity assurance, ensuring that the twin remains accurate throughout operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin relies on an MQTT broker to signal events and data between micro‑services such as the Trajectory Generator Service, Simulation Service, Continuous Validation Service, and the Dashboard. The broker implements the MQTT protocol (version not specified) and allows publish/subscribe communication among services. No further details on network topology, bandwidth, latency, or reliability mechanisms are provided. There is no explicit mention of secure sockets (e.g., TLS), authentication, or redundancy for the MQTT broker."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment details are not explicitly documented. All Python processes, the TimescaleDB database, and the MQTT broker are implied to run locally on the same host that controls the Physical Crane, suggesting an on‑premise, edge‑like deployment. No information is provided about cloud hosting, scalability mechanisms, or availability guarantees."
]