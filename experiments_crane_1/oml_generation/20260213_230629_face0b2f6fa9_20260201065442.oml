// C2: Acting Components
instance CartMotor : DTDFVocab:ActingComponent [
    base:desc "Electric motor that drives the crane carriage along the linear guide (cart movement)."
]

instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Electric motor that raises and lowers the hoist rope for load lifting."
]

instance HoistElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist end that picks up and releases pucks (containers)."
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring angular displacement (swing angle) of the hoisted load."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed affecting the load."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C5: Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing angle measurements from the encoder."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, GantryLibEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind speed measurements from the anemometer."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, GantryLibEnabler
]

// C10: Models/Data
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "Detailed CAD model capturing the geometric structure of the gantry crane."
    DTDFVocab:inputTo GantryLibEnabler
]

instance KinematicMotionModel : DTDFVocab:Model [
    base:desc "Kinematic model describing trolley translation, hoist motion and load swing, referencing the CAD geometry."
    DTDFVocab:inputTo GantryLibEnabler
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for bi‑directional messaging between physical sensors/actuators and digital‑twin services."
    DTDFVocab:enables ContinuousValidationService, HistoricalDataLoggingService
]

instance GantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python module gantrylib that packages CAD and kinematic models and provides algorithms for control, validation and trajectory computation."
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB PostgreSQL time‑series database used to store historical operational data."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboards for visualising real‑time and historic crane states."
    DTDFVocab:enables DataVisualizationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes optimal trajectories for the trolley to achieve target positions while guaranteeing zero residual swinging motion."
    DTDFVocab:provides OptimizedTrajectoryAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Records operational data from the crane into TimescaleDB for later analysis."
    DTDFVocab:provides ArchiveHistoricalDataAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Visualises real‑time and historic crane states through Grafana dashboards."
    DTDFVocab:provides VisualisationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares live sensor data with the kinematic model to detect deviations."
    DTDFVocab:provides DeviationDetectionInsight
]

// C17: Insights/Actions
instance OptimizedTrajectoryAction : DTDFVocab:Action [
    base:desc "Generates and transmits optimal control set‑points to the crane actuators."
    DTDFVocab:IsAutomatic true
]

instance ArchiveHistoricalDataAction : DTDFVocab:Action [
    base:desc "Writes time‑stamped crane state data into TimescaleDB."
    DTDFVocab:IsAutomatic true
]

instance VisualisationInsight : DTDFVocab:Insight [
    base:desc "Provides operators with visual representation of crane status and historical trends."
]

instance DeviationDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects and reports discrepancies between measured sensor data and kinematic model predictions."
]

// C13: Physical System Description
instance LabScaleGantryCrane : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane consisting of a miniature gantry structure, a motor‑driven trolley, controller unit and payload area for moving small pucks."
]

instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains LabScaleGantryCrane, CartMotor, HoistMotor, HoistElectromagnet, SwingAngleEncoder, Anemometer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (a Python application) uses the Physical Crane Interface to send commands to the crane controllers, thereby controlling the crane. No further details on command structure, validation, or acknowledgment are given."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is orchestrated with Docker containers. Core components include a Python‑based simulation/model, an MQTT broker for bidirectional communication with the physical crane, and a TimescaleDB instance for storing time‑series data. Docker (e.g., Docker Compose) coordinates container deployment, networking, and resource isolation, providing an ad‑hoc but cohesive integration of all twin services."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The exemplar includes a continuous validation service that constantly checks the consistency between the physical crane’s measured state and the predictions generated by the CAD‑based kinematic model. This service underpins research on continuous validation methods, fault detection, and the DarTwin notation for system evolution. Validation is performed online during operation by comparing streamed sensor data against model outputs; however, the document does not provide quantitative fidelity thresholds, explicit uncertainty quantification techniques, or detailed quality‑assurance procedures beyond this comparative validation approach."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication is performed via an MQTT broker for signaling, while the Database (TimescaleDB) and Dashboard (Grafana) are accessed directly by the respective services. The architecture consists of multiple containers running on the same system; no specific network topology, bandwidth, latency, redundancy, or security mechanisms are described."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All six digital‑twin containers (Database, Dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service, MQTT Broker) are deployed alongside the physical‑crane software on the same hardware platform, using containerized Python applications and a TimescaleDB instance. The document does not mention cloud or edge platforms, scalability approaches, or availability guarantees."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration is limited to the MQTT protocol for data exchange with the physical crane; all components run locally without reliance on external cloud services or enterprise middleware. No additional external standards or enterprise system interfaces (such as OPC UA, AutomationML, or Azure services) are mentioned."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar adopts AutomationML (AML) as the model‑exchange and specification framework for its digital twin (referred to as AML4DT), thereby complying with the AutomationML standard for representing engineering data and enabling interoperability. No other explicit industry standards, certification requirements, or compliance frameworks are mentioned for the GreenhouseDT or the lab‑scale gantry crane exemplars."
]