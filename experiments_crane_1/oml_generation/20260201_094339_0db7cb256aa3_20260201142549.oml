// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder mounted on the hoist to measure residual oscillation"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed"
    DTDFVocab:producedData AnemometerDataTransmitted
]

instance CartMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the cart motor providing cart position"
    DTDFVocab:producedData CartMotorPositionDataTransmitted
]

instance HoistMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the hoist motor providing hoist position"
    DTDFVocab:producedData HoistMotorPositionDataTransmitted
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance CartMotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoder
]

instance HoistMotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoder
]

// Data instances
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Swing angle telemetry data from swing angle encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo LoggingEnabler, ValidationEnabler
]

instance AnemometerData : DTDFVocab:Data [
    base:desc "Ambient wind speed data from anemometer"
    DTDFVocab:fromData AnemometerDataTransmitted
    DTDFVocab:inputTo LoggingEnabler, ValidationEnabler
]

instance CartMotorPositionData : DTDFVocab:Data [
    base:desc "Cart motor position data from cart motor encoder"
    DTDFVocab:fromData CartMotorPositionDataTransmitted
    DTDFVocab:inputTo LoggingEnabler, ValidationEnabler
]

instance HoistMotorPositionData : DTDFVocab:Data [
    base:desc "Hoist motor position data from hoist motor encoder"
    DTDFVocab:fromData HoistMotorPositionDataTransmitted
    DTDFVocab:inputTo LoggingEnabler, ValidationEnabler
]

// C1: Acting Components
instance CartMotor : DTDFVocab:ActingComponent [
    base:desc "Cart motor driven by Trinamic TMC4671-Eval controller"
]

instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist motor driven by Trinamic TMC4671-Eval controller, coupled to electromagnet"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet providing vertical motion on the hoist motor's carriage"
]

instance LinearRails : DTDFVocab:ActingComponent [
    base:desc "Linear rails providing guided motion for the gantry frame"
]

// C10: Models/Data
instance CADGeometryCraneModel : DTDFVocab:Model [
    base:desc "3D CAD geometry of the lab‑scale gantry crane"
    DTDFVocab:inputTo SimulationEnabler
]

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the trajectory generator for swing‑free motion profiling"
    DTDFVocab:inputTo TrajectoryEnabler
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model for comparison used by the simulation service"
    DTDFVocab:inputTo SimulationEnabler
]

// C11: Enablers
instance LoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance used for storing all telemetry"
    DTDFVocab:enables LoggingService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker and message pipeline for continuous validation"
    DTDFVocab:enables ContinuousValidationService
]

instance TrajectoryEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib library enabling trajectory generation"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation container powered by physics model"
    DTDFVocab:enables SimulationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard enabling real‑time visualization"
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that compares executed trajectories against simulated replicas, computing distance metrics and flagging threshold breaches"
    DTDFVocab:provides TrajectoryDeviationAlert, CorrectTrajectoryAction
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service that applies a kinematic model to produce optimized, swing‑free motion profiles"
    DTDFVocab:provides OptimizedTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that reproduces the crane motion for a given plan using physics‑based simulation"
    DTDFVocab:provides PhysicsSimulationAction
]

instance LoggingService : DTDFVocab:Service [
    base:desc "Service that continuously archives all telemetry into TimescaleDB"
    DTDFVocab:provides ArchiveTelemetryAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboard providing real‑time plots, confidence bounds, and alert panels"
    DTDFVocab:provides TimeSeriesPlotInsight
]

// C17: Insights/Actions
instance TrajectoryDeviationAlert : DTDFVocab:Insight [
    base:desc "Alert when trajectory deviations exceed thresholds, displayed on Grafana dashboard"
]

instance CorrectTrajectoryAction : DTDFVocab:Action [
    base:desc "Operator action to correct the trajectory execution"
    DTDFVocab:IsAutomatic false
]

instance OptimizedTrajectoryAction : DTDFVocab:Action [
    base:desc "Generate optimized swing‑free motion profile"
    DTDFVocab:IsAutomatic true
]

instance PhysicsSimulationAction : DTDFVocab:Action [
    base:desc "Run physics‑based simulation for given trajectory plan"
    DTDFVocab:IsAutomatic true
]

instance ArchiveTelemetryAction : DTDFVocab:Action [
    base:desc "Persist telemetry into TimescaleDB"
    DTDFVocab:IsAutomatic true
]

instance TimeSeriesPlotInsight : DTDFVocab:Insight [
    base:desc "Real‑time time‑series plots and confidence bounds on Grafana dashboard"
]

// C4: Physical and Virtual Containers
instance PhysicalCraneContainer : DTDFVocab:Component [
    base:desc "Physical gantry crane that moves container replicas"
]

instance CraneInterfaceComponent : DTDFVocab:Component [
    base:desc "Interface between physical crane and control system"
]

instance ControlApplicationComponent : DTDFVocab:Component [
    base:desc "Control application orchestrating crane operations"
]

instance LoggingApplicationComponent : DTDFVocab:Component [
    base:desc "Logging application that streams state to TimescaleDB"
]

instance HMIComponent : DTDFVocab:Component [
    base:desc "Human‑Machine Interface for operator interaction"
]

instance TimescaleDBContainer : DTDFVocab:Component [
    base:desc "TimescaleDB container used for telemetry storage"
]

instance GrafanaContainer : DTDFVocab:Component [
    base:desc "Grafana container for visualization"
]

instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Container running trajectory generator service"
]

instance SimulationContainer : DTDFVocab:Component [
    base:desc "Container running simulation service"
]

instance ContinuousValidationContainer : DTDFVocab:Component [
    base:desc "Container running continuous validation service"
]

instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Mosquitto MQTT broker container"
]

// C8: Environment
instance LabScaleGantryCraneSystem : DTDFVocab:Environment [
    base:contains PhysicalCraneContainer, CraneInterfaceComponent, ControlApplicationComponent, LoggingApplicationComponent, HMIComponent, TimescaleDBContainer, GrafanaContainer, TrajectoryGeneratorContainer, SimulationContainer, ContinuousValidationContainer, MQTTBrokerContainer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, executed in Python, generates trajectory commands (desired cart and hoist positions) and forwards them through the Crane Interface to the physical motor controllers; operator‑initiated commands from the HMI are also routed via the Control Application to the interface. MQTT is used solely for inter‑service signalling."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates continuously; data are ingested as frequently as the physical sensors sample, and services such as validation, trajectory planning, and simulation are triggered by incoming data or by explicit operator requests. No fixed time‑step is defined in the documentation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin is orchestrated by a Docker Compose stack consisting of the database, MQTT broker, dashboard, trajectory generator, simulation, and continuous validation containers.  The physical side runs a Python control application, interface, and logging modules, all interconnected through MQTT and database writes, achieving a coherent cyber‑physical system."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (CAD models in Autodesk Fusion360 and Capella/Arcadia models), Manufacturing (BOM and Arduino shield design in KiCad), Operation (real‑time data logging, trajectory execution, continuous validation, and visualization)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by a continuous‑validation service that compares real‑time sensor data against the simulation’s expected trajectory, computing a distance metric and flagging deviations beyond a preset threshold; no formal model verification is reported; validity is maintained through runtime comparison."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The physical hardware communicates with the twin via a local serial/USB interface (Arduino and TMC4671‑Eval drivers). Data and control commands are routed through Python processes; inter‑service messages are exchanged over a local Mosquitto MQTT broker; data visualisation retrieves entries via Grafana’s native TimescaleDB connector. All components reside on the same personal computer and communicate over the local Docker network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin stack is containerised and deployed via Docker Compose on a single personal computer (host machine).  The GitHub repository hosts configuration files, Dockerfiles, and scripts.  Documentation is served through MkDocs on GitHub Pages.  All components run locally, with no cloud deployment noted."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "No explicit integration with external DTs or enterprise systems is described; the twin operates in isolation using open‑source components."
]