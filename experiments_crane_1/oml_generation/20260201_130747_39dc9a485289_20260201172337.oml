// C3: Physical Sensing Components
instance GreenhouseEnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded environmental sensors (temperature, humidity, light) integrated with GreenhouseDT for localized data acquisition. Implicitly inferred from GreenhouseDT's reliance on environmental monitoring without explicit sensor types."
    DTDFVocab:producedData GreenhouseEnvironmentalDataTransmitted
]

instance AirQualitySensorArray : DTDFVocab:SensingComponent [
    base:desc "Set of sensors on Raspberry Pi for real-time measurement of indoor air quality parameters (e.g., CO2, particulate matter, VOCs). No explicit sensor types or spatial distribution provided."
    DTDFVocab:producedData AirQualityDataTransmitted
]

instance CranePositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder sensors on the lab-scale gantry crane measuring joint positions (e.g., horizontal/vertical displacement) for real-time kinematic state tracking."
    DTDFVocab:producedData CranePositionDataTransmitted
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Velocity sensors (e.g., tachometers) measuring end-effector and joint velocities for trajectory validation and control feedback."
    DTDFVocab:producedData CraneVelocityDataTransmitted
]

instance CraneForceTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Force/torque sensors monitoring payload dynamics (e.g., actuator currents, residual swinging motion) for fault detection and dynamic modeling."
    DTDFVocab:producedData CraneForceTorqueDataTransmitted
]

// C4: Physical-to-Virtual Interaction (DataTransmitted)
instance GreenhouseEnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseEnvironmentalSensor
]

instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualitySensorArray
]

instance CranePositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionEncoder
]

instance CraneVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocitySensor
]

instance CraneForceTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneForceTorqueSensor
]

instance TrajectoryExecutionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionEncoder, CraneVelocitySensor, CraneForceTorqueSensor
    base:desc "Composite data stream including actual movement paths, timestamps, and sensor measurements (e.g., residual swinging motion) for real-time trajectory comparison."
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "Python-implemented kinematic model of the lab-scale gantry crane for simulating crane movements and validating trajectories. Used for trajectory optimization and motion planning."
    DTDFVocab:inputTo PythonEnabler, DockerContainerEnabler
]

instance AutomationMLAirQualityModel : DTDFVocab:Model [
    base:desc "AutomationML-based digital twin model for runtime visualization, simulation, and prediction of indoor air quality. Supports model-driven engineering for virus spread prevention analytics."
    DTDFVocab:inputTo PythonEnabler, AutomationMLEngineEnabler
]

instance TimeseriesOperationalData : DTDFVocab:Data [
    base:desc "Structured storage of sensor/actuator telemetry (e.g., joint positions, payload forces, actuator currents) for post-processing, fault diagnosis, and trend analysis."
    DTDFVocab:fromData CranePositionDataTransmitted, CraneVelocityDataTransmitted, CraneForceTorqueDataTransmitted, TrajectoryExecutionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HistoricalTrajectoryData : DTDFVocab:Data [
    base:desc "Versioned time-series data of crane operational metrics (e.g., cycle time, energy use) for long-term performance degradation analysis and data-driven maintenance."
    DTDFVocab:fromData TrajectoryExecutionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance RealTimeCraneStateData : DTDFVocab:Data [
    base:desc "High-frequency composite data stream of crane states (position, velocity, acceleration, puck/container status) for real-time synchronization and discrepancy detection."
    DTDFVocab:fromData CranePositionDataTransmitted, CraneVelocityDataTransmitted, CraneForceTorqueDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance AirQualitySimulationData : DTDFVocab:Data [
    base:desc "Processed sensor data from AirQualitySensorArray used for runtime visualization and prediction of indoor air quality dynamics."
    DTDFVocab:fromData AirQualityDataTransmitted
    DTDFVocab:inputTo PythonEnabler, AzurePipelineEnabler
]

// C11: Enablers
instance PythonEnabler : DTDFVocab:Enabler [
    base:desc "Python programming language and gantrylib library for kinematic modeling, control logic implementation, and prototyping validation algorithms."
    DTDFVocab:enables TrajectoryOptimizationService, FaultDetectionService, ContinuousValidationService, DataVisualizationService
]

instance DockerContainerEnabler : DTDFVocab:Enabler [
    base:desc "Docker for containerizing services (e.g., data logging, visualization) to ensure reproducibility and isolation across development environments."
    DTDFVocab:enables TrajectoryOptimizationService, DataVisualizationService, HistoricalDataLoggingService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database optimized for high write/read throughput of operational metrics (e.g., sensor readings, control commands) with structured storage capabilities."
    DTDFVocab:enables HistoricalDataLoggingService, FaultDetectionService, ContinuousValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for real-time, low-latency data streaming between physical sensors and Digital Twin services via pub/sub architecture."
    DTDFVocab:enables PhysicalCraneInterface, DataVisualizationService, ContinuousValidationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Interactive dashboarding tool for real-time and retrospective visualization of crane telemetry, alerts, and historical trends with 3D CAD model synchronization."
    DTDFVocab:enables DataVisualizationService, ContinuousValidationService
]

instance RESTAPIEnabler : DTDFVocab:Enabler [
    base:desc "REST APIs for service-to-service interactions (e.g., control commands from optimization modules) with standardized JSON payloads."
    DTDFVocab:enables TrajectoryOptimizationService, FaultDetectionService
]

instance GitVersionControlEnabler : DTDFVocab:Enabler [
    base:desc "Git for version control of Digital Twin code, models, and validation algorithms to ensure reproducibility and traceability."
    DTDFVocab:enables SystemEvolutionService
]

instance JupyterNotebookEnabler : DTDFVocab:Enabler [
    base:desc "Jupyter Notebooks for prototyping validation algorithms, fault detection methods, and exploratory data analysis."
    DTDFVocab:enables FaultDetectionService, ContinuousValidationService
]

instance AutomationMLEngineEnabler : DTDFVocab:Enabler [
    base:desc "AutomationML runtime engine for model-driven engineering of digital twin components, supporting hierarchical structuring and runtime execution."
    DTDFVocab:enables AirQualitySimulationService
]

instance AzurePipelineEnabler : DTDFVocab:Enabler [
    base:desc "Microsoft Azure tools for pipeline implementation of air quality analytics, including cloud-based data processing and API-driven decision support."
    DTDFVocab:enables AirQualitySimulationService
]

// C6: Services
instance TrajectoryOptimizationService : DTDFVocab:Service [
    base:desc "Real-time trajectory optimization and motion planning for the crane’s end-effector, minimizing energy consumption and avoiding collisions. Integrates with kinematic model for feasible trajectory generation."
    DTDFVocab:provides OptimalTrajectoryInsight, MotionCommandAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Time-series data storage and versioning of operational metrics (e.g., joint positions, payload forces) for post-processing and long-term analysis."
    DTDFVocab:provides HistoricalPerformanceInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Real-time and retrospective visualization of crane states with 3D CAD overlays, kinematic animations, and dashboard-based KPI monitoring (e.g., cycle time, energy use)."
    DTDFVocab:provides CraneStateVisualizationInsight, FaultAlertInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Real-time synchronization and discrepancy detection between physical crane and digital twin, with automated comparison of predicted vs. actual states and anomaly flagging (±5% error margin)."
    DTDFVocab:provides ValidationDiscrepancyInsight, SynchronizationAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Proactive fault diagnosis and predictive maintenance for crane components using pattern recognition in sensor data (e.g., abnormal vibration spectra, current spikes)."
    DTDFVocab:provides FaultDiagnosisInsight, MaintenanceRecommendationAction
]

instance SystemEvolutionService : DTDFVocab:Service [
    base:desc "Formalized representation of the crane’s system evolution (e.g., hardware/software upgrades, model refinements) with version-controlled models and change impact analysis."
    DTDFVocab:provides SystemChangeInsight, ModelUpdateAction
]

instance AirQualitySimulationService : DTDFVocab:Service [
    base:desc "Runtime visualization, simulation, and prediction of indoor air quality dynamics using AutomationML-based models and Azure pipelines for virus spread prevention analytics."
    DTDFVocab:provides AirQualityPredictionInsight, ControlRecommendationAction
]

instance PhysicalCraneInterface : DTDFVocab:Service [
    base:desc "Python program interfacing the physical crane with the Digital Twin, transmitting state data (position, velocity, acceleration) and trajectory execution data via MQTT."
    DTDFVocab:provides CraneStateDataInsight
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Feasible trajectories optimized for energy efficiency and collision avoidance, validated against kinematic constraints and real-time feedback."
]

instance MotionCommandAction : DTDFVocab:Action [
    base:desc "Closed-loop control commands sent to crane actuators based on optimized trajectories and real-time state feedback."
    DTDFVocab:IsAutomatic true
]

instance HistoricalPerformanceInsight : DTDFVocab:Insight [
    base:desc "Long-term trends in crane performance (e.g., degradation patterns, operational efficiency) derived from versioned time-series data."
]

instance CraneStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D visualization of crane states (e.g., end-effector position, joint angles) synchronized with physical crane movements."
]

instance FaultAlertInsight : DTDFVocab:Insight [
    base:desc "Anomaly flags for deviations exceeding predefined thresholds (e.g., ±5% error margin in trajectory execution)."
]

instance ValidationDiscrepancyInsight : DTDFVocab:Insight [
    base:desc "Quantified discrepancies between predicted and actual crane states (e.g., Euclidean or kinematic error metrics) for model validation."
]

instance SynchronizationAction : DTDFVocab:Action [
    base:desc "Automated synchronization of digital twin with physical crane state to maintain fidelity within acceptable error bounds."
    DTDFVocab:IsAutomatic true
]

instance FaultDiagnosisInsight : DTDFVocab:Insight [
    base:desc "Root cause analysis of faults (e.g., sensor drift, actuator wear) using pattern recognition in sensor data and historical trends."
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Predictive maintenance recommendations based on fault detection results and component health trends."
    DTDFVocab:IsAutomatic false
]

instance SystemChangeInsight : DTDFVocab:Insight [
    base:desc "Impact analysis of proposed system modifications (e.g., new sensors, control algorithms) on digital twin accuracy and performance."
]

instance ModelUpdateAction : DTDFVocab:Action [
    base:desc "Version-controlled updates to digital twin models (e.g., kinematic refinements, sensor calibration adjustments)."
    DTDFVocab:IsAutomatic false
]

instance AirQualityPredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics for indoor air quality dynamics (e.g., virus spread risk) derived from real-time sensor data and simulation models."
]

instance ControlRecommendationAction : DTDFVocab:Action [
    base:desc "Automated control recommendations for HVAC systems or ventilation adjustments based on air quality predictions."
    DTDFVocab:IsAutomatic true
]

instance CraneStateDataInsight : DTDFVocab:Insight [
    base:desc "Real-time state data of the physical crane (position, velocity, acceleration) transmitted via MQTT for digital twin synchronization."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The **Virtual-to-Physical Interaction** in the Digital Twin system is mediated by the **Control Application** and **Trajectory Generator Service**, which translate digital commands into physical actions for the **Physical Crane**. Key components include:
  - **Command Types**:
    - **Trajectory commands**: Generated by the **Trajectory Generator Service** using a **kinematics model** to produce **optimal movement trajectories** (e.g., spline-based paths) with **zero residual swinging motion** at termination.
    - **Configuration commands**: Sent via the **Human Machine Interface (HMI)** to adjust crane parameters (e.g., speed limits, safety zones).
  - **Control Message Formats**: Implicitly structured as **Python objects** or **serialized data** (e.g., JSON/Protobuf) transmitted via the **Physical Crane Interface** to the crane’s controllers.
  - **Validation and Authentication**:
    - **Trajectory Validation**: The **Continuous Validation Service** ensures executed trajectories match simulations by comparing **distance metrics** (e.g., positional error) against thresholds. If breached, operators are notified via the **Dashboard**.
    - **Command Authentication**: Not explicitly detailed, but inferred as **implicit trust** within the closed-loop system (no mention of cryptographic mechanisms).
  - **Feedback Systems**:
    - **Real-time sensor feedback** from the **Physical Crane** (e.g., encoders, IMUs) is looped back to the **Logging Application** and **Validation Service** for continuous monitoring.
    - **Operator feedback**: The **HMI** provides visual/auditory alerts for threshold breaches or system anomalies.
  - **Conflict Resolution**:
    - **Priority-based**: Critical safety commands (e.g., emergency stops) likely override trajectory commands, though specifics are undocumented.
    - **Trajectory Replanning**: The **Trajectory Generator Service** may recompute paths if simulations predict collisions or instability.
  - **Command Execution Confirmation**:
    - Implicit via the **Logging Application**, which records executed trajectories alongside timestamps. The **Validation Service** cross-checks these logs against simulations to confirm adherence to commands."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin systems in the documents adopt a **lightweight, ad-hoc orchestration approach** rather than relying on commercial frameworks. **GreenhouseDT** uses a **hybrid architecture** combining **InfluxDB (time-series database)**, **ActiveMQ (message broker)**, and **virtual machines (VMs)** for behavioral adaptation, with VMs preloaded with prerecorded data to simulate real-time synchronization. The **Air Quality Management** exemplar employs a **Microsoft Azure-based pipeline** for runtime visualization, simulation, and prediction, integrating **AutomationML** for model-driven digital twin engineering. Both exemplars emphasize **containerization/virtualization** (e.g., VMs, Raspberry Pi) for modular deployment but lack explicit orchestration patterns like microservices or edge-cloud coordination. The **gantry crane** system, while inspired by cyber-physical logistics, is described using **C4 Model** for architecture visualization but provides no details on orchestration mechanisms. **No mention of resource management, service mesh, or dynamic reconfiguration** is present."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The *GreenhouseDT* exemplar emphasizes **behavioral adaptation** of both the physical system and its digital twin, implying dynamic fidelity adjustments to maintain alignment. Validation methods are not explicitly described, but the use of **prerecorded data** in virtual machine images suggests offline testing and comparison against historical or simulated scenarios. The *Air Quality Management* exemplar focuses on **runtime visualization, simulation, and prediction**, indicating a reliance on model-driven validation via Azure tools, though no formal verification methods (e.g., uncertainty quantification, error correction) are detailed. Uncertainty sources (e.g., sensor noise, model approximations) are not quantified, and no explicit quality assurance processes are documented. The ad-hoc approach in both exemplars implies manual or domain-specific validation rather than standardized protocols."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **MQTT Broker** serves as the central communication hub for inter-service signaling, enabling asynchronous message exchange between containers (e.g., **Trajectory Generator Service**, **Simulation Service**, **Logging Application**). The system is deployed on a **personal computer**, implying a localized network topology with minimal latency. No specific communication protocols (e.g., TCP/IP, UDP) or network architectures (e.g., star, mesh) are detailed in the documents. Bandwidth and latency requirements are not quantified, but the real-time nature of trajectory validation suggests low-latency constraints. Redundancy mechanisms are not mentioned, nor are security protocols (e.g., encryption, access control) for network communication. The **TimescaleDB database** and **Grafana Dashboard** rely on the same infrastructure, with no explicit separation of network segments."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin system is deployed **on-premise** on a **personal computer**, with all software containers (e.g., **Trajectory Generator Service**, **Simulation Service**, **Logging Application**) running locally. The architecture supports a **monolithic deployment model** via a **docker compose file**, consolidating services into a single host environment. Computational requirements are tailored to the **TimescaleDB database** (for time-series data storage) and the **Trajectory Generator Service** (for real-time kinematics calculations), with no explicit scalability mechanisms (e.g., horizontal/vertical scaling) described. Storage is managed within the database, with no mention of external cloud or edge hosting. Availability and reliability are not quantified, but the system’s design implies high dependability on the local hardware and network stability. No automatic failover or backup mechanisms are referenced."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates horizontally via **MQTT (Message Queuing Telemetry Transport)** for lightweight, publish-subscribe communication between the physical gantry crane and its digital counterpart. No enterprise-wide interoperability standards (e.g., OPC UA, Industry 4.0 protocols) or dependencies on external Digital Twin frameworks are documented. The system’s integration is confined to internal containerized services, with no explicit APIs or gateways for third-party systems. Data exchange is limited to the MQTT broker, which acts as the sole intermediary for sensor/actuator data."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The **Air Quality Management** exemplar adheres to **AutomationML** for digital twin modeling, a **standardized engineering format** for automation and control systems, ensuring interoperability with industry tools. The **GreenhouseDT** exemplar uses **InfluxDB** (a de facto standard for time-series data) and **ActiveMQ** (a widely adopted message broker protocol), though neither is a domain-specific digital twin standard. The **lab-scale gantry crane** system employs the **C4 Model** for architectural documentation, a **software-centric modeling standard** rather than a digital twin-specific framework. No **certification requirements** or **compliance frameworks** (e.g., ISO 23247 for digital twins) are mentioned, and interoperability is limited to **ad-hoc integrations** (e.g., AutomationML, InfluxDB/ActiveMQ stacks) rather than cross-domain standards."
]