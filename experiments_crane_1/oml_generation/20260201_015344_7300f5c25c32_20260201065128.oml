// ====================
// C3: Physical sensing components
// ====================

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder that measures hoist swing on the gantry crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer that measures ambient wind speed affecting crane dynamics"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reading motor states (position, speed, current) from stepper motor controllers"
    DTDFVocab:producedData MotorStateDataTransmitted
]

// ====================
// C4: Physical-to-virtual interaction (DataTransmitted)
// ====================

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStateSensor
]

// ====================
// C10: Data instances
// ====================

instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Time‑series of swing angle values streamed from the encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerMosquitto
]

instance WindSpeedMeasurement : DTDFVocab:Data [
    base:desc "Time‑series of wind speed values streamed from the anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerMosquitto
]

instance MotorStateMeasurement : DTDFVocab:Data [
    base:desc "Aggregated motor state readings (position, speed, current) from stepper drivers"
    DTDFVocab:fromData MotorStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerMosquitto
]

// ====================
// C10: Model instances
// ====================

instance CraneCADModel : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane created in Autodesk Fusion360"
    DTDFVocab:inputTo VisualizationServiceEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator to compute optimal trajectories"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance CranePhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model of crane dynamics used by the Simulation Service"
    DTDFVocab:inputTo SimulationServiceEnabler
]

instance ValidationMetricModel : DTDFVocab:Model [
    base:desc "Model defining validation metrics for comparing executed and simulated trajectories"
    DTDFVocab:inputTo ContinuousValidationEnabler
]

// ====================
// C11: Enablers
// ====================

instance MQTTBrokerMosquitto : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker facilitating inter‑service messaging"
    DTDFVocab:enables DataLoggingService, VisualizationService, TrajectoryGeneratorService,
               SimulationService, ContinuousValidationService, FaultLocalizationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) used for persisting time‑series measurement data"
    DTDFVocab:enables DataLoggingService, VisualizationService,
               ContinuousValidationService, FaultLocalizationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for visualizing stored data and alerts"
    DTDFVocab:enables VisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Docker container running the Trajectory Generator Service"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationServiceEnabler : DTDFVocab:Enabler [
    base:desc "Docker container running the Physics Simulation Service"
    DTDFVocab:enables SimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Docker container running the Continuous Validation Service"
    DTDFVocab:enables ContinuousValidationService
]

instance FaultLocalizationEnabler : DTDFVocab:Enabler [
    base:desc "Docker container running the Fault Localization (time‑series classification) Service"
    DTDFVocab:enables FaultLocalizationService
]

instance VisualizationServiceEnabler : DTDFVocab:Enabler [
    base:desc "Enabler connecting Grafana to TimescaleDB for dashboard rendering"
    DTDFVocab:enables VisualizationService
]

instance DataLoggingServiceEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that writes incoming measurement data into TimescaleDB"
    DTDFVocab:enables DataLoggingService
]

// ====================
// C6: Services
// ====================

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that continuously writes sensor state measurements into TimescaleDB"
    DTDFVocab:provides DataLoggingInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that visualizes measurement and validation data on Grafana dashboards"
    DTDFVocab:provides VisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service that generates optimal crane trajectories using the kinematic model"
    DTDFVocab:provides TrajectoryOptimizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that emulates crane dynamics based on the physics simulation model"
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that compares executed trajectories with simulated ones and raises real‑time alerts"
    DTDFVocab:provides RealTimeAlertInsight, OperatorInterventionAction
]

instance FaultLocalizationService : DTDFVocab:Service [
    base:desc "Service that performs time‑series classification to localise faults and suggest diagnostics"
    DTDFVocab:provides FaultLocalizationInsight, DiagnosticAction
]

// ====================
// C17: Insights & Actions
// ====================

instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Insight that measurement data are successfully persisted in TimescaleDB"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight that current crane state and alerts are displayed on Grafana dashboards"
]

instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight that an optimal trajectory has been computed for the next move"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight that a simulated trajectory reflecting crane physics is available"
]

instance RealTimeAlertInsight : DTDFVocab:Insight [
    base:desc "Real‑time alert indicating measured trajectory deviates beyond the set threshold"
]

instance OperatorInterventionAction : DTDFVocab:Action [
    base:desc "Action prompting the operator via Grafana to intervene and correct the crane motion"
    DTDFVocab:IsAutomatic false
]

instance FaultLocalizationInsight : DTDFVocab:Insight [
    base:desc "Insight that a specific fault has been localized using time‑series classification"
]

instance DiagnosticAction : DTDFVocab:Action [
    base:desc "Action recommending maintenance or calibration based on diagnostic insight"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application and the Trajectory Generator Service send motion commands (desired trajectories) to the Physical Crane Interface, which forwards them to the motor controllers and Arduino to drive the cart and hoist motors and actuate the electromagnet. The Human Machine Interface can also issue commands through the same path."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture consists of a physical gantry crane connected via a Python Physical Crane Interface to four local Python applications (Control, Logging, HMI, and the interface itself). These applications exchange messages through an MQTT broker. The twin services (trajectory generation, simulation, continuous validation) subscribe/publish via MQTT, store data in TimescaleDB, and visualise results in Grafana. All non‑physical containers run as Docker containers on a single PC."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service continuously compares measured trajectories against simulated ones, computing distance metrics and checking them against a configurable threshold; violations trigger operator alerts on the Grafana dashboard. Additional research extended this with time‑series classification to localise faults, providing higher‑fidelity validation of the twin models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication uses MQTT (Eclipse Mosquitto). The Physical Crane Interface communicates with the Arduino and motor drivers over serial/USB (implicit from Python program). Data persistence uses SQL queries to TimescaleDB. Visualization accesses the database via Grafana's native data source connectors."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software runs on a personal computer. The database, MQTT broker, and Grafana dashboard are Docker‑containerised and launched together with Docker‑Compose. The Python modules are installed via pip from the public GitHub repository. The repository includes Docker files, setup scripts, and documentation hosted on GitHub Pages."
]