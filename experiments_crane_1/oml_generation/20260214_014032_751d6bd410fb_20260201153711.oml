// C3: Physical Sensing Components
instance CranePositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures the angular position of crane components (gantry, hoist, puck) with millisecond-level precision for real-time trajectory validation."
    DTDFVocab:producedData CranePositionData
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Captures linear and angular velocity of crane components using IMU-based sensors for dynamic model validation."
    DTDFVocab:producedData CraneVelocityData
]

instance LoadCellSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors payload forces and torque distribution to detect overloading or mechanical stress anomalies."
    DTDFVocab:producedData LoadForceData
]

instance ActuatorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Tracks motor currents to identify actuator failures or energy consumption patterns for optimization."
    DTDFVocab:producedData ActuatorCurrentData
]

instance LimitSwitchSensor : DTDFVocab:SensingComponent [
    base:desc "Detects physical constraints (e.g., end-of-travel stops) to prevent collisions and enforce operational boundaries."
    DTDFVocab:producedData LimitSwitchData
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Measures ambient conditions (temperature, humidity) affecting crane operation in laboratory environments."
    DTDFVocab:producedData EnvironmentalData
]

// C4: Physical-to-Virtual Interaction
instance CranePositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionEncoder
    base:desc "Transmits joint angles (gantry, hoist, puck) at millisecond intervals via OPC UA protocol for real-time trajectory synchronization."
]

instance CraneVelocityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocitySensor
    base:desc "Streams velocity vectors with sub-millisecond timestamps for dynamic model validation and control feedback."
]

instance LoadForceData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadCellSensor
    base:desc "Sends force measurements (N/m) at 1kHz sampling rate for payload stability assessment and fault detection."
]

instance ActuatorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ActuatorCurrentSensor
    base:desc "Transmits motor current profiles (A) for energy optimization and torque anomaly detection via MQTT broker."
]

instance LimitSwitchData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LimitSwitchSensor
    base:desc "Binary state signals (ON/OFF) for safety-critical boundary enforcement with 1ms latency."
]

instance EnvironmentalData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
    base:desc "Periodic environmental readings (1Hz) stored for operational context analysis in TimescaleDB."
]

instance TrajectoryExecutionLog : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionEncoder, CraneVelocitySensor
    base:desc "Timestamped records of executed waypoints, control signals, and actuator commands for post-mortem validation."
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "Forward/inverse kinematic solver implemented in MATLAB/Simulink for trajectory planning and collision avoidance."
    DTDFVocab:inputTo KinematicSimulationEnabler, TrajectoryOptimizationEnabler
]

instance DynamicModel : DTDFVocab:Model [
    base:desc "Physics-based model (PyBullet) simulating crane dynamics including payload interactions and actuator delays."
    DTDFVocab:inputTo DynamicValidationEnabler, ControlParameterAdaptationEnabler
]

instance ControlModel : DTDFVocab:Model [
    base:desc "PID/MPC controller implementation with adaptive gain scheduling for real-time trajectory tracking."
    DTDFVocab:inputTo RealTimeControlEnabler
]

instance HistoricalOperationalData : DTDFVocab:Data [
    base:desc "Structured time-series logs (PostgreSQL) of crane operations including positions, velocities, forces, and timestamps."
    DTDFVocab:fromData CranePositionData, CraneVelocityData, LoadForceData, TrajectoryExecutionLog
    DTDFVocab:inputTo TrendAnalysisEnabler, AnomalyDetectionEnabler, ComparativeVisualizationEnabler
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Low-latency sensor fusion dataset (50ms delay) for closed-loop control and validation."
    DTDFVocab:fromData CranePositionData, CraneVelocityData, ActuatorCurrentData, LimitSwitchData
    DTDFVocab:inputTo ContinuousValidationServiceEnabler
]

instance SimulatedTrajectoryData : DTDFVocab:Data [
    base:desc "Pre-computed optimal trajectories from kinematic/dynamic models for comparative analysis."
    DTDFVocab:inputTo ComparativeVisualizationEnabler
]

instance FaultSignatureDatabase : DTDFVocab:Data [
    base:desc "Machine learning-trained patterns (Isolation Forests, LSTM autoencoders) for mechanical fault classification."
    DTDFVocab:inputTo AnomalyDetectionEnabler
]

// C11: Enablers
instance KinematicSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for forward/inverse kinematic calculations with 10ms computation time."
    DTDFVocab:enables RealTimeTrajectoryOptimizationService
]

instance DynamicValidationEnabler : DTDFVocab:Enabler [
    base:desc "PyBullet physics engine for dynamic model validation with hardware-in-the-loop testing capability."
    DTDFVocab:enables ContinuousValidationService
]

instance TrajectoryOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "CVXPY optimization library for energy/time-constrained trajectory planning with real-time constraints."
    DTDFVocab:enables RealTimeTrajectoryOptimizationService
]

instance RealTimeControlEnabler : DTDFVocab:Enabler [
    base:desc "ROS-based control node executing PID/MPC algorithms with 20ms control loop."
    DTDFVocab:enables AdaptiveControlService
]

instance DataLoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB with custom retention policies for high-frequency operational data storage."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unity/Blender integration for 3D CAD synchronization with live sensor data streams."
    DTDFVocab:enables RealTimeDashboardService, ComparativeVisualizationService
]

instance ValidationFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Custom Python framework implementing Kalman filtering and residual analysis for model-data consistency."
    DTDFVocab:enables ContinuousValidationService
]

instance AlertingSystemEnabler : DTDFVocab:Enabler [
    base:desc "MQTT-based alerting pipeline with email/API integration for threshold breaches."
    DTDFVocab:enables AutomatedAlertingService
]

instance MachineLearningEnabler : DTDFVocab:Enabler [
    base:desc "Scikit-Learn/PyTorch environment for training anomaly detection models on historical crane data."
    DTDFVocab:enables AnomalyDetectionService
]

instance DarTwinNotationEnabler : DTDFVocab:Enabler [
    base:desc "UML-based formal notation for tracking system evolution and change impact assessment."
    DTDFVocab:enables VersioningSupportService, ImpactAssessmentService
]

instance TrendAnalysisEnabler : DTDFVocab:Enabler [
    base:desc "SQL-based analytical queries for operational trend detection and performance benchmarking."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance AnomalyDetectionEnabler : DTDFVocab:Enabler [
    base:desc "LSTM autoencoder implementation for real-time fault pattern recognition."
    DTDFVocab:enables AnomalyDetectionService
]

instance ComparativeVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB Animation Toolbox for overlaying simulated vs. actual trajectories with 50ms rendering latency."
    DTDFVocab:enables ComparativeVisualizationService
]

instance ControlParameterAdaptationEnabler : DTDFVocab:Enabler [
    base:desc "Python-based adaptive PID gain scheduler using real-time sensor feedback."
    DTDFVocab:enables AdaptiveControlService
]

instance ContinuousValidationServiceEnabler : DTDFVocab:Enabler [
    base:desc "Enables continuous validation services by providing the necessary validation framework."
]

// C6: Services
instance RealTimeTrajectoryOptimizationService : DTDFVocab:Service [
    base:desc "Computes and enforces optimal motion profiles minimizing energy consumption or maximizing throughput using kinematic/dynamic models."
    DTDFVocab:provides OptimalTrajectoryInsight, EnergyOptimizationAction
]

instance AdaptiveControlService : DTDFVocab:Service [
    base:desc "Dynamically adjusts PID gains based on real-time sensor feedback (load variations, actuator delays) to maintain stability."
    DTDFVocab:provides StabilityMaintenanceInsight, ParameterAdaptationAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Stores structured operational data in queryable format (SQL/NoSQL) for post-mortem analysis enabling trend analysis and anomaly detection."
    DTDFVocab:provides OperationalDataInsight, DataRetentionAction
]

instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Displays 3D CAD models synchronized with live sensor data (hoist position, trolley velocity) for operator monitoring."
    DTDFVocab:provides SystemStateInsight, OperatorMonitoringAction
]

instance ComparativeVisualizationService : DTDFVocab:Service [
    base:desc "Overlays simulated vs. actual trajectories to validate digital twin fidelity using MATLAB's Animation Toolbox."
    DTDFVocab:provides ModelValidationInsight, FidelityAssessmentAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares digital twin predictions with real-world sensor data using statistical methods (residual analysis, Kalman filtering)."
    DTDFVocab:provides ModelDataConsistencyInsight, DivergenceDetectionAction
]

instance AutomatedAlertingService : DTDFVocab:Service [
    base:desc "Triggers warnings via email/API calls when validation metrics exceed thresholds (e.g., RMSE  5%)."
    DTDFVocab:provides AlertThresholdInsight, WarningNotificationAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Uses machine learning models (Isolation Forests, LSTM autoencoders) to identify deviations indicative of mechanical faults."
    DTDFVocab:provides FaultPatternInsight, AnomalyAlertAction
]

instance RootCauseAnalysisService : DTDFVocab:Service [
    base:desc "Correlates faults with specific system components via causal graphs or Bayesian networks."
    DTDFVocab:provides ComponentFaultInsight, MaintenanceRecommendationAction
]

instance VersioningSupportService : DTDFVocab:Service [
    base:desc "Tracks changes in physical/digital system using formal notation to ensure traceability of modifications."
    DTDFVocab:provides ChangeTraceabilityInsight, VersionControlAction
]

instance ImpactAssessmentService : DTDFVocab:Service [
    base:desc "Simulates effects of hypothetical changes (e.g., new sensor) on system performance before deployment."
    DTDFVocab:provides ChangeImpactInsight, PerformancePredictionAction
]

// C17: Insights/Actions
