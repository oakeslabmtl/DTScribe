// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder attached to the hoist measuring the swinging motion of the payload."
    DTDFVocab:producedData SwingAngleDataMessage
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed affecting the payload."
    DTDFVocab:producedData WindSpeedDataMessage
]

// C4: Physical-to-virtual interaction – Data transmitted
instance SwingAngleDataMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// C10: Data instances
instance SwingAngleTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series record of swing angle measurements stored in TimescaleDB."
    DTDFVocab:fromData SwingAngleDataMessage
    DTDFVocab:inputTo TimescaleDatabase
]

instance WindSpeedTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series record of wind speed measurements stored in TimescaleDB."
    DTDFVocab:fromData WindSpeedDataMessage
    DTDFVocab:inputTo TimescaleDatabase
]

// C11: Enablers
instance MqttBrokerMosquitto : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker enabling bi‑directional data exchange between the Arduino gateway and twin services."
    DTDFVocab:enables DataLoggingService, OptimalControlService
]

instance TimescaleDatabase : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database that persists sensor measurements and control commands."
    DTDFVocab:enables DataLoggingService, DataVisualizationService, ContinuousValidationService, OptimalControlService
]

instance PythonRuntime : DTDFVocab:Enabler [
    base:desc "Python runtime environment used by algorithmic services and models."
    DTDFVocab:enables GantryCranCADModel, GantryCranKinematicModel, TrajectoryGeneratorModel, DataLoggingService, ContinuousValidationService, OptimalControlService, DataVisualizationService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Collects sensor data from the MQTT broker and writes records into TimescaleDB."
    DTDFVocab:provides StoreSensorMeasurementAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Renders crane state and logged data via Grafana dashboards for operators."
    DTDFVocab:provides SensorDataVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares real‑time sensor data against simulated trajectories from the kinematic model."
    DTDFVocab:provides ValidationInsight, RaiseDeviationAlertAction
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes optimal motion commands using the trajectory generator and sends them to the crane controller."
    DTDFVocab:provides ControlCommandInsight, SendMotionCommandAction
]

// C17: Insights
instance SensorDataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Runtime visualization of swing angle and wind speed measurements."
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Detects deviations between physical behavior and kinematic model predictions."
]

instance ControlCommandInsight : DTDFVocab:Insight [
    base:desc "Provides optimal control commands for carriage and hoist motion."
]

// C17: Actions
instance StoreSensorMeasurementAction : DTDFVocab:Action [
    base:desc "Automatically stores incoming sensor measurements into the time‑series database."
    DTDFVocab:IsAutomatic true
]

instance RaiseDeviationAlertAction : DTDFVocab:Action [
    base:desc "Automatically raises an alert when validation detects a deviation beyond acceptable thresholds."
    DTDFVocab:IsAutomatic true
]

instance SendMotionCommandAction : DTDFVocab:Action [
    base:desc "Sends computed motion commands to the crane controller via MQTT."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Component
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Electric motor driving the crane carriage and hoist under commands from the optimal‑control service."
]

// C10: Models
instance GantryCranCADModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the gantry crane created in Autodesk Fusion 360."
    DTDFVocab:inputTo PythonRuntime
]

instance GantryCranKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model capturing motion equations of the cart and hoist."
    DTDFVocab:inputTo PythonRuntime
]

instance TrajectoryGeneratorModel : DTDFVocab:Model [
    base:desc "Analytical trajectory generator building on the kinematic model to compute optimal paths."
    DTDFVocab:inputTo PythonRuntime
]

// C17: Additional Component (Arduino gateway)
instance ArduinoGateway : DTDFVocab:Component [
    base:desc "Arduino board that samples encoder and anemometer data and forwards messages via MQTT."
]

// C17: Environment
instance LabEnvironment : DTDFVocab:Environment [
    base:contains SwingAngleEncoder,
                 AnemometerSensor,
                 ArduinoGateway,
                 MotorActuator,
                 GantryCranCADModel,
                 GantryCranKinematicModel,
                 TrajectoryGeneratorModel,
                 MqttBrokerMosquitto,
                 TimescaleDatabase,
                 PythonRuntime,
                 DataLoggingService,
                 DataVisualizationService,
                 ContinuousValidationService,
                 OptimalControlService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (a Python application) uses the Physical Crane Interface to issue control commands directly to the crane’s controllers, thereby effecting movement of the physical crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The gantry‑crane twin follows an ad‑hoc orchestration: sensor data from an Arduino board are published via Eclipse Mosquitto (MQTT); the twin service consumes the data, stores time‑stamped measurements in TimescaleDB, runs a physics‑based simulation model, and exposes a REST API for the operator UI. Coordination is achieved through message queues and periodic polling, with lightweight Docker containers running on a local personal computer handling resource allocation and service isolation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The exemplar has been used to demonstrate continuous validation methods and fault‑detection techniques, indicating that model fidelity is monitored at runtime through validation services that compare sensed or logged data against the CAD and kinematic models. Specific validation procedures, uncertainty quantification, or error‑correction mechanisms are not described in the document."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin relies on an MQTT broker that provides publish/subscribe signaling between containers (e.g., Trajectory Generator, Simulation, Continuous Validation). The database (TimescaleDB) and dashboard (Grafana) communicate over standard TCP/IP connections. All components are deployed as containers on the same host, forming a local network topology; no external network or cloud connectivity is described."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The whole system is deployed on‑premise as a set of containers (physical‑crane containers and digital‑twin containers). It includes Python applications, a TimescaleDB instance, a Grafana dashboard, and an MQTT broker, all running on a single host machine (edge or workstation). The architecture uses containerization for isolation and easy installation, but no cloud platform, scalability mechanism, or redundancy strategy is detailed."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration relies on open‑source protocols: MQTT (Eclipse Mosquitto) for real‑time data exchange between the Arduino and the twin, TimescaleDB for persistent time‑series storage, and a RESTful HTTP API for the UI. The twin does not depend on external enterprise platforms; it interacts only with the local PC and the Arduino, using standard data formats such as JSON for interoperability."
]