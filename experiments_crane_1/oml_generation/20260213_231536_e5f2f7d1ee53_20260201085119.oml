instance PhysicalCraneInterface : DTDFVocab:SensingComponent [
    base:desc "Python-based interface collecting data from physical crane controllers"
    DTDFVocab:producedData CraneStateDataTransmitted
]

instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalCraneInterface
]

instance CraneStateData : DTDFVocab:Data [
    base:desc "Crane state data continuously logged to TimescaleDB database"
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo LoggingEnabler
]

instance LoggingEnabler : DTDFVocab:Enabler [
    base:desc "Logging Application for continuous data logging to TimescaleDB"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance C4Model : DTDFVocab:Model [
    base:desc "C4 Model for architectural visualization using context and container diagrams"
    DTDFVocab:inputTo VisualizationEnabler
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "C4 Model-based architectural visualization enabler"
    DTDFVocab:enables RealTimeDataVisualizationService
]

instance GitHubVersionControlEnabler : DTDFVocab:Enabler [
    base:desc "Version control via GitHub repositories for digital twin code management"
    DTDFVocab:enables OptimalControlService, HistoricalDataLoggingService, RealTimeDataVisualizationService, ContinuousValidationService, FaultDetectionService
]

instance ContainerizationEnabler : DTDFVocab:Enabler [
    base:desc "Containerization technologies for code dissemination"
    DTDFVocab:enables OptimalControlService, HistoricalDataLoggingService, RealTimeDataVisualizationService, ContinuousValidationService, FaultDetectionService
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal control for system optimization"
    DTDFVocab:provides SystemOptimizationInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Historical data logging for traceability"
    DTDFVocab:provides TraceabilityInsight
]

instance RealTimeDataVisualizationService : DTDFVocab:Service [
    base:desc "Real-time data visualization for monitoring"
    DTDFVocab:provides RuntimeVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation to ensure model accuracy against physical system behavior"
    DTDFVocab:provides SimulationInsight, PredictionInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection for identifying anomalies"
    DTDFVocab:provides FaultDetectionInsight
]

instance SystemOptimizationInsight : DTDFVocab:Insight [
    base:desc "System optimization insights from optimal control"
]

instance TraceabilityInsight : DTDFVocab:Insight [
    base:desc "Traceability through historical data logging"
]

instance RuntimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Runtime visualization for indoor air quality management in virus spread prevention scenarios"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation capabilities for indoor air quality management in virus spread prevention scenarios"
]

instance PredictionInsight : DTDFVocab:Insight [
    base:desc "Prediction capabilities for indoor air quality management in virus spread prevention scenarios"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection insights from fault detection services"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the Control Application (Python) and transmitted to the Physical Crane through the Physical Crane Interface."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Services communicate via an MQTT broker for signaling."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar employs the AutomationML standard [14] for digital twin modeling, with Microsoft Azure tools used for pipeline implementation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Continuous Validation Service continuously compares measurements of executed trajectories with simulations of those same trajectories, calculates distance metrics against an acceptable threshold, and notifies operators via the Grafana dashboard upon threshold breaches to ensure safe operation."
]