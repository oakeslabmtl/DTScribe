// Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring the relative angle between the cart and gantry, sampling at 10 Hz"
    DTDFVocab:producedData SwingAngleMQTT
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer recording ambient airflow, streamed via MQTT at ~10 Hz"
    DTDFVocab:producedData AirflowMQTT
]

// Data Transmitted over MQTT
instance SwingAngleMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AirflowMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// Recorded Data Stored in TimescaleDB
instance SwingAngleRecord : DTDFVocab:Data [
    base:desc "Time‑series record of swing‑angle measurements"
    DTDFVocab:fromData SwingAngleMQTT
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance AirflowRecord : DTDFVocab:Data [
    base:desc "Time‑series record of ambient airflow measurements"
    DTDFVocab:fromData AirflowMQTT
    DTDFVocab:inputTo TimescaleDBEnabler
]

// Acting Components
instance HorizontalStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Horizontal stepper motor assembly driving the cart rail, controlled via GPIO on Raspberry Pi"
]

instance VerticalStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Vertical stepper motor assembly driving the hoist, controlled via GPIO on Raspberry Pi"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the gripper, switched on via relay to pick up small puck payloads"
]

// Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating sensor telemetry and actuator commands"
    DTDFVocab:enables RealTimeMonitoringService, OptimalControlService, HistoricalLoggingService, ContinuousValidationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance storing logged sensor data and simulation outputs"
    DTDFVocab:enables HistoricalLoggingService, ContinuousValidationService
]

instance SimulationDockerEnabler : DTDFVocab:Enabler [
    base:desc "Docker container running the discrete‑time kinematic simulation of the gantry crane"
    DTDFVocab:enables SimulationExecutionService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard rendering 3‑D visualizations and real‑time metrics"
    DTDFVocab:enables ThreeDVisualizationService
]

// Models
instance KinematicModel4DOF : DTDFVocab:Model [
    base:desc "Fourth‑degree‑of‑freedom planar kinematic model derived from CAD geometry"
    DTDFVocab:inputTo SimulationDockerEnabler
]

instance KinematicParametersRecord : DTDFVocab:Data [
    base:desc "CAD‑derived kinematic parameters used by the kinematic model"
    DTDFVocab:inputTo SimulationDockerEnabler
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of actuator positions, velocities, and payload state"
    DTDFVocab:provides CurrentActuatorPositionInsight, CurrentVelocityInsight, PayloadStatusInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal trajectory generation service for precise positioning of the gantry crane"
    DTDFVocab:provides GenerateOptimalTrajectoryAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Historical logging of all positional and velocity data for post‑hoc analysis"
    DTDFVocab:provides HistoricalPositionTrendInsight, HistoricalVelocityTrendInsight
]

instance ThreeDVisualizationService : DTDFVocab:Service [
    base:desc "3‑D rendering of the digital model synchronized with live sensor data"
    DTDFVocab:provides Render3DVisualizationAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation comparing simulated states with live measurements to detect drift or faults"
    DTDFVocab:provides DriftDetectionInsight, FaultAlarmInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Executes the discrete‑time kinematic equations within a Docker container to generate runtime behavior"
    DTDFVocab:provides SimulatedStateInsight
]

// Insights
instance CurrentActuatorPositionInsight : DTDFVocab:Insight [
    base:desc "Current positions of the horizontal and vertical stepper motors"
]

instance CurrentVelocityInsight : DTDFVocab:Insight [
    base:desc "Current velocities of the horizontal and vertical motors"
]

instance PayloadStatusInsight : DTDFVocab:Insight [
    base:desc "Status of the payload holder and magnet engagement"
]

instance HistoricalPositionTrendInsight : DTDFVocab:Insight [
    base:desc "Historical trends of the gantry’s horizontal and vertical positions"
]

instance HistoricalVelocityTrendInsight : DTDFVocab:Insight [
    base:desc "Historical trends of the gantry’s velocities"
]

instance DriftDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of drift between simulated and real states"
]

instance FaultAlarmInsight : DTDFVocab:Insight [
    base:desc "Alarm indicating potential faults in sensors, actuators, or simulation"
]

instance SimulatedStateInsight : DTDFVocab:Insight [
    base:desc "Simulated kinematic states (position and velocity) produced by the kinematic model"
]

// Actions
instance GenerateOptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Generate optimal trajectories for efficient gantry motion"
    DTDFVocab:IsAutomatic true
]

instance Render3DVisualizationAction : DTDFVocab:Action [
    base:desc "Render 3‑D visualization of the gantry in real time"
    DTDFVocab:IsAutomatic true
]

// Physical components of the gantry crane
instance GantryFrame : DTDFVocab:Component [
    base:desc "Main frame supporting the gantry structure"
]

instance Boom : DTDFVocab:Component [
    base:desc "Boom extending from the gantry frame to support the trolley"
]

instance TrolleyCarriage : DTDFVocab:Component [
    base:desc "Carriage that travels along the horizontal rail"
]

instance PayloadHolder : DTDFVocab:Component [
    base:desc "Holder mounting the payload and gripper"
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Embedded Raspberry Pi orchestrating actuators and sensor data flow"
]

// Environmental context
instance LabEnvironment : DTDFVocab:Environment [
    base:contains GantryFrame, Boom, TrolleyCarriage, PayloadHolder, RaspberryPiController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, itself a Python program, uses the same crane interface to transmit control commands to the physical crane. Command validation, authentication, or conflict resolution procedures are not described in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin’s architecture is provisioned with Docker Compose as a six‑container constellation: (1) InfluxDB for long‑term telemetry storage, (2) Mosquitto MQTT broker for intra‑service signalling, (3) Web‑based Dashboard serving the HMI, (4) Trajectory Generator Service exposing a REST API to compute optimal path plans, (5) Command Service publishing movement commands to the crane via MQTT topics, and (6) Logging Application that aggregates sensor streams. This modular container pattern enables loose coupling between services; components communicate through publish/subscribe topics over a shared Docker network, while database access is volume‑mounted for persistence. Resource limits (CPU and memory) are specified per container to ensure bounded utilisation on a single host, and Docker Compose orchestrates startup, health checks, and inter‑container networking, providing a cohesive, container‑centric coordination mechanism for the digital twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A continuous validation service compares the real sensor states with the predictions of the kinematic model. When discrepancies exceed a predefined tolerance, the service logs the mismatch and emits an alert on the operator dashboard. This comparison is performed during runtime, providing real‑time model‑verification without explicit algorithmic thresholds beyond the absolute tolerance used for alerting."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin is built on an MQTT broker for intra‑service signaling. No further details on network topology, bandwidth, latency, or redundancy are provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components – Python control and logging applications, TimescaleDB database, Grafana dashboard, and MQTT broker – are implemented as software modules and appear to run on local, on‑premises hardware. Specific deployment platforms, scalability mechanisms or reliability guarantees are not detailed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation uses an open‑source stack: Python for the core logic, Docker for containerisation, TimescaleDB for time‑series storage, and Grafana for visualization. The project is released under the MIT license. No industry‑specific standards or certification requirements are adopted; interoperability relies on standard open protocols implemented within the Dockerised services."
]