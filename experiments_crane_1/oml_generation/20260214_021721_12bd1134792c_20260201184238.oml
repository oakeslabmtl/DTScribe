// C2: Physical Acting Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing Angle Encoder measuring the angular position/swing motion of the hoist."
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed for environmental data collection."
]

instance CartMotorController : DTDFVocab:ActuatingComponent [
    base:desc "Cart Motor Controller (TMC4671-Eval) controlling the horizontal cart movement via a stepper motor."
    DTDFVocab:producedData SwingAngleData
]

instance HoistMotorController : DTDFVocab:ActuatingComponent [
    base:desc "Hoist Motor Controller (TMC4671-Eval) controlling vertical hoisting via another stepper motor."
    DTDFVocab:producedData CraneStateData
]

// C3: Data Transmitted from Sensing Components
instance SwingAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CraneStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorController
]

// C4: Data Storage and Processing
instance EncoderReadingsData : DTDFVocab:Data [
    base:desc "Real-time angular position readings from the swing angle encoder."
    DTDFVocab:fromData SwingAngleData
    DTDFVocab:inputTo TimescaleDB
]

instance WindData : DTDFVocab:Data [
    base:desc "Environmental wind speed measurements collected by the anemometer."
    DTDFVocab:fromData WindSpeedData
    DTDFVocab:inputTo TimescaleDB
]

instance CraneStateDataLog : DTDFVocab:Data [
    base:desc "Continuous logging of crane state (position, velocity, acceleration, sensor readings)."
    DTDFVocab:fromData CraneStateData
    DTDFVocab:inputTo TimescaleDB
]

instance SimulationData : DTDFVocab:Data [
    base:desc "Emulated crane behavior data generated by the Simulation Service for validation."
    DTDFVocab:inputTo TimescaleDB
]

// C5: CAD and Kinematic Models
instance CraneCADModel : DTDFVocab:Model [
    base:desc "Autodesk Fusion 360 models of the crane frame, motors, and components."
    DTDFVocab:inputTo PythonGantryLib
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Mathematical representations of crane motion (e.g., inverse kinematics for trajectory generation)."
    DTDFVocab:inputTo PythonGantryLib
]

instance InverseKinematicsModel : DTDFVocab:Model [
    base:desc "Specific inverse kinematics implementation for trajectory generation with minimal residual swinging."
    DTDFVocab:inputTo PythonGantryLib
]

// C6: Enablers
instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "PostgreSQL-based time-series database for storing continuous crane state and simulation data."
    DTDFVocab:enables DataLoggingService, ContinuousValidationService
]

instance PythonGantryLib : DTDFVocab:Enabler [
    base:desc "Core Python services implementing gantry crane control logic (gantrylib module)."
    DTDFVocab:enables TrajectoryOptimizationService, SimulationService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Visualization platform displaying real-time and historical data traces for operator decisions."
    DTDFVocab:enables DataVisualizationService
]

instance EclipseMosquitto : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating asynchronous event signaling between services."
    DTDFVocab:enables TrajectoryCommandService, DataLoggingService
]

// C7: Centralized and Decentralized Services
instance CentralizedDigitalTwin : DTDFVocab:DigitalTwin [
    base:desc "Unified digital model encompassing all physical components (CAD models, kinematic models, sensor data) and services."
    base:contains CraneFrameComponent, DualMotorsComponent, ElectromagnetComponent,
        SwingAngleEncoder, Anemometer, ArduinoInterface, PowerSupplyUnit
]

instance CentralizedService : DTDFVocab:Service [
    base:desc "Unified service managing all digital twin components and orchestrating decentralized services."
    DTDFVocab:provides TrajectoryOptimizationInsight, FaultDetectionInsight,
        OperationalMonitoringInsight, ValidationConfidenceMetric
]

instance DecentralizedServiceContainer1 : DTDFVocab:Service [
    base:desc "Database container managing all time-series data storage."
    DTDFVocab:provides DataStorageService
]

instance DecentralizedServiceContainer2 : DTDFVocab:Service [
    base:desc "Dashboard container providing real-time visualization interfaces."
    DTDFVocab:provides DataVisualizationService
]

instance DecentralizedServiceContainer3 : DTDFVocab:Service [
    base:desc "Trajectory generation container implementing optimal path algorithms."
    DTDFVocab:provides TrajectoryOptimizationService
]

instance DecentralizedServiceContainer4 : DTDFVocab:Service [
    base:desc "Simulation container emulating crane behavior and controllers."
    DTDFVocab:provides SimulationService
]

instance DecentralizedServiceContainer5 : DTDFVocab:Service [
    base:desc "Validation container comparing real vs. simulated data metrics."
    DTDFVocab:provides ContinuousValidationService
]

instance DecentralizedServiceContainer6 : DTDFVocab:Service [
    base:desc "Logging container handling continuous crane state data collection."
    DTDFVocab:provides DataLoggingService
]

// C8: Specific Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuous recording of crane state (position, velocity, sensor data) into TimescaleDB."
    DTDFVocab:provides CraneStateDataLog
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Grafana Dashboard displaying real-time and historical data traces (e.g., trajectory execution vs. simulation bounds)."
    DTDFVocab:provides OperationalMonitoringInsight
]

instance TrajectoryOptimizationService : DTDFVocab:Service [
    base:desc "Kinematic model-based service generating trajectories with minimal residual swinging motion."
    DTDFVocab:provides OptimalTrajectoryGeneration
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Emulates crane behavior and controllers to validate trajectories against real-world measurements."
    DTDFVocab:provides SimulationResults
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares real-time measurements with simulations, calculating distance metrics and triggering alerts."
    DTDFVocab:provides ValidationConfidenceMetric
]

// C9: Insights and Actions
instance OptimalTrajectoryGeneration : DTDFVocab:Insight [
    base:desc "Optimal paths (e.g., zero-swing trajectories) reducing operational inefficiencies."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Time-series classification identifying anomalies (e.g., motor faults) before physical damage occurs."
]

instance OperationalMonitoringInsight : DTDFVocab:Insight [
    base:desc "Grafana dashboard visualizing real-time/historical data for operator decisions (e.g., trajectory adjustments)."
]

instance ValidationConfidenceMetric : DTDFVocab:Insight [
    base:desc "Distance metrics between real and simulated data informing trustworthiness of predictions."
]

instance TrajectoryCommandAction : DTDFVocab:Action [
    base:desc "Automated generation and execution of optimal trajectories based on real-time conditions."
    DTDFVocab:IsAutomatic true
]

instance FaultAlertAction : DTDFVocab:Action [
    base:desc "Automatic triggering of maintenance procedures when fault detection exceeds thresholds."
    DTDFVocab:IsAutomatic true
]

// C10: Physical Crane System Components
instance GantryCraneSystem : DTDFVocab:Environment [
    base:contains CraneFrameComponent, DualMotorsComponent, ElectromagnetComponent,
        SwingAngleEncoder, Anemometer, ArduinoInterface, PowerSupplyUnit
]

instance CraneFrameComponent : DTDFVocab:Component [
    base:desc "Physical frame structure of the lab-scale gantry crane system."
]

instance DualMotorsComponent : DTDFVocab:Component [
    base:desc "System of dual stepper motors (cart and hoist) controlling horizontal and vertical movement."
]

instance ElectromagnetComponent : DTDFVocab:Component [
    base:desc "Electromagnet for container pickup in the crane system."
]

instance ArduinoInterface : DTDFVocab:Component [
    base:desc "Arduino-based interface connecting sensors and controllers to the digital twin."
]

instance PowerSupplyUnit : DTDFVocab:Component [
    base:desc "Power supply unit providing electrical power to the crane system."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin interacts with the physical system through:
  - **Control Application (Python)** sending trajectory commands and control signals to the crane’s motor controllers (TMC4671-Eval) via the Physical Crane Interface.
  - **Human Machine Interface (HMI)** allowing operators to input commands, configure parameters, and monitor real-time status.
  - **Trajectory Generator Service** providing optimized movement paths (e.g., zero-swing trajectories) to the control application."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twinning operates on a **real-time to near-real-time** scale:
  - **Data Logging**: Continuous, near-instantaneous updates to **TimescaleDB** (low-latency time-series storage).
  - **Trajectory Generation/Simulation**: Computed offline or in real-time (depending on service requirements), but synchronized with physical execution.
  - **Continuous Validation**: Operates at the same frequency as physical crane operations (e.g., per trajectory execution or per sensor update cycle).
  No explicit time-scale granularity (e.g., milliseconds) is specified, but the system is designed for **low-latency synchronization** (sub-second response expected)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation is structured as:
  - **Core Components**:
    - **Physical Crane** (hardware) + **Physical Crane Interface** (Python) as the primary interaction bridge.
    - **Human Machine Interface** (Python HMI) for operator interaction.
  - **Digital Twin Services** (six containers):
    1. **Database (TimescaleDB)** – Stores all logged data.
    2. **Dashboard (Grafana)** – Visualizes data and validation results.
    3. **Trajectory Generator Service** – Generates optimal trajectories using kinematic models.
    4. **Simulation Service** – Emulates crane behavior for validation.
    5. **Continuous Validation Service** – Compares real vs. simulated data and triggers alerts.
    6. **MQTT Broker (Eclipse Mosquitto)** – Orchestrates inter-service communication.
  - **Orchestration**: Services communicate via MQTT messages, with the **Logging Application** acting as a central data collector."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin operates across the following lifecycle stages of the physical system:
  - **As Designed**: Kinematic models and CAD models represent idealized crane behavior (e.g., perfect motor control, no friction).
  - **As Manufactured**: Physical components (motors, controllers, sensors) are modeled with empirical parameters (e.g., encoder calibration, motor torque curves).
  - **As Operated**: Real-time data logging and continuous validation ensure alignment between physical and digital states during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are addressed through:
  - **Model Validation**:
    - **Continuous Validation Service** compares real crane trajectories with simulated ones using Euclidean distance metrics.
    - **Threshold-Based Alerts**: Operators receive notifications if validation metrics exceed predefined thresholds.
  - **Uncertainty Handling**:
    - **Sensor Calibration**: Empirical tuning of encoders, motors, and controllers (e.g., motor torque curves).
    - **Simulation Accuracy**: Kinematic models are validated against real-world data during operation.
  - **Verification/Validation Methods**:
    - **Kinematic Model Validation**: Trajectory generation aligns with physical constraints (e.g., zero-swing trajectories).
    - **Fault Detection**: Time-series classification techniques (e.g., WSC 2024 paper) identify deviations from normal operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Technical connections between the physical twin (PT) and digital twin (DT) are established via:
  - **Network Protocols**:
    - **MQTT** for asynchronous event signaling between services (e.g., sensor data, commands).
    - **HTTP/REST** implicitly via Python APIs (e.g., HMI, Logging Application).
  - **Communication Architecture**:
    - **Centralized Data Flow**: Physical sensors → Arduino → Python Logging Application → TimescaleDB → Services.
    - **Decentralized Service Orchestration**: Services communicate via MQTT broker, with no single point of failure.
  - **Latency**: Sub-second synchronization expected for real-time control."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is hosted/deployed as:
  - **Single-Point Deployment**: All components (services, database, MQTT broker) run on a **personal computer** (PC) via Docker containers.
  - **Docker Compose**: Automated setup/teardown of containers (database, dashboard, MQTT broker) via a single command.
  - **First-Time Setup**: Automated initialization of TimescaleDB and Grafana during docker-compose execution.
  - **Open-Source Tools**: No proprietary software; relies on open-source frameworks (TimescaleDB, Mosquitto, Grafana, Python)."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration with external systems is **not explicitly detailed** in the documents. The exemplar focuses on isolated crane operations, but potential future extensions could include:
  - **Container Identification System** (expanded harbor use case).
  - **Ship Digital Twin** (buoyancy modeling for container loading).
  - **Industrial IoT Integration** (e.g., cloud-based monitoring via Azure or IoT protocols)."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership and privacy are addressed as:
  - **Data Ownership**: The **physical crane owner** owns the logged data (TimescaleDB), as the exemplar is published under an MIT license (open-source).
  - **Privacy Considerations**: No explicit mention of data anonymization or access controls. Data is stored locally (PC) unless deployed in a cloud environment (not specified)."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Standardization efforts include:
  - **Open-Source Frameworks**: Uses open-source tools (TimescaleDB, Mosquitto, Grafana) without proprietary dependencies.
  - **Modeling Standards**:
    - **CAD Models**: Autodesk Fusion 360 (industry-standard).
    - **System Modeling**: Capella for Arcadia-based system engineering (emerging standard for digital twins).
  - **Protocol Standards**:
    - **MQTT** for inter-service communication (industry-standard IoT protocol).
    - **SQL/PostgreSQL** for data storage (widely adopted).
  - **Ad-Hoc Approach**: No commercial digital twin frameworks (e.g., Eclipse Ditto/BaSyx) are used, relying on general-purpose tools."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety are addressed through:
  - **Remote Operation**: The HMI allows operators to control the crane remotely, but **no explicit safety protocols** (e.g., fail-safes, emergency stop mechanisms) are detailed in the documents.
  - **Data Integrity**: TimescaleDB ensures reliable time-series data storage, but **no encryption** of sensor data is mentioned.
  - **Physical Safety**: The crane is designed for lab-scale use; no mention of industrial-grade safety certifications (e.g., ISO 13849).
  - **Future Work**: Potential improvements include custom driver boards (reducing cost) and virtual commissioning (simulated operation without physical risk)."
]