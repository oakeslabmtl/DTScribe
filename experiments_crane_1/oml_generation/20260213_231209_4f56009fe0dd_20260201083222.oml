// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorControllerFeedback : DTDFVocab:SensingComponent [
    base:desc "Motor controller feedback providing position and speed via Arduino"
    DTDFVocab:producedData MotorFeedbackDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorFeedbackDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerFeedback
]

// C10: Data instances
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series swing angle measurements"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series wind speed measurements"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, TimescaleDBEnabler
]

instance MotorFeedbackData : DTDFVocab:Data [
    base:desc "Position and speed feedback from hoist and cart motors"
    DTDFVocab:fromData MotorFeedbackDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, TimescaleDBEnabler
]

instance ValidationMetricsData : DTDFVocab:Data [
    base:desc "Validation metrics comparing measured vs simulated trajectories"
    DTDFVocab:fromData MotorFeedbackDataTransmitted
    DTDFVocab:inputTo ValidationEngineEnabler
]

// C11: Enablers (tooling & infrastructure)
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker facilitating publish/subscribe between containers"
    DTDFVocab:enables DataLoggingService, RealTimeVisualizationService, TrajectoryGenerationService, PhysicsSimulationService, ContinuousValidationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB PostgreSQL extension storing historic sensor data and validation metrics"
    DTDFVocab:enables HistoricalStorageService, ContinuousValidationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for real‑time visualisation of sensor streams and validation alerts"
    DTDFVocab:enables RealTimeVisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python trajectory generator using kinematic CAD models to compute optimal crane paths"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Physics simulation engine executing dynamic crane model for what‑if analysis"
    DTDFVocab:enables PhysicsSimulationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation service comparing measured trajectories with simulated ones"
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services (dt_services)
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logging application subscribes to MQTT topics and records data into TimescaleDB"
    DTDFVocab:provides LoggingInsight
]

instance HistoricalStorageService : DTDFVocab:Service [
    base:desc "Provides historic query capability over stored time‑series data"
    DTDFVocab:provides HistoricalDataInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Grafana visualises live sensor streams, trajectory overlays and validation alerts"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal crane trajectories with confidence intervals based on kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight, SelectTrajectoryAction
]

instance PhysicsSimulationService : DTDFVocab:Service [
    base:desc "Runs full‑physics simulation of crane dynamics and controller behaviour"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates measured motion against simulation, raising alerts on threshold breaches"
    DTDFVocab:provides ValidationAlertInsight, RaiseAlertAction
]

// C17: Insights and Actions (insights_and_decision_making)
instance LoggingInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data has been successfully logged"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Access to historic sensor data for trend analysis"
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Operators see live crane status, swing angle, wind speed and alerts on dashboard"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Display of optimal trajectory and confidence interval for next container move"
]

instance SelectTrajectoryAction : DTDFVocab:Action [
    base:desc "Operator selects a new trajectory to be sent to the control application"
    DTDFVocab:IsAutomatic false
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation provides predicted motion and forces for validation"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert when measured trajectory deviates beyond validation thresholds"
]

instance RaiseAlertAction : DTDFVocab:Action [
    base:desc "System raises an operator alert and logs the validation failure"
    DTDFVocab:IsAutomatic true
]

// C10: Models (dt_models_and_data)
instance CADModelFusion360 : DTDFVocab:Model [
    base:desc "CAD geometry of the lab‑scale gantry crane created in Autodesk Fusion 360"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model derived from CAD used for trajectory generation"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic physics model of crane and controllers used by simulation engine"
    DTDFVocab:inputTo SimulationEngineEnabler
]

// C2: Acting components (physical_acting_components)
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor driven by TMC4671‑Eval controller"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor driven by TMC4671‑Eval controller"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at hoist tip used to pick up containers"
]

// C17: Environment (system_under_study)
instance LabScaleGantryCraneEnv : DTDFVocab:Environment [
    base:contains CartStepperMotor, HoistStepperMotor, ElectromagnetActuator, SwingAngleEncoder, AnemometerSensor, MotorControllerFeedback
]

// C5: Software container components (multiplicities)
instance PhysicalCraneInterfaceContainer : DTDFVocab:Component [
    base:desc "Python interface reading Arduino sensors and publishing via MQTT"
]

instance ControlApplicationContainer : DTDFVocab:Component [
    base:desc "Control logic consuming trajectories and commanding motors"
]

instance LoggingApplicationContainer : DTDFVocab:Component [
    base:desc "Application subscribing to MQTT and storing data in TimescaleDB"
]

instance HumanMachineInterfaceContainer : DTDFVocab:Component [
    base:desc "Operator UI built with Grafana for monitoring and interaction"
]

instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Eclipse Mosquitto broker facilitating communication among services"
]

instance TimescaleDBContainer : DTDFVocab:Component [
    base:desc "TimescaleDB instance persisting time‑series data"
]

instance GrafanaDashboardContainer : DTDFVocab:Component [
    base:desc "Grafana dashboard visualising live data and insights"
]

instance TrajectoryGeneratorServiceContainer : DTDFVocab:Component [
    base:desc "Service generating optimal trajectories"
]

instance SimulationServiceContainer : DTDFVocab:Component [
    base:desc "Service running physics simulation of crane"
]

instance ContinuousValidationServiceContainer : DTDFVocab:Component [
    base:desc "Service continuously validating sensor data against simulation"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application receives desired motion commands from the Trajectory Generator Service (optimal trajectories) via the MQTT broker and forwards them through the Physical Crane Interface to the motor controllers and electromagnet to actuate the crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A hybrid cyber‑physical architecture where the physical crane is connected to a personal computer via a Python interface; services run as Docker containers on the same machine; MQTT broker mediates messaging among services; data persists in TimescaleDB; operators interact via a web‑based HMI and Grafana dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin includes design artefacts (CAD models of the crane), manufacturing/assembly representation (physical hardware), and operational models (kinematic model, simulation, real‑time data) used during runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously computes distance metrics between measured trajectories and simulated trajectories, compares them against a predefined threshold, and triggers operator alerts when breached; simulation provides confidence bounds (upper/lower) displayed on the dashboard."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Message exchange between PT and DT components uses MQTT (Eclipse Mosquitto) over TCP/IP; sensor data and control commands are serialized in MQTT topics; low‑level controller communication is via serial/USB to Arduino."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital‑twin containers (TimescaleDB, MQTT broker, Grafana, trajectory generator, simulator, validation) are Dockerised and deployed on a single personal computer using a Docker‑Compose file that automatically initialises the database and dashboard."
]