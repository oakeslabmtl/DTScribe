]

instance CraneControlOptimizationModel : DTDFVocab:Model [
    base:desc "Model-Predictive Control (MPC) model for energy-efficient trajectory planning and payload stabilization, validated against physical measurements."
    DTDFVocab:inputTo ControlOptimizationEnabler
]

