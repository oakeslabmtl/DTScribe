// ======================================================
// C3: Physical sensing components
// ======================================================

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder mounted on the hoist, provides angular position of the load."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer attached to the crane frame, measures ambient wind speed."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoSensorBoard : DTDFVocab:SensingComponent [
    base:desc "Arduino board that reads the swing‑angle encoder and anemometer and forwards their values."
    DTDFVocab:producedData ArduinoSensorDataTransmitted
]

// ======================================================
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// ======================================================

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance ArduinoSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoSensorBoard
]

// ======================================================
// C10: Data (time‑series sensor logs)
// ======================================================

instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle values stored in TimescaleDB."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo DockerTimescaleDB
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements stored in TimescaleDB."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo DockerTimescaleDB
]

instance ArduinoSensorLog : DTDFVocab:Data [
    base:desc "Aggregated sensor log (encoder + wind) persisted in TimescaleDB."
    DTDFVocab:fromData ArduinoSensorDataTransmitted
    DTDFVocab:inputTo DockerTimescaleDB
]

// ======================================================
// C2: Acting components
// ======================================================

instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor that drives the crane trolley (cart) via a Trinamic TMC4671‑Eval controller."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor that raises/lowers the load (hoist) via a Trinamic TMC4671‑Eval controller."
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist for gripping the load."
]

// ======================================================
// C6: Services
// ======================================================

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Collects sensor time‑series and stores them in TimescaleDB."
    DTDFVocab:provides DataLoggingInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Streams live sensor data to a Grafana dashboard."
    DTDFVocab:provides RealTimeDashboardInsight, OperatorAlertInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal motion trajectories for the crane using the kinematic model."
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance PhysicsSimulationService : DTDFVocab:Service [
    base:desc "Runs a physics‑based simulation of the crane and controllers."
    DTDFVocab:provides SimulatedTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares measured trajectories with simulated ones and raises alerts."
    DTDFVocab:provides ValidationAlertInsight
    DTDFVocab:provides AdjustCraneCommandAction, InvestigateFaultAction
]

instance OperatorNotificationService : DTDFVocab:Service [
    base:desc "Delivers notifications and alerts to operators via the Grafana dashboard."
    DTDFVocab:provides OperatorAlertInsight
]

// ======================================================
// C11: Enablers
// ======================================================

instance DockerTimescaleDB : DTDFVocab:Enabler [
    base:desc "Docker container running TimescaleDB, the time‑series database."
    DTDFVocab:enables DataLoggingService
]

instance DockerGrafana : DTDFVocab:Enabler [
    base:desc "Docker container running Grafana for real‑time visualization and operator alerts."
    DTDFVocab:enables RealTimeVisualizationService, OperatorNotificationService
]

instance DockerMosquitto : DTDFVocab:Enabler [
    base:desc "Docker container running Eclipse Mosquitto MQTT broker for sensor‑to‑twin messaging."
    DTDFVocab:enables DataLoggingService, RealTimeVisualizationService
]

instance PythonTrajectoryGenerator : DTDFVocab:Enabler [
    base:desc "Python process (gantrylib module) that implements trajectory generation."
    DTDFVocab:enables TrajectoryGenerationService
]

instance PythonSimulationEngine : DTDFVocab:Enabler [
    base:desc "Python process (gantrylib module) that runs the physics‑based crane simulation."
    DTDFVocab:enables PhysicsSimulationService
]

instance PythonContinuousValidator : DTDFVocab:Enabler [
    base:desc "Python process (gantrylib module) that performs continuous validation of measured vs. simulated data."
    DTDFVocab:enables ContinuousValidationService
]

// ======================================================
// C17: Insights & Actions
// ======================================================

instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data has been successfully persisted in TimescaleDB."
]

instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Live visualization of swing angle, wind speed, and motor states on Grafana."
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal motion trajectory computed for the current pick‑and‑place task."
]

instance SimulatedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Simulated trajectory and controller responses for the planned motion."
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating deviation between measured behavior and simulation predictions."
]

instance OperatorAlertInsight : DTDFVocab:Insight [
    base:desc "Operator notification displayed on the dashboard for faults or validation alerts."
]

instance AdjustCraneCommandAction : DTDFVocab:Action [
    base:desc "Operator adjusts crane command setpoints based on twin insights."
    DTDFVocab:IsAutomatic false
]

instance InvestigateFaultAction : DTDFVocab:Action [
    base:desc "Operator initiates fault investigation after a validation alert."
    DTDFVocab:IsAutomatic false
]

// ======================================================
// C10: Models
// ======================================================

instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane (Autodesk Fusion 360)."
    DTDFVocab:inputTo DockerGrafana, PythonSimulationEngine
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used for trajectory generation."
    DTDFVocab:inputTo PythonTrajectoryGenerator
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model of the crane and its controllers."
    DTDFVocab:inputTo PythonSimulationEngine
]

// ======================================================
// Environment and Physical Components
// ======================================================

instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains SwingAngleEncoder, Anemometer, ArduinoSensorBoard,
                CartStepperMotor, HoistStepperMotor, Electromagnet,
                TrinamicCartController, TrinamicHoistController,
                PowerSupplyUnit
]

instance TrinamicCartController : DTDFVocab:Component [
    base:desc "Trinamic TMC4671‑Eval controller driving the cart stepper motor."
]

instance TrinamicHoistController : DTDFVocab:Component [
    base:desc "Trinamic TMC4671‑Eval controller driving the hoist stepper motor."
]

instance PowerSupplyUnit : DTDFVocab:Component [
    base:desc "Power supply providing regulated voltage to all crane electronics."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital‑twin services (e.g., Trajectory Generator Service and Simulation Service) send motion commands through the MQTT broker to the Control Application, which uses the Physical Crane Interface to command the motor controllers and electromagnet on the physical crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "All components run on a single personal computer; Docker containers host the database, MQTT broker, and dashboard, while Python modules provide the Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface, and the various twin services, all communicating via MQTT and SQL queries."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the design stage (CAD models in Autodesk Fusion‑360 and kinematic model) and the operated stage (runtime sensor data, trajectory execution, validation) of the crane."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares executed trajectories with simulation outputs, computes distance metrics, and checks them against a predefined threshold; breaches trigger operator alerts, providing on‑line fidelity assessment of the twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses MQTT (Eclipse Mosquitto) for command and telemetry messages, and SQL over TCP/IP for database access; all services reside on the same Docker network on the host PC."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is hosted on a personal computer; Docker containers run the TimescaleDB, MQTT broker, and Grafana dashboard, while the gantrylib Python package is installed via pip and started with Docker‑Compose, enabling one‑command deployment."
]