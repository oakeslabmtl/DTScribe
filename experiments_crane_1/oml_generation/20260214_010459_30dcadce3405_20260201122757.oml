// Sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder attached to the hoist measuring lateral oscillation at fixed sampling rate."
    DTDFVocab:producedData SwingAngleDataStream
]
instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Wind speed anemometers capturing airflow around the gantry."
    DTDFVocab:producedData WindSpeedDataStream
]
instance LoadMassSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded load mass sensor measuring the weight of the cargo."
    DTDFVocab:producedData LoadMassDataStream
]
instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded position sensor capturing trolley or load location along the horizontal rail."
    DTDFVocab:producedData PositionDataStream
]
instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded torque sensor providing motor torque feedback."
    DTDFVocab:producedData TorqueDataStream
]

// Data transmitted via the physical‑to‑virtual interface
instance SwingAngleDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance WindSpeedDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]
instance LoadMassDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadMassSensor
]
instance PositionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]
instance TorqueDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
]

// Time‑stamped measurement data stored in TimescaleDB
instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurement recorded in TimescaleDB."
    DTDFVocab:fromData SwingAngleDataStream
    DTDFVocab:inputTo LoggingEnabler, ContinuousValidationEnabler
]
instance WindSpeedMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped wind speed measurement recorded in TimescaleDB."
    DTDFVocab:fromData WindSpeedDataStream
    DTDFVocab:inputTo LoggingEnabler, ContinuousValidationEnabler
]
instance LoadMassMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped load mass measurement recorded in TimescaleDB."
    DTDFVocab:fromData LoadMassDataStream
    DTDFVocab:inputTo LoggingEnabler, ContinuousValidationEnabler
]
instance PositionMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped position measurement recorded in TimescaleDB."
    DTDFVocab:fromData PositionDataStream
    DTDFVocab:inputTo LoggingEnabler, ContinuousValidationEnabler
]
instance TorqueMeasurement : DTDFVocab:Data [
    base:desc "Time‑stamped torque measurement recorded in TimescaleDB."
    DTDFVocab:fromData TorqueDataStream
    DTDFVocab:inputTo LoggingEnabler, ContinuousValidationEnabler
]

// Enablers connecting data to services
instance LoggingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler responsible for persisting measurement data to TimescaleDB via the Logging Application."
    DTDFVocab:enables LoggingService
]
instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that forwards measurement data to the Continuous Validation Service for real‑time comparison with simulation predictions."
    DTDFVocab:enables ContinuousValidationService
]
instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Enabler providing the kinematic model to the Trajectory Generator Service to compute motion plans."
    DTDFVocab:enables TrajectoryGeneratorService
]
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that supplies the kinematic model to the Simulation Service for predictive simulation."
    DTDFVocab:enables SimulationService
]
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Enabler mediating messaging between services via an MQTT broker."
    DTDFVocab:enables MQTTBrokerService
]

// Services of the digital twin
instance LoggingService : DTDFVocab:Service [
    base:desc "Service that logs time‑stamped state records into TimescaleDB."
    DTDFVocab:provides HistoricalDataInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that compares real‑time sensor data with simulation outputs, computes validation metrics, and flags deviations beyond pre‑defined thresholds."
    DTDFVocab:provides ValidationInsight, AlertAction
]
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service that computes motion plans using an analytical kinematic model of the gantry crane."
    DTDFVocab:provides TrajectoryPlanningInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Service that executes predictive simulations of the crane’s behaviour using the kinematic model."
    DTDFVocab:provides SimulationResultInsight
]
instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Eclipse Mosquitto MQTT broker that mediates messaging between containerised services."
]
instance DashboardService : DTDFVocab:Service [
    base:desc "Grafana‑powered dashboard providing runtime visualisation and operator controls for the twin."
    DTDFVocab:provides VisualizationInsight, AlertAction
]

// Model used by trajectory generation and simulation
instance KinematicModel : DTDFVocab:Model [
    base:desc "Analytical kinematic model of the gantry crane used by both the Trajectory Generator and Simulation services."
    DTDFVocab:inputTo TrajectoryGeneratorEnabler, SimulationEnabler
]

// Insights and Actions
instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight that provides access to historical state records stored in TimescaleDB for post‑event analysis."
]
instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Insight showing deviation metrics between sensor measurements and simulation predictions."
]
instance AlertAction : DTDFVocab:Action [
    base:desc "Real‑time alert presented on the dashboard when confidence interval exceeds threshold."
    DTDFVocab:IsAutomatic true
]
instance TrajectoryPlanningInsight : DTDFVocab:Insight [
    base:desc "Insight detailing planned trajectory generated by the Trajectory Generator Service."
]
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight presenting simulation output and predictive confidence bounds."
]
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight that visualises real‑time sensor data and model states on the dashboard."
]

// Environment and physical components
instance GantryCraneComponent : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane comprising gantry structure, horizontal rail, trolley, load carriage, electric drive motors with embedded controllers."
]
instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Python program that retrieves state data from the crane controllers and forwards the raw measurement stream to the Logging Application."
]
instance TimescaleDBDatabase : DTDFVocab:Component [
    base:desc "TimescaleDB instance persisting all trajectory, actuation, and sensor data as a time‑series repository."
]
instance DockerContainerStack : DTDFVocab:Component [
    base:desc "Docker containers packaging each component (broker, database, simulation, visualization) and orchestrating deployment."
]
instance MQTTBrokerComponent : DTDFVocab:Component [
    base:desc "Eclipse Mosquitto MQTT broker that mediates messaging between twin services."
]
instance DashboardComponent : DTDFVocab:Component [
    base:desc "Grafana dashboard visualising sensor data and model states."
]
instance TrajectoryGeneratorComponent : DTDFVocab:Component [
    base:desc "Service container executing trajectory generation algorithm."
]
instance SimulationComponent : DTDFVocab:Component [
    base:desc "Service container performing predictive simulations of the crane."
]
instance ContinuousValidationComponent : DTDFVocab:Component [
    base:desc "Service container that continuously validates kinematic predictions against real‑time sensor data."
]
instance DataLoggingComponent : DTDFVocab:Component [
    base:desc "Component responsible for writing time‑stamped records into TimescaleDB."
]
instance ControlAlgorithmComponent : DTDFVocab:Component [
    base:desc "Python code implementing control logic for optimal horizontal and vertical motions of the crane."
]
instance EnvironmentLabScale : DTDFVocab:Environment [
    base:contains GantryCraneComponent, PhysicalCraneInterface, TimescaleDBDatabase,
    DockerContainerStack, MQTTBrokerComponent, DashboardComponent,
    TrajectoryGeneratorComponent, SimulationComponent, ContinuousValidationComponent,
    DataLoggingComponent, ControlAlgorithmComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are issued from the Digital Twin’s Control Application, a Python program that uses the same Physical Crane Interface to communicate with the physical hardware. Commands such as target positions or trajectory plans are sent directly to the crane controller through the interface’s underlying connection. The document does not specify the message format, authentication, or feedback mechanisms; operators rely on the dashboard and the Continuous Validation Service for monitoring compliance and detecting discrepancies."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is orchestrated following a C4 container diagram. Containers include: (1) the Physical Crane hardware; (2) a local MQTT broker exposed to all services; (3) a Trajectory Generator Service responsible for path planning; (4) a Simulation Service that models the crane dynamics; (5) a Dashboard service that renders a real‑time web UI; and (6) a time‑series Database Service (InfluxDB) that stores state logs. Inter‑service communication occurs over asynchronous MQTT topics, while the Dashboard uses HTTPS to pull aggregated data. All containers are deployed on the same virtual machine or Raspberry‑Pi host, with Docker managing isolation. No external orchestration tool (e.g., Kubernetes) is used; rather, a lightweight script manages the deployment lifecycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model and data validity are enforced by the Continuous Validation Service, which operates in real‑time to juxtapose executed trajectories against simulated ones. It calculates Euclidean distance metrics for each trajectory waypoint, compares them to a configurable threshold, and triggers alerts or corrective actions when discrepancies exceed that threshold. This on‑line verification process serves as the primary validation and quality assurance mechanism for the twin’s behavioural models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the virtual components uses an MQTT broker, enabling messaging between services such as the Trajectory Generator Service, Simulation Service and Continuous Validation Service. The Physical Crane Interface interacts with the crane controllers, but the underlying protocol is not specified. All services are run locally on a single computer and coordinated via Docker Compose, implying a local host network topology. Specific bandwidth, latency, reliability, redundancy or security protocols are not detailed."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is deployed on a single machine – a personal computer – where the physical crane is connected. All software components, including the Physical Crane Interface, Control Application, Logging Application, and digital twin services (Database, Dashboard, MQTT broker, etc.) are containerised and orchestrated with Docker Compose. The deployment is on‑premises, without cloud or edge layers, and no scalability or high‑availability mechanisms are described."
]