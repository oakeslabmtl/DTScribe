// ---------------------------
// C4: Data Transmitted
// ---------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    producedFrom Anemometer
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    producedFrom MotorControllerStatusSensor
]

// ---------------------------
// C11: Enablers
// ---------------------------
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB PostgreSQL extension for storing time-series sensor data",
    enables DataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker facilitating data streaming from Arduino to the twin",
    enables DataLoggingService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana container rendering dashboards from TimescaleDB data",
    enables VisualizationDashboardService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Software component that generates optimal swing-free trajectories",
    enables TrajectoryGenerationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine executing the crane dynamics model",
    enables CraneSimulationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation engine comparing live measurements with simulation outputs",
    enables ContinuousValidationService
]

// ---------------------------
// C6: Services
// ---------------------------
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuously streams sensor measurements from Arduino via MQTT into TimescaleDB",
    provides SensorDataStoredInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Grafana visualization dashboard presenting sensor data, simulation results and alerts",
    provides OperatorDecisionInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Optimal trajectory generation service offering swing-free motion plans",
    provides OptimalMotionPlanInsight,
    provides ExecuteTrajectoryAction
]

instance CraneSimulationService : DTDFVocab:Service [
    base:desc "Crane simulation service that runs virtual execution of generated trajectories",
    provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service that checks live measurements against simulation and raises alerts",
    provides TrajectoryDeviationAlertInsight,
    provides TriggerAlertAction
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Human-Machine Interface allowing operator to start/stop trajectories and acknowledge alerts",
    provides OperatorControlAction
]

// ---------------------------
// C3: Physical Sensing Components
// ---------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing Angle Encoder measuring hoist swing on the lab-scale gantry crane",
    producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed that affects crane dynamics",
    producedData WindSpeedDataTransmitted
]

instance MotorControllerStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor aggregating motor positions and controller states read via Arduino",
    producedData MotorStatusDataTransmitted
]

// ---------------------------
// C10: Data (Time-Series)
// ---------------------------
instance SwingAngleTimeSeriesData : DTDFVocab:Data [
    base:desc "Time-series of swing angle measurements stored in TimescaleDB",
    fromData SwingAngleDataTransmitted,
    inputTo TimescaleDBEnabler
]

instance WindSpeedTimeSeriesData : DTDFVocab:Data [
    base:desc "Time-series of wind speed readings stored in TimescaleDB",
    fromData WindSpeedDataTransmitted,
    inputTo TimescaleDBEnabler
]

instance MotorStatusTimeSeriesData : DTDFVocab:Data [
    base:desc "Time-series of motor positions and controller states stored in TimescaleDB",
    fromData MotorStatusDataTransmitted,
    inputTo TimescaleDBEnabler
]

// ---------------------------
// C10: Models
// ---------------------------
instance CADCraneModel : DTDFVocab:Model [
    base:desc "CAD model of the lab-scale gantry crane used for visualization",
    inputTo GrafanaDashboardEnabler
]

instance KinematicCraneModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the trajectory generator to compute swing-free paths",
    inputTo TrajectoryGeneratorEnabler
]

instance SimulationCraneModel : DTDFVocab:Model [
    base:desc "Simulation model of the crane and its controllers for virtual testing",
    inputTo SimulationEngineEnabler
]

// ---------------------------
// C2: Acting Components
// ---------------------------
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor driven by a TMC4671-Eval controller for horizontal motion"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor driven by a TMC4671-Eval controller for vertical lift"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist used to grip loads, controlled by Arduino"
]

instance ArduinoInterfaceBoard : DTDFVocab:Component [
    base:desc "Arduino board reading sensors and commanding motor controllers and electromagnet"
]

instance PowerSupplyUnit : DTDFVocab:Component [
    base:desc "Power supply unit providing required voltages to Arduino, motor drivers and electromagnet"
]

// ---------------------------
// C9: Environment
// ---------------------------
instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains CartStepperMotor, HoistStepperMotor, ElectromagnetActuator,
    ArduinoInterfaceBoard, PowerSupplyUnit, SwingAngleEncoder, Anemometer
]

// ---------------------------
// C17: Insights & Actions
// ---------------------------
instance SensorDataStoredInsight : DTDFVocab:Insight [
    base:desc "Insight that sensor readings are successfully persisted and available for downstream analysis"
]

instance OperatorDecisionInsight : DTDFVocab:Insight [
    base:desc "Insight presented on the dashboard to aid operator decision making"
]

instance OptimalMotionPlanInsight : DTDFVocab:Insight [
    base:desc "Insight delivering an optimal, swing-free motion plan for the crane"
]

instance ExecuteTrajectoryAction : DTDFVocab:Action [
    base:desc "Action that sends the computed trajectory to the crane controllers",
    IsAutomatic true
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight showing simulation outcomes such as predicted swing angles and motor loads"
]

instance TrajectoryDeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Real-time alert when measured trajectory deviates beyond predefined thresholds"
]

instance TriggerAlertAction : DTDFVocab:Action [
    base:desc "Action that notifies the operator dashboard of a validation breach",
    IsAutomatic true
]

instance OperatorControlAction : DTDFVocab:Action [
    base:desc "Manual action by the operator to approve or modify a trajectory",
    IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (Python) sends motion commands and trajectory set‑points to the Physical Crane Interface, which forwards them to the motor controllers and electromagnet; the Trajectory Generator Service provides optimal trajectory commands, and the Continuous Validation Service can trigger operator alerts through the dashboard."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous (real‑time) data streaming and validation; logging occurs continuously while the crane operates, and services such as trajectory generation and validation run synchronously with the physical process."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical crane ↔ Python Interface ↔ Control/Logging Applications ↔ MQTT broker ↔ Services (Trajectory Generator, Simulation, Continuous Validation) ↔ TimescaleDB ↔ Grafana dashboard; all services run on a single PC with Docker‑containerised database, broker and dashboard, coordinated via Docker‑compose."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the design stage (CAD models in Autodesk Fusion360 and kinematic model), the manufacture/assembly stage (physical crane components), and the operation stage (real‑time sensor data, control commands, and validation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service computes distance metrics between measured trajectories and simulated ones, compares them against predefined thresholds, and alerts operators; model validation methods from prior work are reused to ensure twin fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT (Eclipse Mosquitto) for lightweight signalling between services; Python interface communicates with motor controllers (likely via serial/USB); TimescaleDB accessed over TCP/IP using standard PostgreSQL SQL queries."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software runs on a personal computer; Docker containers host the TimescaleDB, MQTT broker and Grafana dashboard; the gantrylib module is installed via pip; deployment automated with a Docker‑compose file; source code and documentation hosted publicly on GitHub under an MIT license."
]