// =============================
// Acting Components
// =============================
instance CartMotorStepperActuator : DTDFVocab:ActingComponent [
    base:desc "Stepper motor that drives the cart along the gantry, controlled by a TMC4671‑Eval motor controller"
]

instance HoistMotorStepperActuator : DTDFVocab:ActingComponent [
    base:desc "Stepper motor that drives the hoist, controlled by a TMC4671‑Eval motor controller"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist for picking up and releasing pucks"
]

// =============================
// Physical Components
// =============================
instance TMC4671EvalMotorController : DTDFVocab:Component [
    base:desc "TMC4671‑Eval motor controller used for both cart and hoist stepper motors"
]

instance ArduinoBoardComponent : DTDFVocab:Component [
    base:desc "Arduino board that reads swing‑angle encoder and anemometer and forwards data to the Python interface"
]

instance PhysicalCraneInterfaceComponent : DTDFVocab:Component [
    base:desc "Python‑based interface that reads motor controller states and sensor values, then publishes them via MQTT"
]

// =============================
// Sensing Components
// =============================
instance SwingAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Quadrature encoder measuring hoist swing angle"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorControllerStateSensor : DTDFVocab:SensingComponent [
    base:desc "Software sensor that extracts motor controller state (position, velocity, current) from the TMC4671 controllers"
    DTDFVocab:producedData MotorStateDataTransmitted
]

// =============================
// Data Transmitted (MQTT)
// =============================
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensor
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerStateSensor
]

// =============================
// Data (Time‑Series, Models, Metrics)
// =============================
instance SwingAngleTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo LoggingEnabler
]

instance WindSpeedTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo LoggingEnabler
]

instance MotorStateTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of motor controller state variables stored in TimescaleDB"
    DTDFVocab:fromData MotorStateDataTransmitted
    DTDFVocab:inputTo LoggingEnabler
]

instance KinematicModelData : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator to compute swing‑free trajectories"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance SimulationModelData : DTDFVocab:Model [
    base:desc "Physics‑based simulation model of crane dynamics used by the Simulation Service"
    DTDFVocab:inputTo SimulationEnabler
]

instance ValidationMetricsData : DTDFVocab:Data [
    base:desc "Metrics comparing executed trajectories against simulated ones, generated by the Continuous Validation Service"
    DTDFVocab:inputTo ValidationEnabler
]

// =============================
// Enablers (Tools / Platforms)
// =============================
instance PythonGantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module that implements trajectory generation, simulation and validation algorithms"
    DTDFVocab:enables TrajectoryGenerationService
    DTDFVocab:enables SimulationService
    DTDFVocab:enables ValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for real‑time signalling between physical interface and digital‑twin services"
    DTDFVocab:enables MQTTSignalService
]

instance LoggingEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑containerised TimescaleDB instance that receives logged data via the Logging Application"
    DTDFVocab:enables LoggingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard container that visualises time‑series and simulation results"
    DTDFVocab:enables VisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Service‑level enabler that consumes the kinematic model and produces optimal trajectories"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that runs the physics simulation using the simulation model"
    DTDFVocab:enables SimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that evaluates validation metrics and raises alerts"
    DTDFVocab:enables ValidationService
]

// =============================
// Services
// =============================
instance LoggingService : DTDFVocab:Service [
    base:desc "Application that records incoming sensor streams into TimescaleDB"
    DTDFVocab:provides DataLoggingInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboard that visualises logged data and simulation outcomes"
    DTDFVocab:provides SimulationResultInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal, swing‑free trajectories for the gantry crane"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Executes the crane dynamics simulation for a given trajectory"
    DTDFVocab:provides SimulationResultInsight
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Continuously validates executed trajectories against simulated ones and emits alerts"
    DTDFVocab:provides RealTimeAlertInsight
    DTDFVocab:provides OperatorInterventionAction
]

instance MQTTSignalService : DTDFVocab:Service [
    base:desc "Generic MQTT signalling service used for command & status exchange between components"
    DTDFVocab:provides RealTimeAlertInsight
]

// =============================
// Insights
// =============================
instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Confirms that sensor data have been successfully stored in the time‑series database"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Provides visual feedback of simulated crane motion for operator decision support"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Delivers the computed optimal trajectory to the motion controller to minimize residual swing"
]

instance RealTimeAlertInsight : DTDFVocab:Insight [
    base:desc "Generates real‑time alerts when validation metrics exceed predefined thresholds"
]

// =============================
// Actions
// =============================
instance OperatorInterventionAction : DTDFVocab:Action [
    base:desc "Allows an operator to intervene and abort or modify the current trajectory"
    DTDFVocab:IsAutomatic false
]

// =============================
// Environment (optional grouping)
// =============================
instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains CartMotorStepperActuator, HoistMotorStepperActuator, ElectromagnetActuator,
                     TMC4671EvalMotorController, ArduinoBoardComponent, PhysicalCraneInterfaceComponent,
                     SwingAngleEncoderSensor, AnemometerSensor, MotorControllerStateSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal motion trajectories and sends them via MQTT to the Control Application, which uses the Physical Crane Interface to command the motor controllers; the Human‑Machine Interface also sends operator commands through the same path to the physical crane."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates in near real‑time: sensor data are streamed continuously and logged; validation compares measured trajectories with simulated ones as soon as new data arrive, generating instant alerts; trajectory generation and control run during movement execution, providing online guidance. No explicit sampling frequency is documented."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A cyber‑physical system where the physical crane and its controller are linked via a Python interface to a suite of digital twin services (trajectory generation, simulation, continuous validation) that communicate over MQTT, store data in TimescaleDB, and present results via a Grafana dashboard; user interaction is provided by a web‑based Human‑Machine Interface."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin covers the designed/ideal stage (CAD models of the crane in Autodesk Fusion 360 and a kinematic model) as well as the operated stage (real‑time sensor data, logging, validation and control during physical operation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service continuously compares measured trajectories with simulated trajectories, computes distance metrics, and checks them against a predefined threshold; violations trigger operator alerts on the dashboard, ensuring model fidelity is monitored during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication between PT and DT is realized through an MQTT broker (Eclipse Mosquitto) over TCP/IP; the Python interface subscribes/publishes to MQTT topics to exchange control commands and sensor updates."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital twin services are containerised with Docker and orchestrated via a single docker‑compose file; they run on a personal computer that also hosts the physical crane interface; the source code and Docker assets are publicly hosted on GitHub."
]