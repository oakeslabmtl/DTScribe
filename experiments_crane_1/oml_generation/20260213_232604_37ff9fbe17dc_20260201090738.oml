instance RaspberryPiSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry Pi sensors used in the physical crane system for data acquisition"
    DTDFVocab:producedData CraneStateDataTransmitted
]

instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RaspberryPiSensor
]

instance CraneStateData : DTDFVocab:Data [
    base:desc "Crane state data captured from physical system and transmitted via MQTT"
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo TimescaleDB, LoggingApplication, MQTTBroker
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB database for continuous storage of operational metrics"
    DTDFVocab:enables HistoricalDataLogging
]

instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Logging Application for data storage and management"
    DTDFVocab:enables HistoricalDataLogging
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker for data transmission between physical and virtual components"
    DTDFVocab:enables HistoricalDataLogging
]

instance GitHub : DTDFVocab:Enabler [
    base:desc "GitHub for version control of digital twin models and code"
    DTDFVocab:enables ContinuousValidation
]

instance Docker : DTDFVocab:Enabler [
    base:desc "Docker containerization for deployment of digital twin components"
    DTDFVocab:enables HistoricalDataLogging
]

instance AzurePipelines : DTDFVocab:Enabler [
    base:desc "Microsoft Azure Pipelines for CI/CD implementation"
    DTDFVocab:enables ContinuousValidation
]

instance AzureDashboards : DTDFVocab:Enabler [
    base:desc "Microsoft Azure Dashboards for real-time data visualization"
    DTDFVocab:enables RealTimeDataVisualization
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine for digital twin operations"
    DTDFVocab:enables SimulationService
]

instance PredictionEnabler : DTDFVocab:Enabler [
    base:desc "Prediction engine for digital twin operations"
    DTDFVocab:enables PredictionService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for continuous validation of model accuracy"
    DTDFVocab:enables ContinuousValidation
]

instance AutomationMLModel : DTDFVocab:Model [
    base:desc "AutomationML model for digital twin representation of the gantry crane system"
    DTDFVocab:inputTo ContinuousValidationEnabler
]

instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Python program capturing crane state data from physical sensors and publishing via MQTT"
]

instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:desc "Laboratory environment where the gantry crane system operates"
    base:contains RaspberryPiSensor, PhysicalCraneInterface
]

instance RealTimeDataVisualization : DTDFVocab:Service [
    base:desc "Real-time data visualization for monitoring"
    DTDFVocab:provides RuntimeVisualization
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation capabilities for indoor air quality management"
    DTDFVocab:provides Simulation
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Prediction capabilities for indoor air quality management"
    DTDFVocab:provides Prediction
]

instance ContinuousValidation : DTDFVocab:Service [
    base:desc "Continuous validation to ensure model accuracy"
    DTDFVocab:provides ModelAccuracyInsight
]

instance OptimalControl : DTDFVocab:Service [
    base:desc "Optimal control for crane operation"
    DTDFVocab:provides OptimalControlAction
]

instance HistoricalDataLogging : DTDFVocab:Service [
    base:desc "Historical data logging for operational metrics"
    DTDFVocab:provides HistoricalDataInsight
]

instance RuntimeVisualization : DTDFVocab:Insight [
    base:desc "Runtime visualization capabilities for indoor air quality management targeting virus spread prevention strategies"
]

instance Simulation : DTDFVocab:Insight [
    base:desc "Simulation capabilities for indoor air quality management targeting virus spread prevention strategies"
]

instance Prediction : DTDFVocab:Insight [
    base:desc "Prediction capabilities for indoor air quality management targeting virus spread prevention strategies"
]

instance OptimalControlAction : DTDFVocab:Action [
    base:desc "Optimal control actions for crane operation"
    DTDFVocab:IsAutomatic true
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Insight into model accuracy for continuous validation"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Historical data insights for operational metrics analysis"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory commands generated by the Trajectory Generator Service are processed by the Control Application (Python), which sends control instructions via the Physical Crane Interface to the physical crane. Command formats, validation, authentication, and feedback mechanisms are not specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system features an AutomationML-based digital twin model, a Raspberry-Pi sensor system for the physical component, and Microsoft Azure tools for implementing the digital twin pipeline."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system utilizes an MQTT broker for communication between digital twin services. Network topology, bandwidth, latency requirements, reliability, redundancy, and security protocols are not detailed in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with Microsoft Azure cloud services for digital twin pipeline implementation and data processing."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adheres to the AutomationML standard for digital twin modeling and utilizes Microsoft Azure tools for pipeline implementation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Continuous Validation Service continuously compares executed trajectory measurements with simulations, calculates distance metrics against an acceptable threshold, and notifies operators via the dashboard when breaches occur; the physical crane system is designed to operate independently of the digital twin for continued functionality."
]