// SENSOR
instance CraneStateSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor assembly that measures the crane's vertical and horizontal position, velocity, payload mass, and status flags"
    DTDFVocab:producedData CraneStateDataTransmitted
]

// DATA TRANSMITTED
instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneStateSensor
]

// DATA
instance CraneStateTimeseriesData : DTDFVocab:Data [
    base:desc "Time‑series of crane state measurements collected by the Logging Application"
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo LoggingApplication
    DTDFVocab:inputTo KinematicProcessingEnabler
]

// ENABLER: Logging Application
instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Python program that writes CraneStateTimeseriesData to TimescaleDB over the PostgreSQL protocol"
    DTDFVocab:enables DataLoggingService
]

// ENABLER: Kinematic Processing
instance KinematicProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processor that uses crane state data and the kinematic model to validate trajectories and compute optimal motion profiles"
    DTDFVocab:enables KinematicModelValidationService
    DTDFVocab:enables OptimalControlService
]

// MODEL
instance KinematicModel : DTDFVocab:Model [
    base:desc "Mathematical representation of the crane's translational and rotational motion used for trajectory validation and optimal control"
    DTDFVocab:inputTo KinematicProcessingEnabler
]

// SERVICES
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Stores time‑series crane state data in TimescaleDB for historical analysis"
    DTDFVocab:provides HistoricalDataInsight
]

instance KinematicModelValidationService : DTDFVocab:Service [
    base:desc "Validates the measured crane trajectory against the kinematic model in real time"
    DTDFVocab:provides ModelDeviationInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes motion profiles to minimize energy consumption and trajectory time, providing control commands"
    DTDFVocab:provides OptimalControlCommandAction
]

instance ActuatorStateMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of all actuator states of the gantry crane"
    DTDFVocab:provides ActuatorStatesInsight
]

instance KinematicVisualizationService : DTDFVocab:Service [
    base:desc "3D visualization of the crane's pose"
    DTDFVocab:provides KinematicPoseInsight
]

// INSIGHTS
instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Access to historical crane state trajectories for post‑hoc analysis"
]

instance ModelDeviationInsight : DTDFVocab:Insight [
    base:desc "Comparison metric between actual and predicted crane poses indicating model deviations"
]

instance ActuatorStatesInsight : DTDFVocab:Insight [
    base:desc "Current status and motion parameters of all crane actuators"
]

instance KinematicPoseInsight : DTDFVocab:Insight [
    base:desc "Real‑time 3D visualization of the crane's current pose"
]

// ACTION
instance OptimalControlCommandAction : DTDFVocab:Action [
    base:desc "Computed control commands sent back to the PLC‑based controller"
    DTDFVocab:IsAutomatic true
]

// ENVIRONMENT & COMPONENTS (system under study)
instance GantryCranePhysicalSystem : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane comprising a compact aluminum framework, linear rail guides, a vertical hoist shaft, a horizontal carriage with a load‑bearing gripper, and a PLC‑based controller"
]

instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains GantryCranePhysicalSystem
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the Control Application (Python) and sent through the Physical Crane Interface to the physical crane’s controllers. The interface establishes a direct connection to the crane controls—typically via a vendor‑specific low‑level protocol over serial or CAN (specific protocol not detailed). Movement instructions, trajectory parameters, and safety limits are transmitted as command messages from the Python application to the crane. The physical crane executes these commands, while any acknowledgement or status feedback is intended to be captured by the Logging Application (acknowledgement implementation details are not specified in the document)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin is managed by an MQTT broker that facilitates publish/subscribe messaging among services such as the Trajectory Generator, Simulation, Continuous Validation, and Dashboard services. The broker operates over TCP using the standard MQTT protocol. No additional network protocols, topology details, or architecture specifications are provided in the document for the broader physical‑to‑digital link."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplar adopts the AutomationML specification for its digital‑twin model, ensuring alignment with mechanistic engineering data‑exchange standards. Core datastore and messaging components include InfluxDB for time‑series data and ActiveMQ for message brokering, both widely recognized open‑source standards in industrial automation."
]