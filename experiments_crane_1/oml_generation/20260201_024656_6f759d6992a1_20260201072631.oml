// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing Angle Encoder mounted on the hoist to measure the swinging angle of the load"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer attached to the crane structure to measure ambient wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Data transmitted from sensors
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Data objects created from transmitted sensor data
instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Real‑time swing angle measurement stream from the Swing Angle Encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDB, KinematicSimulator
]

instance WindSpeedMeasurement : DTDFVocab:Data [
    base:desc "Real‑time wind speed measurement from the Anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

// C11: Enablers that consume data and enable services
instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database used by the Logging Application to store sensor data"
    DTDFVocab:enables HistoricalLoggingService, DataVisualizationService
]

instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Continuously running Python logging application that reads sensor data via the Physical Crane Interface and writes to TimescaleDB"
    DTDFVocab:enables HistoricalLoggingService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Open‑source visualization engine used to render CAD geometry and sensor data"
    DTDFVocab:enables DataVisualizationService
]

instance KinematicSimulator : DTDFVocab:Enabler [
    base:desc "Simulation engine that uses the kinematic model and sensor data to compute optimal control commands and perform validation"
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

// C6: Services provided by the digital twin
instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Service that logs historical sensor data into TimescaleDB for later analysis"
    DTDFVocab:provides HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service that visualizes real‑time and historical sensor data for operators"
    DTDFVocab:provides VisualizationInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service that provides optimal control commands for the crane based on the kinematic model"
    DTDFVocab:provides OptimalControlAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously validates physical crane state against simulated predictions"
    DTDFVocab:provides ValidationInsight
]

// C17: Insights and actions generated by services
instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight into long‑term trends of swing angle and wind speed for performance evaluation"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight showing live swing angle and wind speed plots to aid monitoring"
]

instance OptimalControlAction : DTDFVocab:Action [
    base:desc "Automatic generation of actuation commands for trolley and hoist to achieve desired trajectories"
    DTDFVocab:IsAutomatic true
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating deviation between measured sensor data and kinematic model predictions"
]

// C2: Acting components (physical actuators)
instance MotorizedTrolleyActuator : DTDFVocab:ActingComponent [
    base:desc "Motorized actuator driving horizontal travel of the gantry crane along its rails"
]

instance HoistActuator : DTDFVocab:ActingComponent [
    base:desc "Motorized actuator driving vertical lift of the hoist mechanism"
]

instance CraneController : DTDFVocab:ActingComponent [
    base:desc "Remote controller exposing a bidirectional interface for command issuance and status feedback with the digital twin"
]

// C10: Models used by the digital twin
instance GantryCraneCADModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the lab‑scale gantry crane"
    DTDFVocab:inputTo VisualizationEngine
]

instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Analytical kinematic model capturing motion of the crane and its load"
    DTDFVocab:inputTo KinematicSimulator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, a Python program, sends command messages to the Physical Crane Interface, which forwards them to the crane’s low‑level controllers. Commands are generated by higher‑level services such as the Trajectory Generator Service (providing optimal trajectory way‑points) and are transmitted as Python objects over the internal network. Execution feedback is reflected by subsequent state updates logged by the Logging Application, though explicit acknowledgement messages or validation steps are not detailed in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The gantry‑crane exemplar adopts an ad‑hoc digital‑twin architecture without a dedicated commercial framework. Deployment relies on containerization/virtualisation technologies and the system’s software architecture is described using the C4 model, indicating a loosely coupled arrangement of components rather than a formally orchestrated framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by using a kinematic model that is continuously validated against measured motion of the physical crane. The twin includes a continuous validation service that compares sensed state with simulated predictions, allowing detection of modeling errors and fault detection. Validation methods were employed in prior research on continuous validation and fault detection, but specific uncertainty quantification procedures are not detailed in the documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin uses an MQTT broker for publish/subscribe signaling between the Trajectory Generator Service, Simulation Service, Continuous Validation Service, and other components. MQTT (over TCP/IP) provides the messaging backbone. The TimescaleDB database is accessed via its PostgreSQL protocol, and the Grafana dashboard via HTTP. All components reside on a local LAN connecting the Python processes, MQTT broker, database, and dashboard; no cloud‑based networking, bandwidth, latency, or redundancy specifications are provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire digital twin is deployed on a single on‑premise personal computer. Docker is used to containerize the TimescaleDB database, the MQTT broker, and the Grafana dashboard. Python processes implement the Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface, Trajectory Generator, Simulation, and Continuous Validation services. The deployment relies on the host PC’s compute and storage resources, with container isolation providing basic scalability and fault isolation; no cloud or external edge platforms are used."
]