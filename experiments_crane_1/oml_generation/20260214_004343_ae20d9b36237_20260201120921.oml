    base:desc "velocity data stored in TimescaleDB for post‑hoc analysis"
    DTDFVocab:fromData CraneVelocityTelemetry
    DTDFVocab:inputTo CraneLoggingEnabler
]

instance CraneAccelerationData : DTDFVocab:Data [
    base:desc "acceleration data stored in TimescaleDB for post‑hoc analysis"
    DTDFVocab:fromData CraneAccelerationTelemetry
    DTDFVocab:inputTo CraneLoggingEnabler
]

