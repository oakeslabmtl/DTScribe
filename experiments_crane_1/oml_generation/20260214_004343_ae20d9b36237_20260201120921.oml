instance CranePositionData : DTDFVocab:Data [
    base:desc "position data stored in TimescaleDB for post‑hoc analysis"
    DTDFVocab:fromData CranePositionTelemetry
    DTDFVocab:inputTo CraneLoggingEnabler
]

