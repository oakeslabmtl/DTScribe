instance LightingTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance IrrigationTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IrrigationSensor
