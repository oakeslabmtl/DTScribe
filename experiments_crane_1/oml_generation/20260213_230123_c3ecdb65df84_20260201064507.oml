// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the crane carriage."
    DTDFVocab:producedData SwingAngleTransmission
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed near the crane."
    DTDFVocab:producedData WindSpeedTransmission
]

// C4: Physical-to-virtual interaction
instance SwingAngleTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CraneStateLoggingTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder, Anemometer
]

instance RealTimeVisualizationTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder, Anemometer
]

// C10: Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Swing‑angle measurements (degrees) sampled from the encoder."
    DTDFVocab:fromData SwingAngleTransmission
    DTDFVocab:inputTo PythonPhysicalCraneInterface
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Wind‑speed measurements (m/s) sampled from the anemometer."
    DTDFVocab:fromData WindSpeedTransmission
    DTDFVocab:inputTo PythonPhysicalCraneInterface
]

instance HistoricalCraneStateData : DTDFVocab:Data [
    base:desc "Time‑stamped historical records of crane states stored in TimescaleDB."
    DTDFVocab:fromData CraneStateLoggingTransmission
    DTDFVocab:inputTo LoggingApplication, TimescaleDB
]

instance RealTimeVisualizationData : DTDFVocab:Data [
    base:desc "Live data stream used for operator dashboards."
    DTDFVocab:fromData RealTimeVisualizationTransmission
    DTDFVocab:inputTo VisualizationEngine
]

// C10: Models/Data
instance GantryCraneCADModel : DTDFVocab:Model [
    base:desc "CAD model of the lab‑scale gantry crane structure and components."
    DTDFVocab:inputTo ContainerizationPlatform
]

instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model representing the motion dynamics of the crane carriage."
    DTDFVocab:inputTo ContainerizationPlatform
]

// C11: Enablers
instance PythonPhysicalCraneInterface : DTDFVocab:Enabler [
    base:desc "Python‑based interface that receives raw sensor measurements from the Arduino and forwards them to downstream applications."
    DTDFVocab:enables OptimalMotionControlService, ContinuousKinematicValidationService
]

instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Application that writes time‑stamped records (angle, wind‑speed, controller states) into a TimescaleDB time‑series database."
    DTDFVocab:enables HistoricalLoggingService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Engine that processes live data streams for real‑time operator dashboards."
    DTDFVocab:enables RealTimeVisualizationService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB PostgreSQL extension used for storing historical crane state data."
]

instance ContainerizationPlatform : DTDFVocab:Enabler [
    base:desc "Containerization technologies used to package the twin services in an ad‑hoc, framework‑free setup."
]

instance C4ModellingApproach : DTDFVocab:Enabler [
    base:desc "C4 modelling approach employed for architectural documentation of the digital twin."
]

// C6: Services
instance OptimalMotionControlService : DTDFVocab:Service [
    base:desc "Optimal motion‑control service that computes actuator commands for efficient crane movement."
    DTDFVocab:provides InsightMotionOptimization
]

instance ContinuousKinematicValidationService : DTDFVocab:Service [
    base:desc "Service that continuously validates the kinematic model against measured sensor data."
    DTDFVocab:provides InsightModelValidation
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Service that logs crane state data into a time‑series database for later analysis."
    DTDFVocab:provides InsightHistoricalAnalysis
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Service that delivers real‑time visualization of crane sensor data to operator dashboards."
    DTDFVocab:provides InsightOperatorVisualization
]

// C17: Insights
instance InsightMotionOptimization : DTDFVocab:Insight [
    base:desc "Insight about optimal motion trajectories to improve handling efficiency."
]

instance InsightModelValidation : DTDFVocab:Insight [
    base:desc "Insight regarding deviations between the kinematic model predictions and actual measurements."
]

instance InsightHistoricalAnalysis : DTDFVocab:Insight [
    base:desc "Insight derived from historical crane state data for performance trend analysis."
]

instance InsightOperatorVisualization : DTDFVocab:Insight [
    base:desc "Insight presented to operators via live dashboards for situational awareness."
]

// C18: Environment and Components (optional contextualization)
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains GantryStructure, Carriage, ControllerUnit, InterchangeablePucks
]

instance GantryStructure : DTDFVocab:Component [
    base:desc "Structural frame of the lab‑scale gantry crane."
]

instance Carriage : DTDFVocab:Component [
    base:desc "Motor‑driven carriage that moves along the gantry."
]

instance ControllerUnit : DTDFVocab:Component [
    base:desc "Electronic controller that commands the carriage motor and processes sensor inputs."
]

instance InterchangeablePucks : DTDFVocab:Component [
    base:desc "Container surrogates that are moved between predefined locations."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, a Python program, uses the Physical Crane Interface to issue command messages to the crane’s motor controllers and the electromagnet. Commands include motion set‑points for cart translation, hoist speed, and electromagnet activation/deactivation. The exact message format and validation mechanisms are not described, nor are authentication or acknowledgement protocols. Execution confirmation is provided to the operator through the Human Machine Interface and the Continuous Validation Service."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The lab‑scale gantry crane digital twin follows a container‑based orchestration pattern. Six twin‑related containers are deployed: a TimescaleDB instance storing all sensor and log data, a Grafana dashboard visualising that data, a Trajectory Generator Service that uses a kinematics model to compute swing‑free movement plans, a Simulation Service that reproduces the crane and controller behaviour, a Continuous Validation Service that continuously compares executed trajectories with their simulated counterpart and raises alerts when distance metrics exceed a threshold, and an MQTT broker that provides lightweight, publish‑subscribe signalling among the services. All services are implemented in Python and interact through the MQTT broker and the shared TimescaleDB, constituting a loosely‑coupled, centrally‑managed constellation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin provides a continuous validation service that monitors the correspondence between the physical crane behavior and its digital models, supporting model verification during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital‑twin services communicate over a local Docker‑based network. An Eclipse Mosquitto MQTT broker provides publish/subscribe signaling between the Trajectory Generator, Simulation, Continuous Validation, and other services. The TimescaleDB database and Grafana dashboard run as separate Docker containers reachable via the Docker bridge network. No explicit bandwidth, latency, or redundancy specifications are given; the deployment relies on standard TCP/IP within a single host."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin components are deployed on‑premise on a single personal computer. Python containers are bundled in the pip‑installable gantrylib module, while the Database (TimescaleDB), MQTT broker (Mosquitto) and Dashboard (Grafana) are containerized with Docker and orchestrated via a docker‑compose file. This on‑edge deployment requires modest compute (a typical PC) and storage for time‑series data; scalability is achieved by replicating Docker containers, though no cloud or distributed hosting is described. Availability is managed through Docker‑compose start‑up scripts that initialise the services automatically."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar adopts an AutomationML‑based digital twin, complying with the AutomationML (AML) specification for model‑driven twin engineering. No other standards, certifications, or interoperability frameworks are explicitly mentioned."
]