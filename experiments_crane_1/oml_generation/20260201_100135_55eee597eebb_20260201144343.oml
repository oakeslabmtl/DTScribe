// Sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on hoist to measure swing angle of crane column."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer sensor measuring wind speed at crane location."
    DTDFVocab:producedData AnemometerDataTransmitted
]

instance CartMotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on cart motor measuring horizontal position."
    DTDFVocab:producedData CartPositionDataTransmitted
]

instance HoistMotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on hoist motor measuring vertical lift position."
    DTDFVocab:producedData HoistPositionDataTransmitted
]

// Data transmitted by sensors
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CartPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorPositionEncoder
]

instance HoistPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorPositionEncoder
]

// Data stored in database
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing angle measurement."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance AnemometerData : DTDFVocab:Data [
    base:desc "Time‑stamped wind speed measurement."
    DTDFVocab:fromData AnemometerDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance CartPositionData : DTDFVocab:Data [
    base:desc "Time‑stamped horizontal cart position measurement."
    DTDFVocab:fromData CartPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HoistPositionData : DTDFVocab:Data [
    base:desc "Time‑stamped vertical lift position measurement."
    DTDFVocab:fromData HoistPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// Acting components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Step‑stepper motor driving horizontal cart movement, controlled by TMC4671‑Eval driver."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Step‑stepper motor driving vertical hoist, controlled by TMC4671‑Eval driver."
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet for container pickup, managed by custom Arduino shield."
]

// Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Time‑series database TimescaleDB that stores all plant sensor, actuator, and simulation data."
    DTDFVocab:enables SimulationService, ValidationService, FaultDetectionService, TrajectoryGeneratorService
]

instance MosquittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service messages."
    DTDFVocab:enables ValidationService, FaultDetectionService, TrajectoryGeneratorService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for real‑time visualization of time series."
    DTDFVocab:enables VisualizationService
]

instance CapellaEnabler : DTDFVocab:Enabler [
    base:desc "Capella used for model‑based engineering of crane system."
    DTDFVocab:enables CapellaModel, CADModel, KinematicModel, SimulationModel
]

// Models
instance CapellaModel : DTDFVocab:Model [
    base:desc "Capella Arcadia model describing system behavior and requirements."
    DTDFVocab:inputTo CapellaEnabler
]

instance CADModel : DTDFVocab:Model [
    base:desc "CAD skeleton of gantry rail, cart, hoist, and container support."
    DTDFVocab:inputTo CapellaEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by TrajectoryGeneratorService for motion planning."
    DTDFVocab:inputTo CapellaEnabler
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of crane control dynamics."
    DTDFVocab:inputTo CapellaEnabler
]

// Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates crane dynamics and generates accurate state data."
    DTDFVocab:provides PerformanceMetricsInsight
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Compares real execution against simulation using distance metrics."
    DTDFVocab:provides RealTimeAlertForTrajectoryDeviation
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Classifies fault states from time‑series sensor data."
    DTDFVocab:provides FaultDetectionInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal low‑swing trajectories for container pickup."
    DTDFVocab:provides OptimalTrajectorySuggestion
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Displays real‑time data and simulation outputs in Grafana dashboards."
    DTDFVocab:provides VisualDashboardInsight
]

// Insights
instance RealTimeAlertForTrajectoryDeviation : DTDFVocab:Insight [
    base:desc "Alert when trajectory deviates from planned path, based on swing angle and motor position data."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of faults in motor or electromagnet operation through classification of time‑series sensor data."
]

instance OptimalTrajectorySuggestion : DTDFVocab:Insight [
    base:desc "Suggested low‑swing trajectory for efficient container pickup."
]

instance PerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Simulation accuracy metrics comparing current execution to model predictions."
]

instance VisualDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time dashboard of sensor readings and simulation outputs."
]

// Actions
instance AdjustTrajectoryParametersAction : DTDFVocab:Action [
    base:desc "Operator action to modify trajectory parameters via HMI."
    DTDFVocab:IsAutomatic false
]

instance AdjustPlanAction : DTDFVocab:Action [
    base:desc "Operator action to select or modify container pickup plans."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin’s Trajectory Generator Service computes optimal, swing‑free motion trajectories and forwards them to the Control Application. The Control Application sends motor commands to the Physical Crane Interface, which transmits them to the TMC4671‑Eval controllers and the electromagnet driver on the physical crane."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in real‑time, processing data as it streams from the physical system. The Logging Application writes sensor data continuously, the Trajectory Generator schedules new trajectories on demand, and the Continuous Validation Service evaluates the executed trajectory immediately after completion. The infrastructure is designed for continuous, low‑latency interaction, although explicit timing specifications are not given in the documentation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated by a Docker‑Compose stack on a single workstation; services communicate over local network via MQTT; data flows from sensors to database, visualized in Grafana; trajectory generation and simulation run within dedicated containers receiving state from the database and publishing results back to the broker."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The exemplar covers the design stage with CAD models (Autodesk Fusion360) and Arcadia/Capella models, the manufacturing stage where the physical crane is built from the BOM, and the operation stage where the system runs in real‑time for research or teaching. It is regularly updated for research papers and educational modules, reflecting iterative development and evolution."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service compares measured versus simulated trajectory positions using distance metrics; a user‑defined threshold triggers alerts if limits are breached. Simulation provides confidence bounds plotted against real traces. Validation relies on consistent sensor data and accurate kinematic modelling; no explicit uncertainty quantification is reported but threshold‑based checks serve as a pragmatic validation mechanism."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual communication occurs via the Arduino (likely USB/serial) to the Physical Crane Interface and then to the Logging Application, which writes to TimescaleDB. Virtual‑to‑physical actions are transmitted via the Physical Crane Interface to the Arduino, which drives the TMC4671‑Eval controllers. Inter‑service communication within the twin uses MQTT over a local network. All components run on a single PC with Docker networking."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire twin stack is deployed locally on a Linux PC using Docker and Docker Compose. The database, MQTT broker, Grafana, and all Python services are containerized. Source code and container images are available on GitHub, and the twin can be brought up with a single compose command. The system is distributed under the MIT license."
]