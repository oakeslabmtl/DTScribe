// Sensing Components
instance SwingAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder on the crane that reports the hoist’s swing angle"
    DTDFVocab:producedData SwingAngleTelemetry
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed at the crane"
    DTDFVocab:producedData WindSpeedTelemetry
]

instance CartMotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder on the cart stepper motor providing cart position/time data"
    DTDFVocab:producedData CartEncoderTelemetry
]

instance HoistMotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder on the hoist stepper motor providing hoist position/time data"
    DTDFVocab:producedData HoistEncoderTelemetry
]

// Data Transmitted
instance SwingAngleTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensor
]

instance WindSpeedTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance CartEncoderTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoderSensor
]

instance HoistEncoderTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoderSensor
]

// Data
instance SwingAngleTimeSeriesData : DTDFVocab:Data [
    base:desc "Low‑latency time‑series of swing‑angle measurements logged in the twin"
    DTDFVocab:fromData SwingAngleTelemetry
    DTDFVocab:inputTo TimescaleDBInstance
]

instance WindSpeedTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of wind speed measurements recorded for environmental analysis"
    DTDFVocab:fromData WindSpeedTelemetry
    DTDFVocab:inputTo TimescaleDBInstance
]

instance CartPositionTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of cart position data extracted from motor encoder counts"
    DTDFVocab:fromData CartEncoderTelemetry
    DTDFVocab:inputTo TimescaleDBInstance
]

instance HoistPositionTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of hoist position data extracted from motor encoder counts"
    DTDFVocab:fromData HoistEncoderTelemetry
    DTDFVocab:inputTo TimescaleDBInstance
]

// Models
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "Fusion 360 CAD geometry of the laboratory‑scale gantry crane"
    DTDFVocab:inputTo PhysicsGantrylibModule
]

instance KinematicAnalyticalModel : DTDFVocab:Model [
    base:desc "Kinematic analytical model used by the trajectory generator to calculate optimal movements"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance PhysicsBasedSimulationModel : DTDFVocab:Model [
    base:desc "Python‑based physics‑based simulation model that reproduces the crane’s motion"
    DTDFVocab:inputTo SimulationEnabler
]

// Enablers
instance TimescaleDBInstance : DTDFVocab:Enabler [
    base:desc "TimescaleDB database for continuous high‑frequency telemetry storage"
    DTDFVocab:enables ContinuousDataLoggingService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python module that performs optimal trajectory generation using the kinematic model"
    DTDFVocab:enables OptimalTrajectoryGenerationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python simulation module that executes real‑time simulation of crane motion"
    DTDFVocab:enables RealTimeSimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Validation module that compares executed motion against simulation outputs"
    DTDFVocab:enables ContinuousValidationService
]

instance MosquittoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for inter‑service messaging and control signal exchange"
    DTDFVocab:enables InterServiceMessagingService
]

instance GrafanaDashboardApp : DTDFVocab:Enabler [
    base:desc "Grafana instance for historical data visualization and alerting"
    DTDFVocab:enables HistoricalDataVisualizationService
]

instance DockerComposeEnvironment : DTDFVocab:Enabler [
    base:desc "Docker Compose network that hosts all twin services on a single host"
]

instance PhysicsGantrylibModule : DTDFVocab:Enabler [
    base:desc "Python 'gantrylib' module that provides low‑level API for sensor readouts and motor controls"
    DTDFVocab:enables ContinuousDataLoggingService
]

// Services
instance ContinuousDataLoggingService : DTDFVocab:Service [
    base:desc "Service that writes telemetry streams to TimescaleDB"
]

instance HistoricalDataVisualizationService : DTDFVocab:Service [
    base:desc "Dashboard service that presents trajectory plots and validation alerts via Grafana"
    DTDFVocab:provides TrajectoryPlotInsight, ValidationAlertInsight
]

instance OptimalTrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service that generates optimal trajectories using the kinematic analytical model"
    DTDFVocab:provides TriggerNewTrajectoryAction
]

instance RealTimeSimulationService : DTDFVocab:Service [
    base:desc "Service that runs real‑time simulation of the crane’s motion"
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously validates executed motion against simulation outputs, raising alerts"
    DTDFVocab:provides ValidationAlertInsight
]

instance InterServiceMessagingService : DTDFVocab:Service [
    base:desc "Service that manages MQTT message exchange between virtual services and the physical interface"
]

// Insights
instance TrajectoryPlotInsight : DTDFVocab:Insight [
    base:desc "Plot of planned versus actual trajectory displayed to operators in Grafana"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert triggered when deviation exceeds predefined thresholds during validation"
]

// Actions
instance AdjustSetpointsAction : DTDFVocab:Action [
    base:desc "Operator‑initiated action to modify trajectory or speed setpoints"
    DTDFVocab:IsAutomatic false
]

instance RecalibrateSensorAction : DTDFVocab:Action [
    base:desc "Action to recalibrate swing‑angle encoder or anemometer sensors"
    DTDFVocab:IsAutomatic false
]

instance TriggerNewTrajectoryAction : DTDFVocab:Action [
    base:desc "Action to trigger generation of a new trajectory based on updated setpoints"
    DTDFVocab:IsAutomatic false
]

// Environment and Components
instance PhysicalCraneEnvironment : DTDFVocab:Environment [
    base:contains AluminumFrameComponent, CartMotorControllerComponent, HoistMotorControllerComponent, SwingAngleEncoderComponent, AnemometerComponent, ArduinoMicrocontrollerComponent, PowerSupplyComponent
]

instance AluminumFrameComponent : DTDFVocab:Component [
    base:desc "Aluminum frame of the laboratory‑scale gantry crane"
]

instance CartMotorControllerComponent : DTDFVocab:Component [
    base:desc "Trinamic TMC4671E motor driver board for cart stepper motor"
]

instance HoistMotorControllerComponent : DTDFVocab:Component [
    base:desc "Trinamic TMC4671E motor driver board for hoist stepper motor"
]

instance SwingAngleEncoderComponent : DTDFVocab:Component [
    base:desc "Rotary optical encoder that measures swing angle of the crane"
]

instance AnemometerComponent : DTDFVocab:Component [
    base:desc "Sensor measuring wind speed above the crane"
]

instance ArduinoMicrocontrollerComponent : DTDFVocab:Component [
    base:desc "Arduino microcontroller that reads sensor signals for the Physical Crane Interface"
]

instance PowerSupplyComponent : DTDFVocab:Component [
    base:desc "Power supply unit that powers electronics of the crane"
]

// Acting Components
instance CartMotorActingComponent : DTDFVocab:ActingComponent [
    base:desc "Cart motor stepper driven via Trinamic TMC4671E controller, actuated by trajectory setpoints sent over MQTT"
]

instance HoistMotorActingComponent : DTDFVocab:ActingComponent [
    base:desc "Hoist motor stepper driven via Trinamic TMC4671E controller, actuated by trajectory setpoints sent over MQTT"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service outputs optimal discrete waypoints (position, velocity, acceleration) to the MQTT broker; the Control Application consumes these messages and sends corresponding PWM/duty‑cycle commands to the motor controllers. The Continuous Validation Service sends alert messages via MQTT to the HMI if the measured trajectory deviates beyond a predefined RMS threshold. The HMI can then re‑compute trajectories or adjust control parameters."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Services operate at distinct time‑scales: Logging is continuous (sub‑second sampling); Trajectory generation and simulation are invoked on demand (upon operator request); Continuous Validation runs continuously, comparing measurements and simulated trajectories in near‑real‑time (within the same cycle as telemetry). The PT and DT are synchronised over the MQTT broker in real time."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin runs on a single PC orchestrated by Docker Compose: the physical interface and control application run as Python processes; micro‑services (Database, MQTT, Dashboard, Trajectory, Simulation, Validation) are independent Docker containers linked via the internal Docker network; the HMI (Grafana front‑end) interfaces with the operators over HTTPS and visualises data from the Database; continuous communication between services is via MQTT topics; logging and storage are decoupled from control logic."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the full lifecycle: design (CAD kinematic model and CAD assemblies in Fusion 360), manufacturing (constructing the physical crane from BOM), and operation (run time monitoring, data logging, validation). The twin evolves through research iterations—continuous validation, fault‑classification, and future extensions to harbor/ship simulation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service compares the real trajectory timestamps and positions against the simulation, computing a distance metric (e.g., RMS error) and flagging deviations that exceed a predefined threshold. The validation uses time‑aligned data streams and statistically assessed error bounds. Fault‑classification research applies time‑series classification to detect anomalies. No formal formal verification is described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication occurs over a local TCP/IP network: MQTT broker (Eclipse Mosquitto) for publish/subscribe between services; HTTP/HTTPS for Grafana dashboards; direct serial (UART) from Arduino to the PC for sensor polling. The Logging Application writes to TimescaleDB via PostgreSQL protocol. All Docker containers share a bridge network on the host PC."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted on a personal computer; Docker Compose brings up services via Docker engine; repository and documentation hosted on GitHub; the module can be installed via pip. No cloud deployment is described. All services run locally, container‑ized; the database and broker are initialized automatically on first run."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not addressed in the documents."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not addressed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "No specific industrial or data standards (e.g., AutomationML, Asset Administration Shell, Eclipse Ditto) are employed in the described implementation. The system uses MQTT, TimescaleDB (PostgreSQL), and open‑source software, but does not claim adherence to a formal standard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Not addressed in the documents."
]