// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the crane bridge"
    DTDFVocab:producedData SwingAngleTelemetry
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer providing wind speed measurements affecting crane dynamics"
    DTDFVocab:producedData WindSpeedTelemetry
]

instance MotorControllerStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Component that reads status messages from the motor controller (position, current, error flags)"
    DTDFVocab:producedData MotorStatusTelemetry
]

// C4: Physical-to-virtual interaction (data transmitted)
instance SwingAngleTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorStatusTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerStatusSensor
]

// C10: Data
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurements stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleTelemetry
    DTDFVocab:inputTo TimescaleDBInstance, ValidationEngine
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed readings stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedTelemetry
    DTDFVocab:inputTo TimescaleDBInstance, ValidationEngine
]

instance MotorStatusTimeSeries : DTDFVocab:Data [
    base:desc "Time‑stamped motor controller status messages stored in TimescaleDB"
    DTDFVocab:fromData MotorStatusTelemetry
    DTDFVocab:inputTo TimescaleDBInstance, ValidationEngine
]

// C10: Models/Data
instance GantryCraneCADModel : DTDFVocab:Model [
    base:desc "Detailed 3D CAD geometry of the laboratory‑scale gantry crane"
    DTDFVocab:inputTo OptimalControlEngine, VisualizationEngine
]

instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model derived from the CAD geometry, capturing cart and hoist motion"
    DTDFVocab:inputTo OptimalControlEngine, ValidationEngine
]

// C11: Enablers
instance TimescaleDBInstance : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL) instance hosting high‑frequency temporal data"
    DTDFVocab:enables HistoricalLoggingService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker used for internal signaling between twin services"
    DTDFVocab:enables OptimalControlService, RealTimeVisualizationService
]

instance OptimalControlEngine : DTDFVocab:Enabler [
    base:desc "Computational engine that implements the optimal‑control algorithm based on the kinematic model"
    DTDFVocab:enables OptimalControlService
]

instance ValidationEngine : DTDFVocab:Enabler [
    base:desc "Engine that continuously validates measured states against predictions from the kinematic model"
    DTDFVocab:enables ContinuousValidationService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Rendering engine providing real‑time visualization of crane pose and payload location"
    DTDFVocab:enables RealTimeVisualizationService
]

instance StreamingInterface : DTDFVocab:Enabler [
    base:desc "Python program that streams controller data to the digital twin for feedback‑driven improvements"
    DTDFVocab:enables OperationalDataStreamingService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes optimal trajectory commands for the stepper motors based on the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight, AdjustActuatorCommand
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares sensed crane states to model predictions and flags deviations"
    DTDFVocab:provides ValidationDeviationInsight, TriggerAlertAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Persists time‑stamped sensor, actuator, and command data into TimescaleDB"
    DTDFVocab:provides HistoricalRecordInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Renders live crane pose, payload location, and performance metrics for operator dashboards"
    DTDFVocab:provides PoseVisualizationInsight
]

instance OperationalDataStreamingService : DTDFVocab:Service [
    base:desc "Streams operational data from the physical controller to the digital twin to enable feedback‑driven improvements"
    DTDFVocab:provides FeedbackImprovementAction
]

// C17: Insights
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Provides the computed optimal motion trajectory for cart and hoist"
]

instance ValidationDeviationInsight : DTDFVocab:Insight [
    base:desc "Indicates deviations between measured states and kinematic model predictions"
]

instance HistoricalRecordInsight : DTDFVocab:Insight [
    base:desc "Offers archived historical view of sensor and actuator data for analysis"
]

instance PoseVisualizationInsight : DTDFVocab:Insight [
    base:desc "Displays real‑time crane pose and payload trajectory on the operator dashboard"
]

// C17: Actions
instance AdjustActuatorCommand : DTDFVocab:Action [
    base:desc "Automatically sends corrected actuator commands to the physical controller"
    DTDFVocab:IsAutomatic true
]

instance TriggerAlertAction : DTDFVocab:Action [
    base:desc "Raises an alert when validation detects significant deviation"
    DTDFVocab:IsAutomatic false
]

instance FeedbackImprovementAction : DTDFVocab:Action [
    base:desc "Updates control parameters based on streamed operational feedback"
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance StepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart or hoist, receiving commands from the OptimalControlService"
]

instance CraneController : DTDFVocab:ActingComponent [
    base:desc "Programmable controller that executes actuator commands and provides status messages"
]

// C1: Environment and physical components
instance LaboratoryGantryCrane : DTDFVocab:Environment [
    base:contains MetalGantryStructure, MovableBridge, HoistMechanism, ProgrammableController
]

instance MetalGantryStructure : DTDFVocab:Component [
    base:desc "Rigid metal frame supporting the bridge and hoist"
]

instance MovableBridge : DTDFVocab:Component [
    base:desc "Bridge that translates horizontally along the gantry"
]

instance HoistMechanism : DTDFVocab:Component [
    base:desc "Mechanism that raises and lowers the payload via a rope or cable"
]

instance ProgrammableController : DTDFVocab:Component [
    base:desc "Controller hardware interfacing with sensors and actuators, exposing a TCP/UDP API"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal movement trajectories using a kinematics model. These trajectories are supplied to the Control Application, which uses the Physical Crane Interface to send command messages to the crane controllers. Commands are issued as Python calls through the interface to the hardware. Feedback on execution is captured by the Logging Application, enabling the Continuous Validation Service to compare expected versus actual trajectories. The documents do not detail authentication, validation, or explicit command‑execution confirmations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The exemplars adopt an ad‑hoc orchestration model rather than a commercial digital‑twin framework; they employ containerization and virtualization (e.g., virtual‑machine images for GreenhouseDT) to host services such as an InfluxDB time‑series database, an ActiveMQ message broker and Microsoft Azure cloud tools, and the architecture is visualised with the C4 model for the gantry crane."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by continuous validation: the twin computes a distance metric (e.g., Euclidean error) between the predicted state from the kinematic model and the actual measurements from the swing angle encoder and anemometer. If the metric exceeds a predefined threshold, a validation alarm is raised and the offending data point is flagged for correction. Uncertainty sources such as sensor noise and discretization errors are accounted for by maintaining confidence intervals in the TimescaleDB logs. Validation logs are periodically reviewed to verify that model predictions remain within acceptable error bounds, supporting quality assurance and enabling recalibration of the kinematic model when necessary."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital‑twin containers communicate primarily through an MQTT broker that provides publish/subscribe signaling over TCP/IP. The Logging Application writes crane state data to the TimescaleDB database, while the Grafana Dashboard reads from the same database. The components are modeled as containers in a C4 diagram, implying they run on a shared local network with standard IP connectivity. No specific bandwidth, latency, redundancy, or security protocols are mentioned in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital‑twin components (TimescaleDB, MQTT broker, Grafana Dashboard, Trajectory Generator, Simulation, and Continuous Validation services) are packaged as software containers according to the C4 model and executed on a single on‑premise host (a personal computer). The Python applications (Physical Crane Interface, Control Application, Logging Application, HMI) run alongside these containers on the same machine, providing an integrated on‑edge deployment without reliance on cloud infrastructure."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration relies on standard components: GreenhouseDT exchanges data through an ActiveMQ message broker and stores measurements in an InfluxDB database; the Air Quality Management exemplar connects a Raspberry‑Pi sensor node to an AutomationML‑based digital twin and uses Microsoft Azure tools for the twin pipeline; all exemplars use single‑board computers and container/VM technologies to interface with external sensors and cloud services."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplars adopt a largely ad‑hoc integration approach, avoiding commercial digital‑twin frameworks. However, the Air Quality Management twin follows the AutomationML standard for its model representation, enabling exchange of engineering data. Apart from AutomationML, no specific industry standards, certification requirements, or interoperability frameworks are referenced; the implementations rely on open‑source components such as InfluxDB, ActiveMQ, Docker, and Azure services without formal compliance claims."
]