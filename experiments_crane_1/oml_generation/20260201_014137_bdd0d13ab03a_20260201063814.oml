// C2: Acting Components
instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor that drives the crane hoist via the TMC4671‑Eval controller"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval motor controller interfacing the stepper motor"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring swing angle of the crane's load"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting crane dynamics"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing angle measurements from the encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind speed measurements from the anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C6: Services
instance LoggingApplicationService : DTDFVocab:Service [
    base:desc "Continuously streams crane state into TimescaleDB for historical analysis"
    DTDFVocab:provides LogDataAction
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes optimal swing‑free movement trajectories using the kinematic model"
    DTDFVocab:provides GenerateTrajectoryAction, OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Software simulation of the crane and its controllers to evaluate generated trajectories"
    DTDFVocab:provides SimulateTrajectoryAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories with simulated ones, computes deviation metrics, raises alerts"
    DTDFVocab:provides ValidateTrajectoryAction, DeviationMetricInsight, ThresholdAlertInsight
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualizing time‑series, confidence bounds and system status"
    DTDFVocab:provides ConfidenceBoundVisualizationInsight, AlertDisplayAction
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "MQTT broker for inter‑service communication and signalling"
    DTDFVocab:provides MessageRoutingAction
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the gantry crane used to compute swing‑free trajectories"
    DTDFVocab:inputTo TrajectoryEngineEnabler
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Behavioral simulation model of crane dynamics and motor controllers"
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance CADModel : DTDFVocab:Model [
    base:desc "Geometric CAD representation of the gantry crane structure"
    DTDFVocab:inputTo VisualizationEngineEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database storing sensor data and crane logs"
    DTDFVocab:enables LoggingApplicationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker mediating signalling between twin services"
    DTDFVocab:enables ContinuousValidationService, TrajectoryGeneratorService, SimulationService, DashboardService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker Compose orchestrates all containerised services"
    DTDFVocab:enables LoggingApplicationService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService, DashboardService, MQTTBrokerService
]

instance TrajectoryEngineEnabler : DTDFVocab:Enabler [
    base:desc "Engine that utilizes the kinematic model to generate trajectories"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Engine that runs the simulation model for trajectory evaluation"
    DTDFVocab:enables SimulationService
]

instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Engine that uses the CAD model for visualisation in Grafana"
    DTDFVocab:enables DashboardService
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Provides optimal motion‑plan parameters that eliminate residual swing"
]

instance DeviationMetricInsight : DTDFVocab:Insight [
    base:desc "Provides deviation metrics between executed and simulated trajectories"
]

instance ThresholdAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when deviation metric exceeds a predefined threshold"
]

instance ConfidenceBoundVisualizationInsight : DTDFVocab:Insight [
    base:desc "Displays confidence bounds (blue/yellow bands) on trajectory plots"
]

instance GenerateTrajectoryAction : DTDFVocab:Action [
    base:desc "Generates swing‑free trajectory using the kinematic model"
    DTDFVocab:IsAutomatic true
]

instance SimulateTrajectoryAction : DTDFVocab:Action [
    base:desc "Simulates generated trajectory on the crane model"
    DTDFVocab:IsAutomatic true
]

instance ValidateTrajectoryAction : DTDFVocab:Action [
    base:desc "Calculates distance metric between measured and simulated trajectories"
    DTDFVocab:IsAutomatic true
]

instance LogDataAction : DTDFVocab:Action [
    base:desc "Writes time‑stamped crane state to TimescaleDB"
    DTDFVocab:IsAutomatic true
]

instance AlertDisplayAction : DTDFVocab:Action [
    base:desc "Displays threshold alerts on Grafana dashboard and HMI"
    DTDFVocab:IsAutomatic false
]

instance MessageRoutingAction : DTDFVocab:Action [
    base:desc "Routes messages between services via MQTT"
    DTDFVocab:IsAutomatic true
]

// C6: Physical Components & Environment
instance PhysicalGantrysCrane : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane that moves small pucks representing containers"
]

instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Python program that talks to the crane's motor controller and Arduino for sensor data"
]

instance ControlApplication : DTDFVocab:Component [
    base:desc "Python application that commands crane motions using the generated trajectories"
]

instance HumanMachineInterface : DTDFVocab:Component [
    base:desc "Python front‑end allowing operators to manually control the crane and view alerts"
]

instance CraneLabEnvironment : DTDFVocab:Environment [
    base:contains PhysicalGantrysCrane, HoistStepperMotor, HoistMotorController,
               PhysicalCraneInterface, ControlApplication, HumanMachineInterface,
               SwingAngleEncoder, Anemometer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (a Python service) sends actuator commands to the Physical Crane Interface, which forwards them to the crane’s motor controllers (cart motor controller and hoist motor controller) and to the electromagnet. Commands originate from the Human Machine Interface or from higher‑level services such as the Trajectory Generator Service. The command format and transport details are implemented as Python API calls; the documents do not describe any specific command message schema, validation, authentication, conflict‑resolution, or explicit acknowledgement mechanisms from the physical hardware."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin follows a micro‑service architecture orchestrated with Docker Compose. Python applications implement the Control Application, Logging Application, and HMI; services (Trajectory Generator, Simulation, Continuous Validation) communicate through an MQTT broker. Persistent data is stored in a TimescaleDB database and visualised with a Grafana dashboard. The overall system is modelled with the C4 approach, and containers are launched together with a single Docker‑compose command, providing resource isolation and network management."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The gantry‑crane digital twin follows a linear life‑cycle that starts with a physical‑system design (hardware crane, hoist motor controller TMC4671‑Eval and stepper motor) and a digital representation (CAD geometry and a kinematic model). In the development phase the digital artefacts are encoded as Python services (Control Application, Logging Application, Trajectory Generator, Simulation, Continuous Validation) and packaged as Docker containers together with a TimescaleDB, Grafana and an MQTT broker. Deployment is performed with a single Docker‑Compose command, after which the twin operates in the runtime phase: sensor data flow from the crane to the database, the services consume the data (simulation, validation) and produce outputs (optimal trajectories, alerts). The twin can be evolved by adding new services or updating models, as illustrated by the use of the DarTwin notation for system evolution. Governance aspects such as change‑management policies are not described in the documents."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by a Continuous Validation Service that continuously compares real‑world measurements of executed trajectories (obtained from the Logging Application) with the corresponding simulated trajectories produced by the Simulation Service. The service calculates distance metrics, evaluates them against an acceptable threshold, and triggers operator alerts via the Grafana dashboard when the threshold is breached. This validation loop provides verification of the kinematic and simulation models and supports error detection. The approach has been employed in research on continuous validation, fault detection and digital‑twin evolution."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital‑twin components run on a single personal computer. The TimescaleDB database, MQTT broker (Eclipse Mosquitto) and Grafana dashboard are containerised with Docker and communicate over the host’s localhost network using standard TCP/IP. MQTT is used for inter‑service signalling, while TimescaleDB uses the PostgreSQL protocol for data ingestion. The architecture does not describe a multi‑host network topology, bandwidth or latency requirements, redundancy schemes, or security protocols (e.g., TLS, authentication) for the network communication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The exemplar is deployed on‑premise on a personal computer. Deployment is performed via a Docker‑compose file that starts the TimescaleDB, MQTT broker and Grafana containers and performs first‑time initialization of the database and dashboard. Python services (Control Application, Logging Application, etc.) are installed from the gantrylib package using pip and run directly on the host. Storage is provided by the TimescaleDB time‑series database; computational resources are those of a typical desktop PC. The documents do not discuss cloud or edge hosting, scalability mechanisms, or formal availability/reliability guarantees beyond the Docker‑compose startup process."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Inter‑service integration relies on the MQTT protocol for messaging and on standard SQL access to TimescaleDB. Visualization uses Grafana, which pulls data via its native datasource connectors. No integration with external enterprise systems or other digital twins is described in the documents."
]