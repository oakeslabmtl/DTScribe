// C3: Physical sensing components
instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor mounted on the gantry crane carriage, measuring linear displacement."
    DTDFVocab:producedData PositionTelemetry
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Velocity sensor measuring the carriage's speed along the rail."
    DTDFVocab:producedData VelocityTelemetry
]

instance ActuatorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring the status of the crane's rotary joints and actuator motors."
    DTDFVocab:producedData ActuatorStatusTelemetry
]

// C4: Physical-to-virtual interaction
instance PositionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

instance VelocityTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySensor
]

instance ActuatorStatusTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ActuatorStatusSensor
]

// C10: Models/Data
instance PositionData : DTDFVocab:Data [
    base:desc "Raw position telemetry data captured from PositionSensor."
    DTDFVocab:fromData PositionTelemetry
    DTDFVocab:inputTo LoggingApplicationEnabler, ActiveMQEnabler, InfluxDBEnabler
]

instance VelocityData : DTDFVocab:Data [
    base:desc "Raw velocity telemetry data captured from VelocitySensor."
    DTDFVocab:fromData VelocityTelemetry
    DTDFVocab:inputTo LoggingApplicationEnabler, ActiveMQEnabler, InfluxDBEnabler
]

instance ActuatorStatusData : DTDFVocab:Data [
    base:desc "Raw actuator status telemetry data captured from ActuatorStatusSensor."
    DTDFVocab:fromData ActuatorStatusTelemetry
    DTDFVocab:inputTo LoggingApplicationEnabler, ActiveMQEnabler, InfluxDBEnabler
]

// **Enablers**
instance LoggingApplicationEnabler : DTDFVocab:Enabler [
    base:desc "Python program that logs telemetry into a TimescaleDB database."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance ActiveMQEnabler : DTDFVocab:Enabler [
    base:desc "ActiveMQ message broker relaying telemetry between the physical plant and virtual twin."
    DTDFVocab:enables DataTransportService
]

instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database storing sensor and actuator data."
    DTDFVocab:enables InfluxDBService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Docker container running the kinematic simulation model of the gantry crane."
    DTDFVocab:enables SimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation service that samples sensor data from InfluxDB and compares it against the simulation model."
    DTDFVocab:enables ContinuousValidationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard rendering real‑time sensor streams alongside simulation outputs."
    DTDFVocab:enables VisualizationService
]

instance ControlEnabler : DTDFVocab:Enabler [
    base:desc "Virtual controller testing environment enabling model‑based optimal control before physical deployment."
    DTDFVocab:enables OptimalControlService
]

// **Services**
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service for historical logging of all sensor data, enabling post‑hoc analysis."
    DTDFVocab:provides HistoricalDataInsight
]

instance DataTransportService : DTDFVocab:Service [
    base:desc "Service that transports telemetry between the physical crane and twin via ActiveMQ."
    DTDFVocab:provides TransportStatusInsight
]

instance InfluxDBService : DTDFVocab:Service [
    base:desc "Service that exposes data stored in InfluxDB for downstream consumption."
    DTDFVocab:provides InfluxDataInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service running the kinematic simulation of the gantry crane, generating simulated state trajectories."
    DTDFVocab:provides SimulationOutputInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that compares real‑time sensor data to simulated outputs, detecting drift or faults."
    DTDFVocab:provides ValidationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that renders interactive 3D visualizations of measured and simulated trajectories."
    DTDFVocab:provides VisualizationInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service that allows controller tuning and optimal control in the virtual environment."
    DTDFVocab:provides ControlInsight
]

// **Insights**
instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Access to logged sensor data for post‑hoc analysis."
]

instance TransportStatusInsight : DTDFVocab:Insight [
    base:desc "Monitors health and availability of telemetry transport via ActiveMQ."
]

instance InfluxDataInsight : DTDFVocab:Insight [
    base:desc "Exposes time‑series data stored in InfluxDB."
]

instance SimulationOutputInsight : DTDFVocab:Insight [
    base:desc "Provides simulated state trajectories for the gantry crane."
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Evaluates Euclidean distance between observed and simulated states, triggering alerts on drift."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Displays synchronized sensor and simulation data with confidence bounds."
]

instance ControlInsight : DTDFVocab:Insight [
    base:desc "Represents the effectiveness of controller tuning in the simulation."
]

// **Actions**
instance AlertAction : DTDFVocab:Action [
    base:desc "Automated alert sent to the operator via Grafana when validation metrics exceed thresholds."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control Application is a Python script that sends movement commands (e.g., target positions, speed limits) to the Physical Crane Interface, which translates them into controller‑specific instructions. The command type is not formally described, and the document provides no detail on message formatting, authentication, validation, conflict resolution, or feedback confirmation from the physical crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "All components of the gantry crane digital twin are orchestrated within a Docker‑based C4 architecture. The system comprises a TimescaleDB container for timestamped data storage, an Eclipse Mosquitto MQTT broker container for publish/subscribe telemetry exchange, and several functional containers (e.g., control, simulation, dashboard). Communication between the physical crane and the twin occurs through MQTT topics with QoS 1, and the database is queried via SQL over a REST API. Management of container lifecycle and resource allocation is handled by Docker Compose, enabling isolated but interconnected services on a single container host."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin services communicate over MQTT, with an MQTT broker facilitating signaling between the Trajectory Generator Service, Simulation Service, Continuous Validation Service, and Dashboard. The protocol used is MQTT; however, specific network topology, bandwidth or latency requirements, redundancy, reliability guarantees, or security mechanisms (e.g., TLS, authentication) are not detailed."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin components (Database, Dashboard, Trajectory Generator, Simulation Service, Continuous Validation Service, MQTT Broker) appear to be deployed on local infrastructure, likely on‑premise or local network, to support the lab‑scale gantry crane system. The document does not specify cloud or edge hosting, computational or storage quotas, scalability options, deployment models, or availability/reliability measures."
]