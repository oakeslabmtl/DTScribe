// Sensing Components
instance JointEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Rotary encoder on gantry crane joints measuring joint angles"
    DTDFVocab:producedData CraneTelemetryPythonObject
]

instance PayloadPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor capturing payload X,Y,Z coordinates relative to crane base"
    DTDFVocab:producedData CraneTelemetryPythonObject
]

instance ActuatorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motorized linear actuator currents"
    DTDFVocab:producedData CraneTelemetryPythonObject
]

// Data Transmitted
instance CraneTelemetryPythonObject : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointEncoderSensor, PayloadPositionSensor, ActuatorCurrentSensor
]

// Data Stored
instance TimescaleTelemetryData : DTDFVocab:Data [
    base:desc "Time‑series telemetry data stored in TimescaleDB for high‑frequency historical analysis"
    DTDFVocab:fromData CraneTelemetryPythonObject
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance PostgresTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data persisted in PostgreSQL for retrospective analysis as per Historical Data Logger service"
    DTDFVocab:fromData CraneTelemetryPythonObject
    DTDFVocab:inputTo PostgresEnabler
]

instance MQTTStreamingData : DTDFVocab:Data [
    base:desc "Real‑time MQTT telemetry stream consumed by the Python processing module"
    DTDFVocab:fromData CraneTelemetryPythonObject
    DTDFVocab:inputTo MQTTBrokerEnabler
]

// Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database container handling time‑series telemetry storage"
    DTDFVocab:enables HistoricalTelemetryLoggingService
]

instance PostgresEnabler : DTDFVocab:Enabler [
    base:desc "PostgreSQL database container for historical telemetry logging service"
    DTDFVocab:enables HistoricalDataLoggerService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker relaying real‑time telemetry from Python processing"
    DTDFVocab:enables RealTimeMonitoringService, FaultDetectionService
]

instance PythonProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Python module using NumPy, Pandas, and Matplotlib to process MQTT streams and compute control profiles"
    DTDFVocab:enables OptimalControlService, ContinuousValidationService, FaultDetectionService, OptimalTrajectoryGeneratorService, CADVisualizationService
]

instance CADViewerEnabler : DTDFVocab:Enabler [
    base:desc "Custom 3D CAD viewer integrated into Grafana for live kinematic visualization"
    DTDFVocab:enables CADVisualizationService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring dashboard of joint states, payload coordinates, and actuator currents via web‑based dashboard and APIs"
    DTDFVocab:provides TrajectoryAccuracyInsight, DataQualityInsight, AlertOperatorsAction
]

instance CADVisualizationService : DTDFVocab:Service [
    base:desc "Visualizes the full kinematic model in a 3D CAD viewer for operator interaction"
    DTDFVocab:provides CollisionFreePathInsight, DataQualityInsight
]

instance HistoricalTelemetryLoggingService : DTDFVocab:Service [
    base:desc "Accumulates high‑frequency historical log of sensor telemetry for post‑hoc analysis, stored in TimescaleDB"
    DTDFVocab:provides DataQualityInsight
]

instance HistoricalDataLoggerService : DTDFVocab:Service [
    base:desc "Persists all telemetry in PostgreSQL for retrospective analysis"
    DTDFVocab:provides DataQualityInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Executes optimal control algorithm that computes velocity and acceleration profiles to improve trajectory tracking"
    DTDFVocab:provides TrajectoryAccuracyInsight, AdjustControlAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continually validates the digital model by comparing live telemetry against predicted states"
    DTDFVocab:provides FaultDetectionInsight, DataQualityInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Runs fault‑detection routine that flags anomalies such as unexpected encoder deviation or actuator wear"
    DTDFVocab:provides FaultDetectionInsight, AlertOperatorsAction
]

instance OptimalTrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes collision‑free, minimal‑time paths for payload movement"
    DTDFVocab:provides CollisionFreePathInsight
]

// Insights
instance TrajectoryAccuracyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the deviation between the actual and predicted trajectory positions"
]

instance CollisionFreePathInsight : DTDFVocab:Insight [
    base:desc "Insight confirming that the calculated path is collision‑free"
]

instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Insight indicating consistency and integrity of sensor data streams"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight highlighting detected faults such as unexpected encoder deviations or actuator wear"
]

// Actions
instance AlertOperatorsAction : DTDFVocab:Action [
    base:desc "Automatically alerts operators when sensor deviation exceeds predefined thresholds via Grafana dashboards"
    DTDFVocab:IsAutomatic true
]

instance AdjustControlAction : DTDFVocab:Action [
    base:desc "Automatically adjusts velocity and acceleration profiles based on optimal control calculations"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the Control Application and sent to the physical crane through the Physical Crane Interface. The commands are handled as Python messages over the same local communication channel used to communicate with the crane controllers. The document does not describe command message formats, validation or authentication mechanisms, feedback systems, conflict resolution, or execution confirmation processes."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is deployed on virtual machines provided as GitHub images. It follows a containerised micro‑service pattern (C4 model) with separate services for data ingestion (InfluxDB), message streaming (ActiveMQ/MQTT), and state visualization (frontend dashboard). The twin logic container subscribes to broker topics, updates the database, and exposes status for the dashboard. Deployment scripts and configuration are maintained in the repository, allowing seamless setup of the entire stack."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital twin services communicate through an MQTT broker, which handles signaling between the Trajectory Generator Service, Simulation Service, Continuous Validation Service, and the Grafana dashboard. The broker implements the MQTT protocol and operates on a local network or LAN. No further details on network topology, bandwidth, latency, reliability, redundancy, or security protocols are given."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin runs entirely on a personal computer that is physically linked to the crane controllers via a local serial or CAN interface. All key software components – TimescaleDB (database), MQTT Broker, Grafana Dashboard, and the control and logging services – are packaged as Docker containers and instantiated from that host. Computational requirements are modest (standard CPU, 4 GB RAM for example) as indicated by typical desktop deployment; storage requires sufficient capacity for time‑series logging (e.g., several hundred MB per day). The deployment model is a single‑node edge deployment with Docker container orchestration; scalability is limited to the host’s resources, but containers facilitate horizontal scaling if future hardware is provisioned. Availability is driven by the host OS uptime and Docker container health checks, with no explicit high‑availability or redundant infrastructure described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Physical sensors on a Raspberry‑Pi publish telemetry to the message broker (ActiveMQ/MQTT). The Digital Twin consumes these messages, stores data in InfluxDB, and visualises state via the dashboard. In the Air Quality exemplar, MQTT messages are forwarded to Microsoft Azure IoT Hub, where data is persisted in Azure storage and the AutomationML twin model is retrieved from Azure Blob Storage. Interaction with other enterprise systems is limited to these broker and cloud ingestion mechanisms; no external REST APIs were described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplar follows the AutomationML standard for twin description, enabling model interchange between the physical Raspberry‑Pi sensor network and the Azure‑based simulation and prediction services. The twin model adheres to AutomationML v2.x syntax and incorporates IEC 61360 semantic annotations for indoor air parameters. No additional commercial twin framework, certification, or interoperability standard is referenced in the material."
]