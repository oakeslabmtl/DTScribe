// Acting Component
instance PythonControlApplication : DTDFVocab:ActingComponent [
    base:desc "Python Control Application orchestrates the twin by publishing desired cart and hoist positions, speeds and torques via MQTT to the Physical Crane Interface, and triggers homing and zeroing actions through queued control messages."
]

// Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder mounted on the hoist measures the crane's swing angle."
    DTDFVocab:producedData SwingAngleData
]
instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer mounted on the platform measures wind speed affecting the crane."
    DTDFVocab:producedData WindSpeedData
]
instance CartPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the cart measures horizontal cart position."
    DTDFVocab:producedData CartPositionData
]
instance HoistPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the hoist measures vertical hoist position."
    DTDFVocab:producedData HoistPositionData
]

// Data Transmitted
instance SwingAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance WindSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]
instance CartPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartPositionEncoder
]
instance HoistPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistPositionEncoder
]

// Data
instance SwingAngleTelemetry : DTDFVocab:Data [
    base:desc "Time‑stamped telemetry of the swing angle recorded by the hoist encoder."
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData SwingAngleData
]
instance WindSpeedTelemetry : DTDFVocab:Data [
    base:desc "Time‑stamped wind speed data captured by the platform anemometer."
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData WindSpeedData
]
instance CartPositionTelemetry : DTDFVocab:Data [
    base:desc "Time‑stamped carousel position telemetry from the cart encoder."
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData CartPositionData
]
instance HoistPositionTelemetry : DTDFVocab:Data [
    base:desc "Time‑stamped vertical hoist position telemetry from the hoist encoder."
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData HoistPositionData
]

// Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance within Docker Compose used to store all telemetry, trajectory plans, simulation results and diagnostics."
    DTDFVocab:enables LoggingService, ContinuousValidationService
]
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker managed by Docker Compose, enabling real‑time command and telemetry exchange."
    DTDFVocab:enables ControlCommandService, TrajectoryGeneratorService
]
instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime container executing the Trajectory Generator Service."
    DTDFVocab:enables TrajectoryGeneratorService
]
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Containerized simulation engine executing kinematic models for trajectory reproduction."
    DTDFVocab:enables SimulationService
]
instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Data analytics engine comparing logged telemetry with simulation outputs for deviation detection."
    DTDFVocab:enables ContinuousValidationService
]
instance LoggingEnabler : DTDFVocab:Enabler [
    base:desc "Data ingestion pipeline writing all telemetry into TimescaleDB."
    DTDFVocab:enables LoggingService
]
instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana Docker instance rendering live dashboards from TimescaleDB."
    DTDFVocab:enables VisualizationService
]

// Services
instance ControlCommandService : DTDFVocab:Service [
    base:desc "Service that consumes trajectory commands from the twin and publishes them to the physical crane via MQTT."
    DTDFVocab:provides PublishDesiredPositionAction
]
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Trajectory Generator Service computes swing‑free optimal motion paths for the gantry crane."
    DTDFVocab:provides ForecastedTrajectoryInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation Service reproduces the crane's kinematic behaviour for arbitrary trajectories."
    DTDFVocab:provides SimulationResultInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous Validation Service monitors execution fidelity against simulation and flags deviations."
    DTDFVocab:provides DeviationAlertInsight, FaultClassificationInsight
]
instance LoggingService : DTDFVocab:Service [
    base:desc "Logging Service records time‑stamped telemetry from sensors into TimescaleDB."
    DTDFVocab:provides DataLoggingInsight
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualization Service via Grafana dashboards presenting real‑time and predicted trajectories with confidence bounds."
    DTDFVocab:provides DashboardSnapshotInsight
]

// Insights
instance ForecastedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Forecasted trajectories with confidence bounds for upcoming movements."
]
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulated position, velocity, and swing‑angle profiles for a given trajectory."
]
instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alerts when real‑time telemetry deviates from simulated trajectory beyond tolerance."
]
instance FaultClassificationInsight : DTDFVocab:Insight [
    base:desc "Fault‑classification predictions using time‑series models to detect anomalies in motor and encoder behaviour."
]
instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Recorded telemetry data archive for post‑hoc analysis and validation."
]
instance DashboardSnapshotInsight : DTDFVocab:Insight [
    base:desc "Live and historical Grafana dashboards showing system health, trajectory performance, and fault alerts."
]

// Actions
instance PublishDesiredPositionAction : DTDFVocab:Action [
    base:desc "Operator or twin‑generated command to set desired cart and hoist positions, speeds and torques."
    DTDFVocab:IsAutomatic true
]

// Models
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane derived from Autodesk Fusion 360."
    DTDFVocab:inputTo TrajectoryPlanDatabaseEnabler
]
instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator to compute optimal motion paths."
    DTDFVocab:inputTo TrajectoryPlanDatabaseEnabler
]
instance SimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model reproducing crane kinematics for arbitrary trajectories."
    DTDFVocab:inputTo TrajectoryPlanDatabaseEnabler
]
instance TrajectoryPlanDatabaseModel : DTDFVocab:Model [
    base:desc "Database of trajectory plans stored for reuse and analysis."
    DTDFVocab:inputTo TrajectoryPlanDatabaseEnabler
]

// Trajectory Plan Database Enabler
instance TrajectoryPlanDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB schema holding trajectory plans and associated trajectory data."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The twin generates optimal trajectories via the Trajectory Generator Service, publishes them to the MQTT broker, and the Physical Crane Interface consumes them, converting them into servo motor commands for the TMC4671‑Eval controllers. The Continuous Validation Service compares the executed motion to a simulated reference and publishes alerts to the Grafana dashboard when deviation thresholds are exceeded. All command and state updates flow through the same MQTT broker."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Services operate in continuous real‑time; sensor data are sampled and logged at every motion step (~10–20 ms per wheel update), while trajectory computations and validation checks run per commanded trajectory (typically 1–5 s). Exact rates are derived from the motor controller loop frequencies but are not explicitly specified in the documentation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin architecture is structured in C4 containers: Database, MQTT broker, Dashboard on the physical side; on the digital side, Logic containers (Control Application, Logging Application, Trajectory Generator Service, Simulation Service, Continuous Validation Service). All are connected via MQTT messaging, the database stores telemetry, and the dashboard exposes real‑time visualization. The Physical Crane Interface acts as bridge between hardware and software."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin models and services cover all lifecycle phases: (a) Designed – CAD models (Autodesk Fusion 360) and kinematic models used during design; (b) Manufactured – Simulation models and control firmware deployed on the physical hardware; (c) Operated – Continuous logging, real‑time control, validation, and visualization during day‑to‑day operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation is performed by the Continuous Validation Service, which executes the same trajectory in simulation and measures Euclidean distance between simulated and actual trajectory positions; if the distance exceeds user‑defined thresholds, the system flags a fault. The approach relies on accurate kinematic modelling and synchronous sampling. Uncertainty sources include sensor noise from encoders and anemometer, motor latency, and actuator compliance. The lack of a dedicated physical simulator limits fidelity during development."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT occurs over a local Ethernet network using MQTT (port 1883) for command and telemetry messages, and PostgreSQL/TimescaleDB (port 5432) for database storage. MQTT topics are used for trajectory commands, sensor telemetry, and validation alerts. The Physical Crane Interface and all services run on the same host PC, leveraging local TCP/IP."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin is deployed on a personal computer that also hosts the physical crane. All services are containerized with Docker; Docker Compose brings up TimescaleDB, Mosquitto, Grafana, and the twin application containers with a single command. The host therefore runs both robotic hardware and the digital twin pipeline in a unified environment."
]