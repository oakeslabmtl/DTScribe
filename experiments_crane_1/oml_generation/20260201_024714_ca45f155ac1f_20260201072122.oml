// C3: Physical sensing components
instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the linear position of the lab‑scale gantry crane along its rails"
    DTDFVocab:producedData CraneStateTelemetry
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the velocity of the gantry crane carriage"
    DTDFVocab:producedData CraneStateTelemetry
]

// C4: Physical-to-virtual interaction
instance CraneStateTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor, VelocitySensor
]

// C10: Data
instance CraneStateData : DTDFVocab:Data [
    base:desc "Timestamped position and velocity measurements of the gantry crane"
    DTDFVocab:fromData CraneStateTelemetry
    DTDFVocab:inputTo TimescaleDBEnabler, VisualizationEnabler
]

instance HistoricalTrajectoryData : DTDFVocab:Data [
    base:desc "Persisted trajectory logs stored for post‑analysis"
    DTDFVocab:fromData CraneStateTelemetry
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance ValidationResultData : DTDFVocab:Data [
    base:desc "Result of comparing simulated trajectories from the kinematic model with actual measurements"
    DTDFVocab:fromData CraneStateTelemetry
    DTDFVocab:inputTo VisualizationEnabler
]

// C10: Models/Data
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "Detailed CAD geometry of the lab‑scale gantry crane created in Autodesk Fusion360"
    DTDFVocab:inputTo VisualizationEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Mathematical kinematic model of the gantry crane used for control and validation"
    DTDFVocab:inputTo ControlEnabler, ValidationEnabler
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker container that routes telemetry between components"
    DTDFVocab:enables MonitoringService, ContinuousValidationService, OptimalControlService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL) Docker container for time‑series storage of crane state"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana Docker container that visualizes real‑time and historical crane data"
    DTDFVocab:enables DataVisualizationService
]

instance ControlEnabler : DTDFVocab:Enabler [
    base:desc "Python service container that runs optimal control algorithms and issues commands"
    DTDFVocab:enables OptimalControlService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Python service container that performs continuous validation of the kinematic model"
    DTDFVocab:enables ContinuousValidationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Python monitoring script that reports real‑time status over MQTT"
    DTDFVocab:enables MonitoringService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes and sends control commands to the gantry crane controller to improve motion efficiency"
    DTDFVocab:provides ComputeControlAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Persistently stores sensor and actuator data for later analysis"
    DTDFVocab:provides HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Displays real‑time graphical views of crane state, trajectories, and logged data"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Automatically compares simulated trajectories from the kinematic model with measured data"
    DTDFVocab:provides ValidateKinematicAction
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time status monitoring of the physical gantry crane"
    DTDFVocab:provides RealTimeStatusInsight
]

// C17: Actions / Insights
instance ComputeControlAction : DTDFVocab:Action [
    base:desc "Algorithm that calculates optimal control signals and dispatches them to the Arduino controller"
    DTDFVocab:IsAutomatic true
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Availability of complete historical trajectory data for post‑analysis"
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live graphical dashboards showing position, velocity, and trajectory of the crane"
]

instance ValidateKinematicAction : DTDFVocab:Action [
    base:desc "Executes validation routine that flags deviations between model predictions and actual measurements"
    DTDFVocab:IsAutomatic true
]

instance RealTimeStatusInsight : DTDFVocab:Insight [
    base:desc "Current operational status of the gantry crane (e.g., active, idle, fault)"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (a Python program) issues movement commands to the Physical Crane through the Physical Crane Interface, which directly connects to the crane controllers. Trajectories generated by the Trajectory Generator Service are sent to the Control Application for execution. The system relies on the Python‑based interface for command transmission; no explicit authentication or confirmation mechanisms are described."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system architecture is described using the C4 Model, with context and container diagrams illustrating the digital twin, but the document does not provide details on orchestration patterns, component integration, or resource management."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The exemplar includes a continuous validation service that monitors and verifies the twin’s models during operation, ensuring model validity over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Service components communicate over a local MQTT broker using the MQTT protocol for signaling between the Trajectory Generator, Simulation, Continuous Validation, and other services. All containers (database, dashboard, services) are co‑located, implying a simple network topology without explicit bandwidth, latency, redundancy, or security specifications in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire system—including the Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface, and the six digital‑twin containers (TimescaleDB, Grafana, Trajectory Generator, Simulation, Continuous Validation, MQTT broker)—is deployed on a single computer. The digital‑twin components are containerized, while the Python modules run directly on the host. The documentation does not mention cloud or edge platforms, nor does it specify scalability or high‑availability mechanisms; the host provides the required compute, memory, and storage resources."
]