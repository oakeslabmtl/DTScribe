// C2: Acting Components
instance CartStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor driven through Trinamic TMC4671‑Eval controller"
]

instance HoistStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor driven through Trinamic TMC4671‑Eval controller"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist end for payload gripping"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorControllerFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Motor controller feedback (position/velocity) accessed via Arduino"
    DTDFVocab:producedData MotorStateDataTransmitted
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerFeedbackSensor
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Swing angle measurements of hoist"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Wind speed measurements from anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance MotorStateData : DTDFVocab:Data [
    base:desc "Position and velocity feedback from motor controllers"
    DTDFVocab:fromData MotorStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance for time‑series storage"
    DTDFVocab:enables DataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for message exchange"
    DTDFVocab:enables HumanMachineInterfaceService, ContinuousValidationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana instance for visualization dashboards"
    DTDFVocab:enables GrafanaDashboardService
]

instance TrajectoryEngineEnabler : DTDFVocab:Enabler [
    base:desc "Runtime environment for trajectory generation using kinematic model"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine executing dynamic crane model"
    DTDFVocab:enables SimulationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Validation engine comparing measured and simulated trajectories"
    DTDFVocab:enables ContinuousValidationService
]

// C10: Models/Data
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry (Fusion 360) of the lab‑scale gantry crane"
    DTDFVocab:inputTo GrafanaEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used to compute swing‑free trajectories"
    DTDFVocab:inputTo TrajectoryEngineEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of crane mechanics and controllers"
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance ValidationModel : DTDFVocab:Model [
    base:desc "Model for continuous validation comparing measurements with simulation"
    DTDFVocab:inputTo ValidationEngineEnabler
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Data Logging Service storing time‑series state in TimescaleDB"
    DTDFVocab:provides HistoricalDataAvailabilityInsight, DataExportAction
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana Dashboard Service for real‑time visualization"
    DTDFVocab:provides RealTimeVisualizationInsight, DashboardRefreshAction
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Trajectory Generator Service computing swing‑free paths using kinematic model"
    DTDFVocab:provides SwingFreeTrajectoryInsight, ExecuteTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation Service emulating crane dynamics and controllers"
    DTDFVocab:provides SimulatedDynamicsInsight, RunSimulationAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous Validation Service comparing measured trajectories with simulated ones and raising alerts"
    DTDFVocab:provides ModelMeasurementDiscrepancyInsight, TriggerOperatorInterventionAction
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Human‑Machine Interface allowing operator control via MQTT"
    DTDFVocab:provides OperatorControlInsight, OperatorCommandAction
]

// C17: Insights / Actions
instance HistoricalDataAvailabilityInsight : DTDFVocab:Insight [
    base:desc "Historical sensor and actuator data are stored and queryable"
]

instance DataExportAction : DTDFVocab:Action [
    base:desc "Export logged data for offline analysis"
    DTDFVocab:IsAutomatic false
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Operators can view real‑time crane state dashboards"
]

instance DashboardRefreshAction : DTDFVocab:Action [
    base:desc "Automatically refresh dashboard visualizations"
    DTDFVocab:IsAutomatic true
]

instance SwingFreeTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal swing‑free trajectory computed for given load and destination"
]

instance ExecuteTrajectoryAction : DTDFVocab:Action [
    base:desc "Command crane to follow the planned trajectory"
    DTDFVocab:IsAutomatic true
]

instance SimulatedDynamicsInsight : DTDFVocab:Insight [
    base:desc "Simulation provides predicted crane dynamics and controller responses"
]

instance RunSimulationAction : DTDFVocab:Action [
    base:desc "Run virtual simulation of the planned motion"
    DTDFVocab:IsAutomatic true
]

instance ModelMeasurementDiscrepancyInsight : DTDFVocab:Insight [
    base:desc "Alert when measured vs simulated trajectories exceed tolerance thresholds"
]

instance TriggerOperatorInterventionAction : DTDFVocab:Action [
    base:desc "Notify operator to intervene and correct operation"
    DTDFVocab:IsAutomatic false
]

instance OperatorControlInsight : DTDFVocab:Insight [
    base:desc "Operator can manually control crane via the HMI"
]

instance OperatorCommandAction : DTDFVocab:Action [
    base:desc "Send operator command to physical crane"
    DTDFVocab:IsAutomatic false
]

// Additional Physical Components
instance MetalFrameComponent : DTDFVocab:Component [
    base:desc "Metal frame of the lab‑scale gantry crane"
]

instance PowerSupplyUnitComponent : DTDFVocab:Component [
    base:desc "Power supply unit providing voltage to motors and electronics"
]

instance ArduinoControlBoardComponent : DTDFVocab:Component [
    base:desc "Arduino‑based measurement & control board interfacing sensors and actuators"
]

// Environment
instance LaboratoryGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains MetalFrameComponent, PowerSupplyUnitComponent, ArduinoControlBoardComponent,
                CartStepperMotorActuator, HoistStepperMotorActuator, ElectromagnetActuator,
                SwingAngleEncoder, AnemometerSensor, MotorControllerFeedbackSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service publishes optimal motion set‑points via MQTT; the Control Application subscribes to these messages and, through the Physical Crane Interface, sends command values to the motor controllers and electromagnet, thereby moving the crane in real time."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall constellation comprises the physical crane with its controllers and sensors, a Python interface layer, a Control Application, a Logging Application, an HMI, and on the virtual side the MQTT broker, TimescaleDB, Grafana dashboard, Trajectory Generator, Simulation Service, and Continuous Validation Service, all interconnected via MQTT messages and database queries."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans design (CAD models of the crane in Autodesk Fusion 360), manufacturing (Bill‑of‑Materials and hardware assembly), and operation (real‑time logging, simulation, validation, and trajectory optimisation) phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service calculates distance metrics between measured trajectories and simulated counterparts, compares them against configurable thresholds, and notifies operators when deviations exceed the limits, thereby providing on‑line fidelity assessment of the kinematic and dynamic models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses TCP/IP‑based MQTT (Eclipse Mosquitto) for command and status messages, and PostgreSQL‑compatible SQL over TCP/IP for time‑series data access to TimescaleDB; the Python interface runs on the same host PC as the crane controller."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All virtual components (TimescaleDB, MQTT broker, Grafana) are Dockerised and launched together with Docker‑Compose on a personal computer; the Python services (gantrylib, Control, Logging, HMI) run as native processes on the same machine after pip installation. The source code and Docker files are hosted publicly on GitHub."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture is described using the C4 model (a standardized visual notation), data storage follows the PostgreSQL/TimescaleDB standard, and communication uses the open MQTT protocol; all software components are open‑source and adhere to their respective community standards."
]