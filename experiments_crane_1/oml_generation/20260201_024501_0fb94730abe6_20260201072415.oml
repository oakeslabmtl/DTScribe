// ---------------------------
// Physical Sensing Components
// ---------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring the lateral sway of the crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer recording ambient wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoMicrocontroller : DTDFVocab:SensingComponent [
    base:desc "Arduino microcontroller reading the analog swing‑angle and wind sensors and forwarding measurements over a serial link"
    DTDFVocab:producedData ArduinoSensorDataTransmitted
]

// ---------------------------
// Data Transmitted (Physical → Virtual)
// ---------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance ArduinoSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoMicrocontroller
]

// ---------------------------
// Virtual Data (Stored / Processed)
// ---------------------------
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurement"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo MqttBrokerEnabler, TimescaleDbEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind speed measurement"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo MqttBrokerEnabler, TimescaleDbEnabler
]

instance ArduinoSensorData : DTDFVocab:Data [
    base:desc "Aggregated sensor payload forwarded by the Arduino"
    DTDFVocab:fromData ArduinoSensorDataTransmitted
    DTDFVocab:inputTo MqttBrokerEnabler, TimescaleDbEnabler
]

// ---------------------------
// Models
// ---------------------------
instance GantryCraneCADModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the lab‑scale gantry crane"
    DTDFVocab:inputTo VisualizationEngineEnabler
]

instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic (behavioral) model capturing crane motion dynamics"
    DTDFVocab:inputTo ControlAlgorithmEnabler, ValidationEngineEnabler
]

// ---------------------------
// Enablers (Tooling & Infrastructure)
// ---------------------------
instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker used for publish/subscribe exchange of sensor, control and validation messages"
    DTDFVocab:enables OptimalControlService, HistoricalLoggingService, DataVisualizationService, ContinuousValidationService
]

instance TimescaleDbEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance for persistent logging of sensor measurements and control actions"
    DTDFVocab:enables HistoricalLoggingService
]

instance ControlAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Python‑based optimal‑control algorithm that computes real‑time motion commands"
    DTDFVocab:enables OptimalControlService
]

instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Visualization engine that renders the crane state and trajectory using the CAD model"
    DTDFVocab:enables DataVisualizationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation engine that compares kinematic model predictions with live measurements"
    DTDFVocab:enables ContinuousValidationService
]

// ---------------------------
// Services
// ---------------------------
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal‑control service computing real‑time motion commands for the crane"
    DTDFVocab:provides RealTimeMotionCommandAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Historical data‑logging service recording sensor measurements and control actions in TimescaleDB"
    DTDFVocab:provides HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Data‑visualisation service rendering the crane’s state and trajectory for researchers and engineers"
    DTDFVocab:provides CraneStateVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous‑validation service detecting deviations between kinematic model predictions and live measurements"
    DTDFVocab:provides DeviationDetectionAction
]

// ---------------------------
// Insights / Actions
// ---------------------------
instance RealTimeMotionCommandAction : DTDFVocab:Action [
    base:desc "Automatic generation of motion commands sent to the crane controller"
    DTDFVocab:IsAutomatic true
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight derived from archived sensor and control data for post‑run analysis"
]

instance CraneStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual insight into current crane pose, trajectory and payload status"
]

instance DeviationDetectionAction : DTDFVocab:Action [
    base:desc "Automatic flagging of model‑measurement mismatches to trigger alerts or re‑calibration"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control of the crane is performed by a Control Application, a Python program that issues commands through the Physical Crane Interface, which forwards them to the crane’s controllers. The description does not detail the command format, validation, authentication, feedback loops, conflict resolution, or execution acknowledgements."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The lab‑scale gantry crane digital twin follows an ad‑hoc architecture modelled with the C4 notation. Physical sensors and actuators on the crane publish and subscribe through an Eclipse Mosquitto MQTT broker. Containerised DT services (simulation, monitoring, control) run on a host PC, access time‑series data stored in a TimescaleDB database, and communicate via the MQTT broker and direct Python interfaces. No commercial DT framework is used; component integration is achieved through the broker, the database, and lightweight Python glue code, with resource management handled locally via containerisation (e.g., Docker)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A continuous validation service compares live sensor/actuator data from the crane with the predictions of the CAD and kinematic models to monitor model fidelity and detect drift. Historical data logging enables post‑hoc verification. The document does not specify quantitative fidelity requirements, uncertainty quantification methods, error correction mechanisms, or formal quality‑assurance processes."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital‑twin architecture consists of six logical containers: a TimescaleDB database, a Grafana dashboard, a Trajectory Generator Service, a Simulation Service, a Continuous Validation Service, and an MQTT broker used for signalling between services. Communication among services relies on the MQTT protocol for message exchange, while data persistence uses standard database connections to TimescaleDB. All components are Python‑based applications (except the database and dashboard) and are organised as C4 model containers; no further network topology, bandwidth, latency, redundancy, or security details are provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin consists of six logical containers (Database, Dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service, MQTT Broker) that run on the same host as the physical‑crane containers, following the C4 model abstraction. The deployment appears to be on‑premise using containerized Python services; cloud/edge platforms, scalability mechanisms, deployment models, and availability/reliability guarantees are not specified."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is based on open‑source standards: MQTT is used for real‑time data exchange between the physical crane and the digital twin, while the TimescaleDB provides historical data accessible through SQL queries or RESTful endpoints. The DT exposes REST APIs from its containerised services, allowing other applications to consume or push data in JSON format. No enterprise middleware (e.g., Azure) or proprietary protocols are employed; interoperability relies on MQTT, HTTP/REST, and standard database interfaces."
]