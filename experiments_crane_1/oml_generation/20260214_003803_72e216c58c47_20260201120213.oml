// Sensing Components
instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor capturing the position of the crane head"
    DTDFVocab:producedData PositionDataTransmitted
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Velocity sensor capturing the velocity of the crane movement"
    DTDFVocab:producedData VelocityDataTransmitted
]

instance EncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder sensor measuring discrete shaft position of the gantry motor"
    DTDFVocab:producedData EncoderDataTransmitted
]

// Data Transmitted
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySensor
]

instance EncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderSensor
]

// Data
instance PositionData : DTDFVocab:Data [
    base:desc "Time‑series data of the crane position stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData PositionDataTransmitted
]

instance VelocityData : DTDFVocab:Data [
    base:desc "Time‑series data of the crane velocity stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData VelocityDataTransmitted
]

instance EncoderData : DTDFVocab:Data [
    base:desc "Time‑series data of the crane encoder readings stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData EncoderDataTransmitted
]

// Enabler
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database storing crane telemetry for analysis and validation"
    DTDFVocab:enables OptimalControlService, HistoricalDataLoggingService, DataVisualizationService, ContinuousValidationService
]

// Models
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "CAD geometry and kinematic model of the gantry crane used for simulation and validation"
    DTDFVocab:inputTo TimescaleDBEnabler
]

// Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes optimized motion trajectories to minimize energy or time"
    DTDFVocab:provides OptimizedTrajectoryInsight, OptimizedTrajectoryAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Continuous capture and storage of sensor traces (position, velocity, encoder data) for post‑hoc analysis"
    DTDFVocab:provides CraneHistoryDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time 3D rendering of the crane’s current state and visual trace plots"
    DTDFVocab:provides RealTimeRenderingInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Automated comparison between digital model predictions and physical measurements, flagging deviations"
    DTDFVocab:provides ValidationDeviationAction
]

// Insights and Actions
instance OptimizedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimized trajectory plan generated by the twin to achieve time or energy efficiency"
]

instance OptimizedTrajectoryAction : DTDFVocab:Action [
    base:desc "Command to adjust crane motors to follow the optimal trajectory"
    DTDFVocab:IsAutomatic true
]

instance CraneHistoryDataInsight : DTDFVocab:Insight [
    base:desc "Historical sensor data stored in TimescaleDB for post‑hoc analysis"
]

instance RealTimeRenderingInsight : DTDFVocab:Insight [
    base:desc "3D representation of crane state in real time for monitoring and debugging"
]

instance ValidationDeviationAction : DTDFVocab:Action [
    base:desc "Flag deviation between predicted and measured data for operator notification"
    DTDFVocab:IsAutomatic true
]

// Components
instance CraneHeadComponent : DTDFVocab:Component [
    base:desc "Movable crane head controlled by the motorized gantry"
]

instance GantryRailComponent : DTDFVocab:Component [
    base:desc "Linear rails guiding the horizontal movement of the crane"
]

instance MotorComponent : DTDFVocab:Component [
    base:desc "Dedicated controller motor driving the gantry rail system"
]

instance CraneInterfaceComponent : DTDFVocab:Component [
    base:desc "Interface between the physical crane and the logging application"
]

instance LoggingApplicationComponent : DTDFVocab:Component [
    base:desc "Python process that reads sensors and writes state to the TimescaleDB database"
]

// Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains CraneHeadComponent, GantryRailComponent, MotorComponent, CraneInterfaceComponent, LoggingApplicationComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control Application issues movement commands to the crane through the Physical Crane Interface. Commands are derived from trajectories generated by the Trajectory Generator Service and sent via the same Python API to the physical crane’s controllers. Feedback and command confirmation are handled within the application; no external authentication, validation or conflict‑resolution protocols are described."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows a loosely coupled, messaging‑centric pattern: sensor data flows from the greenhouse’s data acquisition system to the twin via an ActiveMQ broker; the twin stores historical data in an InfluxDB time‑series database and runs on pre‑built virtual machine images that include prerecorded data for testing. Deployment is achieved through containerized or virtualized environments, with separate virtual machines hosting the twin application, the message broker, and the database, thereby decoupling each component for scalability."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The exemplars follow a four‑phase development and operation cycle: design & modeling (construction of the physical plant model using AutomationML or simple sensor scripts), simulation & prediction (running virtual experiments or predictive analytics on Azure or local VM), deployment (installing the twin on the target hardware via containerised virtual machines or Docker stacks), and runtime monitoring & adaptive control (continuous data ingestion from Raspberry‑Pi sensors into an InfluxDB database over ActiveMQ, with automated behavioural adjustments to the greenhouse or indoor air‑quality system). Transition management between these phases is achieved by versioned VM images released through GitHub and automated Azure pipelines that rebuild the twin image when code changes are merged, ensuring consistent rollback and governance of model updates."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Services communicate over an MQTT broker, which is used for signaling between the Trajectory Generator, Simulation, Continuous Validation, and dashboard services. All Python processes publish and subscribe to relevant topics on the broker. No additional network topology, bandwidth, latency, reliability, or security details are provided in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Not in Document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External integration is mediated by the ActiveMQ message broker, which supports AMQP and OpenWire protocols, enabling data ingestion from the physical greenhouse to external analytics or control systems. The twin exposes an HTTP/REST API for external consumption, and the entire stack is versioned and distributed via a GitHub repository, allowing integration with CI/CD pipelines and cloud services. Additionally, the Azure‑based Air Quality exemplar demonstrates how similar twin architectures can be integrated with Microsoft Azure services for cloud‑based analytics."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The GreenhouseDT and Air Quality Management exemplars comply with the AutomationML standard for physical‑plant representation, ensuring interoperability between plant model tools and the twin. The use of Microsoft Azure IoT Suite provides adherence to Azure’s standardised device telemetry and messaging protocols. No additional commercial twin‑framework standards or industry certification requirements are referenced in the provided documents."
]