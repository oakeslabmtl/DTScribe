// C5: Physical Components
instance GreenhouseEnvironment : DTDFVocab:Environment [
    base:desc "Physical greenhouse environment with controlled conditions for plant growth and behavioral adaptation testing."
    base:contains GreenhouseEnvironmentalSensor
]

