// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing on the gantry crane."
    DTDFVocab:producedData SwingAngleTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting crane operation."
    DTDFVocab:producedData WindSpeedTransmitted
]

instance MotorControllerFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reading motor controller status and position feedback via Arduino interface."
    DTDFVocab:producedData MotorStatusTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance SwingAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MotorStatusTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerFeedbackSensor
]

// C5: Data instances
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing angle measurements stored in TimescaleDB."
    DTDFVocab:fromData SwingAngleTransmitted
    DTDFVocab:inputTo LoggingEnabler, MQTTBrokerEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind speed measurements stored in TimescaleDB."
    DTDFVocab:fromData WindSpeedTransmitted
    DTDFVocab:inputTo LoggingEnabler, MQTTBrokerEnabler
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Motor controller status and position feedback data."
    DTDFVocab:fromData MotorStatusTransmitted
    DTDFVocab:inputTo LoggingEnabler, MQTTBrokerEnabler
]

// C11: Enablers
instance LoggingEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestrated logging component that writes incoming sensor data to TimescaleDB."
    DTDFVocab:enables LoggingApplicationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database container for historical data storage."
    DTDFVocab:enables TimescaleDBService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana container rendering dashboards from TimescaleDB data."
    DTDFVocab:enables GrafanaDashboardService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Service container generating optimal motion plans using the kinematic model."
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Physics‑based simulation container using dynamic model of crane and controllers."
    DTDFVocab:enables SimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Container validating executed trajectories against simulated ones."
    DTDFVocab:enables ContinuousValidationService
]

instance HumanMachineInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Python‑based HMI container enabling operator interaction via gantrylib."
    DTDFVocab:enables HumanMachineInterfaceService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker container facilitating event distribution."
    DTDFVocab:enables MQTTBrokerService
]

// C6: Services
instance LoggingApplicationService : DTDFVocab:Service [
    base:desc "Python application streaming sensor measurements into TimescaleDB."
    DTDFVocab:provides DataLoggingInsight
]

instance TimescaleDBService : DTDFVocab:Service [
    base:desc "TimescaleDB instance providing historical query capability."
    DTDFVocab:provides HistoricalDataInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualizing real‑time and historical crane performance."
    DTDFVocab:provides DashboardPerformanceInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Trajectory Generator Service producing optimal motion plans for crane motion."
    DTDFVocab:provides OptimalMotionPlanInsight, ExecuteMotionPlanAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation Service delivering physics‑based prediction of crane dynamics."
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous Validation Service comparing executed trajectories with simulated predictions and issuing alerts."
    DTDFVocab:provides TrajectoryDeviationAlert
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Human‑Machine Interface allowing operators to monitor and adjust crane parameters."
    DTDFVocab:provides AdjustParametersAction
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "MQTT Broker service publishing sensor events and command messages."
    DTDFVocab:provides EventDistributionInsight
]

// C17: Insights
instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data has been successfully logged."
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Ability to query and analyze historical sensor trends."
]

instance DashboardPerformanceInsight : DTDFVocab:Insight [
    base:desc "Visualization of system performance metrics for operator situational awareness."
]

instance OptimalMotionPlanInsight : DTDFVocab:Insight [
    base:desc "Generated optimal motion plan for crane movement."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Predicted dynamic response of crane for given commands."
]

instance TrajectoryDeviationAlert : DTDFVocab:Insight [
    base:desc "Alert indicating deviation between executed and simulated trajectories."
]

instance EventDistributionInsight : DTDFVocab:Insight [
    base:desc "Notification that sensor events have been broadcast via MQTT."
]

// C17: Actions
instance ExecuteMotionPlanAction : DTDFVocab:Action [
    base:desc "Execute the generated motion plan on the crane actuators."
    DTDFVocab:IsAutomatic true
]

instance AdjustParametersAction : DTDFVocab:Action [
    base:desc "Operator manually adjusts crane parameters via HMI."
    DTDFVocab:IsAutomatic false
]

// C10: Models/Data
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "3‑D CAD geometry of the gantry crane created in Autodesk Fusion360."
    DTDFVocab:inputTo GrafanaEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator to compute feasible motions."
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model used by the Simulation Service to predict crane behavior."
    DTDFVocab:inputTo SimulationEnabler
]

// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor controlled by Trinamic TMC4671‑Eval board."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor controlled by Trinamic TMC4671‑Eval board."
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist for picking up pucks."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal motion trajectories and sends set‑point commands via the Control Application through the Physical Crane Interface to the motor controllers; the HMI can also issue start/stop and electromagnet activation commands that are relayed to the Arduino."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture consists of the physical crane linked to a Python Physical Crane Interface, a Control Application, a Logging Application, and an HMI on the operator side; services (Trajectory Generator, Simulation, Continuous Validation) communicate through an MQTT broker and share data via a central TimescaleDB; a Grafana dashboard visualizes the database content; all services are containerized and run on a single personal computer."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers design (CAD models of the crane created in Autodesk Fusion360), manufacturing/assembly (physical crane hardware), and operation (real‑time data acquisition, simulation, validation, and control during runtime)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated ones, calculates distance metrics, and raises alerts when a predefined error threshold is exceeded; this provides runtime fidelity assessment and supports model validation reuse."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication uses MQTT (Eclipse Mosquitto) for signaling; sensor and command data are exchanged over the Python interface (likely TCP/serial to Arduino); the TimescaleDB database is accessed via standard PostgreSQL protocol; all containers share a Docker network on the host PC."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital‑twin components are deployed on a personal computer using Docker containers managed by a Docker‑Compose file; the TimescaleDB, MQTT broker, and Grafana dashboard are containerized; the gantrylib Python module is installed with pip; the repository provides scripts for first‑time setup and automatic initialization."
]