// C2: Acting Components
instance SwingAngleEncoderActuator : DTDFVocab:ActingComponent [
    base:desc "Electromechanical actuator controlling swing angle measurements via encoder feedback for crane kinematic validation"
]

instance HoistElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted at hoist end for puck pickup/release operations, controlled via PLC/Raspberry Pi interface"
]

instance XAxisMotorController : DTDFVocab:ActingComponent [
    base:desc "DC motor controller for X-axis carriage movement with defined actuation range constrained by crane span limits"
]

instance ZAxisMotorController : DTDFVocab:ActingComponent [
    base:desc "DC motor controller for hoist movement with defined vertical actuation range constrained by lift height limits"
]

// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures hoist swinging motion via rotational displacement sensing for kinematic validation"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Captures wind speed data for environmental factor analysis in crane operations"
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// C4: Physical-to-Virtual Data Transmission
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Behavioral model describing crane motion dynamics using geometric and kinematic relationships derived from Fusion360 CAD"
    DTDFVocab:inputTo TimescaleDatabaseEnabler
]

instance PhysicalCraneStateData : DTDFVocab:Data [
    base:desc "Real-time sensor data including swing angle measurements, actuator positions, and derived metrics like puck position"
    DTDFVocab:fromData SwingAngleDataTransmitted, EnvironmentalDataTransmitted
    DTDFVocab:inputTo GrafanaVisualizationEnabler
]

instance HistoricalTrajectoryData : DTDFVocab:Data [
    base:desc "Time-series data of crane trajectories stored for performance analysis and validation comparisons"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDatabaseEnabler
]

// C11: Enablers
instance TimescaleDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB extension for high-resolution time-series data storage of sensor measurements and validation metrics"
    DTDFVocab:hasInput HistoricalDataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker facilitating asynchronous bidirectional communication between physical crane and digital twin"
    DTDFVocab:hasInput PhysicalCraneInterfaceService
]

instance GrafanaVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Interactive dashboard for real-time monitoring of crane kinematics, sensor data trends, and validation metrics"
    DTDFVocab:hasInput DataVisualizationService
]

instance PythonProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Python-based processing framework for sensor fusion, trajectory generation, and validation metric calculations"
    DTDFVocab:hasInput ContinuousValidationService
]

instance ArduinoInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Arduino microcontroller bridge between physical crane sensors/actuators and digital twin data pipeline"
    DTDFVocab:hasInput PhysicalCraneInterfaceService
]

// C6: Services
instance PhysicalCraneInterfaceService : DTDFVocab:Service [
    base:desc "Bidirectional Python program facilitating sensor-actuator communication between physical crane and digital twin"
    DTDFVocab:provides CraneStateInsight, ActuationCommandAction
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Real-time trajectory generation and optimization service using kinematic model and sensor feedback"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Time-series data storage and retrieval service for sensor measurements and control signals"
    DTDFVocab:provides PerformanceAnalysisInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Interactive dashboard service displaying real-time and historical crane kinematic states and validation metrics"
    DTDFVocab:provides VisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Real-time validation service comparing predicted kinematic states with actual sensor data using distance metrics"
    DTDFVocab:provides ValidationResultInsight
]

// C17: Insights/Actions
instance CraneStateInsight : DTDFVocab:Insight [
    base:desc "Real-time insight into physical crane's kinematic state including position, velocity, and swing angle"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimized motion profiles generated for energy-efficient crane operations based on current environmental conditions"
]

instance PerformanceAnalysisInsight : DTDFVocab:Insight [
    base:desc "Historical performance metrics including trajectory accuracy, fault patterns, and operational efficiency trends"
]

instance ValidationResultInsight : DTDFVocab:Insight [
    base:desc "Continuous validation metrics comparing simulated trajectories with executed movements using kinematic error distances"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive visualization of crane kinematics, sensor data trends, and validation metrics for operational monitoring"
]

instance ActuationCommandAction : DTDFVocab:Action [
    base:desc "Automatic control commands sent to crane actuators based on optimal trajectory calculations"
    DTDFVocab:IsAutomatic true
]

// C1: Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains PhysicalCraneComponent, ControllerComponent
]

// C12: Components
instance PhysicalCraneComponent : DTDFVocab:Component [
    base:desc "Modular mechanical gantry structure with movable hoist, carriage, and bridge for material handling in controlled lab environments"
    base:isContainedIn LabScaleGantryCraneEnvironment
]

instance ControllerComponent : DTDFVocab:Component [
    base:desc "Embedded programmable logic controller interfacing with sensors and actuators to regulate crane motion and payload handling"
    base:isContainedIn LabScaleGantryCraneEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "
The **Control Application** (Python-based) generates control commands for the crane using inputs from the **Trajectory Generator Service**, which employs a kinematics model to optimize movement trajectories. Commands are relayed through the **Physical Crane Interface** to the crane’s controllers. The **Continuous Validation Service** compares simulated trajectories (from the **Simulation Service**) with executed trajectories via the **Logging Application**’s data. If discrepancies exceed predefined thresholds, alerts are triggered via the **Dashboard** for operator intervention. No explicit details on command formats (e.g., JSON, binary), validation/authentication mechanisms, or feedback loops (e.g., PID adjustments) are provided. Conflict resolution or command execution confirmation mechanisms are not documented."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The GreenhouseDT exemplar continuously logs environmental data (e.g., temperature, humidity) to an **InfluxDB** time-series database, enabling near-real-time synchronization between the physical greenhouse and its digital twin. No explicit synchronization frequencies or latency requirements are specified, though the use of **ActiveMQ** as a message broker suggests asynchronous communication with potential millisecond-level event handling for sensor data acquisition. The Air Quality Management exemplar supports **runtime visualization**, **simulation**, and **prediction** applications, implying continuous or periodic data flows for indoor air quality monitoring, though no precise temporal granularity (e.g., sampling rates or update intervals) is documented. The lab-scale gantry crane system lacks explicit temporal details; while the C4 Model architecture implies modular data flows, no synchronization frequencies, latency constraints, or event-driven mechanisms are mentioned in the provided documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin systems described employ **ad-hoc orchestration patterns** rather than commercial frameworks. **GreenhouseDT** uses **InfluxDB** for data storage, **ActiveMQ** for message brokering, and **virtual machines** for deployment, facilitating **behavioral adaptation** of both physical and digital components. The **Air Quality Management** exemplar integrates **Microsoft Azure tools** for pipeline implementation, leveraging **AutomationML** for the digital twin and a **Raspberry Pi** for sensor data acquisition, with applications including **runtime visualization, simulation, and prediction**. The **Lab Scale Gantry Crane** system is described using the **C4 Model** for architecture visualization, implying a **containerized or modular software architecture** but lacks explicit details on system-wide coordination mechanisms. All exemplars rely on **single-board computers (Raspberry Pi)** and **containerization/virtualization** for dissemination, with no mention of distributed coordination protocols (e.g., Kubernetes, EdgeX Foundry)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The **GreenhouseDT** exemplar demonstrates a lifecycle with **development, deployment, and adaptive phases**, where both the physical greenhouse and its digital twin exhibit **behavioral adaptation**. The system leverages **virtual machines (VMs) with prerecorded data** for deployment, enabling rapid setup and testing. The **Air Quality Management** exemplar includes **runtime visualization, simulation, and prediction** as lifecycle stages, with **Microsoft Azure tools** facilitating deployment and execution. The **Lab Scale Gantry Crane** system, while not explicitly detailing governance frameworks, is used for **publication-based validation** and **teaching applications**, indicating lifecycle stages tied to **continuous validation** and **operational demonstration**. Transition management is implied through **adaptive behaviors** (GreenhouseDT) and **service-oriented architecture** (Gantry Crane, e.g., Continuous Validation Service). Governance approaches are **ad-hoc** in these exemplars, with no formal frameworks mentioned beyond domain-specific use cases (e.g., virus spread prevention in Air Quality Management)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The system employs a **Continuous Validation Service** that continuously compares **executed trajectories** (derived from sensor measurements: encoders, anemometer) with **simulated trajectories** (generated by the kinematic model) using **Euclidean distance metrics** to quantify deviations. An **acceptable threshold** (not specified numerically) defines the error tolerance, triggering corrective actions (e.g., trajectory adjustments) if exceeded. Uncertainty sources include **sensor noise** (encoder drift, anemometer variability), **environmental factors** (airflow perturbations), and **model inaccuracies** (e.g., kinematic approximations). Error detection mechanisms involve **real-time threshold comparisons**, while correction is handled via **closed-loop control adjustments** in the physical system. Quality assurance processes are implicit in the validation service’s iterative feedback loop, ensuring long-term fidelity between the digital twin and physical crane. No explicit mention of **formal verification methods** (e.g., model checking) or **statistical validation protocols** (e.g., confidence intervals) is provided."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "
The digital twin’s technical connection relies on an **MQTT Broker** (Eclipse Mosquitto) for inter-service communication, adhering to a publish-subscribe architecture. The network topology is not detailed, but the system assumes local connectivity (e.g., Ethernet/Wi-Fi) between containers. No bandwidth, latency, or reliability specifications (e.g., QoS levels, redundancy) are mentioned. Security protocols are not addressed in the document. The **MQTT Broker** facilitates asynchronous signaling between the **Logging Application**, **Trajectory Generator Service**, and **Continuous Validation Service**, but no explicit protocol version (e.g., MQTT v3.1.1) or encryption (e.g., TLS) is referenced."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "
The digital twin is deployed on **on-premise hardware** (personal computer) using a **Docker**-based containerization framework. The **Database**, **MQTT Broker**, and **Dashboard** are containerized via Docker Compose, while other services (e.g., **Trajectory Generator Service**) are bundled as standalone Python modules. The deployment model supports modular scaling via Docker containers, but no scalability mechanisms (e.g., horizontal pod autoscaling) or resource requirements (e.g., CPU/GPU allocation) are specified. Availability/reliability is not explicitly addressed beyond the containerized deployment. The system’s repository structure includes a `docker-compose.yml` file for orchestration, but no cloud/edge deployment or high-availability configurations are documented."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The **GreenhouseDT** exemplar integrates with **InfluxDB** (time-series database) and **ActiveMQ** (message broker) for internal communication, with no explicit mention of external system dependencies. The **Air Quality Management** exemplar uses **Microsoft Azure tools** for cloud-based pipeline orchestration and integrates with **Raspberry Pi sensors** via AutomationML, but lacks details on interoperability standards (e.g., OPC UA, MQTT) or enterprise system dependencies. The **Lab Scale Gantry Crane** system is not described in terms of horizontal integration in the provided documents. No standardized protocols (e.g., REST, SOAP) or interoperability frameworks (e.g., IoT-A, OPC UA) are referenced for external system integration."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplars exhibit **limited adherence to formal standards**. **GreenhouseDT** relies on **InfluxDB** (open-source time-series database) and **ActiveMQ** (open-source message broker), with no mention of industry standards. **Air Quality Management** uses **AutomationML** (a standardized modeling language for automation, per context) but does not reference **ISO 15930** or other compliance frameworks. The **Lab Scale Gantry Crane** system does not mention any standardization efforts beyond the **C4 Model** (a software architecture documentation technique). None of the exemplars reference **OPC UA**, **ISO 23247**, or other digital twin interoperability standards. Interoperability is achieved via **ad-hoc protocols** (e.g., sensor data integration) rather than certified frameworks."
]