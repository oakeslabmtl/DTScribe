// C3: Physical sensing components
instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Provides current crane position read from the controller via the Python‑based Physical Crane Interface and Arduino"
    DTDFVocab:producedData PositionDataTransmitted
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Provides current crane velocity read from the controller via the Python‑based Physical Crane Interface and Arduino"
    DTDFVocab:producedData VelocityDataTransmitted
]

instance CraneStatusFlagSensor : DTDFVocab:SensingComponent [
    base:desc "Provides status flags (e.g., homed, error) from the crane controller"
    DTDFVocab:producedData StatusFlagDataTransmitted
]

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encodes the swing angle of the load, read by an Arduino and forwarded to the Python interface"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Measures ambient wind speed via an Arduino‑connected anemometer"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Reports motor status (on/off, fault) from the embedded controllers"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

// C4: DataTransmitted
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocitySensor
]

instance StatusFlagDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneStatusFlagSensor
]

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

// C10: Data
instance PositionData : DTDFVocab:Data [
    base:desc "Time‑series of crane position stored in TimescaleDB"
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance VelocityData : DTDFVocab:Data [
    base:desc "Time‑series of crane velocity stored in TimescaleDB"
    DTDFVocab:fromData VelocityDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance StatusFlagData : DTDFVocab:Data [
    base:desc "Chronology of status flags stored in TimescaleDB"
    DTDFVocab:fromData StatusFlagDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Swing‑angle measurements stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Wind‑speed measurements stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Motor status records stored in TimescaleDB"
    DTDFVocab:fromData MotorStatusDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

// C10: Models
instance GantryCADModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the lab‑scale gantry crane used for visualization"
    DTDFVocab:inputTo VisualizationEngine
]

instance GantryKinematicModel : DTDFVocab:Model [
    base:desc "Analytical kinematics model that computes swing‑free trajectories"
    DTDFVocab:inputTo KinematicEngine
]

instance GantryBehavioralSimulationModel : DTDFVocab:Model [
    base:desc "Behavioral simulation model of the crane and its low‑level controllers"
    DTDFVocab:inputTo SimulationEngine
]

// C11: Enablers
instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database storing all logged sensor data"
    DTDFVocab:enables LoggingService, ContinuousValidationService, SimulationService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker mediating signalling between trajectory, simulation, validation services"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, GrafanaDashboardService
]

instance KinematicEngine : DTDFVocab:Enabler [
    base:desc "Engine exposing the kinematic model for trajectory generation and validation"
    DTDFVocab:enables TrajectoryGeneratorService, ContinuousValidationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Engine executing the behavioral simulation model"
    DTDFVocab:enables SimulationService, ContinuousValidationService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Engine providing CAD model visualisation to the Grafana dashboard"
    DTDFVocab:enables GrafanaDashboardService
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free motion plans using the kinematic model"
    DTDFVocab:provides PrescriptiveTrajectoryInsight, ReplanTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Emulates crane dynamics and predicts sensor traces for generated trajectories"
    DTDFVocab:provides PredictedTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares logged measurements with simulated predictions, computes distance metrics, and raises alerts"
    DTDFVocab:provides DiagnosticValidationInsight, ConfidenceBoundInsight, VisualAlertAction, HaltCraneAction
]

instance LoggingService : DTDFVocab:Service [
    base:desc "Records real‑time crane state into TimescaleDB"
    DTDFVocab:provides DataLoggingInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Visualises stored data, trajectories and confidence bounds; displays visual alerts"
    DTDFVocab:provides VisualisationInsight, VisualAlertAction
]

// C17: Insights
instance PrescriptiveTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal, swing‑free trajectory computed by the Trajectory Generator"
]

instance DiagnosticValidationInsight : DTDFVocab:Insight [
    base:desc "Quantitative distance metric between predicted and actual sensor data"
]

instance ConfidenceBoundInsight : DTDFVocab:Insight [
    base:desc "Confidence bounds (blue/yellow bands) visualised on Grafana indicating validation status"
]

instance PredictedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Predicted sensor trace generated by the Simulation Service"
]

instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data have been persisted in TimescaleDB"
]

instance VisualisationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualisation of trajectories, sensor data and validation results"
]

// C17: Actions
instance ReplanTrajectoryAction : DTDFVocab:Action [
    base:desc "Operator can trigger a new trajectory computation via the HMI"
    DTDFVocab:IsAutomatic false
]

instance HaltCraneAction : DTDFVocab:Action [
    base:desc "Operator can halt crane motion when validation alerts exceed threshold"
    DTDFVocab:IsAutomatic false
]

instance VisualAlertAction : DTDFVocab:Action [
    base:desc "Displays visual alert on the Human‑Machine Interface and Grafana"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin provides control commands through several services. The Trajectory Generator Service uses a kinematic model of the crane to compute optimal movement trajectories that end with zero residual swing. These trajectory set‑points are sent to the Control Application, which uses the Physical Crane Interface (a Python program) to transmit the commands to the crane’s motor controllers. The Human Machine Interface (a Python front‑end) allows an operator to manually configure and trigger commands, which are likewise routed through the Control Application to the physical hardware. No explicit command message format, authentication, or conflict‑resolution mechanisms are described in the documents; confirmation of command execution is implied by the Logging Application’s continuous state logging."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a service‑oriented architecture orchestrated by Docker‑Compose. All six digital‑twin containers are launched together, sharing a Docker network. The MQTT broker provides publish/subscribe messaging that synchronises the Trajectory Generator, Simulation, and Continuous Validation services. The TimescaleDB stores time‑series data accessed by the Logging Application and Grafana for visualisation. Interaction between services occurs via MQTT messages and standard SQL queries to the database, constituting a loosely coupled yet centrally coordinated constellation of components."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The gantry‑crane digital twin follows a four‑stage lifecycle described in the papers: (1) Development – creation of CAD geometry and a kinematic model of the crane, packaged as Python modules; (2) Integration – the models are wrapped as services (Trajectory Generator, Simulation, Continuous Validation) and deployed together with supporting components (TimescaleDB, Grafana, MQTT broker) via a single Docker‑compose command; (3) Operation – the running services ingest real‑time state from the Physical Crane Interface, log data to TimescaleDB, generate optimal trajectories, simulate them and continuously validate measured vs simulated trajectories; (4) Evolution – the exemplar is reused in successive research projects (continuous‑validation methods, fault‑detection, DarTwin notation) where new services or model refinements are added and redeployed. Transition between stages is managed by the Docker‑compose orchestration; lifecycle governance is informal and relies on the open‑source GitHub repository for version control and documentation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by continuously validating measured trajectories against the simulation output. The Continuous Validation Service computes distance metrics between the real‑world execution and the simulated trajectory, compares them to a configurable threshold, and raises alerts via the Grafana dashboard if the deviation exceeds the limit. Validation thus detects model drift, sensor noise or controller faults. Uncertainty sources include measurement noise from the crane controllers and simplifications in the kinematic and simulation models. The threshold provides a quantitative bound on acceptable error, serving as a quality‑assurance mechanism for both models and data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin relies on an MQTT broker (Eclipse Mosquitto) that handles signalling between the Trajectory Generator, Simulation, Continuous Validation and other services. All services are packaged as Docker containers (Database, MQTT broker, Dashboard, and the Python services) and are orchestrated with a Docker‑compose file, creating a local container network (typically the default bridge network). The documents do not detail bandwidth, latency, or redundancy requirements, nor do they specify additional security protocols beyond the choice of an open‑source MQTT broker."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire system is deployed on a single personal computer (on‑premise). The physical‑side software runs as native Python processes, while the digital‑twin components (TimescaleDB, Grafana dashboard, and MQTT broker) are containerised with Docker. Deployment is automated via a Docker‑compose file that brings up the database, broker and dashboard with a single command and also performs first‑time initialization of the database and dashboard. The required infrastructure therefore includes a PC capable of running Docker and Python, sufficient storage for time‑series data in TimescaleDB, and modest compute resources for the simulation and validation services. Scalability is implied by the containerised architecture (additional instances could be started), but no explicit cloud or edge hosting, high‑availability, or redundancy mechanisms are described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External integration is realised through standard protocols: MQTT is used for inter‑service signalling, and the TimescaleDB (PostgreSQL‑compatible) is accessed via SQL by the Logging Application and Grafana dashboard. No explicit links to other enterprise systems or external digital twins are described, but the use of widely adopted protocols (MQTT, SQL) enables straightforward extension to outside systems that support these standards."
]