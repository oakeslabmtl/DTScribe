instance CraneStateSensor : DTDFVocab:SensingComponent [
    base:desc "Senses state data from the Lab-scale gantry crane physical component"
    DTDFVocab:producedData CraneStateDataTransmitted
]

instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneStateSensor
]

instance CraneStateData : DTDFVocab:Data [
    base:desc "Crane operational state data streamed to TimescaleDB"
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB time-series database for storing crane operational data"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service for logging historical crane operation data to TimescaleDB"
    DTDFVocab:provides HistoricalDataInsight
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Access to historical crane operation data for analysis and validation"
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Service providing real-time visualization of crane operations"
    DTDFVocab:provides CraneRealTimeVisualizationInsight
]

instance CraneRealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of crane state data for monitoring and analysis"
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service for optimal control of crane operations based on digital twin data"
    DTDFVocab:provides OptimalControlAction
]

instance OptimalControlAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of crane parameters for optimal performance"
    DTDFVocab:IsAutomatic true
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service for continuous validation of digital twin synchronization with physical system"
    DTDFVocab:provides ValidationInsight
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Continuous validation results ensuring synchronization between physical and digital twins"
]

instance CraneController : DTDFVocab:Component [
    base:desc "Physical controller component of the Lab-scale gantry crane in industrial automation research"
]

instance ResearchEnvironment : DTDFVocab:Environment [
    base:desc "Industrial automation research and education environment for the Lab-scale gantry crane digital twin"
    base:contains CraneController, DigitalTwinSystem
]

instance DigitalTwinSystem : DTDFVocab:Component [
    base:desc "Digital twin system for the Lab-scale gantry crane"
]

instance C4Model : DTDFVocab:Model [
    base:desc "C4 Model for architecture visualization of Lab-scale gantry crane system"
    DTDFVocab:inputTo C4ToolEnabler
]

instance C4ToolEnabler : DTDFVocab:Enabler [
    base:desc "C4 Model tool for visualizing crane architecture"
    DTDFVocab:enables CraneArchitectureService
]

instance CraneArchitectureService : DTDFVocab:Service [
    base:desc "Service for visualizing crane system architecture using C4 Model"
    DTDFVocab:provides ArchitectureVisualizationInsight
]

instance ArchitectureVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of crane system architecture for development and validation"
]

instance IndoorAirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors monitoring indoor air quality parameters for virus spread prevention"
    DTDFVocab:producedData IndoorAirQualityDataTransmitted
]

instance IndoorAirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndoorAirQualitySensor
]

instance IndoorAirQualityData : DTDFVocab:Data [
    base:desc "Indoor air quality data used for simulation and prediction"
    DTDFVocab:fromData IndoorAirQualityDataTransmitted
    DTDFVocab:inputTo AzureTools
]

instance AzureTools : DTDFVocab:Enabler [
    base:desc "Microsoft Azure tools for data pipeline implementation in air quality management"
    DTDFVocab:enables AirQualityVisualizationService, AirQualitySimulationService, AirQualityPredictionService
]

instance AirQualityVisualizationService : DTDFVocab:Service [
    base:desc "Service for runtime visualization of indoor air quality data"
    DTDFVocab:provides AirQualityVisualizationInsight
]

instance AirQualityVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of indoor air quality parameters for monitoring and decision-making"
]

instance AirQualitySimulationService : DTDFVocab:Service [
    base:desc "Service for simulating indoor air quality scenarios for virus spread prevention"
    DTDFVocab:provides AirQualitySimulationInsight
]

instance AirQualitySimulationInsight : DTDFVocab:Insight [
    base:desc "Simulated scenarios for virus spread prevention based on air quality data"
]

instance AirQualityPredictionService : DTDFVocab:Service [
    base:desc "Service for predicting indoor air quality trends to prevent virus spread"
    DTDFVocab:provides AirQualityPredictionInsight
]

instance AirQualityPredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive insights on air quality trends to inform preventive measures"
]

instance GreenhouseModel : DTDFVocab:Model [
    base:desc "Digital twin model for greenhouse system supporting behavioral adaptation"
    DTDFVocab:inputTo GreenhouseEnabler
]

instance GreenhouseEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for behavioral adaptation in greenhouse digital twin"
    DTDFVocab:enables GreenhouseAdaptationService
]

instance GreenhouseAdaptationService : DTDFVocab:Service [
    base:desc "Service for real-time behavioral adaptation of greenhouse system and digital twin"
    DTDFVocab:provides GreenhouseAdaptationInsight
]

instance GreenhouseAdaptationInsight : DTDFVocab:Insight [
    base:desc "Real-time adjustments based on behavioral adaptation of greenhouse system"
]

instance GitHub : DTDFVocab:Enabler [
    base:desc "GitHub for version control and collaboration in digital twin development"
    DTDFVocab:enables VersionControlService
]

instance VersionControlService : DTDFVocab:Service [
    base:desc "Service for managing digital twin code versions using GitHub"
    DTDFVocab:provides VersionControlInsight
]

instance VersionControlInsight : DTDFVocab:Insight [
    base:desc "Version control management for digital twin development process"
]

instance Docker : DTDFVocab:Enabler [
    base:desc "Docker containerization for deploying digital twin components"
    DTDFVocab:enables ContainerDeploymentService
]

instance ContainerDeploymentService : DTDFVocab:Service [
    base:desc "Service for deploying digital twin components in containers"
    DTDFVocab:provides ContainerDeploymentInsight
]

instance ContainerDeploymentInsight : DTDFVocab:Insight [
    base:desc "Containerized deployment of digital twin components for scalability"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands from the Control Application are transmitted via the Physical Crane Interface to the physical crane hardware. Specific command types, message formats, validation and authentication mechanisms, feedback systems, conflict resolution, and command execution confirmation details are not described in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system architecture is modeled using the C4 Model with context and container diagrams, employing containerization and virtualization for deployment. It adopts an ad-hoc implementation approach without commercial digital twin frameworks, integrating components including InfluxDB for data storage, ActiveMQ message broker for communication, Raspberry Pi sensors for physical data acquisition, and Microsoft Azure tools for cloud-based processing and management."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system utilizes an MQTT Broker for signaling between services. Network topology follows the C4 container model with services interconnected via MQTT. Bandwidth and latency requirements, reliability and redundancy mechanisms, and security protocols are not detailed in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems via AutomationML for standardized digital twin modeling in construction engineering contexts, Microsoft Azure cloud services for scalable data processing, and ActiveMQ message broker for asynchronous communication between physical sensors and digital components. Data exchange follows industry-standard protocols supported by ActiveMQ to ensure interoperability with enterprise systems and other digital twins."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar utilizes AutomationML, an international standard for automation systems, for digital twin modeling. No other industry standards or interoperability frameworks are specified in the documents."
]