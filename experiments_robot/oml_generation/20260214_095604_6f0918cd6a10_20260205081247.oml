// C3: Physical sensing components
instance ManufacturingProcessSensor : DTDFVocab:SensingComponent [
    base:desc "Collects contextual data traces from physical manufacturing systems including sensor readings, operational logs, and environmental metrics for digital shadow data aggregation."
    DTDFVocab:producedData ManufacturingProcessDataTransmitted
]

instance PhysicalSystemStateSensor : DTDFVocab:SensingComponent [
    base:desc "Captures state changes and operational parameters from physical engineered systems to enable real-time monitoring and data abstraction."
    DTDFVocab:producedData PhysicalSystemStateDataTransmitted
]

// C4: Physical-to-virtual interaction
instance ManufacturingProcessDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ManufacturingProcessSensor
    base:desc "Automated one-way data flow from physical manufacturing processes to digital representation, including sensor readings and operational logs via industrial communication protocols (e.g., OPC UA, MQTT)."
]

instance PhysicalSystemStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemStateSensor
    base:desc "Event-triggered data transmission of physical system state changes (e.g., state transitions, threshold alerts) for digital shadow integration."
]

// C10: Models/Data
instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML-based requirements model capturing multi-layered system descriptions across requirements, functions, logics, and physics layers."
    DTDFVocab:inputTo SysMLFrameworkEnabler
]

instance SysMLInternalBlockDiagram : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) representing component-connector architecture of engineered systems."
    DTDFVocab:inputTo SysMLFrameworkEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model defining behavioral dynamics of system components."
    DTDFVocab:inputTo SysMLFrameworkEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language model defining components, connectors, and interfaces for system architecture."
    DTDFVocab:inputTo ArchitectureDescriptionLanguageEnabler
]

instance AADLComponentModel : DTDFVocab:Model [
    base:desc "AADL model for component-based system architecture with explicit interfaces and interconnections."
    DTDFVocab:inputTo ArchitectureDescriptionLanguageEnabler
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "MontiArc model defining component-connector architecture with behavioral extensions."
    DTDFVocab:inputTo ArchitectureDescriptionLanguageEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model extending behavioral descriptions with state-based dynamics."
    DTDFVocab:inputTo ArchitectureDescriptionLanguageEnabler
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for dynamic system behavior simulation and analysis."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance PhysicsBasedSimulationModel : DTDFVocab:Model [
    base:desc "Physics-based or hybrid simulation model for detailed system behavior analysis."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance ManufacturingProcessData : DTDFVocab:Data [
    base:desc "Aggregated sensor and operational data from manufacturing processes for digital shadow analysis."
    DTDFVocab:fromData ManufacturingProcessDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler
]

instance PhysicalSystemStateData : DTDFVocab:Data [
    base:desc "Processed state change data from physical systems for behavioral simulation and monitoring."
    DTDFVocab:fromData PhysicalSystemStateDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler
]

// C11: Enablers
instance SysMLFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "SysML framework enabling Model-Based Systems Engineering (MBSE) with Internal Block Diagrams and state machines for multi-layered system descriptions."
    DTDFVocab:enables SysMLModelingService, BehavioralSimulationService
]

instance ArchitectureDescriptionLanguageEnabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Languages (ACME, AADL, MontiArc) enabling component-connector modeling and behavioral extensions."
    DTDFVocab:enables ComponentArchitectureService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engines (Simulink, physics-based simulators) for dynamic system behavior modeling and analysis."
    DTDFVocab:enables DynamicSimulationService, PhysicsBasedAnalysisService
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "Data aggregation layer for collecting, normalizing, and preprocessing sensor and operational data from physical systems."
    DTDFVocab:enables DataProcessingService, ContextualDataService
]

instance CrossToolIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Mechanisms to bridge heterogeneous tools (SysML → Simulink → C++/Java) maintaining consistency across system lifecycle."
    DTDFVocab:enables ToolChainIntegrationService, ModelConsistencyService
]

instance ProgrammingLanguageEnabler : DTDFVocab:Enabler [
    base:desc "General-purpose programming languages (C++, Java) for low-level logic implementation and custom system components."
    DTDFVocab:enables ImplementationService, CustomLogicService
]

// C6: Services
instance SysMLModelingService : DTDFVocab:Service [
    base:desc "Service providing multi-layered system modeling using SysML requirements, IBDs, and state machines."
    DTDFVocab:provides SysMLModelingInsight
]

instance ComponentArchitectureService : DTDFVocab:Service [
    base:desc "Service defining component-connector architecture using ADLs (ACME, AADL, MontiArc)."
    DTDFVocab:provides ComponentArchitectureInsight
]

instance BehavioralSimulationService : DTDFVocab:Service [
    base:desc "Service enabling behavioral modeling through SysML state machines and MontiArc automata."
    DTDFVocab:provides BehavioralModelInsight
]

instance DynamicSimulationService : DTDFVocab:Service [
    base:desc "Service executing dynamic system simulations using MathWorks Simulink."
    DTDFVocab:provides SimulationResultInsight
]

instance PhysicsBasedAnalysisService : DTDFVocab:Service [
    base:desc "Service performing physics-based or hybrid system simulations."
    DTDFVocab:provides PhysicsAnalysisInsight
]

instance DataProcessingService : DTDFVocab:Service [
    base:desc "Service aggregating, normalizing, and preprocessing sensor and operational data."
    DTDFVocab:provides ProcessedDataInsight
]

instance ContextualDataService : DTDFVocab:Service [
    base:desc "Service providing contextual data traces from physical systems for digital shadow analysis."
    DTDFVocab:provides ContextualDataInsight
]

instance ToolChainIntegrationService : DTDFVocab:Service [
    base:desc "Service ensuring consistency across SysML, Simulink, and programming language implementations."
    DTDFVocab:provides IntegrationConsistencyInsight
]

instance ModelConsistencyService : DTDFVocab:Service [
    base:desc "Service maintaining model consistency across heterogeneous toolchains."
    DTDFVocab:provides ConsistencyValidationInsight
]

instance ImplementationService : DTDFVocab:Service [
    base:desc "Service implementing system components using C++ or Java for low-level logic."
    DTDFVocab:provides ImplementationInsight
]

instance CustomLogicService : DTDFVocab:Service [
    base:desc "Service enabling custom logic integration through general-purpose programming languages."
    DTDFVocab:provides CustomLogicInsight
]

// C17: Insights/Actions
instance SysMLModelingInsight : DTDFVocab:Insight [
    base:desc "Multi-layered system description using SysML requirements, IBDs, and state machines."
]

instance ComponentArchitectureInsight : DTDFVocab:Insight [
    base:desc "Component-connector architecture defined using ADLs (ACME, AADL, MontiArc)."
]

instance BehavioralModelInsight : DTDFVocab:Insight [
    base:desc "Behavioral dynamics modeled through SysML state machines and MontiArc automata."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Dynamic system behavior results from MathWorks Simulink simulations."
]

instance PhysicsAnalysisInsight : DTDFVocab:Insight [
    base:desc "Physics-based or hybrid simulation analysis results."
]

instance ProcessedDataInsight : DTDFVocab:Insight [
    base:desc "Aggregated and normalized sensor and operational data ready for analysis."
]

instance ContextualDataInsight : DTDFVocab:Insight [
    base:desc "Contextual data traces from physical systems for digital shadow applications."
]

instance IntegrationConsistencyInsight : DTDFVocab:Insight [
    base:desc "Consistency validation across SysML, Simulink, and programming language implementations."
]

instance ConsistencyValidationInsight : DTDFVocab:Insight [
    base:desc "Validation of model consistency across heterogeneous toolchains."
]

instance ImplementationInsight : DTDFVocab:Insight [
    base:desc "System components implemented using C++ or Java for low-level logic."
]

instance CustomLogicInsight : DTDFVocab:Insight [
    base:desc "Custom logic integrated through general-purpose programming languages."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The document describes the **Digital Twin (DT) as an active system** capable of processing and interpreting data from physical objects, unlike a passive Digital Shadow (which only receives one-way data flows). Orchestration and coordination in DT systems are implied to rely on **architecture description languages (ADLs)** such as ACME, AADL, MontiArc, or SysML Internal Block Diagrams (IBDs), which define **component integration** (e.g., interfaces, connectors, and composition) and **behavioral modeling** (e.g., state machines in SysML v1.7 or MontiArc Automaton). For detailed behavior, these models are often combined with **simulation tools** (e.g., MathWorks Simulink) or **general-purpose programming languages** (e.g., C++, Java). The document does not specify **resource management** or **system-wide coordination mechanisms** explicitly, but it highlights the need to integrate **heterogeneous tools and stakeholders** within a DT constellation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **fidelity and validity considerations** through **Model-Based Systems Engineering (MBSE) validation and verification (V&V) processes**, though specific methods are not detailed in the provided context. The system relies on **automated one-way data flows** from physical objects (as in Digital Shadows) to digital representations, implying that **uncertainty quantification** and **error detection** are implicitly tied to the **accuracy of data aggregation and abstraction mechanisms**. Validation may involve **cross-model consistency checks** (e.g., between SysML, Simulink, or ADLs) to ensure alignment across **functional, logical, and technical layers**. Quality assurance processes likely include **stakeholder integration** to address **heterogeneous perspectives** and **multi-notation modeling discrepancies**, though explicit error correction mechanisms or uncertainty quantification frameworks are not specified. The system’s fidelity depends on the **granularity of data traces** (e.g., contextual data collected for specific purposes) and their **abstraction levels**, with potential gaps addressed through **active DT components** that interpret and process incoming data."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The document emphasizes the necessity for **interoperability** between **heterogeneous systems** in Digital Twin (DT) ecosystems, particularly in the context of **Model-Based Systems Engineering (MBSE)**. Integration with external systems is implied through the use of **standardized modeling languages** (e.g., SysML, ADLs like AADL or MontiArc) and **simulation tools** (e.g., MathWorks Simulink) to ensure seamless data exchange. While no specific **data exchange protocols** or **interoperability standards** (e.g., OPC UA, MQTT, or REST APIs) are mentioned, the document suggests that DT systems must accommodate **dependencies on external systems** (e.g., enterprise systems or other DTs) to fulfill their purpose. The integration patterns are not explicitly detailed, but the **multi-layered abstraction** (requirements, functional/logical architecture, and technical layers) implies a **modular and hierarchical integration approach** to manage complexity."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The provided documents reference **cybersecurity protocols** and **access control mechanisms** implicitly through the **Asset Administration Shell (AAS)** framework (referenced in [46], [47], [50]), which is a key component of **RAMI4.0** ([49]). The AAS defines a standardized structure for digital twins in Industrie 4.0, incorporating **authentication systems** via **OAuth 2.0** and **JWT (JSON Web Tokens)** for secure communication between assets and their digital twins ([50]). Additionally, the **Functional Mockup Interface (FMI)** ([51])—used for tool-independent exchange of simulation models—implies **fail-safe mechanisms** by ensuring interoperability and deterministic behavior in simulation environments. **Risk assessment approaches** are indirectly supported by the **Asset Administration Shell’s** modular architecture, which allows integration of **threat mitigation strategies** through compliance with **IEC 62443** (industrial cybersecurity standards) and **ISO/IEC 27001** (information security management) as referenced in the **RAMI4.0** framework ([49]). The **MQTT protocol** ([52]), leveraged for lightweight IoT communication, includes **TLS/SSL encryption** for secure data transmission, while **Thingsboard (v4.0.0)** ([53]), an open-source IoT platform, provides **role-based access control (RBAC)** and **audit logging** for safety-critical systems. However, explicit details on **data anonymization**, **consent management**, or **data sharing agreements** are not provided in the documents."
]