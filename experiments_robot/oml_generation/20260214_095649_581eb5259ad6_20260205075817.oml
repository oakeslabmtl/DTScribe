// Sensing components (C3)
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor on the permanent‑magnet synchronous motor"
    DTDFVocab:producedData MotorCurrentData
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder on the motor shaft"
    DTDFVocab:producedData MotorPositionAngleData
]

instance GearWheelEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder on the gear‑wheel of the first axis"
    DTDFVocab:producedData GearWheelAngleData
]

// Data transmitted (C4)
instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorPositionAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearWheelAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearWheelEncoder
]

// Data (C10)
instance MotorCurrentTrace : DTDFVocab:Data [
    base:desc "Trace of motor current streamed via MQTT"
    DTDFVocab:fromData MotorCurrentData
    DTDFVocab:inputTo MQTTTransport
]

instance MotorPositionAngleTrace : DTDFVocab:Data [
    base:desc "Trace of motor position angle streamed via MQTT"
    DTDFVocab:fromData MotorPositionAngleData
    DTDFVocab:inputTo MQTTTransport
]

instance GearWheelAngleTrace : DTDFVocab:Data [
    base:desc "Trace of gear‑wheel position angle streamed via MQTT"
    DTDFVocab:fromData GearWheelAngleData
    DTDFVocab:inputTo MQTTTransport
]

instance ComputedTorqueTrace : DTDFVocab:Data [
    base:desc "Computed torque from motor current and position data via simulation"
]

instance ComputedVelocityTrace : DTDFVocab:Data [
    base:desc "Computed angular velocity derived from motor encoder data"
]

instance FrictionLossTrace : DTDFVocab:Data [
    base:desc "Friction loss estimates generated by real‑time friction identification"
]

instance DriftPredictionTrace : DTDFVocab:Data [
    base:desc "Predicted drift in joint position due to unmodeled dynamics"
]

instance AssetHealthMetricsTrace : DTDFVocab:Data [
    base:desc "Asset health metrics calculated from combined sensor and model data"
]

instance ControllerParameterTuningTrace : DTDFVocab:Data [
    base:desc "Suggested controller parameter adjustments based on simulation results"
]

// Models (C10)
instance SysMLRobotStructureModel : DTDFVocab:Model [
    base:desc "SysML model of the MABI MAX 100 robotic arm structure"
    DTDFVocab:inputTo AssetAdministrationShell
]

instance SimulinkMotorDynamicModel : DTDFVocab:Model [
    base:desc "Simulink model of the permanent‑magnet synchronous motor dynamics"
]

instance SimulinkGearboxDynamicModel : DTDFVocab:Model [
    base:desc "Simulink model of the gearbox dynamics for the first axis"
]

instance SimulinkCoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Simulink Coulomb‑viscous friction model used for joint dynamics"
]

instance SimulinkStribeckFrictionModel : DTDFVocab:Model [
    base:desc "Simulink Stribeck friction model used for joint dynamics"
]

instance SimulinkDahlFrictionModel : DTDFVocab:Model [
    base:desc "Simulink Dahl friction model used for joint dynamics"
]

instance SimulinkLuGreFrictionModel : DTDFVocab:Model [
    base:desc "Simulink LuGre friction model used for joint dynamics"
]

instance DataCalculationModelTorqueVelocity : DTDFVocab:Model [
    base:desc "Model to compute torque and velocity from sensor streams"
]

// Enablers (C11)
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML tool used to create the engineering model of the robot structure"
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink used for executable simulation of the motor, gearbox, and friction models"
    DTDFVocab:enables FrictionIdentificationService, SimulationDynamicJointService, ModelValidationService
]

instance MQTTTransport : DTDFVocab:Enabler [
    base:desc "MQTT transport used to stream sensor data (current, encoder angles) to the digital twin"
    DTDFVocab:enables DataAggregationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell used to structure and expose the digital twin model"
    DTDFVocab:enables ModelValidationService
]

instance WebDashboard : DTDFVocab:Enabler [
    base:desc "Web dashboard providing visualization of insights, metrics, and controller tuning"
    DTDFVocab:enables DashboardVisualizationService
]

// Services (C6)
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time friction identification service that updates friction models for the controller"
    DTDFVocab:provides FrictionLossInsight, MaintenanceScheduleInsight, DriftPredictionInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Data aggregation service that collects and stores sensor traces via MQTT"
    DTDFVocab:provides AssetHealthInsight
]

instance SimulationDynamicJointService : DTDFVocab:Service [
    base:desc "Simulation service that runs joint dynamics models for friction analysis"
    DTDFVocab:provides MotionAccuracyInsight
]

instance ModelValidationService : DTDFVocab:Service [
    base:desc "Model validation service that compares simulated data against measured traces"
    DTDFVocab:provides AssetHealthInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Visualization service that displays insights and metrics on the web dashboard"
    DTDFVocab:provides FrictionLossInsight, DriftPredictionInsight, AssetHealthInsight, MotionAccuracyInsight
]

instance ControllerParameterTuningService : DTDFVocab:Service [
    base:desc "Control system tuning service that suggests controller parameter updates"
    DTDFVocab:provides ControllerParameterUpdateAction
]

instance AssetHealthService : DTDFVocab:Service [
    base:desc "Asset health service that monitors rodkin health metrics"
    DTDFVocab:provides AssetHealthInsight
]

// Insights (C17)
instance FrictionLossInsight : DTDFVocab:Insight [
    base:desc "Identified friction losses in the first axis joint"
]

instance DriftPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted drift in the first axis position due to friction dynamics"
]

instance MaintenanceScheduleInsight : DTDFVocab:Insight [
    base:desc "Suggested maintenance schedule based on friction identification results"
]

instance AssetHealthInsight : DTDFVocab:Insight [
    base:desc "Overall asset health metrics derived from sensor and model data"
]

instance MotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Motion accuracy assessment of the first axis based on simulation versus real data"
]

// Actions (C17)
instance MaintenanceScheduleAction : DTDFVocab:Action [
    base:desc "Action to schedule maintenance for the first axis joint"
    DTDFVocab:IsAutomatic true
]

instance ControllerParameterUpdateAction : DTDFVocab:Action [
    base:desc "Automatic update of controller parameters for improved motion accuracy"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time; data are streamed at the robot’s sensor sampling rate (typically several hundred Hz) and processed instantly by the DT for live friction monitoring."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "PT + encoders + motor current sensor → MQTT broker → digital shadow processing component (Simulink, data calculation) → AAS as asset model → dashboard displaying real‑time friction analysis and model comparison."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (conceptual modeling in SysML), implementation (creation of simulation and calculation models in Simulink), deployment (dashboard and MQTT integration), and operation (continuous live monitoring and friction model updates)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Combined white‑box and black‑box friction models allow continuous recalibration; model validity is assessed by comparing simulated torque/velocity traces to measured data (data trace provenance); limitations of each friction model type and sensor accuracy are acknowledged; uncertainty from load, temperature, and wear are considered through continuous identification."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol used for transmitting sensor streams to the DT; Asset Administration Shell provides standardized interfaces for data access and command publication."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for engineering models, Simulink for executable models, Asset Administration Shells for semantic data representation, and MQTT for data transport aligns with industrial IoT and DT standards."
]