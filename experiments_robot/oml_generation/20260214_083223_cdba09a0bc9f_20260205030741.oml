instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:desc "Manufacturing environment for MABI MAX 100 industrial robot operations"
    base:contains MABIMAX100FirstVerticalAxis
]

instance MABIMAX100FirstVerticalAxis : DTDFVocab:Component [
    base:desc "First vertical axis of MABI MAX 100 industrial robot, critical for precise motion control and friction modeling"
]

instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input current to the MABI MAX 100 robot's first vertical axis"
    DTDFVocab:producedData CurrentAndAngleDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring output angle of the MABI MAX 100 robot's first vertical axis"
    DTDFVocab:producedData CurrentAndAngleDataTransmitted
]

instance CurrentAndAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor, OutputAngleSensor
]

instance InputCurrentData : DTDFVocab:Data [
    base:desc "Real-time time series data of input current from MABI MAX 100 robot's first vertical axis"
    DTDFVocab:fromData CurrentAndAngleDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler, JavaEnabler, MontiArcAutomatonEnabler, SysMLStateMachineEnabler
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Real-time time series data of output angle from MABI MAX 100 robot's first vertical axis"
    DTDFVocab:fromData CurrentAndAngleDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler, JavaEnabler, MontiArcAutomatonEnabler, SysMLStateMachineEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for structural modeling (IBDs)"
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams (IBDs) for structural modeling of MABI MAX 100 robot's first vertical axis"
    DTDFVocab:inputTo SysMLEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME-based architecture description for component-and-connector structure of MABI MAX 100 robot"
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL-based architecture description for component-and-connector structure of MABI MAX 100 robot"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcArchitectureModel : DTDFVocab:Model [
    base:desc "MontiArc-based architecture description for component-and-connector structure of MABI MAX 100 robot"
    DTDFVocab:inputTo MontiArcADLEnabler
]

instance MontiArcBehavioralModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton-based behavioral modeling for MABI MAX 100 robot's first vertical axis"
    DTDFVocab:inputTo MontiArcAutomatonEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machine for behavioral modeling of MABI MAX 100 robot's first vertical axis"
    DTDFVocab:inputTo SysMLStateMachineEnabler
]

instance SimulinkAnalyticalModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink analytical model for multi-physics friction identification in MABI MAX 100 robot"
    DTDFVocab:inputTo SimulinkEnabler
]

instance CppAnalyticalModel : DTDFVocab:Model [
    base:desc "C++-based analytical model for detailed behavior of MABI MAX 100 robot's first vertical axis"
    DTDFVocab:inputTo CppEnabler
]

instance JavaAnalyticalModel : DTDFVocab:Model [
    base:desc "Java-based analytical model for detailed behavior of MABI MAX 100 robot's first vertical axis"
    DTDFVocab:inputTo JavaEnabler
]

instance RFLPMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "RFLP MBSE methodology for system modeling across abstraction levels"
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance OOSEMMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM MBSE methodology for system modeling across abstraction levels"
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance SPESMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "SPES MBSE methodology for system modeling across abstraction levels"
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance SMArDTMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT MBSE methodology for system modeling across abstraction levels"
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component-and-connector structure"
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component-and-connector structure"
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance MontiArcADLEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component-and-connector structure"
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral modeling and simulation"
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance SysMLStateMachineEnabler : DTDFVocab:Enabler [
    base:desc "SysML state machines for behavioral modeling"
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and analytical modeling"
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior implementation"
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior implementation"
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous, multi-physics-aware identification of joint friction for MABI MAX 100 robot's first vertical axis"
    DTDFVocab:provides MultiPhysicsFrictionInsight
]

instance MotionControlOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of robot motion control accuracy for MABI MAX 100 robot's first vertical axis"
    DTDFVocab:provides MotionControlOptimizationAction
]

instance MultiPhysicsFrictionInsight : DTDFVocab:Insight [
    base:desc "Multi-physics-aware identification of joint friction providing data-driven insights for refinement of robot performance"
]

instance MotionControlOptimizationAction : DTDFVocab:Action [
    base:desc "Predictive adjustments based on friction modeling to optimize robot motion control accuracy"
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Shadow system employs the reference model defined in Fig. 1 (UML class diagram), integrating SysML for functional architecture modeling (IBDs), Simulink for behavior simulation, and Asset Administration Shells (AAS) for data exchange and visualization."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for sensor data streaming; no details on network topology, bandwidth, latency, reliability, redundancy, or security protocols beyond the protocol usage are provided."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Data exchange occurs via MQTT protocol for live measurements and Asset Administration Shells (AAS) for structured data representation and visualization."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to industry standards including SysML for model-based systems engineering, ACME, AADL, and MontiArc as architecture description languages for component & connector perspectives, and methodologies such as RFLP, OOSEM, SPES, and SMArDT for multi-level abstraction management. It integrates heterogeneous stakeholders through standardized modeling practices, utilizing tools like Simulink and general-purpose programming languages (C++, Java) for detailed behavior modeling and simulation."
]