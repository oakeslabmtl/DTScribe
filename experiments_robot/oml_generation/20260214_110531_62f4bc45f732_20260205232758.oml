// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving the first vertical axis of MABI MAX 100 industrial robot, producing torque (τ_M) from input current (I_M) within [-90°, 90°] angular range and max 75°/s velocity."
]

instance GearWheel : DTDFVocab:ActingComponent [
    base:desc "Gearwheel component in the transmission system of the first axis, reducing speed and increasing torque output (τ_G) as part of the cycloidal gearbox mechanism."
]

instance CycloidalGearbox : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gearbox reducing backlash and increasing torque transmission efficiency for the first axis, producing output torque (τ_out) and angular position (q_out)."
]

instance Sinumerik840DController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl. CNC controller enabling separate axis control with configurable inputs/outputs for position, speed, and acceleration of the first vertical axis."
]

// C3: Physical Sensing Components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor current (I_M) for torque estimation using manufacturer-provided motor dynamics models."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Dual-position encoder measuring motor angular position (q_M) and velocity (ω_M) in real-time for backlash and elasticity analysis."
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearbox measuring output angular position (q_out) and velocity (ω_out) for positional accuracy and backlash reduction."
    DTDFVocab:producedData OutputPositionDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance OutputPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoder
]

instance DerivedTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorEncoder
]

instance DerivedVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder, SecondaryEncoder
]

// C10: Models/Data
instance SysMLFirstAxisBDD : DTDFVocab:Model [
    base:desc "SysML Block Definition Diagram describing the structural composition of the first vertical axis including Motor, GearWheel, and CycloidalGearbox components with rotational/current flows."
]

instance SysMLFirstAxisIBD : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram illustrating behavioral interactions between Motor, GearWheel, and CycloidalGearbox components for friction analysis."
]

instance AssetAdministrationShell : DTDFVocab:Model [
    base:desc "Asset Administration Shell providing contextual metadata for the first axis including system properties and configuration at creation time."
]

instance TorqueDerivationModel : DTDFVocab:Model [
    base:desc "Data calculation model deriving torque (τ_M) from motor current (I_M) using manufacturer-provided dynamics models."
]

instance VelocityDerivationModel : DTDFVocab:Model [
    base:desc "Data calculation model deriving angular velocity (ω_M, ω_G, ω_out) from encoder measurements using gear ratio constants."
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction model implementing Coulomb-Viscous friction characteristics for dynamic exchange during operation."
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction model implementing Stribeck effect for dynamic friction behavior analysis."
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction model implementing Dahl model for hysteresis and nonlinear friction characteristics."
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction model implementing LuGre model for detailed friction dynamics including stiction and breakaway behavior."
]

instance IdealGearboxSimulation : DTDFVocab:Model [
    base:desc "MATLAB/Simulink simulation model representing ideal gearbox behavior without friction for baseline comparison."
]

instance MotorSimulation : DTDFVocab:Model [
    base:desc "MATLAB/Simulink simulation model representing ideal motor behavior (Simulation M) for friction analysis."
]

instance GearWheelSimulation : DTDFVocab:Model [
    base:desc "MATLAB/Simulink simulation model representing ideal gearwheel behavior (Simulation GW) for friction analysis."
]

instance GearboxSimulation : DTDFVocab:Model [
    base:desc "MATLAB/Simulink simulation model representing ideal cycloidal gearbox behavior (Simulation GB) for friction analysis."
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current (I_M) data streamed via MQTT from the SINUMERIK 840D controller."
    DTDFVocab:fromData MotorCurrentDataTransmitted
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Measured motor angular position (q_M) and velocity (ω_M) data from MotorEncoder via MQTT."
    DTDFVocab:fromData MotorPositionDataTransmitted
]

instance OutputPositionData : DTDFVocab:Data [
    base:desc "Measured output angular position (q_out) and velocity (ω_out) data from SecondaryEncoder via MQTT."
    DTDFVocab:fromData OutputPositionDataTransmitted
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Derived torque values (τ_M, τ_G, τ_out) calculated from current and encoder data using manufacturer dynamics models."
    DTDFVocab:fromData DerivedTorqueDataTransmitted
]

instance DerivedVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocities (ω_M, ω_G, ω_out) calculated from encoder data using gear ratio constants."
    DTDFVocab:fromData DerivedVelocityDataTransmitted
]

instance SimulatedMotorPositionData : DTDFVocab:Data [
    base:desc "Simulated motor position data (δr_M) accounting for friction effects from MotorSimulation model."
]

instance SimulatedGearWheelPositionData : DTDFVocab:Data [
    base:desc "Simulated gearwheel position data (δr_G) accounting for friction effects from GearWheelSimulation model."
]

instance SimulatedGearboxPositionData : DTDFVocab:Data [
    base:desc "Simulated gearbox output position data (δr_out) accounting for friction effects from GearboxSimulation model."
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML Block Definition and Internal Block Diagrams for structural/behavioral modeling of the first axis components."
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for executable simulation models including ideal behavior and various friction models (Coulomb-Viscous, Stribeck, Dahl, LuGre)."
]

instance MQTTProtocolEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol enabling real-time sensor data streaming from SINUMERIK 840D controller to Digital Shadow."
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell providing metadata management and contextual data linking for the first axis components."
]

instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard integrating data traces, models, and processing components for friction analysis visualization."
]

// C6: Services
instance FrictionDerivationService : DTDFVocab:Service [
    base:desc "Real-time friction identification service combining white-box (analytical) and black-box (data-driven) models for continuous model refinement."
]

instance StructuralAnalysisService : DTDFVocab:Service [
    base:desc "SysML-based structural analysis service providing insights into component interactions and friction effects within the first axis."
]

instance MultiPhysicsSimulationService : DTDFVocab:Service [
    base:desc "Multi-physics-aware simulation service modeling joint friction effects using MATLAB/Simulink friction models subtracted from ideal behavior simulations."
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Service integrating time-series data traces with engineering models and simulation models for friction analysis."
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring live sensor data and simulated outputs for real-time friction deviation detection."
]

instance FrictionVisualizationService : DTDFVocab:Service [
    base:desc "Service visualizing friction analysis results including data traces, models, and processing components on the dashboard."
]

instance OperationalInsightService : DTDFVocab:Service [
    base:desc "Service providing insights into friction-induced motion inaccuracies and control optimization opportunities."
]

instance ModelContextualizationService : DTDFVocab:Service [
    base:desc "Service providing contextual metadata management and linking for the first axis components."
]

// C17: Insights/Actions
instance StaticFrictionInsight : DTDFVocab:Insight [
    base:desc "Real-time identification of static friction coefficients for model refinement and wear detection."
]

instance KineticFrictionInsight : DTDFVocab:Insight [
    base:desc "Real-time identification of kinetic friction coefficients accounting for velocity-dependent effects."
]

instance ViscousFrictionInsight : DTDFVocab:Insight [
    base:desc "Real-time identification of viscous friction coefficients for damping analysis."
]

instance FrictionParameterUpdateAction : DTDFVocab:Action [
    base:desc "Automatic update of friction model parameters based on live data to adapt to wear, temperature, or load changes."
    DTDFVocab:IsAutomatic true
]

instance ComponentInteractionInsight : DTDFVocab:Insight [
    base:desc "Insights into structural interactions between Motor, GearWheel, and CycloidalGearbox components affecting friction."
]

instance StructuralDeviationInsight : DTDFVocab:Insight [
    base:desc "Analysis of deviations between ideal structural behavior and actual measurements due to friction effects."
]

instance FrictionEffectSimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results showing the impact of friction models (Coulomb-Viscous, Stribeck, Dahl, LuGre) on system behavior."
]

instance MultiPhysicsValidationInsight : DTDFVocab:Insight [
    base:desc "Validation metrics comparing simulated outputs (δr_M, δr_G, δr_out) with reference measurements (r_M, r_G, r_out)."
]

instance DataTraceIntegrationInsight : DTDFVocab:Insight [
    base:desc "Insights into the integration of time-series data traces with engineering models for semantic support."
]

instance ModelDataLinkingInsight : DTDFVocab:Insight [
    base:desc "Traceability insights linking data sources to specific models within the Digital Shadow Reference Model."
]

instance RealTimeDeviationInsight : DTDFVocab:Insight [
    base:desc "Real-time detection of deviations between simulated and measured outputs indicating friction anomalies."
]

instance OperationalStatusInsight : DTDFVocab:Insight [
    base:desc "Current operational status including system health and friction-induced performance metrics."
]

instance FrictionAnalysisVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of friction analysis results including data traces, model outputs, and processing components."
]

instance OperationalTrendInsight : DTDFVocab:Insight [
    base:desc "Trend analysis of operational data showing friction behavior over time and operational conditions."
]

instance MotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantitative analysis of motion inaccuracies caused by friction affecting machining precision."
]

instance ControlOptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for control parameter adjustments to mitigate friction-induced deviations."
]

instance AssetContextInsight : DTDFVocab:Insight [
    base:desc "Insights into asset metadata and contextual information linking for the first axis components."
]

// Relationships
// Data Flow Connections
DTDFVocab:DataTransmitted MotorCurrentDataTransmitted [
    DTDFVocab:fromData MotorCurrentData
]

DTDFVocab:DataTransmitted MotorPositionDataTransmitted [
    DTDFVocab:fromData MotorPositionData
]

DTDFVocab:DataTransmitted OutputPositionDataTransmitted [
    DTDFVocab:fromData OutputPositionData
]

DTDFVocab:DataTransmitted DerivedTorqueDataTransmitted [
    DTDFVocab:fromData DerivedTorqueData
]

DTDFVocab:DataTransmitted DerivedVelocityDataTransmitted [
    DTDFVocab:fromData DerivedVelocityData
]

// Model/Data Input Connections
DTDFVocab:Model SysMLFirstAxisBDD [
    DTDFVocab:inputTo SysMLModelingEnabler
]

DTDFVocab:Model SysMLFirstAxisIBD [
    DTDFVocab:inputTo SysMLModelingEnabler
]

DTDFVocab:Model AssetAdministrationShell [
    DTDFVocab:inputTo AssetAdministrationShellEnabler
]

DTDFVocab:Model TorqueDerivationModel [
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

DTDFVocab:Model VelocityDerivationModel [
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

DTDFVocab:Model CoulombViscousFrictionModel [
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

DTDFVocab:Model StribeckFrictionModel [
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

DTDFVocab:Model DahlFrictionModel [
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

DTDFVocab:Model LuGreFrictionModel [
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

DTDFVocab:Model IdealGearboxSimulation [
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

DTDFVocab:Model MotorSimulation [
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

DTDFVocab:Model GearWheelSimulation [
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

DTDFVocab:Model GearboxSimulation [
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

DTDFVocab:Data MotorCurrentData [
    DTDFVocab:inputTo TorqueDerivationModel, VelocityDerivationModel
]

DTDFVocab:Data MotorPositionData [
    DTDFVocab:inputTo VelocityDerivationModel
]

DTDFVocab:Data OutputPositionData [
    DTDFVocab:inputTo VelocityDerivationModel
]

DTDFVocab:Data DerivedTorqueData [
    DTDFVocab:inputTo CoulombViscousFrictionModel, StribeckFrictionModel, DahlFrictionModel, LuGreFrictionModel
]

DTDFVocab:Data DerivedVelocityData [
    DTDFVocab:inputTo CoulombViscousFrictionModel, StribeckFrictionModel, DahlFrictionModel, LuGreFrictionModel
]

DTDFVocab:Data SimulatedMotorPositionData [
    DTDFVocab:inputTo DashboardVisualizationEnabler
]

DTDFVocab:Data SimulatedGearWheelPositionData [
    DTDFVocab:inputTo DashboardVisualizationEnabler
]

DTDFVocab:Data SimulatedGearboxPositionData [
    DTDFVocab:inputTo DashboardVisualizationEnabler
]

// Enabler Connections
DTDFVocab:Enabler SysMLModelingEnabler [
    DTDFVocab:enables StructuralAnalysisService
]

DTDFVocab:Enabler MATLABSimulinkEnabler [
    DTDFVocab:enables MultiPhysicsSimulationService
]

DTDFVocab:Enabler MQTTProtocolEnabler [
    DTDFVocab:enables DataIntegrationService, RealTimeMonitoringService
]

DTDFVocab:Enabler AssetAdministrationShellEnabler [
    DTDFVocab:enables ModelContextualizationService
]

DTDFVocab:Enabler DashboardVisualizationEnabler [
    DTDFVocab:enables FrictionVisualizationService, OperationalInsightService
]

// Service Connections
DTDFVocab:Service FrictionDerivationService [
    DTDFVocab:provides StaticFrictionInsight, KineticFrictionInsight, ViscousFrictionInsight, FrictionParameterUpdateAction
]

DTDFVocab:Service StructuralAnalysisService [
    DTDFVocab:provides ComponentInteractionInsight, StructuralDeviationInsight
]

DTDFVocab:Service MultiPhysicsSimulationService [
    DTDFVocab:provides FrictionEffectSimulationInsight, MultiPhysicsValidationInsight
]

DTDFVocab:Service DataIntegrationService [
    DTDFVocab:provides DataTraceIntegrationInsight, ModelDataLinkingInsight
]

DTDFVocab:Service RealTimeMonitoringService [
    DTDFVocab:provides RealTimeDeviationInsight, OperationalStatusInsight
]

DTDFVocab:Service FrictionVisualizationService [
    DTDFVocab:provides FrictionAnalysisVisualizationInsight, OperationalTrendInsight
]

DTDFVocab:Service OperationalInsightService [
    DTDFVocab:provides MotionAccuracyInsight, ControlOptimizationInsight
]

DTDFVocab:Service ModelContextualizationService [
    DTDFVocab:provides ModelDataLinkingInsight, AssetContextInsight
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin operates on a **real-time, continuous time scale**, synchronized with the physical system’s operational frequency. Key time-scale specifics include:
  - **Sensor data acquisition rate**: Not explicitly stated, but implied to be **high-frequency** (e.g., ≥1 kHz for encoder data) to capture dynamic friction effects.
  - **Model update frequency**: Dynamic exchange of friction models occurs **during operation** to adapt to wear, temperature, or load changes.
  - **Dashboard refresh rate**: Visualization updates in **real-time** to reflect live data and processed friction analysis."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation is orchestrated as follows:
  - **Centralized processing**: All simulation models (*Simulation M*, *Simulation GW*, *Simulation GB*) and data traces are managed within a unified **digital shadow** framework (FrictionShadow).
  - **Data flow**:
    1. Physical sensors (encoders, current sensors) → **MQTT** → Digital Shadow (data traces).
    2. Data traces → **Processing components** (simulation models) → Simulated outputs.
    3. Simulated outputs → **Comparison with reference data** → Friction analysis.
  - **Component interactions**:
    - **Sources** (sensors/calculations) feed data traces into **Processing components** (simulation models).
    - **Models** (engineering, simulation) are linked to **assets** (Mabi robot axis) via SysML descriptions.
    - **Metadata** (e.g., system properties) is stored separately for traceability.
  - **Visualization**: Dashboard aggregates all data traces, models, and processing results for operational insights."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin covers the **operational phase** of the physical system’s life cycle, focusing on **as-operated** representation:
  - **Design phase**: Not explicitly addressed; the DT is built post-deployment for **continuous improvement** of motion accuracy.
  - **Manufacturing phase**: Not applicable; the DT targets **runtime friction analysis** during machining operations.
  - **Operational phase**: Primary focus on **real-time friction modeling and control optimization** via live data integration. The DT enables **adaptive model updates** to account for wear, tool changes, or environmental factors (e.g., temperature)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
  - **Model Validation**:
    - **Comparison of simulated outputs (ˆ*r_M*, ˆ*r_G*, ˆ*r_out*)** with **reference measurements** (*r_M*, *r_G*, *r_out*) to quantify friction-induced deviations.
    - **Uncertainty analysis** via backlash reduction using dual encoders and manufacturer-provided motor constants.
  - **Verification Mechanisms**:
    - **Traceability** of data traces to their **sources** (sensors/calculations) and **processing components** (simulation models).
    - **Metadata** (e.g., system properties, time stamps) for contextual validation.
  - **Error Handling**:
    - **Dynamic model exchange** mitigates parameter drift due to wear or environmental changes.
    - **Friction models** (white-box/black-box) are validated against **operational data** to ensure accuracy over time.
  - **Uncertainty Sources**:
    - **Sensor noise** in encoder/current measurements.
    - **Model simplifications** (e.g., ideal gearbox behavior assumptions).
    - **Parameter variability** (e.g., temperature-dependent friction coefficients)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection between the physical twin (PT) and digital twin (DT) includes:
  - **Network Protocol**: **MQTT** for **real-time sensor data streaming** (e.g., *I_M*, *q_out*) from the Siemens SINUMERIK 840D sl. CNC controller to the digital shadow.
  - **Data Format**: **Time-series data traces** (arrays of torque/velocity values) with **metadata** (source, time stamps).
  - **Synchronization**: **Continuous, one-way data flow** from PT to DT (digital shadow) with **no feedback control** (as per digital shadow definition).
  - **Latency**: Implicitly low-latency due to MQTT’s real-time capabilities and operational requirements."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is **hosted in a centralized computational environment** supporting:
  - **Simulation Software**: **MATLAB/Simulink** for executable friction models.
  - **Data Processing**: **Processing components** (e.g., *Simulation M*) running on a **local or cloud-based server** (not specified).
  - **Visualization**: **Dashboard** integrated with the digital shadow framework for operational monitoring.
  - **Deployment Architecture**:
    - **Physical Layer**: Siemens SINUMERIK 840D sl. CNC controller with embedded sensors.
    - **Virtual Layer**: Digital shadow framework (DSRM concretization) with **SysML models**, **Simulink simulations**, and **MQTT integration**.
    - **No remote actuation**: The DT is **passive** (digital shadow) and does not send commands back to the PT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin adheres to the following standards:
  - **SysML** (OMG standard) for **system modeling** (Block Definition Diagrams, Internal Block Diagrams).
  - **Asset Administration Shell (AAS)** (Industry 4.0 standard) for **metadata management** and **contextual data linking**.
  - **MQTT** (OASIS standard) for **real-time data streaming** from the CNC controller to the digital shadow.
  - **Model-Based Systems Engineering (MBSE)** methodologies (e.g., RFLP, OOSEM) for **multi-physics modeling**."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The digital twin incorporates the following security and safety considerations:
  - **Passive Operation**: As a **digital shadow**, the DT does not execute **remote commands** on the physical system, eliminating direct safety risks (e.g., human accidents).
  - **Data Integrity**: **MQTT-based streaming** ensures **encrypted data transmission** (implied by industrial standards) to prevent tampering.
  - **Access Control**: **Asset Administration Shell (AAS)** metadata includes **system properties** for configuration validation, reducing unauthorized access risks.
  - **Safety Constraints**:
    - **Operational limits** (e.g., axis range [-90°, 90°], max speed 75°/s) are enforced by the **CNC controller**, not the DT.
    - **No feedback loop**: The DT does not alter physical behavior, mitigating safety hazards from virtual-to-physical interactions.
  - **Cybersecurity**: While not explicitly detailed, **industrial-grade protocols** (MQTT, AAS) are assumed to follow **IEC 62443** standards for cybersecurity in manufacturing."
]