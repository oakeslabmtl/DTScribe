// C1: Environments/Components
instance InjectionMoldingEnvironment : DTDFVocab:Environment [
    base:contains InjectionUnitComponent, ClampingUnitComponent, CoolingSystemComponent, MoldComponent
]

instance InjectionUnitComponent : DTDFVocab:Component [
    base:desc "Primary injection mechanism responsible for material pressurization and flow during molding cycles, equipped with pressure and temperature sensors."
    base:contains PressureTransducer, ThermalFlowSensor
]

instance ClampingUnitComponent : DTDFVocab:Component [
    base:desc "Component providing clamping force during injection molding, monitored for stability and wear through load sensors."
    base:contains LoadPayloadSensor
]

instance CoolingSystemComponent : DTDFVocab:Component [
    base:desc "Thermal management system maintaining part quality through controlled cooling, with embedded temperature sensors."
    base:contains EnvironmentalTemperatureSensor
]

instance MoldComponent : DTDFVocab:Component [
    base:desc "Final component shape defining the molded part geometry, equipped with sensors for cycle time and quality monitoring."
    base:contains CycleTimeSensor
]

instance RoboticSystemEnvironment : DTDFVocab:Environment [
    base:contains RoboticArmComponent, JointComponent
]

instance RoboticArmComponent : DTDFVocab:Component [
    base:desc "Robotic arm system performing material handling and positioning tasks in manufacturing processes."
]

instance JointComponent : DTDFVocab:Component [
    base:desc "Articulated joint system in robotic arms requiring dynamic friction modeling for precise motion control."
    base:contains JointFrictionSensor
]

