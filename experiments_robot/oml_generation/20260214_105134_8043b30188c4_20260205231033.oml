    base:desc "Automatic adjustment of process parameters to compensate for dynamic friction variations, maintaining system stability."
    DTDFVocab:IsAutomatic true
]

instance FrictionPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted friction characteristics under varying operational conditions, supporting proactive process optimization."
]

