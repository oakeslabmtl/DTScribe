// C3: Physical Sensing Components
instance JointFrictionSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency sensor capturing real-time joint friction measurements for dynamic model adaptation in robotic systems, with millisecond-level sampling requirements for predictive maintenance and fault detection."
    DTDFVocab:producedData JointFrictionDataTransmitted
]

instance EnvironmentalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the CPS to capture environmental conditions affecting friction characteristics and process stability in injection molding operations."
    DTDFVocab:producedData EnvironmentalTemperatureDataTransmitted
]

instance LoadPayloadSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring operational load and payload conditions to enable dynamic compensation in friction modeling and process optimization."
    DTDFVocab:producedData LoadPayloadDataTransmitted
]

instance PressureTransducer : DTDFVocab:SensingComponent [
    base:desc "High-precision pressure sensor capturing real-time pressure data during injection molding cycles for process monitoring and quality control."
    DTDFVocab:producedData PressureDataTransmitted
]

instance CycleTimeSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor tracking injection molding cycle times to enable real-time performance monitoring and optimization of production throughput."
    DTDFVocab:producedData CycleTimeDataTransmitted
]

instance ThermalFlowSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring thermal flow characteristics during injection molding to support predictive maintenance and defect prevention."
    DTDFVocab:producedData ThermalFlowDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance JointFrictionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointFrictionSensor
    DTDFVocab:transmissionProtocol MQTTProtocolEnabler
    DTDFVocab:transmissionFrequency MillisecondLevel
    DTDFVocab:eventTrigger SensorThresholds
]

instance EnvironmentalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalTemperatureSensor
    DTDFVocab:transmissionProtocol MQTTProtocolEnabler
    DTDFVocab:transmissionFrequency SecondLevel
    DTDFVocab:eventTrigger ScheduledIntervals
]

instance LoadPayloadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadPayloadSensor
    DTDFVocab:transmissionProtocol MQTTProtocolEnabler
    DTDFVocab:transmissionFrequency MillisecondLevel
    DTDFVocab:eventTrigger OperationalStateChanges
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureTransducer
    DTDFVocab:transmissionProtocol MQTTProtocolEnabler
    DTDFVocab:transmissionFrequency MillisecondLevel
    DTDFVocab:eventTrigger SensorThresholds
]

instance CycleTimeDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CycleTimeSensor
    DTDFVocab:transmissionProtocol MQTTProtocolEnabler
    DTDFVocab:transmissionFrequency CycleLevel
    DTDFVocab:eventTrigger InjectionCycleCompletion
]

instance ThermalFlowDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ThermalFlowSensor
    DTDFVocab:transmissionProtocol MQTTProtocolEnabler
    DTDFVocab:transmissionFrequency SecondLevel
    DTDFVocab:eventTrigger ScheduledIntervals
]

// C10: Models/Data
instance PhysicsBasedFrictionModel : DTDFVocab:Model [
    base:desc "White-box Simulink-based dynamic simulation model capturing nonlinear friction phenomena in robotic systems, dynamically adapted via continuous data streams to compensate for wear and temperature variations."
    DTDFVocab:inputTo SimulinkProcessingEnabler
]

instance DataDrivenFrictionModel : DTDFVocab:Model [
    base:desc "Black-box machine learning model trained on historical friction data to predict nonlinear friction characteristics under varying operational conditions."
    DTDFVocab:inputTo MachineLearningEnabler
]

instance InjectionMoldingProcessModel : DTDFVocab:Model [
    base:desc "Engineering model combining discrete-event and continuous-time simulations for injection molding processes, integrating thermal/fluid behavior and production scheduling."
    DTDFVocab:inputTo SimulinkProcessingEnabler, DEVSSchedulingEnabler
]

instance QualityControlModel : DTDFVocab:Model [
    base:desc "Data calculation model performing statistical analysis and defect prediction based on sensor data traces to enable automated quality control in injection molding."
    DTDFVocab:inputTo DataProcessingEnabler
]

instance JointFrictionData : DTDFVocab:Data [
    base:desc "Aggregated time-series data traces of joint friction measurements with contextual metadata supporting traceability to source sensors and processing components."
    DTDFVocab:fromData JointFrictionDataTransmitted
    DTDFVocab:inputTo DataDrivenFrictionModel, PhysicsBasedFrictionModel
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Structured environmental data including temperature readings with quality flags and timestamps, supporting purpose-driven processing for process optimization."
    DTDFVocab:fromData EnvironmentalTemperatureDataTransmitted
    DTDFVocab:inputTo InjectionMoldingProcessModel
]

instance OperationalLoadData : DTDFVocab:Data [
    base:desc "Process load and payload data traces with metadata enabling traceability to operational conditions affecting process stability and component wear."
    DTDFVocab:fromData LoadPayloadDataTransmitted
    DTDFVocab:inputTo PhysicsBasedFrictionModel, QualityControlModel
]

instance PressureData : DTDFVocab:Data [
    base:desc "Real-time pressure data traces with millisecond-level resolution supporting process monitoring and quality control in injection molding."
    DTDFVocab:fromData PressureDataTransmitted
    DTDFVocab:inputTo InjectionMoldingProcessModel, QualityControlModel
]

instance CycleTimeData : DTDFVocab:Data [
    base:desc "Historical and real-time cycle time data with metadata supporting production scheduling and throughput optimization."
    DTDFVocab:fromData CycleTimeDataTransmitted
    DTDFVocab:inputTo DEVSSchedulingEnabler
]

instance ThermalFlowData : DTDFVocab:Data [
    base:desc "Thermal flow characteristics data traces supporting predictive maintenance and defect prevention in injection molding processes."
    DTDFVocab:fromData ThermalFlowDataTransmitted
    DTDFVocab:inputTo InjectionMoldingProcessModel
]

// C11: Enablers
instance SimulinkProcessingEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation engine executing dynamic system models for friction compensation and process simulation in injection molding."
    DTDFVocab:enables ProcessMonitoringService, FrictionCompensationService
]

instance MachineLearningEnabler : DTDFVocab:Enabler [
    base:desc "Data-driven processing framework implementing neural networks and machine learning algorithms for friction prediction and process optimization."
    DTDFVocab:enables FrictionPredictionService, DefectPredictionService
]

instance DEVSSchedulingEnabler : DTDFVocab:Enabler [
    base:desc "Discrete-event simulation framework for production scheduling and workflow modeling in manufacturing systems."
    DTDFVocab:enables ProductionSchedulingService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Data calculation engine performing statistical analysis, anomaly detection, and data normalization for quality control and predictive maintenance."
    DTDFVocab:enables QualityControlService, PredictiveMaintenanceService
]

instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based architecture modeling tool enabling functional and logical architecture description of CPS components and behaviors."
    DTDFVocab:enables ArchitectureDesignService
]

instance ThingsBoardIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Cloud-based IoT platform integrating heterogeneous data sources via adapters and middleware for unified digital twin data aggregation."
    DTDFVocab:enables DataAggregationService
]

instance MQTTProtocolEnabler : DTDFVocab:Enabler [
    base:desc "Message Queuing Telemetry Transport protocol enabling lightweight, publish-subscribe data transmission from physical sensors to digital twin components."
    DTDFVocab:enables RealTimeDataTransmissionService
]

// C6: Services
instance ProcessMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring service aggregating and abstracting sensor data traces to provide operational insights for injection molding processes."
    DTDFVocab:provides OperationalInsight, AnomalyDetectionInsight
]

instance FrictionCompensationService : DTDFVocab:Service [
    base:desc "Dynamic friction compensation service adjusting process parameters based on real-time friction modeling to maintain system stability."
    DTDFVocab:provides FrictionCompensationAction
]

instance FrictionPredictionService : DTDFVocab:Service [
    base:desc "Predictive friction analysis service forecasting friction characteristics under varying operational conditions using machine learning."
    DTDFVocab:provides FrictionPredictionInsight
]

instance DefectPredictionService : DTDFVocab:Service [
    base:desc "Defect prediction service analyzing sensor data traces to forecast potential defects in injection molded parts before they occur."
    DTDFVocab:provides DefectPredictionInsight
]

instance ProductionSchedulingService : DTDFVocab:Service [
    base:desc "Production scheduling optimization service integrating cycle time data with discrete-event simulations for efficient resource allocation."
    DTDFVocab:provides SchedulingRecommendationInsight
]

instance QualityControlService : DTDFVocab:Service [
    base:desc "Automated quality control service performing real-time statistical analysis of process data to ensure product conformance."
    DTDFVocab:provides QualityAssuranceInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance service analyzing wear patterns and operational data to estimate remaining useful life of critical components."
    DTDFVocab:provides MaintenanceRecommendationInsight
]

instance ArchitectureDesignService : DTDFVocab:Service [
    base:desc "Systems engineering service enabling functional and logical architecture modeling of CPS components using SysML and ADLs."
    DTDFVocab:provides ArchitectureDesignInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Data integration service consolidating heterogeneous data sources via middleware for unified digital twin data processing."
    DTDFVocab:provides UnifiedDataInsight
]

instance RealTimeDataTransmissionService : DTDFVocab:Service [
    base:desc "Real-time data transmission service ensuring efficient, low-latency transfer of sensor data from physical systems to digital twin components."
    DTDFVocab:provides TransmissionEfficiencyInsight
]

