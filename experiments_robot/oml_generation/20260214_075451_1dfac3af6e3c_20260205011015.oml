instance PhysicalSystem : DTDFVocab:SensingComponent [
    base:desc "Physical system providing state data for digital shadow reference model"
    DTDFVocab:producedData PhysicalSystemStateDataTransmitted
]

instance PhysicalSystemStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystem
]

instance PhysicalSystemStateData : DTDFVocab:Data [
    base:desc "Physical system state data transmitted via automated one-way flow"
    DTDFVocab:fromData PhysicalSystemStateDataTransmitted
]

instance SysMLIBDStructuralModel : DTDFVocab:Model [
    base:desc "Structural model using SysML IBDs for component & connector-based system descriptions"
    DTDFVocab:inputTo SysMLMBSE
]

instance ACMEStructuralModel : DTDFVocab:Model [
    base:desc "Structural model using ACME architecture description language"
    DTDFVocab:inputTo ACMEADL
]

instance AADLStructuralModel : DTDFVocab:Model [
    base:desc "Structural model using AADL architecture description language"
    DTDFVocab:inputTo AADLADL
]

instance MontiArcStructuralModel : DTDFVocab:Model [
    base:desc "Structural model using MontiArc ADL for component & connector descriptions"
    DTDFVocab:inputTo MontiArcADL
]

instance MontiArcAutomatonBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model using MontiArc Automaton for detailed behavior specification"
    DTDFVocab:inputTo MontiArcAutomaton
]

instance SysMLStateMachineBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model using SysML v1.7 state machines"
    DTDFVocab:inputTo SysMLStateMachine
]

instance SimulinkAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model using MathWorks Simulink for simulation and analysis"
    DTDFVocab:inputTo Simulink
]

instance CppJavaGeneralPurposeCodeModel : DTDFVocab:Model [
    base:desc "Analytical model implemented in general-purpose programming languages (C++ or Java)"
    DTDFVocab:inputTo CppProgrammingLanguage, JavaProgrammingLanguage
]

instance SysMLMBSE : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering using SysML for system structure modeling"
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP methodology for hierarchical abstraction levels"
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for hierarchical abstraction levels"
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for hierarchical abstraction levels"
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for hierarchical abstraction levels"
]

instance ACMEADL : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component & connector-based system descriptions"
]

instance AADLADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component & connector-based system descriptions"
]

instance MontiArcADL : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component & connector-based system descriptions"
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavior modeling"
]

instance SysMLStateMachine : DTDFVocab:Enabler [
    base:desc "SysML v1.7 state machines for behavior modeling"
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and behavior detailing"
]

instance CppProgrammingLanguage : DTDFVocab:Enabler [
    base:desc "C++ general-purpose programming language for behavior detailing"
]

instance JavaProgrammingLanguage : DTDFVocab:Enabler [
    base:desc "Java general-purpose programming language for behavior detailing"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to industry standards including SysML for system modeling (including IBDs), AADL, ACME, and MontiArc as architecture description languages, and methodologies such as RFLP (Requirements, Functions, Logics, Physics), OOSEM, SPES, and SMArDT for managing system complexity and integrating heterogeneous stakeholders."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The system implements X.509 certificate-based authentication and TLS encryption for secure communication within the Asset Administration Shell (AAS) framework [50], MQTT protocol with TLS encryption for message transmission using Mosquitto [52], and role-based access control (RBAC) in Thingsboard [53] for user permissions management."
]