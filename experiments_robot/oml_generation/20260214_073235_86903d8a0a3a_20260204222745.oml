// C3: Physical sensing components
instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Internal current sensor generates raw measurement data (input current) from the robot joint."
    DTDFVocab:producedData CurrentDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor angular velocity of each robot joint."
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor providing first‑axis position measurement of the manipulator."
    DTDFVocab:producedData PositionDataTransmitted
]

instance FrictionSensor : DTDFVocab:SensingComponent [
    base:desc "Joint friction sensor continuously streaming friction data."
    DTDFVocab:producedData FrictionDataTransmitted
]

instance LoadSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring joint load (force/torque) during machining."
    DTDFVocab:producedData LoadDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor reporting joint temperature for thermal effects on friction."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

instance FrictionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FrictionSensor
]

instance LoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C10: Data (processed)
instance CurrentData : DTDFVocab:Data [
    base:desc "Filtered current measurement formatted as JSON."
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo ProcessingEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Processed angular velocity data ready for model consumption."
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo ProcessingEnabler
]

instance PositionData : DTDFVocab:Data [
    base:desc "Processed position data in JSON format."
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo ProcessingEnabler
]

instance FrictionData : DTDFVocab:Data [
    base:desc "Pre‑processed friction measurement for modeling."
    DTDFVocab:fromData FrictionDataTransmitted
    DTDFVocab:inputTo ProcessingEnabler
]

instance LoadData : DTDFVocab:Data [
    base:desc "Filtered load data for friction compensation calculations."
    DTDFVocab:fromData LoadDataTransmitted
    DTDFVocab:inputTo ProcessingEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature data after low‑pass filtering, used for parameter updates."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo ProcessingEnabler
]

// C11: Enablers
instance ProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that consumes input traces, applies physics‑based or neural‑network models, and emits output traces for the digital shadow."
    DTDFVocab:enables RealTimeFrictionMonitoring,
                     PredictiveFrictionModeling,
                     FrictionCompensationControl,
                     PredictiveMaintenanceService,
                     FaultDetectionService,
                     SimulationOptimizationService,
                     ProductQualityPredictionService,
                     DataVisualizationService
]

instance AASExecutorEnabler : DTDFVocab:Enabler [
    base:desc "AAS Executor pushes measured, simulated, and reference values into the ThingsBoard database."
]

instance ThingsBoardEnabler : DTDFVocab:Enabler [
    base:desc "ThingsBoard instance stores all traces and model results for historical analysis and real‑time updates."
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker (e.g., Mosquitto) forwards JSON messages from sensors to the AAS Executor and ThingsBoard."
]

// C10: Models/Data
instance JointFrictionWhiteBoxModel : DTDFVocab:Model [
    base:desc "Physics‑based white‑box Simulink dynamic simulation of robot joint friction."
    DTDFVocab:inputTo ProcessingEnabler
]

instance JointFrictionBlackBoxModel : DTDFVocab:Model [
    base:desc "Data‑driven black‑box neural‑network estimator for joint friction, continuously updated from sensor streams."
    DTDFVocab:inputTo ProcessingEnabler
]

instance SystemStructureEngineeringModel : DTDFVocab:Model [
    base:desc "Engineering model describing the system structure of the robotic manipulator."
    DTDFVocab:inputTo ProcessingEnabler
]

instance DynamicBehaviourSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model representing dynamic behaviour of the robot for real‑time calculations."
    DTDFVocab:inputTo ProcessingEnabler
]

instance ParameterUpdateDataCalculationModel : DTDFVocab:Model [
    base:desc "Data‑calculation model updating parameters (e.g., friction coefficients) based on processed data."
    DTDFVocab:inputTo ProcessingEnabler
]

// C6: Services
instance RealTimeFrictionMonitoring : DTDFVocab:Service [
    base:desc "Real‑time monitoring of internal joint friction."
    DTDFVocab:provides RealTimeFrictionInsight
]

instance PredictiveFrictionModeling : DTDFVocab:Service [
    base:desc "Predictive modeling of friction behavior for future operating conditions."
    DTDFVocab:provides PredictiveFrictionInsight
]

instance FrictionCompensationControl : DTDFVocab:Service [
    base:desc "Control‑level compensation of identified friction during runtime."
    DTDFVocab:provides FrictionCompensationAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance service that flags anomalous friction patterns."
    DTDFVocab:provides AnomalyDetectionInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection service for early detection of joint issues."
    DTDFVocab:provides FaultDetectionInsight
]

instance SimulationOptimizationService : DTDFVocab:Service [
    base:desc "Simulation‑based optimization to tune machining parameters and reduce CO₂ emissions."
    DTDFVocab:provides CO2EmissionReductionInsight
]

instance ProductQualityPredictionService : DTDFVocab:Service [
    base:desc "Product‑quality prediction based on production data."
    DTDFVocab:provides QualityPredictionInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Visualization of measured, simulated, and reference values stored in the digital shadow."
    DTDFVocab:provides VisualizationAction
]

// C17: Insights
instance RealTimeFrictionInsight : DTDFVocab:Insight [
    base:desc "Insight providing current friction level for immediate monitoring."
]

instance PredictiveFrictionInsight : DTDFVocab:Insight [
    base:desc "Insight forecasting future friction behavior based on model predictions."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting anomalous friction patterns indicating potential failures."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight identifying fault conditions from sensor data."
]

instance CO2EmissionReductionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating potential CO₂ emission reduction from optimized machining parameters."
]

instance QualityPredictionInsight : DTDFVocab:Insight [
    base:desc "Insight predicting product quality outcomes."
]

// C17: Actions
instance FrictionCompensationAction : DTDFVocab:Action [
    base:desc "Action to apply compensation torque to counteract estimated friction."
    DTDFVocab:IsAutomatic true
]

instance VisualizationAction : DTDFVocab:Action [
    base:desc "Action to render dashboards visualizing measured, simulated, and reference data."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in (near) real‑time: sensor data from the robot are streamed continuously to the digital shadow via MQTT/ThingsBoard; the processing pipeline runs the friction simulation models and updates the Asset Administration Shell (AAS) with a latency that must respect the control‑system dead time. Synchronisation follows the live data stream frequency (i.e., the sensor sampling rate) and the temporal granularity is at the level of individual data traces, enabling dynamic adaptation of both white‑box (physics‑based) and black‑box (data‑driven) friction models."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a pipeline orchestration: physical robot → IoT sensors → MQTT broker → ThingsBoard storage → Asset Administration Shell executor → processing components (simulation models in Simulink, data‑calculation models) → updated digital shadow → visualization dashboard. Multi‑domain coupling is achieved by integrating SysML structural models with Simulink behavioural models via the FMI standard. Resource management and automation are provided by the AAS executor, which autonomously triggers simulations, collects results, and forwards them to the shadow and dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "According to Document 1, the development of a digital twin follows the typical Model‑Based Systems Engineering (MBSE) lifecycle that is split into several abstraction levels: (1) requirements engineering, (2) functional architecture, (3) logical architecture, and (4) product/technical layer. At each level the system is represented by appropriate artifacts – SysML requirement and block diagrams, architecture description languages (e.g., ACME, AADL, MontiArc) for component‑connector structures, state‑machine or automaton models for behavior, and finally executable simulation models (e.g., Simulink) or source code (C++, Java). Transition between stages is managed by a concretization step that maps reference‑model concepts to concrete class‑diagram elements, establishing a conformance relation (Document 2). Governance of the lifecycle is implied by the need to maintain traceability of data traces back to the originating processing component and models (Document 2)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by combining validated white‑box Simulink simulations with continuously trained black‑box neural‑network models, and by enforcing traceability of transformations from SysML (or other MBSE artefacts) to simulation models. Verification activities include correctness checks of model transformations, as highlighted for SysML‑to‑simulation pipelines, and uncertainty quantification arising from sensor noise and model approximation. Real‑time constraints such as control‑system dead time are considered to guarantee that model updates (parameter identification and retraining) occur within the permissible latency for high‑precision robot control. Error detection relies on monitoring anomalies in friction behaviour, enabling predictive maintenance and early fault detection. Quality assurance is achieved through continuous validation of model outputs against measured data, automatic updating of model parameters via the Processing component, and maintaining provenance via the origin‑traceability links."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The communication backbone consists of an MQTT publish‑subscribe network. Sensors send data to a preprocessing component, which connects to an MQTT broker (Mosquitto) that converts the data to JSON and distributes them via hierarchical topics. The AAS Executor subscribes to the relevant topics and retrieves the data. Topics can be assigned read/write permissions to control access. The system also uses the ThingsBoard IoT platform for storage and visualization, which connects to the same MQTT broker. No explicit bandwidth, latency, redundancy, or security protocol (e.g., TLS) details are provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital shadow is built on top of an Asset Administration Shell that serves as the single source of truth. A relational database is configured according to the DS data model and stores the AAS submodels, SysML identification points, and FMU simulation artefacts. The AAS Executor component runs locally, interprets the AAS and executes the simulation models (FMUs exported from Simulink). Processed data are sent to a ThingsBoard dashboard for visualization. The deployment is on‑premise (database, MQTT broker, AAS Executor) with no cloud or edge specifics mentioned; scalability and availability mechanisms are not described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is realized through industry‑4.0 standards: data exchange uses MQTT; asset description and service interfaces use the Asset Administration Shell (AAS); persistent storage and visualisation employ ThingsBoard. Model interoperability is ensured by FMI linking SysML and Simulink models. The digital shadow can be extended by other applications via the AAS and ThingsBoard APIs, enabling interoperability with enterprise MES, production planning, or other Digital Twins."
]