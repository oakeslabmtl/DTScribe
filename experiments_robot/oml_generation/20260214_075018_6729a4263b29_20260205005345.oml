instance RequirementsModel : DTDFVocab:Model [
    base:desc "Hierarchical requirements model using RFLP methodology"
    DTDFVocab:inputTo RFLPEnabler
]

instance FunctionalModel : DTDFVocab:Model [
    base:desc "Hierarchical functional model using OOSEM methodology"
    DTDFVocab:inputTo OOSEMEnabler
]

instance LogicalModel : DTDFVocab:Model [
    base:desc "Hierarchical logical model using SPES methodology"
    DTDFVocab:inputTo SPESEnabler
]

instance PhysicalModel : DTDFVocab:Model [
    base:desc "Hierarchical physical model using SMArDT methodology"
    DTDFVocab:inputTo SMArDTEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "Component-and-connector architecture description using ACME ADL"
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "Component-and-connector architecture description using AADL ADL"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcArchitectureModel : DTDFVocab:Model [
    base:desc "Component-and-connector architecture description using MontiArc ADL"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLIBDArchitectureModel : DTDFVocab:Model [
    base:desc "Component-and-connector architecture description using SysML Interface Block Diagrams"
    DTDFVocab:inputTo SysMLIBDEnabler
]

instance MontiArcBehaviorModel : DTDFVocab:Model [
    base:desc "Behavior model created using MontiArc Automaton"
    DTDFVocab:inputTo MontiArcAutomatonEnabler
]

instance SysMLStateMachineBehaviorModel : DTDFVocab:Model [
    base:desc "Behavior model created using SysML State Machines v1.7"
    DTDFVocab:inputTo SysMLStateMachineEnabler
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulation model created using MathWorks Simulink"
    DTDFVocab:inputTo SimulinkEnabler
]

instance CppImplementationModel : DTDFVocab:Model [
    base:desc "Implementation model using C++ programming language"
    DTDFVocab:inputTo CppEnabler
]

instance JavaImplementationModel : DTDFVocab:Model [
    base:desc "Implementation model using Java programming language"
    DTDFVocab:inputTo JavaEnabler
]

instance RFLPEnabler : DTDFVocab:Enabler [
    base:desc "RFLP methodology for requirements layer modeling"
    DTDFVocab:enables RequirementsModelingService
]

instance OOSEMEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for functional layer modeling"
    DTDFVocab:enables FunctionalModelingService
]

instance SPESEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for logical layer modeling"
    DTDFVocab:enables LogicalModelingService
]

instance SMArDTEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for physical layer modeling"
    DTDFVocab:enables PhysicalModelingService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language tool"
    DTDFVocab:enables ACMEArchitectureService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language tool"
    DTDFVocab:enables AADLArchitectureService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language tool"
    DTDFVocab:enables MontiArcArchitectureService
]

instance SysMLIBDEnabler : DTDFVocab:Enabler [
    base:desc "SysML Interface Block Diagrams tool"
    DTDFVocab:enables SysMLIBDArchitectureService
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavior modeling"
    DTDFVocab:enables MontiArcBehaviorService
]

instance SysMLStateMachineEnabler : DTDFVocab:Enabler [
    base:desc "SysML State Machines v1.7 for behavior modeling"
    DTDFVocab:enables SysMLStateMachineService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation"
    DTDFVocab:enables SimulationService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for implementation"
    DTDFVocab:enables CppImplementationService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for implementation"
    DTDFVocab:enables JavaImplementationService
]

instance RequirementsModelingService : DTDFVocab:Service [
    base:desc "Service for requirements modeling and validation"
    DTDFVocab:provides RequirementsValidationInsight
]

instance FunctionalModelingService : DTDFVocab:Service [
    base:desc "Service for functional modeling and analysis"
    DTDFVocab:provides FunctionalAnalysisInsight
]

instance LogicalModelingService : DTDFVocab:Service [
    base:desc "Service for logical modeling and validation"
    DTDFVocab:provides LogicalValidationInsight
]

instance PhysicalModelingService : DTDFVocab:Service [
    base:desc "Service for physical modeling and validation"
    DTDFVocab:provides PhysicalValidationInsight
]

instance ACMEArchitectureService : DTDFVocab:Service [
    base:desc "Service for ACME-based architecture modeling and validation"
    DTDFVocab:provides ACMEArchitectureValidationInsight
]

instance AADLArchitectureService : DTDFVocab:Service [
    base:desc "Service for AADL-based architecture modeling and validation"
    DTDFVocab:provides AADLArchitectureValidationInsight
]

instance MontiArcArchitectureService : DTDFVocab:Service [
    base:desc "Service for MontiArc-based architecture modeling and validation"
    DTDFVocab:provides MontiArcArchitectureValidationInsight
]

instance SysMLIBDArchitectureService : DTDFVocab:Service [
    base:desc "Service for SysML IBD-based architecture modeling and validation"
    DTDFVocab:provides SysMLIBDValidationInsight
]

instance MontiArcBehaviorService : DTDFVocab:Service [
    base:desc "Service for behavior modeling using MontiArc Automaton"
    DTDFVocab:provides BehaviorSimulationInsight
]

instance SysMLStateMachineService : DTDFVocab:Service [
    base:desc "Service for behavior modeling using SysML State Machines"
    DTDFVocab:provides SysMLStateMachineValidationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for simulation using Simulink"
    DTDFVocab:provides SimulationResultInsight
]

instance CppImplementationService : DTDFVocab:Service [
    base:desc "Service for C++ implementation of system components"
    DTDFVocab:provides CppImplementationInsight
]

instance JavaImplementationService : DTDFVocab:Service [
    base:desc "Service for Java implementation of system components"
    DTDFVocab:provides JavaImplementationInsight
]

instance RequirementsValidationInsight : DTDFVocab:Insight [
    base:desc "Validation insight for requirements model"
]

instance FunctionalAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analysis insight for functional model"
]

instance LogicalValidationInsight : DTDFVocab:Insight [
    base:desc "Validation insight for logical model"
]

instance PhysicalValidationInsight : DTDFVocab:Insight [
    base:desc "Validation insight for physical model"
]

instance ACMEArchitectureValidationInsight : DTDFVocab:Insight [
    base:desc "Validation insight for ACME architecture model"
]

instance AADLArchitectureValidationInsight : DTDFVocab:Insight [
    base:desc "Validation insight for AADL architecture model"
]

instance MontiArcArchitectureValidationInsight : DTDFVocab:Insight [
    base:desc "Validation insight for MontiArc architecture model"
]

instance SysMLIBDValidationInsight : DTDFVocab:Insight [
    base:desc "Validation insight for SysML IBD architecture model"
]

instance BehaviorSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from behavior simulation"
]

instance SysMLStateMachineValidationInsight : DTDFVocab:Insight [
    base:desc "Validation insight for SysML State Machine model"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight from simulation results"
]

instance CppImplementationInsight : DTDFVocab:Insight [
    base:desc "Insight from C++ implementation"
]

instance JavaImplementationInsight : DTDFVocab:Insight [
    base:desc "Insight from Java implementation"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Industry standards such as SysML [17], ACME [23], AADL [24], MontiArc [25], [26], and SysML IBDs [17], [27] are used for architecture description languages (ADLs) to model system components, interfaces, interconnections, and behavior, facilitating interoperability and integration of heterogeneous stakeholders and perspectives."
]