// C3: Physical sensing components (digital shadow ingestion)
instance DigitalShadowIngestionComponent : DTDFVocab:SensingComponent [
    base:desc "Component that ingests the one‑way data flow from the physical asset (digital shadow) as described in DT services."
    DTDFVocab:producedData RawCpsTraceData
]

// C4: Physical-to-virtual interaction
instance RawCpsTraceData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DigitalShadowIngestionComponent
]

// C11: Data
instance EnrichedCpsTraceData : DTDFVocab:Data [
    base:desc "Contextual data trace collected from the cyber‑physical system and enriched with metadata."
    DTDFVocab:fromData RawCpsTraceData
    DTDFVocab:inputTo SoftwareProcessingModule
]

// C10: Models
instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "Engineering model (SysML block definition & internal block diagrams) capturing the system’s structure."
    DTDFVocab:inputTo SoftwareProcessingModule
]

instance ComponentConnectorADLModel : DTDFVocab:Model [
    base:desc "Component‑&‑connector ADL model (ACME, AADL, MontiArc) encoding component interfaces and interconnections."
    DTDFVocab:inputTo SoftwareProcessingModule
]

instance BehaviouralStateMachineModel : DTDFVocab:Model [
    base:desc "Behavioural model expressed via SysML state machines, MontiArc Automaton, or Simulink dynamic simulations (white‑box)."
    DTDFVocab:inputTo SoftwareProcessingModule
]

instance DataDrivenMLRegressorModel : DTDFVocab:Model [
    base:desc "Data‑driven analytical model (machine‑learning regressor) used for predictive analysis."
    DTDFVocab:inputTo SoftwareProcessingModule
]

instance HybridPhysicsDataModel : DTDFVocab:Model [
    base:desc "Hybrid model that combines physics‑based models with data‑driven analytical models."
    DTDFVocab:inputTo SoftwareProcessingModule
]

// C11: Enablers
instance SoftwareProcessingModule : DTDFVocab:Enabler [
    base:desc "Software module implemented in C++/Java that executes simulation or data‑calculation models defined in the Digital Shadow Reference Model."
    DTDFVocab:enables MonitoringService, PredictionService, ControlService
]

instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "MBSE tooling (SysML) used to create block definition and internal block diagrams."
]

instance ArchitectureADLTool : DTDFVocab:Enabler [
    base:desc "Architecture description languages (ACME, AADL, MontiArc) used to model component‑connector structures."
]

instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink used for dynamic white‑box simulations of behavioural models."
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time state monitoring of the physical asset."
    DTDFVocab:provides RealTimeStateInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Generates predictive indicators based on hybrid model simulations."
    DTDFVocab:provides PredictiveIndicatorInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Pushes processed information back to the physical system to perform control actions."
    DTDFVocab:provides SystemControlAction
]

// C17: Insights
instance RealTimeStateInsight : DTDFVocab:Insight [
    base:desc "Insight into the current operational state of the asset derived from processed data."
]

instance PredictiveIndicatorInsight : DTDFVocab:Insight [
    base:desc "Forecasted performance indicators produced by hybrid models."
]

// C17: Actions
instance SystemControlAction : DTDFVocab:Action [
    base:desc "Automated control action sent to the physical system to adjust operation."
    DTDFVocab:IsAutomatic true
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by combining white‑box physics‑based models (e.g., Simulink dynamic simulations) with black‑box data‑driven models to capture complex, non‑linear phenomena. Validation and verification rely on fine‑grained traceability: each generated data trace can be traced back through the ‘originates‑from’ association to the processing component and the specific models that produced it, ensuring correctness of model transformations (e.g., SysML to simulation). Uncertainty sources such as sensor noise or model simplifications are acknowledged, and the traceability infrastructure supports error detection and correction. Quality assurance is achieved through verification of transformations, conformance checking between concrete realizations and the reference digital shadow model, and systematic documentation of model‑data relationships."
]