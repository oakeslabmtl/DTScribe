    base:desc "Behavioral insights from MontiArc Automaton state machine modeling. Describes dynamic system responses across different operational scenarios."
]

instance ComponentInteractionInsight : DTDFVocab:Insight [
    base:desc "Component interaction insights analyzing interconnections between digital twin instances. Identifies coordination patterns and potential bottlenecks."
]

instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive failure insights from Simulink-based what-if scenario analysis. Estimates component failure probabilities under various operational conditions."
]

