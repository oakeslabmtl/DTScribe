    base:desc "Scenario outcome insights from performance metric analysis. Evaluates potential operational changes before implementation through simulation."
]

instance EnvironmentalImpactInsight : DTDFVocab:Insight [
    base:desc "Environmental impact insights analyzing contextual parameters. Provides sustainability metrics and operational efficiency recommendations."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Multi-perspective visualization insights tailored to different stakeholders. Presents system data in engineer, operator, and domain expert views."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Operational optimization insights derived from heterogeneous modeling tools. Identifies efficiency improvements across functional and logical architectures."
]

instance ResourceUtilizationInsight : DTDFVocab:Insight [
    base:desc "Resource utilization insights analyzing performance metrics. Provides recommendations for optimal system resource allocation."
]

instance ModelConsistencyInsight : DTDFVocab:Insight [
    base:desc "Model consistency insights validating cross-tool transformations. Ensures coherence between SysML, Simulink, and ADL representations."
]

instance IntegrationInsight : DTDFVocab:Insight [
