instance RequirementsDataSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for requirements phase data from system development"
    DTDFVocab:producedData RequirementsDataTransmitted
]

instance FunctionalDataSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for functional architecture phase data from system development"
    DTDFVocab:producedData FunctionalDataTransmitted
]

instance LogicalDataSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for logical architecture phase data from system development"
    DTDFVocab:producedData LogicalDataTransmitted
]

instance ProductTechnicalDataSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for product/technical layer phase data from system development"
    DTDFVocab:producedData ProductTechnicalDataTransmitted
]

instance RequirementsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RequirementsDataSensor
]

instance FunctionalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FunctionalDataSensor
]

instance LogicalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LogicalDataSensor
]

instance ProductTechnicalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProductTechnicalDataSensor
]

instance RequirementsData : DTDFVocab:Data [
    base:desc "Data derived from system requirements phase"
    DTDFVocab:fromData RequirementsDataTransmitted
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance FunctionalData : DTDFVocab:Data [
    base:desc "Data derived from functional architecture phase"
    DTDFVocab:fromData FunctionalDataTransmitted
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance LogicalData : DTDFVocab:Data [
    base:desc "Data derived from logical architecture phase"
    DTDFVocab:fromData LogicalDataTransmitted
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance ProductTechnicalData : DTDFVocab:Data [
    base:desc "Data derived from product/technical layer phase"
    DTDFVocab:fromData ProductTechnicalDataTransmitted
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance SysMLInternalBlockDiagrams : DTDFVocab:Model [
    base:desc "Structural representation using SysML Internal Block Diagrams for multi-level abstraction modeling"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance ACME : DTDFVocab:Model [
    base:desc "Architecture Description Language for component, interface, and interconnection descriptions"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance AADL : DTDFVocab:Model [
    base:desc "Architecture Description Language for component, interface, and interconnection descriptions"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance MontiArc : DTDFVocab:Model [
    base:desc "Architecture Description Language for component, interface, and interconnection descriptions"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance SysMLStateMachines : DTDFVocab:Model [
    base:desc "Behavioral modeling using SysML v1.7 state machines"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance MontiArcAutomaton : DTDFVocab:Model [
    base:desc "Behavioral modeling using MontiArc Automaton"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance MathWorksSimulink : DTDFVocab:Model [
    base:desc "Analytical model for simulation and detailed behavior specification"
    DTDFVocab:inputTo SimulinkEnabler
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for requirements and architecture modeling"
    DTDFVocab:enables RequirementsModelingService
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "Object-Oriented Systems Engineering Methodology for system design"
    DTDFVocab:enables FunctionalArchitectureService
]

instance SPES : DTDFVocab:Enabler [
    base:desc "System Product Engineering System for integrated product development"
    DTDFVocab:enables LogicalArchitectureService
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "System Modeling and Analysis for Digital Twin methodology"
    DTDFVocab:enables ProductTechnicalService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and analytical modeling"
    DTDFVocab:enables SimulationService
]

instance CPlusPlusEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior specification"
    DTDFVocab:enables BehaviorSpecificationService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior specification"
    DTDFVocab:enables BehaviorSpecificationService
]

instance RequirementsModelingService : DTDFVocab:Service [
    base:desc "Service for requirements modeling and validation"
    DTDFVocab:provides RequirementsValidationInsight
]

instance FunctionalArchitectureService : DTDFVocab:Service [
    base:desc "Service for functional architecture analysis"
    DTDFVocab:provides FunctionalArchitectureInsight
]

instance LogicalArchitectureService : DTDFVocab:Service [
    base:desc "Service for logical architecture analysis"
    DTDFVocab:provides LogicalArchitectureInsight
]

instance ProductTechnicalService : DTDFVocab:Service [
    base:desc "Service for product/technical layer analysis"
    DTDFVocab:provides ProductTechnicalInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for simulation and analytical modeling"
    DTDFVocab:provides SimulationInsight
]

instance BehaviorSpecificationService : DTDFVocab:Service [
    base:desc "Service for behavior specification using C++ and Java"
    DTDFVocab:provides BehaviorSpecificationInsight
]

instance RequirementsValidationInsight : DTDFVocab:Insight [
    base:desc "Insight for validating requirements against system architecture"
]

instance FunctionalArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight for analyzing functional architecture design"
]

instance LogicalArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight for logical architecture design validation"
]

instance ProductTechnicalInsight : DTDFVocab:Insight [
    base:desc "Insight for product/technical layer implementation analysis"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from simulation results for system behavior"
]

instance BehaviorSpecificationInsight : DTDFVocab:Insight [
    base:desc "Insight from detailed behavior specification using programming languages"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Industry standards and tools including SysML [17], ACME [23], AADL [24], MontiArc [25], [26], and MathWorks Simulink [28] are utilized for modeling system structure, behavior, and integration across multiple abstraction levels (requirements, functional architecture, logical architecture, product/technical layer) within Model-Based Systems Engineering (MBSE) frameworks."
]