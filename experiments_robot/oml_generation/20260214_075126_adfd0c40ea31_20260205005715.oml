instance RequirementsModel : DTDFVocab:Model [
    base:desc "SysML model for capturing system requirements"
    DTDFVocab:inputTo RFLPMethodology
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model for functional architecture"
    DTDFVocab:inputTo OOSEMMethodology
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model for logical architecture"
    DTDFVocab:inputTo SPESMethodology
]

instance ProductTechnicalLayerModel : DTDFVocab:Model [
    base:desc "SysML model for product and technical layer"
    DTDFVocab:inputTo SMArDTMethodology
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME architecture description for component interfaces and interconnections"
    DTDFVocab:inputTo ACMETool
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL architecture description for component interfaces and interconnections"
    DTDFVocab:inputTo AADLTool
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description for component interfaces and interconnections"
    DTDFVocab:inputTo MontiArcTool
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram for component interfaces and interconnections"
    DTDFVocab:inputTo SysMLIBDTool
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcAutomatonTool
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machine for behavioral modeling"
    DTDFVocab:inputTo SysMLStateMachineTool
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for simulation"
    DTDFVocab:inputTo SimulinkTool
]

instance CppCodeModel : DTDFVocab:Model [
    base:desc "C++ code for detailed behavior modeling"
    DTDFVocab:inputTo CppTool
]

instance JavaCodeModel : DTDFVocab:Model [
    base:desc "Java code for detailed behavior modeling"
    DTDFVocab:inputTo JavaTool
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for requirements abstraction"
    DTDFVocab:enables SimulationService
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for functional architecture abstraction"
    DTDFVocab:enables SimulationService
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for logical architecture abstraction"
    DTDFVocab:enables SimulationService
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for technical layer abstraction"
    DTDFVocab:enables SimulationService
]

instance ACMETool : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for modeling component interfaces and interconnections"
    DTDFVocab:enables SimulationService
]

instance AADLTool : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for modeling component interfaces and interconnections"
    DTDFVocab:enables SimulationService
]

instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for modeling component interfaces and interconnections"
    DTDFVocab:enables SimulationService
]

instance SysMLIBDTool : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component interfaces and interconnections"
    DTDFVocab:enables SimulationService
]

instance MontiArcAutomatonTool : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:enables SimulationService
]

instance SysMLStateMachineTool : DTDFVocab:Enabler [
    base:desc "SysML state machines for behavioral modeling"
    DTDFVocab:enables SimulationService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation support"
    DTDFVocab:enables SimulationService
]

instance CppTool : DTDFVocab:Enabler [
    base:desc "C++ general-purpose programming language for detailed behavior"
    DTDFVocab:enables SimulationService
]

instance JavaTool : DTDFVocab:Enabler [
    base:desc "Java general-purpose programming language for detailed behavior"
    DTDFVocab:enables SimulationService
]

instance AdditionalSimulationTools : DTDFVocab:Enabler [
    base:desc "Additional simulation tools referenced in [29], [30]"
    DTDFVocab:enables SimulationService
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for running simulations and analyzing results"
    DTDFVocab:provides SimulationInsight
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulation results for decision-making"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Relevant industry standards include SysML [17], AADL [24], ACME [23], and MontiArc [25,26] for architecture description and system modeling, ensuring interoperability and structured representation across different abstraction levels."
]