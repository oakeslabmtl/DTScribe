// C3: Physical sensing components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted on the motor shaft"
    DTDFVocab:producedData MotorShaftEncoderTx
]

instance GearboxSecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the cycloidal gearbox"
    DTDFVocab:producedData GearboxSecondaryEncoderTx
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Electric current sensor for motor current I_M"
    DTDFVocab:producedData MotorCurrentSensorTx
]

instance AxisPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor providing output angle of the first vertical axis"
    DTDFVocab:producedData AxisPositionSensorTx
]

// C4: Physical-to-virtual interaction (data transmitted)
instance MotorShaftEncoderTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxSecondaryEncoderTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxSecondaryEncoder
]

instance MotorCurrentSensorTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance AxisPositionSensorTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AxisPositionSensor
]

// C10: Data items derived from transmitted streams
instance ShaftEncoderData : DTDFVocab:Data [
    base:desc "Discrete shaft position counts from the motor shaft encoder"
    DTDFVocab:fromData MotorShaftEncoderTx
    DTDFVocab:inputTo MqttBroker, AssetAdministrationShell
]

instance GearboxEncoderData : DTDFVocab:Data [
    base:desc "Discrete position counts from the gearbox secondary encoder"
    DTDFVocab:fromData GearboxSecondaryEncoderTx
    DTDFVocab:inputTo MqttBroker, AssetAdministrationShell
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor phase current I_M"
    DTDFVocab:fromData MotorCurrentSensorTx
    DTDFVocab:inputTo MqttBroker, AssetAdministrationShell
]

instance AxisAngleData : DTDFVocab:Data [
    base:desc "Measured output angle of the vertical axis"
    DTDFVocab:fromData AxisPositionSensorTx
    DTDFVocab:inputTo MqttBroker, AssetAdministrationShell
]

// C11: Enablers (tools and infrastructure)
instance MqttBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker that streams live sensor data to the digital shadow"
    DTDFVocab:enables RealTimeFrictionIdentificationService, DataVisualizationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell encapsulating sensor data and linking to SysML model elements"
    DTDFVocab:enables RealTimeFrictionIdentificationService, DataVisualizationService
]

instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink executable engine running friction and dynamics models"
    DTDFVocab:enables RealTimeFrictionIdentificationService
]

instance DashboardVisualization : DTDFVocab:Enabler [
    base:desc "Integrated dashboard for visualizing measured vs. simulated data traces"
    DTDFVocab:enables DataVisualizationService
]

// C10: Engineering & Simulation Models
instance SysMLAxisStructureModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams describing motor, gearwheel and cycloidal gearbox structure"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of motor, gearwheel and gearbox with Coulomb‑Viscous, Stribeck, Dahl and LuGre friction models"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction parameters using combined white‑box and black‑box models"
    DTDFVocab:provides FrictionParameterDerivationInsight, UpdateControllerFrictionParametersAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Visualization of live and simulated data traces; comparison of measured vs. simulated torque and angular velocity"
    DTDFVocab:provides WearAndTemperatureChangeDetectionInsight, ScheduleMaintenanceAction
]

// C17: Insights
instance FrictionParameterDerivationInsight : DTDFVocab:Insight [
    base:desc "Derivation of friction parameters that can be fed back to the robot controller to improve motion accuracy"
]

instance WearAndTemperatureChangeDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of wear or temperature‑induced changes enabling proactive maintenance decisions"
]

// C17: Actions
instance UpdateControllerFrictionParametersAction : DTDFVocab:Action [
    base:desc "Automatically upload derived friction parameters to the robot controller for motion compensation"
    DTDFVocab:IsAutomatic true
]

instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Generate a maintenance work order when wear or temperature anomalies are detected"
    DTDFVocab:IsAutomatic false
]

// C5: Physical components (contextual)
instance MotorComponent : DTDFVocab:Component [
    base:desc "Electric motor driving the first vertical axis"
]

instance GearboxComponent : DTDFVocab:Component [
    base:desc "Cycloidal gearbox coupled to the motor"
]

instance AxisComponent : DTDFVocab:Component [
    base:desc "First vertical axis of the MABI MAX 100 robot"
]

instance RobotEnvironment : DTDFVocab:Environment [
    base:contains MotorComponent, GearboxComponent, AxisComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Not in Document (digital shadow is a one‑way, passive entity and does not send commands back to the robot)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow consisting of a singleton purpose (FrictionDerivation), the asset (MABI robot first axis), multiple DataTrace objects (measured and simulated), Processing components (Simulation_M, Simulation_GW, Simulation_GB) that consume input traces and produce output traces using the simulation models, all linked according to the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational stage – the digital shadow is created and used during robot run‑time to continuously identify friction and refine control; it builds on models defined during design."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each data point to its source and processing component; comparison of simulated friction‑free model versus measured data to validate friction models; continuous online identification to capture wear and temperature effects, ensuring high fidelity of the digital shadow."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow over MQTT; data are encapsulated in AAS structures for linking with the SysML model."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Uses the Industry 4.0 Asset Administration Shell (AAS) standard, SysML (OMG standard) for modeling, and MQTT (OASIS standard) for data transport."
]