// C3: Physical sensing components
instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted encoder directly on the motor shaft delivering angular position measurements"
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder placed after the gearbox delivering angular position measurements"
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the input electric current of the motor"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical‑to‑virtual data flow (DataTransmitted)
instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C5: Data (abstracted, stored)
instance MotorAngleData : DTDFVocab:Data [
    base:desc "Time‑series of motor‑shaft angular position"
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo SimulinkEngine, MQTTBroker
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Time‑series of post‑gearbox angular position"
    DTDFVocab:fromData GearboxAngleDataTransmitted
    DTDFVocab:inputTo SimulinkEngine, MQTTBroker
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor input electric current"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MLExecutionEngine, MQTTBroker
]

// C11: Enablers (tooling and middleware)
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker used for event‑driven streaming of sensor measurements from the physical robot to the digital twin"
    DTDFVocab:enables RealTimeMonitoringService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink execution environment for multi‑physics simulation and model‑based calibration"
    DTDFVocab:enables ModelCalibrationService
]

instance MLExecutionEngine : DTDFVocab:Enabler [
    base:desc "Execution platform for data‑driven machine‑learning models (e.g., friction identification regression)"
    DTDFVocab:enables FrictionIdentificationService
]

instance DashboardApplication : DTDFVocab:Enabler [
    base:desc "Operator dashboard UI that visualises insights and enables action execution"
    DTDFVocab:enables DashboardVisualizationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Standardized AAS for data exchange and semantic interoperability with the Siemens SINUMERIK 840Dsl controller"
]

// C10: Models (simulation and ML)
instance RobotDynamicsSimulinkModel : DTDFVocab:Model [
    base:desc "Detailed multi‑physics Simulink model of the six‑axis MABI MAX‑100 robot (mechanical, electrical, thermal)"
    DTDFVocab:inputTo SimulinkEngine
]

instance FrictionMLModel : DTDFVocab:Model [
    base:desc "Machine‑learning regression model trained on contextual data traces to estimate joint friction coefficients"
    DTDFVocab:inputTo MLExecutionEngine
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring service that consumes streamed sensor traces and presents current robot state"
    DTDFVocab:provides RobotStateInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Service that runs Simulink‑based calculations to calibrate the robot dynamics model using angle data"
    DTDFVocab:provides MotionAccuracyImprovementInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service that applies the friction ML model to sensor traces to identify joint friction coefficients"
    DTDFVocab:provides FrictionCoefficientInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Service that visualises insights and enables operators to trigger corrective actions"
    DTDFVocab:provides AdjustControlParametersAction
]

// C17: Insights
instance RobotStateInsight : DTDFVocab:Insight [
    base:desc "Current robot pose and status derived from live sensor streams"
]

instance MotionAccuracyImprovementInsight : DTDFVocab:Insight [
    base:desc "Estimated improvement in positioning accuracy after model calibration"
]

instance FrictionCoefficientInsight : DTDFVocab:Insight [
    base:desc "Estimated joint friction coefficients obtained from the friction identification service"
]

// C17: Actions
instance AdjustControlParametersAction : DTDFVocab:Action [
    base:desc "Operator‑initiated adjustment of controller parameters based on insight recommendations"
    DTDFVocab:IsAutomatic false
]

// C2: Acting components (controller)
instance SiemensSinumerik840DslController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840Dsl CNC controller interfaced with the digital twin via AAS"
]

// C8: Environment (optional)
instance ManufacturingCellEnvironment : DTDFVocab:Environment [
    base:contains MotorMountedEncoder, GearboxEncoder, MotorCurrentSensor, SiemensSinumerik840DslController
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated according to the Digital Shadow reference model (Fig. 1), which is expressed as a UML class diagram that follows a component‑connector architecture. Core elements include Data Trace objects that hold contextual data and metadata, a Processing Component that consumes input Data Traces, selects an appropriate Simulation Model or Data‑Calculation Model (e.g., a Simulink model, a C++ algorithm, or a state‑machine defined in SysML), executes the model, and emits a new Data Trace. The origin‑from association links every generated Data Trace to the responsible Processing Component, the input traces, and the specific model, preserving transitive traceability across the chain. The architecture is aligned with Model‑Based Systems Engineering (MBSE) layers—requirements, functional architecture, logical architecture, and physical/technical layer—and may be described with SysML, ADLs such as AADL, MontiArc, or ACME, and integrated with external simulation tools. Resource management and coordination are handled by the Processing Component, which schedules model execution, manages data flow, and ensures that the produced Data Traces conform to the semantic contracts defined by the reference model, thereby constituting the overall DT constellation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The methodology emphasizes model fidelity by integrating physics‑based white‑box simulations with data‑driven black‑box models and requires validation through comparison of simulated outputs against measured sensor data. Traceability is provided by the Digital Shadow Reference Model, which records model versions and transformation steps (e.g., from SysML to simulation code). The literature highlights the need to address uncertainty sources such as modeling errors and sensor noise, and calls for uncertainty quantification, error detection, and correction mechanisms, together with systematic verification of model‑to‑code pipelines to ensure quality and correctness."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on the MQTT messaging protocol for the one‑way data transmission from the physical object to the digital representation. No additional details on network topology, bandwidth, latency, redundancy, or security protocols are provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation conforms to several industry standards: the Asset Administration Shell (AAS) is used as the information model for asset metadata; system architecture and behavior are modeled with SysML (including block definition diagrams and internal block diagrams) and expressed in UML class diagrams as the Digital Shadow Reference Model; ADLs such as ACME or AADL are referenced for component‑connector descriptions. These standards provide a certification‑ready, interoperable foundation and enable integration with other AAS‑compatible tools."
]