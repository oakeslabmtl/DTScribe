// C4: Physical sensing component
instance PlantTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Real‑time telemetry from the physical plant collected via embedded sensors."
    DTDFVocab:producedData TelemetryDataTransmitted
]

// C4: Data transmitted
instance TelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Aggregated telemetry traces stored as contextual data traces for the digital shadow."
    DTDFVocab:producedFrom PlantTelemetrySensor
]

// C10: Data
instance TelemetryData : DTDFVocab:Data [
    base:desc "Contextual telemetry data used as inputs to simulation and model translation."
    DTDFVocab:fromData TelemetryDataTransmitted
    DTDFVocab:inputTo SystemModelMappingEnabler
]

// C10: Models
instance StructuralSimulationModel : DTDFVocab:Model [
    base:desc "Structural dynamics model generated from SysML component diagram and MontiArc automata, implemented as Simulink block."
    DTDFVocab:inputTo SimulinkIntegrationEnabler
]

instance ThermalSimulationModel : DTDFVocab:Model [
    base:desc "Thermal dynamics model generated from SysML component diagram and MontiArc automata, implemented as Simulink block."
    DTDFVocab:inputTo SimulinkIntegrationEnabler
]

// C11: Enablers
instance SimulinkIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Maps Simulink blocks and signals to Simulink implementation."
    DTDFVocab:enables SimulationService
]

instance MontiArcTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Transforms MontiArc automaton models to executable code."
    DTDFVocab:enables TranslationService
]

instance SystemModelMappingEnabler : DTDFVocab:Enabler [
    base:desc "Enforces mapping rules between SysML connectors and Simulink signal flow."
    DTDFVocab:enables MappingService
]

instance CodeGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Generates C++/Java code from model artefacts."
    DTDFVocab:enables CodeGenerationService
]

instance MBSEFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Provides MBSE tooling such as ACME, AADL, and SysML diagram management."
    DTDFVocab:enables MBSEService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Runs continuous‑time simulations in MathWorks Simulink."
    DTDFVocab:provides SimulationResultInsight
]

instance TranslationService : DTDFVocab:Service [
    base:desc "Converts MontiArc automaton models into executable representations."
    DTDFVocab:provides TranslatedModelInsight
]

instance MappingService : DTDFVocab:Service [
    base:desc "Applies connector binding and mapping rules to synchronize digital and physical artefacts."
    DTDFVocab:provides MappingAccuracyInsight
]

instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Creates C++ or Java code from logical and physical models."
    DTDFVocab:provides CodeGenerationInsight, GenerateCodeAction
]

instance MBSEService : DTDFVocab:Service [
    base:desc "Manages MBSE artifacts and ensures adherence to SMArDT, RFLP, OOSEM, and SPES methodologies."
    DTDFVocab:provides MBSEComplianceInsight
]

// C17: Insights
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Provides runtime simulation profiles and state trajectories."
]

instance TranslatedModelInsight : DTDFVocab:Insight [
    base:desc "Reports on fidelity of MontiArc automaton translation."
]

instance MappingAccuracyInsight : DTDFVocab:Insight [
    base:desc "Evaluates correctness of SysML-simulated connector bindings."
]

instance CodeGenerationInsight : DTDFVocab:Insight [
    base:desc "Logs generated C++/Java files and build status."
]

instance MBSEComplianceInsight : DTDFVocab:Insight [
    base:desc "Confirms adherence to the multi‑level abstraction methodologies."
]

// C17: Action
instance GenerateCodeAction : DTDFVocab:Action [
    base:desc "Triggers automated generation of target language code from model artefacts."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital Twin development follows a multi‑layered MBSE lifecycle, beginning with high‑level requirements, progressing through functional architecture, logical architecture, and finally the product/technical implementation. At each layer the twin is represented in increasingly detailed models: requirements are captured in natural language and requirement tables; functional architecture is expressed in SysML Requirements diagrams and block definition diagrams; logical architecture uses SysML IBDs or ADLs such as ACME or AADL to describe component‑connector structure; the product/technical layer is modeled with simulation primitives in tools like MathWorks Simulink or MontiArc automata. Transition between layers is managed by traceability links and model transformation rules, ensuring that each abstraction level is consistently derived from the preceding one. Lifecycle governance is typically performed through a model management system that enforces version control, change request workflows, and compliance checks against the MBSE methodology."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin employs SysML v1.7 for architecture modeling, with component‑connector descriptions in SysML IBDs, block definition diagrams and requirement diagrams. For logical and functional architecture, ACME, AADL, and MontiArc are also used as ADL standards. Simulation behavior is implemented using MathWorks Simulink, which follows the Simulink modeling standard."
]