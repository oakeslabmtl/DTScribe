]

instance ProcessPressureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring pressure parameters in continuous manufacturing processes, critical for real-time operational data acquisition [64]."
    DTDFVocab:producedData ProcessPressureDataTransmitted
]

instance EnvironmentalHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing contextual environmental data traces for purpose-driven aggregation in manufacturing systems [32]."
    DTDFVocab:producedData EnvironmentalHumidityDataTransmitted
]

instance RobotDynamicsSensor : DTDFVocab:SensingComponent [
    base:desc "High-fidelity sensor capturing robot dynamics data for intrinsic model validation and scalability in industrial applications [14]."
