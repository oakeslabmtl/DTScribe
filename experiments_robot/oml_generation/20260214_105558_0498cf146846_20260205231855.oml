instance InjectionMoldingTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InjectionMoldingTemperatureSensor
    base:desc "Real-time temperature data transmitted via MQTT protocol for lightweight publish-subscribe communication between IoT devices and digital shadow [52]."
]

instance RoboticJointPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoboticJointPositionSensor
    base:desc "Event-triggered position data transmission capturing nonlinear friction phenomena with low-latency requirements [64]."
]

instance ProcessPressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProcessPressureSensor
    base:desc "Time-based pressure data transmission for continuous process monitoring with aggregation and abstraction [56]."
]

instance EnvironmentalHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalHumiditySensor
    base:desc "Contextual environmental data traces transmitted via industry-specific protocols for purpose-driven manufacturing applications [59]."
]

instance RobotDynamicsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotDynamicsSensor
    base:desc "High-fidelity dynamics data transmitted for intrinsic model validation with scalable identification methods [14]."
]

// C10: Models/Data
instance PhysicsBasedInjectionModel : DTDFVocab:Model [
    base:desc "White-box physics-based model implemented in Simulink for interpretable dynamic simulation of injection molding processes [28]."
    DTDFVocab:inputTo InjectionMoldingDataAggregator
]

instance DataDrivenFrictionModel : DTDFVocab:Model [
    base:desc "Black-box machine learning model capturing nonlinear friction phenomena in robotic systems using probabilistic latent variable approaches [14]."
    DTDFVocab:inputTo RoboticsDataProcessor
]

instance ProcessOptimizationData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted data traces from injection molding processes for optimization and decision support [63]."
    DTDFVocab:fromData InjectionMoldingTemperatureDataTransmitted, ProcessPressureDataTransmitted
    DTDFVocab:inputTo ProcessOptimizationEnabler
]

instance RoboticsStateData : DTDFVocab:Data [
    base:desc "Contextual data traces from robotic systems including position, velocity, and friction data for autonomous decision-making [62]."
    DTDFVocab:fromData RoboticJointPositionDataTransmitted, RobotDynamicsDataTransmitted
    DTDFVocab:inputTo RoboticsControlEnabler
]

instance ManufacturingContextData : DTDFVocab:Data [
    base:desc "Purpose-driven aggregated data combining environmental and operational parameters for multi-perspective manufacturing analysis [31]."
    DTDFVocab:fromData EnvironmentalHumidityDataTransmitted
    DTDFVocab:inputTo DecisionSupportEnabler
]

