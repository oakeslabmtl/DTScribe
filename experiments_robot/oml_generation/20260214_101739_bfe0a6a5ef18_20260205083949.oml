// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving the robot axis, controlled via Siemens SINUMERIK 840d sl CNC controller with remote actuation capabilities for position, speed, and acceleration commands."
]

instance SiemensSINUMERIK840dController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840d sl CNC controller enforcing safety constraints through a safety cell with emergency stop mechanisms and interlocks. Interfaces with Digital Twin via industrial protocols (OPC UA, MQTT)."
]

instance RobotSafetyCell : DTDFVocab:ActingComponent [
    base:desc "Safety cell implementing emergency stop mechanisms, interlocks, and guarded access to prevent unauthorized or hazardous operations during robot actuation."
]

// C3: Physical Sensing Components
instance MotorShaftPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted directly on the motor shaft providing high-precision position feedback for closed-loop control and model validation."
    DTDFVocab:producedData MotorShaftPositionData
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder mounted behind the gearbox to mitigate backlash and provide redundant high-precision position feedback."
    DTDFVocab:producedData GearboxPositionData
]

// C4: Physical-to-Virtual Interaction
instance MotorShaftPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftPositionEncoder
    base:desc "Time-series position measurements from motor shaft encoder transmitted via MQTT protocol for real-time streaming."
]

instance GearboxPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
    base:desc "Time-series position measurements from gearbox encoder transmitted via MQTT protocol for real-time streaming."
]

// C10: Models/Data
instance RobotKinematicModel : DTDFVocab:Model [
    base:desc "Mathematical model representing the kinematic behavior of the MABI MAX 100 six-axis robot, including joint configurations and motion trajectories."
    DTDFVocab:inputTo SysMLModelingEnabler, SimulinkSimulationEnabler
]

instance JointFrictionIdentificationModel : DTDFVocab:Model [
    base:desc "Model for continuous identification of joint friction parameters using time-series position data and operational state traces."
    DTDFVocab:inputTo SysMLModelingEnabler, SimulinkSimulationEnabler
]

instance PositionFeedbackData : DTDFVocab:Data [
    base:desc "Aggregated high-precision position feedback data from both motor and gearbox encoders, processed for closed-loop control validation."
    DTDFVocab:fromData MotorShaftPositionData, GearboxPositionData
    DTDFVocab:inputTo SysMLModelingEnabler, SimulinkSimulationEnabler
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Collected and processed contextual data including joint friction, operational states, and sensor readings for analysis and visualization."
    DTDFVocab:fromData MotorShaftPositionData, GearboxPositionData
    DTDFVocab:inputTo DataAggregationEnabler, VisualizationEnabler
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based modeling enabler supporting multi-layered modeling (requirements, functional/logical architecture) via Internal Block Diagrams and state machines."
    DTDFVocab:enables RobotKinematicService, JointFrictionAnalysisService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink enabler for detailed behavioral modeling, simulation of dynamic systems, and implementation of control algorithms."
    DTDFVocab:enables MotionAccuracyOptimizationService, FrictionCompensationService
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for collecting and processing contextual data traces from physical robot into structured digital representations."
    DTDFVocab:enables DataVisualizationService, PerformanceAnalysisService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for representing aggregated data in dashboards and visual interfaces for stakeholder interpretation."
    DTDFVocab:enables DataVisualizationService
]

instance MQTTDataStreamingEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol enabler for real-time transmission of time-series sensor data from physical components to digital shadow."
    DTDFVocab:enables DataAggregationService
]

// C6: Services
instance RobotKinematicService : DTDFVocab:Service [
    base:desc "Service providing kinematic analysis and validation of robot motion trajectories using position feedback data."
    DTDFVocab:provides RobotMotionAccuracyInsight
]

instance JointFrictionAnalysisService : DTDFVocab:Service [
    base:desc "Service for continuous identification and analysis of joint friction parameters based on operational data traces."
    DTDFVocab:provides JointFrictionCompensationInsight
]

instance MotionAccuracyOptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing robot motion accuracy through real-time control adjustments and model-driven validation."
    DTDFVocab:provides MotionAccuracyImprovementAction
]

instance FrictionCompensationService : DTDFVocab:Service [
    base:desc "Service implementing friction compensation algorithms in real-time control loops to enhance system performance."
    DTDFVocab:provides FrictionCompensationAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service enabling dashboard-based visualization of aggregated robot operational data for stakeholder interpretation."
    DTDFVocab:provides OperationalStateVisualizationInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Service collecting and processing contextual data traces from physical robot for digital shadow representation."
    DTDFVocab:provides ContextualDataInsight
]

instance PerformanceAnalysisService : DTDFVocab:Service [
    base:desc "Service analyzing robot performance metrics and identifying optimization opportunities based on operational data."
    DTDFVocab:provides PerformanceOptimizationInsight
]

// C17: Insights/Actions
instance RobotMotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Insight into robot motion accuracy derived from kinematic model validation against position feedback data."
]

instance JointFrictionCompensationInsight : DTDFVocab:Insight [
    base:desc "Insight into joint friction characteristics enabling targeted compensation strategies for improved performance."
]

instance MotionAccuracyImprovementAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of control parameters to improve motion accuracy based on real-time feedback."
    DTDFVocab:IsAutomatic true
]

instance FrictionCompensationAction : DTDFVocab:Action [
    base:desc "Automatic implementation of friction compensation algorithms in control loops to mitigate joint friction effects."
    DTDFVocab:IsAutomatic true
]

instance OperationalStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of robot operational states and contextual data traces for stakeholder interpretation."
]

instance ContextualDataInsight : DTDFVocab:Insight [
    base:desc "Aggregated contextual data traces including joint friction, operational states, and sensor readings for analysis."
]

instance PerformanceOptimizationInsight : DTDFVocab:Insight [
    base:desc "Identified optimization opportunities for robot performance based on operational data analysis."
]

// C1: Environment
instance RobotManufacturingEnvironment : DTDFVocab:Environment [
    base:desc "Manufacturing environment containing the MABI MAX 100 six-axis robot and associated physical components."
    base:contains PermanentMagnetSynchronousMotor, SiemensSINUMERIK840dController,
                RobotSafetyCell, MotorShaftPositionEncoder, GearboxPositionEncoder
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system operates within a **real-time, data-driven framework**, where synchronization between the physical and digital components relies on **live measurements** and **streamed data** (e.g., via MQTT or similar protocols). The temporal granularity is dictated by the need for **up-to-date representations** of the physical system's state, ensuring minimal latency to maintain fidelity. While exact synchronization frequencies are not specified, the system is designed to support **continuous, near-real-time updates** to reflect dynamic changes in the physical asset (e.g., Mabi). The architecture implicitly assumes **low-latency data acquisition** to enable real-time decision-making and autonomous processing of incoming data streams, aligning with the distinction between passive digital shadows (one-way data flow) and active Digital Twins (bidirectional interaction)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system’s orchestration and coordination are implicitly tied to the integration of heterogeneous modeling tools and methodologies from Model-Based Systems Engineering (MBSE). The document describes a multi-layered approach (e.g., RFLP, OOSEM, SPES, SMArDT) for system decomposition, where architecture description languages (ADLs) like ACME, AADL, MontiArc, or SysML IBDs define component-connector perspectives. Behavioral modeling is extended via tools like MathWorks Simulink, simulation frameworks, or general-purpose languages (C++, Java). The Digital Twin’s constellation thus relies on **orchestration patterns** that combine these tools to manage system-wide coordination, though no specific architecture pattern (e.g., microservices, service-oriented, or event-driven) is prescribed. Resource management is not explicitly detailed, but the integration of diverse stakeholders and perspectives (via MBSE) implies a need for **cross-domain coordination mechanisms** to align functional, logical, and physical layers."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system validates model fidelity through **comparative analysis of simulated data versus measured data**, focusing on **friction loss identification** in the first axis. **Executable simulation models** (e.g., **MathWorks MATLAB Simulink**) are employed to model joint friction dynamically, enabling **continuous, multi-physics-aware identification** of discrepancies. Validation relies on **real-time data streams** to refine models iteratively, ensuring alignment between digital and physical system behaviors. No explicit mention of **uncertainty quantification**, **error correction mechanisms**, or **quality assurance processes** (e.g., sensor noise mitigation, cross-tool validation) is provided in the documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for the Digital Shadow system relies on **MQTT (Message Queuing Telemetry Transport)** as the primary communication protocol for transmitting sensor data from the physical object to its digital representation. The document does not specify **network topology, architecture, bandwidth requirements, latency constraints, reliability mechanisms, or security protocols**. While MQTT is a lightweight protocol suitable for IoT and industrial applications, no further technical details (e.g., network segmentation, encryption, or redundancy) are provided in the text."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system must integrate with **heterogeneous modeling tools and notations** to address the complexity of multi-perspective system descriptions, as dictated by **MBSE methodologies**. While the document does not explicitly mention **enterprise systems (e.g., ERP, MES)** or **specific middleware technologies (e.g., APIs, model transformation frameworks)**, it emphasizes the need for **semantic interoperability** to bridge gaps between tools like **SysML, ADLs (ACME/AADL/MontiArc), Simulink, and general-purpose languages (C++/Java)**. The integration is primarily **internal to the Digital Twin ecosystem**, focusing on **data exchange and semantic alignment** across modeling layers and stakeholders. The system’s design implicitly supports **external data ingestion** (e.g., from physical assets via MQTT) but does not detail **standardized protocols** or **enterprise-level integration patterns** beyond the requirement for **heterogeneous tool compatibility**."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system incorporates a **physical safety cell** restricting the industrial robot's working range to **[-90°, 90°]** to prevent collisions or unsafe operations. The system leverages **Asset Administration Shells (AAS)** for structured data representation, enabling standardized communication and interoperability across the automation pyramid. While the documents mention **MQTT** for live-data streaming (e.g., in [42] and [52]), no explicit cybersecurity protocols (e.g., authentication, encryption, or access control) are detailed. The focus is on **mechanical safety constraints** and **model-driven engineering** (e.g., SysML, Functional Mockup Interface (FMI) via [51]) rather than cybersecurity frameworks like IEC 62443 or ISO 27001. No references to threat mitigation, fail-safe mechanisms, or compliance with safety standards (e.g., IEC 61508, ISO 26262) are provided."
]