// ---------------------------------------------------
// C3: Physical sensing components
// ---------------------------------------------------

// Motor encoder mounted on the motor shaft
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted on the motor shaft"
    DTDFVocab:producedData MotorEncoderAngleTransmitted
]

// Secondary encoder behind the gearbox
instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder placed behind the cycloidal gearbox"
    DTDFVocab:producedData GearboxEncoderAngleTransmitted
]

// Motor current sensor
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor phase current I_M"
    DTDFVocab:producedData MotorCurrentTransmitted
]

// CNC controller position output
instance CNCPositionSensor : DTDFVocab:SensingComponent [
    base:desc "CNC controller provides position output"
    DTDFVocab:producedData CNCPositionTransmitted
]

// CNC controller speed output
instance CNCSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "CNC controller provides speed output"
    DTDFVocab:producedData CNCSpeedTransmitted
]

// CNC controller acceleration output
instance CNCAccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "CNC controller provides acceleration output"
    DTDFVocab:producedData CNCAccelerationTransmitted
]

// ---------------------------------------------------
// C4: Physical-to-virtual interaction (DataTransmitted)
// ---------------------------------------------------

// Live sensor streams via MQTT
instance MotorEncoderAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance CNCPositionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CNCPositionSensor
]

instance CNCSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CNCSpeedSensor
]

instance CNCAccelerationTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CNCAccelerationSensor
]

// ---------------------------------------------------
// C10: Data (raw measurements & references)
// ---------------------------------------------------

// Measured data derived from live streams
instance MeasuredMotorEncoderAngle : DTDFVocab:Data [
    base:desc "Measured motor encoder angle I_M (raw)"
    DTDFVocab:fromData MotorEncoderAngleTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance MeasuredGearboxEncoderAngle : DTDFVocab:Data [
    base:desc "Measured gearbox encoder angle (raw)"
    DTDFVocab:fromData GearboxEncoderAngleTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance MeasuredMotorCurrent : DTDFVocab:Data [
    base:desc "Measured motor phase current I_M (raw)"
    DTDFVocab:fromData MotorCurrentTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance MeasuredCNCPosition : DTDFVocab:Data [
    base:desc "Measured CNC position output (raw)"
    DTDFVocab:fromData CNCPositionTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance MeasuredCNCSpeed : DTDFVocab:Data [
    base:desc "Measured CNC speed output (raw)"
    DTDFVocab:fromData CNCSpeedTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance MeasuredCNCAcceleration : DTDFVocab:Data [
    base:desc "Measured CNC acceleration output (raw)"
    DTDFVocab:fromData CNCAccelerationTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

// Reference data (outputs r_M, r_G, r_out) from controller/simulation
instance ReferenceMotorOutput : DTDFVocab:Data [
    base:desc "Reference motor output r_M (torque & angular velocity)"
    DTDFVocab:fromData MotorEncoderAngleTransmitted
    DTDFVocab:inputTo SimulinkEnabler
]

instance ReferenceGearOutput : DTDFVocab:Data [
    base:desc "Reference gear output r_G (torque & angular velocity)"
    DTDFVocab:fromData GearboxEncoderAngleTransmitted
    DTDFVocab:inputTo SimulinkEnabler
]

instance ReferenceAxisOutput : DTDFVocab:Data [
    base:desc "Reference axis output r_out (torque & angular velocity)"
    DTDFVocab:fromData MotorCurrentTransmitted
    DTDFVocab:inputTo SimulinkEnabler
]

// Simulated counterpart data (ˆr_M, ˆr_G, ˆr_out)
instance SimulatedMotorOutput : DTDFVocab:Data [
    base:desc "Simulated motor output ^r_M (torque & angular velocity) from MATLAB/Simulink"
    DTDFVocab:fromData MotorEncoderAngleTransmitted
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulatedGearOutput : DTDFVocab:Data [
    base:desc "Simulated gear output ^r_G (torque & angular velocity) from MATLAB/Simulink"
    DTDFVocab:fromData GearboxEncoderAngleTransmitted
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulatedAxisOutput : DTDFVocab:Data [
    base:desc "Simulated axis output ^r_out (torque & angular velocity) from MATLAB/Simulink"
    DTDFVocab:fromData MotorCurrentTransmitted
    DTDFVocab:inputTo SimulinkEnabler
]

// Derived data (torque, angular velocity, acceleration) computed from raw measurements
instance ComputedTorque : DTDFVocab:Data [
    base:desc "Torque computed from measured current and encoder data"
    DTDFVocab:fromData MotorCurrentTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance ComputedAngularVelocity : DTDFVocab:Data [
    base:desc "Angular velocity computed from encoder angle derivatives"
    DTDFVocab:fromData MotorEncoderAngleTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance ComputedAcceleration : DTDFVocab:Data [
    base:desc "Acceleration computed from speed derivative"
    DTDFVocab:fromData CNCSpeedTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

// ---------------------------------------------------
// C10: Models
// ---------------------------------------------------

// Engineering models (SysML)
instance SysMLAxisBlockModel : DTDFVocab:Model [
    base:desc "SysML block definition diagram of the first robot axis"
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLAxisIBDModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram of the first robot axis"
    DTDFVocab:inputTo SysMLEnabler
]

// Simulation models (MATLAB/Simulink)
instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the permanent‑magnet synchronous motor"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulinkGearwheelModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the gearwheel"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulinkGearboxFrictionModel_CoulombViscous : DTDFVocab:Model [
    base:desc "MATLAB/Simulink gearbox friction model with Coulomb–Viscous formulation"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulinkGearboxFrictionModel_Stribeck : DTDFVocab:Model [
    base:desc "MATLAB/Simulink gearbox friction model using the Stribeck curve"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulinkGearboxFrictionModel_Dahl : DTDFVocab:Model [
    base:desc "MATLAB/Simulink gearbox friction model following Dahl dynamics"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulinkGearboxFrictionModel_LuGre : DTDFVocab:Model [
    base:desc "MATLAB/Simulink gearbox friction model based on the LuGre model"
    DTDFVocab:inputTo SimulinkEnabler
]

// ---------------------------------------------------
// C11: Enablers (tooling)
// ---------------------------------------------------
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML toolchain used for structural modeling of the axis"
    DTDFVocab:enables EngineeringModelService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for executable simulation of motor and gearbox"
    DTDFVocab:enables SimulationExecutionService
]

instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker used to stream live sensor data to the digital shadow"
    DTDFVocab:enables RealTimeDataIngestionService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell integration layer for model interoperability"
    DTDFVocab:enables ModelManagementService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Custom dashboard for real‑time visualization of twin data"
    DTDFVocab:enables DashboardVisualizationService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that computes torque, velocity and acceleration from raw streams"
    DTDFVocab:enables FrictionIdentificationService , MotionControlAccuracyImprovementService
]

// ---------------------------------------------------
// C6: Services
// ---------------------------------------------------
instance EngineeringModelService : DTDFVocab:Service [
    base:desc "Service that provides access to SysML engineering models"
    DTDFVocab:provides ModelingInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service that runs MATLAB/Simulink simulations and returns reference data"
    DTDFVocab:provides SimulationInsight
]

instance RealTimeDataIngestionService : DTDFVocab:Service [
    base:desc "Service that ingests live MQTT sensor streams into the twin"
    DTDFVocab:provides RealTimeDataInsight
]

instance ModelManagementService : DTDFVocab:Service [
    base:desc "Service that manages AAS‑based model versions and updates"
    DTDFVocab:provides ModelUpdateInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time dashboard visualization of sensor, computed and simulated data"
    DTDFVocab:provides VisualizationInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of static, kinetic and viscous friction parameters per gear stage"
    DTDFVocab:provides FrictionParameterIdentificationInsight
]

instance MotionControlAccuracyImprovementService : DTDFVocab:Service [
    base:desc "Support for adjusting control algorithms to improve positional accuracy"
    DTDFVocab:provides ControlAlgorithmAdjustmentAction
]

// ---------------------------------------------------
// C17: Insights / Actions
// ---------------------------------------------------
instance FrictionParameterIdentificationInsight : DTDFVocab:Insight [
    base:desc "Identification of static, kinetic and viscous friction parameters per gear stage"
]

instance ControlAlgorithmAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjustment of motion‑control algorithms based on identified friction parameters"
    DTDFVocab:IsAutomatic true
]

instance ModelingInsight : DTDFVocab:Insight [
    base:desc "Insight into the structural composition of the axis derived from SysML models"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from simulation runs comparing measured and simulated torque/velocity trajectories"
]

instance RealTimeDataInsight : DTDFVocab:Insight [
    base:desc "Insight from live sensor streams enabling immediate twin state updates"
]

instance ModelUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight that model versions have been synchronized via the Asset Administration Shell"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight presented on the custom dashboard for operators"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital shadow operates in real‑time, processing sensor streams continuously as the robot runs. Data are received and processed without batching, allowing immediate comparison of measured and simulated values during operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow named FrictionShadow with purpose class FrictionDerivation, asset class Mabi (first axis), processing components SimulationM, SimulationGW, SimulationGB that consume input traces and produce simulated outputs, all linked through the Digital Shadow Reference Model and presented in a unified dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated (runtime) stage – the digital shadow is created and used during robot operation to monitor and identify friction."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Combines analytical white‑box friction models and data‑driven black‑box models; traceability is maintained via the Processing component linking input traces to output; model validity is assessed by comparing simulated data against measured reference traces."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted to the digital shadow over MQTT; Asset Administration Shells provide structured metadata."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Uses the Asset Administration Shell (AAS) standard, SysML (OMG) for modeling, and follows the Digital Shadow Reference Model (Kritzinger et al.)"
]