instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures input current for the first axis of MABI MAX 100 robot"
    DTDFVocab:producedData MQTTDataTransmission
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Measures output angle for the first axis of MABI MAX 100 robot"
    DTDFVocab:producedData MQTTDataTransmission
]

instance MQTTDataTransmission : DTDFVocab:DataTransmitted [
    base:desc "Time series sensor data transmitted via MQTT protocol from physical robot to digital twin"
    DTDFVocab:producedFrom InputCurrentSensor, OutputAngleSensor
]

instance InputCurrentData : DTDFVocab:Data [
    base:desc "Time series input current data from physical robot's first axis"
    DTDFVocab:fromData MQTTDataTransmission
    DTDFVocab:inputTo SimulinkEnabler, JavaEnabler, CppEnabler
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Time series output angle data from physical robot's first axis"
    DTDFVocab:fromData MQTTDataTransmission
    DTDFVocab:inputTo SimulinkEnabler, JavaEnabler, CppEnabler
]

instance StructuralModel_SysML_IBD : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram for structural (geometric) modeling of MABI MAX 100 robot"
    DTDFVocab:inputTo SysMLEnabler, ACMEEnabler, AADLEnabler
]

instance BehavioralModel_MontiArcAutomaton : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling of MABI MAX 100 robot"
    DTDFVocab:inputTo MontiArcEnabler
]

instance StateMachineModel_SysML : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines for behavioral modeling of MABI MAX 100 robot"
    DTDFVocab:inputTo SysMLEnabler
]

instance AnalyticalSimulationModel_Simulink : DTDFVocab:Model [
    base:desc "MathWorks Simulink analytical simulation model for MABI MAX 100 robot"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for multi-level abstraction modeling (requirements, functional architecture, logical architecture, product/technical layer)"
    DTDFVocab:enables JointFrictionIdentificationService, VisualizationService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component & connector perspectives"
    DTDFVocab:enables JointFrictionIdentificationService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component & connector perspectives"
    DTDFVocab:enables JointFrictionIdentificationService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component & connector perspectives"
    DTDFVocab:enables JointFrictionIdentificationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation tool for analytical simulations"
    DTDFVocab:enables JointFrictionIdentificationService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for implementation and simulation"
    DTDFVocab:enables VisualizationService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for implementation and dashboard"
    DTDFVocab:enables VisualizationService
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP methodology for system complexity management"
    DTDFVocab:enables JointFrictionIdentificationService, VisualizationService
]

instance OOSEMMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for system complexity management"
    DTDFVocab:enables JointFrictionIdentificationService, VisualizationService
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for system complexity management"
    DTDFVocab:enables JointFrictionIdentificationService, VisualizationService
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for system complexity management"
    DTDFVocab:enables JointFrictionIdentificationService, VisualizationService
]

instance JointFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous multi-physics-aware identification of joint friction to improve robot motion accuracy"
    DTDFVocab:provides JointFrictionInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Unified dashboard for real-time data visualization and decision support"
    DTDFVocab:provides DashboardInsight
]

instance JointFrictionInsight : DTDFVocab:Insight [
    base:desc "Continuous multi-physics-aware identification of joint friction to improve robot motion accuracy"
]

instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Real-time data visualization and decision support via unified dashboard"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system utilizes real-time data-driven representations with live measurements and time series of all sensors for synchronization, maintaining temporal granularity based on sensor sampling rates to ensure accurate state representation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system architecture follows a Digital Shadow Reference Model defined via UML class diagram, comprising components such as Purpose, Data Trace, Asset, Processing, and Model, integrated using component & connector perspective with ADLs including ACME, AADL, MontiArc, and SysML IBDs for structural and behavioral description."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for data transmission between physical and digital components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with industry standards including SysML [17] for systems engineering modeling, ACME [23], AADL [24], MontiArc [25, 26] for architecture description languages, and SysML Internal Block Diagrams (IBDs) [17, 27] for component and connector perspectives. Interoperability between heterogeneous modeling tools and notations is addressed through standardized interfaces to integrate stakeholder perspectives [31]."
]