prefix DTDFVocab: http://example.org/DTDFVocab
prefix base: http://example.org/base
instance RFLPInsight : DTDFVocab:Insight [
    base:desc "Requirements and abstraction insights from RFLP methodology"
]
instance OOSEMInsight : DTDFVocab:Insight [
    base:desc "Requirements and abstraction insights from OOSEM methodology"
]
instance SPESInsight : DTDFVocab:Insight [
    base:desc "Requirements and abstraction insights from SPES methodology"
]
instance SMArDTInsight : DTDFVocab:Insight [
    base:desc "Requirements and abstraction insights from SMArDT methodology"
]
instance ACMEInsight : DTDFVocab:Insight [
    base:desc "Component and connector insights from ACME ADL"
]
instance AADLInsight : DTDFVocab:Insight [
    base:desc "Embedded systems insights from AADL ADL"
]
instance MontiArcInsight : DTDFVocab:Insight [
    base:desc "Component-based systems insights from MontiArc ADL"
]
instance SysMLIBDInsight : DTDFVocab:Insight [
    base:desc "Component interfaces and interconnections insights from SysML IBDs"
]
instance MontiArcAutomatonInsight : DTDFVocab:Insight [
    base:desc "Behavioral modeling insights from MontiArc Automaton"
]
instance SysMLStateMachinesInsight : DTDFVocab:Insight [
    base:desc "Behavioral modeling insights from SysML v1.7 state machines"
]
instance SimulinkInsight : DTDFVocab:Insight [
    base:desc "Simulation insights from MathWorks Simulink"
]
instance CppInsight : DTDFVocab:Insight [
    base:desc "Detailed behavior insights from C++ code"
]
instance JavaInsight : DTDFVocab:Insight [
    base:desc "Detailed behavior insights from Java code"
]
instance RFLPService : DTDFVocab:Service [
    base:desc "Multi-level abstraction service using RFLP methodology"
    DTDFVocab:provides RFLPInsight
]
instance OOSEMService : DTDFVocab:Service [
    base:desc "Multi-level abstraction service using OOSEM methodology"
    DTDFVocab:provides OOSEMInsight
]
instance SPESService : DTDFVocab:Service [
    base:desc "Multi-level abstraction service using SPES methodology"
    DTDFVocab:provides SPESInsight
]
instance SMArDTService : DTDFVocab:Service [
    base:desc "Multi-level abstraction service using SMArDT methodology"
    DTDFVocab:provides SMArDTInsight
]
instance ACMEService : DTDFVocab:Service [
    base:desc "Component & connector modeling service using ACME ADL"
    DTDFVocab:provides ACMEInsight
]
instance AADLService : DTDFVocab:Service [
    base:desc "Embedded systems modeling service using AADL ADL"
    DTDFVocab:provides AADLInsight
]
instance MontiArcService : DTDFVocab:Service [
    base:desc "Component-based systems modeling service using MontiArc ADL"
    DTDFVocab:provides MontiArcInsight
]
instance SysMLIBDService : DTDFVocab:Service [
    base:desc "Component interfaces and interconnections service using SysML IBDs"
    DTDFVocab:provides SysMLIBDInsight
]
instance MontiArcAutomatonService : DTDFVocab:Service [
    base:desc "Behavioral modeling service using MontiArc Automaton"
    DTDFVocab:provides MontiArcAutomatonInsight
]
instance SysMLStateMachinesService : DTDFVocab:Service [
    base:desc "Behavioral modeling service using SysML v1.7 state machines"
    DTDFVocab:provides SysMLStateMachinesInsight
]
instance SimulinkService : DTDFVocab:Service [
    base:desc "Simulation service using MathWorks Simulink"
    DTDFVocab:provides SimulinkInsight
]
instance CppService : DTDFVocab:Service [
    base:desc "Detailed behavior modeling service using C++"
    DTDFVocab:provides CppInsight
]
instance JavaService : DTDFVocab:Service [
    base:desc "Detailed behavior modeling service using Java"
    DTDFVocab:provides JavaInsight
]
instance RFLPEnabler : DTDFVocab:Enabler [
    base:desc "RFLP methodology for multi-level abstraction"
    DTDFVocab:enables RFLPService
]
instance OOSEMEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for multi-level abstraction"
    DTDFVocab:enables OOSEMService
]
instance SPESEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for multi-level abstraction"
    DTDFVocab:enables SPESService
]
instance SMArDTEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for multi-level abstraction"
    DTDFVocab:enables SMArDTService
]
instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component & connector modeling"
    DTDFVocab:enables ACMEService
]
instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for embedded systems"
    DTDFVocab:enables AADLService
]
instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component-based systems"
    DTDFVocab:enables MontiArcService
]
instance SysMLIBDEnabler : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component interfaces and interconnections"
    DTDFVocab:enables SysMLIBDService
]
instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:enables MontiArcAutomatonService
]
instance SysMLStateMachinesEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 state machines for behavioral modeling"
    DTDFVocab:enables SysMLStateMachinesService
]
instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and detailed behavior modeling"
    DTDFVocab:enables SimulinkService
]
instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior modeling"
    DTDFVocab:enables CppService
]
instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior modeling"
    DTDFVocab:enables JavaService
]
instance RequirementsModel : DTDFVocab:Model [
    base:desc "Requirements abstraction level model"
    DTDFVocab:inputTo RFLPEnabler
]
instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "Functional architecture level model"
    DTDFVocab:inputTo OOSEMEnabler
]
instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Logical architecture level model"
    DTDFVocab:inputTo SPESEnabler
]
instance ProductTechnicalLayerModel : DTDFVocab:Model [
    base:desc "Product/technical layer model"
    DTDFVocab:inputTo SMArDTEnabler
]
instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language for component & connector modeling"
    DTDFVocab:inputTo ACMEEnabler
]
instance AADLModel : DTDFVocab:Model [
    base:desc "AADL Architecture Description Language for embedded systems"
    DTDFVocab:inputTo AADLEnabler
]
instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc Architecture Description Language for component-based systems"
    DTDFVocab:inputTo MontiArcEnabler
]
instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams for component interfaces and interconnections"
    DTDFVocab:inputTo SysMLIBDEnabler
]
instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcAutomatonEnabler
]
instance SysMLStateMachinesModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines for behavioral modeling"
    DTDFVocab:inputTo SysMLStateMachinesEnabler
]
instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink for simulation and detailed behavior modeling"
    DTDFVocab:inputTo SimulinkEnabler
]
instance CppCodeModel : DTDFVocab:Model [
    base:desc "C++ programming language for detailed behavior modeling"
    DTDFVocab:inputTo CppEnabler
]
instance JavaCodeModel : DTDFVocab:Model [
    base:desc "Java programming language for detailed behavior modeling"
    DTDFVocab:inputTo JavaEnabler
]
instance RFLPMethodologyModel : DTDFVocab:Model [
    base:desc "RFLP methodology for multi-level abstraction"
    DTDFVocab:inputTo RFLPEnabler
]
instance OOSEMMethodologyModel : DTDFVocab:Model [
    base:desc "OOSEM methodology for multi-level abstraction"
    DTDFVocab:inputTo OOSEMEnabler
]
instance SPESMethodologyModel : DTDFVocab:Model [
    base:desc "SPES methodology for multi-level abstraction"
    DTDFVocab:inputTo SPESEnabler
]
instance SMArDTMethodologyModel : DTDFVocab:Model [
    base:desc "SMArDT methodology for multi-level abstraction"
    DTDFVocab:inputTo SMArDTEnabler
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin employs Model-Based Systems Engineering (MBSE) methodologies using SysML for system modeling, Architecture Description Languages (ADLs) such as AADL, ACME, and MontiArc for component & connector perspectives, and tools like MathWorks Simulink for behavior simulation. Methodologies including RFLP, OOSEM, SPES, and SMArDT manage abstraction levels across requirements, functional, logical, and product/technical layers, ensuring compliance with industry standards and interoperability among heterogeneous stakeholders."
]