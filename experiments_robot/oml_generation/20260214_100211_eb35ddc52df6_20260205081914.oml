// C3: Physical sensing components
instance OperationalLogCollector : DTDFVocab:SensingComponent [
    base:desc "Passive collection of operational logs from physical system components, aggregated via one-way data flow mechanisms"
    DTDFVocab:producedData OperationalLogDataTransmitted
]

instance SensorTelemetryCollector : DTDFVocab:SensingComponent [
    base:desc "Real-time sensor data acquisition from physical system components, supporting IIoT protocols or custom middleware"
    DTDFVocab:producedData SensorTelemetryDataTransmitted
]

instance ContextualDataTraceCollector : DTDFVocab:SensingComponent [
    base:desc "Aggregation of contextual data traces including sensor readings, IoT telemetry, and operational logs for Digital Shadow"
    DTDFVocab:producedData ContextualDataTraceTransmitted
]

// C4: Physical-to-virtual interaction
instance OperationalLogDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalLogCollector
]

instance SensorTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SensorTelemetryCollector
]

instance ContextualDataTraceTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContextualDataTraceCollector
]

// C10: Models/Data
instance SysMLInternalBlockDiagramModel : DTDFVocab:Model [
    base:desc "Component-connector based system architecture model using SysML Internal Block Diagrams for structural representation"
    DTDFVocab:inputTo SysMLToolchainEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "Behavioral model of system dynamics using SysML state machines (v1.7+) for stateful behavior representation"
    DTDFVocab:inputTo SysMLToolchainEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "Component-based behavioral model using MontiArc Automaton for stateful behavior and event-driven interactions"
    DTDFVocab:inputTo MontiArcToolchainEnabler
]

instance MathWorksSimulinkModel : DTDFVocab:Model [
    base:desc "Detailed behavioral simulation model for control system design and co-simulation with other tools"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance DigitalShadowData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces from physical system, preprocessed for consistency"
    DTDFVocab:fromData ContextualDataTraceTransmitted
    DTDFVocab:inputTo DigitalShadowIntegrationEnabler
]

instance OperationalData : DTDFVocab:Data [
    base:desc "Heterogeneous operational data including real-time sensor feeds and historical operational traces"
    DTDFVocab:fromData SensorTelemetryDataTransmitted, OperationalLogDataTransmitted
    DTDFVocab:inputTo DataIntegrationEnabler
]

instance HeterogeneousData : DTDFVocab:Data [
    base:desc "Bridged data formats between Digital Shadow data and MBSE models through model transformation frameworks"
    DTDFVocab:fromData DigitalShadowData, OperationalData
    DTDFVocab:inputTo DataTransformationEnabler
]

// C11: Enablers
instance SysMLToolchainEnabler : DTDFVocab:Enabler [
    base:desc "Integration of SysML tools (e.g., Cameo, MagicDraw) for collaborative modeling and system architecture description"
    DTDFVocab:enables SysMLModelingService, StateMachineSimulationService
]

instance MontiArcToolchainEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc IDE for component-based modeling with automata and event-driven interactions"
    DTDFVocab:enables AutomatonBehaviorService, ComponentInteractionService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed behavioral simulation and control system design"
    DTDFVocab:enables SimulationValidationService, ControlSystemDesignService
]

instance DigitalShadowIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Digital Shadow data aggregation and abstraction mechanisms with one-way data flow protocols"
    DTDFVocab:enables DataAggregationService, ContextualAnalysisService
]

instance DataIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Heterogeneous data integration tools bridging Digital Shadow data formats with MBSE models"
    DTDFVocab:enables DataBridgingService, ModelDataIntegrationService
]

instance DataTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Model transformation frameworks and APIs for data format compatibility between DS and MBSE"
    DTDFVocab:enables DataFormatConversionService, ModelDataMappingService
]

instance RFLPMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "Requirements, Functions, Logics, Physics methodology for multi-abstraction modeling and traceability"
    DTDFVocab:enables MultiAbstractionModelingService, TraceabilityManagementService
]

instance OOSEMMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "Object-Oriented Systems Engineering Method for complex system decomposition and integration"
    DTDFVocab:enables SystemDecompositionService, IntegrationValidationService
]

instance SPESMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "Software Product-Line Engineering and Systems methodology for reusable system components"
    DTDFVocab:enables ComponentReusabilityService, SystemVariationManagementService
]

instance SMArDTMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "Smart Digital Twin methodology for harmonizing diverse stakeholder perspectives"
    DTDFVocab:enables StakeholderIntegrationService, PerspectiveHarmonizationService
]

