// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) on the vertical axis motor"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted on the motor shaft"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance SecondaryEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder placed after the gearbox"
    DTDFVocab:producedData SecondaryEncoderDataTransmitted
]

instance RobotControllerOutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Robot controller output angle sensor providing r_out"
    DTDFVocab:producedData OutputAngleDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance SecondaryEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoderSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotControllerOutputAngleSensor
]

instance SimulatedTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    // No producedFrom relation (simulation model not a SensingComponent)
]

instance SimulatedVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    // No producedFrom relation (simulation model not a SensingComponent)
]

instance FrictionParametersDataTransmitted : DTDFVocab:DataTransmitted [
    // No producedFrom relation (calculation model not a SensingComponent)
]

// C10: Data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor current (I_M) streamed via MQTT"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTEnabler
]

instance MotorEncoderData : DTDFVocab:Data [
    base:desc "Time‑series of motor encoder position streamed via MQTT"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MQTTEnabler
]

instance SecondaryEncoderData : DTDFVocab:Data [
    base:desc "Time‑series of secondary encoder position streamed via MQTT"
    DTDFVocab:fromData SecondaryEncoderDataTransmitted
    DTDFVocab:inputTo MQTTEnabler
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Time‑series of output angle (r_out) streamed via MQTT"
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo MQTTEnabler
]

instance SimulatedTorqueData : DTDFVocab:Data [
    base:desc "Simulated torque trace generated by the MATLAB/Simulink model"
    DTDFVocab:fromData SimulatedTorqueDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

instance SimulatedVelocityData : DTDFVocab:Data [
    base:desc "Simulated velocity trace generated by the MATLAB/Simulink model"
    DTDFVocab:fromData SimulatedVelocityDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

instance FrictionParametersData : DTDFVocab:Data [
    base:desc "Calculated friction parameters (static, kinetic, viscous) derived from live sensor traces"
    DTDFVocab:fromData FrictionParametersDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

// C10: Models
instance SysMLAssetStructureModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams describing motor, gearwheel and gearbox structure"
    DTDFVocab:inputTo SysMLEnabler
]

instance MotorGearboxSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the permanent‑magnet synchronous motor, gearwheel and cycloidal gearbox"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance FrictionParameterCalculationModel : DTDFVocab:Model [
    base:desc "Data calculation model processing live sensor traces to compute simulated torque, velocity and friction parameters"
    DTDFVocab:inputTo MQTTEnabler, DashboardEnabler
]

// C11: Enablers
instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker used for streaming live sensor data from robot controller to the digital shadow"
    DTDFVocab:enables FrictionIdentificationService, VisualizationDashboardService, ModelBasedControlImprovementService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard application visualizing data and model outputs in a unified interface"
    DTDFVocab:enables VisualizationDashboardService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment executing simulation models of motor, gearwheel and gearbox"
    DTDFVocab:enables FrictionIdentificationService, ModelBasedControlImprovementService
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML tooling used to define asset structure and model relationships"
    DTDFVocab:enables FrictionIdentificationService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell linking model data with physical asset metadata"
    DTDFVocab:enables ModelBasedControlImprovementService
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Identifies static, kinetic and viscous friction by comparing simulated and measured torque/velocity"
    DTDFVocab:provides FrictionParametersInsight, DeviationHighlightInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Visualizes sensor data, simulated traces and friction parameters in a unified dashboard"
    DTDFVocab:provides DeviationHighlightInsight
]

instance ModelBasedControlImprovementService : DTDFVocab:Service [
    base:desc "Improves motion control by feeding back friction parameters to the robot controller"
    DTDFVocab:provides FeedBackControlAction
]

// C17: Insights/Actions
instance FrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters (static, kinetic, viscous) for the vertical axis"
]

instance DeviationHighlightInsight : DTDFVocab:Insight [
    base:desc "Detected deviations between measured and simulated torque/velocity behavior"
]

instance FeedBackControlAction : DTDFVocab:Action [
    base:desc "Feed friction parameters back to the robot controller to enhance motion accuracy"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is defined as a passive one‑way data flow; no commands or control signals are sent from the virtual model back to the robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data acquisition and processing are performed in real‑time (continuous) during robot operation; the paper does not specify a numeric sampling rate."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow constellation follows the Digital Shadow Reference Model: a Purpose (FrictionDerivation), an Asset (MABI axis), Sources (sensors, MQTT channels), Processing components (Simulation_M, Simulation_GW, Simulation_GB) that consume input traces and produce output traces, and Models (engineering, simulation, data‑calculation) linked via explicit associations."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow spans the operated stage of the robot, using engineering models (SysML structural model) created during design and live operational data for runtime identification of friction."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability is ensured by linking each DataPoint to its originating sensor and processing component; friction models are validated by comparing simulated torque/velocity against measured references; the system supports continuous re‑identification to maintain model fidelity over wear."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot controller to the digital shadow via MQTT; the Asset Administration Shell provides structured metadata linking; no other network protocols are described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation uses the Asset Administration Shell (AAS) specification and SysML, which are established standards in Industry 4.0 for data and model representation."
]