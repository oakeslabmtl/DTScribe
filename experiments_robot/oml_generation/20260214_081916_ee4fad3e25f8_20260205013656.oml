instance Motor : DTDFVocab:Component [
    base:desc "Motor component of the MABI MAX 100 serial robot used for precise motion control in machining operations"
]

instance Gearbox : DTDFVocab:Component [
    base:desc "Gearbox component of the MABI MAX 100 serial robot enabling precise motion control"
]

instance Encoder : DTDFVocab:Component [
    base:desc "Encoder component of the MABI MAX 100 serial robot providing position feedback"
]

instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input current of the MABI MAX 100 robot"
    DTDFVocab:producedData InputCurrentData
]

instance AngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring output angle of the MABI MAX 100 robot axes"
    DTDFVocab:producedData OutputAngleData
]

instance InputCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
]

instance OutputAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngleSensor
]

instance InputCurrentTimeSeriesData : DTDFVocab:Data [
    base:desc "Time series data of input current from MABI MAX 100 robot sensors"
    DTDFVocab:fromData InputCurrentData
    DTDFVocab:inputTo Simulink, Cpp, Java
]

instance OutputAngleTimeSeriesData : DTDFVocab:Data [
    base:desc "Time series data of output angle from MABI MAX 100 robot sensors"
    DTDFVocab:fromData OutputAngleData
    DTDFVocab:inputTo Simulink, Cpp, Java
]

instance SysMLModel : DTDFVocab:Model [
    base:desc "SysML model covering requirements, functional, logical, and product/technical layers for MABI MAX 100 robot"
    DTDFVocab:inputTo SysMLIBD
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME architecture description model for component & connector structures"
    DTDFVocab:inputTo ACME
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL architecture description model for system components and interfaces"
    DTDFVocab:inputTo AADL
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description model for system composition"
    DTDFVocab:inputTo MontiArc
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) model for component & connector structures"
    DTDFVocab:inputTo SysMLIBD
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton behavioral model for state transitions"
    DTDFVocab:inputTo MontiArcAutomaton
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machine behavioral model for robot motion control"
    DTDFVocab:inputTo SysMLStateMachine
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink analytical model for dynamic system simulation"
    DTDFVocab:inputTo Simulink
]

instance CppCodeModel : DTDFVocab:Model [
    base:desc "C++ general-purpose code model for system logic"
    DTDFVocab:inputTo Cpp
]

instance JavaCodeModel : DTDFVocab:Model [
    base:desc "Java general-purpose code model for system logic"
    DTDFVocab:inputTo Java
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements, Functions, Logics, Physics) MBSE methodology for layered abstraction"
    DTDFVocab:enables RealTimeMonitoringService
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM MBSE methodology for layered abstraction"
    DTDFVocab:enables RealTimeMonitoringService
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES MBSE methodology for layered abstraction"
    DTDFVocab:enables RealTimeMonitoringService
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT MBSE methodology for layered abstraction"
    DTDFVocab:enables RealTimeMonitoringService
]

instance ACME : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for system component modeling"
    DTDFVocab:enables RealTimeMonitoringService
]

instance AADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for system interface modeling"
    DTDFVocab:enables RealTimeMonitoringService
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component composition"
    DTDFVocab:enables RealTimeMonitoringService
]

instance SysMLIBD : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component & connector structures"
    DTDFVocab:enables RealTimeMonitoringService
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:enables RealTimeMonitoringService
]

instance SysMLStateMachine : DTDFVocab:Enabler [
    base:desc "SysML state machines for dynamic behavior modeling"
    DTDFVocab:enables RealTimeMonitoringService
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and analytical modeling"
    DTDFVocab:enables RealTimeMonitoringService
]

instance Cpp : DTDFVocab:Enabler [
    base:desc "C++ general-purpose programming language for system logic"
    DTDFVocab:enables RealTimeMonitoringService
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java general-purpose programming language for system logic"
    DTDFVocab:enables RealTimeMonitoringService
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real-time monitoring of MABI MAX 100 robot operations"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight on real-time status of robot components for monitoring purposes"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization of live measurements from the physical system to the digital shadow via one-way data flow, ensuring continuous state representation without feedback to the physical system, as defined by Kritzinger et al. [32]."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Shadow Reference Model (DSRM) defines a concrete architecture with Processing (consuming and producing data traces), Model (digital representation), and Asset (physical system interface) components, where data flows from Asset to Processing for aggregation and abstraction before being processed by the Model component."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for sensor data transmission between physical and digital components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with industry standards such as SysML [17], AADL [24], ACME [23], and MontiArc [25], [26] for architecture description and systems modeling. These standards enable interoperability through component & connector perspectives and support integration of diverse stakeholders [31]."
]