// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving the first axis via gear transmission to achieve precise motion control."
]

instance CycloidalGearTransmission : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear transmission used for precise motion control in the robot's first axis."
]

instance SiemensSINUMERIK840DslController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl controller governing actuation commands and interfacing with the physical system."
]

instance SafetyCell : DTDFVocab:ActingComponent [
    base:desc "Safety cell enforcing operational limits and restricting maximum working range of the robot."
]

// C3: Physical Sensing Components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted directly on the motor shaft for high-resolution angular position feedback."
    DTDFVocab:producedData MotorShaftEncoderDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder positioned behind the gearbox to monitor positional feedback after transmission."
    DTDFVocab:producedData GearboxPositionEncoderDataTransmitted
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring torque at the motor output shaft for dynamic analysis."
    DTDFVocab:producedData TorqueSensorDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring angular velocity of the motor shaft for kinematic analysis."
    DTDFVocab:producedData AngularVelocitySensorDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input current to the permanent magnet synchronous motor for power analysis."
    DTDFVocab:producedData MotorCurrentSensorDataTransmitted
]

instance GearboxStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring gearbox operational parameters including temperature and wear indicators."
    DTDFVocab:producedData GearboxStateSensorDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance MotorShaftEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxPositionEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

instance TorqueSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
]

instance AngularVelocitySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

instance MotorCurrentSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance GearboxStateSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxStateSensor
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "Mathematical model describing the robot's kinematic relationships between joint angles and end-effector positions."
    DTDFVocab:inputTo SysMLModelingEnabler, SimulinkSimulationEnabler
]

instance DynamicModel : DTDFVocab:Model [
    base:desc "Mathematical model describing the robot's dynamic behavior including forces, torques, and accelerations."
    DTDFVocab:inputTo SysMLModelingEnabler, SimulinkSimulationEnabler
]

instance JointFrictionModel : DTDFVocab:Model [
    base:desc "Data-driven model identifying joint friction characteristics through analysis of sensor data traces."
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance RobotControlModel : DTDFVocab:Model [
    base:desc "Control model implementing the robot's motion control algorithms executed by the Siemens SINUMERIK 840D sl controller."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance TimeSeriesSensorData : DTDFVocab:Data [
    base:desc "Aggregated time-series data from all sensors including torque, angular velocity, current, and positional feedback."
    DTDFVocab:fromData MotorShaftEncoderDataTransmitted, GearboxPositionEncoderDataTransmitted, TorqueSensorDataTransmitted, AngularVelocitySensorDataTransmitted, MotorCurrentSensorDataTransmitted, GearboxStateSensorDataTransmitted
    DTDFVocab:inputTo SysMLModelingEnabler, SimulinkSimulationEnabler, MQTTCommunicationEnabler
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Contextual data traces collected for analysis including temporal correlations and operational context."
    DTDFVocab:fromData TimeSeriesSensorData
    DTDFVocab:inputTo SysMLModelingEnabler, DataAggregationEnabler
]

instance SimulationResults : DTDFVocab:Data [
    base:desc "Output data from behavioral simulations including predicted system responses under varying conditions."
]

instance SimulinkSimulationOutput : DTDFVocab:Data [
    base:desc "Raw simulation output from MathWorks Simulink containing detailed behavioral responses."
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML (Systems Modeling Language) for structural and behavioral modeling across multiple abstraction layers (requirements, functional architecture, logical architecture, and product/technical layers)."
    DTDFVocab:enables MonitoringService, DiagnosticsService, SimulationAnalysisService, DataDrivenInsightsService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed behavioral modeling and simulation of system dynamics."
    DTDFVocab:enables SimulationAnalysisService, DataDrivenInsightsService
]

instance MQTTCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol for real-time data exchange between physical system and digital representation."
    DTDFVocab:enables MonitoringService, DiagnosticsService
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "Automated aggregation and abstraction of sensor data for purpose-specific analytics."
    DTDFVocab:enables DataDrivenInsightsService
]

instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Real-time visualization platform for monitoring joint angles, motor currents, gearbox states, and other operational parameters."
    DTDFVocab:enables MonitoringService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of operational parameters (joint angles, motor currents, gearbox states) and identification of joint friction through data-driven analysis."
    DTDFVocab:provides RealTimeDashboardInsight, JointFrictionIdentificationInsight
]

instance DiagnosticsService : DTDFVocab:Service [
    base:desc "Fault detection through abstraction and aggregation of sensor data to identify anomalies in motor/gearbox behavior."
    DTDFVocab:provides FaultDetectionInsight, AnomalyAlertAction
]

instance SimulationAnalysisService : DTDFVocab:Service [
    base:desc "Behavioral modeling using mathematical models (e.g., Simulink) to predict system responses under varying conditions."
    DTDFVocab:provides PredictiveSimulationInsight, SystemResponsePredictionInsight
]

instance DataDrivenInsightsService : DTDFVocab:Service [
    base:desc "Aggregation and abstraction of sensor data for purpose-specific analytics including predictive maintenance and performance benchmarking."
    DTDFVocab:provides PredictiveMaintenanceInsight, PerformanceBenchmarkingInsight
]

// C17: Insights/Actions
instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of joint angles, motor currents, and gearbox states in a unified dashboard for operational monitoring."
]

instance JointFrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Data-driven identification of joint friction characteristics through analysis of contextual data traces."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of anomalies in motor and gearbox behavior through sensor data aggregation and abstraction."
]

instance AnomalyAlertAction : DTDFVocab:Action [
    base:desc "Automatic generation of alerts when anomalies are detected in motor or gearbox behavior."
    DTDFVocab:IsAutomatic true
]

instance PredictiveSimulationInsight : DTDFVocab:Insight [
    base:desc "Predicted system responses under varying conditions derived from behavioral simulations."
]

instance SystemResponsePredictionInsight : DTDFVocab:Insight [
    base:desc "Detailed predictions of system behavior including kinematic and dynamic responses."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Insights for predictive maintenance derived from aggregated sensor data and behavioral models."
]

instance PerformanceBenchmarkingInsight : DTDFVocab:Insight [
    base:desc "Performance metrics and benchmarks derived from operational data and simulation results."
]

// C1: Environment
instance IndustrialRobotEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotor, CycloidalGearTransmission, SiemensSINUMERIK840DslController, SafetyCell, MotorShaftEncoder, GearboxPositionEncoder, TorqueSensor, AngularVelocitySensor, MotorCurrentSensor, GearboxStateSensor
]

instance DigitalTwinSystemEnvironment : DTDFVocab:Environment [
    base:contains KinematicModel, DynamicModel, JointFrictionModel, RobotControlModel, TimeSeriesSensorData, ContextualDataTraces, SimulationResults, SimulinkSimulationOutput
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin (DT) system is modeled using **Model-Based Systems Engineering (MBSE)** methodologies, specifically leveraging **SysML** for architecture description (e.g., Internal Block Diagrams [IBDs]) and **MathWorks Simulink** for behavioral modeling. The constellation is **centralized around the DS**, which acts as a passive data collector for the physical asset (e.g., robot axis). Active components (e.g., simulation or control logic) are external to the DS and must be integrated separately. The system does not describe orchestration patterns, resource management, or system-wide coordination mechanisms beyond the **one-way data flow** from physical to digital. No distributed or microservice-based architectures are mentioned."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle stages encompass a structured **Model-Based Systems Engineering (MBSE)** approach, where the system is described across **four hierarchical abstraction layers**: **requirements**, **functional architecture**, **logical architecture**, and **product/technical layer**. These stages correspond to progressive refinement phases, where **requirements** define functional and non-functional needs, **functional architecture** decomposes high-level functions into sub-functions, **logical architecture** maps these functions to system components and their interactions (e.g., using **Architecture Description Languages (ADLs)** like **ACME**, **AADL**, **MontiArc**, or **SysML Internal Block Diagrams (IBDs)**), and the **product/technical layer** specifies physical implementation details. Transition management between phases involves **methodologies such as RFLP (Requirements, Functions, Logics, Physics)**, **OOSEM**, **SPES**, or **SMArDT**, ensuring traceability and consistency. Governance is implied through the integration of **heterogeneous stakeholder perspectives** and the use of **formal modeling languages** to maintain alignment across phases. Additionally, the **Digital Shadow Reference Model** (as per Kritzinger et al.) suggests lifecycle stages include **data collection (contextual traces)**, **aggregation**, and **abstraction** for specific purposes, implying a passive-to-active evolution where the Digital Twin may later incorporate **active components** for bidirectional interaction."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The document does not explicitly detail **fidelity requirements** or **validation/verification methods** for the Digital Twin system. However, it implies the need for **uncertainty quantification** and **error detection** through **model-data comparison** to improve motion accuracy, though no specific techniques (e.g., model checking, inconsistency detection via RFLP) or tools (e.g., Simulink for error correction) are mentioned. The **Digital Shadow Reference Model (DSRM)** focuses on **contextual data aggregation**, but explicit **uncertainty modeling** or **quality assurance processes** are not elaborated."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for the Digital Twin system is not explicitly detailed in the provided document. The only reference to communication is the use of **MQTT** for streaming sensor data (Section IV.A). No information is provided regarding **communication protocols beyond MQTT**, **network topology**, **bandwidth/latency requirements**, **reliability/redundancy mechanisms**, or **security protocols** for network communication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **deployment infrastructure** for the Digital Twin system is not explicitly described in the document. The document mentions the use of **SysML** for modeling and **MathWorks Simulink** for simulation (Section II.A), as well as a **dashboard** for visualization (Section IV.A), but no details are provided on **hosting platforms (cloud/edge/on-premise)**, **computational/storage requirements**, **scalability mechanisms**, or **deployment models**."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with **external systems** via **Asset Administration Shells (AAS)**, a key interoperability standard within the **RAMI 4.0** framework, as referenced in the abstract. Data exchange protocols are not explicitly detailed, but **MQTT** is implied for **real-time data streaming** from physical assets to the Digital Shadow. Dependencies on external systems are **indirect**, as the Digital Shadow itself is a **passive collector** requiring external active components for processing. No explicit integration patterns with other Digital Twins or enterprise systems are described, though the use of AAS suggests potential alignment with **Industry 4.0 standards** for cross-system interoperability."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **industry standards** such as **SysML** (for systems modeling), **Unified Modeling Language (UML)** (used in the **Digital Shadow Reference Model** as a class diagram notation), and **Architecture Description Languages (ADLs)** like **ACME**, **AADL**, and **MontiArc**. While **Asset Administration Shells (AAS)** are referenced in the broader context of digital shadows, they are not explicitly tied to the DT system in the provided document. **Interoperability** is implied through the use of **multi-notation modeling** (e.g., SysML + Simulink + C++/Java) and **standardized ADLs**, though no specific **certification frameworks** or **compliance protocols** (e.g., ISO, IEC) are mentioned. The system’s reliance on **formal modeling languages** suggests alignment with **engineering best practices**, but explicit **standardization bodies** or **compliance requirements** are absent."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system incorporates **cybersecurity protocols** aligned with **RAMI4.0** reference architecture principles (as referenced in [48] and [49]), ensuring structured integration of security measures across the automation pyramid. **Access control mechanisms** are implied through the **Asset Administration Shell (AAS)** framework ([46], [47], [50]), which provides standardized interfaces for role-based access and data encapsulation. **Authentication systems** are not explicitly detailed, but the use of **MQTT (Message Queuing Telemetry Transport)** ([52]) for data streaming suggests lightweight, secure communication protocols, often paired with TLS/SSL encryption in industrial IoT deployments. **Threat mitigation strategies** are indirectly addressed via the **Digital Shadow** concept ([42]), where virtual representations of physical assets (e.g., robotic arms like the **MABI Max-100-2-25-P** ([44])) enable real-time monitoring and anomaly detection. **Fail-safe mechanisms** are implemented via the **safety cell** of the robotic system ([44]), which physically restricts the working range to mitigate collision risks. **Risk assessment approaches** are not explicitly described, though the **model-driven engineering (MDE) methodology** ([43]) implies systematic validation of safety-critical behaviors through formalized simulation models. **Safety-critical system considerations** are partially addressed via **friction modeling** in robot dynamics ([45]), where structured learning of dynamic forces ensures predictable behavior in high-precision applications. The **Functional Mockup Interface (FMI)** ([51]) is not referenced in the provided documents for security or safety purposes."
]