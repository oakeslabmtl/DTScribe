// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Primary actuator for the MABI MAX 100 robot's first axis, providing high-precision torque generation with encoder feedback for closed-loop control."
]

instance CycloidalGearbox : DTDFVocab:ActingComponent [
    base:desc "Two-stage gear transmission system providing precise motion control and minimal backlash for the robot's output shaft, coupled with the permanent magnet synchronous motor."
]

instance SINUMERIK840DslController : DTDFVocab:ActingComponent [
    base:desc "Siemens industrial controller enabling closed-loop control, remote programming, and monitoring interfaces for the robot's actuation system with industrial-grade compliance protocols."
]

// C3: Physical Sensing Components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution position encoder mounted directly on the permanent magnet synchronous motor to provide real-time angular feedback for closed-loop control."
    DTDFVocab:producedData MotorEncoderDataStream
]

instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution position encoder positioned behind the cycloidal gearbox to measure output shaft angle with minimal backlash."
    DTDFVocab:producedData SecondaryEncoderDataStream
]

instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor monitoring input current to the motor for torque/load monitoring and real-time control adjustments."
    DTDFVocab:producedData InputCurrentDataStream
]

// C4: Physical-to-Virtual Interaction
instance MotorEncoderDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance SecondaryEncoderDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoder
]

instance InputCurrentDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

// C10: Models/Data
instance PositionalFeedbackModel : DTDFVocab:Model [
    base:desc "Multi-physics-aware model for joint friction identification and motion accuracy improvement through continuous physics-informed modeling of encoder data."
    DTDFVocab:inputTo SysMLModelingTool, SimulinkSimulationTool
]

instance TorqueLoadMonitoringModel : DTDFVocab:Model [
    base:desc "Model for real-time torque/load monitoring derived from input current sensor data, enabling predictive maintenance and operational optimization."
    DTDFVocab:inputTo SysMLModelingTool, SimulinkSimulationTool
]

instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated sensor readings (positional feedback, current data) and operational logs collected for real-time system state monitoring."
    DTDFVocab:fromData MotorEncoderDataStream, SecondaryEncoderDataStream, InputCurrentDataStream
    DTDFVocab:inputTo MQTTDataStreaming, AssetAdministrationShell
]

instance MultiPhysicsSimulationData : DTDFVocab:Data [
    base:desc "Processed simulation data incorporating joint friction models and multi-physics dynamics for system behavior analysis."
    DTDFVocab:fromData ContextualDataTrace
    DTDFVocab:inputTo SimulinkSimulationTool
]

// C11: Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML-based toolchain for system architecture modeling (IBDs, state machines) and multi-domain system engineering."
    DTDFVocab:enables RealTimeMonitoringService, MultiPhysicsIdentificationService
]

instance SimulinkSimulationTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed multi-physics simulation and behavioral modeling of robot dynamics."
    DTDFVocab:enables MultiPhysicsIdentificationService, VisualizationDashboardService
]

instance MQTTDataStreaming : DTDFVocab:Enabler [
    base:desc "Lightweight publish-subscribe protocol for real-time data streaming between physical robot and Digital Shadow with low-latency integration."
    DTDFVocab:enables RealTimeMonitoringService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Standardized data exchange framework enabling semantic interoperability for industrial Digital Twin implementations."
    DTDFVocab:enables RealTimeMonitoringService, VisualizationDashboardService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing continuous monitoring of system state through contextual data traces and operational logs."
    DTDFVocab:provides SystemStateInsight
]

instance MultiPhysicsIdentificationService : DTDFVocab:Service [
    base:desc "Service for continuous, physics-informed identification of joint friction and other multi-physics parameters to enhance motion accuracy."
    DTDFVocab:provides MotionAccuracyInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Service enabling stakeholder visualization of system states, performance metrics, and multi-physics relationships."
    DTDFVocab:provides SystemVisualizationInsight
]

// C17: Insights/Actions
instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Real-time contextual data traces aggregated for operational state monitoring and anomaly detection."
]

instance MotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Identified joint friction parameters and multi-physics relationships improving motion accuracy through continuous modeling."
]

instance SystemVisualizationInsight : DTDFVocab:Insight [
    base:desc "Dashboard-based visualization of system states, performance metrics, and multi-physics dynamics for stakeholder analysis."
]

// C1: Environment
instance MABIMAX100RobotEnvironment : DTDFVocab:Environment [
    base:desc "Industrial automation environment containing the MABI MAX 100 six-axis serial robot with high-precision motion control requirements."
]

// C5: Components
instance FirstAxisMechanicalAssembly : DTDFVocab:Component [
    base:desc "Mechanical subsystem comprising the permanent magnet synchronous motor, cycloidal gearbox, and associated encoders for the robot's first axis."
    base:isContainedIn MABIMAX100RobotEnvironment
]

instance ControlSystemAssembly : DTDFVocab:Component [
    base:desc "Electrical and control subsystem including the SINUMERIK 840D sl controller and current sensor for closed-loop actuation."
    base:isContainedIn MABIMAX100RobotEnvironment
]

// Component containment relationships
instance FirstAxisMechanicalAssembly : DTDFVocab:Component [
    base:contains PermanentMagnetSynchronousMotor, CycloidalGearbox, MotorEncoder, SecondaryEncoder
]

instance ControlSystemAssembly : DTDFVocab:Component [
    base:contains SINUMERIK840DslController, InputCurrentSensor
]

instance MABIMAX100RobotEnvironment : DTDFVocab:Environment [
    base:contains FirstAxisMechanicalAssembly, ControlSystemAssembly
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system in the document is implemented as a **concrete realization of the Digital Shadow reference model**, structured around a **UML class diagram** defining key concepts for manufacturing. The constellation consists of a **pipeline linking real-time measurement data (via MQTT streaming) to simulation models (e.g., MathWorks Simulink or other tools) and a dashboard for visualization**. The orchestration is **purpose-specific**, focusing on the automated one-way data flow from the physical object (robot axis) to its digital representation, with no explicit mention of broader architecture patterns (e.g., microservices, event-driven), resource management, or system-wide coordination beyond this pipeline. The document does not describe integration with external orchestration frameworks or multi-twin coordination."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system employs **multi-layered abstraction** to ensure model fidelity, where validation is primarily achieved by **comparing simulated data against measured data** to identify discrepancies, such as **friction effects** in physical systems. Uncertainty sources include **temperature variations and positional inaccuracies**, which are quantified through **contextual data traces** aggregated from the physical system. The system adheres to the **Digital Shadow Reference Model**, where passive data collection (e.g., sensor readings) is abstracted and validated against digital representations. Quality assurance processes are implicit in the **MBSE framework**, ensuring traceability across abstraction layers. No explicit mention of **error detection mechanisms, PID control, or sensor noise mitigation** is provided in the documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical network infrastructure for the digital shadow relies on **MQTT protocol** for data transmission, as explicitly stated in the document ('time series of all sensors, which are streamed via MQTT'). No further details are provided regarding network topology (e.g., star, mesh), bandwidth/latency requirements, reliability mechanisms (e.g., redundancy, failover), or security protocols (e.g., TLS, authentication). The document does not specify whether the connection is centralized or distributed, nor does it describe additional infrastructure components like gateways or brokers."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The document does not provide explicit details on **horizontal integration** with external systems. However, it implies **interoperability challenges** due to the use of **multiple modeling notations and tools** (e.g., SysML, MontiArc, Simulink, C++, Java). While no **data exchange protocols** or **standards** (e.g., OPC UA, MQTT, REST) are mentioned, the need to integrate **heterogeneous stakeholders and perspectives** suggests dependencies on **external systems** (e.g., enterprise systems, other Digital Twins). The document does not specify **integration patterns** beyond the **modular and tool-agnostic** approach implied by MBSE methodologies."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **industry standards** for **systems modeling and interoperability**, including:
  - **SysML** (Systems Modeling Language) for MBSE and architecture description.
  - **Unified Modeling Language (UML)** (e.g., UML class diagrams) for conceptual modeling.
  - **Architecture Description Languages (ADLs)**: **ACME**, **AADL**, and **MontiArc**, which standardize component-based system design and interoperability.
  - **Asset Administration Shell (AAS)** (referenced in the abstract), a key **Industry 4.0 standard** for semantic interoperability and data exchange in digital ecosystems.
  The system also implicitly aligns with **compliance frameworks** for **heterogeneous toolchain integration** (e.g., MathWorks Simulink, C++/Java), though specific **certification requirements** or **compliance frameworks** (e.g., ISO/IEC, IEC 62443) are not detailed in the provided context."
]