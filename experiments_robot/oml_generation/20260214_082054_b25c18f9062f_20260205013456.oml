instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor measuring input current to the robot joint"
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor measuring output angle of the robot joint"
    DTDFVocab:producedData OutputAngleDataTransmitted
]

instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
    base:desc "Time series data of input current transmitted via MQTT"
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
    base:desc "Time series data of output angle transmitted via MQTT"
]

instance InputCurrentData : DTDFVocab:Data [
    base:desc "Input current time series data used for digital twin analysis"
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo Simulink, Cpp, Java
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Output angle time series data used for digital twin analysis"
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo Simulink, Cpp, Java
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed dynamic simulation"
    DTDFVocab:enables DashboardVisualizationService
]

instance Cpp : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed dynamic analysis"
    DTDFVocab:enables FrictionIdentificationService
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed dynamic analysis"
    DTDFVocab:enables FrictionIdentificationService
]

instance SysML : DTDFVocab:Enabler [
    base:desc "SysML for Model-Based Systems Engineering (MBSE) system modeling"
]

instance ACME : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component and connector architecture specification"
]

instance AADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component and connector architecture specification"
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component and connector architecture specification"
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavior modeling"
]

instance StructuralModel : DTDFVocab:Model [
    base:desc "Structural component and connector descriptions using ACME, AADL, MontiArc, and SysML IBDs"
    DTDFVocab:inputTo ACME, AADL, MontiArc, SysML
]

instance BehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral models using MontiArc Automaton and SysML v1.7 state machines"
    DTDFVocab:inputTo MontiArcAutomaton, SysML
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Detailed simulation models using MathWorks Simulink, C++, and Java"
    DTDFVocab:inputTo Simulink, Cpp, Java
]

instance RFLP : DTDFVocab:Model [
    base:desc "RFLP (Requirements, Functions, Logics, Physics) methodology for system complexity management"
    DTDFVocab:inputTo SysML
]

instance OOSEM : DTDFVocab:Model [
    base:desc "OOSEM methodology for system complexity management"
    DTDFVocab:inputTo SysML
]

instance SPES : DTDFVocab:Model [
    base:desc "SPES methodology for system complexity management"
    DTDFVocab:inputTo SysML
]

instance SMArDT : DTDFVocab:Model [
    base:desc "SMArDT methodology for system complexity management"
    DTDFVocab:inputTo SysML
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of joint friction using white-box and black-box models to enhance robot motion accuracy"
    DTDFVocab:provides JointFrictionInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Decision support through dashboard visualizations for user interaction"
    DTDFVocab:provides DashboardVisualizationInsight
]

instance JointFrictionInsight : DTDFVocab:Insight [
    base:desc "Multi-physics-aware identification of joint friction for enhanced robot motion accuracy"
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Dashboard visualization for user interaction and decision support"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data from physical assets is streamed via MQTT in real-time, capturing live measurements to ensure continuous synchronization between the physical and digital components with minimal latency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Shadow Reference Model, defined as a UML class diagram, structures components including DataTrace (for contextual data collection), Source (data origin), and Asset (physical entities), with defined relationships for aggregation and abstraction of data traces."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems uses Asset Administration Shells (AAS) as an interoperability standard, MQTT for real-time data exchange, and interfaces with the Siemens SINUMERIK 840D sl controller for industrial automation processes."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with industry standards including SysML for systems engineering modeling, AADL for architecture description, ACME for component-based architecture, and MontiArc for modular architecture design. Interoperability is addressed through the integration of heterogeneous modeling notations and tools as per MBSE practices."
]