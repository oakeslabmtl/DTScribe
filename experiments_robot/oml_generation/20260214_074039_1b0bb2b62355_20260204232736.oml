// C3: Physical sensing component (derived from system description)
instance EncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder on the first robot axis providing high‑resolution position data for the digital shadow"
    DTDFVocab:producedData EncoderDataTransmitted
]

// C4: Physical-to-virtual data transmission
instance EncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderSensor
]

// C10: Contextual data (digital shadow)
instance EncoderContextualTrace : DTDFVocab:Data [
    base:desc "Aggregated contextual data trace derived from encoder position samples, forming part of the digital shadow"
    DTDFVocab:fromData EncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEngine, MLInferenceEngine
]

// C10: White‑box physics‑based model
instance SimulinkAxisDynamicsModel : DTDFVocab:Model [
    base:desc "White‑box physics‑based model of the robot axis dynamics implemented as a Simulink dynamic simulation"
    DTDFVocab:inputTo SimulinkEngine
]

// C10: Black‑box data‑driven model
instance MLFrictionRegressorModel : DTDFVocab:Model [
    base:desc "Black‑box machine‑learning regressor capturing nonlinear joint friction effects"
    DTDFVocab:inputTo MLInferenceEngine
]

// C11: Enablers (simulation / inference runtimes)
instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation environment that executes the white‑box dynamics model"
    DTDFVocab:enables MonitoringService
]

instance MLInferenceEngine : DTDFVocab:Enabler [
    base:desc "Runtime inference engine that evaluates the friction regressor model on incoming data traces"
    DTDFVocab:enables AnalysisService
]

// C6: Services delivered by the Digital Twin
instance MonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of the robot axis by comparing simulated baseline predictions with live sensor data"
    DTDFVocab:provides AxisStateInsight
]

instance AnalysisService : DTDFVocab:Service [
    base:desc "Analyzes residual friction by applying the ML regressor to the contextual data trace"
    DTDFVocab:provides FrictionAnalysisInsight
]

instance FeedbackService : DTDFVocab:Service [
    base:desc "Generates corrective control actions based on combined model outputs for potential feedback to the physical axis"
    DTDFVocab:provides GenerateFeedbackAction
]

// C17: Insights
instance AxisStateInsight : DTDFVocab:Insight [
    base:desc "Insight into the current state of the robot axis derived from baseline simulation and live sensor data"
]

instance FrictionAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight into nonlinear friction behavior obtained from the machine‑learning regressor model"
]

// C17: Action (potential feedback)
instance GenerateFeedbackAction : DTDFVocab:Action [
    base:desc "Automatically creates control adjustments to compensate friction residuals and improve motion accuracy"
    DTDFVocab:IsAutomatic true
]

// C1: Physical components of the system under study
instance AxisMotorComponent : DTDFVocab:Component [
    base:desc "Servo motor driving the first robot axis"
]

instance AxisGearboxComponent : DTDFVocab:Component [
    base:desc "Gearbox transmitting motor torque to the axis joint"
]

instance AxisEncoderComponent : DTDFVocab:Component [
    base:desc "Rotary encoder attached to the axis for position feedback"
]

instance CNCControllerComponent : DTDFVocab:Component [
    base:desc "Siemens SINUMERIK 840D sl CNC controller orchestrating robot motion"
]

instance SerialSixAxisRobot : DTDFVocab:Component [
    base:desc "MABI MAX 100 serial six‑axis industrial robot, focused on the first vertical axis"
    base:contains AxisMotorComponent, AxisGearboxComponent, AxisEncoderComponent, CNCControllerComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "According to the documents, the digital shadow does not push data back to the physical system and therefore lacks a virtual‑to‑physical control flow. While a Digital Twin can provide active components to interpret incoming data, the source material does not describe any command types, control message formats, validation, authentication, feedback, conflict resolution, or execution confirmation mechanisms."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by combining analytically interpretable Simulink simulations with statistically learned machine‑learning models, allowing validation against measured robot behavior. The approach emphasises traceability of transformations (e.g., SysML → simulation) and verification of model correctness. Reliability depends on the correctness of underlying models and data transformations; therefore, verification methods and quality‑assurance processes are applied to detect and correct errors, and uncertainties are implicitly managed by the hybrid model structure."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The digital twin is integrated with an external Siemens SINUMERIK 840D sl CNC controller; data is streamed using the MQTT protocol and the twin implements the Asset Administration Shell (AAS) standard, facilitating interoperability with other enterprise systems and digital twins."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin implementation follows the Asset Administration Shell (AAS) specification for standardized asset representation, uses SysML as the modelling language for exchanging engineering models, and adopts MQTT as the communication protocol for real‑time data streaming, aligning with Industry 4.0 interoperability standards."
]