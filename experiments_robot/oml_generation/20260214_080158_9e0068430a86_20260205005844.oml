import DTDFVocab
instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results insight from SysML model"
]

instance BehaviorInsight : DTDFVocab:Insight [
    base:desc "Behavior specification insight from C++"
]

instance ProcessedDataInsight : DTDFVocab:Insight [
    base:desc "Processed data insight from Java"
]

instance RequirementsInsight : DTDFVocab:Insight [
    base:desc "Requirements validation insight"
]

instance FunctionalArchitectureInsight : DTDFVocab:Insight [
    base:desc "Functional architecture design insight"
]

instance LogicalArchitectureInsight : DTDFVocab:Insight [
    base:desc "Logical architecture design insight"
]

instance ProductTechnicalLayerInsight : DTDFVocab:Insight [
    base:desc "Product/technical layer implementation insight"
]

instance ACMEModelingInsight : DTDFVocab:Insight [
    base:desc "ACME architecture description insight"
]

instance AADLModelingInsight : DTDFVocab:Insight [
    base:desc "AADL architecture description insight"
]

instance MontiArcModelingInsight : DTDFVocab:Insight [
    base:desc "MontiArc architecture description insight"
]

instance SysMLIBDInsight : DTDFVocab:Insight [
    base:desc "SysML IBD component interface insight"
]

instance MontiArcAutomatonInsight : DTDFVocab:Insight [
    base:desc "MontiArc Automaton behavior insight"
]

instance SysMLStateMachineInsight : DTDFVocab:Insight [
    base:desc "SysML state machine behavior insight"
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service using SysML models",
    DTDFVocab:provides SimulationInsight
]

instance BehaviorSpecificationService : DTDFVocab:Service [
    base:desc "Behavior specification service using C++",
    DTDFVocab:provides BehaviorInsight
]

instance DataProcessingService : DTDFVocab:Service [
    base:desc "Data processing service using Java",
    DTDFVocab:provides ProcessedDataInsight
]

instance RequirementsService : DTDFVocab:Service [
    base:desc "Requirements management service using RFLP",
    DTDFVocab:provides RequirementsInsight
]

instance FunctionalArchitectureService : DTDFVocab:Service [
    base:desc "Functional architecture service using OOSEM",
    DTDFVocab:provides FunctionalArchitectureInsight
]

instance LogicalArchitectureService : DTDFVocab:Service [
    base:desc "Logical architecture service using SPES",
    DTDFVocab:provides LogicalArchitectureInsight
]

instance ProductTechnicalLayerService : DTDFVocab:Service [
    base:desc "Product/technical layer service using SMArDT",
    DTDFVocab:provides ProductTechnicalLayerInsight
]

instance ACMEModelingService : DTDFVocab:Service [
    base:desc "ACME modeling service for component interfaces",
    DTDFVocab:provides ACMEModelingInsight
]

instance AADLModelingService : DTDFVocab:Service [
    base:desc "AADL modeling service for component interfaces",
    DTDFVocab:provides AADLModelingInsight
]

instance MontiArcModelingService : DTDFVocab:Service [
    base:desc "MontiArc modeling service for component-connector",
    DTDFVocab:provides MontiArcModelingInsight
]

instance SysMLIBDService : DTDFVocab:Service [
    base:desc "SysML IBD service for component interfaces",
    DTDFVocab:provides SysMLIBDInsight
]

instance MontiArcAutomatonService : DTDFVocab:Service [
    base:desc "MontiArc Automaton service for behavior modeling",
    DTDFVocab:provides MontiArcAutomatonInsight
]

instance SysMLStateMachineService : DTDFVocab:Service [
    base:desc "SysML state machine service for behavior modeling",
    DTDFVocab:provides SysMLStateMachineInsight
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation",
    DTDFVocab:enables SimulationService
]

instance CPlusPlus : DTDFVocab:Enabler [
    base:desc "C++ for behavior specification and data processing",
    DTDFVocab:enables BehaviorSpecificationService
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java for behavior specification and data processing",
    DTDFVocab:enables DataProcessingService
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP methodology for hierarchical abstraction levels",
    DTDFVocab:enables RequirementsService
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for hierarchical abstraction levels",
    DTDFVocab:enables FunctionalArchitectureService
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for hierarchical abstraction levels",
    DTDFVocab:enables LogicalArchitectureService
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for hierarchical abstraction levels",
    DTDFVocab:enables ProductTechnicalLayerService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME tool for architecture description",
    DTDFVocab:enables ACMEModelingService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL tool for architecture description",
    DTDFVocab:enables AADLModelingService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc tool for architecture description",
    DTDFVocab:enables MontiArcModelingService
]

instance SysMLIBDEnabler : DTDFVocab:Enabler [
    base:desc "SysML IBD tool for component interfaces",
    DTDFVocab:enables SysMLIBDService
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton tool for behavior modeling",
    DTDFVocab:enables MontiArcAutomatonService
]

instance SysMLStateMachineEnabler : DTDFVocab:Enabler [
    base:desc "SysML state machine tool for behavior modeling",
    DTDFVocab:enables SysMLStateMachineService
]

instance SysMLModel : DTDFVocab:Model [
    base:desc "SysML for structural and behavioral modeling",
    DTDFVocab:inputTo Simulink
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME architecture description language for component interfaces",
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL architecture description language for component interfaces",
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description language for component-connector modeling",
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML IBD for component interfaces and interconnections",
    DTDFVocab:inputTo SysMLIBDEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling",
    DTDFVocab:inputTo MontiArcAutomatonEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavioral modeling",
    DTDFVocab:inputTo SysMLStateMachineEnabler
]

instance RequirementsModel : DTDFVocab:Model [
    base:desc "Requirements abstraction level model",
    DTDFVocab:inputTo RFLPMethodology
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "Functional architecture model",
    DTDFVocab:inputTo OOSEMMethodology
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Logical architecture model",
    DTDFVocab:inputTo SPESMethodology
]

instance ProductTechnicalLayerModel : DTDFVocab:Model [
    base:desc "Product/technical layer model",
    DTDFVocab:inputTo SMArDTMethodology
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to industry standards including SysML for Model-Based Systems Engineering (MBSE), ACME, AADL, and MontiArc as architecture description languages (ADLs) for component & connector perspectives, ensuring structured system modeling across abstraction levels such as requirements, functional architecture, logical architecture, and product/technical layer."
]