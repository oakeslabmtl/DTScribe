// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor with input current I_M and output torque τ_M"
]

instance GearwheelGearbox : DTDFVocab:ActingComponent [
    base:desc "Gearwheel gearbox transmitting motor torque to the drive axis"
]

instance CycloidalGearbox : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gearbox providing high reduction for the axis"
]

instance Sinumerik840DController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl controller driving the axis"
]

// C4: Physical‑to‑virtual interaction (Data transmitted)
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// C3: Physical sensing components
instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder delivering motor angle and derived torque, velocity, acceleration",
    DTDFVocab:producesData MotorEncoderDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the gearbox delivering gearbox angle and derived kinematics",
    DTDFVocab:producesData GearboxEncoderDataTransmitted
]

// C10: Data (raw/processed)
instance MotorAngleData : DTDFVocab:Data [
    base:desc "Motor angle time‑series derived from MotorMountedEncoder",
    DTDFVocab:fromData MotorEncoderDataTransmitted
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Gearbox angle time‑series derived from GearboxEncoder",
    DTDFVocab:fromData GearboxEncoderDataTransmitted
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Derived torque data calculated from encoder measurements",
    DTDFVocab:fromData MotorEncoderDataTransmitted
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity time‑series calculated from angle data",
    DTDFVocab:fromData MotorEncoderDataTransmitted
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration derived from velocity data",
    DTDFVocab:fromData MotorEncoderDataTransmitted
]

instance RawTimeSeriesData : DTDFVocab:Data [
    base:desc "Raw time‑series of current, torque, angular velocity and acceleration",
    DTDFVocab:fromData MotorEncoderDataTransmitted,
    DTDFVocab:fromData GearboxEncoderDataTransmitted
]

instance ProcessedTimeSeriesData : DTDFVocab:Data [
    base:desc "Processed (filtered, calibrated) time‑series used for model identification",
    DTDFVocab:fromData RawTimeSeriesData
]

// C17: Insights
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters identified in real time"
]

instance ModelUpdateInsight : DTDFVocab:Insight [
    base:desc "Notification that friction models have been updated with new parameters"
]

instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Result of comparing simulated and measured data"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Dashboard visual feedback of simulation vs measurement"
]

instance DataIngestionInsight : DTDFVocab:Insight [
    base:desc "Confirmation that live sensor data has been received via MQTT"
]

instance EngineeringModelInsight : DTDFVocab:Insight [
    base:desc "Status of SysML engineering model consistency"
]

instance ModelIntegrationInsight : DTDFVocab:Insight [
    base:desc "Result of integrating models into the AAS"
]

// C17: Action
instance AdjustMotionControlAction : DTDFVocab:Action [
    base:desc "Feeds derived friction parameters back to the robot controller to adjust motion control for improved accuracy",
    DTDFVocab:IsAutomatic true
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction parameters",
    DTDFVocab:provides FrictionParameterInsight,
                     AdjustMotionControlAction
]

instance ModelUpdatingService : DTDFVocab:Service [
    base:desc "Updates white‑box and black‑box friction models with newly identified parameters",
    DTDFVocab:provides ModelUpdateInsight
]

instance SimulationComparisonService : DTDFVocab:Service [
    base:desc "Compares simulated data against measured data for validation",
    DTDFVocab:provides SimulationValidationInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Integrated visualization of simulation vs measurement on a dashboard",
    DTDFVocab:provides VisualizationInsight
]

instance DataIngestionService : DTDFVocab:Service [
    base:desc "Ingests MQTT streamed sensor data into the digital twin",
    DTDFVocab:provides DataIngestionInsight
]

instance EngineeringModelManagementService : DTDFVocab:Service [
    base:desc "Manages SysML engineering models within the digital twin",
    DTDFVocab:provides EngineeringModelInsight
]

instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Integrates models into the Asset Administration Shell",
    DTDFVocab:provides ModelIntegrationInsight
]

// C11: Enablers
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML tooling for structural modeling",
    DTDFVocab:enables EngineeringModelManagementService
]

instance MatlabSimulinkTool : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink environment for executable simulation models",
    DTDFVocab:enables RealTimeFrictionIdentificationService,
                     ModelUpdatingService,
                     SimulationComparisonService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker for live sensor data streaming",
    DTDFVocab:enables DataIngestionService
]

instance AASEnvironment : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for model integration",
    DTDFVocab:enables ModelIntegrationService
]

instance DashboardApp : DTDFVocab:Enabler [
    base:desc "Web dashboard for visualization of simulated vs measured data",
    DTDFVocab:enables DashboardVisualizationService
]

// C10: Models
instance SysMLAxisStructureModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagram describing axis structure"
]

instance MatlabFrictionFreeSimModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction‑free dynamic model of the axis"
]

instance MatlabCoulombViscousModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink Coulomb‑Viscous friction model"
]

instance MatlabStribeckModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink Stribeck friction model"
]

instance MatlabDahlModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink Dahl friction model"
]

instance MatlabLuGreModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink LuGre friction model"
]

instance TorqueVelocityCalculationModel : DTDFVocab:Model [
    base:desc "Model for calculating torque and velocity from sensor data"
]

// Environment (grouping)
instance AxisEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotor,
                 GearwheelGearbox,
                 CycloidalGearbox,
                 Sinumerik840DController,
                 MotorMountedEncoder,
                 GearboxEncoder
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow is passive and does not send commands back to the robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time operation during robot runtime; data are processed online as they arrive."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow comprising a processing component that consumes MQTT data traces, applies simulation and data‑calculation models, and produces derived data traces; all linked to the physical asset (first axis) via the AAS."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational stage – the digital shadow is used while the robot is running to improve motion accuracy."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Combination of analytical white‑box and data‑driven black‑box friction models; full traceability of each data point to its source and processing model; validation by comparing simulated outputs with measured reference data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol used for streaming sensor data from the robot to the digital shadow; data organized as DataTraces and DataPoints according to the Digital Shadow Reference Model."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) as an industry‑standard representation, and adherence to SysML modelling standards."
]