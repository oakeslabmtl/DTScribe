    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML functional architecture model"
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLBehavioralModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine behavioral model"
    DTDFVocab:inputTo SysMLEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME architecture description for component & connector perspectives"
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL model for component & connector perspectives"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcArchitectureModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description for component & connector perspectives"
    DTDFVocab:inputTo MontiArcEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavior modeling"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SimulinkMotionControlModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for motion control simulation"
    DTDFVocab:inputTo SimulinkEnabler
]

instance CppBehaviorModel : DTDFVocab:Model [
    base:desc "C++ model for detailed behavior specification"
    DTDFVocab:inputTo CppEnabler
]

instance JavaBehaviorModel : DTDFVocab:Model [
    base:desc "Java model for detailed behavior specification"
    DTDFVocab:inputTo JavaEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for system architecture modeling across abstraction levels"
    DTDFVocab:enables SystemArchitectureService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME architecture description language for component & connector perspectives"
    DTDFVocab:enables SystemArchitectureService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL for component & connector perspectives"
    DTDFVocab:enables SystemArchitectureService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc for component & connector perspectives and behavior modeling"
    DTDFVocab:enables SystemArchitectureService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and analytical modeling"
    DTDFVocab:enables MotionControlService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior specification"
    DTDFVocab:enables MotionControlService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior specification"
    DTDFVocab:enables MotionControlService
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP methodology for system complexity management"
    DTDFVocab:enables StakeholderIntegrationService
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for stakeholder integration"
    DTDFVocab:enables StakeholderIntegrationService
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for system complexity"
    DTDFVocab:enables StakeholderIntegrationService
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for stakeholder integration"
    DTDFVocab:enables StakeholderIntegrationService
]

instance SystemArchitectureService : DTDFVocab:Service [
    base:desc "Service for system architecture modeling and integration"
    DTDFVocab:provides ArchitectureInsight
]

instance MotionControlService : DTDFVocab:Service [
    base:desc "Service for precise motion control of MABI MAX 100 robot"
    DTDFVocab:provides MotionControlInsight
]

instance StakeholderIntegrationService : DTDFVocab:Service [
    base:desc "Service for integrating heterogeneous stakeholder perspectives"
    DTDFVocab:provides StakeholderIntegrationInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service for real-time monitoring of robot operations"
    DTDFVocab:provides MonitoringInsight
]

instance ArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight on system architecture integrity and design"
]

instance MotionControlInsight : DTDFVocab:Insight [
    base:desc "Insight on motion control accuracy and performance"
]

instance StakeholderIntegrationInsight : DTDFVocab:Insight [
    base:desc "Insight on stakeholder requirements integration"
]

instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight on real-time operational status of robot"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system employs a Digital Shadow Reference Model defined as a UML class diagram (Fig. 1) and a Concrete Digital Shadow Model (Fig. 5), integrating components such as motor, gearbox, and sensors. It utilizes architecture patterns including SysML and UML for structural modeling, and implements Asset Administration Shells (AAS) for standardized digital representation and interoperability."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The lifecycle phases of the Digital Twin encompass development stages defined by Model-Based Systems Engineering (MBSE), where modeling is structured across abstraction levels including requirements, functional architecture, logical architecture, and product/technical layers. The methodology for deriving Digital Shadows (as part of the Twin development process) includes four specific steps: 1) Problem identification, 2) Asset and model analysis, 3) Use or creation of calculations/models, and 4) Data identification. These steps are supported by methodologies such as RFLP (Requirements, Functions, Logics, Physics), OOSEM, SPES, and SMArDT, which manage complexity through structured abstraction and integration of heterogeneous stakeholder perspectives during the development phase."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for communication between physical and digital components."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through MQTT protocol for real-time sensor data streaming, Asset Administration Shells (AAS) ensuring interoperability across platforms, and connectivity to the Siemens SINUMERIK 840D sl controller for industrial control system communication."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with industry standards includes the use of Asset Administration Shells (AAS) for structured asset information modeling, SysML for system architecture description, and MQTT protocol for lightweight publish-subscribe messaging in data streaming, ensuring interoperability and adherence to industrial communication protocols."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The safety cell of the robot restricts the maximum working range to [-90°, 90°]."
]