instance MABIMAX100PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor for MABI MAX 100 robot's six axes"
    DTDFVocab:producedData MABIMAX100PositionData
]

instance MABIMAX100PositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MABIMAX100PositionSensor
    base:desc "Time series position data streamed via MQTT protocol"
]

instance MABIMAX100SensorData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted sensor data from physical system"
    DTDFVocab:fromData MABIMAX100PositionData
    DTDFVocab:inputTo SimulinkEnabler, SysMLEnabler, CppEnabler, JavaEnabler
]

instance PermanentMagnetMotor : DTDFVocab:Component [
    base:desc "Permanent magnet synchronous motor in MABI MAX 100 robot"
]

instance GearTransmission : DTDFVocab:Component [
    base:desc "Gear transmission system of MABI MAX 100 robot"
]

instance CycloidalGear : DTDFVocab:Component [
    base:desc "Cycloidal gear mechanism in MABI MAX 100 robot"
]

instance SinumerikController : DTDFVocab:Component [
    base:desc "Siemens SINUMERIK 840D sl controller"
]

instance MABIMAX100RobotEnvironment : DTDFVocab:Environment [
    base:desc "Environment for MABI MAX 100 robot system"
    base:contains PermanentMagnetMotor, GearTransmission, CycloidalGear, SinumerikController
]

