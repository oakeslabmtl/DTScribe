// Digital Twin Development Process: Modeling and Code Generation

// Virtual sensor that triggers the modeling workflow
instance ModelingProcessSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor that initiates the modeling workflow"
    DTDFVocab:producedData ModelingProcessDataTransmitted
]

// Data transmitted by the modeling workflow sensor
instance ModelingProcessDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ModelingProcessSensor
]

// Data artifact representing the collection of modeling outputs
instance ModelingData : DTDFVocab:Data [
    base:desc "Data containing modeling artifacts such as requirement models and architecture diagrams"
    DTDFVocab:fromData ModelingProcessDataTransmitted
]

// Models describing different system layers and behavior
instance RequirementsModel : DTDFVocab:Model [
    base:desc "System requirements captured using SysML"
    DTDFVocab:inputTo MBSEEnabler
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "Functional architecture described in SysML"
    DTDFVocab:inputTo MBSEEnabler
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Logical product layer modeled with ACME, AADL, and MontiArc"
    DTDFVocab:inputTo MBSEEnabler
]

instance BehaviorModel : DTDFVocab:Model [
    base:desc "Behavior represented through MontiArc Automaton or SysML state machines"
    DTDFVocab:inputTo SimulationEnabler
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Validated behavior through simulation in MathWorks Simulink"
    DTDFVocab:inputTo SimulationEnabler
]

instance CodeGenerationModel : DTDFVocab:Model [
    base:desc "Code generated in C++ or Java from the modeling artifacts"
    DTDFVocab:inputTo CodeGenEnabler
]

// Enablers that execute the modeling process and toolchain
instance MBSEEnabler : DTDFVocab:Enabler [
    base:desc "Enabler implementing MBSE methodologies (RFLP, OOSEM, SPES, SMArDT)"
    DTDFVocab:enables ModelingService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that executes simulation models in Simulink"
    DTDFVocab:enables SimulationService
]

instance CodeGenEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that generates executable code in C++ or Java"
    DTDFVocab:enables CodeGenerationService
]

// Services that process the modeling outputs
instance ModelingService : DTDFVocab:Service [
    base:desc "Service providing insights on design completeness and consistency"
    DTDFVocab:provides DesignInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service providing insights on simulation validation results"
    DTDFVocab:provides SimulationInsight
]

instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Service triggering automatic generation of C++ or Java code"
    DTDFVocab:provides CodeGenAction
]

// Insights generated by the services
instance DesignInsight : DTDFVocab:Insight [
    base:desc "Insight into system design completeness and consistency"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight into the validity of behavior through simulation"
]

// Action generated by the code generation service
instance CodeGenAction : DTDFVocab:Action [
    base:desc "Action that automates the generation of C++ or Java code from models"
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Life Cycle Stages: The DT lifecycle is captured through Model‑Based Systems Engineering (MBSE) and is structured into four abstraction layers. (1) Requirements: system needs are expressed in SysML requirement diagrams and use‑case models. (2) Functional Architecture: the functional structure is designed in SysML and linked to the requirements. (3) Logical Architecture: logical components and connectors are described with architecture description languages such as ACME, AADL and MontiArc, with behavioral extensions (e.g., MontiArc Automaton or SysML 1.7 state machines). (4) Product/Technical Layer: concrete components, connector specifications and implementation artefacts are produced in general‑purpose languages (C++/Java) and simulation tools (MathWorks Simulink or equivalent). Transitions between these stages are managed by mapping artifacts across abstraction layers – requirements trace to functional elements, functional elements trace to logical components, and logical components trace to technical implementation. Lifecycle governance is performed within the MBSE framework, ensuring consistency, traceability and coherent model updates."
]