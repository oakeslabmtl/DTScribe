// ------------------------------------------------------------
// C1: Digital Twin Instance
// ------------------------------------------------------------
instance FrictionShadow : DTDFVocab:Component [
    base:desc "Digital shadow representing the first rotational axis of the MABI MAX 100 robot"
]

// ------------------------------------------------------------
// C3: Physical sensing components
// ------------------------------------------------------------
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) measuring instantaneous phase current"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the motor shaft providing shaft angle r_M"
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder mounted after the gearbox providing output angle r_out"
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

// ------------------------------------------------------------
// C4: Physical-to-virtual interaction (live sensor data)
// ------------------------------------------------------------
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// ------------------------------------------------------------
// C10: Data (time‑series)
// ------------------------------------------------------------
instance MotorCurrentTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of motor current I_M streamed via MQTT"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance MotorShaftAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of motor shaft angle r_M streamed via MQTT"
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance GearboxAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of gearbox output angle r_out streamed via MQTT"
    DTDFVocab:fromData GearboxAngleDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

// ------------------------------------------------------------
// C10: Simulated data (generated by Simulink)
// ------------------------------------------------------------
instance SimulinkSimulation : DTDFVocab:Component [
    base:desc "MATLAB/Simulink simulation generating friction‑free and friction‑augmented behavior data"
    DTDFVocab:producedData SimulatedCurrentDataTransmitted
    DTDFVocab:producedData SimulatedMotorAngleDataTransmitted
    DTDFVocab:producedData SimulatedGearboxAngleDataTransmitted
]

instance SimulatedCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkSimulation
]

instance SimulatedMotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkSimulation
]

instance SimulatedGearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkSimulation
]

instance SimulatedCurrentTimeSeries : DTDFVocab:Data [
    base:desc "Simulated motor current time‑series (friction‑free model)"
    DTDFVocab:fromData SimulatedCurrentDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

instance SimulatedMotorAngleTimeSeries : DTDFVocab:Data [
    base:desc "Simulated motor shaft angle time‑series (friction‑augmented model)"
    DTDFVocab:fromData SimulatedMotorAngleDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

instance SimulatedGearboxAngleTimeSeries : DTDFVocab:Data [
    base:desc "Simulated gearbox output angle time‑series"
    DTDFVocab:fromData SimulatedGearboxAngleDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

// ------------------------------------------------------------
// C10: Derived measurements (torque, velocity, acceleration)
// ------------------------------------------------------------
instance DataCalculationModule : DTDFVocab:Component [
    base:desc "Algorithmic module deriving torque, angular velocity and acceleration from raw sensor traces"
    DTDFVocab:producedData DerivedTorqueDataTransmitted
    DTDFVocab:producedData DerivedVelocityDataTransmitted
    DTDFVocab:producedData DerivedAccelerationDataTransmitted
]

instance DerivedTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DataCalculationModule
]

instance DerivedVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DataCalculationModule
]

instance DerivedAccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DataCalculationModule
]

instance TorqueTimeSeries : DTDFVocab:Data [
    base:desc "Derived torque time‑series calculated from current and angle data"
    DTDFVocab:fromData DerivedTorqueDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

instance VelocityTimeSeries : DTDFVocab:Data [
    base:desc "Derived angular velocity time‑series"
    DTDFVocab:fromData DerivedVelocityDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

instance AccelerationTimeSeries : DTDFVocab:Data [
    base:desc "Derived angular acceleration time‑series"
    DTDFVocab:fromData DerivedAccelerationDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

// ------------------------------------------------------------
// C11: Enablers (tooling & integration)
// ------------------------------------------------------------
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker used for real‑time streaming of sensor traces"
    DTDFVocab:enables RealTimeFrictionIdentificationService
    DTDFVocab:enables ModelComparisonService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink engine executing simulation models"
    DTDFVocab:enables ModelComparisonService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Custom web dashboard for visualizing measured and simulated data"
    DTDFVocab:enables VisualizationDashboardService
    DTDFVocab:enables ControllerParameterUpdateService
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML toolchain for structural and behavioral modeling"
    DTDFVocab:enables ModelDefinitionService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shells for model integration and interoperability"
    DTDFVocab:enables IntegrationService
]

// ------------------------------------------------------------
// C6: Services
// ------------------------------------------------------------
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction coefficients"
    DTDFVocab:provides FrictionParametersInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Interactive dashboard visualizing live traces, simulated results and model deviations"
    DTDFVocab:provides ModelDeviationInsight
    DTDFVocab:provides VisualizeDataTracesAction
]

instance ModelComparisonService : DTDFVocab:Service [
    base:desc "Comparison of simulated vs. measured data to evaluate model accuracy"
    DTDFVocab:provides ModelComparisonInsight
]

instance ControllerParameterUpdateService : DTDFVocab:Service [
    base:desc "Service that updates robot controller parameters with identified friction coefficients"
    DTDFVocab:provides UpdateRobotControllerAction
]

instance ModelDefinitionService : DTDFVocab:Service [
    base:desc "Definition of engineering models (SysML block diagrams, internal block diagrams)"
    DTDFVocab:provides ModelStructureInsight
]

instance IntegrationService : DTDFVocab:Service [
    base:desc "Integration of digital twin artifacts via Asset Administration Shells"
    DTDFVocab:provides IntegrationInsight
]

// ------------------------------------------------------------
// C17: Insights & Actions
// ------------------------------------------------------------
instance FrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Identified static, kinetic and viscous friction parameters"
]

instance ModelDeviationInsight : DTDFVocab:Insight [
    base:desc "Detected deviations between simulated and measured data"
]

instance ModelComparisonInsight : DTDFVocab:Insight [
    base:desc "Quantitative results of model vs. measurement comparison"
]

instance ModelStructureInsight : DTDFVocab:Insight [
    base:desc "Structural information extracted from SysML engineering models"
]

instance IntegrationInsight : DTDFVocab:Insight [
    base:desc "Status of AAS‑based integration between virtual and physical assets"
]

instance VisualizeDataTracesAction : DTDFVocab:Action [
    base:desc "Engineer triggers visualization of selected data traces on the dashboard"
    DTDFVocab:IsAutomatic false
]

instance UpdateRobotControllerAction : DTDFVocab:Action [
    base:desc "Update robot controller with newly identified friction coefficients"
    DTDFVocab:IsAutomatic true
]

// ------------------------------------------------------------
// C5: Environment (optional, showing composition)
// ------------------------------------------------------------
instance RobotAxisEnvironment : DTDFVocab:Environment [
    base:contains MotorCurrentSensor, MotorShaftEncoder, GearboxEncoder,
                 SimulinkSimulation, DataCalculationModule,
                 FrictionShadow
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow follows the digital‑shadow reference model which defines a one‑way data flow from physical to virtual only."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time operation during robot runtime; data are processed as they are received to enable online model identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow consisting of a Purpose element (FrictionDerivation), an Asset element (Mabi robot first axis), Processing components (Simulation_M, Simulation_GW, Simulation_GB) that consume input data traces and produce simulated traces, and Metadata linking all elements according to the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated stage – the digital shadow is created and used while the robot is in service to monitor and improve its dynamic behavior."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each data point to its generating model and source; continuous identification to account for wear, temperature and load changes; validation by comparing simulated friction‑augmented output with measured output; use of both analytical (white‑box) and data‑driven (black‑box) models to bound uncertainty."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow over MQTT; the digital shadow consumes these MQTT messages to populate its data traces."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Industry 4.0 Asset Administration Shell (AAS) standard and SysML modeling language for engineering models."
]