// ===========================================================
// Physical Acting Components (C2)
// ===========================================================
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor driving the first axis of the MABI MAX 100 six‑axis industrial robot."
]

instance PrimaryGearTransmission : DTDFVocab:ActingComponent [
    base:desc "Primary gear transmission coupling the motor to the cycloidal gearbox on the first robot axis."
]

instance CycloidalGearbox : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gearbox that, together with the primary transmission, drives the first robot axis."
]

// ===========================================================
// Physical Sensing Components (C3)
// ===========================================================
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor position encoder mounted on the motor shaft of the first axis."
    DTDFVocab:producedData DataTransmittedMotorEncoder
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder fixed to the output shaft of the cycloidal gearbox."
    DTDFVocab:producedData DataTransmittedGearboxEncoder
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring the motor input current I_M."
    DTDFVocab:producedData DataTransmittedMotorCurrent
]

// ===========================================================
// Data Transmitted (C4)
// ===========================================================
instance DataTransmittedMotorEncoder : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance DataTransmittedGearboxEncoder : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance DataTransmittedMotorCurrent : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance DataTransmittedTorque : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance DataTransmittedAngularVelocity : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance DataTransmittedAcceleration : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

// ===========================================================
// Data (C5)
// ===========================================================
instance AngleData : DTDFVocab:Data [
    base:desc "Rotary angle of the first axis derived directly from the motor encoder."
    DTDFVocab:fromData DataTransmittedMotorEncoder
    DTDFVocab:inputTo WebDashboardEnabler
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Output shaft angle provided by the gearbox encoder."
    DTDFVocab:fromData DataTransmittedGearboxEncoder
    DTDFVocab:inputTo WebDashboardEnabler
]

instance CurrentData : DTDFVocab:Data [
    base:desc "Motor input current I_M measured by the current sensor."
    DTDFVocab:fromData DataTransmittedMotorCurrent
    DTDFVocab:inputTo DataProcessingEngineEnabler
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Mechanical torque calculated from current sensor data."
    DTDFVocab:fromData DataTransmittedTorque
    DTDFVocab:inputTo DataProcessingEngineEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity computed from encoder position over time."
    DTDFVocab:fromData DataTransmittedAngularVelocity
    DTDFVocab:inputTo DataProcessingEngineEnabler
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration derived from successive velocity measurements."
    DTDFVocab:fromData DataTransmittedAcceleration
    DTDFVocab:inputTo DataProcessingEngineEnabler
]

// ===========================================================
// Models / Data (C10)
// ===========================================================
instance EngineeringModelSysMLStructure : DTDFVocab:Model [
    base:desc "SysML block and internal‑block diagrams describing the structure and power flows of the first robot axis."
    DTDFVocab:inputTo AssetAdministrationShellEnabler
]

instance SimulationModelMATLABMotorGearbox : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of motor, gearwheel and cycloidal gearbox, with optional friction blocks."
    DTDFVocab:inputTo DataProcessingEngineEnabler
]

instance FrictionModelCoulombViscous : DTDFVocab:Model [
    base:desc "Coulomb‑Viscous friction equation used for initial identification."
    DTDFVocab:inputTo DataProcessingEngineEnabler
]

instance FrictionModelStribeck : DTDFVocab:Model [
    base:desc "Stribeck friction model for velocity‑dependent friction."
    DTDFVocab:inputTo DataProcessingEngineEnabler
]

instance FrictionModelDahl : DTDFVocab:Model [
    base:desc "Dahl model capturing pre‑sliding behavior."
    DTDFVocab:inputTo DataProcessingEngineEnabler
]

instance FrictionModelLuGre : DTDFVocab:Model [
    base:desc "LuGre friction model for high‑fidelity black‑box identification."
    DTDFVocab:inputTo DataProcessingEngineEnabler
]

// ===========================================================
// Enablers (C11)
// ===========================================================
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker (e.g., Mosquitto) that receives live sensor streams and republishes them as topics."
    DTDFVocab:enables LiveDataStreamingService
]

instance DataProcessingEngineEnabler : DTDFVocab:Enabler [
    base:desc "Computational engine (MATLAB Runtime) that performs data calculation, parameter estimation and model selection."
    DTDFVocab:enables ContinuousFrictionParameterEstimationService
    DTDFVocab:enables AutomaticModelSelectionService
]

instance WebDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard (HTML/JS) that visualizes measured versus simulated data in real time."
    DTDFVocab:enables RealTimeDashboardVisualizationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell used to integrate engineering and simulation models into the digital twin."
    DTDFVocab:enables ModelIntegrationService
]

// ===========================================================
// Services (C6)
// ===========================================================
instance RealTimeDashboardVisualizationService : DTDFVocab:Service [
    base:desc "Service that streams live angle, velocity and torque data to the web dashboard for operator monitoring."
    DTDFVocab:provides PositioningErrorInsight
]

instance ContinuousFrictionParameterEstimationService : DTDFVocab:Service [
    base:desc "Continuously identifies static, kinetic and viscous friction parameters from incoming data."
    DTDFVocab:provides FrictionParameterInsight
]

instance AutomaticModelSelectionService : DTDFVocab:Service [
    base:desc "Automatically selects and updates white‑box or black‑box friction models based on latest parameter estimates."
    DTDFVocab:provides MotionControlRefinementAction
]

instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Integrates SysML and Simulink models into the AAS‑based digital twin."
    // No direct insight/action required for the current scope
]

instance LiveDataStreamingService : DTDFVocab:Service [
    base:desc "Service that streams live sensor data from the MQTT broker to downstream consumers."
]

// ===========================================================
// Insights / Actions (C17)
// ===========================================================
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Estimated friction parameters (static, kinetic, viscous) derived from live sensor data."
]

instance PositioningErrorInsight : DTDFVocab:Insight [
    base:desc "Real‑time view of positioning error by comparing measured and simulated joint angles."
]

instance MotionControlRefinementAction : DTDFVocab:Action [
    base:desc "Feed back identified friction parameters to the robot controller to refine motion‑control algorithms."
    DTDFVocab:IsAutomatic true
]

// ===========================================================
// Environment and Physical Components (C9)
// ===========================================================
instance RobotAxisEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotor,
               PrimaryGearTransmission,
               CycloidalGearbox,
               MotorEncoder,
               GearboxEncoder,
               MotorCurrentSensor
]

instance RobotFirstAxis : DTDFVocab:Component [
    base:desc "The first rotational axis of the MABI MAX 100 robot, comprising motor, transmission and gearbox."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time operation during robot runtime; data are processed and visualized as they are received, enabling on‑line model updating."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A digital shadow composed of DataTraces linked to Sources, a Processing component that executes simulation and friction models, and a set of Models (engineering, simulation, data‑calculation) instantiated for the first robot axis, all tied to the asset via an AAS representation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Focused on the operational stage of the robot; the digital shadow is created and used while the physical system is running to monitor and refine friction behavior."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each DataPoint to its generating model and source; validation by comparing simulated friction‑free and friction‑included outputs against measured reference traces; continuous re‑identification of model parameters to maintain accuracy despite wear or environmental changes."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are published over MQTT; the digital shadow consumes these MQTT messages to populate DataTraces. No other networking details are specified."
]