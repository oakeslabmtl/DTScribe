instance RFLP : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for requirements management"
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for object-oriented system engineering"
]

instance SPES : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for system product engineering"
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for system architecture and design"
]

instance ACME : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component-based systems"
]

instance AADL : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for embedded systems"
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component and connector modeling"
]

instance SysMLIBDs : DTDFVocab:Enabler [
    base:desc "SysML Integrated Block Diagrams for system modeling"
]

instance MathWorksSimulink : DTDFVocab:Enabler [
    base:desc "Simulation tool for dynamic system modeling and analysis"
]

instance CPlusPlus : DTDFVocab:Enabler [
    base:desc "General-purpose programming language for detailed behavior description"
]

instance Java : DTDFVocab:Enabler [
    base:desc "General-purpose programming language for system simulation"
]

instance SysMLIBDsGeometricModel : DTDFVocab:Model [
    base:desc "Geometric representation using SysML Integrated Block Diagrams"
    DTDFVocab:inputTo SysMLIBDs
]

instance SysMLv1_7StateMachine : DTDFVocab:Model [
    base:desc "Behavioral model using state machines in SysML v1.7"
    DTDFVocab:inputTo SysMLIBDs
]

instance MontiArcAutomatonBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model using MontiArc Automaton"
    DTDFVocab:inputTo MontiArc
]

instance SimulinkAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model using MathWorks Simulink simulations"
    DTDFVocab:inputTo MathWorksSimulink
]

instance RequirementsData : DTDFVocab:Data [
    base:desc "Hierarchical system abstraction data for requirements layer"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
    DTDFVocab:fromData RequirementsDataTransmitted
]

instance RequirementsDataTransmitted : DTDFVocab:DataTransmitted [
]

instance FunctionalData : DTDFVocab:Data [
    base:desc "Hierarchical system abstraction data for functional layer"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
    DTDFVocab:fromData FunctionalDataTransmitted
]

instance FunctionalDataTransmitted : DTDFVocab:DataTransmitted [
]

instance LogicalData : DTDFVocab:Data [
    base:desc "Hierarchical system abstraction data for logical layer"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
    DTDFVocab:fromData LogicalDataTransmitted
]

instance LogicalDataTransmitted : DTDFVocab:DataTransmitted [
]

instance ProductTechnicalData : DTDFVocab:Data [
    base:desc "Hierarchical system abstraction data for product/technical layer"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
    DTDFVocab:fromData ProductTechnicalDataTransmitted
]

instance ProductTechnicalDataTransmitted : DTDFVocab:DataTransmitted [
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Industry standards such as SysML (including state machines in SysML v1.7), ACME, AADL, and MontiArc (including MontiArc Automaton) are utilized for architecture description, enabling component & connector modeling, interface specifications, and behavior description, with integration into modeling tools like MathWorks Simulink and general-purpose programming languages such as C++ and Java."
]