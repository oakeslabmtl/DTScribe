// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) measuring real‑time input current of the permanent‑magnet synchronous motor"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder directly mounted on the motor shaft providing high‑resolution angular position"
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the cycloidal gearbox delivering output shaft angle"
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

// C4: Physical‑to‑virtual interaction – DataTransmitted
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorEncoderSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor, GearboxEncoderSensor
]

instance AccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor, GearboxEncoderSensor
]

// C10: Data
instance MeasuredCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current trace I_M streamed via MQTT"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance MeasuredMotorAngleData : DTDFVocab:Data [
    base:desc "Measured motor shaft angle r_M streamed via MQTT"
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance MeasuredGearboxAngleData : DTDFVocab:Data [
    base:desc "Measured gearbox output angle r_G streamed via MQTT"
    DTDFVocab:fromData GearboxAngleDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Derived torque τ computed from current and angle measurements"
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkFrictionEngine
]

instance DerivedVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω obtained by differentiating angle traces"
    DTDFVocab:fromData VelocityDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkFrictionEngine
]

instance DerivedAccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration α obtained by differentiating velocity"
    DTDFVocab:fromData AccelerationDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkFrictionEngine
]

// C10: Models
instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams describing motor, gearboxes and connections"
    DTDFVocab:inputTo AssetAdministrationShellEnabler
]

instance SimulinkFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable models (Coulomb‑Viscous, Stribeck, Dahl, LuGre) for friction identification"
    DTDFVocab:inputTo SimulinkFrictionEngine
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker handling live, real‑time streaming of sensor data from the robot to the digital shadow"
    DTDFVocab:enables DashboardVisualizationService, RealTimeFrictionIdentificationService, ModelComparisonService
]

instance SimulinkFrictionEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink runtime executing friction models and performing real‑time identification"
    DTDFVocab:enables RealTimeFrictionIdentificationService, ModelComparisonService
]

instance WebDashboardApp : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard providing operators with actionable visual insights on friction trends"
    DTDFVocab:enables DashboardVisualizationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell integration enabling provision of identified friction parameters to the robot controller"
    DTDFVocab:enables FrictionParameterProvisionService
]

// C6: Services
instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Interactive dashboard visualizing measured and simulated torque/velocity data streams"
    DTDFVocab:provides InsightFrictionTrendVisualization
]

instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction parameters from live data"
    DTDFVocab:provides InsightFrictionParameterEstimation
]

instance ModelComparisonService : DTDFVocab:Service [
    base:desc "Comparison of simulated vs. measured torque and angular‑velocity traces to validate models"
    DTDFVocab:provides InsightModelMeasurementComparison
]

instance FrictionParameterProvisionService : DTDFVocab:Service [
    base:desc "Provision of identified friction parameters to the robot controller for motion‑control adaptation"
    DTDFVocab:provides ActionAdjustMotionControl
]

// C17: Insights
instance InsightFrictionTrendVisualization : DTDFVocab:Insight [
    base:desc "Operator‑oriented visual insight on friction trends over time displayed on the dashboard"
]

instance InsightFrictionParameterEstimation : DTDFVocab:Insight [
    base:desc "Automated extraction of static, kinetic and viscous friction coefficients from incoming data"
]

instance InsightModelMeasurementComparison : DTDFVocab:Insight [
    base:desc "Insight highlighting deviations between simulated and measured torque/velocity profiles"
]

// C17: Actions
instance ActionAdjustMotionControl : DTDFVocab:Action [
    base:desc "Feed derived friction parameters back to the robot controller to adjust motion‑control algorithms and improve positioning accuracy"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow does not push data or commands back to the robot; it remains a one‑way data flow from PT to VT."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time (online) data acquisition and processing; the digital shadow updates friction estimates and visualizations on the fly as new sensor samples arrive."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A digital shadow consisting of a Purpose element (FrictionDerivation), an Asset element (the first axis), multiple DataTrace/DataPoint elements (measured and simulated torque/velocity series), Source elements (sensor channels), Processing components (Simulation M, GW, GB) that consume input traces and produce output traces using the simulation models, all linked through the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational stage – the digital shadow is created and used during runtime of the robot to monitor and improve motion accuracy; it does not cover design or manufacturing phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each data point to its source and processing model; comparison of simulated friction‑free behavior with measured data to assess model accuracy; use of manufacturer‑provided dynamic parameters in the simulation; ability to continuously re‑identify friction parameters to maintain validity over wear and temperature changes."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are streamed from the robot to the digital shadow using the MQTT protocol over the plant network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation utilizes the Asset Administration Shell (AAS) standard for Industry 4.0 integration and follows SysML modeling conventions; the digital shadow concept is grounded in the Kritzinger et al. definition of digital shadows."
]