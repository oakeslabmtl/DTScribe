import DTDFVocab from "DTDFVocab"

/// C3: Physical sensing component
instance PhysicalObjectDataCollector : DTDFVocab:SensingComponent [
    base:desc "Automated one‑way data flow sensor that continuously collects contextual data traces from the cyber‑physical system for the digital shadow",
    DTDFVocab:producedData PhysicalObjectDataTransmission
]

/// C4: Physical-to-virtual interaction (data transmission)
instance PhysicalObjectDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalObjectDataCollector
]

/// C10: Raw data trace collected from the physical object
instance PhysicalObjectRawDataTrace : DTDFVocab:Data [
    base:desc "Raw data trace representing the collected contextual data from the physical object, stored in Thingsboard",
    DTDFVocab:fromData PhysicalObjectDataTransmission,
    DTDFVocab:inputTo SimulinkProcessingEngine, NeuralNetworkProcessingEngine
]

/// C10: Physics‑based white‑box model (Simulink)
instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based white‑box model implemented in MathWorks Simulink for dynamic simulations of the system",
    DTDFVocab:inputTo SimulinkProcessingEngine
]

/// C10: Data‑driven black‑box model (Neural Network)
instance NeuralNetworkFrictionModel : DTDFVocab:Model [
    base:desc "Data‑driven black‑box neural‑network model used to predict friction behavior",
    DTDFVocab:inputTo NeuralNetworkProcessingEngine
]

/// C11: Processing component for Simulink model
instance SimulinkProcessingEngine : DTDFVocab:Enabler [
    base:desc "Processing component that executes the Simulink dynamic simulation model using input data traces",
    DTDFVocab:enables DataProcessingService
]

/// C11: Processing component for Neural‑Network model
instance NeuralNetworkProcessingEngine : DTDFVocab:Enabler [
    base:desc "Processing component that runs the neural‑network friction model on input data traces",
    DTDFVocab:enables DataProcessingService
]

/// C6: Service that orchestrates model execution and provides traceability
instance DataProcessingService : DTDFVocab:Service [
    base:desc "Service that orchestrates model execution and provides fine‑grained traceability of generated output data traces",
    DTDFVocab:provides TraceabilityInsight, DerivedDataTraceAction
]

/// C17: Insight about traceability
instance TraceabilityInsight : DTDFVocab:Insight [
    base:desc "Fine‑grained traceability linking each output data trace to its originating processing component, input traces, and specific model"
]

/// C17: Action to generate derived data traces
instance DerivedDataTraceAction : DTDFVocab:Action [
    base:desc "Automatic generation of derived data traces after model execution",
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin extends the digital shadow by adding active components that can interpret incoming data and push control information back to the physical system. These active components enable the twin to send commands or configuration updates to the physical object, though the documents do not detail command formats, authentication, or confirmation mechanisms."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The approach requires high model fidelity by continuously updating physics‑based (white‑box) and data‑driven (black‑box) friction models with the live data stream, ensuring the models stay accurate over the robot’s life (Document 4). Verification and traceability are achieved by linking each data trace back to the processing component, input traces and the model that produced it, thereby supporting detection of errors and model correctness (Document 3). The correctness of transformations between modeling artifacts (e.g., from SysML to simulation models) is emphasized as a prerequisite for reliable digital shadows (Document 2). Real‑time constraints such as control system dead time are considered to guarantee that model updates meet the timing requirements of the robot control loop (Document 4)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The documents reference the MQTT protocol (implemented by the Mosquitto broker) and the ThingsBoard IoT platform as examples of communication infrastructure that can be used for connecting physical devices to digital models. These technologies provide the underlying network communication for transmitting data traces, but the specific network topology, bandwidth, latency, or redundancy provisions are not described."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "A cloud‑based deployment is suggested for digital shadow and twin services, as exemplified by the study on using cloud technologies for a CNC machine digital shadow at the machine shop floor level. The documents do not specify the exact hosting platform, scaling strategies, storage sizes, or availability guarantees."
]