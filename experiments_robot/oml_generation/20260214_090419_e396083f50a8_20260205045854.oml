// C2: Acting Components
instance RealTimePhysicalSensor : DTDFVocab:SensingComponent [
    base:desc "A physical sensor that streams real‑time data from the physical system into the Digital Twin."
    DTDFVocab:producedData RealTimeDataTransmitted
]

// C4: Physical-to-virtual interaction
instance RealTimeDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RealTimePhysicalSensor
]

// C10: Models/Data
instance RealTimeData : DTDFVocab:Data [
    base:desc "Dataset representing real‑time data received by the Digital Twin."
    DTDFVocab:fromData RealTimeDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, ModelGenerationEnabler
]

// C11: Enablers
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that consumes real‑time data and performs processing to produce predictive control signals."
    DTDFVocab:enables DataProcessingService
]

instance ModelGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that propagates model changes from SysML/ADL artifacts to generated C++ or Java code via the MBSE toolchain's version control."
    DTDFVocab:enables ModelGenerationService
]

// C6: Services
instance DataProcessingService : DTDFVocab:Service [
    base:desc "Service that analyses real‑time data and provides predictive control actions."
    DTDFVocab:provides PredictiveControlAction
]

instance ModelGenerationService : DTDFVocab:Service [
    base:desc "Service that generates C++ and Java code from SysML and ADL models using the MBSE code generation pipeline."
    DTDFVocab:provides GeneratedCodeInsight
]

// C17: Insights/Actions
instance PredictiveControlAction : DTDFVocab:Action [
    base:desc "Action to adjust system parameters based on predictive insights derived from real‑time data."
    DTDFVocab:IsAutomatic true
]

instance GeneratedCodeInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that new simulation or control code has been generated from updated SysML/ADL models."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Lifecycle stages for a Digital Twin are understood through MBSE as a sequence of abstraction layers: requirements, functional architecture, logical architecture, and product/technical layers. Transitions between these layers are managed via SysML models (requirements, behavioral diagrams, IBDs) and corresponding ADLs (ACME, AADL, MontiArc) that capture component‑connector relationships and state machine behavior. Governance of the lifecycle is implicit in the MBSE process, with architecture description languages ensuring traceability from high‑level functional requirements down to executable code representations."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to the SysML modeling language (ISO/IEC 59556) is implicit, as SysML is used for requirements and architecture modeling. Component/connector descriptions may use the ACME or AADL standards, and state machine behavior can be modeled with MontiArc. The document does not specify additional certification or compliance frameworks beyond these modeling standards. Interoperability is supported through the use of open architecture description languages (e.g., ACME, AADL) that facilitate mapping between different system views."
]