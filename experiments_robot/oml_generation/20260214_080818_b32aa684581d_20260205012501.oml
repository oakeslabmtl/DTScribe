instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted on motor of MABI MAX 100 robot first axis"
    DTDFVocab:producedData MotorPositionData
]

instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder mounted post-gearbox of MABI MAX 100 robot first axis"
    DTDFVocab:producedData GearboxPositionData
]

instance CurrentSensors : DTDFVocab:SensingComponent [
    base:desc "Current sensors measuring input current for MABI MAX 100 robot motor"
    DTDFVocab:producedData InputCurrentData
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Torque sensor for MABI MAX 100 robot first axis"
    DTDFVocab:producedData TorqueData
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Angular velocity sensor for MABI MAX 100 robot first axis"
    DTDFVocab:producedData AngularVelocityData
]

instance AccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Acceleration sensor for MABI MAX 100 robot first axis"
    DTDFVocab:producedData AccelerationData
]

instance MotorPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoder
]

instance InputCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensors
]

instance TorqueData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
]

instance AngularVelocityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

instance AccelerationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AccelerationSensor
]

instance MotorPosition : DTDFVocab:Data [
    base:desc "Position angle data from motor encoder of MABI MAX 100 robot first axis"
    DTDFVocab:fromData MotorPositionData
    DTDFVocab:inputTo SimulinkEnabler
]

instance GearboxPosition : DTDFVocab:Data [
    base:desc "Position angle data from secondary encoder of MABI MAX 100 robot first axis"
    DTDFVocab:fromData GearboxPositionData
    DTDFVocab:inputTo SimulinkEnabler
]

instance InputCurrent : DTDFVocab:Data [
    base:desc "Measured input current data from current sensors of MABI MAX 100 robot"
    DTDFVocab:fromData InputCurrentData
    DTDFVocab:inputTo SimulinkEnabler
]

instance Torque : DTDFVocab:Data [
    base:desc "Torque data from torque sensor of MABI MAX 100 robot first axis"
    DTDFVocab:fromData TorqueData
    DTDFVocab:inputTo SimulinkEnabler
]

instance AngularVelocity : DTDFVocab:Data [
    base:desc "Angular velocity data from angular velocity sensor of MABI MAX 100 robot first axis"
    DTDFVocab:fromData AngularVelocityData
    DTDFVocab:inputTo SimulinkEnabler
]

instance Acceleration : DTDFVocab:Data [
    base:desc "Acceleration data from acceleration sensor of MABI MAX 100 robot first axis"
    DTDFVocab:fromData AccelerationData
    DTDFVocab:inputTo SimulinkEnabler
]

instance ReferenceOutputM : DTDFVocab:Data [
    base:desc "Reference output for motor position of MABI MAX 100 robot first axis"
    DTDFVocab:inputTo SimulinkEnabler
]

instance ReferenceOutputG : DTDFVocab:Data [
    base:desc "Reference output for gearbox position of MABI MAX 100 robot first axis"
    DTDFVocab:inputTo SimulinkEnabler
]

instance ReferenceOutputOut : DTDFVocab:Data [
    base:desc "Reference output for system output of MABI MAX 100 robot first axis"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulatedOutputM : DTDFVocab:Data [
    base:desc "Simulated motor position output from friction models of MABI MAX 100 robot"
    DTDFVocab:inputTo DashboardVisualizationToolsEnabler
]

instance SimulatedOutputG : DTDFVocab:Data [
    base:desc "Simulated gearbox position output from friction models of MABI MAX 100 robot"
    DTDFVocab:inputTo DashboardVisualizationToolsEnabler
]

instance SimulatedOutputOut : DTDFVocab:Data [
    base:desc "Simulated system output from friction models of MABI MAX 100 robot"
    DTDFVocab:inputTo DashboardVisualizationToolsEnabler
]

instance SysMLBDD : DTDFVocab:Model [
    base:desc "SysML Block Definition Diagram for structural modeling of MABI MAX 100 robot first axis"
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLIBD : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram for structural modeling of MABI MAX 100 robot first axis"
    DTDFVocab:inputTo SysMLEnabler
]

instance CoulombViscousModel : DTDFVocab:Model [
    base:desc "Coulomb-Viscous friction model for MABI MAX 100 robot joint"
    DTDFVocab:inputTo SimulinkEnabler
]

instance StribeckModel : DTDFVocab:Model [
    base:desc "Stribeck friction model for MABI MAX 100 robot joint"
    DTDFVocab:inputTo SimulinkEnabler
]

instance DahlModel : DTDFVocab:Model [
    base:desc "Dahl friction model for MABI MAX 100 robot joint"
    DTDFVocab:inputTo SimulinkEnabler
]

instance LuGreModel : DTDFVocab:Model [
    base:desc "LuGre friction model for MABI MAX 100 robot joint"
    DTDFVocab:inputTo SimulinkEnabler
]

instance AASModel : DTDFVocab:Model [
    base:desc "Asset Administration Shell for MABI MAX 100 robot asset metadata"
    DTDFVocab:inputTo AASEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML tool for system modeling of MABI MAX 100 robot"
    DTDFVocab:enables SystemModelingService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks MATLAB Simulink for simulation of MABI MAX 100 robot friction models"
    DTDFVocab:enables FrictionIdentificationService, MotionAccuracyEnhancementService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shells for MABI MAX 100 robot metadata management"
    DTDFVocab:enables AssetMetadataService
]

instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol for real-time sensor data streaming to digital shadow"
    DTDFVocab:enables DataStreamingService
]

instance SiemensSINUMERIK840DslEnabler : DTDFVocab:Enabler [
    base:desc "Siemens SINUMERIK 840D sl CNC controller for MABI MAX 100 robot control"
    DTDFVocab:enables RobotControlService
]

instance DashboardVisualizationToolsEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard visualization tools for real-time monitoring of MABI MAX 100 robot data"
    DTDFVocab:enables RealTimeMonitoringService
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of joint friction using white-box and black-box models for MABI MAX 100 robot"
    DTDFVocab:provides FrictionModelIdentificationInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Integrated dashboard visualization for real-time monitoring of MABI MAX 100 robot data"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance MotionAccuracyEnhancementService : DTDFVocab:Service [
    base:desc "Motion accuracy enhancement through friction model refinement for MABI MAX 100 robot"
    DTDFVocab:provides UpdateControlParametersAction
]

instance SystemModelingService : DTDFVocab:Service [
    base:desc "System modeling service for MABI MAX 100 robot using SysML"
    DTDFVocab:provides SystemModelingInsight
]

instance AssetMetadataService : DTDFVocab:Service [
    base:desc "Asset metadata management service using AAS for MABI MAX 100 robot"
    DTDFVocab:provides AssetMetadataInsight
]

instance DataStreamingService : DTDFVocab:Service [
    base:desc "Real-time data streaming service via MQTT for MABI MAX 100 robot"
    DTDFVocab:provides DataStreamingInsight
]

instance RobotControlService : DTDFVocab:Service [
    base:desc "Robot control service using Siemens SINUMERIK 840D sl for MABI MAX 100 robot"
    DTDFVocab:provides RobotControlInsight
]

instance FrictionModelIdentificationInsight : DTDFVocab:Insight [
    base:desc "Friction model identification insights for MABI MAX 100 robot joint"
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring visualization of MABI MAX 100 robot data"
]

instance UpdateControlParametersAction : DTDFVocab:Action [
    base:desc "Update control parameters based on friction model refinement for MABI MAX 100 robot motion accuracy"
    DTDFVocab:IsAutomatic true
]

instance SystemModelingInsight : DTDFVocab:Insight [
    base:desc "SysML system modeling insights for MABI MAX 100 robot"
]

instance AssetMetadataInsight : DTDFVocab:Insight [
    base:desc "Asset metadata insights from AAS for MABI MAX 100 robot"
]

instance DataStreamingInsight : DTDFVocab:Insight [
    base:desc "MQTT data streaming insights for MABI MAX 100 robot"
]

instance RobotControlInsight : DTDFVocab:Insight [
    base:desc "Robot control insights from Siemens SINUMERIK 840D sl for MABI MAX 100 robot"
]

instance Motor : DTDFVocab:Component [
    base:desc "Motor component of MABI MAX 100 robot first axis"
]

instance Gearwheel : DTDFVocab:Component [
    base:desc "Gearwheel component of MABI MAX 100 robot first axis"
]

instance CycloidalGearbox : DTDFVocab:Component [
    base:desc "Cycloidal gearbox component of MABI MAX 100 robot first axis"
]

instance RobotFirstAxisEnvironment : DTDFVocab:Environment [
    base:desc "Environment for MABI MAX 100 robot first axis"
    base:contains Motor, Gearwheel, CycloidalGearbox
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "No virtual-to-physical interaction; digital shadow functions as a passive one-way data flow with no data transmitted back to the physical system"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time data streaming via MQTT; specific time interval or synchronization rate not documented in the source material"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Digital shadow integrating structural SysML models, Simulink simulation models, and live operational data via AAS, with traceable data processing components and unified dashboard visualization for friction analysis"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "As-operated phase; digital shadow continuously monitors and refines models during robot operation to account for wear, tool changes, and application variations"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol for real-time sensor data transmission between physical robot and digital shadow"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Asset Administration Shells (AAS) per Industrie 4.0 standards and SysML modeling standards"
]