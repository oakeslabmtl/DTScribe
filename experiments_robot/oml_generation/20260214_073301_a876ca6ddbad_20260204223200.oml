// C3: Physical sensing component
instance MqttEmbeddedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor embedded in equipment that publishes time‑stamped readings via MQTT (Mosquitto broker) to the digital twin."
    DTDFVocab:producedData MqttDataTransmission
]

// C4: Physical-to-virtual interaction
instance MqttDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MqttEmbeddedSensor
]

// C10: Data
instance SensorDataTrace : DTDFVocab:Data [
    base:desc "Collected sensor data trace stored as time‑stamped reading in the digital shadow."
    DTDFVocab:fromData MqttDataTransmission
    DTDFVocab:inputTo ProcessingComponentEnabler
]

// C10: Models
instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "Simulink dynamic simulation model representing system behavior, applied to sensor data."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Data‑calculation model that derives higher‑level abstractions from pre‑processed sensor traces."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance EngineeringStructureModel : DTDFVocab:Model [
    base:desc "Engineering model describing system structure, properties, and behavior."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

// C11: Enabler
instance ProcessingComponentEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that aggregates, filters, transforms MQTT data, validates against model specifications, executes simulation and calculation models, and stores results in the digital shadow."
    DTDFVocab:enables DigitalShadowUpdateService
]

// C6: Service
instance DigitalShadowUpdateService : DTDFVocab:Service [
    base:desc "Service that updates the digital shadow with processed output traces and exposes them for downstream use."
    DTDFVocab:provides TraceabilityInsight, DataQualityValidationAction
]

// C17: Insight
instance TraceabilityInsight : DTDFVocab:Insight [
    base:desc "Provides transitive traceability from output data traces back to the processing component, input traces, and applied models."
]

// C17: Action
instance DataQualityValidationAction : DTDFVocab:Action [
    base:desc "Automatically validates input data quality and triggers alerts when deviations are detected."
    DTDFVocab:IsAutomatic true
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through verification of model transformations (e.g., from SysML to simulation models) and by maintaining fine‑grained traceability of data traces to the processing components and underlying models. The reliability of the Digital Twin depends on the correctness of the engineering, simulation and data‑calculation models, with explicit traceability used to detect and correct errors. Quality‑assurance processes include model‑based verification, traceability checks, and conformance to the Digital Shadow Reference Model; uncertainty sources are addressed by ensuring correct transformations and model correctness, although quantitative uncertainty quantification is not detailed in the documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between physical devices and the digital shadow relies on the MQTT protocol over a client‑server topology; physical nodes act as MQTT clients publishing to topics on a Mosquitto broker, while the digital‑twin side (e.g., Thingsboard platform) subscribes to these topics. No explicit bandwidth, latency, or redundancy specifications are given in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital shadow and twin are hosted on cloud‑based IoT platforms such as Thingsboard (version 4.0.0) and can also be deployed at the shop‑floor level using cloud‑enabled services, as described for a CNC‑machine digital shadow (Document 57). The deployment relies on standard cloud infrastructure providing compute and storage for the processing components and model execution; scalability is achieved through the cloud platform’s elastic resources. No on‑premise or edge‑specific deployment details are provided."
]