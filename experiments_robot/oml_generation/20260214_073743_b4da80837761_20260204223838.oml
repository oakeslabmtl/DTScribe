// C3: Physical sensing components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder provides angular position of the permanent‑magnet synchronous motor (r_M)"
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind the gearbox provides angular position of the gearbox output shaft (r_G)"
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "CNC controller measures motor input current I_M used for torque estimation"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Data (derived from DataTransmitted)
instance MeasuredMotorAngleData : DTDFVocab:Data [
    base:desc "Live measured motor angular position trace r_M"
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo MQTTStreamingEnabler
]

instance MeasuredGearboxAngleData : DTDFVocab:Data [
    base:desc "Live measured gearbox angular position trace r_G"
    DTDFVocab:fromData GearboxAngleDataTransmitted
    DTDFVocab:inputTo MQTTStreamingEnabler
]

instance MeasuredMotorCurrentData : DTDFVocab:Data [
    base:desc "Live measured motor input current I_M"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTStreamingEnabler
]

// C11: Enablers
instance MQTTStreamingEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker streams live sensor data (I_M, r_M, r_G, r_out) from the robot to the digital shadow"
    DTDFVocab:enables FrictionIdentificationService
    DTDFVocab:enables RealTimeVisualizationService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink executes friction‑free and friction models (Coulomb‑Viscous, Stribeck, Dahl, LuGre)"
    DTDFVocab:enables FrictionParameterGenerationService
]

instance SysMLStructureEnabler : DTDFVocab:Enabler [
    base:desc "SysML tool processes structural hierarchy (Axis, Motor, Gearbox) and flow ports"
    DTDFVocab:enables RealTimeVisualizationService
]

instance VisualizationDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Custom dashboard visualizes real‑time sensor traces, identified friction parameters and model predictions"
    DTDFVocab:enables RealTimeVisualizationService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell integrates the digital shadow into the enterprise IT landscape"
    DTDFVocab:enables FrictionParameterGenerationService
]

// C10: Models
instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "Engineering SysML model describing the Axis, Motor, Gearbox hierarchy and rotational/current flow ports"
    DTDFVocab:inputTo SysMLStructureEnabler
]

instance FrictionIdentificationModel : DTDFVocab:Model [
    base:desc "Combined white‑box/black‑box model continuously identifies static, kinetic and viscous friction parameters"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance FrictionFreeSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction‑free simulation used as baseline for friction parameter extraction"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuously identifies static, kinetic and viscous friction from live sensor streams"
    DTDFVocab:provides FrictionParameterInsight
    DTDFVocab:provides AdjustMotionControlAction
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of measured traces, identified friction parameters and simulation results"
    DTDFVocab:provides PositioningErrorReductionInsight
]

instance FrictionParameterGenerationService : DTDFVocab:Service [
    base:desc "Generates refined friction parameters and publishes them to the robot controller"
    DTDFVocab:provides FrictionParameterInsight
]

// C17: Insights
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters (static, kinetic, viscous) reduce positioning errors and enhance machining precision"
]

instance PositioningErrorReductionInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight that friction compensation improves axis positioning accuracy within ±90° range"
]

// C17: Actions
instance AdjustMotionControlAction : DTDFVocab:Action [
    base:desc "Automatically feeds refined friction parameters back to the robot controller to adjust model‑based motion control"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time operation: data are streamed live via MQTT and processed on‑the‑fly to update friction models during robot operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow (class FrictionShadow) instantiated with a singleton purpose (FrictionDerivation), asset (Mabi), processing components (Simulation_M, Simulation_GW, Simulation_GB) that consume input traces and produce simulated traces, and a dashboard for user interaction. All components conform to the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow is created for the operational stage of the robot, using engineering models (design) and simulation models (run‑time) to support runtime identification and control refinement."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability is ensured by linking each DataTrace to its originating source and processing component; simulated friction‑free behavior is compared to measured data to quantify deviation. Continuous updating of both white‑box analytical models and black‑box data‑driven models improves model fidelity and control accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Live sensor data are transmitted from the robot to the digital shadow using the MQTT protocol over the plant network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation uses Asset Administration Shells (AAS) as an Industry 4.0 standard for model integration, and SysML, an ISO‑standardized systems modeling language."
]