// Sensing components – torque and angular velocity sensors on MABI MAX 100 vertical axis
instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Torque sensor capturing rotational torque (τ) on the first vertical axis of the MABI MAX 100 serial robotic arm."
    DTDFVocab:producedData TorqueAngularVelocityData
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Angular velocity sensor measuring ω of the first vertical axis of the MABI MAX 100 robotic arm."
    DTDFVocab:producedData TorqueAngularVelocityData
]

// Data transmitted via MQTT – aggregated torque and angular velocity data stream
instance TorqueAngularVelocityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor, AngularVelocitySensor
]

// Data set created from the transmitted stream for analysis
instance TorqueAngularVelocityDataSet : DTDFVocab:Data [
    base:desc "Aggregated dataset of torque and angular velocity time series received from MABI MAX 100 via MQTT."
    DTDFVocab:fromData TorqueAngularVelocityData
    DTDFVocab:inputTo DigitalShadowIngestionEnabler, SimulinkSimulationEnabler
]

// Enabler for passive digital shadow ingestion using MQTT
instance DigitalShadowIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Active processing module that ingests one‑way MQTT data streams into the digital shadow reference model."
    DTDFVocab:enables PassiveMonitoringAndDiagnosticsService
]

// Enabler for running the multi‑physics identification model in a simulation environment
instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulink‑based simulation enabler that processes the digital twin data to identify motor friction and wear."
    DTDFVocab:enables PassiveMonitoringAndDiagnosticsService
]

// Computational model – multi‑physics algorithm for detecting motor friction and wear
instance MotorFrictionWearIdentificationModel : DTDFVocab:Model [
    base:desc "Model implementing a multi‑physics‑aware identification algorithm to detect motor friction and wear on the MABI MAX 100 vertical axis."
    DTDFVocab:inputTo DigitalShadowIngestionEnabler, SimulinkSimulationEnabler
]

// Service – passive monitoring and diagnostics, no control exerted
instance PassiveMonitoringAndDiagnosticsService : DTDFVocab:Service [
    base:desc "Passive monitoring and diagnostics service that ingests joint kinematic and dynamic data, applies a multi‑physics identification algorithm, and visualises findings in a real‑time dashboard."
    DTDFVocab:provides MotorFrictionAndWearInsight
]

// Insight – findings of detected friction and wear
instance MotorFrictionAndWearInsight : DTDFVocab:Insight [
    base:desc "Insight generated by the passive monitoring service indicating detected motor friction and wear conditions on the MABI MAX 100 vertical axis."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical to digital data are transmitted using the MQTT protocol. The source does not specify protocol versions, QoS levels, authentication mechanisms, or network topology details."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system conforms to established modelling and architecture standards, including the Unified Modeling Language (UML) for high‑level conceptual modelling and SysML for system architecture and behavior. Architecture Description Languages employed—ACME, AADL, and MontiArc—adhere to their respective specifications, enabling standardized component‑and‑connector descriptions and interface definitions that support interoperability across toolchains."
]