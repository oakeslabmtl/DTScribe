// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor current IM"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring motor shaft angular position"
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the gearbox output measuring angular position"
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

// C4: Data transmitted instances
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// C10: Data instances
instance MotorCurrentContinuousSeries : DTDFVocab:Data [
    base:desc "Continuous time-series of measured motor current IM"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo DataProcessingComponent
]

instance MotorAngleContinuousSeries : DTDFVocab:Data [
    base:desc "Continuous time-series of motor angular position"
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo DataProcessingComponent
]

instance GearboxAngleContinuousSeries : DTDFVocab:Data [
    base:desc "Continuous time-series of gearbox angular position"
    DTDFVocab:fromData GearboxAngleDataTransmitted
    DTDFVocab:inputTo DataProcessingComponent
]

instance DerivedTorqueContinuousSeries : DTDFVocab:Data [
    base:desc "Derived torque τ calculated from motor current and speed"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulationExecutor, FrictionModelUpdater
]

instance AngularVelocityContinuousSeries : DTDFVocab:Data [
    base:desc "Derived angular velocity ω of motor calculated from encoder data"
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo SimulationExecutor, FrictionModelUpdater
]

instance AccelerationContinuousSeries : DTDFVocab:Data [
    base:desc "Derived angular acceleration calculated from velocity data"
    DTDFVocab:inputTo SimulationExecutor
]

// C10: Models
instance SysMLStructuralModelAxis : DTDFVocab:Model [
    base:desc "SysML structural model of the first vertical axis (motor, gearwheel, cycloidal gearbox)"
    DTDFVocab:inputTo AASMapping
]

instance SimulinkMotorDynamics : DTDFVocab:Model [
    base:desc "Simulink model of motor dynamics without friction"
    DTDFVocab:inputTo SimulationExecutor
]

instance SimulinkGearboxDynamics : DTDFVocab:Model [
    base:desc "Simulink model of gearbox dynamics (gearwheel, cycloidal gearbox) without friction"
    DTDFVocab:inputTo SimulationExecutor
]

instance SimulinkFrictionModelCoulombViscous : DTDFVocab:Model [
    base:desc "Simulink friction model using Coulomb–Viscous model"
    DTDFVocab:inputTo FrictionModelUpdater
]

instance SimulinkFrictionModelStribeck : DTDFVocab:Model [
    base:desc "Simulink friction model using Stribeck model"
    DTDFVocab:inputTo FrictionModelUpdater
]

instance SimulinkFrictionModelDahl : DTDFVocab:Model [
    base:desc "Simulink friction model using Dahl model"
    DTDFVocab:inputTo FrictionModelUpdater
]

instance SimulinkFrictionModelLuGre : DTDFVocab:Model [
    base:desc "Simulink friction model using LuGre model"
    DTDFVocab:inputTo FrictionModelUpdater
]

// C11: Enablers
instance DataProcessingComponent : DTDFVocab:Enabler [
    base:desc "Enabler for data processing: deriving torque, angular velocity, acceleration"
    DTDFVocab:enables DataProcessingService
]

instance FrictionModelUpdater : DTDFVocab:Enabler [
    base:desc "Enabler for real‑time friction model parameter identification and update"
    DTDFVocab:enables FrictionIdentificationService, FrictionUpdateService
]

instance SimulationExecutor : DTDFVocab:Enabler [
    base:desc "Enabler executing Simulink motor and gearbox simulation models"
    DTDFVocab:enables MotorSimulationService, GearboxSimulationService, FrictionModelSimulationService
]

instance MQTTBridge : DTDFVocab:Enabler [
    base:desc "MQTT bridge facilitating live MQTT streaming from physical sensors to digital twin"
    DTDFVocab:enables MQTTDataStreamingService
]

instance DashboardVisualization : DTDFVocab:Enabler [
    base:desc "Enabler providing a visualization dashboard for measured and simulated data"
    DTDFVocab:enables DataVisualizationService
]

instance AASMapping : DTDFVocab:Enabler [
    base:desc "Enabler linking digital twin models and data to Asset Administration Shells for semantic integration"
    DTDFVocab:enables AASService
]

// C6: Services
instance DataProcessingService : DTDFVocab:Service [
    base:desc "Service processing raw sensor data to compute derived mechanical quantities"
    DTDFVocab:provides TorqueInsight, VelocityInsight, AccelerationInsight, ControlOptimizationAction
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service for real‑time friction model identification"
    DTDFVocab:provides FrictionModelInsight, WearProgressInsight, TemperatureEffectInsight, LoadVariationInsight
]

instance FrictionUpdateService : DTDFVocab:Service [
    base:desc "Service for updating friction model parameters in the simulation models"
    DTDFVocab:provides FrictionModelUpdateAction
]

instance MotorSimulationService : DTDFVocab:Service [
    base:desc "Service simulating motor dynamics with input of current and speed"
    DTDFVocab:provides MotorSimulationInsight
]

instance GearboxSimulationService : DTDFVocab:Service [
    base:desc "Service simulating gearbox dynamics"
    DTDFVocab:provides GearboxSimulationInsight
]

instance FrictionModelSimulationService : DTDFVocab:Service [
    base:desc "Service simulating friction effects using selected friction model"
    DTDFVocab:provides FrictionSimulationInsight
]

instance MQTTDataStreamingService : DTDFVocab:Service [
    base:desc "One-way automatic MQTT data streaming service"
    DTDFVocab:provides StreamingDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service presenting data traces of measured and simulated data on a dashboard"
    DTDFVocab:provides VisualizationInsight
]

instance AASService : DTDFVocab:Service [
    base:desc "Service maintaining semantic links to AAS"
    DTDFVocab:provides AASIntegrationInsight
]

// C17: Insights
instance TorqueInsight : DTDFVocab:Insight [
    base:desc "Insight on derived torque τ"
]

instance VelocityInsight : DTDFVocab:Insight [
    base:desc "Insight on derived angular velocity ω"
]

instance AccelerationInsight : DTDFVocab:Insight [
    base:desc "Insight on derived angular acceleration"
]

instance FrictionModelInsight : DTDFVocab:Insight [
    base:desc "Insight on current friction model parameters and fit quality"
]

instance WearProgressInsight : DTDFVocab:Insight [
    base:desc "Insight into joint wear progress based on friction loss analysis"
]

instance TemperatureEffectInsight : DTDFVocab:Insight [
    base:desc "Insight into temperature effects on friction and load"
]

instance LoadVariationInsight : DTDFVocab:Insight [
    base:desc "Insight into load variations affecting joint performance"
]

instance MotorSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight into simulated motor behavior"
]

instance GearboxSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight into simulated gearbox behavior"
]

instance FrictionSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight into simulated friction response"
]

instance StreamingDataInsight : DTDFVocab:Insight [
    base:desc "Insight confirming live data has been received via MQTT"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight displaying comparison of measured and simulated data traces"
]

instance AASIntegrationInsight : DTDFVocab:Insight [
    base:desc "Insight confirming semantic integration with AAS"
]

// C17: Actions
instance ControlOptimizationAction : DTDFVocab:Action [
    base:desc "Action enabling control algorithm tuning using derived data"
    DTDFVocab:IsAutomatic true
]

instance FrictionModelUpdateAction : DTDFVocab:Action [
    base:desc "Action to apply updated friction parameters to simulation"
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance CentralDigitalShadowComponent : DTDFVocab:Component [
    base:desc "Central digital shadow component coordinating all processing and modeling activities"
]

// C4: Environment
instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains CentralDigitalShadowComponent
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time data streaming synchronized with robot control cycle; simulation and processing executed per sample, providing updated friction estimates as data arrives"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration of components: physical robot (PT) sending sensor streams via MQTT to Digital Shadow; Digital Shadow’s processing component consumes streams, runs simulation models, generates data traces; simulation models and engineering models are linked via AAS; data traces displayed in unified dashboard; all components interact through defined data trace provenance; the constellation enables continuous friction identification"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated (runtime) stage of the robot during which real‑time data is collected and models updated; additionally, a design/validation stage during which engineering models and simulation models are created and validated against measured data"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of data points to source (via processing component, model, and AAS), continuous comparison of simulated and reference data traces, use of engineering and simulation models for validation, dynamic identification of friction parameters to adapt to wear; uncertainty handled through continuous recalibration; data provenance preserved to support V&V"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "One‑way MQTT communication from PT to DT; data streams consist of time‑stamped sensor values (current, positions) and derived variables; DT processing component consumes streams; no reverse communication defined; AAS used for semantic description of assets"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of standardized modeling languages: SysML for system architecture, AAS for asset metadata, UML for reference model; adherence to MBSE methodologies; integration of AAS IDs for semantic consistency"
]