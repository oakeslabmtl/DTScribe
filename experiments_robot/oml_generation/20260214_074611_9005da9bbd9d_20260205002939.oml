// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures motor current I_M of the MABI MAX 100 base vertical axis."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder providing motor shaft angle (r_M)."
    DTDFVocab:producedData MotorEncoderAngleDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind the gearbox providing gearbox output angle (r_G)."
    DTDFVocab:producedData GearboxEncoderAngleDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// C10: Data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor current I_M sampled from the robot."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance MotorEncoderAngleData : DTDFVocab:Data [
    base:desc "Time‑series of motor shaft angle r_M from the motor encoder."
    DTDFVocab:fromData MotorEncoderAngleDataTransmitted
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance GearboxEncoderAngleData : DTDFVocab:Data [
    base:desc "Time‑series of gearbox output angle r_G from the secondary encoder."
    DTDFVocab:fromData GearboxEncoderAngleDataTransmitted
    DTDFVocab:inputTo ProcessingComponentEnabler
]

// C10: Models/Data (engineering and simulation models)
instance SysMLAxisModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams of the base vertical axis."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the permanent‑magnet synchronous motor."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the cycloidal gearbox."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Friction calculation model combining Coulomb (static/kinetic) and viscous terms."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Stribeck friction model used for detailed identification of speed‑dependent friction."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Dahl friction model for hysteresis‑based friction behaviour."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "LuGre friction model for advanced dynamic friction identification."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

// C11: Enablers
instance MqttEnabler : DTDFVocab:Enabler [
    base:desc "MQTT transport layer that streams live sensor data from the robot to the digital shadow."
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shells used for binding engineering model data to the digital twin."
]

instance ProcessingComponentEnabler : DTDFVocab:Enabler [
    base:desc "Executes MATLAB/Simulink simulation and friction identification models consumes sensor data via MQTT."
    DTDFVocab:enables FrictionIdentificationService, ControlAdaptationService
]

instance WebDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard that visualizes real‑time data and identified friction parameters."
    DTDFVocab:enables RealTimeVisualizationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization in an integrated dashboard."
    DTDFVocab:provides FrictionParameterInsight, ControlParameterUpdateAction
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuously identifies static, kinetic and viscous friction parameters of the gearbox."
    DTDFVocab:provides FrictionParameterInsight
]

instance ControlAdaptationService : DTDFVocab:Service [
    base:desc "Model‑based control adaptation to improve robot motion accuracy."
    DTDFVocab:provides ControlParameterUpdateAction
]

// C17: Insights / Actions
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Updated static, kinetic, and viscous friction coefficients identified by the digital shadow."
]

instance ControlParameterUpdateAction : DTDFVocab:Action [
    base:desc "Feeds refined friction parameters back to the robot controller to adjust motion control algorithms."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates in real‑time: sensor time series are continuously acquired and processed, enabling on‑line friction identification during robot operation. The pipeline supports dynamic exchange of friction models and continuous update of the virtual model while the robot runs."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation consists of a purpose (FrictionDerivation), an asset representation (Mabi), processing components (Simulation_M, Simulation_GW, Simulation_GB) that consume input traces and produce simulated outputs, a set of data traces (I_M, r_M, r_G, r_out, ˆr_M, ˆr_G, ˆr_out), and a visualization dashboard that aggregates the results for user interpretation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow operates on the 'as‑operated' stage of the robot, ingesting live operational data to continuously update friction models during runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability is maintained by linking each data trace to its generating processing component and underlying model; simulated friction‑free behavior is compared against measured traces to quantify deviation; both white‑box (analytical) and black‑box (data‑driven) friction models are continuously updated, providing multi‑physics‑aware identification and validation against live data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow over MQTT; Asset Administration Shells are used to bind physical assets to their virtual representations; the processing components run locally and consume MQTT topics to generate simulated data."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach employs the Asset Administration Shell (AAS) standard for asset representation and SysML, an OMG modelling language, for engineering models."
]