// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving the first axis via input current (IM), producing torque (τM) for rotational motion within the MABI MAX 100 robot's restricted working range [-90°, 90°] with max angular velocity |q̇_max| = 75°/s."
]

instance GearWheel : DTDFVocab:ActingComponent [
    base:desc "Gearwheel component transmitting torque (τG) with a low gear ratio between the motor and cycloidal gearbox in the first axis of MABI MAX 100 robot."
]

instance CycloidalGearbox : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gearbox transmitting final system output torque (τout) with reduced speed and increased torque for the first axis of MABI MAX 100 robot."
]

instance Sinumerik840DslCncController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl CNC controller managing axis control via position, speed, and acceleration inputs/outputs for the first axis of MABI MAX 100 robot."
]

// C3: Physical Sensing Components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Primary position encoder mounted directly on the motor shaft measuring rotational position for backlash reduction and positional uncertainty mitigation in the first axis of MABI MAX 100 robot."
    DTDFVocab:producedData MotorEncoderData
]

instance SecondaryPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder mounted behind the gearbox measuring rotational position to compare with motor encoder readings for elasticity and friction inference in the first axis of MABI MAX 100 robot."
    DTDFVocab:producedData SecondaryEncoderData
]

instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring input current (IM) to the permanent magnet synchronous motor for torque estimation and friction modeling in the first axis of MABI MAX 100 robot."
    DTDFVocab:producedData CurrentSensorData
]

instance TorqueEstimationSensor : DTDFVocab:SensingComponent [
    base:desc "Derived torque estimation sensor calculating torque (τM) from motor constants, input current (IM), velocity, and acceleration for friction analysis in the first axis of MABI MAX 100 robot."
    DTDFVocab:producedData TorqueEstimationData
]

// C4: Physical-to-Virtual Interaction
instance MotorEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance SecondaryEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryPositionEncoder
]

instance CurrentSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
]

instance TorqueEstimationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueEstimationSensor
]

// C10: Models/Data
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML Block Definition Diagram (BDD) and Internal Block Diagram (IBD) representing the structural composition of the first axis (motor, gearwheel, cycloidal gearbox) in the MABI MAX 100 robot."
]

instance AssetAdministrationShell : DTDFVocab:Model [
    base:desc "Asset Administration Shell (AAS) providing contextual information about the first axis asset including system properties, data trace origins, and semantic enrichment for the MABI MAX 100 robot."
]

instance TorqueCalculationModel : DTDFVocab:Model [
    base:desc "Data calculation model deriving torque (τM) from motor constants, input current (IM), and sensor readings for friction analysis in the first axis of MABI MAX 100 robot."
]

instance IdealGearboxSimulation : DTDFVocab:Model [
    base:desc "Base simulation model of the cycloidal gearbox without friction effects (ideal behavior) implemented in MATLAB Simulink for the first axis of MABI MAX 100 robot."
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Coulomb-Viscous friction model simulating static, kinetic, and viscous friction effects in the gearbox for the first axis of MABI MAX 100 robot."
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Stribeck friction model accounting for stiction, breakaway, and steady-state friction effects in the gearbox for the first axis of MABI MAX 100 robot."
]

instance MotorSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model (Simulation M) of the permanent magnet synchronous motor output for the first axis of MABI MAX 100 robot."
]

instance GearWheelSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model (Simulation GW) of the gearwheel output for the first axis of MABI MAX 100 robot."
]

instance SystemSimulationModel : DTDFVocab:Model [
    base:desc "Overall system simulation model (Simulation GB) of the first axis including all components for the MABI MAX 100 robot."
]

instance MeasuredInputCurrentData : DTDFVocab:Data [
    base:desc "Time-stamped measured data of input current (IM) from the physical twin, used for torque estimation and friction modeling in the first axis of MABI MAX 100 robot."
    DTDFVocab:fromData CurrentSensorData
]

instance MotorEncoderMeasurements : DTDFVocab:Data [
    base:desc "Time-stamped measured data of motor encoder readings (position, velocity) from the physical twin for backlash compensation and friction analysis in the first axis of MABI MAX 100 robot."
    DTDFVocab:fromData MotorEncoderData
]

instance SecondaryEncoderMeasurements : DTDFVocab:Data [
    base:desc "Time-stamped measured data of secondary encoder readings (position) from the physical twin for elasticity and friction inference in the first axis of MABI MAX 100 robot."
    DTDFVocab:fromData SecondaryEncoderData
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Derived torque data (τM) calculated from motor constants and sensor inputs, used for friction modeling and control algorithm optimization in the first axis of MABI MAX 100 robot."
    DTDFVocab:fromData TorqueEstimationData
]

instance SimulatedMotorOutput : DTDFVocab:Data [
    base:desc "Simulated motor output data (δrM) generated by the motor simulation model for comparison with measured data in the first axis of MABI MAX 100 robot."
    DTDFVocab:fromData MotorSimulationModel
]

instance SimulatedGearWheelOutput : DTDFVocab:Data [
    base:desc "Simulated gearwheel output data (δrG) generated by the gearwheel simulation model for comparison with measured data in the first axis of MABI MAX 100 robot."
    DTDFVocab:fromData GearWheelSimulationModel
]

instance SimulatedSystemOutput : DTDFVocab:Data [
    base:desc "Simulated system output data (δrout) generated by the overall system simulation model for comparison with measured data in the first axis of MABI MAX 100 robot."
    DTDFVocab:fromData SystemSimulationModel
]

// C11: Enablers
instance MqttDataIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol implementation enabling real-time streaming of sensor data (position, current, torque) from the physical twin to the digital shadow for the first axis of MABI MAX 100 robot."
]

instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML tooling for creating and managing structural (BDD) and behavioral (IBD) models of the first axis components in the MABI MAX 100 robot."
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell implementation providing semantic enrichment and contextual information about the first axis asset in the MABI MAX 100 robot."
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Custom processing components calculating derived data traces (torque, velocity) from raw sensor readings for the first axis of MABI MAX 100 robot."
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink environment executing friction models (Coulomb-Viscous, Stribeck) and system simulations for the first axis of MABI MAX 100 robot."
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unified dashboard for integrated visualization of simulated vs. measured data traces enabling understanding of physical relationships in the first axis of MABI MAX 100 robot."
]

instance TorqueEstimationEnabler : DTDFVocab:Enabler [
    base:desc "Custom logic implementing torque estimation algorithms from motor constants and sensor inputs for the first axis of MABI MAX 100 robot."
]

instance FrictionModelingEnabler : DTDFVocab:Enabler [
    base:desc "White-box (analytical) and black-box (data-driven) friction modeling components for continuous identification of joint friction in the first axis of MABI MAX 100 robot."
]

instance ControlAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Model-based control algorithm support providing precise dynamics models (including friction) for improving robot accuracy in the first axis of MABI MAX 100 robot."
]

// C6: Services
instance FrictionModelingService : DTDFVocab:Service [
    base:desc "Continuous, multi-physics-aware identification of joint friction (static, kinetic, viscous) using white-box and black-box models for the first axis of MABI MAX 100 robot."
]

instance MotionAccuracyService : DTDFVocab:Service [
    base:desc "Enhancement of robot motion control by refining friction models with live operational data to improve motion accuracy in the first axis of MABI MAX 100 robot."
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Unified dashboard providing integrated visualization of simulated vs. measured data traces for understanding physical relationships in the first axis of MABI MAX 100 robot."
]

instance TorqueEstimationService : DTDFVocab:Service [
    base:desc "Derivation of torque (τM) from motor constants and input parameters (velocity, acceleration) for friction analysis in the first axis of MABI MAX 100 robot."
]

instance ModelCreationService : DTDFVocab:Service [
    base:desc "Development of structural (SysML) and behavioral (Simulink) models for the first axis components including friction models (Coulomb-Viscous, Stribeck) in the MABI MAX 100 robot."
]

instance ModelValidationService : DTDFVocab:Service [
    base:desc "Validation of simulation models against measured data to ensure accuracy of friction and system dynamics representations in the first axis of MABI MAX 100 robot."
]

instance ControlAlgorithmService : DTDFVocab:Service [
    base:desc "Provision of precise dynamics models (including friction) for model-based control algorithms to improve robot accuracy in the first axis of MABI MAX 100 robot."
]

instance OperationalMonitoringService : DTDFVocab:Service [
    base:desc "Real-time dashboard for visualizing deviations between simulated and measured data enabling proactive adjustments to the system in the first axis of MABI MAX 100 robot."
]

// C17: Insights/Actions
instance FrictionAnalysisInsight : DTDFVocab:Insight [
    base:desc "Identification of friction losses (static, kinetic, viscous) in the gearbox to improve motion accuracy in the first axis of MABI MAX 100 robot."
]

instance ModelRefinementAction : DTDFVocab:Action [
    base:desc "Continuous updates to friction models (white-box and black-box) based on operational data to accommodate wear, temperature, or load variations in the first axis of MABI MAX 100 robot."
    DTDFVocab:IsAutomatic true
]

instance MotionAccuracyImprovementInsight : DTDFVocab:Insight [
    base:desc "Refined friction models enabling enhanced motion control accuracy in the first axis of MABI MAX 100 robot."
]

instance ControlAlgorithmOptimizationAction : DTDFVocab:Action [
    base:desc "Integration of precise dynamics models into model-based control algorithms to enhance robot accuracy in the first axis of MABI MAX 100 robot."
    DTDFVocab:IsAutomatic true
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Unified dashboard showing integrated visualization of simulated vs. measured data traces for understanding physical relationships in the first axis of MABI MAX 100 robot."
]

instance TorqueAnalysisInsight : DTDFVocab:Insight [
    base:desc "Derived torque data (τM) analysis from motor constants and sensor inputs for friction modeling in the first axis of MABI MAX 100 robot."
]

instance ModelCreationInsight : DTDFVocab:Insight [
    base:desc "Completed structural (SysML) and behavioral (Simulink) models for the first axis components including friction models in the MABI MAX 100 robot."
]

instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Validated simulation models ensuring accuracy of friction and system dynamics representations in the first axis of MABI MAX 100 robot."
]

instance OperationalMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of system performance with visualizations of simulated vs. measured data deviations in the first axis of MABI MAX 100 robot."
]

// C12: Components
instance FirstAxisEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotor, GearWheel, CycloidalGearbox, Sinumerik840DslCncController, MotorPositionEncoder, SecondaryPositionEncoder, CurrentSensor, TorqueEstimationSensor
]

instance FrictionShadowComponent : DTDFVocab:Component [
    base:desc "Digital Shadow Reference Model incarnated as FrictionShadow class with purpose (FrictionDerivation) for the first axis of MABI MAX 100 robot, designed for continuous improvement of friction models."
    base:contains CoulombViscousFrictionModel, StribeckFrictionModel, TorqueCalculationModel, IdealGearboxSimulation
]

instance DataTraceComponent : DTDFVocab:Component [
    base:desc "Processing component aggregating raw sensor readings into structured data traces (torque, velocity) for integration into the digital shadow model of the first axis in MABI MAX 100 robot."
    base:contains MeasuredInputCurrentData, MotorEncoderMeasurements, SecondaryEncoderMeasurements, DerivedTorqueData
]

instance SimulationComponent : DTDFVocab:Component [
    base:desc "Simulation component executing executable models (MATLAB Simulink) for the first axis including motor, gearwheel, and overall system simulations in the MABI MAX 100 robot."
    base:contains MotorSimulationModel, GearWheelSimulationModel, SystemSimulationModel
]

