// C3: Physical sensing component
instance PhysicalObjectStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor collecting contextual data traces from the physical object for the digital shadow (one‑way data flow)."
    DTDFVocab:producedData PhysicalStateDataTransmitted
]

// C4: Data transmitted from sensor
instance PhysicalStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalObjectStateSensor
]

// C10: Data (aggregated/abstracted)
instance AggregatedPhysicalStateData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted physical state data after preprocessing, used as input for the digital twin."
    DTDFVocab:inputTo MosquittoMqttBroker
    DTDFVocab:fromData PhysicalStateDataTransmitted
]

// C11: Enablers
instance MosquittoMqttBroker : DTDFVocab:Enabler [
    base:desc "Mosquitto MQTT server/client implementation used as the transport mechanism for one‑way shadow data."
    DTDFVocab:enables DigitalShadowIngestionService
]

instance ModelTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Toolchain component that performs model‑to‑model transformations (e.g., SysML → Simulink) and dispatches models to execution environments."
    DTDFVocab:enables ModelExecutionService
]

// C6: Services
instance DigitalShadowIngestionService : DTDFVocab:Service [
    base:desc "Service that receives MQTT‑transmitted aggregated physical state data and updates the digital twin."
    DTDFVocab:provides PhysicalStateInsight
]

instance ModelExecutionService : DTDFVocab:Service [
    base:desc "Service that executes transformed models (Simulink, C++, Java) and produces simulation results."
    DTDFVocab:provides ModelBasedInsight
    DTDFVocab:provides UpdateDigitalTwinModelAction
]

// C17: Insights and Actions
instance PhysicalStateInsight : DTDFVocab:Insight [
    base:desc "Insight derived from real‑time physical state data available within the digital twin."
]

instance ModelBasedInsight : DTDFVocab:Insight [
    base:desc "Insight generated from combined analytical, geometric and behavioral models."
]

instance UpdateDigitalTwinModelAction : DTDFVocab:Action [
    base:desc "Automated action that integrates simulation results into the digital twin representation."
    DTDFVocab:IsAutomatic true
]

// C10: Models/Data
instance SysMLRequirementModel : DTDFVocab:Model [
    base:desc "SysML requirement diagram capturing system constraints for the digital twin."
    DTDFVocab:inputTo ModelTransformationEnabler
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML functional diagram describing functional behavior of the system."
    DTDFVocab:inputTo ModelTransformationEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME ADL architecture description defining components, connectors and interfaces."
    DTDFVocab:inputTo ModelTransformationEnabler
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "MontiArc component model with connectors, used for code generation and behavioral specification."
    DTDFVocab:inputTo ModelTransformationEnabler
]

instance SimulinkControlModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model generated from SysML for executable simulation of system behavior."
    DTDFVocab:inputTo ModelTransformationEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "According to Document 1, a Digital Twin (as opposed to a digital shadow) provides active components that can send information back to the physical system, enabling bidirectional interaction. The Twin can generate control commands or actuation requests that are transmitted to the physical asset, allowing the physical object to be influenced or steered by the virtual model. No specific command formats or protocols are detailed in the provided texts."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and validity are ensured through systematic traceability and verification of all model transformations, especially the conversion from SysML specifications to simulation models (e.g., Simulink). The reliability of the digital shadow depends on the correctness of underlying models and the applied data transformations; thus, verification methods are applied to guarantee transformation integrity. Uncertainty sources are acknowledged, and uncertainty quantification is advocated as part of the quality assurance process. Error detection and correction mechanisms are implied by the emphasis on traceability, enabling identification of inconsistencies between physical data and model predictions, and supporting corrective actions to maintain model accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical infrastructure mentioned includes the MQTT protocol (implemented by Mosquitto, Doc 2) and the ThingsBoard IoT platform (Doc 2), which together imply a network layer capable of publish/subscribe messaging over TCP/IP. The architecture typically follows a client‑broker model where sensors publish data to an MQTT broker (Mosquitto) and applications such as ThingsBoard subscribe to the data streams. Security considerations such as authentication are inherent to MQTT implementations, though exact mechanisms are not specified in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Document 2 references cloud‑based technologies used for a CNC machine digital shadow, suggesting that the digital twin can be hosted on cloud platforms or edge/on‑premise servers that interface with the manufacturing floor. The deployment may involve scalable compute and storage resources provided by the cloud to accommodate large data volumes and analytics workloads, while edge deployment can reduce latency for real‑time control. Specific scalability or availability mechanisms are not detailed in the source material."
]