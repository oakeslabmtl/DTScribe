instance RobotFrictionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ForceTorqueSensor
]

instance InjectionMoldingDisplacementDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DisplacementSensor
]

instance ProcessEnvironmentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperaturePressureSensor
]

instance RobotStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotStateSensor
]

