instance ForceTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Heterogeneous sensor capturing nonlinear physical effects like robot friction for digital shadow construction in cyber-physical systems"
    DTDFVocab:producedData RobotFrictionDataTransmitted
]

