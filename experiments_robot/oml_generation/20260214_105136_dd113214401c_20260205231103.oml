    base:desc "Sensor measuring dimensional deviations in injection molding processes to support data-driven model calibration"
    DTDFVocab:producedData InjectionMoldingDisplacementDataTransmitted
]

instance TemperaturePressureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing temperature and pressure data for process monitoring and optimization in continuous manufacturing"
    DTDFVocab:producedData ProcessEnvironmentDataTransmitted
]

instance RobotStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor collecting intrinsic system data from robotic arms for scalable identification methods without dedicated setups"
    DTDFVocab:producedData RobotStateDataTransmitted
]

