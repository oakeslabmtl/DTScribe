// C3: Physical sensing components
instance RobotInputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input electric current of the robotic manipulator"
    DTDFVocab:producedData InputCurrentTransmitted
]

instance MotorAngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor angular velocity of the robot joints"
    DTDFVocab:producedData AngularVelocityTransmitted
]

instance FirstAxisPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the first‑axis position of the robot"
    DTDFVocab:producedData AxisPositionTransmitted
]

// C4: Physical-to-virtual interaction
instance InputCurrentTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotInputCurrentSensor
]

instance AngularVelocityTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorAngularVelocitySensor
]

instance AxisPositionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FirstAxisPositionSensor
]

// Raw data instances
instance InputCurrentData : DTDFVocab:Data [
    base:desc "Raw input current trace streamed from the robot"
    DTDFVocab:fromData InputCurrentTransmitted
    DTDFVocab:inputTo PreprocessingComponent, NeuralNetworkExecutionComponent
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Raw motor angular velocity trace streamed from the robot"
    DTDFVocab:fromData AngularVelocityTransmitted
    DTDFVocab:inputTo PreprocessingComponent, NeuralNetworkExecutionComponent
]

instance AxisPositionData : DTDFVocab:Data [
    base:desc "Raw first‑axis position trace streamed from the robot"
    DTDFVocab:fromData AxisPositionTransmitted
    DTDFVocab:inputTo PreprocessingComponent, NeuralNetworkExecutionComponent
]

// C10: Models/Data
instance LowPassFilterModel : DTDFVocab:Model [
    base:desc "Low‑pass filter applied to raw sensor traces to remove noise"
    DTDFVocab:inputTo PreprocessingComponent
]

instance FrictionSimulinkModel : DTDFVocab:Model [
    base:desc "White‑box Simulink model of robot joint friction used for real‑time control"
    DTDFVocab:inputTo SimulationExecutionComponent
]

instance NeuralNetworkModel : DTDFVocab:Model [
    base:desc "Data‑driven neural‑network model trained on sensor traces for friction estimation"
    DTDFVocab:inputTo NeuralNetworkExecutionComponent
]

// C11: Enablers
instance PreprocessingComponent : DTDFVocab:Enabler [
    base:desc "Component that applies LowPassFilterModel to incoming raw data"
    DTDFVocab:enables RealTimeFrictionMonitoringService, PredictiveMaintenanceService
]

instance SimulationExecutionComponent : DTDFVocab:Enabler [
    base:desc "Component that executes FrictionSimulinkModel in a real‑time control loop"
    DTDFVocab:enables ClosedLoopControlService, MachiningParameterOptimizationService, WhatIfScenarioExecutionService
]

instance NeuralNetworkExecutionComponent : DTDFVocab:Enabler [
    base:desc "Component that runs NeuralNetworkModel for data‑calculation based insights"
    DTDFVocab:enables RealTimeFrictionMonitoringService, PredictiveMaintenanceService
]

instance AASExecutorComponent : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell Executor that stores processed traces in Thingsboard"
    DTDFVocab:enables CentralDataRepositoryService
]

// C6: Services
instance RealTimeFrictionMonitoringService : DTDFVocab:Service [
    base:desc "Provides continuous monitoring of joint friction levels in real time"
    DTDFVocab:provides FrictionLevelInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Detects early fault conditions by analysing friction trends"
    DTDFVocab:provides FaultDetectionInsight
]

instance ClosedLoopControlService : DTDFVocab:Service [
    base:desc "Compensates internal joint friction via closed‑loop control commands to the robot controller"
    DTDFVocab:provides ControlCompensationAction
]

instance MachiningParameterOptimizationService : DTDFVocab:Service [
    base:desc "Optimises machining parameters using simulation‑based evaluation of friction impact"
    DTDFVocab:provides ParameterOptimizationInsight
]

instance WhatIfScenarioExecutionService : DTDFVocab:Service [
    base:desc "Executes what‑if scenarios by varying load, temperature and payload in the digital twin"
    DTDFVocab:provides WhatIfScenarioResultInsight
]

instance CentralDataRepositoryService : DTDFVocab:Service [
    base:desc "Stores all processed data traces in Thingsboard for downstream visualization and quality prediction"
    DTDFVocab:provides DataVisualizationAction
]

// C17: Insights
instance FrictionLevelInsight : DTDFVocab:Insight [
    base:desc "Insight describing the current estimated friction level of each robot joint"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating a predicted fault based on abnormal friction evolution"
]

instance ParameterOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal machining parameters derived from simulation runs"
]

instance WhatIfScenarioResultInsight : DTDFVocab:Insight [
    base:desc "Insight summarising outcomes of a what‑if scenario analysis"
]

// C17: Actions
instance ControlCompensationAction : DTDFVocab:Action [
    base:desc "Action that sends compensation torque commands to the robot controller"
    DTDFVocab:IsAutomatic true
]

instance DataVisualizationAction : DTDFVocab:Action [
    base:desc "Action that triggers visualization dashboards in the downstream UI"
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture adopts a model‑driven approach: the robot’s physical structure is described with a SysML model and its friction dynamics with executable simulation models (e.g., Simulink). Both models and their metadata are encapsulated in an Asset Administration Shell (AAS). An automated pipeline continuously ingests live sensor data from the robot, triggers the simulation models, updates the AAS with computed results, and pushes the refreshed data to a ThingsBoard dashboard via MQTT. Thus the constellation consists of three coordinated layers – the physical robot, the AAS‑based digital twin, and the IoT/visualisation platform – orchestrated by the pipeline that handles data acquisition, model execution, and result dissemination."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows a Model‑Based Systems‑Engineering (MBSE) sequence: first requirements are modelled, then a functional architecture, followed by a logical architecture and finally a product/technical layer. These stages are represented with SysML and component‑&‑connector ADLs such as ACME, AADL, MontiArc or SysML IBDs. After the abstract stages, a concretization step instantiates the Digital‑Shadow reference model into a concrete Realisation; this is achieved by defining a conformance relation (a mapping of reference concepts to concrete classes) as described in the reference‑model approach. Transition between stages is managed by the 'originates‑from' traceability links that connect data traces to the processing components that generated them, thereby providing governance over the lifecycle through traceable data provenance."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by continuously updating model parameters with live data streams. Validation and verification are supported by the traceability links defined in the reference model, enabling verification of model transformations (e.g., SysML to Simulink) and back‑tracing of derived data to their source models. Uncertainty is managed by combining white‑box physics models with black‑box statistical models and by employing adaptive control loops that detect deviations in friction behavior for early fault detection. Quality assurance processes include transitive traceability, runtime monitoring of prediction error, and automatic triggering of model re‑training or parameter recalibration when deviations exceed predefined thresholds."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The implementation relies on an MQTT broker that provides a lightweight, publish‑subscribe message transport (MQTT) with hierarchical topics and optional read/write permissions. Data are encoded as JSON. The MQTT network connects the robot’s preprocessing unit, the AAS Executor, and the ThingsBoard IoT platform used for visualization. Communication is broker‑centric; no explicit bandwidth, latency, or redundancy specifications are given, but MQTT’s design offers low overhead and supports reliable delivery via QoS levels. Security is implied through topic‑based permissioning, but specific security protocols are not detailed."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The twin employs MQTT as the publish/subscribe protocol and the ThingsBoard platform for real‑time IoT data collection, storage and visualisation, ensuring compatibility with any MQTT‑enabled device. The Asset Administration Shell (AAS) provides a standards‑based wrapper that follows the Industry 4.0 AAS specification, exposing structural (SysML) and behavioural (Simulink) models via the Functional Mock‑up Interface (FMI) for multi‑domain model exchange. These standards enable seamless data exchange with external enterprise systems, production‑planning tools, and other digital twins."
]