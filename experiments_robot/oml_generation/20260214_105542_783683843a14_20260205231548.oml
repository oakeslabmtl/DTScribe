// C3: Physical sensing components
instance ProcessParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Real-time sensor capturing process parameters like temperature, pressure, and speed for manufacturing systems (e.g., CNC machines)."
    DTDFVocab:producedData ProcessParameterDataTransmitted
]

instance StateVariableSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing machine state variables such as health status, production status, and operational conditions for continuous process monitoring."
    DTDFVocab:producedData StateVariableDataTransmitted
]

instance ContextualDataTraceCollector : DTDFVocab:SensingComponent [
    base:desc "Component aggregating contextual data traces including operational logs, environmental parameters, and unstructured data for digital shadow purposes."
    DTDFVocab:producedData ContextualDataTraceTransmitted
]

// C4: Physical-to-virtual interaction
instance ProcessParameterDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProcessParameterSensor
]

instance StateVariableDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StateVariableSensor
]

instance ContextualDataTraceTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContextualDataTraceCollector
]

// C10: Models/Data
instance PhysicsBasedModel : DTDFVocab:Model [
    base:desc "White-box physics-based model (e.g., Simulink-based dynamic simulations) for interpretable, predictable behavior modeling of nonlinear phenomena like robot friction."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance DataDrivenModel : DTDFVocab:Model [
    base:desc "Black-box data-driven model using machine learning to capture complex, nonlinear relationships from intrinsic state data (e.g., robot dynamics)."
    DTDFVocab:inputTo MachineLearningEnabler
]

instance SysMLInternalBlockDiagram : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) defining component-connector perspectives including interfaces, interconnections, and composition for multi-layer architecture."
    DTDFVocab:inputTo ArchitectureModelingEnabler
]

instance MontiArcStateMachine : DTDFVocab:Model [
    base:desc "MontiArc state machine model for behavioral description of system components with stateful transitions."
    DTDFVocab:inputTo ArchitectureModelingEnabler
]

instance ProcessParameterData : DTDFVocab:Data [
    base:desc "Aggregated process parameter data including temperature, pressure, and speed readings from manufacturing systems."
    DTDFVocab:fromData ProcessParameterDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance StateVariableData : DTDFVocab:Data [
    base:desc "Machine state variables including health status, production status, and operational conditions for decision support."
    DTDFVocab:fromData StateVariableDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Purpose-driven aggregated contextual data traces including operational logs, environmental parameters, and unstructured data for specific use cases."
    DTDFVocab:fromData ContextualDataTraceTransmitted
    DTDFVocab:inputTo DataAggregationEnabler
]

// C11: Enablers
instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink and other simulation tools for detailed behavioral modeling integrated with architecture models for cross-layer consistency."
    DTDFVocab:enables PhysicsBasedSimulationService, BehavioralValidationService
]

instance MachineLearningEnabler : DTDFVocab:Enabler [
    base:desc "AI/ML framework enabling data-driven modeling for capturing complex relationships in system behavior."
    DTDFVocab:enables PredictiveAnalyticsService, AnomalyDetectionService
]

instance ArchitectureModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML and MontiArc tools for defining component-connector perspectives and state machines in multi-layer architecture descriptions."
    DTDFVocab:enables ArchitectureDesignService, ComponentModelingService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ETL pipelines and preprocessing components for filtering, normalization, and aggregation of heterogeneous sensor data."
    DTDFVocab:enables DataPreprocessingService, TraceabilityVerificationService
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "Contextual data aggregation framework implementing one-way data flows from physical systems to digital representations."
    DTDFVocab:enables DigitalShadowService, DataAbstractionService
]

instance CommunicationProtocolEnabler : DTDFVocab:Enabler [
    base:desc "MQTT, OPC UA, and IoT protocols enabling lightweight publish-subscribe communication and industrial data exchange."
    DTDFVocab:enables RealTimeDataTransmissionService, DeviceConnectivityService
]

