// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures motor input current per joint drive, used to infer joint torque."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance JointAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Captures joint angular position via position encoders on each drive."
    DTDFVocab:producedData JointAngleDataTransmitted
]

// C4: Physical-to-virtual interaction
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance JointAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointAngleSensor
]

// C10: Models/Data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor current measurements transmitted over MQTT."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo RealtimeDataProcessorEnabler
]

instance JointAngleData : DTDFVocab:Data [
    base:desc "Time‑series of joint angle readings from encoder sensors, transmitted over MQTT."
    DTDFVocab:fromData JointAngleDataTransmitted
    DTDFVocab:inputTo RealtimeDataProcessorEnabler
]

// C11: Enablers (MBSE tools and runtime processor)
instance RealtimeDataProcessorEnabler : DTDFVocab:Enabler [
    base:desc "Processes real‑time sensor streams to compute joint torque and friction parameters."
    DTDFVocab:enables MonitoringService, VisualizationService
]

instance SysMLMBSETool : DTDFVocab:Enabler [
    base:desc "SysML used to define the robot’s functional and logical architecture via component‑connector descriptions."
    DTDFVocab:enables MonitoringService, VisualizationService
]

instance SimulinkEnvironment : DTDFVocab:Enabler [
    base:desc "Simulink model used for behavior simulation and validation."
    DTDFVocab:enables MonitoringService, VisualizationService
]

instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc used for component‑connector modelling."
    DTDFVocab:enables MonitoringService, VisualizationService
]

instance CPlusPlusCodeGenerator : DTDFVocab:Enabler [
    base:desc "Code generator targeting Siemens controller using C++."
    DTDFVocab:enables MonitoringService, VisualizationService
]

instance JavaCodeGenerator : DTDFVocab:Enabler [
    base:desc "Code generator targeting Siemens controller using Java."
    DTDFVocab:enables MonitoringService, VisualizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Provides continuous monitoring of joint positions, inferred torques, and friction parameters."
    DTDFVocab:provides JointPositionInsight, TorqueInferenceInsight, JointFrictionParameterInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Hosts a dashboard that displays live joint data and derived friction estimates."
    DTDFVocab:provides JointPositionInsight, TorqueInferenceInsight, JointFrictionParameterInsight
]

// C17: Insights
instance JointPositionInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into current joint positions derived from encoder data."
]

instance TorqueInferenceInsight : DTDFVocab:Insight [
    base:desc "Insight on inferred joint torque calculated from motor current measurements."
]

instance JointFrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Insight on derived joint‑friction parameters used to improve controller accuracy."
]

// Infrastructure components
instance MechanicalArm : DTDFVocab:Component [
    base:desc "Six‑axis mechanical arm of the MABI MAX100 industrial robot."
]

instance DriveElectronics : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor and cycloidal gearbox powering the robot."
]

instance ProgrammableController : DTDFVocab:Component [
    base:desc "Siemens SINUMERIK 840D SL drive controlling motion execution."
]

instance SensorModule : DTDFVocab:Component [
    base:desc "Container for encoder sensors that provide joint position measurements."
]

// Environment
instance MABI_MAX100Environment : DTDFVocab:Environment [
    base:contains MechanicalArm, DriveElectronics, ProgrammableController, SensorModule
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT relies on MQTT for all data transmission from the physical system to the digital layer; no other network protocol, topology or specific bandwidth/latency requirements are detailed in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Shadow interconnects with external enterprise systems using standard industrial protocols. Sensor data is streamed via MQTT to the DataTrace component. The system publishes and consumes data through Asset Administration Shells, providing semantic context that aligns with Industry 4.0 interoperability standards. Legacy integration is achieved by bridging MQTT streams into OPC UA endpoints, allowing legacy PLCs and MES systems to communicate with the digital shadow. Configuration and metadata are exposed through a REST/JSON interface, while state updates can be pushed back to the plant’s MES or ERP using secure HTTP POSTs. The overall integration pattern is publish‑subscribe for real‑time telemetry and RESTful for command and control, ensuring seamless horizontal connectivity across factory and enterprise layers."
]