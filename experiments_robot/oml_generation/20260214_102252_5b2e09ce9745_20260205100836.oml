// C3: Physical sensing components
instance PrimaryMotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Primary encoder on motor shaft providing sub-millimeter resolution (repeatability 0.06 mm, accuracy 0.1 mm) for positional displacement measurement. Samples input current reflecting motor torque at high frequencies for real-time monitoring."
    DTDFVocab:producedData PrimaryMotorShaftEncoderDataTransmitted
]

instance SecondaryGearTransmissionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder on gear transmission output compensating for gearbox compliance. Provides sub-millimeter resolution (repeatability 0.06 mm, accuracy 0.1 mm) for output angle measurement with high-frequency sampling."
    DTDFVocab:producedData SecondaryGearTransmissionEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction
instance PrimaryMotorShaftEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "One-way data flow from primary motor shaft encoder to digital shadow. Includes raw positional displacement and input current data sampled at high frequency via controller's internal protocols."
    DTDFVocab:producedFrom PrimaryMotorShaftEncoder
]

instance SecondaryGearTransmissionEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "One-way data flow from secondary gear transmission encoder to digital shadow. Includes output angle measurements with compensation for gearbox compliance, sampled at high frequency."
    DTDFVocab:producedFrom SecondaryGearTransmissionEncoder
]

// C10: Models/Data
instance RobotKinematicModel : DTDFVocab:Model [
    base:desc "SysML-based model describing the six-axis serial robot's kinematic structure using Internal Block Diagrams (IBDs) for component-connector perspectives. Includes motor-gearbox-mechanical linkage relationships."
    DTDFVocab:inputTo MathWorksSimulinkIntegration, SysMLModelingFramework
]

instance RobotDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Detailed behavioral model of robot dynamics implemented in MathWorks Simulink for real-time or offline simulation of kinematic states and operational parameters."
    DTDFVocab:inputTo MathWorksSimulinkIntegration
]

instance RawEncoderData : DTDFVocab:Data [
    base:desc "Raw sensor data traces including positional displacement, output angle, and input current from both primary and secondary encoders. Collected via event-triggered or periodic updates from physical system."
    DTDFVocab:fromData PrimaryMotorShaftEncoderDataTransmitted, SecondaryGearTransmissionEncoderDataTransmitted
    DTDFVocab:inputTo DataPreprocessingPipeline, MQTTDataStreaming
]

instance ProcessedKinematicData : DTDFVocab:Data [
    base:desc "Structured kinematic abstractions derived from raw encoder data including compensated positional states, velocity profiles, and torque estimates. Used for real-time monitoring and visualization."
    DTDFVocab:fromData PrimaryMotorShaftEncoderDataTransmitted, SecondaryGearTransmissionEncoderDataTransmitted
    DTDFVocab:inputTo DataPreprocessingPipeline, DataVisualizationDashboard, RobotDynamicSimulationService
]

// C11: Enablers
instance MathWorksSimulinkIntegration : DTDFVocab:Enabler [
    base:desc "Integration layer connecting SysML models and general-purpose programming languages (C++, Java) with MathWorks Simulink for dynamic simulation execution and validation."
    DTDFVocab:enables RobotDynamicSimulationService
]

instance SysMLModelingFramework : DTDFVocab:Enabler [
    base:desc "SysML v1.7 implementation supporting multi-layered system description (requirements, functional/logical/physical architecture) using Internal Block Diagrams (IBDs) and state machines for component behavior modeling."
    DTDFVocab:enables SystemArchitectureService, BehavioralModelingService
]

instance MQTTDataStreaming : DTDFVocab:Enabler [
    base:desc "Lightweight publish-subscribe protocol enabling low-latency, high-frequency data streaming between physical robot and digital shadow. Supports event-triggered transmissions (state changes, threshold crossings) and periodic updates."
    DTDFVocab:enables DataAcquisitionService
]

instance DataPreprocessingPipeline : DTDFVocab:Enabler [
    base:desc "Pipeline for data validation, normalization, and abstraction to ensure consistency and relevance for digital twin purposes. Includes transformation rules for raw sensor data into structured kinematic representations."
    DTDFVocab:enables DataAbstractionService
]

instance AssetAdministrationShellIntegration : DTDFVocab:Enabler [
    base:desc "Standardized data encapsulation framework enabling semantic interoperability between digital shadow and industrial IoT ecosystems. Provides structured metadata and service interfaces for heterogeneous stakeholder integration."
]

// C6: Services
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Automated collection of contextual data traces from physical robot (sensor readings, operational states) via one-way data flows. Supports high-frequency sampling and event-triggered transmissions."
    DTDFVocab:provides RealTimeDataInsight
]

instance DataAbstractionService : DTDFVocab:Service [
    base:desc "Transformation of raw sensor data into structured kinematic abstractions (positional states, velocity profiles) using predefined aggregation rules. Enables purpose-specific data representations for monitoring."
    DTDFVocab:provides ProcessedKinematicInsight
]

instance DataVisualizationDashboard : DTDFVocab:Service [
    base:desc "Presentation layer displaying processed data traces to stakeholders via dashboard interface. Provides real-time situational awareness without autonomous decision-making capabilities."
    DTDFVocab:provides SituationalAwarenessInsight
]

instance RobotDynamicSimulationService : DTDFVocab:Service [
    base:desc "Execution of detailed dynamic simulations using MathWorks Simulink to validate robot kinematics and operational behaviors against expected models."
    DTDFVocab:provides SimulationValidationInsight
]

instance SystemArchitectureService : DTDFVocab:Service [
    base:desc "Management of multi-layered system architecture (requirements, functional/logical/physical) using SysML IBDs and ADLs. Ensures alignment across heterogeneous modeling perspectives."
    DTDFVocab:provides ArchitectureConsistencyInsight
]

instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Behavioral modeling using SysML state machines or MontiArc Automaton to define component interactions and state transitions within the digital twin."
    DTDFVocab:provides BehavioralConsistencyInsight
]

// C17: Insights/Actions
instance RealTimeDataInsight : DTDFVocab:Insight [
    base:desc "Continuous monitoring of raw sensor data traces (positional displacement, output angle, input current) from physical robot axes in near-real-time."
]

instance ProcessedKinematicInsight : DTDFVocab:Insight [
    base:desc "Structured representation of robot kinematic states including compensated positional data, velocity profiles, and torque estimates derived from raw sensor inputs."
]

instance SituationalAwarenessInsight : DTDFVocab:Insight [
    base:desc "Visualized overview of robot operational states and performance metrics enabling stakeholders to assess current system condition without autonomous control."
]

instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Comparison between simulated robot behaviors (from MathWorks Simulink) and actual physical performance to validate model accuracy and identify discrepancies."
]

instance ArchitectureConsistencyInsight : DTDFVocab:Insight [
    base:desc "Verification of alignment between requirements, functional, logical, and physical architecture layers as defined in SysML and ADL models."
]

instance BehavioralConsistencyInsight : DTDFVocab:Insight [
    base:desc "Assessment of component interactions and state transitions against defined behavioral models (SysML state machines or MontiArc Automaton)."
]

// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Six-axis drive motor providing precise motion control through torque generation. Coupled with gear transmission system for mechanical advantage and positional accuracy."
]

instance CycloidalGearTransmission : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear system compensating for backlash and providing high positional accuracy (0.1 mm) between motor and output shaft. Enables precise motion control for machining operations."
]

instance SiemensSINUMERIKController : DTDFVocab:ActingComponent [
    base:desc "Industrial controller managing motor actuation and closed-loop feedback via encoder-based positional correction. Implements safety constraints and operational thresholds for robot axes."
]

// C1: Physical System Environment
instance MABIMAX100RobotEnvironment : DTDFVocab:Environment [
    base:desc "Manufacturing domain environment containing the six-axis serial robot MABI MAX 100 designed for machining operations. Includes physical components, sensing infrastructure, and actuation systems."
    base:contains PermanentMagnetSynchronousMotor, CycloidalGearTransmission, SiemensSINUMERIKController,
                PrimaryMotorShaftEncoder, SecondaryGearTransmissionEncoder
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin (DT) constellation** in this context is implicitly defined by the **Model-Based Systems Engineering (MBSE) framework**, which integrates **heterogeneous modeling notations and tools** (e.g., SysML for architecture, MontiArc Automaton/state machines for behavior, and simulation tools like MathWorks Simulink or general-purpose languages like C++/Java). The orchestration relies on **architecture description languages (ADLs)** such as ACME, AADL, or MontiArc to define **component & connector perspectives**, including interfaces, interconnections, and composition. While the document does not specify **orchestration patterns** (e.g., microservices, event-driven, or service-oriented architectures), it implies a **modular and tool-agnostic integration** approach. The **Digital Shadow Reference Model** (Fig. 1) further suggests that DTs must include **active components** (e.g., data processing modules) to interpret and act upon aggregated data traces, but no explicit **resource management** (e.g., load balancing, fault tolerance) or **system-wide coordination mechanisms** (e.g., middleware like Apache Kafka or OPC UA) are detailed. The document emphasizes **stakeholder integration** and **heterogeneous tool interoperability** as critical for constellation design."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through **high-precision sensor calibration** (repeatability: **0.06 mm**, positional accuracy: **0.1 mm**) and **closed-loop validation** comparing **reference values** (e.g., controller commands) against **simulated values** (e.g., physics-based models of friction). Uncertainty sources, such as **gear backlash** and **motor current ripple**, are quantified via empirical testing and incorporated into the Digital Twin’s predictive models. Error detection relies on **real-time discrepancy analysis** between simulated and actual system states, while correction mechanisms adjust control parameters dynamically. Quality assurance processes include **friction parameter derivation** (validated by comparing simulated vs. measured trajectories) and **periodic recalibration** of sensor offsets to maintain model accuracy."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates horizontally via **MBSE toolchains**, enabling interoperability between **SysML (for architecture modeling), ADLs (e.g., AADL, MontiArc), and simulation/analysis tools (e.g., Simulink, C++/Java)**. Data exchange occurs through **sensor time-series streams** transmitted via **MQTT**, as referenced in the **Digital Shadow Reference Model** for manufacturing contexts. The system adheres to **heterogeneous stakeholder perspectives** and **multi-notation modeling** (e.g., combining SysML with simulation tools) to ensure seamless data flow between **physical objects (e.g., sensors/actuators) and digital representations**. No explicit integration with **ERP systems, IoT platforms, or other Digital Twins** is documented, but the architecture supports **modular, standards-based interoperability** (e.g., via ADL/ADL mappings) to accommodate external dependencies. The focus is on **real-time data aggregation** (e.g., sensor traces) rather than batch-oriented enterprise integrations."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE) standards**, specifically leveraging **SysML** as the primary modeling language. **Architecture Description Languages (ADLs)** such as **ACME**, **AADL**, and **MontiArc** are utilized for component-based system modeling, though no explicit alignment with **ISO 10303 (STEP)** or **OMG standards** is mentioned. The document does not reference industry-specific standards like **ISO 23247 (Digital Twin Framework)**, **OPC UA**, or **FIWARE**, nor does it detail **certification requirements** or **compliance frameworks**. Interoperability is implicitly supported through the integration of heterogeneous modeling tools (e.g., **SysML**, **Simulink**, **C++/Java**), but no standardized protocols or APIs are explicitly defined."
]