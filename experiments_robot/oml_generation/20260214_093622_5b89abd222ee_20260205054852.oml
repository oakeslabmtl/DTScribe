// C3: Physical sensing components (model artifacts as virtual sensors)
instance SysMLModelSensor : DTDFVocab:SensingComponent [
    base:desc "SysML model artifacts expressed in SysML v1.7 capturing functional, logical, and product/technical layers."
    DTDFVocab:producedData SysMLModelDataTransmitted
]

instance MontiArcAutomatonSensor : DTDFVocab:SensingComponent [
    base:desc "MontiArc automaton models representing dynamic behavior of the system."
    DTDFVocab:producedData MontiArcAutomatonDataTransmitted
]

instance SimulinkModelSensor : DTDFVocab:SensingComponent [
    base:desc "Simulink blocks linked to SysML interfaces for numerical simulation of system dynamics."
    DTDFVocab:producedData SimulinkModelDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmitted from sensors)
instance SysMLModelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLModelSensor
]

instance MontiArcAutomatonDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MontiArcAutomatonSensor
]

instance SimulinkModelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkModelSensor
]

// C10: Models/Data
instance SysMLModelData : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces derived from SysML artifacts, used to populate the digital shadow."
    DTDFVocab:inputTo MBSETracingEnabler
    DTDFVocab:fromData SysMLModelDataTransmitted
]

instance MontiArcAutomatonData : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces derived from MontiArc automaton models."
    DTDFVocab:inputTo MBSETracingEnabler
    DTDFVocab:fromData MontiArcAutomatonDataTransmitted
]

instance SimulinkModelData : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces derived from Simulink block models."
    DTDFVocab:inputTo MBSETracingEnabler
    DTDFVocab:fromData SimulinkModelDataTransmitted
]

// C11: Enablers
instance MBSETracingEnabler : DTDFVocab:Enabler [
    base:desc "Enables synchronization of the MBSE model hierarchy with the virtual twin environment."
    DTDFVocab:enables ModelTraceAlignmentService
]

// C6: Services
instance ModelTraceAlignmentService : DTDFVocab:Service [
    base:desc "Service that aligns and validates MBSE trace data against the digital shadow."
    DTDFVocab:provides ModelTraceConsistencyInsight
]

// C17: Insights/Actions
instance ModelTraceConsistencyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating consistency between the MBSE model traces and the digital twin’s current state."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The orchestrated digital twin is structured according to a concrete UML class diagram (‘Concrete Digital Shadow’). It comprises six principal classes: Purpose, DataTrace, Source, Asset, Processing, and Model. The Asset class represents the physical entity and is the root of the hierarchy. DataTrace instances capture time‑series for each observable attribute; Source defines the origin of each trace (e.g., specific sensors). Processing components implement algorithms that transform raw traces into higher‑level state estimates or model parameters. Model binds the processed traces to the virtual representation, while Purpose records the intended application domain (e.g., monitoring, diagnosis). All classes are integrated via explicit associations and aggregations within a centralized architecture, ensuring coordination of data acquisition, storage, real‑time processing, and representation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle is organized in a multi‑level MBSE hierarchy that mirrors the common abstraction ladder: 1) Requirements – captured as SysML requirement diagrams; 2) Functional architecture – expressed through SysML activity or sequence diagrams; 3) Logical architecture – defined with SysML block definition diagrams (BDDs) and SysML Internal Block Diagrams (IBDs); 4) Product/technical layer – represented with concrete implementation models in languages such as C++ or Java, or code generated from SysML/Simulink. Transitions between layers are managed by systematic mapping rules that preserve consistency and traceability. Governance is achieved through the application of MBSE methodologies (e.g., RFLP, OOSEM, SPES, SMArDT) that prescribe model versioning, quality checks, and change control, ensuring a disciplined evolution from abstract to concrete representations."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system streams real‑time sensor data from the MABI Max‑100 robot over the MQTT protocol, as described in the MABI robot documentation and the Mosquitto implementation reference. The robot’s safety cell confines its operational envelope, thereby limiting the maximum reachable zone and preventing accidental over‑reach. No further explicit cybersecurity measures (such as TLS, JWT, or role‑based access control), authentication mechanisms, failure‑safe designs, or risk assessment procedures are detailed in the provided documents."
]