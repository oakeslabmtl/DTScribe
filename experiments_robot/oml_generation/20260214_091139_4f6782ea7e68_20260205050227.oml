// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor that actuates the first axis of the MABI MAX 100 robot"
]

instance DualGearbox : DTDFVocab:ActingComponent [
    base:desc "Dual‑gear assembly (gearwheel + cycloidal gearbox) that transfers motor torque to the axis"
]

// Component for CNC controller
instance ControllerComponent : DTDFVocab:Component [
    base:desc "CNC controller (Siemens SINUMERIK 840D sl) issuing position/speed/acceleration commands to the axis"
]

// C3: Physical sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor shaft encoder supplying motor shaft position data"
    DTDFVocab:producedData EncoderStream
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the gearbox supplying gearbox output position data"
    DTDFVocab:producedData GearboxEncoderStream
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor current used for torque estimation"
    DTDFVocab:producedData CurrentSensorStream
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Output angle sensor measuring the actual axis position"
    DTDFVocab:producedData AngleSensorStream
]

// C4: Physical‑to‑virtual interaction (Data transmitted over MQTT)
instance EncoderStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance CurrentSensorStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance AngleSensorStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

// C10: Models/Data
instance EncoderPositionData : DTDFVocab:Data [
    base:desc "Time‑series of motor shaft encoder position extracted from EncoderStream"
    DTDFVocab:fromData EncoderStream
    DTDFVocab:inputTo SimulinkTool
]

instance GearboxEncoderPositionData : DTDFVocab:Data [
    base:desc "Time‑series of gearbox output position extracted from GearboxEncoderStream"
    DTDFVocab:fromData GearboxEncoderStream
    DTDFVocab:inputTo SimulinkTool
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor current extracted from CurrentSensorStream"
    DTDFVocab:fromData CurrentSensorStream
    DTDFVocab:inputTo SimulinkTool
]

instance MotorTorqueData : DTDFVocab:Data [
    base:desc "Motor torque computed from current sensor data and motor parameters"
    DTDFVocab:fromData CurrentSensorStream
    DTDFVocab:inputTo SimulinkTool
]

instance MotorVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity computed from encoder position data"
    DTDFVocab:fromData EncoderStream
    DTDFVocab:inputTo SimulinkTool
]

instance MotorAccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration computed from encoder velocity data"
    DTDFVocab:fromData EncoderStream
    DTDFVocab:inputTo SimulinkTool
]

instance AxisPositionData : DTDFVocab:Data [
    base:desc "Axis position time‑series from output angle sensor"
    DTDFVocab:fromData AngleSensorStream
    DTDFVocab:inputTo SimulinkTool
]

// C11: Enablers
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML tool used for structural modeling of the first axis"
    DTDFVocab:enables []
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink used for executable simulation of motor and gearbox models"
    DTDFVocab:enables RealTimeFrictionIdentification, SimulationBasedComparison, DashboardVisualization, ProvisionUpdatedFrictionParameters
]

instance AASTool : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell enabling linkage of physical assets with virtual models"
    DTDFVocab:enables []
]

instance MQTTTool : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating real‑time sensor data transfer between physical robot and digital twin"
    DTDFVocab:enables []
]

instance DashboardTool : DTDFVocab:Enabler [
    base:desc "Dashboard visualization tool displaying data traces and model outputs"
    DTDFVocab:enables DashboardVisualization
]

// C6: Services
instance RealTimeFrictionIdentification : DTDFVocab:Service [
    base:desc "Service performing real‑time friction identification and model refinement using live sensor data"
    DTDFVocab:provides UpdatedFrictionParametersInsight, FrictionModelParameterEstimationAction, MaintenanceRecommendationInsight
]

instance SimulationBasedComparison : DTDFVocab:Service [
    base:desc "Service comparing measured versus simulated kinematics for validation of the twin model"
    DTDFVocab:provides KinematicsComparisonInsight
]

instance DashboardVisualization : DTDFVocab:Service [
    base:desc "Service visualizing data traces and model outputs on a dashboard"
    DTDFVocab:provides DashboardDisplayInsight
]

instance ProvisionUpdatedFrictionParameters : DTDFVocab:Service [
    base:desc "Service providing updated friction parameters to the robot controller"
    DTDFVocab:provides UpdatedFrictionParametersUpdateAction
]

// C17: Insights & Actions
instance UpdatedFrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Insight detailing updated friction parameters and loss characteristics derived from identification"
]

instance FrictionModelParameterEstimationAction : DTDFVocab:Action [
    base:desc "Action performing estimation of friction model parameters during operation"
    DTDFVocab:IsAutomatic true
]

instance MaintenanceRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending maintenance or component replacement due to wear observed in sensor data"
]

instance KinematicsComparisonInsight : DTDFVocab:Insight [
    base:desc "Insight comparing measured vs. simulated axis kinematics for accuracy assessment"
]

instance DashboardDisplayInsight : DTDFVocab:Insight [
    base:desc "Insight used to drive visual representation of data traces and simulated outputs on dashboard"
]

instance UpdatedFrictionParametersUpdateAction : DTDFVocab:Action [
    base:desc "Action automatically transmitting updated friction parameters to the CNC controller"
    DTDFVocab:IsAutomatic true
]

// C4: Models
instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of the permanent‑magnet synchronous motor including electrical dynamics"
    DTDFVocab:inputTo SimulinkTool
]

instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of the dual‑gear assembly (gearwheel + cycloidal gearbox) including mechanical dynamics"
    DTDFVocab:inputTo SimulinkTool
]

instance FrictionCoulombViscousModel : DTDFVocab:Model [
    base:desc "Coulomb‑Viscous friction model represented in Simulink"
    DTDFVocab:inputTo SimulinkTool
]

instance FrictionStribeckModel : DTDFVocab:Model [
    base:desc "Stribeck friction model represented in Simulink"
    DTDFVocab:inputTo SimulinkTool
]

instance FrictionDahlModel : DTDFVocab:Model [
    base:desc "Dahl friction model represented in Simulink"
    DTDFVocab:inputTo SimulinkTool
]

instance FrictionLuGreModel : DTDFVocab:Model [
    base:desc "LuGre friction model represented in Simulink"
    DTDFVocab:inputTo SimulinkTool
]

// C5: Environment
instance RobotAxisEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotor, DualGearbox, MotorEncoder, GearboxEncoder, MotorCurrentSensor, OutputAngleSensor, ControllerComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is passive and does not issue commands back to the physical axis; it only provides processed data and insights for monitoring and control optimization"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Realtime data streaming with sensor sampling rates captured via MQTT; simulation and calculation models operate at the same resolution as the incoming data, enabling quasi‑instantaneous analysis of friction effects"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A loosely coupled orchestration comprising the physical asset (robot axis), its AAS, the SysML engineering model, the Simulink simulation models, the data‑calculation and processing components, data‑trace storage, and the visualization dashboard; all components exchange data via MQTT and AAS interfaces"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operate phase – the digital shadow is built for the operated industrial robot, continuously ingesting live data to improve control accuracy during runtime"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of every data point back to its source (sensor or simulation) via originates‑from associations; comparison of measured vs. simulated traces to validate friction model accuracy; continuous identification accounting for wear, load, and temperature changes; uncertainty addressed through data‑driven model updates"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol used to stream high‑frequency sensor data from the robot to the DT; Asset Administration Shells (AAS) provide semantic links between physical assets and digital models; network likely Ethernet‑based for low latency communication"
]