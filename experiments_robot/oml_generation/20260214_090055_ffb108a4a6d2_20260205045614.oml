// C3: Physical sensing components (software simulation)
instance SimulationSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Software simulation output component producing model-generated data from MathWorks Simulink for continuous‑time dynamic representation."
    DTDFVocab:producedData SimulatedDataTransmitted
]

// C4: Physical-to-virtual interaction
instance SimulatedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationSensingComponent
]

// C10: Data
instance SimulatedData : DTDFVocab:Data [
    base:desc "Contextual data trace extracted from the physical domain via simulation, representing dynamic system behavior."
    DTDFVocab:fromData SimulatedDataTransmitted
    DTDFVocab:inputTo SimulinkCodeGenEnabler
]

// C10: Models
instance SysMLBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model represented in SysML v1.7 employing activity diagrams and state‑machines, refined via MontiArc Automaton to capture detailed system behavior."
    DTDFVocab:inputTo SimulinkCodeGenEnabler
]

// C11: Enablers
instance SimulinkCodeGenEnabler : DTDFVocab:Enabler [
    base:desc "Enabler integrating MathWorks Simulink simulation and C++/Java code generation for validating and deploying the digital twin models."
    DTDFVocab:enables MonitoringControlService
]

// C6: Services
instance MonitoringControlService : DTDFVocab:Service [
    base:desc "Service enabling real‑time monitoring, control, optimization, and predictive analysis, built on the outputs of the simulation and code generation pipeline."
    DTDFVocab:provides PredictionInsight, OptimisationAction
]

// C17: Insights
instance PredictionInsight : DTDFVocab:Insight [
    base:desc "Insight providing predictive information on system behavior derived from the validated simulation results."
]

// C17: Actions
instance OptimisationAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust system parameters for optimization based on predictive insights."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "In a digital twin implementation following MBSE best practices, the development is partitioned into four primary abstraction levels. At the requirements level the twin’s functional and performance targets are captured in textual or SysML requirement diagrams. The functional architecture level is expressed through SysML Block Definition Diagrams and ACME components, mapping out the high‑level functional decomposition. The logical architecture is modeled with SysML IBDs, MontiArc connectors, and AADL to describe component interactions and data flows. The product/technical layer includes code generation, Simulink simulation models, and Java/C++ implementation. Transition between levels is traced via SysML model relationships to preserve consistency, while governance is achieved through iterative review cycles, stakeholder alignment, and traceability of changes."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "The digital twin relies on the Asset Administration Shell (AAS) as defined in the Plattform Industrie 4.0 “Details of the Asset Administration Shell” (2021). The AAS instance encapsulates ownership metadata, including the asset owner, legal domain, and governance policies. Access is controlled via a role‑based access control (RBAC) model embedded in the AAS profile, allowing fine‑grained read/write permissions and the definition of data sharing agreements. Optional privacy tags can be attached to data sets; these tags allow automated anonymisation and compliance with privacy regulations such as GDPR. Data in transit is protected by TLS 1.3 over MQTT (Mosquitto 2017) and data at rest is encrypted with AES‑256, combining encrypt‑then‑MAC security best practices."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security is achieved through a multi‑layered approach: 
1. The RAMI 4.0 reference architecture (Platform Industrie 4.0 2016) prescribes network segmentation, secure gateways, and safety‑critical components.
2. The AAS specification mandates secure communication with TLS 1.3 and client certificates for MQTT endpoints (Mosquitto 2017). 
3. Authentication is handled by the ThingsBoard IoT platform (Jan 2024) via OAuth 2.0 and JSON Web Tokens (JWTs). 
4. Threat mitigation includes firewall rules, intrusion detection on the EMQX broker, and continuous monitoring of AAS data via anomaly detection algorithms. 
5. Safety‑critical behaviors are modeled using the Functional Mockup Interface (FMI) standard (2011), where safety constraints and deadlines are encoded in the FMU. The digital twin implements watchdog timers that revert the system to the last safe state upon detecting lapses, complying with IEC 61508 safety integrity level 2 where applicable."
]