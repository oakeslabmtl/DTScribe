// C4: Physical-to-virtual interaction – MQTT data streams
instance RobotJointMqttDataStream : DTDFVocab:DataTransmitted [
    base:desc "Automated one‑way MQTT publish/subscribe stream carrying robot joint state measurements"
    DTDFVocab:producedFrom RobotJointStateSensor
]

instance FrictionMqttDataStream : DTDFVocab:DataTransmitted [
    base:desc "MQTT stream publishing friction‑related sensor measurements"
    DTDFVocab:producedFrom FrictionMeasurementSensor
]

// C3: Physical sensing components
instance RobotJointStateSensor : DTDFVocab:SensingComponent [
    base:desc "Physical robot joint state sensor publishing position, velocity, and torque via MQTT"
    DTDFVocab:producedData RobotJointMqttDataStream
]

instance FrictionMeasurementSensor : DTDFVocab:SensingComponent [
    base:desc "Physical friction sensor delivering real‑time friction coefficient data over MQTT"
    DTDFVocab:producedData FrictionMqttDataStream
]

// C10: Data objects derived from MQTT streams
instance RobotJointStateData : DTDFVocab:Data [
    base:desc "Digital twin representation of robot joint state derived from MQTT stream"
    DTDFVocab:fromData RobotJointMqttDataStream
    DTDFVocab:inputTo SimulinkEngine, ThingsBoardIoTPlatform
]

instance FrictionMeasurementData : DTDFVocab:Data [
    base:desc "Digital twin representation of measured friction data derived from MQTT stream"
    DTDFVocab:fromData FrictionMqttDataStream
    DTDFVocab:inputTo MLInferenceEngine, ThingsBoardIoTPlatform
]

// C10: Models – white‑box and black‑box
instance WhiteBoxSimulinkDynamicModel : DTDFVocab:Model [
    base:desc "Physics‑based Simulink white‑box model providing interpretable dynamic simulation of the robot"
    DTDFVocab:inputTo SimulinkEngine
]

instance BlackBoxMLLatentVariableModel : DTDFVocab:Model [
    base:desc "Data‑driven machine‑learning black‑box model capturing non‑linear effects via latent variables"
    DTDFVocab:inputTo MLInferenceEngine
]

// C11: Enablers (tooling and runtime platforms)
instance MosquittoMqttBroker : DTDFVocab:Enabler [
    base:desc "Mosquitto MQTT broker facilitating publish/subscribe communication between sensors and digital twin"
    DTDFVocab:enables DigitalShadowSyncService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation engine executing the white‑box dynamic model"
    DTDFVocab:enables HybridModelCompositionService
]

instance MLInferenceEngine : DTDFVocab:Enabler [
    base:desc "Runtime environment executing the black‑box machine‑learning latent‑variable model"
    DTDFVocab:enables HybridModelCompositionService
]

instance ThingsBoardIoTPlatform : DTDFVocab:Enabler [
    base:desc "ThingsBoard IoT platform consuming digital twin data for visualization and monitoring"
    DTDFVocab:enables DigitalShadowSyncService
]

// C6: Services
instance DigitalShadowSyncService : DTDFVocab:Service [
    base:desc "Service synchronising the digital shadow with incoming MQTT data streams"
    DTDFVocab:provides StateVisualizationInsight, AnomalyDetectionAction
]

instance HybridModelCompositionService : DTDFVocab:Service [
    base:desc "Service composing white‑box Simulink and black‑box ML models into a hybrid digital twin"
    DTDFVocab:provides ModelTraceabilityInsight, TriggerModelRetrainingAction
]

// C17: Insights
instance StateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight presenting current robot state and friction levels on the ThingsBoard dashboard"
]

instance ModelTraceabilityInsight : DTDFVocab:Insight [
    base:desc "Insight exposing traceability links from requirements through SysML specifications to concrete simulation and ML models"
]

// C17: Actions
instance AnomalyDetectionAction : DTDFVocab:Action [
    base:desc "Automatic action detecting anomalies in sensor data and raising alarms"
    DTDFVocab:IsAutomatic true
]

instance TriggerModelRetrainingAction : DTDFVocab:Action [
    base:desc "Action that triggers retraining of the black‑box ML model when prediction error exceeds threshold"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "A digital twin can include active components that push control or command information back to the physical system, unlike the passive digital shadow (Document 1). The provided documents do not detail the specific command types, message formats, validation, authentication, feedback loops, conflict resolution, or confirmation mechanisms used for this reverse flow."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through verification and traceability of model transformations (e.g., SysML to simulation models). Validation depends on the correctness of the underlying models and the data processing pipeline. Reliability is tied to model accuracy; uncertainty arises from model approximations and data quality, and quality assurance is achieved via systematic verification of transformations and maintained traceability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical network infrastructure described relies on the MQTT protocol implemented by Mosquitto (Document 2) together with an open‑source IoT platform such as Thingsboard (Document 2). This implies a client‑server (publisher‑subscriber) topology over IP networks, where edge devices act as MQTT clients communicating with a central broker that may be hosted on‑premise or in the cloud. No explicit bandwidth, latency, reliability, redundancy, or security (e.g., TLS) requirements are given beyond the use of MQTT."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment of the digital shadow/twin can be cloud‑based, as illustrated by the CNC‑machine digital shadow approach that employs cloud‑based technologies (Document 2). Platforms like Thingsboard can be run on cloud, edge, or on‑premise environments, providing scalability and availability, but the documents do not specify exact computational, storage, or reliability specifications."
]