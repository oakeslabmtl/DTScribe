namespace base = "http://www.w3.org/2000/01/rdf-schema#"
namespace DTDFVocab = "http://example.com/DTDFVocab"
instance MABIMAX100BaseAxis : DTDFVocab:Component [
    base:desc "Base axis component of MABI MAX 100 industrial robot"
]

instance MABIMAX100Joints : DTDFVocab:Component [
    base:desc "Six-axis joint assembly of MABI MAX 100 industrial robot"
]

instance MABIMAX100MechanicalStructure : DTDFVocab:Component [
    base:desc "Mechanical structure of MABI MAX 100 industrial robot"
]

instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:desc "Manufacturing environment for MABI MAX 100 industrial robot",
    base:contains MABIMAX100
]

instance MABIMAX100 : DTDFVocab:SystemUnderStudy [
    base:desc "MABI MAX 100 industrial robot",
    base:contains MABIMAX100BaseAxis, MABIMAX100Joints, MABIMAX100MechanicalStructure,
    DTDFVocab:hasEnvironment ManufacturingEnvironment
]

instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input current to robotic joints",
    DTDFVocab:producedData RobotSensorDataTransmission
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring output angle of robotic joints",
    DTDFVocab:producedData RobotSensorDataTransmission
]

instance RobotSensorDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor, OutputAngleSensor
]

instance FrictionLossDetection : DTDFVocab:Insight [
    base:desc "Detection of friction loss in robotic joints through real-time analytics"
]

instance MotionAccuracyImprovement : DTDFVocab:Action [
    base:desc "Automatic adjustment of robot motion parameters to improve accuracy based on sensor data",
    DTDFVocab:IsAutomatic true
]

instance SystemStateVisualization : DTDFVocab:Insight [
    base:desc "Real-time visualization of system state for monitoring and troubleshooting"
]

instance PerformanceMetricsVisualization : DTDFVocab:Insight [
    base:desc "Visualization of performance metrics for operational optimization"
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous multi-physics-aware joint friction identification service for real-time analysis of joint friction in industrial robots",
    DTDFVocab:provides FrictionLossDetection
]

instance AccuracyImprovementService : DTDFVocab:Service [
    base:desc "Real-time accuracy improvement service for robotic operations using sensor data-driven adjustments",
    DTDFVocab:provides MotionAccuracyImprovement
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Dashboard-based visualization service for system state monitoring and performance metrics display",
    DTDFVocab:provides SystemStateVisualization, PerformanceMetricsVisualization
]

instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML for structural modeling across requirements, functional, logical, and product/technical abstraction levels",
    DTDFVocab:enables FrictionIdentificationService, AccuracyImprovementService, DashboardVisualizationService
]

instance RFLPMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "RFLP methodology for requirements, functional, logical, and physical modeling",
    DTDFVocab:enables FrictionIdentificationService, AccuracyImprovementService, DashboardVisualizationService
]

instance OOSEMMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for object-oriented system engineering modeling",
    DTDFVocab:enables FrictionIdentificationService, AccuracyImprovementService, DashboardVisualizationService
]

instance SPESMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for systematic product engineering and simulation",
    DTDFVocab:enables FrictionIdentificationService, AccuracyImprovementService, DashboardVisualizationService
]

instance SMArDTMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for model-based system architecture and design",
    DTDFVocab:enables FrictionIdentificationService, AccuracyImprovementService, DashboardVisualizationService
]

instance ACMEADLEnabler : DTDFVocab:Enabler [
    base:desc "ACME architecture description language for component & connector perspectives",
    DTDFVocab:enables FrictionIdentificationService, AccuracyImprovementService, DashboardVisualizationService
]

instance AADLADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL architecture description language for component & connector perspectives",
    DTDFVocab:enables FrictionIdentificationService, AccuracyImprovementService, DashboardVisualizationService
]

instance MontiArcADLEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc architecture description language for component & connector perspectives",
    DTDFVocab:enables FrictionIdentificationService, AccuracyImprovementService, DashboardVisualizationService
]

instance SysMLIBDsEnabler : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component & connector perspectives",
    DTDFVocab:enables FrictionIdentificationService, AccuracyImprovementService, DashboardVisualizationService
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral modeling of robotic joints",
    DTDFVocab:enables FrictionIdentificationService, AccuracyImprovementService, DashboardVisualizationService
]

instance SysMLStateMachinesEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 state machines for behavior specification",
    DTDFVocab:enables FrictionIdentificationService, AccuracyImprovementService, DashboardVisualizationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for dynamic system simulation and analysis",
    DTDFVocab:enables FrictionIdentificationService, AccuracyImprovementService, DashboardVisualizationService
]

instance CppProgrammingLanguageEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior specification",
    DTDFVocab:enables FrictionIdentificationService, AccuracyImprovementService, DashboardVisualizationService
]

instance JavaProgrammingLanguageEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior specification",
    DTDFVocab:enables FrictionIdentificationService, AccuracyImprovementService, DashboardVisualizationService
]

instance FrictionModelDynamicPipeline : DTDFVocab:Enabler [
    base:desc "Dynamic pipeline for real-time exchange and refinement of friction models",
    DTDFVocab:enables FrictionIdentificationService, AccuracyImprovementService
]

instance InputCurrentData : DTDFVocab:Data [
    base:desc "Real-time input current measurements from robot joints",
    DTDFVocab:fromData RobotSensorDataTransmission,
    DTDFVocab:inputTo MontiArcAutomatonEnabler, SimulinkEnabler
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Real-time output angle measurements from robot joints",
    DTDFVocab:fromData RobotSensorDataTransmission,
    DTDFVocab:inputTo MontiArcAutomatonEnabler, SimulinkEnabler
]

instance RequirementsModel : DTDFVocab:Model [
    base:desc "SysML-based requirements model for digital twin system",
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based functional architecture model",
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based logical architecture model",
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance ProductTechnicalLayerModel : DTDFVocab:Model [
    base:desc "SysML-based product/technical layer model",
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance ACMEComponentModel : DTDFVocab:Model [
    base:desc "ACME architecture description for component & connector perspectives",
    DTDFVocab:inputTo ACMEADLEnabler
]

instance AADLComponentModel : DTDFVocab:Model [
    base:desc "AADL architecture description for component & connector perspectives",
    DTDFVocab:inputTo AADLADLEnabler
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description for component & connector perspectives",
    DTDFVocab:inputTo MontiArcADLEnabler
]

instance SysMLIBDsModel : DTDFVocab:Model [
    base:desc "SysML IBD for component & connector perspectives",
    DTDFVocab:inputTo SysMLIBDsEnabler
]

instance MontiArcAutomatonBehaviorModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling of robotic joints",
    DTDFVocab:inputTo MontiArcAutomatonEnabler
]

instance SysMLStateMachinesModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines for behavior specification",
    DTDFVocab:inputTo SysMLStateMachinesEnabler
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink simulation model for dynamic analysis",
    DTDFVocab:inputTo SimulinkEnabler
]

instance CppBehaviorModel : DTDFVocab:Model [
    base:desc "C++ code for detailed behavior specification",
    DTDFVocab:inputTo CppProgrammingLanguageEnabler
]

instance JavaBehaviorModel : DTDFVocab:Model [
    base:desc "Java code for detailed behavior specification",
    DTDFVocab:inputTo JavaProgrammingLanguageEnabler
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system maintains real-time synchronization with the physical asset through continuous data streams from live sensor measurements, ensuring the digital representation reflects the current physical state with minimal latency for critical operational monitoring."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system employs a Digital Shadow Reference Model as a UML class diagram to define the structure of contextual data traces, their aggregation, and abstraction for manufacturing applications, orchestrating the integration of physical data into the digital representation through standardized component interfaces and data flow mechanisms."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between physical and virtual components uses MQTT protocol for sensor data transmission; network topology, bandwidth, and redundancy specifications are not detailed in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Sensor data is streamed via MQTT protocol; Asset Administration Shells (AAS) are implemented."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system implements Asset Administration Shells (AAS) for standardized asset management, adheres to Model-Based Systems Engineering (MBSE) using SysML for requirements and architecture modeling, and employs UML class diagrams for reference model definitions, with architecture description languages (ADLs) such as AADL, ACME, and MontiArc ensuring interoperability and component-based system descriptions."
]