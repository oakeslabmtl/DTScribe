// C3: Physical-to-virtual sensing component (source of automated data flow)
instance PhysicalObjectDataSource : DTDFVocab:SensingComponent [
    base:desc "Physical object providing an automated one‑way data flow of contextual data traces to the digital shadow"
    DTDFVocab:producedData PhysicalStateDataTransmitted
]

// C4: Data transmitted from the physical object
instance PhysicalStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalObjectDataSource
]

// C10: Incoming contextual data trace captured from the physical object
instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces captured from the physical object for a specific purpose"
    DTDFVocab:fromData PhysicalStateDataTransmitted
    DTDFVocab:inputTo DataIngestionEngine
]

// C10: Derived data trace produced after model execution
instance DerivedDataTrace : DTDFVocab:Data [
    base:desc "Derived data trace generated by processing components after applying engineering or simulation models"
    DTDFVocab:inputTo ModelExecutionEngine
]

// C11: Enabler that ingests raw data and forwards it to services
instance DataIngestionEngine : DTDFVocab:Enabler [
    base:desc "Active software component that interprets incoming data traces, maintains provenance links, and routes data to services"
    DTDFVocab:enables RealTimeMonitoringService, HistoricalVisualizationService
]

// C11: Enabler that executes MBSE, ADL and simulation models
instance ModelExecutionEngine : DTDFVocab:Enabler [
    base:desc "Engine that runs SysML, ACME, AADL, MontiArc and Simulink models and connects their results to downstream services"
    DTDFVocab:enables InsightGenerationService
]

// C6: Real‑time monitoring service
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Passive service providing real‑time monitoring of the physical state"
    DTDFVocab:provides RealTimeStateInsight
]

// C6: Historical data visualization service
instance HistoricalVisualizationService : DTDFVocab:Service [
    base:desc "Passive service offering visualization of historical data over time"
    DTDFVocab:provides HistoricalTrendInsight
]

// C6: Data‑driven insight generation service
instance InsightGenerationService : DTDFVocab:Service [
    base:desc "Passive service generating data‑driven insights by processing derived data traces"
    DTDFVocab:provides DataDrivenInsight
]

// C17: Insight for current state
instance RealTimeStateInsight : DTDFVocab:Insight [
    base:desc "Insight representing the current physical state derived from incoming data traces"
]

// C17: Insight for historical trends
instance HistoricalTrendInsight : DTDFVocab:Insight [
    base:desc "Insight showing trends and patterns extracted from historical data visualization"
]

// C17: Insight produced by model‑based analysis
instance DataDrivenInsight : DTDFVocab:Insight [
    base:desc "Insight generated from execution of MBSE, ADL and simulation models and subsequent data analysis"
]

// C10: Structural and behavioral models used by the twin
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams describing components, interfaces and connectors"
    DTDFVocab:inputTo ModelExecutionEngine
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME architecture description language model capturing component composition and connectors"
    DTDFVocab:inputTo ModelExecutionEngine
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL model detailing software–hardware bindings and execution semantics"
    DTDFVocab:inputTo ModelExecutionEngine
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "MontiArc ADL model specifying component ports and connector topology"
    DTDFVocab:inputTo ModelExecutionEngine
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state‑machine diagram encoding behavioral logic of logical architecture"
    DTDFVocab:inputTo ModelExecutionEngine
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model refining component behavior as executable automata"
    DTDFVocab:inputTo ModelExecutionEngine
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink dynamic model representing physics‑based analytical simulations"
    DTDFVocab:inputTo ModelExecutionEngine
]

instance CppImplementationArtifact : DTDFVocab:Model [
    base:desc "C++ implementation artifact linked to higher‑level models for executable behavior"
    DTDFVocab:inputTo ModelExecutionEngine
]

instance JavaImplementationArtifact : DTDFVocab:Model [
    base:desc "Java implementation artifact associated with model elements for runtime execution"
    DTDFVocab:inputTo ModelExecutionEngine
]

// C11: Tooling/enablers (methodologies) supporting the twin
instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements‑Functions‑Logics‑Physics) methodology governing abstraction layers"
    DTDFVocab:enables ModelingSupportService
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology facilitating object‑oriented system engineering"
    DTDFVocab:enables ModelingSupportService
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology supporting stakeholder‑centric engineering"
    DTDFVocab:enables ModelingSupportService
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT approach managing multi‑view digital twin development"
    DTDFVocab:enables ModelingSupportService
]

// Supporting service for methodology enablers
instance ModelingSupportService : DTDFVocab:Service [
    base:desc "Service providing guidance and tooling integration per applied methodology"
    DTDFVocab:provides ModelingSupportInsight
]

// Insight associated with methodology support
instance ModelingSupportInsight : DTDFVocab:Insight [
    base:desc "Insight indicating compliance with selected engineering methodology"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital shadow receives an automated one‑way data flow from the physical object; data traces are generated continuously as the physical state changes and are streamed to the digital representation in (near) real‑time. Synchronization is event‑driven at the granularity of individual data traces; the documents do not specify explicit frequencies, latency bounds, or batch intervals."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is orchestrated according to the Digital Shadow Reference Model (Fig. 1) and its concrete realization (Fig. 5). The architecture follows a component‑and‑connector style in which the main elements are Purpose, DataTrace, Source, Asset, Processing, and Model. Data acquisition components (e.g., an MQTT client reading from a Siemens SINUMERIK controller) act as Sources that generate DataTraces associated with a specific Asset (e.g., a robot axis). Processing components consume these traces, invoke simulation or data‑calculation Models, and emit new DataTraces, while the ‘originates from’ association preserves transitive traceability. The system is centrally coordinated: the Processing layer schedules model execution and manages the flow of traces, enabling fine‑grained traceability and resource management across the twin’s components."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is pursued by coupling white‑box physics‑based Simulink models with black‑box data‑driven machine‑learning models to capture complex, non‑linear phenomena. Validation and verification are centred on traceability of model artifacts and correctness of model transformations, such as ensuring that SysML specifications are accurately converted into simulation models. Uncertainty arising from data‑driven components is addressed through probabilistic latent‑variable modelling. Quality assurance processes include verification of transformation steps, maintenance of traceability links to source data, and continuous comparison of model predictions with observed physical behaviour."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach conforms to established modeling standards: SysML is used for system‑level modelling; ADLs including ACME, AADL, and MontiArc provide standardized component‑connector descriptions; and the Digital Shadow Reference Model employs a formal conformance relation to ensure that concrete realizations adhere to the reference class diagram. These standards facilitate interoperability across tools and stakeholder groups and provide a certified basis for model exchange and integration."
]