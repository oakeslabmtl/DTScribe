// C3: Physical sensing component
instance PhysicalIoTSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real‑time data from the physical system via MQTT protocol using Mosquitto server‑client library."
    DTDFVocab:producedData MQTTDataPacket
]

// C4: Physical‑to‑virtual interaction (Data transmitted)
instance MQTTDataPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalIoTSensor
    base:desc "IoT data packet transmitted over MQTT from the physical system."
]

// C10: Data (enriched trace)
instance TwinDataTrace : DTDFVocab:Data [
    base:desc "Enriched data trace with metadata, processed by the Processing component."
    DTDFVocab:fromData MQTTDataPacket
    DTDFVocab:inputTo ProcessingEngine
]

// C10: Models / Data
instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML requirements, functional and logical architecture models capturing structural information."
    DTDFVocab:inputTo ProcessingEngine
]

instance SimulinkDynamicsModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink dynamic simulation model providing physics‑based behavioral representation (white‑box)."
    DTDFVocab:inputTo ProcessingEngine
]

instance MLPredictionModel : DTDFVocab:Model [
    base:desc "Machine‑learning data‑calculation model capturing non‑linear data‑driven relationships (black‑box)."
    DTDFVocab:inputTo ProcessingEngine
]

// C11: Enablers
instance ProcessingEngine : DTDFVocab:Enabler [
    base:desc "Processing component that consumes input traces, invokes appropriate simulation or data‑calculation model, and generates output traces for the digital shadow."
    DTDFVocab:enables DigitalShadowUpdateService
]

instance MosquittoBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker implemented by Mosquitto that receives IoT data from sensors."
    DTDFVocab:enables DataIngestionService
]

// C6: Services
instance DigitalShadowUpdateService : DTDFVocab:Service [
    base:desc "Updates the Digital Shadow with generated output traces, maintaining fine‑grained traceability."
    DTDFVocab:provides TraceabilityInsight, ConformanceMappingAction
]

instance DataIngestionService : DTDFVocab:Service [
    base:desc "Ingests MQTT data packets into the Thingsboard platform for further processing."
    DTDFVocab:provides IngestionInsight
]

// C17: Insights/Actions
instance TraceabilityInsight : DTDFVocab:Insight [
    base:desc "Fine‑grained traceability linking each data trace to its generating Processing component, consumed input traces, and involved models."
]

instance ConformanceMappingAction : DTDFVocab:Action [
    base:desc "Maps concrete model elements to abstract reference concepts, establishing a conformance relation."
    DTDFVocab:IsAutomatic true
]

instance IngestionInsight : DTDFVocab:Insight [
    base:desc "Metadata describing the origin of ingested data traces from the physical system via MQTT."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the Model‑Based Systems‑Engineering (MBSE) abstraction layers described in Document 1: a requirements stage, a functional‑architecture stage, a logical‑architecture stage, and a product/technical (implementation) stage. At each stage the DT is represented by SysML diagrams (e.g., block definition and internal‑block diagrams) or architecture description languages (ADLs) such as ACME, AADL, or MontiArc. Transition between stages is managed by mapping models from one abstraction to the next, and the overall development integrates heterogeneous stakeholder perspectives as required by MBSE."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is achieved by integrating white‑box (e.g., Simulink) and black‑box (e.g., machine‑learning) models while preserving full traceability from raw data traces through processing components to the generated shadow. Verification of model transformations, such as from SysML specifications to simulation models, is mandated to ensure correctness of the generated artifacts. Uncertainty sources—including sensor noise and model approximation errors—are acknowledged, and the reference model’s fine‑grained traceability links enable detection of inconsistencies and propagation of corrective actions. Quality assurance relies on these traceability mechanisms together with verification methods cited for model‑based development of complex systems."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital shadow approach described in the CNC‑machine case study employs cloud‑based technologies for hosting the digital representation at the machine‑shop floor level, indicating that the deployment can be performed on cloud platforms. No further details on compute, storage, scalability, or redundancy are provided."
]