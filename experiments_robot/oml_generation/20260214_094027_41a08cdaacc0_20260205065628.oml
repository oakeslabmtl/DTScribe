// Acting Component
instance PermanentMagnetSyncMotorWithGearbox : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor and gear transmission (gearbox and cycloidal gearbox) driving the first joint."
]

// Sensing Components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring AC current."
    DTDFVocab:producedData MotorCurrentMQTTData
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder providing position information."
    DTDFVocab:producedData MotorEncoderMQTTData
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Gearbox encoder providing transmission position."
    DTDFVocab:producedData GearboxEncoderMQTTData
]

// Data Transmitted
instance MotorCurrentMQTTData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderMQTTData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderMQTTData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// Measured Data
instance MeasuredMotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current recorded via MQTT."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData MotorCurrentMQTTData
]

instance MeasuredMotorEncoderData : DTDFVocab:Data [
    base:desc "Measured motor encoder angle recorded via MQTT."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData MotorEncoderMQTTData
]

instance MeasuredGearboxEncoderData : DTDFVocab:Data [
    base:desc "Measured gearbox encoder angle recorded via MQTT."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData GearboxEncoderMQTTData
]

// Derived Data
instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Derived torque from current and encoder data."
    DTDFVocab:inputTo SimulinkExecutionEnvironment
    DTDFVocab:fromData MotorCurrentMQTTData, MotorEncoderMQTTData, GearboxEncoderMQTTData
]

instance DerivedAngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity of first joint."
    DTDFVocab:inputTo SimulinkExecutionEnvironment
    DTDFVocab:fromData MotorEncoderMQTTData, GearboxEncoderMQTTData
]

instance DerivedAngularAccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration of first joint."
    DTDFVocab:inputTo SimulinkExecutionEnvironment
    DTDFVocab:fromData MotorEncoderMQTTData, GearboxEncoderMQTTData
]

// Simulated Data
instance SimulatedTorqueData : DTDFVocab:Data [
    base:desc "Simulated torque from friction models."
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

instance SimulatedAngularVelocityData : DTDFVocab:Data [
    base:desc "Simulated angular velocity from friction models."
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

instance SimulatedAngularAccelerationData : DTDFVocab:Data [
    base:desc "Simulated angular acceleration from friction models."
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

// Models
instance SysMLMotorGearboxModel : DTDFVocab:Model [
    base:desc "SysML structural model of permanent‑magnet synchronous motor and gearboxes."
    DTDFVocab:inputTo SysMLModelingTool
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "Simulink model of the synchronous motor dynamics."
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "Simulink model of the gearbox transmission."
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

instance SimulinkFrictionModelCoulombViscous : DTDFVocab:Model [
    base:desc "Simulink model implementing Coulomb‑Viscous friction."
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

instance SimulinkFrictionModelStribeck : DTDFVocab:Model [
    base:desc "Simulink model implementing Stribeck friction."
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

instance SimulinkFrictionModelDahl : DTDFVocab:Model [
    base:desc "Simulink model implementing Dahl friction."
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

instance SimulinkFrictionModelLuGre : DTDFVocab:Model [
    base:desc "Simulink model implementing LuGre friction."
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

// Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML tool for structural modeling of motor and gearboxes."
    DTDFVocab:enables AssetModelingService
]

instance SimulinkExecutionEnvironment : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for executable simulation of motor, gearbox, and friction models."
    DTDFVocab:enables ContinuousFrictionIdentificationService, SimulateFrictionModelsService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell providing semantic abstraction of asset data."
    DTDFVocab:enables DataLinkageService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker for real‑time sensor data streaming."
    DTDFVocab:enables RealTimeDataReceptionService
]

instance WebDashboard : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard for visualization of twin state and insights."
    DTDFVocab:enables VisualizationDashboardService
]

// Services
instance AssetModelingService : DTDFVocab:Service [
    base:desc "Modeling of asset structure in SysML."
    DTDFVocab:provides AssetModelDataLinkageInsight
]

instance ContinuousFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous friction identification generating updated friction parameters."
    DTDFVocab:provides UpdatedFrictionParametersInsight, RetuneControlGainsAction
]

instance SimulateFrictionModelsService : DTDFVocab:Service [
    base:desc "Simulation of white‑ and black‑box friction models."
]

instance DataLinkageService : DTDFVocab:Service [
    base:desc "Data linkage to the asset model via AAS."
    DTDFVocab:provides AssetModelDataLinkageInsight
]

instance RealTimeDataReceptionService : DTDFVocab:Service [
    base:desc "Real‑time reception of sensor streams and state estimation."
    DTDFVocab:provides RealTimeStateEstimationInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Visualization of twin state, friction parameters, and maintenance plans."
    DTDFVocab:provides TrajectoryPlanningImprovementInsight, GearWearMonitoringPlanInsight
]

// Insights
instance UpdatedFrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Updated friction parameters (Coulomb, viscous, Stribeck) derived by the DT."
]

instance RealTimeStateEstimationInsight : DTDFVocab:Insight [
    base:desc "Real‑time estimation of motor torque, angular velocity, and acceleration."
]

instance AssetModelDataLinkageInsight : DTDFVocab:Insight [
    base:desc "Semantic linkage between digital twin and asset administration shell."
]

instance TrajectoryPlanningImprovementInsight : DTDFVocab:Insight [
    base:desc "Improved trajectory planning guidance from updated friction data."
]

instance GearWearMonitoringPlanInsight : DTDFVocab:Insight [
    base:desc "Gear wear monitoring plan based on friction wear trends."
]

// Actions
instance RetuneControlGainsAction : DTDFVocab:Action [
    base:desc "Retune control gains of robot based on updated friction parameters."
    DTDFVocab:IsAutomatic false
]

// Component (Digital Shadow)
instance DigitalShadowFirstJoint : DTDFVocab:Component [
    base:desc "Digital shadow representing first joint (base axis) of MABI MAX 100 serial industrial robot."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow is passive and does not send commands back to the robot"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time continuous streaming and processing, with data transmitted at the robot’s sensor rates (e.g., current and encoder updates at the plant’s control cycle)"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical robot + sensors → MQTT broker → DT processing component (constructing digital shadow) → simulation/analysis models → dashboard; all orchestrated within a single application environment"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Designed (ideal structural and simulation models), manufactured (sensor data from the actual robot), operated (live data and continuous friction model adaptation)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Models validated by continuously comparing simulated and measured data; white‑box friction models with parameter identification, data‑driven models complementing, traceability of data points, analysis of uncertainties due to wear, temperature, and load; verification through real‑time drift assessment"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication via MQTT publish/subscribe over IP network; use of Asset Administration Shell interfaces; synchronous data exchange between robot controller, sensors, and DT processing"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Modeling performed with SysML, data exchange via MQTT, asset semantic via Asset Administration Shells (AAS); adherence to relevant industry standards for modeling and communication"
]