// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving the first axis of MABI MAX 100 industrial robot, interfacing with gearbox and controller for motion control."
]

instance Gearbox : DTDFVocab:ActingComponent [
    base:desc "Mechanical gearbox component of MABI MAX 100 robot axis, transmitting torque from motor to load while enabling speed reduction."
]

instance SiemensSINUMERIK840DslController : DTDFVocab:ActingComponent [
    base:desc "Industrial robot controller (Siemens SINUMERIK 840D sl) interfacing with physical twin to collect real-time operational data (motor currents, positional feedback) and execute motion control commands."
]

// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input current of the permanent magnet synchronous motor in MABI MAX 100 robot axis."
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring torque output from the gearbox in MABI MAX 100 robot axis."
    DTDFVocab:producedData TorqueDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring angular velocity of the robot axis in MABI MAX 100 robot."
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

instance PositionalFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor providing positional feedback from the robot axis encoder in MABI MAX 100."
    DTDFVocab:producedData PositionalFeedbackDataTransmitted
]

// C4: Physical-to-virtual interaction
instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

instance PositionalFeedbackDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionalFeedbackSensor
]

// C10: Models/Data
instance RobotAxisSysMLModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) representing component-connector architecture of MABI MAX 100 robot axis including motor, gearbox, and controller."
    DTDFVocab:inputTo MATLABSimulinkEnabler, SiemensSINUMERIK840DslEnabler
]

instance FrictionLossSimulationModel : DTDFVocab:Model [
    base:desc "Executable simulation model in MATLAB Simulink for behavioral modeling and friction loss analysis of robot axis components."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces collected from physical system via Digital Shadow, including time-series sensor measurements (input current, torque, angular velocity, positional feedback)."
    DTDFVocab:fromData InputCurrentDataTransmitted, TorqueDataTransmitted, AngularVelocityDataTransmitted, PositionalFeedbackDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler, DashboardVisualizationEnabler
]

instance RobotMotionAccuracyData : DTDFVocab:Data [
    base:desc "Processed data representing robot motion accuracy metrics derived from simulation and real-time operational data."
    DTDFVocab:fromData ContextualDataTraces
    DTDFVocab:inputTo DashboardVisualizationEnabler
]

instance JointFrictionUnderstandingData : DTDFVocab:Data [
    base:desc "Analytical data characterizing joint friction behavior and loss patterns in MABI MAX 100 robot axis."
    DTDFVocab:fromData ContextualDataTraces
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

// C11: Enablers
instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks MATLAB Simulink platform for executable simulation models processing sensor data, detecting friction loss, and deriving control adjustments."
    DTDFVocab:enables SimulationAndAnalysisService, FrictionLossDetectionService
]

instance SiemensSINUMERIK840DslEnabler : DTDFVocab:Enabler [
    base:desc "Siemens SINUMERIK 840D sl industrial robot controller enabling real-time data collection and motion control interface."
    DTDFVocab:enables PassiveDataCollectionService
]

instance MQTTProtocolEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol for low-bandwidth, high-latency optimized transmission of time-series sensor data from physical system to Digital Shadow."
    DTDFVocab:enables PassiveDataCollectionService
]

instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard-based visualization interface for system states, data trends, and simulation results."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance PassiveDataCollectionService : DTDFVocab:Service [
    base:desc "Automated one-way data aggregation service collecting and abstracting contextual data traces from physical system via Digital Shadow."
    DTDFVocab:provides MotionAccuracyInsight, FrictionLossInsight
]

instance SimulationAndAnalysisService : DTDFVocab:Service [
    base:desc "Service leveraging MATLAB Simulink for behavioral modeling and friction loss simulation integrated with Siemens controller."
    DTDFVocab:provides MotionAccuracyInsight, FrictionLossInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service providing dashboard-based visualization of system states, data trends, and simulation results for stakeholders."
    DTDFVocab:provides MotionAccuracyInsight, FrictionLossInsight
]

instance FrictionLossDetectionService : DTDFVocab:Service [
    base:desc "Service detecting and analyzing friction loss patterns in robot axis components through simulation and real-time data processing."
    DTDFVocab:provides FrictionLossInsight
]

// C17: Insights/Actions
instance MotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Data-driven insight into robot motion accuracy improvements derived from contextual data traces and simulation results."
]

instance FrictionLossInsight : DTDFVocab:Insight [
    base:desc "Analytical insight into joint friction behavior and loss patterns enabling predictive maintenance and performance tuning."
]

// C1: Environment
instance MABIMax100RobotEnvironment : DTDFVocab:Environment [
    base:desc "High-precision manufacturing environment hosting MABI MAX 100 serial industrial robot with permanent magnet synchronous motor, gearbox, and Siemens SINUMERIK 840D sl controller."
    base:contains RobotAxisComponent
]

instance RobotAxisComponent : DTDFVocab:Component [
    base:desc "Modular component representing the first axis of MABI MAX 100 robot including motor, gearbox, and controller interconnections."
    base:isContainedIn MABIMax100RobotEnvironment
]

instance PermanentMagnetSynchronousMotor : DTDFVocab:Component [
    base:desc "Permanent magnet synchronous motor driving the first axis of MABI MAX 100 industrial robot."
    base:isContainedIn RobotAxisComponent
]

instance Gearbox : DTDFVocab:Component [
    base:desc "Mechanical gearbox component of MABI MAX 100 robot axis."
    base:isContainedIn RobotAxisComponent
]

instance SiemensSINUMERIK840DslController : DTDFVocab:Component [
    base:desc "Industrial robot controller (Siemens SINUMERIK 840D sl) interfacing with physical twin."
    base:isContainedIn RobotAxisComponent
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system leverages real-time data streaming via **MQTT** for synchronization between the physical and digital components, implying low-latency, event-driven updates. The temporal granularity is determined by the frequency of sensor data acquisition, which is streamed continuously to maintain an up-to-date digital representation. While the document does not specify exact synchronization frequencies or latency requirements, the use of MQTT suggests a **real-time or near-real-time** operational paradigm, where data is pushed asynchronously to the Digital Twin for immediate processing. The system's temporal aspects are inherently tied to the **data-driven, real-time** nature of the Digital Twin, ensuring alignment between the physical and digital states through continuous data flow."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellation in this context is orchestrated through **Model-Based Systems Engineering (MBSE)** methodologies, leveraging **architecture description languages (ADLs)** such as **ACME, AADL, MontiArc, or SysML Internal Block Diagrams (IBDs)** to define component-based structures, interfaces, and interconnections. The system employs **component & connector perspectives** to model interactions, with some ADLs (e.g., MontiArc Automaton or SysML state machines) extending to behavioral descriptions. Integration of heterogeneous tools (e.g., **MathWorks Simulink, simulation tools, or general-purpose languages like C++/Java**) is required to manage complexity across **requirements, functional, logical, and product/technical layers**. The constellation lacks explicit details on resource management or system-wide coordination mechanisms but implies a **modular, hierarchical architecture** where active components (e.g., Digital Twin services) process data traces from digital shadows (passive entities)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **validation and verification processes** to ensure model fidelity, primarily through **comparative analysis of simulated data against measured data** to quantify deviations and uncertainties. The **sensor arrangement** (e.g., position encoders) is designed to **reduce backlash and positional uncertainty**, indirectly contributing to data accuracy. However, the document does not specify formal verification methods (e.g., model checking, theorem proving), explicit uncertainty quantification frameworks, or structured quality assurance processes (e.g., ISO/IEC standards, traceability matrices). Error detection mechanisms are implied through data-driven validation but lack detailed correction protocols or automated feedback loops. The system’s reliance on **MBSE methodologies** (e.g., RFLP, OOSEM) suggests layered validation but does not provide granularity on fidelity metrics or error propagation studies."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for the Digital Shadow system leverages the **MQTT protocol** for streaming sensor data from physical assets to the digital representation. While the document does not specify **network topology**, **bandwidth requirements**, or **latency constraints**, the use of MQTT implies support for **low-power, intermittent connectivity** environments typical in industrial IoT deployments. No details are provided regarding **reliability mechanisms** (e.g., redundancy, failover), **security protocols** (e.g., TLS, authentication), or **network architecture** (e.g., star, mesh). The infrastructure is designed to handle **time-series data** with minimal overhead, but no explicit **data routing** or **protocol extensions** are mentioned."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with **external data sources** through **MQTT-based streaming protocols**, enabling real-time exchange of **sensor time-series data** from the physical system. While the document does not explicitly mention **interoperability standards** (e.g., OPC UA, REST APIs) or **enterprise system dependencies**, the use of MQTT implies adherence to **lightweight, publish-subscribe communication** for data exchange. Integration patterns are **data-centric**, focusing on **asynchronous, event-driven** updates rather than synchronous or transactional interactions. No details are provided on **cross-Digital Twin coordination** or **enterprise-level integration**, but the system is designed to **consume and process external data streams** dynamically."
]