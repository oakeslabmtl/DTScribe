// Sensing component
instance ContextDataCollector : DTDFVocab:SensingComponent [
    base:desc "Collects aggregated contextual data traces as specified in the digital shadow reference model, embodying virtual‑to‑physical interaction."
    DTDFVocab:producedData ContextDataTransmitted
]

// Data transmitted
instance ContextDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContextDataCollector
]

// Data
instance AggregatedContextualData : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces collected and abstracted for simulation purposes."
    DTDFVocab:fromData ContextDataTransmitted
    DTDFVocab:inputTo ContextDataProcessingEnabler
]

// Enabler
instance ContextDataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processes aggregated contextual data using C++ or Java implementations, enabling subsequent simulation and execution services."
    DTDFVocab:enables SimulationService, ExecutionService
]

// Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates the Digital Twin models using MathWorks Simulink, providing simulation insights."
    DTDFVocab:provides SimulationInsight
]

instance ExecutionService : DTDFVocab:Service [
    base:desc "Executes the Digital Twin models in C++ or Java, providing execution insights."
    DTDFVocab:provides ExecutionInsight
]

// Models
instance FunctionalLayerModel : DTDFVocab:Model [
    base:desc "Functional layer model defined via Model-Based Systems Engineering using SysML component‑connector architecture."
    DTDFVocab:inputTo ContextDataProcessingEnabler
]

instance LogicalLayerModel : DTDFVocab:Model [
    base:desc "Logical layer model defined via Model-Based Systems Engineering using SysML component‑connector architecture."
    DTDFVocab:inputTo ContextDataProcessingEnabler
]

instance ProductTechnicalLayerModel : DTDFVocab:Model [
    base:desc "Product/Technical layer model defined via Model-Based Systems Engineering using SysML component‑connector architecture."
    DTDFVocab:inputTo ContextDataProcessingEnabler
]

// Insights
instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from Simulink simulation of the Digital Twin models across functional, logical, and product/technical layers."
]

instance ExecutionInsight : DTDFVocab:Insight [
    base:desc "Insight derived from execution of the Digital Twin models in C++ or Java."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system leverages MQTT as the primary messaging protocol, implemented via the Mosquitto broker (see [52]). Mosquitto supports secure authentication through username/password credentials and optional client certificates, and enforces strict Access Control Lists (ACLs) at the topic level to restrict publish/subscribe rights. Transport security is achieved using TLS v1.2/v1.3, permitting both server‑side and mutual client‑server TLS authentication, and the broker optionally supports SASL mechanisms (PLAIN, EXTERNAL) to further strengthen the authentication channel. In addition, the system integrates the ThingsBoard 4.0.0 open‑source IoT platform (see [53]), which provides comprehensive security and safety controls: JWT‑based authentication for cloud services, OAuth2 and LDAP integration for enterprise single‑sign‑on, role‑based access control (admin, tenant, customer, gateway) that scopes permissions to specific device groups and dashboards, TLS 1.2+ over HTTPS for all HTTP endpoints and MQTT transport, per‑device client certificates or shared access keys, and detailed audit logs for all connection events, message deliveries, and configuration changes. ThingsBoard also implements fail‑safe mechanisms such as automatic reconnect, message persistence, and keep‑alive timeouts, ensuring reliable operation even under network disruptions. The combination of broker‑level ACLs, TLS encryption, and platform‑level RBAC and audit logging forms a layered security posture that mitigates unauthorized access, data tampering, and eavesdropping, while supporting safety‑critical requirements through deterministic message handling and controlled device access."
]