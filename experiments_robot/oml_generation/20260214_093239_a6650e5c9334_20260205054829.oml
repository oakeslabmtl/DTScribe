// C3: Physical sensing components
instance JointTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Measures the torque at the robot joint for residual analysis against simulated behaviour."
    DTDFVocab:producedData JointTorqueDataT
]

instance MaintenanceLogFeedSensor : DTDFVocab:SensingComponent [
    base:desc "Feeds maintenance logs such as bearing replacement history for trend analysis."
    DTDFVocab:producedData MaintenanceLogDataT
]

instance PerformanceMetricFeedSensor : DTDFVocab:SensingComponent [
    base:desc "Collects performance metrics including joint speed, temperature and energy consumption."
    DTDFVocab:producedData PerformanceMetricDataT
]

// C4: Physical‑to‑virtual interaction
instance JointTorqueDataT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointTorqueSensor
]

instance MaintenanceLogDataT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MaintenanceLogFeedSensor
]

instance PerformanceMetricDataT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PerformanceMetricFeedSensor
]

// C10: Models/Data
instance JointTorqueData : DTDFVocab:Data [
    base:desc "Time‑stamped joint torque measurements used for residual analysis."
    DTDFVocab:fromData JointTorqueDataT
    DTDFVocab:inputTo SimulinkEnabler
]

instance MaintenanceLogData : DTDFVocab:Data [
    base:desc "Maintenance log entries recording component replacements and service dates."
    DTDFVocab:fromData MaintenanceLogDataT
    DTDFVocab:inputTo SimulinkEnabler
]

instance PerformanceMetricData : DTDFVocab:Data [
    base:desc "Metrics describing joint performance such as speed, temperature, and energy usage."
    DTDFVocab:fromData PerformanceMetricDataT
    DTDFVocab:inputTo SimulinkEnabler
]

instance FrictionSimulationModel : DTDFVocab:Model [
    base:desc "Joint‑friction simulation model combining MontiArc Automaton state logic and Simulink continuous dynamics."
    DTDFVocab:inputTo SimulinkEnabler
]

// C11: Enablers
instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "Integrates MathWorks Simulink with MontiArc Automaton to run real‑time simulation of robot joint dynamics."
    DTDFVocab:enables FrictionDetectionService
]

// C6: Services
instance FrictionDetectionService : DTDFVocab:Service [
    base:desc "Detects friction in robot joint by comparing measured torques to simulated nominal behaviour using residual analysis."
    DTDFVocab:provides FrictionDetectionInsight, AdjustControllerGainAction, ReplaceBearingAction
]

// C17: Insights
instance FrictionDetectionInsight : DTDFVocab:Insight [
    base:desc "Residual analysis indicates increased friction in joint; confidence level is 92 % based on measurement uncertainty."
]

// C17: Actions
instance AdjustControllerGainAction : DTDFVocab:Action [
    base:desc "Recommend adjusting joint controller gains to compensate for detected friction."
    DTDFVocab:IsAutomatic false
]

instance ReplaceBearingAction : DTDFVocab:Action [
    base:desc "Recommend replacing worn bearings as part of scheduled maintenance."
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is described using Model‑Based Systems Engineering (MBSE) techniques, leveraging SysML for system architecture and behavioral modeling, and architecture description languages such as ACME, AADL, MontiArc and SysML IBDs for component‑connector representations. These models are integrated with simulation environments (e.g., MathWorks Simulink) and code generation to C++ or Java, thereby providing an orchestrated architecture that coordinates component interactions, manages resources, and controls system‑wide behavior through a hierarchical decomposition of functional, logical and product/technical layers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The development of a Digital Twin is described as proceeding through successive abstraction levels: requirements, functional architecture, logical architecture, and product/technical layers. Transitions between these stages are managed by model‑based systems engineering (MBSE) methods such as RFLP, OOSEM, SPES, or SMArDT, with consistency ensured by the use of architecture description languages (ADLs) and detailed behaviour models."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Standardisation is exemplified by the adoption of widely recognized modelling languages and architecture description languages. The document cites SysML (ISO/IEC‑standardised for system modelling), ACME, AADL, MontiArc, and SysML IBDs, as well as state‑machine models in SysML v1.7, indicating adherence to established industry standards for system description and behavioural modelling."
]