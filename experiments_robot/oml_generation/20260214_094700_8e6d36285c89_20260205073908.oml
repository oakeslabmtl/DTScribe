// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor providing input current data for the permanent‑magnet synchronous motor."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder on motor shaft measuring motor angular position."
    DTDFVocab:producedData MotorEncoderAngleDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder on gearbox output shaft measuring gearbox angular position."
    DTDFVocab:producedData GearboxEncoderAngleDataTransmitted
]

// C4: Physical‑to‑virtual interaction
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// C10: Models/Data – derived data
instance MotorTorqueData : DTDFVocab:Data [
    base:desc "Derived motor torque computed from current and encoder readings."
    DTDFVocab:inputTo FrictionModelProcessingEnabler
    DTDFVocab:fromData MotorCurrentDataTransmitted
]

instance MotorVelocityData : DTDFVocab:Data [
    base:desc "Derived motor angular velocity computed from encoder data."
    DTDFVocab:inputTo FrictionModelProcessingEnabler
    DTDFVocab:fromData MotorEncoderAngleDataTransmitted
]

instance MotorAccelerationData : DTDFVocab:Data [
    base:desc "Derived motor angular acceleration computed from encoder data."
    DTDFVocab:inputTo FrictionModelProcessingEnabler
    DTDFVocab:fromData MotorEncoderAngleDataTransmitted
]

// C10: Models/Data – data traces
instance CurrentDataTrace : DTDFVocab:Data [
    base:desc "Continuous stream of motor current values with timestamps, transmitted via MQTT."
    DTDFVocab:inputTo FrictionModelProcessingEnabler
    DTDFVocab:fromData MotorCurrentDataTransmitted
]

instance EncoderAngleDataTrace : DTDFVocab:Data [
    base:desc "Continuous stream of motor encoder angles with timestamps, transmitted via MQTT."
    DTDFVocab:inputTo FrictionModelProcessingEnabler
    DTDFVocab:fromData MotorEncoderAngleDataTransmitted
]

instance GearboxAngleDataTrace : DTDFVocab:Data [
    base:desc "Continuous stream of gearbox encoder angles with timestamps, transmitted via MQTT."
    DTDFVocab:inputTo FrictionModelProcessingEnabler
    DTDFVocab:fromData GearboxEncoderAngleDataTransmitted
]

instance FrictionModelParametersData : DTDFVocab:Data [
    base:desc "Updated friction model parameters derived from continuous multi‑physics identification."
    DTDFVocab:inputTo AASEnabler
]

// C9: Models
instance MotorStructuralModel : DTDFVocab:Model [
    base:desc "SysML structural model of the motor."
    DTDFVocab:inputTo SysMLToolEnabler
]

instance DualGearboxStructuralModel : DTDFVocab:Model [
    base:desc "SysML structural model of dual gearboxes."
    DTDFVocab:inputTo SysMLToolEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink kinematic simulation model."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink Coulomb‑Viscous friction model."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink Stribeck friction model."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink Dahl friction model."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink LuGre friction model."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

// C11: Enablers
instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard tool enabler providing real‑time visualisation of data."
    DTDFVocab:enables RealTimeDataVisualizationService
]

instance FrictionModelProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing component linking sensor data and simulation models to produce higher‑level abstractions."
    DTDFVocab:enables MultiPhysicsFrictionIdentificationService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell enabler linking asset configuration and data."
    DTDFVocab:enables FrictionModelParameterProvisionService
]

instance SysMLToolEnabler : DTDFVocab:Enabler [
    base:desc "SysML tool enabling structural and system architecture modelling."
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink tool enabling simulation of kinematic and friction models."
    DTDFVocab:enables MultiPhysicsFrictionIdentificationService
]

instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol enabler for telemetry of sensor data."
]

// C6: Services
instance RealTimeDataVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time data visualization in a unified dashboard."
    DTDFVocab:provides MotionAccuracyInsight, ToolWearMonitoringInsight, MaintenancePlanningInsight
]

instance MultiPhysicsFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous multi‑physics friction identification using white‑box and black‑box models."
    DTDFVocab:provides JointFrictionCharacteristicsInsight
]

instance FrictionModelParameterProvisionService : DTDFVocab:Service [
    base:desc "Provision of updated friction model parameters for robot control and maintenance planning."
    DTDFVocab:provides UpdateRobotControlAction, MaintenancePlanningAction
]

// C17: Insights/Actions
instance MotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Improved motion accuracy due to updated friction model parameters."
]

instance ToolWearMonitoringInsight : DTDFVocab:Insight [
    base:desc "Tool wear monitoring enabled by friction analysis results."
]

instance MaintenancePlanningInsight : DTDFVocab:Insight [
    base:desc "Maintenance planning informed by updated friction model validation results."
]

instance JointFrictionCharacteristicsInsight : DTDFVocab:Insight [
    base:desc "Enhanced understanding of joint‑friction characteristics achieved through multi‑physics identification."
]

instance UpdateRobotControlAction : DTDFVocab:Action [
    base:desc "Update robot control parameters with derived friction model parameters."
    DTDFVocab:IsAutomatic true
]

instance MaintenancePlanningAction : DTDFVocab:Action [
    base:desc "Plan maintenance activities based on friction model validation."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time streaming of sensor data and simulation runs; digital shadow maintained in real‑time synchronized with PT operation (no explicit sampling interval given)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow consists of the asset model, live data sources, processing components that compute simulation and friction models, and a dashboard that aggregates and visualizes the resulting data traces; all components are connected via MQTT and AAS interfaces."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "DT covers the operated phase of the physical robot; it uses design‑time engineering and behaviour models but is actively used during live operation to identify and update friction dynamics."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Four‑way traceability of data points to source measurements and model computations; simultaneous use of analytical white‑box friction models and data‑driven black‑box models to validate against live measurements; multi‑physics awareness and continuous re‑identification mitigates drift due to wear or temperature; uncertainty analysis not explicitly quantified in the paper."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data transmitted via MQTT; data traces are identified by their sources and processed by the processing component; Asset Administration Shells provide semantic metadata for data exchange."
]