]

instance CNCMachineToolpathSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing CNC machine toolpath data including operational logs and performance metrics for manufacturing process analysis."
    DTDFVocab:producedData CNCToolpathDataTransmitted
]

instance EnvironmentalConditionSensor : DTDFVocab:SensingComponent [
    base:desc "Multi-parameter sensor measuring temperature, humidity, and ambient conditions affecting manufacturing processes."
    DTDFVocab:producedData EnvironmentalConditionDataTransmitted
]

