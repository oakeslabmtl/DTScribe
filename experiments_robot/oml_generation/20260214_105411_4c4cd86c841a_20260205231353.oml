    DTDFVocab:producedFrom InjectionMoldingPressureSensor
]

instance CNCToolpathDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CNCMachineToolpathSensor
]

instance EnvironmentalConditionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalConditionSensor
]

// C10: Models/Data
instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "UML class diagram-based reference model standardizing data trace aggregation for purpose-driven digital twin enrichment as per Kritzinger et al."
    DTDFVocab:inputTo DigitalShadowAggregationPipeline
]

instance PhysicsBasedDynamicModel : DTDFVocab:Model [
    base:desc "Simulink-based white-box model implementing analytical formulations of physical phenomena for interpretable system behavior prediction."
    DTDFVocab:inputTo SimulationEngine
]

