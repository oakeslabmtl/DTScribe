    base:desc "High-resolution encoder capturing robot joint positions and velocities for dynamic state estimation, supporting scalable identification methods as per Sorrentino et al."
    DTDFVocab:producedData RobotStateDataTransmitted
]

instance RobotForceTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Force/torque sensor measuring nonlinear friction phenomena in industrial robotics, providing high-precision dynamic behavior data for model validation."
