]

instance ProcessingComponents : DTDFVocab:Enabler [
    base:desc "Data processing models embedded in Digital Shadow"
    DTDFVocab:enables LowPassFilterComponent, DataAggregationComponent, FrictionModelProcessing, ModelUpdateProcessor
]

instance MBSEToolchains : DTDFVocab:Enabler [
    base:desc "Toolchains for cross-model integration"
    DTDFVocab:enables PhysicsBasedFrictionModel, DataDrivenFrictionModel
]

instance MultiViewModeling : DTDFVocab:Enabler [
    base:desc "Multi-view modeling for engineering, operational, and data-driven perspectives"
    DTDFVocab:enables ReferenceModelConcretization
]

// C12: Data
instance MotorEncoderTrace : DTDFVocab:Data [
    base:desc "High-resolution angular velocity and position feedback from motor encoder"
    DTDFVocab:fromData MotorEncoderTrace
    DTDFVocab:inputTo FrictionModelProcessing
]

instance GearboxEncoderTrace : DTDFVocab:Data [
    base:desc "High-resolution position feedback from gearbox encoder"
    DTDFVocab:fromData GearboxEncoderTrace
    DTDFVocab:inputTo FrictionModelProcessing
]

