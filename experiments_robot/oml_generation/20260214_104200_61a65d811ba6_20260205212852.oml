// C2: Acting Components
instance MABIMAX100RobotDriveSystem : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motors with cycloidal gearboxes for precise motion control in MABI MAX 100 industrial robot, integrated with Siemens SINUMERIK 840D sl control system for real-time friction compensation"
]

instance CycloidalGearbox : DTDFVocab:Actuator [
    base:desc "High-precision cycloidal gearbox paired with motors for torque amplification in MABI MAX 100 robot joints, enabling precise motion control under varying loads"
]

instance SINUMERIK840DSLController : DTDFVocab:Actuator [
    base:desc "Siemens SINUMERIK 840D sl control system implementing real-time friction compensation strategies for MABI MAX 100 robot's closed-loop motion control"
]

// C3: Physical sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Directly mounted encoder on permanent magnet synchronous motors providing high-resolution angular velocity and position feedback for friction analysis"
    DTDFVocab:producedData MotorEncoderTrace
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder mounted behind cycloidal gearbox for high-resolution position feedback with spatial redundancy for friction compensation"
    DTDFVocab:producedData GearboxEncoderTrace
]

instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring raw electrical input current from motor windings, processed with low-pass filtering for noise removal before MQTT transmission"
    DTDFVocab:producedData RawMotorCurrentData
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Motor-mounted encoder providing real-time angular velocity measurements for friction dynamics analysis"
    DTDFVocab:producedData AngularVelocityTrace
]

instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "High-resolution position sensor tracking first axis movement for precision machining applications"
    DTDFVocab:producedData PositionTrace
]

// C4: Physical-to-virtual interaction
instance MotorEncoderTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
    DTDFVocab:formattedAs JSON
    DTDFVocab:transmittedVia MQTT
]

instance GearboxEncoderTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
    DTDFVocab:formattedAs JSON
    DTDFVocab:transmittedVia MQTT
]

instance RawMotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
    DTDFVocab:formattedAs JSON
    DTDFVocab:transmittedVia MQTT
]

instance AngularVelocityTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
    DTDFVocab:formattedAs JSON
    DTDFVocab:transmittedVia MQTT
]

instance PositionTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
    DTDFVocab:formattedAs JSON
    DTDFVocab:transmittedVia MQTT
]

instance FilteredCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
    DTDFVocab:processedWith LowPassFilterComponent
    DTDFVocab:formattedAs JSON
    DTDFVocab:transmittedVia MQTT
]

// C5: Data processing components
instance LowPassFilterComponent : DTDFVocab:ProcessingComponent [
    base:desc "Real-time low-pass filter applied to input current signals to remove noise before MQTT transmission"
]

instance DataAggregationComponent : DTDFVocab:ProcessingComponent [
    base:desc "Component aggregating raw sensor data traces into structured JSON messages for MQTT transmission"
]

instance FrictionModelProcessing : DTDFVocab:ProcessingComponent [
    base:desc "Computational component performing real-time friction identification using both white-box and black-box models"
]

instance ModelUpdateProcessor : DTDFVocab:ProcessingComponent [
    base:desc "Component handling on-the-fly model updates including neural network retraining and parameter recalibration"
]

// C6: Services
instance RealTimeFrictionIdentification : DTDFVocab:Service [
    base:desc "Continuous multi-physics-aware monitoring of joint friction using both white-box and black-box models"
    DTDFVocab:provides FrictionBehaviorInsight, ControlAccuracyImprovement
]

instance LiveDataLink : DTDFVocab:Service [
    base:desc "Seamless integration of real-time sensor data streams with computational models"
    DTDFVocab:provides DataAggregationComponent
]

instance InteractiveFrictionVisualization : DTDFVocab:Service [
    base:desc "Interactive dashboard showing friction behavior and model accuracy metrics"
    DTDFVocab:provides FrictionBehaviorInsight, ProcessAnomalyInsight, ModelAccuracyMetrics
]

instance PredictiveFaultDetection : DTDFVocab:Service [
    base:desc "Early fault detection via anomaly analysis in friction data"
    DTDFVocab:provides PredictiveMaintenanceAction
]

instance MachiningParameterOptimization : DTDFVocab:Service [
    base:desc "Simulative optimization of machining parameters using physics-based simulations"
    DTDFVocab:provides ParameterOptimizationAction
]

// C10: Models/Data
instance PhysicsBasedFrictionModel : DTDFVocab:Model [
    base:desc "White-box physics-based friction model implemented in Simulink"
    DTDFVocab:inputTo SimulationEngines
]

instance DataDrivenFrictionModel : DTDFVocab:Model [
    base:desc "Black-box data-driven friction model using machine learning techniques"
    DTDFVocab:inputTo SimulationEngines
]

instance FrictionCompensationSimulator : DTDFVocab:Model [
    base:desc "Simulation model implementing real-time friction compensation strategies"
    DTDFVocab:inputTo SimulationEngines
]

instance MotionAccuracySimulation : DTDFVocab:Model [
    base:desc "Physics-based simulation evaluating motion accuracy improvements"
    DTDFVocab:inputTo DiscreteEventSimulation
]

instance DataTraceAggregationModel : DTDFVocab:Model [
    base:desc "Model structuring data traces through processing components"
    DTDFVocab:inputTo ArchitectureDescriptionLanguages
]

instance ReferenceModelConcretization : DTDFVocab:Model [
    base:desc "Concretization of reference model for specific use cases"
    DTDFVocab:inputTo ArchitectureDescriptionLanguages
]

