instance ModelBasedSystemsEngineering : DTDFVocab:Enabler [
    base:desc "MBSE methodology framework using SysML for requirements and architecture modeling"
    DTDFVocab:enables PhysicsBasedFrictionModel, DataDrivenFrictionModel, MotionAccuracySimulation
]

instance ArchitectureDescriptionLanguages : DTDFVocab:Enabler [
    base:desc "ADLs for modeling components and interconnections"
    DTDFVocab:enables DataTraceAggregationModel, ReferenceModelConcretization
]

instance DigitalShadowReferenceModel : DTDFVocab:Enabler [
    base:desc "UML-based reference model structuring data traces and processing components"
    DTDFVocab:enables DataTraceAggregationModel
]

instance SimulationEngines : DTDFVocab:Enabler [
    base:desc "MathWorks MATLAB Simulink for simulation models"
    DTDFVocab:enables PhysicsBasedFrictionModel, DataDrivenFrictionModel, FrictionCompensationSimulator
]

instance DiscreteEventSimulation : DTDFVocab:Enabler [
    base:desc "DEVS frameworks for complex event-driven manufacturing processes"
