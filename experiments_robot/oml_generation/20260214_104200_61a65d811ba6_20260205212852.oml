instance ManufacturingProcessEnvironment : DTDFVocab:Environment [
    base:contains PhysicsBasedFrictionModel, DataDrivenFrictionModel, FrictionCompensationSimulator,
        MotionAccuracySimulation, DataTraceAggregationModel, ReferenceModelConcretization,
