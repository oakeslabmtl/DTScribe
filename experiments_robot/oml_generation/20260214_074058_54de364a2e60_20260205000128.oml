// C3: Physical sensing components
instance PhysicalObjectTraceGenerator : DTDFVocab:SensingComponent [
    base:desc "Physical object that automatically generates contextual data traces as part of the digital‑shadow one‑way data flow."
    DTDFVocab:producedData ContextualDataTrace
]

// C4: Physical-to-virtual interaction
instance ContextualDataTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalObjectTraceGenerator
]

// C10: Models/Data
instance AggregatedContextualData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces organized for a specific purpose as defined in the digital‑shadow reference model."
    DTDFVocab:fromData ContextualDataTrace
    DTDFVocab:inputTo SysMLToolchain, ADLToolchain, SimulinkEngine
]

instance MBSEDigitalTwinModel : DTDFVocab:Model [
    base:desc "Digital Twin model constructed using MBSE techniques (SysML internal block diagrams, state machines, v1.7 extensions) and ADLs (ACME, AADL, MontiArc) to capture system structure and behavior."
    DTDFVocab:inputTo SysMLToolchain, ADLToolchain
]

// C11: Enablers
instance SysMLToolchain : DTDFVocab:Enabler [
    base:desc "SysML modeling environment supporting internal block diagrams, state machines, and extensions for MBSE."
    DTDFVocab:enables ModelExecutionService
]

instance ADLToolchain : DTDFVocab:Enabler [
    base:desc "Architecture description language toolchain (ACME, AADL, MontiArc) for functional and logical architecture definition."
    DTDFVocab:enables ModelExecutionService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation engine used for behavioral analysis of the Digital Twin."
    DTDFVocab:enables SimulationService
]

// C6: Services
instance ModelExecutionService : DTDFVocab:Service [
    base:desc "Executes MBSE models and coordinates simulation runs."
    DTDFVocab:provides ContextualTraceAggregationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs dynamic simulations of the Digital Twin model."
    DTDFVocab:provides UpdateDigitalTwinAction
]

// C17: Insights/Actions
instance ContextualTraceAggregationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from aggregated contextual data traces, enabling informed decision making."
]

instance UpdateDigitalTwinAction : DTDFVocab:Action [
    base:desc "Updates the digital representation based on simulation results."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "A digital twin extends the digital shadow by providing active components capable of sending control information back to the physical system. According to the paper, the twin can generate commands or control messages that are interpreted by the physical asset, but the documents do not detail command formats, validation, authentication, feedback loops, conflict resolution or execution acknowledgements."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin operates on a real‑time, data‑driven basis, continuously linking live sensor data from the physical system to its digital counterpart. Incoming measurements are captured as time‑series traces at the native sampling rate of each sensor, enabling live‑data linking and near‑zero latency updates. Synchronization between physical and digital components is therefore performed continuously, with temporal granularity determined by the sensor sampling interval and without explicit fixed frequency values provided in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system architecture follows the Digital Shadow Reference Model (DSRM), which defines four core elements—Asset, Source, Model, and Processing. A concrete realization (concretization) maps these abstract concepts to concrete classes and associations, establishing a layered pipeline where the Asset provides raw data traces, the Source records and aggregates them, the Model encapsulates engineering, simulation, or data‑calculation models, and the Processing component consumes input traces, executes the models, and produces derived output traces. Traceability is maintained through 'originates‑from' associations, enabling transitive provenance tracking. This composition orchestrates the overall Digital Twin, integrating heterogeneous modelling notations (e.g., SysML, simulation tools) and managing resources via the processing pipeline."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the Model‑Based Systems‑Engineering (MBSE) abstraction hierarchy described in the document: (1) Requirements stage – capture and formalise stakeholder requirements; (2) Functional architecture stage – model functional decomposition using SysML internal block diagrams (IBDs) and architecture description languages (ADLs); (3) Logical architecture stage – specify component‑connector structures with ADLs such as ACME, AADL or MontiArc, including interface definitions; (4) Product/technical stage – map logical components to concrete implementation artifacts such as Simulink simulation models or source code in C++/Java. Transitions between these stages are managed by MBSE traceability mechanisms, ensuring that each representation (requirements, functional, logical, technical) is linked and governed throughout the Twin’s life‑cycle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical sensor data is streamed to the digital shadow via the MQTT protocol, using a Mosquitto server as the broker. The documents do not provide further details on network topology, bandwidth, latency, redundancy, or additional security mechanisms."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on the SysML modelling language (an OMG standard) and on UML class diagrams for the digital‑shadow reference model. Architecture description languages (ACME, AADL, MontiArc) are employed to capture component‑connector structures, following industry‑accepted ADL conventions. No additional certification, compliance frameworks, or interoperability standards are explicitly mentioned in the provided text."
]