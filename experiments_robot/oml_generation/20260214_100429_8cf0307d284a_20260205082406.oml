// C3: Physical sensing components
instance OperationalLogCollector : DTDFVocab:SensingComponent [
    base:desc "Collects operational logs from the physical system for contextual data traces"
    DTDFVocab:producedData OperationalLogDataTransmitted
]

instance SensorNetwork : DTDFVocab:SensingComponent [
    base:desc "Deploys IoT devices and sensor networks to capture real-time environmental and operational parameters"
    DTDFVocab:producedData SensorDataTransmitted
]

instance ManufacturingProcessLogger : DTDFVocab:SensingComponent [
    base:desc "Records discrete event logs from manufacturing processes for Digital Shadow integration"
    DTDFVocab:producedData ManufacturingEventDataTransmitted
]

// C4: Physical-to-virtual interaction
instance OperationalLogDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalLogCollector
    base:desc "Transmits structured operational logs via event-triggered mechanisms for Digital Shadow aggregation"
]

instance SensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SensorNetwork
    base:desc "Transmits time-series sensor data (e.g., temperature, pressure) via periodic or event-triggered protocols"
]

instance ManufacturingEventDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ManufacturingProcessLogger
    base:desc "Transmits discrete manufacturing event logs for process monitoring and analysis"
]

// C10: Models/Data
instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "Defines the UML class diagram structure for Digital Shadow data traces, including aggregation and abstraction layers"
    DTDFVocab:inputTo SysMLModelingEnabler, DigitalShadowDataStorage
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model capturing discrete-event behavior for system components"
    DTDFVocab:inputTo SysMLModelingEnabler, SimulationIntegrationEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model for component-connector behavioral modeling with state transitions"
    DTDFVocab:inputTo MontiArcEnabler, SimulationIntegrationEnabler
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL model defining safety-critical component interfaces, deployment, and resource allocation"
    DTDFVocab:inputTo AADLEngineeringEnabler, SimulationIntegrationEnabler
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for continuous-time dynamic system simulation and control design"
    DTDFVocab:inputTo SimulinkEnabler, SimulationIntegrationEnabler
]

instance OperationalData : DTDFVocab:Data [
    base:desc "Aggregated operational data traces from Digital Shadow, preprocessed for quality assurance"
    DTDFVocab:fromData OperationalLogDataTransmitted, SensorDataTransmitted, ManufacturingEventDataTransmitted
    DTDFVocab:inputTo DigitalShadowDataStorage, ActiveDataProcessingEnabler
]

instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Results from simulation engines (Simulink, etc.) including predicted system states and anomalies"
    DTDFVocab:fromData SimulinkDynamicModel
    DTDFVocab:inputTo SimulationIntegrationEnabler, OptimizationService
]

instance HistoricalData : DTDFVocab:Data [
    base:desc "Long-term stored data traces for trend analysis and maintenance forecasting"
    DTDFVocab:fromData OperationalLogDataTransmitted
    DTDFVocab:inputTo DigitalShadowDataStorage, MachineLearningEnabler
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7+ for requirements, architecture, and behavioral modeling (state machines, IBDs)"
    DTDFVocab:enables DataInterpretationService, MonitoringService, VisualizationService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc for component-connector architectures and automaton-based behavioral modeling"
    DTDFVocab:enables PredictionService, ControlService
]

instance AADLEngineeringEnabler : DTDFVocab:Enabler [
    base:desc "AADL for safety-critical system architecture with component interfaces and deployment"
    DTDFVocab:enables MonitoringService, OptimizationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for dynamic system simulation, control design, and co-simulation"
    DTDFVocab:enables PredictionService, ControlService, OptimizationService
]

instance DigitalShadowDataStorage : DTDFVocab:Enabler [
    base:desc "Time-series database (e.g., InfluxDB) storing aggregated Digital Shadow data traces"
    DTDFVocab:enables MonitoringService
]

instance ActiveDataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Active software components for real-time data interpretation and processing"
    DTDFVocab:enables DataInterpretationService, PredictionService, OptimizationService
]

instance SimulationIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Integration layer for bridging heterogeneous simulation tools (Simulink, MATLAB, etc.)"
    DTDFVocab:enables PredictionService, ControlService
]

instance MachineLearningEnabler : DTDFVocab:Enabler [
    base:desc "Machine learning modules for predictive maintenance and anomaly detection"
    DTDFVocab:enables PredictionService, MaintenanceOptimizationService
]

instance ToolInteroperabilityEnabler : DTDFVocab:Enabler [
    base:desc "Mechanisms (XMI, FMI, APIs) for bridging SysML, Simulink, C++, and Java ecosystems"
    DTDFVocab:enables DataInterpretationService, VisualizationService
]

// C6: Services
instance DataInterpretationService : DTDFVocab:Service [
    base:desc "Active software components interpreting incoming Digital Shadow data (contextual traces, sensor feeds) for real-time analysis"
    DTDFVocab:provides RealTimeDataInsight, DataQualityAssessmentAction
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous state monitoring leveraging aggregated Digital Shadow data with ADL-based component models"
    DTDFVocab:provides SystemHealthInsight, AnomalyDetectionInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Simulation-based prediction of system behavior using MathWorks Simulink and behavioral models"
    DTDFVocab:provides BehaviorForecastInsight, MaintenanceForecastInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Analysis of data traces and simulation outputs to suggest system configuration improvements"
    DTDFVocab:provides ConfigurationOptimizationInsight, ResourceAllocationInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Closed-loop control capabilities adjusting physical system parameters based on digital insights"
    DTDFVocab:provides ParameterAdjustmentAction, ClosedLoopControlInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Presentation of system states, data trends, and simulation results using SysML/ADL models"
    DTDFVocab:provides SystemStateVisualizationInsight, TrendAnalysisVisualizationInsight
]

instance MaintenanceOptimizationService : DTDFVocab:Service [
    base:desc "Proactive maintenance suggestions leveraging simulation and optimization outputs"
    DTDFVocab:provides MaintenanceScheduleInsight, InterventionRecommendationAction
]

// C17: Insights/Actions
instance RealTimeDataInsight : DTDFVocab:Insight [
    base:desc "Contextual interpretation of incoming Digital Shadow data with near-real-time processing"
]

instance DataQualityAssessmentAction : DTDFVocab:Action [
    base:desc "Automated validation and normalization of incoming data traces"
    DTDFVocab:IsAutomatic true
]

instance SystemHealthInsight : DTDFVocab:Insight [
    base:desc "Continuous assessment of system health using aggregated Digital Shadow data"
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of system anomalies through pattern recognition in operational data"
]

instance BehaviorForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted system behavior based on simulation models and current operational state"
]

instance MaintenanceForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasted maintenance requirements derived from predictive simulation outputs"
]

instance ConfigurationOptimizationInsight : DTDFVocab:Insight [
    base:desc "Suggested improvements to system configuration based on optimization analysis"
]

instance ResourceAllocationInsight : DTDFVocab:Insight [
    base:desc "Optimized resource allocation recommendations derived from simulation data"
]

instance ParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated adjustment of physical system parameters based on digital insights"
    DTDFVocab:IsAutomatic true
]

instance ClosedLoopControlInsight : DTDFVocab:Insight [
    base:desc "Real-time feedback loop between digital twin and physical system for adaptive control"
]

instance SystemStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive visualization of current system state using SysML/ADL models"
]

instance TrendAnalysisVisualizationInsight : DTDFVocab:Insight [
    base:desc "Presentation of historical data trends and predictive forecasts"
]

instance MaintenanceScheduleInsight : DTDFVocab:Insight [
    base:desc "Proactive maintenance scheduling based on predictive analytics"
]

instance InterventionRecommendationAction : DTDFVocab:Action [
    base:desc "Automated recommendations for corrective interventions"
    DTDFVocab:IsAutomatic false
]

instance HistoricalAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analysis of historical data trends for long-term system behavior understanding"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin constellation** is orchestrated through **MBSE methodologies** (e.g., RFLP, OOSEM) and **architecture description languages (ADLs)** like ACME, AADL, or MontiArc, which define **component integration** via interfaces, connectors, and composition rules. The system employs **multi-tool integration** (e.g., SysML for architecture, Simulink/MathWorks for behavior simulation, or general-purpose languages like C++/Java for implementation), necessitating **resource management** across heterogeneous tools. **System-wide coordination** is implied by the use of **state machines (SysML v1.7)** or **MontiArc Automaton** to model behavior, ensuring synchronization between digital and physical layers. The **architecture pattern** leans toward **modularity and abstraction**, with potential decentralization (e.g., multiple twins per abstraction layer) or centralization (e.g., a unified digital shadow model). No explicit orchestration framework (e.g., microservices, service-oriented architecture) is mentioned, but the **component-based approach** suggests plug-and-play integration of services."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **fidelity requirements** aligned with the **Digital Shadow Reference Model**, where data traces from physical objects are aggregated and abstracted for specific purposes. **Validation and verification (V&V)** methods are implied but not explicitly detailed in the provided context; however, the integration of **MBSE tools** (e.g., SysML, Simulink) suggests adherence to structured validation processes such as **model checking**, **simulation-based testing**, and **requirements traceability**. Uncertainty sources may arise from **data abstraction discrepancies** (e.g., loss of granularity in aggregated traces) or **model-simulation mismatches** (e.g., discrepancies between ADL-defined behaviors and real-world dynamics). Error detection mechanisms are not specified, but the use of **active software components** in the DT implies **real-time monitoring** and **anomaly detection** via automated data processing pipelines. Quality assurance processes likely involve **cross-tool consistency checks** (e.g., validating SysML models against Simulink simulations) and **stakeholder-driven validation** to reconcile heterogeneous perspectives."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with **external systems** through **interoperability standards** inherent to MBSE and ADLs, such as **SysML IBDs** (Internal Block Diagrams) for structural integration or **state machines** for behavioral synchronization. **Data exchange protocols** are not explicitly specified, but the use of **simulation tools (Simulink, MathWorks)** and **general-purpose languages (C++, Java)** implies compatibility with **industry-standard APIs** (e.g., OPC UA for manufacturing, REST/gRPC for enterprise systems). Dependencies on external systems are managed via **heterogeneous tool integration**, as described in Section II.A, where models in different notations (e.g., SysML, ADLs) must align. **Integration patterns** may include **digital shadow aggregation** (as per Kritzinger et al.’s reference model) or **real-time data pipelines** between physical objects and digital representations, though no specific protocols (e.g., MQTT, AMQP) are mentioned. The system’s ability to interact with **other Digital Twins or enterprise systems** is implied by the **component & connector** paradigm of ADLs, enabling **loose coupling** via defined interfaces."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE) standards**, particularly leveraging **SysML** (Systems Modeling Language) for system architecture and behavior modeling. For **architecture description**, it aligns with **ADLs (Architecture Description Languages)** such as **ACME**, **AADL (Architecture Analysis & Design Language)**, and **MontiArc**, which standardize component-based system representation. **Interoperability** is addressed through integration with **simulation tools (e.g., MathWorks Simulink)** and **general-purpose programming languages (C++, Java)**, ensuring compatibility across heterogeneous modeling environments. While **industry-specific standards** (e.g., manufacturing, aerospace) are not explicitly mentioned, the reference to **Digital Shadow** (as per [32]) implies compliance with **data aggregation and abstraction frameworks** for contextual traces. **Certification requirements** and **compliance frameworks** are not detailed, but the use of structured modeling methodologies suggests adherence to **ISO/IEC 15288 (Systems Engineering)** or similar standards. **Interoperability standards** are inferred to include **UML (Unified Modeling Language)** for class diagrams (e.g., Fig. 1) and **model exchange formats** (e.g., XMI) to facilitate integration across tools."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The **Asset Administration Shell (AAS)** framework (as described in [46], [47], and [50]) integrates security and safety considerations through structured metadata and standardized interfaces. Key measures include:
  1. **Access Control Mechanisms**: Role-based access control (RBAC) is implied via the AAS's **Submodel** and **SubmodelElement** structures ([46], [50]), where permissions can be assigned to entities (e.g., users, systems) to restrict data/modification access.
  2. **Authentication Systems**: The AAS leverages **OAuth 2.0** and **OpenID Connect** for identity management ([50]), ensuring secure authentication for IoT devices and users interacting with Digital Twin components.
  3. **Cybersecurity Protocols**: The **Reference Architecture Model Industrie 4.0 (RAMI4.0)** ([48], [49]) mandates compliance with **IEC 62443** (industrial automation cybersecurity) and **ISO/IEC 27001** for information security management, which are foundational for Digital Twin security.
  4. **Threat Mitigation Strategies**: The AAS employs **encryption (TLS 1.2+)** for data-in-transit ([50]) and **digital signatures** for integrity verification of exchanged models (e.g., via **Functional Mockup Interface (FMI)** ([51])). Risk assessment aligns with **ISO 31000** principles ([46]).
  5. **Fail-Safe Mechanisms**: The **Digital Shadow** concept ([42]) incorporates redundancy and failover protocols at multiple automation pyramid levels (e.g., **PLC, MES, ERP**), ensuring continuity during disruptions.
  6. **Safety-Critical Systems**: For manufacturing Digital Twins ([43]), **safety PLCs** and **functional safety standards (IEC 61508, IEC 62061)** are referenced, with real-time validation via **model-driven engineering (MDE)** tools (e.g., **Eclipse Modeling Framework**).
  7. **Risk Assessment Approaches**: The AAS includes **asset lifecycle metadata** ([47]) to track vulnerabilities, while **RAMI4.0’s** hierarchical layers ([49]) enable granular risk analysis across **product, resource, and system** dimensions.
  The **ThingsBoard IoT platform** ([53]) further augments security with **MQTT over TLS** ([52]) and **role-based device authentication**, though specifics for Digital Twin integration are not detailed in the provided documents."
]