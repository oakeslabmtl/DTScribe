// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor coupled with cycloidal gear transmission for precise motion control in the MABI MAX 100 six-axis robot. Operates under Siemens SINUMERIK 840D sl CNC controller with position/speed/acceleration command acceptance."
]

instance CycloidalGearTransmission : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear transmission defining actuation range and torque capabilities for the robot's motion control system. Enables precise motion with reduced backlash when combined with encoder feedback loops."
]

instance SINUMERIK840DslController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl CNC controller governing the robot's actuation mechanisms. Implements safety constraints, real-time processing, and dynamic adjustments based on digital twin insights. Accepts remote position/speed/acceleration commands."
]

// C3: Physical Sensing Components
instance PrimaryMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted directly on the permanent magnet synchronous motor shaft providing sub-millimeter angular positioning accuracy. Part of dual encoder system to mitigate backlash and positional uncertainty."
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance SecondaryGearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the cycloidal gearbox providing redundant angular positioning measurements. Cross-verifies with primary encoder to ensure high-precision feedback for control loops."
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input current to the motor for dynamic behavior modeling and torque calculation. Provides real-time operational data for digital twin aggregation."
    DTDFVocab:producedData CurrentDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring output angular velocity from the gearbox for kinematic analysis and control loop validation. Ensures synchronization between physical and digital representations."
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PrimaryMotorEncoder
    base:desc "Time-series data of motor shaft angle transmitted via MQTT protocol with sub-millimeter precision. Used for positional verification and backlash compensation."
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryGearboxEncoder
    base:desc "Time-series data of gearbox output angle transmitted via MQTT protocol. Cross-verified with motor encoder data to ensure positional accuracy."
]

instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
    base:desc "Real-time input current measurements transmitted via MQTT protocol for torque calculation and dynamic behavior analysis."
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
    base:desc "Output angular velocity measurements transmitted via MQTT protocol for kinematic validation and control loop optimization."
]

// C10: Models/Data
instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based functional architecture model of the MABI MAX 100 robot defining requirements, functions, and logical components across abstraction layers. Includes Internal Block Diagrams (IBDs) for component interconnections."
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLLogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based logical architecture model detailing component interfaces, compositions, and hierarchical structures for the six-axis robot system. Supports multi-notation model management."
    DTDFVocab:inputTo SysMLEnabler
]

instance SimulinkPhysicsSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink executable simulation model replicating the robot's dynamic behavior including motor-gearbox coupling, multi-axis kinematics, and physics-based control loops. Used for validation and optimization."
    DTDFVocab:inputTo SimulinkEnabler
]

instance DigitalShadowContextualData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces from the Digital Shadow Reference Model including time-series sensor data, operational logs, and historical performance metrics. Processed for specific purposes like fault detection and performance analysis."
    DTDFVocab:fromData MotorEncoderDataTransmitted, GearboxEncoderDataTransmitted, CurrentDataTransmitted, AngularVelocityDataTransmitted
    DTDFVocab:inputTo DigitalShadowEnabler
]

instance RobotKinematicsModel : DTDFVocab:Data [
    base:desc "Data representing the robot's multi-axis kinematics including joint interactions, collision avoidance parameters, and load handling constraints. Derived from sensor data and simulation models."
    DTDFVocab:fromData DigitalShadowContextualData
    DTDFVocab:inputTo SimulinkEnabler
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling environment enabling multi-layered system engineering for the robot's functional and logical architecture. Supports Internal Block Diagrams (IBDs) and heterogeneous stakeholder integration."
    DTDFVocab:enables RobotArchitectureService, DataAggregationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink platform for creating executable physics simulations of the robot's dynamic behavior. Enables validation of control loops, kinematics, and operational constraints."
    DTDFVocab:enables SimulationService, PhysicsValidationService
]

instance DigitalShadowEnabler : DTDFVocab:Enabler [
    base:desc "Digital Shadow Reference Model implementation using UML class diagrams to structure and process contextual data traces. Enables passive data collection and aggregation for manufacturing analytics."
    DTDFVocab:enables DataAggregationService, RealTimeMonitoringService
]

instance MQTTCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol implementation for lightweight, efficient transmission of sensor data from physical components to the digital twin. Ensures real-time data flow with optimized sampling frequencies."
    DTDFVocab:enables DataTransmissionService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Executable simulation service using Simulink models to replicate the robot's dynamic interactions including motor-gearbox coupling, axis coordination, and physics-based validation of torque/velocity profiles."
    DTDFVocab:provides RobotBehaviorInsight
]

instance PhysicsValidationService : DTDFVocab:Service [
    base:desc "Physics-based validation service ensuring consistency between simulated and physical behavior through torque, velocity, and kinematic analysis."
    DTDFVocab:provides PhysicsConsistencyInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Passive data aggregation and abstraction service processing contextual data traces (sensor readings, operational logs) for performance analysis and fault detection without autonomous actuation."
    DTDFVocab:provides OperationalPerformanceInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Dashboard-based real-time monitoring service displaying the robot's state including axis positions, operational metrics, and sensor data aggregated from the Digital Shadow."
    DTDFVocab:provides CurrentStateInsight
]

instance DataTransmissionService : DTDFVocab:Service [
    base:desc "Service managing the MQTT-based transmission of sensor data from physical components to the digital twin with optimized sampling frequencies for low-latency operational monitoring."
    DTDFVocab:provides DataIntegrityInsight
]

instance RobotArchitectureService : DTDFVocab:Service [
    base:desc "Service providing structured views of the robot's functional and logical architecture through SysML models, supporting multi-notation model management and stakeholder integration."
    DTDFVocab:provides SystemStructureInsight
]

// C17: Insights/Actions
instance RobotBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insights into the robot's dynamic behavior including motor-gearbox interactions, axis coordination, and response to control commands derived from Simulink simulations."
]

instance PhysicsConsistencyInsight : DTDFVocab:Insight [
    base:desc "Validation insights ensuring consistency between simulated physics models and actual physical behavior through torque, velocity, and kinematic analysis."
]

instance OperationalPerformanceInsight : DTDFVocab:Insight [
    base:desc "Performance metrics and fault detection insights derived from aggregated sensor data and operational logs, enabling proactive maintenance and optimization."
]

instance CurrentStateInsight : DTDFVocab:Insight [
    base:desc "Real-time insights into the robot's current state including axis positions, velocities, and operational parameters for immediate monitoring and decision support."
]

instance DataIntegrityInsight : DTDFVocab:Insight [
    base:desc "Insights into the integrity and quality of transmitted sensor data including latency metrics, data completeness, and protocol compliance."
]

instance SystemStructureInsight : DTDFVocab:Insight [
    base:desc "Structural insights into the robot's functional and logical architecture including component relationships, interfaces, and hierarchical compositions as modeled in SysML."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system’s orchestration and coordination are implicitly tied to the integration of heterogeneous modeling tools and methodologies from Model-Based Systems Engineering (MBSE). The system may adopt architecture patterns such as component & connector perspectives (e.g., ACME, AADL, MontiArc, or SysML Internal Block Diagrams) to describe system structure, interfaces, and interconnections. Behavioral descriptions may be handled via state machines (SysML v1.7) or simulation tools like MathWorks Simulink, C++, or Java. Resource management and system-wide coordination are not explicitly detailed, but the document suggests a need for integrating multiple modeling notations and tools (e.g., ADLs for architecture, simulation tools for behavior) to achieve a comprehensive system description. The orchestration likely involves active components (e.g., Digital Twins) processing data from passive digital shadows, with no explicit mention of centralized vs. decentralized control mechanisms."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system’s horizontal integration is not explicitly detailed in the provided context. The document focuses on internal modeling methodologies (e.g., MBSE, ADLs, simulation tools) and the conceptual distinction between digital shadows (one-way data flow) and Digital Twins (active processing). There is no mention of external data exchange protocols, interoperability standards (e.g., OPC UA, MQTT, REST APIs), dependencies on enterprise systems, or integration patterns with other Digital Twins. The document does not provide specifics on how the system interacts with external stakeholders, systems, or ecosystems beyond its passive (shadow) and active (twin) components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE) standards**, particularly leveraging **SysML** for modeling and **architecture description languages (ADLs)** such as **ACME**, **AADL**, and **MontiArc** for component-based system representation. Interoperability is facilitated through **multi-tool integration**, including **MathWorks Simulink** and general-purpose languages (**C++**, **Java**). While no explicit **industry standards** (e.g., ISO, IEC) or **certification frameworks** are mentioned, the use of **SysML v1.7** (supporting state machines) and **MontiArc Automaton** for behavioral modeling aligns with **modeling and simulation standards** in systems engineering. The **Digital Shadow Reference Model** (Fig. 1) implies adherence to **UML-based class modeling** for data aggregation and abstraction, though no compliance frameworks or interoperability protocols (e.g., OPC UA, FIWARE) are specified."
]