// C3: Physical sensing components
instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder providing shaft angle r_M."
    DTDFVocab:producedData MQTTMotorEncoderTransmission
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary gearbox encoder providing gear angle r_G."
    DTDFVocab:producedData MQTTGearboxEncoderTransmission
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor phase current I_M."
    DTDFVocab:producedData MQTTMotorCurrentTransmission
]

// C4: Physical‑to‑virtual interaction
instance MQTTMotorCurrentTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MQTTMotorEncoderTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder
]

instance MQTTGearboxEncoderTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// C10: Data traces
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Live time‑series of motor current I_M."
    DTDFVocab:fromData MQTTMotorCurrentTransmission
    DTDFVocab:inputTo SimulinkEnabler, DashboardEnabler, MQTTEnabler
]

instance MotorEncoderAngleData : DTDFVocab:Data [
    base:desc "Live time‑series of motor shaft angle r_M."
    DTDFVocab:fromData MQTTMotorEncoderTransmission
    DTDFVocab:inputTo SimulinkEnabler, DashboardEnabler, MQTTEnabler
]

instance GearboxEncoderAngleData : DTDFVocab:Data [
    base:desc "Live time‑series of gearbox angle r_G."
    DTDFVocab:fromData MQTTGearboxEncoderTransmission
    DTDFVocab:inputTo SimulinkEnabler, DashboardEnabler, MQTTEnabler
]

// C11: Enablers (tooling and infrastructure)
instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker for real‑time sensor data streaming."
    DTDFVocab:enables RealTimeVisualizationDashboard, FrictionParameterIdentification
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for simulation and friction modelling."
    DTDFVocab:enables FrictionParameterIdentification, AutomaticControlModelUpdate
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Custom web dashboard for visualising live data and insights."
    DTDFVocab:enables RealTimeVisualizationDashboard, AutomaticControlModelUpdate
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML toolchain for engineering block definition and internal block diagrams."
    // No enables relationship to a Service (removed to satisfy disjoint class constraints)
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell handling component representation and metadata."
    // No enables relationship to a Service (removed to satisfy disjoint class constraints)
]

// C10: Models/Data
instance SysMLAxisModel : DTDFVocab:Model [
    base:desc "SysML block definition & internal block diagram of the robot axis."
    DTDFVocab:inputTo SysMLEnabler, AssetAdministrationShellEnabler
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "Simulink model of the permanent‑magnet synchronous motor."
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "Simulink model of the gearwheel and cycloidal gearbox."
    DTDFVocab:inputTo SimulinkEnabler
]

instance FrictionModelCoulombViscous : DTDFVocab:Model [
    base:desc "Friction model combining Coulomb and viscous effects."
    DTDFVocab:inputTo SimulinkEnabler
]

instance FrictionModelStribeck : DTDFVocab:Model [
    base:desc "Stribeck friction model for low‑speed behaviour."
    DTDFVocab:inputTo SimulinkEnabler
]

instance FrictionModelDahl : DTDFVocab:Model [
    base:desc "Dahl friction model capturing pre‑sliding displacement."
    DTDFVocab:inputTo SimulinkEnabler
]

instance FrictionModelLuGre : DTDFVocab:Model [
    base:desc "LuGre friction model for dynamic stick‑slip phenomena."
    DTDFVocab:inputTo SimulinkEnabler
]

instance DataCalculationTorqueVelocityModel : DTDFVocab:Model [
    base:desc "Calculation model deriving torque, angular velocity and acceleration from sensor data."
    DTDFVocab:inputTo SimulinkEnabler, DashboardEnabler
]

// C6: Services
instance RealTimeVisualizationDashboard : DTDFVocab:Service [
    base:desc "Web dashboard visualising live sensor traces and derived insights."
    DTDFVocab:provides PositionalAccuracyImprovementInsight, PresentInsightsDashboardAction
]

instance FrictionParameterIdentification : DTDFVocab:Service [
    base:desc "Identification of static, kinetic and viscous friction parameters by comparing simulated and measured data."
    DTDFVocab:provides FrictionParametersInsight, AdjustTorqueCommandsAction
]

instance AutomaticControlModelUpdate : DTDFVocab:Service [
    base:desc "Automatic update of the robot control model with identified friction parameters to improve motion accuracy."
    DTDFVocab:provides PositionalAccuracyImprovementInsight
]

// C17: Insights
instance FrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters (static, kinetic, viscous) identified from data."
]

instance PositionalAccuracyImprovementInsight : DTDFVocab:Insight [
    base:desc "Insight that updated friction parameters improve positional accuracy of the robot axis."
]

// C17: Actions
instance AdjustTorqueCommandsAction : DTDFVocab:Action [
    base:desc "Feedback of identified friction parameters to robot control algorithms to adjust torque commands."
    DTDFVocab:IsAutomatic true
]

instance PresentInsightsDashboardAction : DTDFVocab:Action [
    base:desc "Display of friction and accuracy insights on the operator dashboard."
    DTDFVocab:IsAutomatic false
]

// C8: Component (optional example)
instance AxisComponent : DTDFVocab:Component [
    base:desc "Physical representation of the first axis of the MABI MAX 100 robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization with the robot’s operating cycle; data are captured and streamed online as the robot moves (no explicit sample rate given)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow comprising a Purpose element (FrictionDerivation), an Asset element (MABI robot first axis), Sources (sensor channels), Processing components (Simulation M, GW, GB) that consume input traces and produce simulated traces, Models (engineering, simulation, data‑calculation), and a Dashboard for user interaction."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow is created and used during the operational stage of the robot, supporting online model refinement while the robot is in service."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each data point to its source and processing component, enabling verification by comparing simulated friction‑less data with measured traces; the processing component records provenance to ensure model validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the physical robot to the digital shadow using the MQTT protocol."
]