instance MABIMAX100FirstAxisDigitalTwin : DTDFVocab:DigitalTwin [
    base:desc "Digital Twin for MABI MAX 100 first axis"
    base:contains MABIMAX100FirstAxisEnvironment
]

instance MABIMAX100FirstAxisEnvironment : DTDFVocab:Environment [
    base:contains MotorEncoder, SecondaryEncoder, CurrentSensor, SysMLEnabler, SimulinkEnabler, AASEnabler, MQTTEnabler, DashboardEnabler
    base:isContainedIn MABIMAX100FirstAxisDigitalTwin
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder measuring position for MABI MAX 100 first axis"
    DTDFVocab:producedData MotorEncoderPositionDataTransmitted
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder measuring position for MABI MAX 100 first axis"
    DTDFVocab:producedData SecondaryEncoderPositionDataTransmitted
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor current for MABI MAX 100 first axis"
    DTDFVocab:producedData CurrentSensorCurrentDataTransmitted
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance MotorEncoderPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance SecondaryEncoderPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoder
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance CurrentSensorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance PositionData : DTDFVocab:Data [
    base:desc "Position data from motor and secondary encoders"
    DTDFVocab:fromData MotorEncoderPositionDataTransmitted, SecondaryEncoderPositionDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, SysMLEnabler
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance CurrentData : DTDFVocab:Data [
    base:desc "Current measurements from current sensor"
    DTDFVocab:fromData CurrentSensorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Simulated torque output from friction models"
    DTDFVocab:inputTo SimulinkEnabler
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Simulated angular velocity output from friction models"
    DTDFVocab:inputTo SimulinkEnabler
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance SysML_BDD : DTDFVocab:Model [
    base:desc "SysML Block Definition Diagram for MABI MAX 100 first axis"
    DTDFVocab:inputTo SysMLEnabler
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance SysML_IBD : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram for MABI MAX 100 first axis"
    DTDFVocab:inputTo SysMLEnabler
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Coulomb-Viscous friction model implemented in Simulink"
    DTDFVocab:inputTo SimulinkEnabler
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Stribeck friction model implemented in Simulink"
    DTDFVocab:inputTo SimulinkEnabler
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Dahl friction model implemented in Simulink"
    DTDFVocab:inputTo SimulinkEnabler
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "LuGre friction model implemented in Simulink"
    DTDFVocab:inputTo SimulinkEnabler
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance WhiteBoxFrictionModel : DTDFVocab:Model [
    base:desc "White-box friction model for MABI MAX 100 first axis"
    DTDFVocab:inputTo SimulinkEnabler
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance BlackBoxFrictionModel : DTDFVocab:Model [
    base:desc "Black-box friction model for MABI MAX 100 first axis"
    DTDFVocab:inputTo SimulinkEnabler
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML tooling for structural modeling of MABI MAX 100 first axis"
    DTDFVocab:enables ContinuousFrictionIdentification, MotionAccuracyEnhancement
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks MATLAB Simulink for friction simulation and modeling"
    DTDFVocab:enables ContinuousFrictionIdentification, MotionAccuracyEnhancement, DashboardVisualization
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for digital twin asset management"
    DTDFVocab:enables ContinuousFrictionIdentification
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol for sensor data streaming"
    DTDFVocab:enables DashboardVisualization
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard visualization tools for real-time monitoring"
    DTDFVocab:enables DashboardVisualization
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance ContinuousFrictionIdentification : DTDFVocab:Service [
    base:desc "Continuous identification of friction dynamics using live operational data"
    DTDFVocab:provides FrictionDynamicsInsight
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance MotionAccuracyEnhancement : DTDFVocab:Service [
    base:desc "Enhancement of robot motion accuracy through optimized control parameters"
    DTDFVocab:provides OptimizedControlParametersAction
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance DashboardVisualization : DTDFVocab:Service [
    base:desc "Real-time visualization of robot performance metrics and friction models"
    DTDFVocab:provides DashboardViewInsight
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance FrictionDynamicsInsight : DTDFVocab:Insight [
    base:desc "Insights into friction dynamics for optimizing robot control"
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance OptimizedControlParametersAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of robot control parameters based on friction insights"
    DTDFVocab:IsAutomatic true
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance DashboardViewInsight : DTDFVocab:Insight [
    base:desc "Visual representation of system status and performance metrics"
    base:isContainedIn MABIMAX100FirstAxisEnvironment
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with live data streams"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Integration of SysML models, Simulink simulations, AAS for data linking, MQTT data streams, and a unified dashboard for the first axis of the MABI MAX 100 robot"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "As-operated stage of the physical system"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation through deviation analysis between simulated and measured data to ensure model accuracy"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol for real-time sensor data transmission"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Asset Administration Shell (AAS) standards and SysML modeling language"
]