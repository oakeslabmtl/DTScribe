// C3: Physical sensing components
instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder providing angular position of the permanent‑magnet synchronous motor shaft"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance SecondaryEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder providing angular position after the gear transmission"
    DTDFVocab:producedData SecondaryEncoderDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Phase current sensor measuring motor current I_M"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance SecondaryEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoderSensor
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    // derived data, no producedFrom relationship to a SensingComponent
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    // derived data, no producedFrom relationship to a SensingComponent
]

instance AngularAccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    // derived data, no producedFrom relationship to a SensingComponent
]

// C10: Data items
instance MotorPositionData : DTDFVocab:Data [
    base:desc "Raw motor shaft angular position from MotorEncoder"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance SecondaryPositionData : DTDFVocab:Data [
    base:desc "Raw angular position after gearbox from SecondaryEncoder"
    DTDFVocab:fromData SecondaryEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor phase current I_M"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque computed from motor current and position"
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity computed from position traces"
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance AngularAccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration computed from velocity traces"
    DTDFVocab:fromData AngularAccelerationDataTransmitted
    DTDFVocab:inputTo SimulinkEngineEnabler
]

// C10: Models/Data (Engineering & Simulation)
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams describing motor, gearboxes and flows"
    DTDFVocab:inputTo AssetAdministrationShellEnabler
]

instance SimulinkFrictionFreeModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of friction‑free behavior of the axis"
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance SimulinkCoulombViscousModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model implementing Coulomb‑Viscous friction"
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance SimulinkStribeckModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model implementing the Stribeck friction law"
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance SimulinkDahlModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model implementing the Dahl friction law"
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance SimulinkLuGreModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model implementing the LuGre friction law"
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance TorqueComputationModel : DTDFVocab:Model [
    base:desc "Data calculation model for deriving torque from current and position data"
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance VelocityComputationModel : DTDFVocab:Model [
    base:desc "Data calculation model for deriving angular velocity from position traces"
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance AccelerationComputationModel : DTDFVocab:Model [
    base:desc "Data calculation model for deriving angular acceleration from velocity traces"
    DTDFVocab:inputTo SimulinkEngineEnabler
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker streaming live sensor data from the robot to the digital shadow"
    DTDFVocab:enables RealTimeVisualizationService
]

instance SimulinkEngineEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution engine running simulation and friction identification models"
    DTDFVocab:enables FrictionParameterIdentificationService, ModelUpdateService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell providing model integration and metadata management"
    DTDFVocab:enables ModelUpdateService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of measured and simulated data in a unified dashboard"
    DTDFVocab:provides RealTimeDataInsight
]

instance FrictionParameterIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of static, kinetic and viscous friction parameters"
    DTDFVocab:provides FrictionParameterInsight, ControlSetpointAdjustmentAction
]

instance ModelUpdateService : DTDFVocab:Service [
    base:desc "Provision of updated friction models for improving robot motion control accuracy"
    DTDFVocab:provides MaintenanceSchedulingAction
]

// C17: Insights/Actions
instance RealTimeDataInsight : DTDFVocab:Insight [
    base:desc "Insight into current state of measured and simulated variables for operator monitoring"
]

instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters (static, Coulomb, viscous) identified from sensor data"
]

instance ControlSetpointAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of robot controller set‑points based on updated friction parameters"
    DTDFVocab:IsAutomatic true
]

instance MaintenanceSchedulingAction : DTDFVocab:Action [
    base:desc "Scheduling of maintenance activities when friction trends indicate wear"
    DTDFVocab:IsAutomatic false
]

// C0: Component representing the system under study
instance AxisOneAssemblyComponent : DTDFVocab:Component [
    base:desc "First axis of the MABI MAX 100 six‑axis robot, comprising a PMSM, gear transmission, cycloidal gearbox, and two position encoders"
]

// C0: Environment
instance RobotEnvironment : DTDFVocab:Environment [
    base:contains AxisOneAssemblyComponent
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time operation during robot motion; data is processed and visualized as it is received, enabling on‑line friction identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow consisting of a Purpose class (FrictionDerivation), an Asset class (Mabi robot), Sources (sensor channels), Processing components (Simulation M, Simulation GW, Simulation GB) that consume input traces and produce simulated traces, and Models (engineering, simulation, data‑calculation) linked through the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated stage – the digital shadow is created for the robot while it is in use to monitor and improve motion accuracy."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Combination of white‑box (analytical) and black‑box (data‑driven) friction models; continuous identification to capture wear, load, temperature effects; traceability of each data point to its source and processing model; validation by comparing simulated friction‑compensated output with measured reference data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the physical robot to the digital shadow via the MQTT protocol; the Asset Administration Shell (AAS) is used to encapsulate model metadata and enable standardized data access."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) as a standard for model representation and data exchange; SysML as a standard modeling language; MQTT as a standard IoT messaging protocol."
]