// ====================== Acting Components ======================
instance PermanentMagnetSynchronousMotor : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor (input current I_M, output torque τ_M) driving the first axis"
]

instance GearwheelGearbox : DTDFVocab:Component [
    base:desc "Gearwheel gearbox providing torque τ_G to the drive train"
]

instance CycloidalGearbox : DTDFVocab:Component [
    base:desc "Cycloidal gearbox delivering the final output torque τ_out"
]

// ====================== Sensing Components ======================
// Motor current sensor
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor phase current I_M on the PMSM"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// Motor encoder (directly on motor shaft)
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Rotary encoder mounted on the motor shaft providing raw angular position"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

// Secondary encoder behind the gearwheel gearbox
instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder located after the gearwheel gearbox delivering gearbox shaft angle"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

// Derived kinematics processor (computes ω and α from encoder streams)
instance KinematicsDerivationProcessor : DTDFVocab:SensingComponent [
    base:desc "Software component that derives angular velocity ω and acceleration from encoder data"
    DTDFVocab:producedData KinematicsDataTransmitted
]

// ====================== DataTransmitted ======================
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance KinematicsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom KinematicsDerivationProcessor
]

// ====================== Data (Measured) ======================
instance MeasuredMotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current trace I_M streamed from the robot"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance MeasuredMotorAngleData : DTDFVocab:Data [
    base:desc "Measured motor shaft angular position from MotorEncoder"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance MeasuredGearboxAngleData : DTDFVocab:Data [
    base:desc "Measured gearbox shaft angular position from GearboxEncoder"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance DerivedKinematicsData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω and acceleration computed from encoder streams"
    DTDFVocab:fromData KinematicsDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

// ====================== Simulation Models ======================
instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the PMSM including electrical dynamics"
    DTDFVocab:inputTo SimulinkRuntimeEngine
]

instance GearwheelSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the gearwheel gearbox torque transmission τ_G"
    DTDFVocab:inputTo SimulinkRuntimeEngine
]

instance CycloidalGearboxSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the cycloidal gearbox delivering τ_out"
    DTDFVocab:inputTo SimulinkRuntimeEngine
]

instance WhiteBoxFrictionModel : DTDFVocab:Model [
    base:desc "White‑box friction model (static, kinetic, viscous) used for identification"
    DTDFVocab:inputTo SimulinkRuntimeEngine
]

instance BlackBoxFrictionModel : DTDFVocab:Model [
    base:desc "Black‑box friction model learned from measured data traces"
    DTDFVocab:inputTo SimulinkRuntimeEngine
]

// ====================== Data (Simulated) ======================
instance SimulatedMotorTorqueData : DTDFVocab:Data [
    base:desc "Simulated motor torque trace τ̂_M generated by MotorSimulinkModel"
    DTDFVocab:inputTo SimulinkRuntimeEngine
]

instance SimulatedGearboxTorqueData : DTDFVocab:Data [
    base:desc "Simulated gearwheel torque trace τ̂_G generated by GearwheelSimulinkModel"
    DTDFVocab:inputTo SimulinkRuntimeEngine
]

instance SimulatedOutputTorqueData : DTDFVocab:Data [
    base:desc "Simulated output torque trace τ̂_out generated by CycloidalGearboxSimulinkModel"
    DTDFVocab:inputTo SimulinkRuntimeEngine
]

// ====================== Enablers ======================
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker used for live streaming of sensor data from the robot"
    DTDFVocab:enables RealTimeFrictionIdentificationService, ContinuousModelUpdateService, VisualizationDashboardService, FrictionParameterProvisionService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell linking model elements with the physical asset"
    DTDFVocab:enables ContinuousModelUpdateService
]

instance SimulinkRuntimeEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment running the simulation and friction models"
    DTDFVocab:enables RealTimeFrictionIdentificationService, ContinuousModelUpdateService
]

instance DashboardVisualizationTool : DTDFVocab:Enabler [
    base:desc "Custom web dashboard visualising live data, model updates and identified friction parameters"
    DTDFVocab:enables VisualizationDashboardService
]

// ====================== Services ======================
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction using measured and simulated torque traces"
    DTDFVocab:provides FrictionParameterDerivationInsight
]

instance ContinuousModelUpdateService : DTDFVocab:Service [
    base:desc "Continuous update of simulation models based on newly received measurement data"
    DTDFVocab:provides ModelRefreshInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Integrated dashboard visualising live sensor data, simulated traces and identified friction parameters"
    DTDFVocab:provides FrictionLossDetectionInsight
]

instance FrictionParameterProvisionService : DTDFVocab:Service [
    base:desc "Provision of derived friction parameters to the Siemens SINUMERIK 840D CNC controller for motion‑control improvement"
    DTDFVocab:provides FrictionParameterProvisionAction
]

// ====================== Insights ======================
instance FrictionParameterDerivationInsight : DTDFVocab:Insight [
    base:desc "Derivation of static, kinetic and viscous friction parameters for the gearbox"
]

instance ModelRefreshInsight : DTDFVocab:Insight [
    base:desc "Recognition that simulation models have been refreshed with latest measurement data"
]

instance FrictionLossDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of friction losses in the gear train based on discrepancy between measured and simulated torques"
]

// ====================== Actions ======================
instance FrictionParameterProvisionAction : DTDFVocab:Action [
    base:desc "Automatic upload of identified friction parameters to the robot controller to improve motion accuracy"
    DTDFVocab:IsAutomatic true
]

// ====================== Environment (Physical System) ======================
instance FirstVerticalAxisEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotor, GearwheelGearbox, CycloidalGearbox
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time acquisition and processing of sensor streams (live data flow) to enable on‑line friction model identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A digital shadow consisting of a Purpose (FrictionDerivation), an Asset (MABI first axis), Sources (sensor channels), Processing components (Simulation_M, Simulation_GW, Simulation_GB) that consume measured data and simulation models, and resulting DataTraces stored in the shadow; all linked via the AAS and MQTT infrastructure."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational/run‑time stage – the digital shadow is created for the operated robot to analyse friction during actual machining tasks."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each DataPoint to its generating Processing component and source; use of both analytical (white‑box) and data‑driven (black‑box) friction models; comparison of simulated friction‑free behavior with measured data to validate model accuracy; continuous model exchange ensures up‑to‑date fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are streamed from the robot to the digital shadow using the MQTT protocol; the Asset Administration Shell provides the semantic linking of data and models."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) standard for digital twin data integration and SysML as a standardized modeling language."
]