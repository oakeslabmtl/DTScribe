// C3: Physical sensing components
instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "High‑resolution motor encoder measuring shaft rotation, published to MQTT topic 'drive/encMotor'"
    DTDFVocab:producedData MotorEncoderTopic
]

instance OutputShftEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary high‑resolution encoder on the output shaft, used to cancel mechanical backlash, published to MQTT topic 'drive/encOutput'"
    DTDFVocab:producedData OutputEncoderTopic
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor for the permanent‑magnet synchronous motor, published to MQTT topic 'drive/motorCurrent'"
    DTDFVocab:producedData MotorCurrentTopic
]

// C4: Physical-to-virtual interaction
instance MotorEncoderTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance OutputEncoderTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputShftEncoderSensor
]

instance MotorCurrentTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Models/Data
instance MotorEncoderData : DTDFVocab:Data [
    base:desc "Time‑series of motor shaft position encoded by high‑resolution encoder"
    DTDFVocab:fromData MotorEncoderTopic
    DTDFVocab:inputTo MQTTBroker, SimulinkEngine, SysMLModel, AssetAdministrationShell
]

instance OutputEncoderData : DTDFVocab:Data [
    base:desc "Time‑series of output shaft position encoded by secondary encoder"
    DTDFVocab:fromData OutputEncoderTopic
    DTDFVocab:inputTo MQTTBroker, SimulinkEngine, SysMLModel, AssetAdministrationShell
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor current from current sensor"
    DTDFVocab:fromData MotorCurrentTopic
    DTDFVocab:inputTo MQTTBroker, SimulinkEngine, SysMLModel, AssetAdministrationShell
]

instance SimulinkMotorGearSimulationModel : DTDFVocab:Model [
    base:desc "Simulink model representing permanent‑magnet synchronous motor, gear train, and cycloidal gear assembly dynamics"
    DTDFVocab:inputTo SimulinkEngine
]

instance SysMLComponentConnectorModel : DTDFVocab:Model [
    base:desc "SysML model capturing component‑connector architecture of the drive system"
    DTDFVocab:inputTo SysMLModel
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker handling real‑time telemetry and actuation command exchange"
    DTDFVocab:enables TwinDataSyncService, MotorControlService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation engine for behavioral modeling"
    DTDFVocab:enables SimulationService
]

instance SysMLModel : DTDFVocab:Enabler [
    base:desc "SysML structural taxonomy providing interface for simulation synchronization"
    DTDFVocab:enables SimulationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell encapsulating sensor and actuator data, providing a standard interface"
    DTDFVocab:enables TwinDataSyncService
]

instance MBSEFramework : DTDFVocab:Enabler [
    base:desc "MBSE framework using SysML, UML, and MontiArc for architectural definition"
    DTDFVocab:enables SimulationService
]

instance MontiArcBehaviour : DTDFVocab:Enabler [
    base:desc "MontiArc component‑level behaviour model used for system behaviour specification"
    DTDFVocab:enables SimulationService
]

instance UMLModeling : DTDFVocab:Enabler [
    base:desc "UML object‑modeling tool for detailing system components"
    DTDFVocab:enables SimulationService
]

// C6: Services
instance TwinDataSyncService : DTDFVocab:Service [
    base:desc "Service synchronizing real‑time telemetry with the digital twin"
    DTDFVocab:provides MotorPositionInsight, MotorCurrentInsight, TwinPerformanceInsight
]

instance MotorControlService : DTDFVocab:Service [
    base:desc "Service issuing control commands to the Siemens SINUMERIK 840D SL servo drive via MQTT"
    DTDFVocab:provides MotorControlAction, EmergencyStopAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service integrating Simulink simulation with SysML structural model for state prediction"
    DTDFVocab:provides SimulatedPositionInsight, SimulatedCurrentInsight
]

// C17: Insights/Actions
instance MotorPositionInsight : DTDFVocab:Insight [
    base:desc "Assessment of motor shaft position accuracy derived from dual encoder data"
]

instance MotorCurrentInsight : DTDFVocab:Insight [
    base:desc "Monitoring of motor current for torque verification and fault detection"
]

instance TwinPerformanceInsight : DTDFVocab:Insight [
    base:desc "Overall performance evaluation of the drive system integrating sensor and simulation data"
]

instance SimulatedPositionInsight : DTDFVocab:Insight [
    base:desc "Predicted motor shaft position from Simulink simulation"
]

instance SimulatedCurrentInsight : DTDFVocab:Insight [
    base:desc "Predicted motor current from Simulink simulation"
]

instance MotorControlAction : DTDFVocab:Action [
    base:desc "Open‑loop or closed‑loop motor velocity/position command sent to the servo drive"
    DTDFVocab:IsAutomatic false
]

instance EmergencyStopAction : DTDFVocab:Action [
    base:desc "Urgent stop command to halt the motor and ensure safety"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance SiemensServoDrive : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D SL servo drive that converts MQTT actuation commands into motor torque"
]

instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor driven by the servo drive"
]

instance GearTrain : DTDFVocab:ActingComponent [
    base:desc "Gear train reducing torque and adjusting speed before passing to the cycloidal gear assembly"
]

instance CycloidalGearAssembly : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear assembly delivering final output motion"
]

// C15: Environment
instance IndustrialAutomationEnvironment : DTDFVocab:Environment [
    base:desc "Environment containing the drive system components and enablers"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "No virtual‑to‑physical interaction is defined. The digital twin is a digital shadow that only observes and processes incoming sensor streams; it does not generate or send control commands, feedback, or any backward data to the physical robot. Consequently, there are no command types, control message formats, validation, authentication, conflict resolution or execution confirmation mechanisms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sensor data streams are transmitted from the physical machine to the digital shadow in a real‑time, continuous fashion over MQTT. The system processes each incoming time‑series message immediately, thereby synchronizing the digital representation with the physical state at the moment of arrival; explicit synchronization frequencies or latency thresholds are not specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin is organized using a layered reference model that merges MBSE practices. Functional and logical architecture is captured with SysML IBDs and ADLs, while the virtual model is built and validated through simulation in Simulink. The overall orchestration follows a concrete workflow in which sensor data traces are aggregated, processed by an active processing layer, and used to update a virtual asset model; communication and resource coordination are mediated through an MQTT broker serving as the data bus, and the architecture relies on UML‑style class diagrams to capture component integration."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Twin’s fidelity is evaluated by comparing simulated outputs from the Simulink model against measured telemetry from the physical system. Discrepancies are quantified using a root‑mean‑square error metric between simulated and real position/time data. Data uncertainty originates from sensor noise, encoder quantization, and MQTT network latency; the Twin tracks these uncertainties and flags parameters when error exceeds predefined thresholds, triggering a recalibration routine. No additional automated validation loops, fault detection algorithms, or periodic consistency checks are described beyond this error‑threshold monitoring."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The primary communication channel is an MQTT broker that receives telemetry from the physical asset and delivers it to the digital twin. Configuration details such as topic hierarchy, QoS levels, TLS, or network topology are not specified in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external equipment is achieved solely through the MQTT protocol, delivering raw sensor time series from a Siemens SINUMERIK 840D industrial controller to the digital twin. The data flow is strictly one‑way, as defined for a digital shadow; no commands or control data are sent back to the physical system."
]