// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor acquiring input current as a time‑series stream from the physical asset."
    DTDFVocab:producedData MQTTMessageInputCurrent
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor acquiring torque as a time‑series stream from the physical asset."
    DTDFVocab:producedData MQTTMessageTorque
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor acquiring angular velocity as a time‑series stream from the physical asset."
    DTDFVocab:producedData MQTTMessageAngularVelocity
]

// C4: Physical‑to‑virtual interaction (data transmission)
instance MQTTMessageInputCurrent : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance MQTTMessageTorque : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
]

instance MQTTMessageAngularVelocity : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

// C10: Data produced from sensors
instance InputCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of input current values received via MQTT."
    DTDFVocab:fromData MQTTMessageInputCurrent
    DTDFVocab:inputTo ThingsBoardMiddlewareEnabler
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Time‑series of torque values received via MQTT."
    DTDFVocab:fromData MQTTMessageTorque
    DTDFVocab:inputTo ThingsBoardMiddlewareEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Time‑series of angular velocity values received via MQTT."
    DTDFVocab:fromData MQTTMessageAngularVelocity
    DTDFVocab:inputTo ThingsBoardMiddlewareEnabler
]

// C10: Models/Data
instance GeometricStructuralModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram describing the geometric and structural aspects of the asset."
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance BehavioralSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model capturing analytical/behavioral dynamics of the asset."
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance CodeArtifactModel : DTDFVocab:Model [
    base:desc "C++ implementation artifact derived from the system model for real‑time execution."
    DTDFVocab:inputTo CppRuntimeEnabler
]

// C11: Enablers (middleware, simulation engines, modeling tools)
instance ThingsBoardMiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ThingsBoard middleware validates MQTT messages against a JSON schema, performs unit conversion and outlier filtering."
    DTDFVocab:enables DataProcessingService
]

instance SimulinkEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulink engine executes the BehavioralSimulinkModel for simulation runs."
    DTDFVocab:enables SimulationService
]

instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling environment (e.g., Cameo, MagicDraw) manages the GeometricStructuralModel."
    DTDFVocab:enables ModelManagementService
]

instance CppRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "C++ runtime environment compiles and runs the CodeArtifactModel."
    DTDFVocab:enables CodeExecutionService
]

// C6: Services
instance DataProcessingService : DTDFVocab:Service [
    base:desc "Processing component that consumes validated data traces, performs calculations or invokes simulation models, and emits higher‑level abstractions."
    DTDFVocab:provides HighLevelAbstractionInsight, DecisionSupportAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Executes the Simulink behavioral model to generate simulation results."
    DTDFVocab:provides SimulationResultInsight
]

instance ModelManagementService : DTDFVocab:Service [
    base:desc "Provides access to structural model artifacts and supports model‑based engineering activities."
    DTDFVocab:provides StructuralModelInsight
]

instance CodeExecutionService : DTDFVocab:Service [
    base:desc "Runs compiled C++ code artifacts derived from system models."
    DTDFVocab:provides CodeExecutionInsight
]

// C17: Insights and Actions
instance HighLevelAbstractionInsight : DTDFVocab:Insight [
    base:desc "Higher‑level abstraction generated by processing input data traces, retaining provenance via the ‘originates‑from’ association."
]

instance DecisionSupportAction : DTDFVocab:Action [
    base:desc "Automated decision‑support action triggered by high‑level abstraction results."
    DTDFVocab:IsAutomatic true
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation output data providing analytical insight into system behavior."
]

instance StructuralModelInsight : DTDFVocab:Insight [
    base:desc "Insight derived from the SysML structural model regarding component relationships."
]

instance CodeExecutionInsight : DTDFVocab:Insight [
    base:desc "Runtime insight obtained from executing the C++ code artifact."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is defined as a passive entity that neither operates autonomously nor pushes data back to the physical system; therefore no control flow from the virtual representation to the physical object is described."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated using a Model‑Based Systems‑Engineering (MBSE) approach that leverages architecture description languages (ADLs) such as ACME, AADL, MontiArc and SysML internal block diagrams to define components, their interfaces, and connector topologies. Functional and logical architectures are captured in models (RFLP, OOSEM, SPES, SMArDT) and linked to processing components that implement data‑calculation or simulation models. Each processing component consumes input data traces and produces output traces, with traceability maintained through the ‘originates‑from’ association, enabling transitive provenance across components. The overall system conforms to a Digital Shadow Reference Model, instantiated through a concretization step that maps reference concepts to concrete classes and associations, thereby providing a structured constellation of components, models, and data‑flow pipelines."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin’s development follows the Model‑Based Systems‑Engineering (MBSE) lifecycle that is split into four abstraction levels: (1) requirements engineering, (2) functional architecture, (3) logical architecture, and (4) product/technical layer. At each level the twin is represented by appropriate models – e.g., SysML requirement diagrams, functional block diagrams, logical component‑connector models, and detailed product‑level designs – and transitions between levels are managed by mapping concepts forward (requirements → functions → logical components → physical realization) as described in Document 1."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by combining white‑box (physics‑based Simulink) models with data‑driven (black‑box) models, and by enforcing traceability of model transformations (e.g., from SysML to simulation models). Validation and verification activities focus on ensuring the correctness of these transformations and on maintaining the reliability of the Digital Twin; uncertainty sources are acknowledged, and verification methods are applied to guarantee that the integrated models faithfully represent the underlying physical processes."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The network layer relies on MQTT (TCP/IP) as the communication protocol for streaming sensor time‑series data. A Mosquitto broker is used to mediate publish‑subscribe interactions between the physical equipment (publishers) and the digital twin platform (subscribers). MQTT QoS levels (e.g., QoS 1) ensure at‑least‑once delivery, and broker persistence can be enabled to increase reliability. While the documents do not specify topology, bandwidth, or latency, MQTT provides a lightweight, low‑latency architecture suitable for high‑frequency sensor streams. Security aspects are not detailed beyond the typical use of TLS for MQTT, which is not explicitly mentioned in the source."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin relies on several established standards and modeling conventions. SysML, an OMG standard for systems engineering, is used for requirements and structural modeling. Architecture description languages such as ACME, AADL, and MontiArc provide standardised component‑connector specifications. The reference model approach introduces a formal conformance relation (as defined in [41]) that specifies which concrete class diagrams conform to the abstract domain model, thereby enforcing a standardized modeling contract across implementations."
]