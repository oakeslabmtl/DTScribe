// Sensing Component
instance PhysicalInstrumentation : DTDFVocab:SensingComponent [
    base:desc "Instrumentation source providing contextual sensor traces aggregated by the Digital Shadow."
    DTDFVocab:producedData PhysicalInstrumentationDataTransmission
]

// Data Transmission between Sensor and Digital Shadow
instance PhysicalInstrumentationDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalInstrumentation
]

// Data aggregated in the Digital Shadow
instance DigitalShadowData : DTDFVocab:Data [
    base:desc "Passive one-way data aggregation of contextual sensor traces from the physical system to the digital domain."
    DTDFVocab:fromData PhysicalInstrumentationDataTransmission
    DTDFVocab:inputTo ADLTool_ACME, SimulinkSimulator, CodeGenerationTool_CPP
]

// Enablers / Tools
instance ADLTool_ACME : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language (ADL) modeling tool enabling component-interface representation."
    DTDFVocab:enables ModelingService
]

instance SimulinkSimulator : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink model-based simulation and validation tool."
    DTDFVocab:enables SimulationService
]

instance CodeGenerationTool_CPP : DTDFVocab:Enabler [
    base:desc "C++ code generation tool for compiling digital twin artifacts."
    DTDFVocab:enables CodeGenerationService
]

// Services
instance ModelingService : DTDFVocab:Service [
    base:desc "Service that models and validates digital twin architecture using ADLs such as ACME, AADL, and MontiArc."
    DTDFVocab:provides ModelComplianceInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that performs dynamic simulation of the digital twin models in Simulink."
    DTDFVocab:provides SimulationResultInsight, RunSimulationAction
]

instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Service that generates executable artifacts in C++ or Java from the digital twin models."
    DTDFVocab:provides GenerateExecutableAction
]

// Insights
instance ModelComplianceInsight : DTDFVocab:Insight [
    base:desc "Insight verifying compliance of the digital twin architecture with MBSE requirements using ADL models."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing simulation results from Simulink runs."
]

// Actions
instance GenerateExecutableAction : DTDFVocab:Action [
    base:desc "Action generating executable artifacts in C++ or Java from the digital twin models."
    DTDFVocab:IsAutomatic true
]

instance RunSimulationAction : DTDFVocab:Action [
    base:desc "Action executing the Simulink simulation of the digital twin models."
    DTDFVocab:IsAutomatic false
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Life cycle stages of a Digital Twin in this context follow a Model‑Based Systems Engineering (MBSE) approach extending from the Requirements level, through Functional Architecture, Logical Architecture, to the Product/Technical Layer. Representation at the Requirements stage is spec‑based (e.g., SysML requirement diagrams), at the Functional level SysML activity and block‑definition diagrams capture service interfaces, at the Logical level ADLs such as MontiArc or AADL are used to describe component–connector relationships, and at the Product level Simulink models or code in C++/Java provide executable artifacts. Transition between stages is managed through model mapping rules that ensure traceability across levels; the evolution of a twin from a high‑level concept to a deployable asset is governed by an MBSE lifecycle management process that supports versioning of models and artifacts, typically integrated with a configuration‑management system, although specific tools are not named in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The document references established modeling standards: SysML (ISO/IEC 19505 series), ACME (ISO/IEC 21496), AADL (ASAM / ISO 26262 integration), and MontiArc (open‑source ADL). Their inclusion indicates compliance with the corresponding ISO/IEC or IEEE specifications for system architecture and behavioral modeling; however, no explicit certification, compliance framework, or interoperability standard beyond these ADLs is cited."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety are addressed through a layered architecture aligned with RAMI 4.0. MQTT message transport is implemented with Mosquitto configured for TLS 1.3 encryption and username/password authentication (or optional client certificates). Device connectivity and data aggregation are handled by Thingsboard 4.0.0, which exposes a REST/HTTP API over HTTPS, uses JSON Web Tokens (JWT) for stateless authentication, and applies role‑based access control (RBAC). The Asset Administration Shell (AAS) API follows the Industry 4.0 specification, providing secure endpoints that require OAuth 2.0 bearer tokens and support AES‑256 encryption for data at rest. Safety‑critical aspects are enforced through fail‑safe logic at the twin module level, with integrity checks and redundant data paths, while periodic risk assessments are performed using a threat‑modeling framework that maps identified vulnerabilities to mitigation strategies such as intrusion‑detection rules and network segmentation. All components are compliant with ISO IEC 27001 and IEC 62443 standards for cybersecurity."
]