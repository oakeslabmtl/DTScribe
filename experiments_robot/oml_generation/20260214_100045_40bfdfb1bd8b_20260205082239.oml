// C3: Physical sensing components
instance OperationalProcessSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real-time data traces from operational processes in the heterogeneous physical system, supporting multi-perspective stakeholder views."
    DTDFVocab:producedData OperationalProcessDataTransmitted
]

instance PhysicalObjectSensor : DTDFVocab:SensingComponent [
    base:desc "Gathers contextual data from physical objects within the complex system, enabling integration with digital representations."
    DTDFVocab:producedData PhysicalObjectDataTransmitted
]

// C4: Physical-to-virtual interaction
instance OperationalProcessDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalProcessSensor
    base:desc "Automated one-way data flow from operational processes, aggregated and abstracted for digital representation."
]

instance PhysicalObjectDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalObjectSensor
    base:desc "Passive unidirectional data transmission from physical objects, requiring external software interpretation."
]

// C10: Models/Data
instance GeometricModel : DTDFVocab:Model [
    base:desc "CAD-based geometric representation of physical components, structured using MBSE methodologies."
    DTDFVocab:inputTo SysMLModelingEnabler, MontiArcADLEnabler
]

instance BehavioralModel : DTDFVocab:Model [
    base:desc "State machine or automaton-based behavioral description (e.g., SysML v1.7 or MontiArc Automaton) for dynamic system behavior."
    DTDFVocab:inputTo SimulinkSimulationEnabler, MontiArcADLEnabler
]

instance AnalyticalModel : DTDFVocab:Model [
    base:desc "Physics-based or mathematical simulation models (e.g., mathematical formulations) for system analysis."
    DTDFVocab:inputTo SimulinkSimulationEnabler, CppJavaImplementationEnabler
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Live sensor feeds from operational processes and physical objects, ingested in near-real-time."
    DTDFVocab:fromData OperationalProcessDataTransmitted, PhysicalObjectDataTransmitted
    DTDFVocab:inputTo DataAggregationPipelineEnabler, DigitalShadowReferenceEnabler
]

instance HistoricalOperationalData : DTDFVocab:Data [
    base:desc "Aggregated operational logs and historical traces for trend analysis and validation."
    DTDFVocab:fromData OperationalProcessDataTransmitted
    DTDFVocab:inputTo DataAggregationPipelineEnabler, SysMLModelingEnabler
]

instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Processed simulation results from tools like MathWorks Simulink, integrated into digital twin models."
    DTDFVocab:fromData PhysicalObjectDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEnabler, CppJavaImplementationEnabler
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based tooling for requirements, functional/logical architectures, and behavioral modeling (e.g., state machines)."
    DTDFVocab:enables ContextualDataAggregationService, StakeholderIntegrationService
]

instance MontiArcADLEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component-connector architectures and automaton-based behavioral descriptions."
    DTDFVocab:enables BehavioralModelingService, SystemDecompositionService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed behavioral modeling and dynamic system simulation."
    DTDFVocab:enables PredictiveAnalysisService, OptimizationService
]

instance CppJavaImplementationEnabler : DTDFVocab:Enabler [
    base:desc "General-purpose languages (C++/Java) for implementing system logic, control algorithms, and domain-specific simulations."
    DTDFVocab:enables ControlAlgorithmService, DomainSpecificSimulationService
]

instance DataAggregationPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Automated pipelines for interpreting one-way data flows, including filtering, normalization, and validation."
    DTDFVocab:enables DataInterpretationService, ContextualDataAggregationService
]

instance DigitalShadowReferenceEnabler : DTDFVocab:Enabler [
    base:desc "UML-based class diagrams defining data trace aggregation and abstraction (per Digital Shadow Reference Model)."
]

// C6: Services
instance DataInterpretationService : DTDFVocab:Service [
    base:desc "Active components analyzing one-way data flows to derive actionable insights from sensor/operational traces."
    DTDFVocab:provides OperationalInsight, DataQualityAssuranceAction
]

instance ContextualDataAggregationService : DTDFVocab:Service [
    base:desc "Collects, processes, and structures data traces for purpose-driven analysis (e.g., manufacturing optimization)."
    DTDFVocab:provides AggregatedDataInsight, PurposeDrivenAnalysisAction
]

instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Supports multi-layered system descriptions (functional/logical architectures) via ADLs and behavioral simulations."
    DTDFVocab:provides SystemBehaviorInsight, ModelValidationAction
]

instance PredictiveAnalysisService : DTDFVocab:Service [
    base:desc "Leverages processed data for predictive maintenance, anomaly detection, and process adjustments."
    DTDFVocab:provides PredictiveMaintenanceInsight, AnomalyDetectionAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimizes system performance using simulation outputs and real-time data."
    DTDFVocab:provides OptimizationRecommendationInsight, ProcessAdjustmentAction
]

instance StakeholderIntegrationService : DTDFVocab:Service [
    base:desc "Facilitates collaboration across heterogeneous perspectives (engineers, operators, managers) via unified modeling."
    DTDFVocab:provides StakeholderAlignmentInsight, CollaborationAction
]

instance ControlAlgorithmService : DTDFVocab:Service [
    base:desc "Implements autonomous control logic for physical system adjustments based on digital twin insights."
    DTDFVocab:provides ControlAlgorithmInsight, AutonomousAdjustmentAction
]

instance DomainSpecificSimulationService : DTDFVocab:Service [
    base:desc "Executes physics-based or AI-driven simulations for domain-specific analysis."
    DTDFVocab:provides SimulationResultInsight, DomainSpecificAnalysisAction
]

instance SystemDecompositionService : DTDFVocab:Service [
    base:desc "Defines components, interfaces, and composition hierarchies using ADLs (ACME, AADL, MontiArc)."
    DTDFVocab:provides SystemDecompositionInsight, ArchitectureValidationAction
]

// C17: Insights/Actions
instance OperationalInsight : DTDFVocab:Insight [
    base:desc "Derived insights from operational process data traces, enabling real-time decision support."
]

instance AggregatedDataInsight : DTDFVocab:Insight [
    base:desc "Structured and purpose-driven aggregated data for manufacturing optimization and predictive maintenance."
]

instance SystemBehaviorInsight : DTDFVocab:Insight [
    base:desc "Multi-layered behavioral descriptions (state machines, automata) for system validation and verification."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics for equipment failure prevention and maintenance scheduling."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Data-driven recommendations for process optimization and resource allocation."
]

instance StakeholderAlignmentInsight : DTDFVocab:Insight [
    base:desc "Unified stakeholder perspectives through integrated modeling frameworks."
]

instance ControlAlgorithmInsight : DTDFVocab:Insight [
    base:desc "Autonomous control logic derived from digital twin analysis."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Processed simulation outputs for domain-specific decision-making."
]

instance SystemDecompositionInsight : DTDFVocab:Insight [
    base:desc "Component-connector architecture definitions for system modularity and scalability."
]

instance DataQualityAssuranceAction : DTDFVocab:Action [
    base:desc "Automated validation and preprocessing of data traces (filtering, normalization)."
    DTDFVocab:IsAutomatic true
]

instance PurposeDrivenAnalysisAction : DTDFVocab:Action [
    base:desc "Contextual data analysis tailored to specific operational objectives."
    DTDFVocab:IsAutomatic true
]

instance ModelValidationAction : DTDFVocab:Action [
    base:desc "Formal verification of behavioral and architectural models."
    DTDFVocab:IsAutomatic false
]

instance AnomalyDetectionAction : DTDFVocab:Action [
    base:desc "Real-time detection of operational anomalies using processed data."
    DTDFVocab:IsAutomatic true
]

instance ProcessAdjustmentAction : DTDFVocab:Action [
    base:desc "Autonomous adjustments to physical processes based on optimization insights."
    DTDFVocab:IsAutomatic true
]

instance CollaborationAction : DTDFVocab:Action [
    base:desc "Facilitation of multi-stakeholder collaboration through shared digital models."
    DTDFVocab:IsAutomatic false
]

instance AutonomousAdjustmentAction : DTDFVocab:Action [
    base:desc "Autonomous control actions executed by the digital twin without external intervention."
    DTDFVocab:IsAutomatic true
]

instance DomainSpecificAnalysisAction : DTDFVocab:Action [
    base:desc "Execution of domain-specific simulations (physics-based or AI-driven)."
    DTDFVocab:IsAutomatic true
]

instance ArchitectureValidationAction : DTDFVocab:Action [
    base:desc "Validation of system decomposition and component interfaces."
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin constellation** in this context is implicitly tied to **Model-Based Systems Engineering (MBSE)** methodologies, which rely on **multi-notation modeling tools** (e.g., SysML for architecture, ADLs like ACME/AADL/MontiArc for component-connector views, and simulation tools like MathWorks Simulink or general-purpose languages like C++/Java for behavior). The orchestration and coordination of the DT system would require **architecture patterns** such as **component-based integration**, where components (e.g., digital shadows, simulation models, or active processing units) are interconnected via **interfaces, connectors, and composition rules** defined in ADLs. Resource management would involve **heterogeneous toolchains** (e.g., combining SysML IBDs with Simulink for dynamic behavior), while system-wide coordination would depend on **stakeholder-specific perspectives** and **model synchronization** across layers (e.g., aligning logical architecture with physical implementations). The document does not specify explicit orchestration frameworks (e.g., microservices, event-driven architectures) but implies a **hybrid, model-driven approach** to DT coordination."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **fidelity and validity considerations** through **validation and verification (V&V) methods** aligned with MBSE practices. Model fidelity is ensured by **multi-layered abstraction** (e.g., functional/logical/physical architectures) and **behavioral modeling** (e.g., state machines or MontiArc Automaton). Uncertainty sources are addressed via **data aggregation and abstraction** (as defined in the Digital Shadow Reference Model) and **error quantification** through **simulation tools** (e.g., MathWorks Simulink) or **analytical models**. Quality assurance processes involve **cross-tool validation** (e.g., SysML for structural integrity, simulation tools for dynamic behavior) and **stakeholder-driven integration** to reconcile heterogeneous perspectives. While specific **error detection/correction mechanisms** or **quantitative uncertainty metrics** are not detailed, the framework implies reliance on **automated data processing** (e.g., passive Digital Shadow data flows) and **active DT components** for real-time adjustments."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **hosting and deployment infrastructure** for a Digital Twin (DT) system is implicitly tied to the **heterogeneous modeling and simulation tools** referenced in the document. While no explicit hosting platforms (e.g., cloud, edge, or on-premise) are specified, the integration of **modeling languages (SysML, ADLs like AADL/ACME/MontiArc)**, **simulation tools (Simulink, other simulation methods [29]–[30])**, and **general-purpose programming languages (C++, Java)** suggests a distributed deployment model. **Computational and storage requirements** are likely high due to the need to handle complex models across multiple abstraction layers (requirements, functional/logical architecture, physics). **Scalability mechanisms** are not detailed, but the use of diverse tools implies modularity and potential for scaling via middleware or orchestration frameworks. **Deployment models** may include hybrid approaches (e.g., edge for real-time data processing and cloud for heavy computation), though specifics are absent. **Availability/reliability assurance** is not addressed, but the reliance on active components (e.g., for DT functionality) implies redundancy or fault-tolerant designs may be required."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The document does not provide explicit details on **horizontal integration** with external systems, such as data exchange protocols (e.g., OPC UA, MQTT, REST/HTTP) or interoperability standards (e.g., ISO 22400 for DTs, GAIA-X for data sovereignty). However, the **Digital Shadow Reference Model** (Fig. 1) suggests integration with **physical objects** via **one-way automated data flows**, implying dependencies on **sensors/actuators** and potentially **enterprise systems** (e.g., ERP, MES) for contextual data aggregation. The MBSE context further implies integration with **external modeling tools** (e.g., Simulink, C++/Java environments) and **simulation platforms** for behavior validation. While no specific integration patterns (e.g., API gateways, message brokers) or DT-to-DT coordination mechanisms are described, the **heterogeneous stakeholder integration** requirement hints at a need for **standardized interfaces** and **semantic interoperability** to bridge disparate systems."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system, as described in the provided documents, integrates **cybersecurity protocols** aligned with **RAMI4.0 (Reference Architecture Model Industrie 4.0)** standards ([48], [49]), which emphasize hierarchical access control and role-based authentication mechanisms within the **Automation Pyramid** ([42]). Specifically, **Digital Shadows** (a concept introduced in [42]) are employed at multiple levels of the pyramid to ensure **fail-safe mechanisms** and **threat mitigation strategies**, including real-time monitoring of asset states and operational data. The **Asset Administration Shell (AAS)** ([46], [47], [50]) serves as a standardized framework for encapsulating asset metadata, operational data, and security policies, enabling **authentication systems** via **OAuth 2.0** and **JWT (JSON Web Tokens)** for secure communication ([50]). Additionally, the **Functional Mockup Interface (FMI)** ([51]) supports **tool-independent exchange of simulation models**, ensuring interoperability while maintaining **risk assessment approaches** through validated model-driven engineering methodologies ([43]). The system leverages **MQTT (Message Queuing Telemetry Transport)** via **Mosquitto** ([52]) for lightweight, secure IoT communication, and **Thingsboard (v4.0.0)** ([53]) provides **access control mechanisms** (e.g., RBAC) and **data encryption** for IoT device integration. Safety-critical considerations are addressed through **structured learning of robot dynamics** ([45]), including **friction modeling** for predictive maintenance and failure prevention in robotic systems (e.g., **MABI robotic arms** ([44]))."
]