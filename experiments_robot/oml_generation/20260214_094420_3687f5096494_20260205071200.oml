// C3: Physical sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder providing absolute angle of the permanent‑magnet synchronous motor."
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Gearbox encoder providing absolute angle of the gearbox output."
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor supplied by the Siemens SINUMERIK controller measuring current I_M."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Torque sensor providing back‑EMF derived torque measurement τ."
    DTDFVocab:producedData TorqueDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted over MQTT)
instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
]

// C4: Data (processed inside DT)
instance MotorAngleData : DTDFVocab:Data [
    base:desc "Measured motor angle received via MQTT."
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo MatlabSimulinkEnabler
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Measured gearbox output angle received via MQTT."
    DTDFVocab:fromData GearboxAngleDataTransmitted
    DTDFVocab:inputTo MatlabSimulinkEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current I_M received via MQTT."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MatlabSimulinkEnabler
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Measured back‑EMF derived torque τ received via MQTT."
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo MatlabSimulinkEnabler
]

instance FrictionEstimateData : DTDFVocab:Data [
    base:desc "Aggregated friction estimates derived from simulation models."
    DTDFVocab:inputTo DashboardEngineEnabler
]

// C11: Enablers
instance MatlabSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for MATLAB/Simulink simulation models implementing Coulomb‑Viscous, Stribeck, Dahl, and LuGre friction models."
    DTDFVocab:enables FrictionMonitoringService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating live telemetry streaming from PT to DT."
    DTDFVocab:enables FrictionMonitoringService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) for asset description and context management."
    DTDFVocab:enables FrictionMonitoringService
]

instance DashboardEngineEnabler : DTDFVocab:Enabler [
    base:desc "Custom web‑UI dashboard engine (e.g., Chart.js) for real‑time visualization."
    DTDFVocab:enables FrictionMonitoringService
]

// C10: Models/Data
instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "SysML structural model of the first vertical axis (motor, gearbox, cycloidal gearbox)."
    DTDFVocab:inputTo AssetAdministrationShellEnabler
]

instance SimModelMotorFriction : DTDFVocab:Model [
    base:desc "Simulink model of motor dynamics with Coulomb‑Viscous, Stribeck, Dahl, and LuGre friction."
    DTDFVocab:inputTo MatlabSimulinkEnabler
]

instance SimModelGearboxFriction : DTDFVocab:Model [
    base:desc "Simulink model of gearbox dynamics incorporating friction characteristics."
    DTDFVocab:inputTo MatlabSimulinkEnabler
]

instance SimModelAxisFriction : DTDFVocab:Model [
    base:desc "Simulink model of overall axis dynamics integrating motor and gearbox friction."
    DTDFVocab:inputTo MatlabSimulinkEnabler
]

// C6: Services
instance FrictionMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time visualization and continuous friction identification service for the first axis of the MABI MAX 100 robot."
    DTDFVocab:provides FrictionEstimatesInsight, TorqueComparisonInsight, AdjustControlParametersAction, PositionalAccuracyImprovementInsight
]

// C17: Insights
instance FrictionEstimatesInsight : DTDFVocab:Insight [
    base:desc "Real‑time friction estimates and trend analysis for the first vertical axis."
]

instance TorqueComparisonInsight : DTDFVocab:Insight [
    base:desc "Online comparison between simulated and measured torques."
]

instance PositionalAccuracyImprovementInsight : DTDFVocab:Insight [
    base:desc "Improved positional accuracy from 0.1 mm after friction model updates."
]

// C17: Actions
instance AdjustControlParametersAction : DTDFVocab:Action [
    base:desc "Manual adjustment of control parameters and maintenance scheduling based on friction insights."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Not in Document. The digital shadow does not send commands or data back to the physical robot; it operates as a purely passive observation layer."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization at the sample rate of the sensor data (typically hundreds of Hz for motor current and encoder signals). The DT updates friction models in real‑time as new data arrive."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized digital shadow comprising: physical robot axis (motor, gearboxes), MQTT data sources (encoders, current), a Processing component that consumes sensor traces, executes Simulink simulation models (motor, gearwheel, gearbox, friction), generates derived data traces, and exposes results through an AAS‑backed interface and a visualization dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the ‘as designed’ stage (ideal frictionless simulation models), the ‘as manufactured’ stage (parametric models calibrated with manufacturer data), and the ‘as operated’ stage (online friction identification from live measurements)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fine‑grained traceability links each data trace to its originating source and processing component, enabling verification of the simulation against measured data and identification of deviations. Continuous comparison between simulated and measured torques quantifies model validity and informs online parameter updates. Uncertainty not quantified explicitly but can be inferred from residuals between measured and simulated values."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual data flows over MQTT (publish/subscribe). The DT subscribes to encoder and current topics and publishes processed friction estimates on separate topics consumed by the dashboard. No explicit OPC UA or Ethernet‑Industrial links are mentioned."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Not in Document. The implementation details of the host environment, cloud versus on‑premise, and scaling considerations are not specified."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not in Document. No mention of integration with external systems or other digital twins."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not in Document. Data ownership, privacy policies, and rights are not discussed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to MBSE standards: SysML for modeling, Asset Administration Shell (AAS) for asset description, and the Digital Shadow Reference Model (DSRM). The simulation environment uses MATLAB/Simulink, an industry‑accepted modeling tool."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Not in Document. No explicit cybersecurity or safety‑critical considerations are mentioned."
]