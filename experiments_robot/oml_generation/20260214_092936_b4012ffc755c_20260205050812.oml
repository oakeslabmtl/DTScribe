// C3: Physical sensing components
instance MotorElectricalCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Actuator input electrical current sensor feeding real‑time telemetry"
    DTDFVocab:producedData MotorElectricalCurrentDataTransmitted
]

instance RotationalAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Joint rotational angle sensor measuring output angle in real‑time"
    DTDFVocab:producedData RotationalAngleDataTransmitted
]

// C4: DataTransmitted
instance MotorElectricalCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorElectricalCurrentSensor
]

instance RotationalAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RotationalAngleSensor
]

// C10: Models
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML component‑connector architecture for MABI MAX 100 robot"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SimulinkBehaviorModel : DTDFVocab:Model [
    base:desc "Simulink model simulating mechanical, electrical and control dynamics"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "Model aggregating time‑series sensor traces and contextual metadata"
    DTDFVocab:inputTo MQTTCommunicationEnabler
]

instance MontiArcADLModel : DTDFVocab:Model [
    base:desc "MontiArc component‑connector ADL for hardware‑to‑virtual mapping"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL hierarchical model mapping physical components to virtual representations"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

// C10: Data
instance MotorElectricalCurrentTimeSeries : DTDFVocab:Data [
    base:desc "Aggregated time‑series of actuator electrical current collected via MQTT"
    DTDFVocab:inputTo MQTTCommunicationEnabler, SimulinkSimulationEnabler
    DTDFVocab:fromData MotorElectricalCurrentDataTransmitted
]

instance RotationalAngleTimeSeries : DTDFVocab:Data [
    base:desc "Aggregated time‑series of joint rotational angle recorded from sensor"
    DTDFVocab:inputTo MQTTCommunicationEnabler, SimulinkSimulationEnabler
    DTDFVocab:fromData RotationalAngleDataTransmitted
]

// C11: Enablers
instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink tool enabling behavioral simulation"
    DTDFVocab:enables JointFrictionIdentificationService
]

instance MQTTCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "MQTT publish/subscribe protocol enabling real‑time telemetry exchange"
    DTDFVocab:enables JointFrictionIdentificationService
]

// C6: Service
instance JointFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Multi‑physics identification service estimating joint friction by fusing kinematic, dynamic, and electromagnetic measurements"
    DTDFVocab:provides JointFrictionEstimationInsight, PublishDiagnosticsToDashboardAction, PublishParametersToMQTTAction
]

// C17: Insights/Actions
instance JointFrictionEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated joint friction coefficient derived from fused sensor data"
]

instance PublishDiagnosticsToDashboardAction : DTDFVocab:Action [
    base:desc "Publish processed diagnostics to web‑based dashboard for operator monitoring"
    DTDFVocab:IsAutomatic true
]

instance PublishParametersToMQTTAction : DTDFVocab:Action [
    base:desc "Publish raw telemetry and identified parameters via MQTT for real‑time visualization"
    DTDFVocab:IsAutomatic true
]

// C3: Component
instance MABI_MAX100_RobotPlatform : DTDFVocab:Component [
    base:desc "Industrial robot platform MABI MAX 100 operated by Siemens SINUMERIK 840D motion controller"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the Model‑Based Systems Engineering (MBSE) abstraction hierarchy: (1) Requirements phase, (2) Functional architecture, (3) Logical architecture, and (4) Product/technical layer.  At each level, different modeling notations and tools are employed.  Requirements are typically captured in textual or diagrammatic form.  Functional architecture is expressed with SysML, notably SysML Interaction Block Diagrams (IBDs) for component structure and inter‑connectivity.  Logical architecture is described using Architecture Description Languages (ADLs) such as ACME, AADL, or MontiArc, which capture components, interfaces, and connectors from a component‑and‑connector perspective.  The product/technical layer is realized with code (e.g., C++ or Java) or simulation models (e.g., MathWorks Simulink).  The document emphasizes that these phases are complementary and that a comprehensive Digital Twin may integrate models across multiple notations, although explicit transition management and governance mechanisms are not detailed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The twin’s technical connection is based on the MQTT publish/subscribe protocol, where the physical robot publishes telemetry to the 'robots/telemetry' topic and the digital twin subscribes to this feed. No explicit details on network topology, latency, bandwidth, redundancy, or security measures are provided in the documents supplied."
]