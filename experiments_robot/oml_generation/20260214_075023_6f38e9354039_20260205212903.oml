instance RobotJointCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Robot sensor measuring input current for joint friction monitoring"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance RobotJointAngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Robot sensor measuring angular velocity for joint friction monitoring"
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

instance RobotJointPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Robot sensor measuring position data for joint friction monitoring"
    DTDFVocab:producedData PositionDataTransmitted
]

instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotJointCurrentSensor
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotJointAngularVelocitySensor
]

instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotJointPositionSensor
]

instance CurrentData : DTDFVocab:Data [
    base:desc "Current data transmitted via MQTT protocol with JSON formatting"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo AASExecutorEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity data transmitted via MQTT protocol with JSON formatting"
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo AASExecutorEnabler
]

instance PositionData : DTDFVocab:Data [
    base:desc "Position data transmitted via MQTT protocol with JSON formatting"
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo AASExecutorEnabler
]

instance RealTimeMonitoringCompensationService : DTDFVocab:Service [
    base:desc "Real-time monitoring and compensation of internal joint friction and external machining forces via control system adjustments"
    DTDFVocab:provides ControlSystemAdjustment
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance and early fault detection through anomaly identification in friction data"
    DTDFVocab:provides FaultDetectionInsight
]

instance MachiningParameterOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of machining parameters for CO2 reduction and product quality prediction"
    DTDFVocab:provides CO2ReductionInsight, ProductQualityPredictionInsight
]

instance SimulativeExperimentationService : DTDFVocab:Service [
    base:desc "Simulative experimentation for process optimization before real-world execution"
    DTDFVocab:provides SimulationResultInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualization through interactive digital twin cockpits"
    DTDFVocab:provides InteractiveVisualizationInsight
]

instance MultiPurposeApplicationSupportService : DTDFVocab:Service [
    base:desc "Multi-purpose application support for sustainable manufacturing and quality control"
    DTDFVocab:provides SustainableManufacturingSupportInsight, QualityControlSupportInsight
]

instance ControlSystemAdjustment : DTDFVocab:Action [
    base:desc "Adjust control system parameters for real-time compensation of internal joint friction and external machining forces"
    DTDFVocab:IsAutomatic true
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Early fault detection through anomaly identification in friction data"
]

instance CO2ReductionInsight : DTDFVocab:Insight [
    base:desc "Optimization of machining parameters for CO2 reduction"
]

instance ProductQualityPredictionInsight : DTDFVocab:Insight [
    base:desc "Product quality prediction based on machining parameter optimization"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Results from simulative experimentation for process optimization before real-world execution"
]

instance InteractiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive digital twin cockpit visualization for system monitoring"
]

instance SustainableManufacturingSupportInsight : DTDFVocab:Insight [
    base:desc "Support for sustainable manufacturing processes"
]

instance QualityControlSupportInsight : DTDFVocab:Insight [
    base:desc "Support for quality control in manufacturing"
]

instance ThingsboardEnabler : DTDFVocab:Enabler [
    base:desc "Thingsboard platform for data storage and visualization"
    DTDFVocab:enables VisualizationService
]

instance AASExecutorEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell Executor for populating measured, simulated, and reference values"
    DTDFVocab:enables RealTimeMonitoringCompensationService, PredictiveMaintenanceService, MachiningParameterOptimizationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for physics-based simulations"
    DTDFVocab:enables SimulativeExperimentationService
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for system architecture modeling"
    DTDFVocab:enables SimulativeExperimentationService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL for system architecture modeling"
    DTDFVocab:enables SimulativeExperimentationService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME for system architecture modeling"
    DTDFVocab:enables SimulativeExperimentationService
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArcAutomaton for system architecture modeling"
    DTDFVocab:enables SimulativeExperimentationService
]

instance DEVSEnabler : DTDFVocab:Enabler [
    base:desc "DEVS for discrete-event simulation"
    DTDFVocab:enables SimulativeExperimentationService
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Physics-based white-box model using Simulink for dynamic simulations of robotic joints"
    DTDFVocab:inputTo SimulinkEnabler
]

instance FrictionAdaptationMLModel : DTDFVocab:Model [
    base:desc "Data-driven black-box machine learning model for friction adaptation using neural networks"
    DTDFVocab:inputTo AASExecutorEnabler
]

instance StructuralEngineeringModel : DTDFVocab:Model [
    base:desc "Engineering model describing structural aspects of robotic joints"
    DTDFVocab:inputTo SysMLEnabler
]

instance PropertyEngineeringModel : DTDFVocab:Model [
    base:desc "Engineering model describing property aspects of robotic joints"
    DTDFVocab:inputTo SysMLEnabler
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulation model for discrete-event simulation of machining processes"
    DTDFVocab:inputTo DEVSEnabler
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Data calculation model for higher-level abstractions of machining parameters"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SysMLArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based system architecture model for robotic machining system"
    DTDFVocab:inputTo SysMLEnabler
]

instance UMLReferenceModel : DTDFVocab:Model [
    base:desc "UML-based reference model for structured data traceability and conformance relations"
    DTDFVocab:inputTo SysMLEnabler
]

instance RoboticMachiningSystemEnvironment : DTDFVocab:Environment [
    base:desc "Industrial robotic machining system with real-time control requirements"
    base:contains RoboticJoint, ControlSystem, MachiningTool
]

instance RoboticJoint : DTDFVocab:Component [
    base:desc "Robotic joint with dynamic friction behavior affected by operational conditions, loads, and environmental factors"
]

instance ControlSystem : DTDFVocab:Component [
    base:desc "Control system for real-time compensation of internal joint friction and external machining forces"
]

instance MachiningTool : DTDFVocab:Component [
    base:desc "Machining tool used in high-precision manufacturing processes"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with physical system data, where friction model parameters are dynamically updated during runtime to compensate for control system dead time, ensuring continuous adaptation to changing operational conditions."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated through an Asset Administration Shell (AAS) integrating SysML structural models and Simulink behavioral models via Functional Mock-up Interface (FMI), with data flow managed by ThingsBoard and MQTT protocols for real-time monitoring and visualization. The system includes a pipeline that processes live robot data, runs simulations, and updates the digital shadow with traceable data linking to computation methods."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through traceability and verification of transformations (e.g., from SysML to simulation models), with reliability dependent on model correctness. Dynamic adaptation of physics-based and data-driven friction models occurs via automatic parameter updates and neural network retraining as new data arrives, compensating for wear, temperature changes, or varying payloads. Anomaly detection in friction behavior enables predictive maintenance and early fault detection, reducing trajectory errors and enhancing system reliability. Fine-grained traceability of data traces to their generating components and models supports continuous quality assurance."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT publish-subscribe architecture with hierarchical topics; ThingsBoard as IoT data storage platform; security implemented through topic-based read/write permissions; no specific bandwidth, latency, or redundancy details provided."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration via Asset Administration Shell (AAS) for Industry 4.0 interoperability, utilizing MQTT for IoT data communication and ThingsBoard for visualization, with SysML and Simulink models integrated through Functional Mock-up Interface (FMI) for multi-domain modeling. Data exchange adheres to standardized protocols ensuring seamless connectivity with external IoT devices and enterprise systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system employs Model-Based Systems Engineering (MBSE) standards including SysML [17] for system modeling, ACME [23], AADL [24], and MontiArc [25], [26] as architecture description languages (ADLs) for component & connector perspectives, and adheres to reference model conformance relations [41] to ensure structured development and interoperability."
]