    base:desc "Continuous monitoring service providing real-time manufacturing process visualization and alerts"
]

instance PerformanceOptimizationService : DTDFVocab:Service [
    base:desc "Service analyzing process metrics to recommend optimization actions based on digital twin insights"
]

