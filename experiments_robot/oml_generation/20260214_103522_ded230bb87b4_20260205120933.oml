// C2: Acting Components
instance ManufacturingProcessController : DTDFVocab:ActingComponent [
    base:desc "Centralized controller managing digital twin coordination in manufacturing environment"
]

instance SimulationEngine : DTDFVocab:ActingComponent [
    base:desc "Simulation tool (e.g., MathWorks Simulink) executing dynamic behavior models for DT validation"
]

instance DataAggregator : DTDFVocab:ActingComponent [
    base:desc "Middleware component aggregating contextual data traces from digital shadows for specific manufacturing purposes"
]

// C3: Physical sensing components
instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental monitoring sensors collecting process conditions (temperature, humidity, pressure)"
]

instance MotionSensor : DTDFVocab:SensingComponent [
    base:desc "Motion tracking sensors capturing operational movement patterns in manufacturing cells"
]

instance ProcessVariableSensor : DTDFVocab:SensingComponent [
    base:desc "Process parameter sensors measuring real-time manufacturing process variables"
]

// C4: Physical-to-virtual interaction
instance EnvironmentalDataTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance MotionDataTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionSensor
]

instance ProcessVariableDataTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProcessVariableSensor
]

// C10: Models/Data
instance ManufacturingProcessModel : DTDFVocab:Model [
    base:desc "Behavioral model capturing manufacturing process dynamics using MontiArc automata or SysML state machines"
]

instance DigitalShadowAggregator : DTDFVocab:Model [
    base:desc "Contextual data aggregation framework processing digital shadow traces for specific manufacturing purposes"
]

instance ProcessPerformanceMetrics : DTDFVocab:Data [
    base:desc "Aggregated manufacturing performance metrics derived from raw sensor data traces"
    DTDFVocab:fromData EnvironmentalDataTrace, MotionDataTrace, ProcessVariableDataTrace
]

instance OperationalContextData : DTDFVocab:Data [
    base:desc "Contextual data traces representing operational context for digital twin alignment"
    DTDFVocab:fromData EnvironmentalDataTrace
]

// C11: Enablers
