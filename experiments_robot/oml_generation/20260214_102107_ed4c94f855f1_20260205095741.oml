// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving the robot's first axis with operational limits constrained by current and RPM specifications."
]

instance CycloidalPrimaryGearbox : DTDFVocab:ActingComponent [
    base:desc "Primary gearbox with low gear ratio (≤1:100) to reduce motor speed and increase torque, incorporating mechanical backlash mitigation via sensor feedback."
]

instance RobotAxisController : DTDFVocab:ActingComponent [
    base:desc "Closed-loop control system for friction compensation and precise positioning, leveraging encoder feedback loops."
]

// C3: Physical Sensing Components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution encoder mounted directly on the motor shaft to measure input angular position for closed-loop control."
    DTDFVocab:producedData MotorShaftPositionData
]

instance GearboxOutputEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearbox to measure output angle with high resolution for precise positioning."
    DTDFVocab:producedData GearboxOutputPositionData
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input current to the permanent magnet synchronous motor for operational monitoring and torque estimation."
    DTDFVocab:producedData MotorCurrentData
]

// C4: Physical-to-Virtual Interaction
instance MotorShaftPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxOutputPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxOutputEncoder
]

instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Models/Data
instance SysMLInternalBlockDiagram : DTDFVocab:Model [
    base:desc "SysML IBD for component & connector perspectives describing system structure and interconnections (e.g., motor, gearbox, encoders)."
    DTDFVocab:inputTo SysMLToolchainEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "Behavioral model using MontiArc Automaton to describe state machines for control logic and system behavior."
    DTDFVocab:inputTo MontiArcEnabler
]

instance SimulinkControlModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for detailed behavioral simulation of dynamic systems, control logic, and hybrid modeling."
    DTDFVocab:inputTo SimulinkEnabler
]

instance RobotAxisFunctionalArchitecture : DTDFVocab:Model [
    base:desc "Functional architecture model describing requirements, functions, and logical components of the robot axis system."
    DTDFVocab:inputTo SysMLToolchainEnabler
]

instance MotorGearboxTorqueModel : DTDFVocab:Model [
    base:desc "Physics-based model for torque transmission through the gearbox, including backlash and friction compensation."
    DTDFVocab:inputTo SimulinkEnabler
]

instance SensorDataAggregationModel : DTDFVocab:Model [
    base:desc "Model for aggregating and contextualizing sensor data traces (e.g., motor currents, encoder angles) into actionable insights."
    DTDFVocab:inputTo DataProcessingEnabler
]

instance MotorCurrentDataInstance : DTDFVocab:Data [
    base:desc "Time-series data of input current to the permanent magnet synchronous motor, used for torque estimation and operational monitoring."
    DTDFVocab:fromData MotorCurrentData
    DTDFVocab:inputTo DataProcessingEnabler, SimulinkEnabler
]

instance MotorShaftPositionDataInstance : DTDFVocab:Data [
    base:desc "High-resolution angular position data from the motor shaft encoder, critical for closed-loop control and model validation."
    DTDFVocab:fromData MotorShaftPositionData
    DTDFVocab:inputTo DataProcessingEnabler, ControlLogicEnabler
]

instance GearboxOutputPositionDataInstance : DTDFVocab:Data [
    base:desc "High-resolution output angle data from the gearbox encoder, ensuring precise positioning and feedback for control adjustments."
    DTDFVocab:fromData GearboxOutputPositionData
    DTDFVocab:inputTo DataProcessingEnabler, ControlLogicEnabler
]

instance ControllerLogData : DTDFVocab:Data [
    base:desc "Operational logs from the Siemens SINUMERIK 840D sl controller, including motion commands and system states."
    DTDFVocab:inputTo DataProcessingEnabler
]

// C11: Enablers
instance SysMLToolchainEnabler : DTDFVocab:Enabler [
    base:desc "SysML toolchain for multi-layered system description (requirements, functional/logical architectures) and IBD modeling."
    DTDFVocab:enables ArchitectureValidationService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc framework for component-based system modeling with behavioral extensions via state machines/automata."
    DTDFVocab:enables ControlLogicService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed behavioral simulation, hybrid modeling, and control logic implementation."
    DTDFVocab:enables SimulationService, ControlLogicService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Software agents and algorithms (e.g., implemented in C++/Java) for interpreting and processing sensor/operational data traces."
    DTDFVocab:enables DataInterpretationService, VisualizationService
]

instance MQTTProtocolEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol for real-time streaming of time-series sensor data (e.g., motor currents, encoder angles) from physical to digital systems."
    DTDFVocab:enables DataTransmissionService
]

instance ControlLogicEnabler : DTDFVocab:Enabler [
    base:desc "General-purpose programming languages (C++/Java) for implementing custom control logic, feedback mechanisms, and optimization algorithms."
    DTDFVocab:enables ClosedLoopControlService, FrictionCompensationService
]

// C6: Services
instance DataInterpretationService : DTDFVocab:Service [
    base:desc "Processing and contextualizing sensor/operational data traces (e.g., motor currents, gearbox torque, controller logs) to derive actionable insights."
    DTDFVocab:provides SensorDataInsight, OperationalStateInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Rendering system states and operational metrics in real-time dashboards for stakeholders (e.g., engineers, operators)."
    DTDFVocab:provides RealTimeDashboardInsight
]

instance BehavioralAnalysisService : DTDFVocab:Service [
    base:desc "Leveraging model-based abstractions (functional/logical architectures) to simulate and validate system behavior under varying conditions."
    DTDFVocab:provides SystemBehaviorInsight, ValidationResultInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Executing detailed behavioral simulations (e.g., dynamic systems, control logic) using MathWorks Simulink and other simulation engines."
    DTDFVocab:provides SimulationResultInsight
]

instance DataTransmissionService : DTDFVocab:Service [
    base:desc "Streaming time-series data (e.g., input current, output angle) via MQTT protocol for real-time monitoring and analysis."
    DTDFVocab:provides DataStreamInsight
]

instance ClosedLoopControlService : DTDFVocab:Service [
    base:desc "Implementing closed-loop control systems with encoder feedback for precise positioning and friction compensation."
    DTDFVocab:provides PositionalAccuracyInsight, ControlStabilityInsight
]

instance FrictionCompensationService : DTDFVocab:Service [
    base:desc "Applying friction compensation models to mitigate mechanical backlash and improve system performance."
    DTDFVocab:provides FrictionModelInsight
]

instance ArchitectureValidationService : DTDFVocab:Service [
    base:desc "Validating system architecture and component interconnections using SysML IBDs and ADLs."
    DTDFVocab:provides ArchitectureConsistencyInsight
]

instance ControlLogicService : DTDFVocab:Service [
    base:desc "Developing and deploying control logic for the robot axis using MontiArc Automaton and Simulink."
    DTDFVocab:provides ControlLogicInsight
]

// C17: Insights/Actions
instance SensorDataInsight : DTDFVocab:Insight [
    base:desc "Contextualized sensor data traces (e.g., motor currents, encoder angles) for operational monitoring and diagnostics."
]

instance OperationalStateInsight : DTDFVocab:Insight [
    base:desc "Derived operational state of the robot axis, including torque, speed, and positional accuracy."
]

instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Visual representation of system states and operational metrics for real-time stakeholder monitoring."
]

instance SystemBehaviorInsight : DTDFVocab:Insight [
    base:desc "Simulated system behavior under varying conditions, validated against model-based abstractions."
]

instance ValidationResultInsight : DTDFVocab:Insight [
    base:desc "Results of behavioral analysis and validation, indicating system compliance with requirements."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Outputs from detailed behavioral simulations, including dynamic responses and control performance."
]

instance DataStreamInsight : DTDFVocab:Insight [
    base:desc "Real-time stream of sensor data (e.g., input current, output angle) for monitoring and analysis."
]

instance PositionalAccuracyInsight : DTDFVocab:Insight [
    base:desc "Assessment of positional accuracy achieved through closed-loop control with encoder feedback."
]

instance ControlStabilityInsight : DTDFVocab:Insight [
    base:desc "Evaluation of control system stability and responsiveness under operational conditions."
]

instance FrictionModelInsight : DTDFVocab:Insight [
    base:desc "Model of friction and backlash effects in the gearbox, used for compensation and performance optimization."
]

instance ArchitectureConsistencyInsight : DTDFVocab:Insight [
    base:desc "Validation of system architecture and component interconnections for consistency and correctness."
]

instance ControlLogicInsight : DTDFVocab:Insight [
    base:desc "Developed control logic for the robot axis, including state machines and optimization algorithms."
]

// C1: Environment (Physical System)
instance MabiMax100RobotAxisEnvironment : DTDFVocab:Environment [
    base:desc "Physical environment of the MABI MAX 100 industrial serial robot's first axis, including permanent magnet synchronous motor, gearbox, and Siemens SINUMERIK 840D sl controller."
    base:contains PermanentMagnetSynchronousMotor, CycloidalPrimaryGearbox, MotorShaftEncoder, GearboxOutputEncoder, MotorCurrentSensor, RobotAxisController
]

// C5: Components (Physical System)
instance MabiMax100RobotAxis : DTDFVocab:Component [
    base:desc "First axis of the MABI MAX 100 industrial serial robot, comprising motor, gearbox, encoders, and controller for precise motion control."
    base:isContainedIn MabiMax100RobotAxisEnvironment
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin constellation** is orchestrated through **Model-Based Systems Engineering (MBSE)** methodologies, which integrate multiple modeling notations (e.g., SysML for architecture, MontiArc Automaton for behavior, or Simulink for simulation) and tools (e.g., C++, Java, or general-purpose languages). The system leverages **architecture description languages (ADLs)** like ACME, AADL, or SysML Internal Block Diagrams (IBDs) to define components, interfaces, interconnections, and composition. Coordination mechanisms are implied by the **component & connector perspective** of ADLs, where behavior is described via state machines (SysML v1.7) or automata (MontiArc). Resource management is not explicitly detailed, but the integration of heterogeneous tools and stakeholders (Section II.A) suggests a federated or service-oriented architecture pattern. No explicit system-wide coordination protocols (e.g., event-driven, publish-subscribe) are mentioned."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system’s **fidelity and validity** are implicitly addressed through:
  - **Model validation** via comparison of **simulated behavior** (using tools like **SysML** and **Simulink**) with **measured physical data** (e.g., sensor streams from encoders and current inputs) to derive and refine parameters such as **friction models** (as inferred from Section IV’s focus on data-driven corrections).
  - **Uncertainty quantification** is implied through the use of **data aggregation and abstraction** (per the Digital Shadow Reference Model) to filter noise and inconsistencies in sensor data before integration into the Digital Twin.
  - **Quality assurance** processes are suggested by the integration of **MBSE methodologies** (e.g., SysML, ADLs) and **simulation tools**, which enforce structured validation and verification (V&V) workflows. However, explicit details on **fidelity requirements**, **error correction mechanisms**, or **formal uncertainty quantification** are not provided in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **hosting and deployment infrastructure** for the Digital Shadow system is implicitly tied to **Model-Based Systems Engineering (MBSE)** methodologies and tools, which may include **SysML** for modeling, **Simulink** or other simulation tools for behavioral analysis, and general-purpose languages like **C++ or Java** for implementation. However, no explicit details are provided regarding **hosting platforms** (e.g., cloud, edge, or on-premise), **computational/storage requirements**, **scalability mechanisms**, or **deployment models**. The document focuses on modeling and abstraction rather than infrastructure specifics, leaving these aspects undocumented."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system relies on **MQTT** for **real-time sensor data streaming** from the physical object (e.g., robot axis) to the digital shadow, ensuring **low-latency, event-driven communication**. Integration with **external modeling tools** (e.g., Simulink, C++, Java) and **heterogeneous stakeholders** is critical, as the system must aggregate and abstract **contextual data traces** for specific purposes. While the document does not specify **interoperability standards** beyond MQTT, it implies dependencies on **standardized data exchange protocols** (e.g., OPC UA, REST, or proprietary APIs) for broader enterprise system or Digital Twin ecosystem integration. No explicit mention of **blockchain, edge computing, or cloud orchestration** is provided."
]