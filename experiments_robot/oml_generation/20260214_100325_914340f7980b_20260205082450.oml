// C3: Physical sensing components (implied via Digital Shadow)
instance IoTSensorDataCollector : DTDFVocab:SensingComponent [
    base:desc "Automated collection of contextual data traces from physical system via IoT sensors/PLCs as per Digital Shadow Reference Model [32]. Handles raw data acquisition without autonomous operation."
    DTDFVocab:producedData IoTSensorDataTransmitted
]

instance OperationalLogCollector : DTDFVocab:SensingComponent [
    base:desc "Collects operational logs and environmental parameters from physical system components. Part of one-way data flow to Digital Shadow."
    DTDFVocab:producedData OperationalDataTransmitted
]

instance EnvironmentalParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Senses environmental parameters (e.g., temperature, pressure) from physical system for Digital Shadow aggregation."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// C4: Physical-to-virtual interaction
instance IoTSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IoTSensorDataCollector
]

instance OperationalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalLogCollector
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalParameterSensor
]

// C10: Models/Data
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "Multi-layered system description using SysML for requirements, architecture, and behavior (state machines in v1.7). Implicit geometric representation."
    DTDFVocab:inputTo SysMLFrameworkEnabler, ModelIntegrationFramework
]

instance ACMEComponentModel : DTDFVocab:Model [
    base:desc "Component-connector-based modeling using ACME ADL for interfaces, composition, and behavioral extensions."
    DTDFVocab:inputTo ACMEFrameworkEnabler, ModelIntegrationFramework
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "Architecture description using AADL for component-connector relationships and system integration."
    DTDFVocab:inputTo AADLFrameworkEnabler, ModelIntegrationFramework
]

instance MontiArcBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral modeling using MontiArc with MontiArc Automaton for state-based behavior and component interactions."
    DTDFVocab:inputTo MontiArcFrameworkEnabler, ModelIntegrationFramework
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Detailed behavioral modeling and dynamic simulation using MathWorks Simulink for system components."
    DTDFVocab:inputTo SimulinkEnabler, ModelIntegrationFramework
]

instance CppJavaControlImplementation : DTDFVocab:Model [
    base:desc "Low-level implementation of system logic/control algorithms in C++ or Java for execution."
    DTDFVocab:inputTo CodeExecutionEnabler, ModelIntegrationFramework
]

instance AggregatedContextualData : DTDFVocab:Data [
    base:desc "Processed and abstracted data from raw sensor/operational logs via Digital Shadow aggregation layers."
    DTDFVocab:fromData IoTSensorDataTransmitted, OperationalDataTransmitted, EnvironmentalDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, ModelIntegrationFramework
]

instance TimeSeriesSensorData : DTDFVocab:Data [
    base:desc "Time-series database storage of validated sensor data for DT analysis."
    DTDFVocab:fromData IoTSensorDataTransmitted
    DTDFVocab:inputTo TimeSeriesDatabaseEnabler, DataProcessingEnabler
]

instance FeatureExtractedData : DTDFVocab:Data [
    base:desc "Feature-extracted data from raw traces for actionable insights in DT."
    DTDFVocab:fromData OperationalDataTransmitted
    DTDFVocab:inputTo FeatureExtractionEnabler, DataProcessingEnabler
]

// C11: Enablers
instance SysMLFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling framework for multi-layered system description (requirements, architecture, behavior)."
    DTDFVocab:enables SysMLModelingService
]

instance ACMEFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component-connector modeling and behavioral extensions."
    DTDFVocab:enables ComponentModelingService
]

instance AADLFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "AADL for architecture analysis and design with component-connector relationships."
    DTDFVocab:enables SystemIntegrationService, ArchitectureValidationService
]

instance MontiArcFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc with MontiArc Automaton for state-based behavioral modeling."
    DTDFVocab:enables BehavioralSimulationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed behavioral modeling and dynamic simulation."
    DTDFVocab:enables DynamicSimulationService, ControlAlgorithmDevelopmentService
]

instance CodeExecutionEnabler : DTDFVocab:Enabler [
    base:desc "Execution environment for C++/Java implementations of control logic."
    DTDFVocab:enables ControlExecutionService, LowLevelImplementationService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Aggregation/abstraction layers processing raw data into actionable DT insights."
    DTDFVocab:enables DataValidationService, FeatureExtractionService
]

instance TimeSeriesDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database for storing validated sensor data traces."
    DTDFVocab:enables HistoricalDataQueryService, TrendAnalysisService
]

instance FeatureExtractionEnabler : DTDFVocab:Enabler [
    base:desc "Tools for extracting features from raw data traces for DT analysis."
    DTDFVocab:enables PatternRecognitionService, AnomalyDetectionService
]

instance ModelIntegrationFramework : DTDFVocab:Enabler [
    base:desc "Framework for consolidating heterogeneous models (SysML, ADLs, simulation tools) into unified DT representation."
    DTDFVocab:enables HeterogeneousModelIntegrationService
]

// C6: Services
instance SysMLModelingService : DTDFVocab:Service [
    base:desc "Multi-layered system modeling using SysML across requirements, architecture, and behavior."
    DTDFVocab:provides SystemRequirementsInsight, ArchitecturalDesignInsight
]

instance ComponentModelingService : DTDFVocab:Service [
    base:desc "Component-connector modeling using ACME ADL for system decomposition."
    DTDFVocab:provides ComponentDecompositionInsight, InterfaceSpecificationInsight
]

instance BehavioralSimulationService : DTDFVocab:Service [
    base:desc "Behavioral simulation using MontiArc Automaton and Simulink for dynamic system analysis."
    DTDFVocab:provides DynamicBehaviorInsight, StateTransitionInsight
]

instance DynamicSimulationService : DTDFVocab:Service [
    base:desc "Detailed dynamic simulation of system components using Simulink."
    DTDFVocab:provides SimulationResultsInsight, ControlAlgorithmValidationInsight
]

instance ControlExecutionService : DTDFVocab:Service [
    base:desc "Execution of control logic implemented in C++/Java for physical system interaction."
    DTDFVocab:provides ControlExecutionInsight, RealTimeCommandAction
]

instance DataValidationService : DTDFVocab:Service [
    base:desc "Validation and filtering of raw sensor/operational data for quality assurance."
    DTDFVocab:provides DataQualityInsight, AnomalyDetectionInsight
]

instance FeatureExtractionService : DTDFVocab:Service [
    base:desc "Extraction of meaningful features from raw data traces for DT analysis."
    DTDFVocab:provides FeaturePatternsInsight, DataAbstractionInsight
]

instance SystemIntegrationService : DTDFVocab:Service [
    base:desc "Service for integrating system components and validating architecture."
    DTDFVocab:provides SystemIntegrationInsight
]

instance ArchitectureValidationService : DTDFVocab:Service [
    base:desc "Service for validating architecture models and designs."
    DTDFVocab:provides ArchitectureValidationInsight
]

instance StateMachineModelingService : DTDFVocab:Service [
    base:desc "Service for modeling state machines and behavioral states."
    DTDFVocab:provides StateTransitionInsight
]

instance ControlAlgorithmDevelopmentService : DTDFVocab:Service [
    base:desc "Service for developing and validating control algorithms."
    DTDFVocab:provides ControlAlgorithmValidationInsight
]

instance LowLevelImplementationService : DTDFVocab:Service [
    base:desc "Service for implementing low-level control logic in C++/Java."
    DTDFVocab:provides LowLevelImplementationInsight
]

instance HistoricalDataQueryService : DTDFVocab:Service [
    base:desc "Service for querying historical sensor data."
    DTDFVocab:provides HistoricalDataInsight
]

instance TrendAnalysisService : DTDFVocab:Service [
    base:desc "Service for analyzing trends in sensor data."
    DTDFVocab:provides TrendAnalysisInsight
]

instance PatternRecognitionService : DTDFVocab:Service [
    base:desc "Service for recognizing patterns in data traces."
    DTDFVocab:provides FeaturePatternsInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Service for detecting anomalies in system data."
    DTDFVocab:provides AnomalyDetectionInsight
]

instance HeterogeneousModelIntegrationService : DTDFVocab:Service [
    base:desc "Integration of models from diverse notations/tools (SysML, ADLs, simulation) into unified DT."
    DTDFVocab:provides ModelConsistencyInsight
]

