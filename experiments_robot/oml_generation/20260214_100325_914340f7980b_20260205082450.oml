]

instance ControlExecutionInsight : DTDFVocab:Insight [
    base:desc "Insights about control execution performance and behavior."
]

instance LowLevelImplementationInsight : DTDFVocab:Insight [
    base:desc "Insights about low-level implementation details and performance."
]

