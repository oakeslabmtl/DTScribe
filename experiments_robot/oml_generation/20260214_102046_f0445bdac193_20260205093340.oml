// C3: Physical Sensing Components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution motor encoder mounted directly on the motor shaft providing sub-millimeter positional feedback for the MABI MAX 100's first vertical axis."
    DTDFVocab:producedData MotorShaftPositionData
]

instance GearboxSecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearbox for the MABI MAX 100's first vertical axis, providing redundant high-resolution positional feedback with sub-millimeter precision."
    DTDFVocab:producedData GearboxPositionData
]

// C4: Physical-to-Virtual Interaction
instance MotorShaftPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
    base:desc "Time-series rotational position data streamed from the motor shaft encoder via MQTT protocol."
]

instance GearboxPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxSecondaryEncoder
    base:desc "Time-series rotational position data streamed from the gearbox secondary encoder via MQTT protocol."
]

instance CombinedAxisPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder, GearboxSecondaryEncoder
    base:desc "Aggregated time-series data combining motor shaft and gearbox encoder readings for comprehensive axis position tracking."
]

// C10: Models/Data
instance SysMLComponentConnectorModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) representing the component and connector architecture of the MABI MAX 100's first vertical axis, capturing structural relationships between mechanical and electrical subsystems."
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLLogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML IBD for logical architecture representation of the MABI MAX 100's first vertical axis, aligning with Model-Based Systems Engineering (MBSE) methodologies."
    DTDFVocab:inputTo SysMLEnabler
]

instance FrictionBehaviorSimulationModel : DTDFVocab:Model [
    base:desc "Executable MathWorks MATLAB Simulink model simulating friction behavior of the MABI MAX 100's first vertical axis, integrating sensor data for physical dynamics validation."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance AxisPositionTimeSeriesData : DTDFVocab:Data [
    base:desc "Processed time-series data representing rotational position, velocity, and acceleration of the MABI MAX 100's first vertical axis, aggregated from encoder streams."
    DTDFVocab:fromData MotorShaftPositionData, GearboxPositionData
    DTDFVocab:inputTo MATLABSimulinkEnabler, MQTTStreamingEnabler
]

instance FrictionAnalysisData : DTDFVocab:Data [
    base:desc "Derived data representing friction characteristics and mechanical behavior of the MABI MAX 100's first vertical axis, generated through simulation and sensor data integration."
    DTDFVocab:fromData AxisPositionTimeSeriesData
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML (Systems Modeling Language) implementation supporting MBSE methodologies for multi-abstraction modeling (requirements to physical layers) of the MABI MAX 100's first vertical axis."
    DTDFVocab:enables ArchitectureModelingService, LogicalDesignService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks MATLAB Simulink environment providing executable simulation models for friction behavior and physical dynamics validation of the MABI MAX 100's first vertical axis."
    DTDFVocab:enables FrictionSimulationService, DynamicAnalysisService
]

instance MQTTStreamingEnabler : DTDFVocab:Enabler [
    base:desc "MQTT (Message Queuing Telemetry Transport) protocol implementation enabling low-latency, bidirectional streaming of sensor time-series data from the physical robot to the digital shadow."
    DTDFVocab:enables RealTimeDataAcquisitionService, SensorDataStreamingService
]

// C6: Services
instance RealTimeDataAcquisitionService : DTDFVocab:Service [
    base:desc "Continuous monitoring and acquisition of real-time sensor data (position, velocity, acceleration) from the MABI MAX 100's first vertical axis via MQTT streaming."
    DTDFVocab:provides AxisStateInsight
]

instance SensorDataStreamingService : DTDFVocab:Service [
    base:desc "Low-latency streaming of time-series sensor data from the physical robot's first vertical axis to the digital shadow for real-time analysis."
    DTDFVocab:provides DataStreamQualityInsight
]

instance FrictionSimulationService : DTDFVocab:Service [
    base:desc "Executable simulation of friction behavior for the MABI MAX 100's first vertical axis using MATLAB Simulink models integrated with sensor data."
    DTDFVocab:provides FrictionCharacterizationInsight
]

instance DynamicAnalysisService : DTDFVocab:Service [
    base:desc "Dynamic system analysis of the MABI MAX 100's first vertical axis through simulation-based validation of physical behaviors."
    DTDFVocab:provides OperationalDynamicsInsight
]

instance ArchitectureModelingService : DTDFVocab:Service [
    base:desc "Structural and behavioral modeling of the MABI MAX 100's first vertical axis using SysML component and connector architecture."
    DTDFVocab:provides SystemArchitectureInsight
]

instance LogicalDesignService : DTDFVocab:Service [
    base:desc "Logical architecture representation of the MABI MAX 100's first vertical axis aligning with MBSE methodologies."
    DTDFVocab:provides LogicalSystemDesignInsight
]

// C17: Insights/Actions
instance AxisStateInsight : DTDFVocab:Insight [
    base:desc "Real-time operational state of the MABI MAX 100's first vertical axis including position, velocity, and acceleration metrics."
]

instance DataStreamQualityInsight : DTDFVocab:Insight [
    base:desc "Quality assessment of the sensor data streams from the MABI MAX 100's first vertical axis, including latency and synchronization metrics."
]

instance FrictionCharacterizationInsight : DTDFVocab:Insight [
    base:desc "Characterization of friction behavior in the MABI MAX 100's first vertical axis through simulation and sensor data integration."
]

instance OperationalDynamicsInsight : DTDFVocab:Insight [
    base:desc "Dynamic behavior analysis of the MABI MAX 100's first vertical axis including mechanical responses and control system interactions."
]

instance SystemArchitectureInsight : DTDFVocab:Insight [
    base:desc "Structural and behavioral architecture of the MABI MAX 100's first vertical axis as modeled in SysML."
]

instance LogicalSystemDesignInsight : DTDFVocab:Insight [
    base:desc "Logical design representation of the MABI MAX 100's first vertical axis components and their interactions."
]

// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor coupled with a cycloidal gear for the MABI MAX 100's first vertical axis, accepting position, speed, or acceleration control inputs."
]

instance CycloidalGearMechanism : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear mechanism for the MABI MAX 100's first vertical axis, providing precise motion regulation in conjunction with the permanent magnet synchronous motor."
]

// C1: System Under Study
instance MABIMAX100FirstVerticalAxis : DTDFVocab:SystemUnderStudy [
    base:desc "First vertical axis of the MABI MAX 100 serial industrial robot, selected for digital twinning due to its critical role in operational dynamics, specifically for modeling friction and mechanical behaviors."
    DTDFVocab:hasEnvironment ManufacturingAutomationEnvironment
]

instance MABIMAX100MechatronicSystem : DTDFVocab:System [
    base:desc "Mechatronic system combining mechanical, electrical, and control subsystems of the MABI MAX 100 industrial robot operating in manufacturing/industrial automation domain."
    DTDFVocab:hasEnvironment ManufacturingAutomationEnvironment
]

instance ManufacturingAutomationEnvironment : DTDFVocab:Environment [
    base:desc "Industrial automation environment where the MABI MAX 100 operates, requiring real-time sensor data collection and high-fidelity simulation for predictive maintenance and performance optimization."
    base:contains MABIMAX100FirstVerticalAxis, PermanentMagnetSynchronousMotor, CycloidalGearMechanism
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system operates within a temporal framework defined by the **automated one-way data flow** between the physical object and its digital representation, as described in the Digital Shadow Reference Model. While the document does not specify exact synchronization frequencies or latency requirements, it implies a **real-time, data-driven representation** where sensor data (e.g., from robot axes) is collected as **time series** and aggregated for specific purposes. The system's temporal granularity is tied to the **contextual data traces** captured over defined intervals, ensuring alignment between the physical state and its digital abstraction. No explicit mention of multi-scale time handling (e.g., microseconds for control vs. minutes for analytics) or service-specific time constraints (e.g., hard real-time vs. soft real-time) is provided in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin constellation** is implicitly addressed through **Model-Based Systems Engineering (MBSE)** frameworks, which rely on **architecture description languages (ADLs)** (e.g., ACME, AADL, MontiArc, SysML IBDs) to define component-based systems with interfaces, interconnections, and composition. Behavioral descriptions are extended via tools like **MathWorks Simulink**, simulation methods, or general-purpose languages (C++, Java). The **Digital Shadow Reference Model** (Fig. 1) focuses on passive data aggregation, but the broader **Digital Twin system** requires **active components** (e.g., autonomous processing units) to interpret and act on data, as highlighted by Kritzinger et al. [32]–[37]. Orchestration and coordination are not explicitly detailed, but the integration of **multiple modeling notations and tools** (e.g., SysML, ADLs, simulation tools) suggests a **heterogeneous, modular architecture** with potential for **resource management** via component-based orchestration patterns. No explicit mention of system-wide coordination mechanisms (e.g., middleware, event-driven architectures) is provided."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **dt_technical_connection** for the Digital Shadow system is primarily defined by a **one-way communication architecture** leveraging the **MQTT protocol** for streaming sensor data from physical assets to the digital representation. The document does not specify the **network topology** (e.g., star, mesh, or hierarchical) or **bandwidth/latency requirements**, though the use of MQTT suggests support for **low-bandwidth, high-frequency data transmission** typical in IoT deployments. No details are provided on **reliability mechanisms** (e.g., retransmission policies, QoS levels) or **security protocols** (e.g., TLS, authentication/authorization frameworks). The connection is inherently **unidirectional**, with no bidirectional or control-oriented communication pathways described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with external systems via **sensor data streaming protocols**, specifically **MQTT**, as referenced in the context of manufacturing use cases (e.g., robot axes). The document does not provide explicit details on **interoperability standards** (e.g., OPC UA, REST APIs) or **data exchange formats** (e.g., JSON, XML), but it confirms the use of **lightweight, publish-subscribe messaging** for real-time data acquisition. Dependencies on **enterprise systems** (e.g., ERP, MES) are not mentioned; instead, the focus is on **heterogeneous modeling tools** (e.g., SysML, Simulink) and **stakeholder perspectives** during the development phase. No explicit patterns for **cross-Digital Twin integration** (e.g., federated twins) or **enterprise system dependencies** are described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The provided context does not explicitly mention **industry standards** or **specifications** for Digital Twin (DT) systems. However, the **Model-Based Systems Engineering (MBSE)** framework leverages **SysML** (ISO/IEC 10746-5:2011) as a standardized modeling language for system architecture and behavior. **Architecture Description Languages (ADLs)** like **AADL** (SAE AS5506) and **ACME** are also standardized for component-based system modeling. **Interoperability** is implied through the integration of **heterogeneous tools** (e.g., Simulink, C++, Java) and **multi-notation models**, though no explicit **compliance frameworks** (e.g., ISO 23247 for DTs) or **certification requirements** are referenced. The **Digital Shadow Reference Model** (Fig. 1) does not address standardization beyond its UML-based conceptualization."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system incorporates **physical safety measures** through the **safety cell of the MABI MAX 100 robotic arm**, which restricts its maximum working range to **[-90°, 90°]** to prevent collisions or unsafe operations. **Communication security** is addressed via **MQTT (Message Queuing Telemetry Transport)** for streaming time-series sensor data, ensuring lightweight and efficient data exchange between components. However, the provided documents do **not specify** explicit cybersecurity protocols (e.g., encryption, authentication, or access control mechanisms), threat mitigation strategies, fail-safe mechanisms, or compliance with safety-critical standards (e.g., ISO 26262, IEC 61508)."
]