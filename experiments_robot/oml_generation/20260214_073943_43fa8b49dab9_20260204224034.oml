// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the input electric current of the machine, streamed via MQTT."
    DTDFVocab:producedData InputCurrentDataTrans
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that captures the torque produced by the machine, streamed via MQTT."
    DTDFVocab:producedData TorqueDataTrans
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that records the angular velocity of the rotating shaft, streamed via MQTT."
    DTDFVocab:producedData AngularVelocityDataTrans
]

// C4: Physical‑to‑virtual interaction – data transmitted
instance InputCurrentDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance TorqueDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
]

instance AngularVelocityDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

// C10: Models/Data – aggregated sensor data
instance AggregatedSensorData : DTDFVocab:Data [
    base:desc "Aggregated real‑time data object that combines current, torque, and angular velocity measurements."
    DTDFVocab:fromData InputCurrentDataTrans, TorqueDataTrans, AngularVelocityDataTrans
    DTDFVocab:inputTo AggregationEnabler
]

instance SensorAggregationModel : DTDFVocab:Model [
    base:desc "Model that abstracts raw MQTT measurements into a unified data structure used by the aggregation component."
    DTDFVocab:inputTo AggregationEnabler
]

// C11: Enablers – transport & processing
instance MQTTTransportEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol layer that provides a one‑way automated data flow from physical sensors to the digital shadow."
    DTDFVocab:inputTo AggregationEnabler
]

instance AggregationEnabler : DTDFVocab:Enabler [
    base:desc "Software component that aggregates and abstracts raw sensor measurements into higher‑level data objects."
    DTDFVocab:enables PerformanceInsightService
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML tooling used for requirements, functional, logical and product architecture modeling."
    DTDFVocab:enables ModelManagementService
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton framework for behavioral modeling of the twin."
    DTDFVocab:enables ModelManagementService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for simulation and data‑calculation models integrated in the twin."
    DTDFVocab:enables DecisionSupportService
]

instance CppImplementationEnabler : DTDFVocab:Enabler [
    base:desc "C++ implementation layer for performance‑critical twin components."
    DTDFVocab:enables DecisionSupportService
]

instance JavaImplementationEnabler : DTDFVocab:Enabler [
    base:desc "Java implementation layer for platform‑independent twin services."
    DTDFVocab:enables DecisionSupportService
]

// C6: Services
instance PerformanceInsightService : DTDFVocab:Service [
    base:desc "Service that delivers aggregated performance indicators derived from sensor data."
    DTDFVocab:provides AggregatedPerformanceInsight
]

instance ModelManagementService : DTDFVocab:Service [
    base:desc "Service that manages model artifacts, traceability links, and conformance mapping between digital shadow and concrete twin."
    DTDFVocab:provides ModelTraceabilityInsight, ModelUpdateAction
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Decision‑support service that consumes simulation outputs and computed indicators to guide operational actions."
    DTDFVocab:provides OperationalDecisionInsight, OperationalAdjustmentAction
]

// C17: Insights / Actions
instance AggregatedPerformanceInsight : DTDFVocab:Insight [
    base:desc "Higher‑level abstract data object representing aggregated performance indicators of the machine."
]

instance ModelTraceabilityInsight : DTDFVocab:Insight [
    base:desc "Insight that captures provenance information linking output traces to original sensor data and applied models."
]

instance OperationalDecisionInsight : DTDFVocab:Insight [
    base:desc "Insight providing recommended operational decisions based on simulated scenarios and live sensor data."
]

instance ModelUpdateAction : DTDFVocab:Action [
    base:desc "Action that triggers update of concrete twin models to keep them in sync with the digital shadow."
    DTDFVocab:IsAutomatic false
]

instance OperationalAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic action that adjusts machine operating parameters (e.g., set‑point changes) according to decision insight."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is structured around the Digital Shadow Reference Model, which defines a set of core concepts as UML classes: Purpose (the intended use), Asset (the physical entity), DataTrace (individual data points), Processing (components that execute computational logic), and Model (engineering, simulation, or data‑calculation models). A Processing component consumes one or more input DataTraces, applies a specific Model, and generates output DataTraces that become part of the digital shadow. The 'originatesFrom' association records the provenance of each DataTrace, linking it transitively to the Processing component, its input traces, and the involved Model, thereby providing fine‑grained traceability across the twin. Concretization of the reference model is achieved by mapping these abstract classes to concrete implementations such as database tables, simulation tools (e.g., Simulink) or code modules (e.g., C++/Java). This component‑based orchestration enables systematic integration of heterogeneous modeling notations and tools, supporting a coordinated flow of data through processing pipelines under the governance of the reference model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin development follows a Model‑Based Systems‑Engineering (MBSE) lifecycle in which models are produced at successive abstraction levels: (1) requirements models, (2) functional architecture models, (3) logical architecture models, and (4) product/technical (implementation) models. Representation types evolve from high‑level SysML requirement diagrams to detailed component‑and‑connector descriptions using architecture description languages such as ACME, AADL, MontiArc, and SysML internal block diagrams, and finally to executable artifacts in simulation tools (e.g., MathWorks Simulink) or code (C++, Java). Transitions between these stages are governed by explicit conformance relations defined in the Digital Shadow reference model, preserving traceability of data traces and model elements across the lifecycle."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on established modelling standards: SysML is used for requirement and internal‑block diagrams; architecture description languages such as ACME, AADL and MontiArc serve as standardized notations for component‑connector specifications; UML class diagrams constitute the basis of the Digital Shadow reference model and its concrete realizations. Conformance relations defined in the reference model provide a formal mechanism to ensure that concrete DT artefacts adhere to these modelling standards."
]