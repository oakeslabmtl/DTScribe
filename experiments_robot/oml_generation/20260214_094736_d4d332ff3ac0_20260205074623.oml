// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Electric current sensor measuring motor current (I_M) in the MABI MAX 100; samples at 1 kHz and streams via MQTT."
    DTDFVocab:producedData MotorCurrentTransmission
]
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder attached to the motor shaft measuring angular position."
    DTDFVocab:producedData MotorPositionTransmission
]
instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder positioned behind the cycloidal gearbox measuring output joint angle."
    DTDFVocab:producedData GearboxPositionTransmission
]

// C4: Physical-to-virtual interaction
instance MotorCurrentTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]
instance MotorPositionTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]
instance GearboxPositionTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// C10: Models/Data
instance MotorCurrent : DTDFVocab:Data [
    base:desc "Measured motor current I_M (floating‑point value) streamed in real time over MQTT."
    DTDFVocab:inputTo RealTimeFrictionEngine
    DTDFVocab:fromData MotorCurrentTransmission
]
instance MotorTorque : DTDFVocab:Data [
    base:desc "Derived motor torque τ from current measurement; produced in the digital shadow."
    DTDFVocab:inputTo RealTimeFrictionEngine
    DTDFVocab:fromData MotorCurrentTransmission
]
instance MotorAngularVelocity : DTDFVocab:Data [
    base:desc "Derived motor angular velocity ω from motor encoder data; streamed via MQTT as a time‑series."
    DTDFVocab:inputTo RealTimeFrictionEngine
    DTDFVocab:fromData MotorPositionTransmission
]
instance GearboxTorque : DTDFVocab:Data [
    base:desc "Derived gearbox torque transduced at the second encoder; time‑series data in the DT."
    DTDFVocab:inputTo RealTimeFrictionEngine
    DTDFVocab:fromData GearboxPositionTransmission
]
instance GearboxAngularVelocity : DTDFVocab:Data [
    base:desc "Derived gearbox angular velocity from encoder; time‑series data in the DT."
    DTDFVocab:inputTo RealTimeFrictionEngine
    DTDFVocab:fromData GearboxPositionTransmission
]
instance StructuralSysMLMotorModel : DTDFVocab:Model [
    base:desc "Structural SysML representation of the permanent‑magnet synchronous motor for the first rotary joint."
    DTDFVocab:inputTo RealTimeFrictionEngine
]
instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "Executable Simulink simulation of the motor dynamics including current, torque and velocity."
    DTDFVocab:inputTo RealTimeFrictionEngine
]
instance SimulinkGearWheelModel : DTDFVocab:Model [
    base:desc "Simulink model of the gearwheel in the transmission chain."
    DTDFVocab:inputTo RealTimeFrictionEngine
]
instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "Simulink simulation of the cycloidal gearbox comprising the first joint."
    DTDFVocab:inputTo RealTimeFrictionEngine
]
instance SimulinkFrictionModel : DTDFVocab:Model [
    base:desc "Simulink representation of friction (Coulomb‑Viscous, Stribeck, Dahl, LuGre) for identification."
    DTDFVocab:inputTo RealTimeFrictionEngine
]

// C11: Enablers
instance RealTimeFrictionEngine : DTDFVocab:Enabler [
    base:desc "Enabler that runs the Simulink identification engine, consumes sensor data streams via MQTT, and provides the RealTimeFrictionEstimation service."
    DTDFVocab:enables RealTimeFrictionEstimation
]

// C6: Services
instance RealTimeFrictionEstimation : DTDFVocab:Service [
    base:desc "Service that performs real‑time friction parameter estimation using white‑box models and data‑driven learning."
    DTDFVocab:provides FrictionParameterUpdate, UpdateControllerInputs
]

// C17: Insights/Actions
instance FrictionParameterUpdate : DTDFVocab:Insight [
    base:desc "Insight on updated static, kinetic and viscous friction parameters derived from simulation‑measurement comparison."
]
instance UpdateControllerInputs : DTDFVocab:Action [
    base:desc "Automatic action that sends updated friction compensation inputs to the robot controller."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in real‑time, processing live data streams synchronous with the robot’s operating cycle (maximum joint speed 75 deg/s) and continuously updating friction models during operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation comprises the physical asset (first axis), the digital shadow (data traces and simulation models), the data ingestion layer (MQTT broker and AAS interfaces), and the visualization layer (dashboard). All components interact through one‑way data flow from physical to virtual, with computational processing performed by the digital shadow."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans all three lifecycle phases: design (ideal, friction‑free simulation models), manufacture (actual robot and sensor data), and operation (continuous identification and refinement of friction models during live use)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validity ensured by traceability of every data point back to its source and computational model; continuous identification keeps models aligned with lived wear and temperature effects; verification of simulation against measured torque and velocity; analytical white‑box models provide physical interpretability while black‑box models capture residual behaviours; uncertainty handled through ongoing calibration but explicit error bounds not quantified."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical to virtual data are transmitted over MQTT messaging protocol; semantic publishing via Asset Administration Shells (AAS); one‑way data flow from robot to digital shadow; no bi‑directional network link described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML v1.7 for structural and behavioral modeling; adoption of MBSE methods such as RFLP, OOSEM, SPES, SMArDT; Digital Shadow Reference Model (DSRM) as reference architecture; Asset Administration Shells (AAS) conform to the Open Digital Architecture of Industry 4.0; no mention of IEC 62443 compliance."
]