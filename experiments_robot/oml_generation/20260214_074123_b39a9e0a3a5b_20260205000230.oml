// C3: Physical sensing components
instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures input electrical current of each joint drive"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance AngleSensor : DTDFVocab:SensingComponent [
    base:desc "Measures output angular position (angle) of each robot joint"
    DTDFVocab:producedData AngleDataTransmitted
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Measures torque exerted at each joint"
    DTDFVocab:producedData TorqueDataTransmitted
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Measures angular velocity of each joint"
    DTDFVocab:producedData VelocityDataTransmitted
]

instance AccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Measures angular acceleration of each joint"
    DTDFVocab:producedData AccelerationDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
]

instance AngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngleSensor
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySensor
]

instance AccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AccelerationSensor
]

// C10: Data
instance CurrentData : DTDFVocab:Data [
    base:desc "Input current time‑series streamed via MQTT from the robot joint drives"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance AngleData : DTDFVocab:Data [
    base:desc "Joint angle (position) time‑series streamed via MQTT"
    DTDFVocab:fromData AngleDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Joint torque time‑series streamed via MQTT"
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance VelocityData : DTDFVocab:Data [
    base:desc "Joint angular velocity time‑series streamed via MQTT"
    DTDFVocab:fromData VelocityDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Joint angular acceleration time‑series streamed via MQTT"
    DTDFVocab:fromData AccelerationDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

// C11: Enablers
instance MqttBroker : DTDFVocab:Enabler [
    base:desc "Mosquitto MQTT broker handling real‑time one‑way streaming of contextual sensor traces using MQTT"
    DTDFVocab:enables DataAggregationService, DashboardVisualizationService
]

// C6: Services
instance DataAggregationService : DTDFVocab:Service [
    base:desc "Aggregates and abstracts contextual sensor data for friction analysis"
    DTDFVocab:provides InsightFrictionRelations
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Provides monitoring and diagnostic visualisation of friction‑related relations in the operator dashboard"
    DTDFVocab:provides ActionDisplayDashboard
]

// C17: Insights / Actions
instance InsightFrictionRelations : DTDFVocab:Insight [
    base:desc "Analyzes friction‑related relations derived from aggregated sensor data"
]

instance ActionDisplayDashboard : DTDFVocab:Action [
    base:desc "Displays friction analysis results on the operator dashboard"
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance SimulinkFrictionModel : DTDFVocab:Model [
    base:desc "Dynamic friction model of the six‑axis robot simulated in MathWorks Simulink, providing predictive and optimisation capabilities"
    DTDFVocab:inputTo MqttBroker
]

instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "UML class diagram defining the contextual data‑trace aggregation and abstraction layer for the digital shadow"
    DTDFVocab:inputTo MqttBroker
]

instance SysMLArchitectureModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams capturing the robot's structural and functional architecture"
    DTDFVocab:inputTo MqttBroker
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated through a Processing component as defined in the Digital Shadow Reference Model. This component consumes input data traces, applies either simulation models or data‑calculation models, and produces output data traces that become part of the shadow. Traceability is encoded by the 'originates from' association, allowing each output trace to be linked back to the generating processing component, the consumed input traces, and the specific models used; this traceability is maintained transitively across the workflow. Concretization of the reference model yields concrete classes, associations, and mappings that instantiate the orchestration logic for a particular domain."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The document outlines a digital‑twin lifecycle that follows a Model‑Based Systems‑Engineering (MBSE) sequence: starting with requirement modelling, progressing to functional architecture, then logical architecture, and finally the product/technical layer. During the development phase the twin is represented with SysML models; when the physical system is deployed, a digital shadow is instantiated that receives an automated one‑way data flow from the asset. Transition between these phases is managed by maintaining traceability links between the MBSE artefacts and the generated data‑trace aggregation that constitutes the shadow, while governance relies on preserving consistency across heterogeneous modelling notations and stakeholder perspectives."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the physical sensors and the digital shadow relies on the MQTT protocol, with Mosquitto serving as the broker and client implementations referenced (Light, 2017). The network follows a broker‑client topology where sensor endpoints publish MQTT messages to the broker, which are then consumed by the digital twin services (e.g., Thingsboard platform). Bandwidth and latency requirements are not quantified in the documents, and reliability is assumed to be provided by MQTT’s QoS mechanisms. No explicit security protocols (e.g., TLS) or redundancy schemes are described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The methodology adopts widely recognised modelling standards: SysML (an OMG standard) for requirements and structural diagrams, and several ADLs—including ACME, AADL, and MontiArc—that are established language specifications for component‑connector architectures. The digital shadow reference model itself is expressed as a UML class diagram, aligning with the UML standard for system description."
]