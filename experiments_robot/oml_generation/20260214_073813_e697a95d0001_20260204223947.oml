// C3: Physical sensing components
instance PhysicalJointStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that captures joint state information from the physical system, generating contextual data traces for the digital shadow."
    DTDFVocab:producedData JointStateDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmission)
instance JointStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalJointStateSensor
]

// C5: Data (aggregated traces)
instance JointStateDataTrace : DTDFVocab:Data [
    base:desc "Aggregated and abstracted joint state data trace used as input for simulation and analytical models."
    DTDFVocab:fromData JointStateDataTransmitted
    DTDFVocab:inputTo SimulinkEngine, MachineLearningEngine
]

// C10: Models/Data
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML block-definition and internal block diagrams capturing structural aspects of the system."
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink white-box simulation model representing dynamic behavior of the system."
    DTDFVocab:inputTo SimulinkEngine
]

instance MachineLearningPredictorModel : DTDFVocab:Model [
    base:desc "Black-box machine learning predictor model used for data‑driven insights such as friction‑level estimation."
    DTDFVocab:inputTo MachineLearningEngine
]

// C11: Enablers
instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation engine used to execute dynamic behavior models."
    DTDFVocab:enables InsightGenerationService
]

instance MachineLearningEngine : DTDFVocab:Enabler [
    base:desc "Machine‑learning runtime environment executing predictor models on input data traces."
    DTDFVocab:enables InsightGenerationService
]

// C6: Services
instance InsightGenerationService : DTDFVocab:Service [
    base:desc "Processing service that consumes data traces and model outputs to generate multi‑physics insights."
    DTDFVocab:provides JointFrictionLevelInsight, OperatorDashboardVisualizationAction
]

// C17: Insights/Actions
instance JointFrictionLevelInsight : DTDFVocab:Insight [
    base:desc "Identifies joint friction levels from processed data, providing health assessment for the physical system."
]

instance OperatorDashboardVisualizationAction : DTDFVocab:Action [
    base:desc "Visualizes generated insights on operator dashboards to support human decision‑making."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "In contrast to a digital shadow, a Digital Twin can provide active components that interpret incoming data and generate command messages that are sent back to the physical system, enabling bidirectional interaction. The documents do not specify command formats, protocols, or validation mechanisms, only that the Twin is capable of pushing data to the physical object."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin lifecycle described in the documents follows the Model‑Based Systems‑Engineering (MBSE) development flow. It starts with the requirements abstraction, proceeds to functional architecture, then logical architecture, and finally the product/technical layer where the concrete implementation resides. At each stage the system is represented by models in languages such as SysML, ADLs (e.g., ACME, AADL, MontiArc) and may be refined into simulation or code artifacts. Transition between stages is managed by mapping abstract concepts to concrete realizations (concretization) and by maintaining traceability through the ‘originates‑from’ association. Governance is implicit in the need to keep the concrete model conformant to the reference digital‑shadow model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The approach stresses traceability of every model and data artifact to its origin and mandates verification of model transformations (e.g., from SysML specifications to simulation models). Fidelity requirements are addressed by combining white‑box physics models with black‑box data‑driven models and by validating simulated outputs against measured sensor data. Uncertainty is recognized as stemming from model simplifications and data noise; quality assurance includes systematic verification of transformation correctness and continuous validation loops that compare digital‑twin predictions with real‑world observations."
]