// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring the input current I_M of the robot axis"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Primary position encoder mounted on the motor shaft"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the cycloidal gearbox providing output angle"
    DTDFVocab:producedData OutputAngleDataTransmitted
]

// C4: Physical-to-virtual interaction – data transmitted via MQTT
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// Derived measurements (torque, angular velocity, acceleration) produced from the three raw sensors
instance DerivedMeasurementsTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorEncoderSensor, GearboxEncoderSensor
]

// C10: Data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor current I_M obtained from MotorCurrentSensor"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Motor shaft angle time‑series from MotorEncoderSensor"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Gearbox output angle time‑series from GearboxEncoderSensor"
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Calculated torque time‑series derived from current and position data"
    DTDFVocab:fromData DerivedMeasurementsTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Calculated angular velocity time‑series derived from encoder data"
    DTDFVocab:fromData DerivedMeasurementsTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Calculated angular acceleration time‑series derived from velocity data"
    DTDFVocab:fromData DerivedMeasurementsTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

instance FrictionParameterData : DTDFVocab:Data [
    base:desc "Identified static, kinetic and viscous friction parameters for the gearbox"
    DTDFVocab:inputTo SimulinkEngine
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker used for live streaming of sensor data to the digital shadow"
    DTDFVocab:enables RealTimeFrictionIdentificationService, DataTraceabilityService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for simulation and data‑calculation models"
    DTDFVocab:enables ContinuousModelUpdatingService, RealTimeFrictionIdentificationService
]

instance DashboardPlatform : DTDFVocab:Enabler [
    base:desc "Unified dashboard visualizing friction identification results and robot positioning"
    DTDFVocab:enables UnifiedDashboardService
]

instance AASEnvironment : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) providing meta‑information about the robot axis"
    DTDFVocab:enables DataTraceabilityService, ContinuousModelUpdatingService
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time friction identification service using streamed sensor data"
    DTDFVocab:provides FrictionParametersDerivedInsight
]

instance ContinuousModelUpdatingService : DTDFVocab:Service [
    base:desc "Continuous updating of white‑box and black‑box friction models during operation"
    DTDFVocab:provides RefreshFrictionModelsAction
]

instance UnifiedDashboardService : DTDFVocab:Service [
    base:desc "Integrated visualization service presenting model states and positioning accuracy"
    DTDFVocab:provides PositioningAccuracyImprovedInsight
]

instance DataTraceabilityService : DTDFVocab:Service [
    base:desc "Traceability service linking each data point to its origin and AAS metadata"
    DTDFVocab:provides DataTraceabilityInsight
]

// C17: Insights
instance FrictionParametersDerivedInsight : DTDFVocab:Insight [
    base:desc "Static, kinetic and viscous friction parameters identified for the gearbox"
]

instance PositioningAccuracyImprovedInsight : DTDFVocab:Insight [
    base:desc "Improved positioning accuracy of the robot axis after friction compensation"
]

instance DataTraceabilityInsight : DTDFVocab:Insight [
    base:desc "Complete traceability of each data point to its originating sensor and AAS asset"
]

// C17: Actions
instance RefreshFrictionModelsAction : DTDFVocab:Action [
    base:desc "Refreshes white‑box and black‑box friction models with newly identified parameters"
    DTDFVocab:IsAutomatic true
]

instance UpdateRobotControlAlgorithmAction : DTDFVocab:Action [
    base:desc "Updates the robot control algorithm with derived friction parameters to enhance positioning"
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance WhiteBoxFrictionModel : DTDFVocab:Model [
    base:desc "Physics‑based (white‑box) model of gearbox friction incorporating Coulomb‑Viscous behavior"
    DTDFVocab:inputTo SimulinkEngine
]

instance BlackBoxFrictionModel : DTDFVocab:Model [
    base:desc "Data‑driven (black‑box) model of gearbox friction using Stribeck/Dahl/LuGre representations"
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "Executable Simulink model of the motor, cycloidal gearbox and associated dynamics"
    DTDFVocab:inputTo SimulinkEngine
]

instance SysMLAxisModel : DTDFVocab:Model [
    base:desc "SysML block and internal block diagrams describing the axis architecture"
    DTDFVocab:inputTo AASEnvironment
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Model that calculates torque, angular velocity and acceleration from raw sensor streams"
    DTDFVocab:inputTo SimulinkEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow does not send commands or data back to the physical robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time / continuous during robot operation; data traces are updated as the robot moves."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow combines the asset (first axis), data traces, processing components (simulation and calculation models), and a dashboard service to provide friction analysis and model verification."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated (runtime) stage – the digital shadow is created and used while the robot is running to improve motion control accuracy."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous identification of friction parameters using both white‑box (analytical) and black‑box (data‑driven) models, traceability of each data point to its source and processing model, and validation by comparing simulated friction‑free data with measured data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Live data transferred via MQTT from the robot controller to the digital shadow; Asset Administration Shells provide metadata and model linkage."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Industry 4.0 Asset Administration Shell (AAS) standard and SysML modeling language for model exchange."
]