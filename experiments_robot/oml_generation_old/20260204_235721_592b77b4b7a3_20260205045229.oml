// C3: Physical sensing component (simulation data capture)
instance SimulationDataSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Captures simulation outputs generated from Model-Based Systems Engineering (RFLP, OOSEM, SPES, SMArDT) using SysML for requirements, ACME, AADL, and MontiArc for architectural description, and MontiArc Automaton for behavior, feeding the digital twin."
    DTDFVocab:producedData SimulationDataTransmitted
]

// C4: Data transmitted from the sensing component
instance SimulationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationDataSensingComponent
]

// C10: Data collected from the sending component
instance SimulationData : DTDFVocab:Data [
    base:desc "Raw simulation data produced by the modeling environment, representing the system’s logical behavior and architecture as defined in SysML, ACME, AADL, and MontiArc."
    DTDFVocab:fromData SimulationDataTransmitted
    DTDFVocab:inputTo ModelEncodingEnabler
]

// C11: Enabler for turning models into code
instance ModelEncodingEnabler : DTDFVocab:Enabler [
    base:desc "Encodes the models defined in ACME, AADL, and MontiArc into formal representations suitable for code generation, enabling the subsequent code generation service."
    DTDFVocab:enables CodeGenerationService
]

// C6: Service responsible for generating executable code
instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Generates C++ or Java code from the encoded models and simulation data, facilitating deployment of the digital twin’s logical components."
    DTDFVocab:provides GeneratedCodeInsight, ExecuteGeneratedCodeAction
]

// C17: Insight into generated code quality and correctness
instance GeneratedCodeInsight : DTDFVocab:Insight [
    base:desc "Provides analysis of the generated C++/Java code for compliance with safety-critical standards and performance benchmarks."
]

// C17: Action to execute the generated code
instance ExecuteGeneratedCodeAction : DTDFVocab:Action [
    base:desc "Triggers execution of the generated code within the digital twin’s runtime environment, validating behavior against the original models."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Life Cycle Stages: The DT lifecycle is captured through Model‑Based Systems Engineering (MBSE) and is structured into four abstraction layers. (1) Requirements: system needs are expressed in SysML requirement diagrams and use‑case models. (2) Functional Architecture: the functional structure is designed in SysML and linked to the requirements. (3) Logical Architecture: logical components and connectors are described with architecture description languages such as ACME, AADL and MontiArc, with behavioral extensions (e.g., MontiArc Automaton or SysML 1.7 state machines). (4) Product/Technical Layer: concrete components, connector specifications and implementation artefacts are produced in general‑purpose languages (C++/Java) and simulation tools (MathWorks Simulink or equivalent). Transitions between these stages are managed by mapping artifacts across abstraction layers – requirements trace to functional elements, functional elements trace to logical components, and logical components trace to technical implementation. Lifecycle governance is performed within the MBSE framework, ensuring consistency, traceability and coherent model updates."
]