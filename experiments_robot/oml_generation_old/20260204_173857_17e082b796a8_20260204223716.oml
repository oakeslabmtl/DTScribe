// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor electric current measurement (I_M) from the permanent‑magnet synchronous motor"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder providing angular position of the motor shaft"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Gearbox‑mounted position encoder providing angular position after the cycloidal gearbox"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Output shaft angle sensor providing the robot end‑effector angular position"
    DTDFVocab:producedData OutputAngleDataTransmitted
]

// C4: DataTransmitted (raw sensor streams)
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

// C4: DataTransmitted (derived quantities)
instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentDataTransmitted, MotorEncoderDataTransmitted, GearboxEncoderDataTransmitted, OutputAngleDataTransmitted
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderDataTransmitted, GearboxEncoderDataTransmitted, OutputAngleDataTransmitted
]

instance AccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocityDataTransmitted
]

// C5: Data (raw and processed)
instance CurrentData : DTDFVocab:Data [
    base:desc "Raw current time‑series (I_M) streamed via MQTT"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkSimulationEngine
]

instance MotorEncoderData : DTDFVocab:Data [
    base:desc "Raw position time‑series from motor‑mounted encoder"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkSimulationEngine
]

instance GearboxEncoderData : DTDFVocab:Data [
    base:desc "Raw position time‑series from gearbox‑mounted encoder"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkSimulationEngine
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Raw output angle time‑series streamed via MQTT"
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkSimulationEngine
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque (τ) time‑series computed in real time from raw measurements"
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEngine, AssetAdministrationShell
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity (ω) time‑series computed from encoder positions"
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEngine, AssetAdministrationShell
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration computed from angular velocity"
    DTDFVocab:fromData AccelerationDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEngine, AssetAdministrationShell
]

// C10: Models/Data (engineering & simulation)
instance SysMLAxisStructureModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams describing the axis structure"
    DTDFVocab:inputTo AssetAdministrationShell
]

instance SimulinkFrictionlessModel : DTDFVocab:Model [
    base:desc "Simulink executable model of the axis without friction (baseline)"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkCoulombViscousModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Coulomb‑viscous friction behavior"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkStribeckModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Stribeck friction characteristic"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkDahlModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Dahl friction dynamics"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkLuGreModel : DTDFVocab:Model [
    base:desc "Simulink model implementing LuGre friction model"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

// C11: Enablers (tools & platforms)
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker used for real‑time streaming of sensor and derived data"
    DTDFVocab:enables RealTimeVisualizationService
]

instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for running friction models"
    DTDFVocab:enables FrictionIdentificationService, ModelParameterRefinementService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for data integration and traceability"
    DTDFVocab:enables FrictionIdentificationService, ModelParameterRefinementService
]

instance WebDashboard : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard for operator visualization of real‑time data and insights"
    DTDFVocab:enables RealTimeVisualizationService
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of static, kinetic and viscous friction parameters using white‑box and black‑box models"
    DTDFVocab:provides FrictionParameterInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of sensor streams, derived traces and friction insights on a dashboard"
    DTDFVocab:provides MotionAccuracyImprovementInsight
]

instance ModelParameterRefinementService : DTDFVocab:Service [
    base:desc "Generation of refined model parameters to improve robot motion control accuracy"
    DTDFVocab:provides ControlParameterAdjustmentAction
]

// C17: Insights / Actions
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Identified friction parameters (static, kinetic, viscous) derived from real‑time data"
]

instance MotionAccuracyImprovementInsight : DTDFVocab:Insight [
    base:desc "Insight that refined parameters increase robot motion accuracy, shown on the dashboard"
]

instance ControlParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of the robot controller parameters based on identified friction values"
    DTDFVocab:IsAutomatic true
]

// C9: Environment (physical context)
instance RobotVerticalAxisEnvironment : DTDFVocab:Environment [
    base:contains MotorCurrentSensor, MotorEncoderSensor, GearboxEncoderSensor, OutputAngleSensor, SimulinkSimulationEngine, MQTTBroker, AssetAdministrationShell, WebDashboard
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data are exchanged continuously in real time, with live sensor streams synchronized to the robot's control cycle and processed on‑the‑fly for friction identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow is instantiated as a concrete realization of the Digital Shadow Reference Model, comprising purpose (FrictionDerivation), asset (MABI first axis), sources (sensors and derived data), processing components (simulation models), and data traces organized into a unified dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow combines engineering models (structural and behavioral SysML models) representing the design stage with live operational data, thus addressing both the design and operational life‑cycle stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability links each data point to its source and processing model, enabling validation by comparing simulated friction‑less and friction‑augmented outputs against measured reference data; continuous updating of white‑box and black‑box parameters ensures model fidelity over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Live sensor streams are transmitted from the robot to the digital shadow via the MQTT protocol."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Asset Administration Shells (AAS) are employed to standardize the representation and exchange of asset data within the digital shadow ecosystem."
]