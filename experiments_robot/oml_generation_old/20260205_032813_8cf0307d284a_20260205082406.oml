// C3: Physical Sensing Components
instance OperationalLogCollector : DTDFVocab:SensingComponent [
    base:desc "Passive data collection component relying on operational logs to feed one-way data flows into the Digital Shadow"
    DTDFVocab:producedData OperationalLogDataTransmitted
]

instance SensorNetwork : DTDFVocab:SensingComponent [
    base:desc "IoT-based sensor network collecting contextual data traces from physical systems for Digital Shadow integration"
    DTDFVocab:producedData SensorNetworkDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance OperationalLogDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalLogCollector
    base:desc "Structured operational logs transmitted from physical system to Digital Shadow"
]

instance SensorNetworkDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SensorNetwork
    base:desc "Aggregated sensor data traces from IoT devices for Digital Shadow consumption"
]

// C10: Models/Data
instance SysMLRequirementModel : DTDFVocab:Model [
    base:desc "SysML v1.7+ model capturing requirements, architecture, and behavioral modeling (e.g., state machines) for system engineering"
    DTDFVocab:inputTo SysMLEnabler
]

instance AADLComponentModel : DTDFVocab:Model [
    base:desc "AADL model defining components, interfaces, and deployment for safety-critical and embedded systems"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "MontiArc model supporting component-connector architectures and behavioral modeling via automata"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLInternalBlockDiagram : DTDFVocab:Model [
    base:desc "SysML IBDs for logical and physical architecture visualization"
    DTDFVocab:inputTo SysMLEnabler
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for dynamic system simulation, control system design, and signal processing"
    DTDFVocab:inputTo SimulinkEnabler
]

instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "UML class diagram defining Digital Shadow reference model for contextual data traces aggregation and abstraction"
    DTDFVocab:inputTo DigitalShadowEnabler
]

instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces from physical system for specific use cases (e.g., manufacturing)"
    DTDFVocab:fromData OperationalLogDataTransmitted, SensorNetworkDataTransmitted
    DTDFVocab:inputTo DigitalShadowEnabler, ActiveProcessingEnabler
]

instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Data generated from simulation engines (e.g., Simulink) for behavioral analysis and prediction"
    DTDFVocab:fromData SensorNetworkDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, OptimizationService
]

instance ModelArtifactData : DTDFVocab:Data [
    base:desc "Structured model artifacts (e.g., SysML, ADL models) stored for long-term analysis and version control"
    DTDFVocab:fromData OperationalLogDataTransmitted
    DTDFVocab:inputTo ModelManagementEnabler
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7+ framework enabling requirements, architecture, and behavioral modeling (e.g., state machines)"
    DTDFVocab:enables SysMLModelingService, BehavioralSimulationService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL tooling for component-based system description in safety-critical and embedded systems"
    DTDFVocab:enables ArchitecturalModelingService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc framework supporting component-connector architectures and automata-based behavioral modeling"
    DTDFVocab:enables ComponentArchitectureService, AutomataBehaviorService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for dynamic system simulation, control system design, and signal processing with co-simulation capabilities"
    DTDFVocab:enables DynamicSimulationService
]

instance DigitalShadowEnabler : DTDFVocab:Enabler [
    base:desc "Digital Shadow reference model implementation enabling passive data collection and aggregation from physical systems"
    DTDFVocab:enables PassiveMonitoringService
]

instance ActiveProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Software modules within DT interpreting, analyzing, and acting upon Digital Shadow data (e.g., ML for predictive maintenance)"
    DTDFVocab:enables DataInterpretationService, PredictiveAnalysisService
]

instance ModelManagementEnabler : DTDFVocab:Enabler [
    base:desc "Shared repositories and model management tools for reconciling multi-disciplinary models (e.g., mechanical, electrical, software)"
    DTDFVocab:enables MultiNotationIntegrationService, ModelVersionControlService
]

instance CppImplementationEnabler : DTDFVocab:Enabler [
    base:desc "C++ implementation for performance-critical components and custom algorithms"
    DTDFVocab:enables CustomAlgorithmService
]

instance JavaImplementationEnabler : DTDFVocab:Enabler [
    base:desc "Java implementation for cross-platform logic and data processing"
    DTDFVocab:enables CrossPlatformLogicService
]

instance TimeSeriesDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database (e.g., InfluxDB, TimescaleDB) for storing aggregated data traces and model artifacts"
    DTDFVocab:enables DataStorageService
]

// C6: Services
instance SysMLModelingService : DTDFVocab:Service [
    base:desc "Service enabling requirements, architecture, and behavioral modeling using SysML v1.7+"
    DTDFVocab:provides SysMLModelingInsight
]

instance ArchitecturalModelingService : DTDFVocab:Service [
    base:desc "Service for component-based system description using ADLs (e.g., AADL, ACME)"
    DTDFVocab:provides ComponentArchitectureInsight
]

instance BehavioralSimulationService : DTDFVocab:Service [
    base:desc "Service for discrete-event behavior modeling using state machines and automata"
    DTDFVocab:provides BehavioralModelInsight
]

instance ComponentArchitectureService : DTDFVocab:Service [
    base:desc "Service for component-based architecture modeling and analysis"
    DTDFVocab:provides ComponentArchitectureInsight
]

instance AutomataBehaviorService : DTDFVocab:Service [
    base:desc "Service for automata-based behavioral modeling and simulation"
    DTDFVocab:provides BehavioralModelInsight
]

instance DynamicSimulationService : DTDFVocab:Service [
    base:desc "Service for dynamic system simulation and control system design using Simulink"
    DTDFVocab:provides SimulationOutputInsight
]

instance PassiveMonitoringService : DTDFVocab:Service [
    base:desc "Service for continuous state monitoring of physical system via Digital Shadow data aggregation"
    DTDFVocab:provides SystemHealthInsight
]

instance DataInterpretationService : DTDFVocab:Service [
    base:desc "Service for real-time interpretation and processing of Digital Shadow data"
    DTDFVocab:provides DataInterpretationInsight
]

instance PredictiveAnalysisService : DTDFVocab:Service [
    base:desc "Service for predictive maintenance and anomaly detection using simulation and ML"
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service for system configuration optimization based on data traces and simulation outputs"
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance MultiNotationIntegrationService : DTDFVocab:Service [
    base:desc "Service for reconciling heterogeneous modeling notations (e.g., SysML, ADLs, simulation tools)"
    DTDFVocab:provides IntegratedModelInsight
]

instance ModelVersionControlService : DTDFVocab:Service [
    base:desc "Service for managing model artifacts and ensuring consistency across iterative development"
    DTDFVocab:provides ModelConsistencyInsight
]

instance CustomAlgorithmService : DTDFVocab:Service [
    base:desc "Service for implementing custom algorithms and data processing in C++"
    DTDFVocab:provides CustomAlgorithmInsight
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Service for storing and retrieving aggregated data traces and model artifacts"
    DTDFVocab:provides DataRetrievalInsight
]

instance CrossPlatformLogicService : DTDFVocab:Service [
    base:desc "Service for implementing cross-platform logic and data processing in Java"
    DTDFVocab:provides CrossPlatformLogicInsight
]

