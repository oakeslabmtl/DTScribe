// C2: Acting Components
instance FirstJointActingComponent : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor and its gear transmission (gearbox and cycloidal gearbox) that drive the first joint of the MABI MAX‑100 serial industrial robot."
]

// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor monitoring motor electrical current."
    DTDFVocab:producedData MotorCurrentSignal
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Position encoder attached to motor shaft."
    DTDFVocab:producedData MotorAngleSignal
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Position encoder attached to gearbox output."
    DTDFVocab:producedData GearboxAngleSignal
]

// C4: Physical‑to‑virtual interaction
instance MotorCurrentSignal : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorAngleSignal : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxAngleSignal : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// C10: Models/Data
instance SysMLMotorGearboxModel : DTDFVocab:Model [
    base:desc "SysML component definition of motor and gearbox for the first joint."
    DTDFVocab:inputTo SysMLTool
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model of the permanent‑magnet synchronous motor."
    DTDFVocab:inputTo SimulinkTool
]

instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "Simulink model of the gear transmission including gearbox and cycloidal gearbox."
    DTDFVocab:inputTo SimulinkTool
]

instance SimulinkCoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Simulink representation of Coulomb and viscous friction components."
    DTDFVocab:inputTo SimulinkTool
]

instance SimulinkStribeckFrictionModel : DTDFVocab:Model [
    base:desc "Simulink model of Stribeck friction."
    DTDFVocab:inputTo SimulinkTool
]

instance SimulinkDahlFrictionModel : DTDFVocab:Model [
    base:desc "Simulink representation of Dahl friction model."
    DTDFVocab:inputTo SimulinkTool
]

instance SimulinkLuGreFrictionModel : DTDFVocab:Model [
    base:desc "Simulink representation of LuGre friction model."
    DTDFVocab:inputTo SimulinkTool
]

// Data instances
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured electric motor current."
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData MotorCurrentSignal
]

instance MotorAngleData : DTDFVocab:Data [
    base:desc "Measured motor shaft angle via encoder."
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData MotorAngleSignal
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Measured gearbox output angle via encoder."
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData GearboxAngleSignal
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Estimated motor torque derived from sensor data."
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData MotorCurrentSignal
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Estimated angular velocity derived from encoder data."
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData MotorAngleSignal
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Estimated angular acceleration derived from encoder data."
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData MotorAngleSignal
]

// C11: Enablers
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML modeling tool used for structural modeling of motor and gearboxes."
    DTDFVocab:enables DataLinkageService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink used for executable simulation of motor, gearbox, and friction models."
    DTDFVocab:enables WhiteBlackBoxFrictionsSimulationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell providing semantic abstraction of the digital twin."
    DTDFVocab:enables DataLinkageService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker for live data streaming from sensors to the digital twin."
    DTDFVocab:enables ContinuousFrictionIdentificationService, DataLinkageService, VisualizationDashboardService
]

instance WebDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard for visualization of sensor data and simulation results."
    DTDFVocab:enables VisualizationDashboardService
]

// C6: Services
instance ContinuousFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service performing continuous friction identification from real‑time sensor data."
    DTDFVocab:provides UpdatedFrictionParametersInsight, RealTimeStateEstimationInsight
]

instance WhiteBlackBoxFrictionsSimulationService : DTDFVocab:Service [
    base:desc "Service simulating white‑ and black‑box friction models for comparison."
    DTDFVocab:provides TrajectoryPlanningInsight
]

instance DataLinkageService : DTDFVocab:Service [
    base:desc "Service linking sensor data with the asset model."
    DTDFVocab:provides MaintenancePlanningInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Service providing a web‑based visualization dashboard for user interaction."
    DTDFVocab:provides MaintenancePlanningInsight
]

instance ParameterProvisionService : DTDFVocab:Service [
    base:desc "Service delivering updated friction parameters to control algorithms."
    DTDFVocab:provides ControlImprovementInsight
]

// C17: Insights
instance UpdatedFrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Updated friction parameters (Coulomb, viscous, Stribeck coefficients) from identification."
]

instance RealTimeStateEstimationInsight : DTDFVocab:Insight [
    base:desc "Real‑time state estimation (torque, velocity, acceleration) of the joint."
]

instance ControlImprovementInsight : DTDFVocab:Insight [
    base:desc "Improved control gains retuned based on updated friction parameters."
]

instance MaintenancePlanningInsight : DTDFVocab:Insight [
    base:desc "Maintenance plan recommendation for gear wear monitoring."
]

instance TrajectoryPlanningInsight : DTDFVocab:Insight [
    base:desc "Enhanced trajectory planning using updated friction models."
]

// C17: Actions
instance RetuneControlGainsAction : DTDFVocab:Action [
    base:desc "Auto‑retune of control algorithm gains based on identified friction parameters."
    DTDFVocab:IsAutomatic true
]

instance PlanMaintenanceAction : DTDFVocab:Action [
    base:desc "Planning maintenance activities for gear wear monitoring."
    DTDFVocab:IsAutomatic false
]

instance ImproveTrajectoryPlanningAction : DTDFVocab:Action [
    base:desc "Improvement of trajectory planning using refined friction models."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow is passive and does not send commands back to the robot"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time continuous streaming and processing, with data transmitted at the robot’s sensor rates (e.g., current and encoder updates at the plant’s control cycle)"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical robot + sensors → MQTT broker → DT processing component (constructing digital shadow) → simulation/analysis models → dashboard; all orchestrated within a single application environment"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Designed (ideal structural and simulation models), manufactured (sensor data from the actual robot), operated (live data and continuous friction model adaptation)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Models validated by continuously comparing simulated and measured data; white‑box friction models with parameter identification, data‑driven models complementing, traceability of data points, analysis of uncertainties due to wear, temperature, and load; verification through real‑time drift assessment"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication via MQTT publish/subscribe over IP network; use of Asset Administration Shell interfaces; synchronous data exchange between robot controller, sensors, and DT processing"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Modeling performed with SysML, data exchange via MQTT, asset semantic via Asset Administration Shells (AAS); adherence to relevant industry standards for modeling and communication"
]