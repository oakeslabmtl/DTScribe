prefix DTDFVocab: http://example.org/dtdf
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation results insight from Simulink"
]

instance ImplementationInsight : DTDFVocab:Insight [
    base:desc "Implementation insights from C++ and Java"
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service using MathWorks Simulink",
    DTDFVocab:provides SimulationResultInsight
]

instance ImplementationService : DTDFVocab:Service [
    base:desc "Implementation service using C++ and Java",
    DTDFVocab:provides ImplementationInsight
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation",
    DTDFVocab:enables SimulationService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for implementation",
    DTDFVocab:enables ImplementationService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for implementation",
    DTDFVocab:enables ImplementationService
]

instance RFLPModel : DTDFVocab:Model [
    base:desc "RFLP methodology for hierarchical system modeling across requirements, functional, logical, and physical layers",
    DTDFVocab:inputTo SimulinkEnabler
]

instance OOSEMModel : DTDFVocab:Model [
    base:desc "OOSEM methodology for hierarchical system modeling",
    DTDFVocab:inputTo SimulinkEnabler
]

instance SPESModel : DTDFVocab:Model [
    base:desc "SPES methodology for hierarchical system modeling",
    DTDFVocab:inputTo SimulinkEnabler
]

instance SMArDTModel : DTDFVocab:Model [
    base:desc "SMArDT methodology for hierarchical system modeling",
    DTDFVocab:inputTo SimulinkEnabler
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language for component-and-connector-based system descriptions",
    DTDFVocab:inputTo SimulinkEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL Architecture Description Language for component-and-connector-based system descriptions",
    DTDFVocab:inputTo SimulinkEnabler
]

instance MontiArcADLModel : DTDFVocab:Model [
    base:desc "MontiArc Architecture Description Language for component-and-connector-based system descriptions",
    DTDFVocab:inputTo SimulinkEnabler
]

instance SysMLIBDsModel : DTDFVocab:Model [
    base:desc "SysML IBDs for component-and-connector-based system descriptions",
    DTDFVocab:inputTo SimulinkEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavior modeling",
    DTDFVocab:inputTo SimulinkEnabler
]

instance SysMLStateMachineV17Model : DTDFVocab:Model [
    base:desc "SysML state machines (v1.7) for behavior modeling",
    DTDFVocab:inputTo SimulinkEnabler
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Industry standards such as SysML [17], ACME [23], AADL [24], MontiArc [25], [26], and SysML IBDs [17], [27] are used for architecture description languages (ADLs) to model system components, interfaces, interconnections, and behavior, facilitating interoperability and integration of heterogeneous stakeholders and perspectives."
]