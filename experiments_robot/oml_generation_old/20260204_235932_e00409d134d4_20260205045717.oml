// Enablers
instance SysMLEditorEnabler : DTDFVocab:Enabler [
    base:desc "Provides SysML v1.7 support for modeling requirements, functional, logical, and product abstractions."
    DTDFVocab:enables SysMLEditingService
]

instance MontiArcWorkbenchEnabler : DTDFVocab:Enabler [
    base:desc "Prepares and drives MontiArc component/connector models and MontiArc Automaton state machines."
    DTDFVocab:enables MontiArcModelingService
]

instance SimulinkEngineEnabler : DTDFVocab:Enabler [
    base:desc "Enables the MathWorks Simulink engine for dynamic simulation of continuous‐time subsystems."
    DTDFVocab:enables SimulinkSimulationService
]

instance CodeGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Offers automatic code generation from MBSE models, targeting C++ or Java deployment."
    DTDFVocab:enables CodeGenerationService
]

instance DatabaseBackendEnabler : DTDFVocab:Enabler [
    base:desc "Hosts time‑series storage and retrieval for sensor traces and simulation outputs."
    DTDFVocab:enables DataHostingService
]

instance OPCUAProtocolEnabler : DTDFVocab:Enabler [
    base:desc "Supports real‑time data ingestion via OPC UA telemetry protocol."
    DTDFVocab:enables TelemetryService
]

instance MQTTProtocolEnabler : DTDFVocab:Enabler [
    base:desc "Facilitates real‑time data ingestion through MQTT telemetry."
    DTDFVocab:enables TelemetryService
]

// Services
instance SysMLEditingService : DTDFVocab:Service [
    base:desc "Handles creation and validation of SysML v1.7 diagrams."
    DTDFVocab:provides SysMLDiagramInsight
]

instance MontiArcModelingService : DTDFVocab:Service [
    base:desc "Manages composition, connectors, and interaction contracts of MontiArc models."
    DTDFVocab:provides MontiArcModelInsight
]

instance SimulinkSimulationService : DTDFVocab:Service [
    base:desc "Performs discrete‑event and numerical simulation of SysML and MontiArc models."
    DTDFVocab:provides SimulinkSimulationInsight
]

instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Generates executable C++ and Java artifacts from MBSE models."
    DTDFVocab:provides CodeGenerationInsight
]

instance DataHostingService : DTDFVocab:Service [
    base:desc "Stores and queries time‑series data generated by simulations or instrumentation."
    DTDFVocab:provides DataAccessInsight
]

instance TelemetryService : DTDFVocab:Service [
    base:desc "Receives real‑time telemetry using OPC UA and MQTT."
    DTDFVocab:provides TelemetryInsight
]

// Insights
instance SysMLDiagramInsight : DTDFVocab:Insight [
    base:desc "Insight derived from SysML v1.7 architecture diagrams."
]

instance MontiArcModelInsight : DTDFVocab:Insight [
    base:desc "Insight derived from MontiArc component/connector models."
]

instance SimulinkSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from Simulink dynamic simulation results."
]

instance CodeGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight regarding readiness and compliance of generated code."
]

instance DataAccessInsight : DTDFVocab:Insight [
    base:desc "Insight into access patterns and storage efficiency of time‑series data."
]

instance TelemetryInsight : DTDFVocab:Insight [
    base:desc "Insight into telemetry ingestion health and protocol performance."
]

// Models
instance SysMLArchitectureModel : DTDFVocab:Model [
    base:desc "Captures system requirements, functional, logical, and product abstractions using SysML v1.7."
    DTDFVocab:inputTo SysMLEditorEnabler
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "Defines component composition and connectors using MontiArc."
    DTDFVocab:inputTo MontiArcWorkbenchEnabler
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "Numerical model for simulating continuous‑time dynamics in MathWorks Simulink."
    DTDFVocab:inputTo SimulinkEngineEnabler
]

// Data
instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Aggregated time‑series outputs from Simulink dynamic simulations."
    DTDFVocab:inputTo SimulinkEngineEnabler
    DTDFVocab:fromData SimulinkSimulationTransmitted
]

instance GeneratedCodeArtifacts : DTDFVocab:Data [
    base:desc "Executable C++ or Java artifacts generated from MBSE models."
    DTDFVocab:inputTo CodeGeneratorEnabler
    DTDFVocab:fromData CodeGenerationTransmitted
]

// Data Transmitted
instance SimulinkSimulationTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkEngineEnabler
]

instance CodeGenerationTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CodeGeneratorEnabler
]