// C3: Physical sensing components (virtual sensing via Digital Shadow)
instance DigitalShadowSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Digital shadow component that collects contextual data traces from the system under study."
    DTDFVocab:producedData DigitalShadowDataTransmitted
]

// C4: Physical-to-virtual interaction
instance DigitalShadowDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DigitalShadowSensingComponent
]

// C10: Models/Data
instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "Functional model derived from SysML artifacts as part of the MBSE lifecycle, following RFLP, OOSEM, SPES, and SMArDT methodologies."
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "Behavioral model encoded via MontiArc Automaton representing state transitions."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Contextual data traces collected by the digital shadow, defined by its UML class diagram."
    DTDFVocab:fromData DigitalShadowDataTransmitted
    DTDFVocab:inputTo DataModelEnabler
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for SysML modeling following RFLP, OOSEM, SPES, and SMArDT methodologies."
    DTDFVocab:enables SysMLModelingService
]

instance MontiArcArchitectureEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for component–connector architecture modeling using MontiArc ADL."
    DTDFVocab:enables MontiArcArchitectureService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for simulation of SysML state machines or MontiArc Automaton using MathWorks Simulink."
    DTDFVocab:enables SimulationService
]

instance DataModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that processes contextual data traces and couples them with model artefacts for simulation and monitoring."
    DTDFVocab:enables DataIntegrationService
]

// C6: Services
instance SysMLModelingService : DTDFVocab:Service [
    base:desc "Service that validates the functional and logical SysML model by running checks against requirements."
    DTDFVocab:provides ModelingInsight, ModelingAction
]

instance MontiArcArchitectureService : DTDFVocab:Service [
    base:desc "Service that verifies the component–connector architecture defined in MontiArc ADL."
    DTDFVocab:provides ArchitectureInsight, ArchitectureAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that executes simulation of the behavioral model in Simulink and evaluates results."
    DTDFVocab:provides SimulationInsight, SimulationAction
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Service that ingests contextual data traces and supplies them to the simulation and monitoring processes."
    DTDFVocab:provides DataInsight, DataAction
]

// C17: Insights/Actions
instance ModelingInsight : DTDFVocab:Insight [
    base:desc "Insight into functional and logical model alignment with system requirements."
]

instance ModelingAction : DTDFVocab:Action [
    base:desc "Automated consistency check action for the functional model."
    DTDFVocab:IsAutomatic true
]

instance ArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight into the quality and correctness of the component–connector architecture."
]

instance ArchitectureAction : DTDFVocab:Action [
    base:desc "Automated validation action for MontiArc architecture."
    DTDFVocab:IsAutomatic true
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight into simulation accuracy of the behavioral model."
]

instance SimulationAction : DTDFVocab:Action [
    base:desc "Automated simulation run action in Simulink."
    DTDFVocab:IsAutomatic true
]

instance DataInsight : DTDFVocab:Insight [
    base:desc "Insight into the quality and completeness of contextual data traces."
]

instance DataAction : DTDFVocab:Action [
    base:desc "Automated data ingestion and preprocessing action for the digital twin."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellation is orchestrated through a multi‑layer model‑based systems engineering (MBSE) architecture. Functional and logical abstractions are realised with SysML Interaction‑Block Diagrams (IBDs) or through architecture description languages such as ACME, AADL, or MontiArc. Behavioral dynamics are encoded in MontiArc Automaton, SysML state machines, or embedded MATLAB/Simulink. These models are transformed and synchronised via a common metamodel to generate executable artefacts in C++ or Java, which are then deployed as runtime components. The constellation manages resource allocation, simulation scheduling, and consistency checks across the distributed models, thereby enabling coordinated operation of the digital twin subsystems."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital Twin lifecycle is organized into the following MBSE phases: 1) Requirements Modeling – captured via SysML requirement diagrams; 2) Functional Architecture – expressed in SysML Block Definition and Internal Block Diagrams, and by ADLs such as ACME or AADL components; 3) Logical Architecture – further decomposed with MontiArc automaton/state‑machine constructs; 4) Product/Technical Implementation – implemented through Simulink models, MATLAB code, or general‑purpose languages such as C++/Java. Transition between phases is achieved by model transformation and integration of heterogeneous notations, enabling traceability across abstraction layers. Lifecycle governance is implicitly supported by MBSE best practices and the use of consistent modeling languages, though an explicit governance framework is not described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration is achieved by composing heterogeneous modeling and simulation frameworks. The system imports SysML, AADL, MontiArc, and Simulink artefacts and integrates them through model‑to‑model and model‑to‑code transformations. Generated code in C++/Java exposes services that can be consumed by enterprise applications. Integration patterns include synchronous model updates, API‑based data exchange, and runtime coupling of simulation engines with external analytics or control services. This approach enables the digital twin to interoperate with other enterprise systems using the standard MBSE toolchain and shared APIs."
]