// C3: Physical sensing components
instance MosquittoMqttGateway : DTDFVocab:SensingComponent [
    base:desc "Collects physical system data via MQTT using the Mosquitto server‑client library for one‑way automated data flow to the digital twin."
    DTDFVocab:producedData MqttTelemetryData
]

// C4: Physical-to-virtual interaction
instance MqttTelemetryData : DTDFVocab:DataTransmitted [
    base:desc "Data transmitted from the Mosquitto MQTT gateway to the digital twin platform."
    DTDFVocab:producedFrom MosquittoMqttGateway
]

// C10: Data (input trace)
instance TelemetryDataTrace : DTDFVocab:Data [
    base:desc "Raw telemetry trace collected from physical sensors, originating from MQTT telemetry data."
    DTDFVocab:fromData MqttTelemetryData
    DTDFVocab:inputTo ThingsboardProcessingEnabler
]

// C10: Data (output trace)
instance SimulationOutputTrace : DTDFVocab:Data [
    base:desc "Processed simulation output trace generated by executing Simulink or ML models on input telemetry."
    DTDFVocab:fromData MqttTelemetryData
    DTDFVocab:inputTo ThingsboardProcessingEnabler
]

// C11: Enablers
instance ThingsboardProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing enabler based on Thingsboard (v4.0.0) that ingests MQTT data, invokes simulation or machine‑learning models, and generates digital shadow traces."
    DTDFVocab:enables ModelExecutionService
]

// C6: Services
instance ModelExecutionService : DTDFVocab:Service [
    base:desc "Executes simulation (Simulink) and data‑calculation (ML) models to produce analytical results for the digital twin."
    DTDFVocab:provides SimulationTraceInsight, UpdateDigitalShadowAction
]

// C17: Insights
instance SimulationTraceInsight : DTDFVocab:Insight [
    base:desc "Provides traceability of simulation outputs back to originating physical data and models."
]

// C17: Actions
instance UpdateDigitalShadowAction : DTDFVocab:Action [
    base:desc "Updates the digital shadow with new model outputs; automated."
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML requirements model capturing functional and quality requirements of the system under study."
    DTDFVocab:inputTo ThingsboardProcessingEnabler
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML functional architecture model defining component interactions and logical behavior."
    DTDFVocab:inputTo ThingsboardProcessingEnabler
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Simulink dynamic simulation model delivering physics‑based behavioral representation (white‑box)."
    DTDFVocab:inputTo ThingsboardProcessingEnabler
]

instance MachineLearningPredictionModel : DTDFVocab:Model [
    base:desc "Machine‑learning prediction model capturing data‑driven relationships (black‑box)."
    DTDFVocab:inputTo ThingsboardProcessingEnabler
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the Model‑Based Systems‑Engineering (MBSE) abstraction layers described in Document 1: a requirements stage, a functional‑architecture stage, a logical‑architecture stage, and a product/technical (implementation) stage. At each stage the DT is represented by SysML diagrams (e.g., block definition and internal‑block diagrams) or architecture description languages (ADLs) such as ACME, AADL, or MontiArc. Transition between stages is managed by mapping models from one abstraction to the next, and the overall development integrates heterogeneous stakeholder perspectives as required by MBSE."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is achieved by integrating white‑box (e.g., Simulink) and black‑box (e.g., machine‑learning) models while preserving full traceability from raw data traces through processing components to the generated shadow. Verification of model transformations, such as from SysML specifications to simulation models, is mandated to ensure correctness of the generated artifacts. Uncertainty sources—including sensor noise and model approximation errors—are acknowledged, and the reference model’s fine‑grained traceability links enable detection of inconsistencies and propagation of corrective actions. Quality assurance relies on these traceability mechanisms together with verification methods cited for model‑based development of complex systems."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital shadow approach described in the CNC‑machine case study employs cloud‑based technologies for hosting the digital representation at the machine‑shop floor level, indicating that the deployment can be performed on cloud platforms. No further details on compute, storage, scalability, or redundancy are provided."
]