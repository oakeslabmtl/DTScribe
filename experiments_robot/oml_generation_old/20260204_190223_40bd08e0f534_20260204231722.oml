// C3: Physical sensing component (derived from digital shadow definition)
instance PhysicalStateSensor : DTDFVocab:SensingComponent [
    base:desc "Automated one-way data flow component that captures the physical object's state as contextual data traces, as defined in the digital shadow description."
    DTDFVocab:producedData PhysicalStateDataTransmitted
]

// C4: Physical-to-virtual interaction – data transmitted
instance PhysicalStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalStateSensor
    base:desc "Contextual data trace collected from the physical object, aggregated and abstracted for a specific purpose (digital shadow)."
]

// C10: Data (aggregated contextual data)
instance AggregatedContextualData : DTDFVocab:Data [
    DTDFVocab:fromData PhysicalStateDataTransmitted
    DTDFVocab:inputTo ProcessingComponentEnabler
    base:desc "Aggregated and abstracted contextual data derived from raw physical state traces, used as input for processing components."
]

// C10: Models/Data – SysML model
instance SysMLLogicalModel : DTDFVocab:Model [
    base:desc "SysML logical/functional architecture model capturing structural aspects (components, interfaces, connectors) of the system."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

// C10: Models/Data – Simulink model
instance SimulinkBehavioralModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink executable simulation model representing behavioral and analytical dynamics of the physical asset."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

// C10: Model artefact data – SysML model data
instance SysMLModelData : DTDFVocab:Data [
    base:desc "Data representing the SysML logical model artifacts employed in processing."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

// C10: Model artefact data – Simulink model data
instance SimulinkModelData : DTDFVocab:Data [
    base:desc "Data representing the Simulink simulation outputs used in analytics."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

// C11: Enabler – processing component
instance ProcessingComponentEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that consumes raw data traces, applies engineering/simulation/data-calculation models, and emits derived output traces, maintaining provenance via 'originates‑from' links."
    DTDFVocab:enables AnalyticsService
]

// C6: Service – analytics
instance AnalyticsService : DTDFVocab:Service [
    base:desc "Service performing model‑driven analytics to generate performance metrics and anomaly indicators from derived data traces."
    DTDFVocab:provides PerformanceMetricInsight, AnomalyIndicatorInsight
]

// C17: Insight – performance metrics
instance PerformanceMetricInsight : DTDFVocab:Insight [
    base:desc "Insight providing performance metrics of the physical asset derived from processed data."
]

// C17: Insight – anomaly detection
instance AnomalyIndicatorInsight : DTDFVocab:Insight [
    base:desc "Insight indicating anomalies detected in the physical asset based on processed data traces."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The paper states that a Digital Twin can provide active components that interpret and process incoming data and may push information back to the physical asset, unlike a digital shadow. No concrete command types, message formats, validation, authentication, feedback loops, conflict‑resolution procedures or execution confirmations are described in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin maintains a real‑time, data‑driven representation of the physical asset. Live measurements are captured from the asset and streamed continuously to the twin using the MQTT protocol, enabling near‑real‑time synchronization between physical and digital components. The temporal granularity follows individual measurement events, and latency is kept minimal to support real‑time decision making."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system architecture follows the Digital Shadow Reference Model, which defines concepts such as data traces, processing components, and engineering or simulation models together with their associations. Concrete realizations are created by mapping these reference concepts to specific classes and components using MBSE languages (e.g., SysML) and architecture description languages (e.g., ACME, AADL). Active processing components consume input data traces, apply the associated models, and produce output traces, establishing a traceable data pipeline. This orchestrated structure integrates heterogeneous models and tools while supporting fine‑grained traceability across the Digital Twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through systematic traceability and verification of transformations (e.g., from SysML to simulation models). Validation includes checking the correctness of both the white‑box Simulink simulation and the black‑box machine‑learning components against recorded robot state data. Uncertainty sources such as sensor noise and model approximation errors are acknowledged, with a need for quantification and error‑correction mechanisms. The reliability of the Digital Twin relies on rigorous verification of model transformations and continuous verification of data integrity, as emphasized for digital shadows."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin design adheres to several industry‑accepted modeling standards: SysML (including state‑machine specifications in version 1.7) is used for structural and behavioral engineering models; architecture description languages such as ACME, AADL, and MontiArc are employed for component‑connector representations; the reference‑model approach relies on a conformance relation that defines which concrete models conform to the abstract domain concepts. No additional certification or interoperability standards are explicitly referenced."
]