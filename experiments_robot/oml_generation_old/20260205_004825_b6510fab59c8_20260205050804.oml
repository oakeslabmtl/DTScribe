// Acting Components
instance PermanentMagnetSynchronousMotorActingComponent : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor (PMSM) used as the primary actuator for the first axis, modeled with its mechanical interface and gear reduction path."
]

instance GearboxCycloidalGeartrainActingComponent : DTDFVocab:ActingComponent [
    base:desc "Gearbox followed by a cycloidal gearset forming a combined gear train for precise positional reduction of the motor output shaft."
]

// Physical Components
instance PermanentMagnetSynchronousMotorComponent : DTDFVocab:Component [
    base:desc "Physical PMSM motor component in the drive system."
]

instance GearboxComponent : DTDFVocab:Component [
    base:desc "Gearbox and cycloidal gearset providing positional reduction."
]

instance MotorShaftEncoderComponent : DTDFVocab:Component [
    base:desc "Incremental position encoder mounted on the PMSM shaft."
]

instance GearboxOutputEncoderComponent : DTDFVocab:Component [
    base:desc "Incremental position encoder positioned behind the gearbox to measure output shaft position."
]

instance MotorCurrentSensorComponent : DTDFVocab:Component [
    base:desc "Current sensor measuring input current to the PMSM drive electronics."
]

// Sensing Components
instance MotorShaftEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Incremental encoder mounted directly on the PMSM shaft."
    DTDFVocab:producedData MotorShaftEncoderDataMQTT
]

instance GearboxOutputEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Incremental encoder positioned behind the gearbox to capture output shaft position."
    DTDFVocab:producedData GearboxOutputEncoderDataMQTT
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring input current to the PMSM drive electronic system."
    DTDFVocab:producedData MotorCurrentDataMQTT
]

// Data Transmitted (via MQTT)
instance MotorShaftEncoderDataMQTT : DTDFVocab:DataTransmitted [
    base:desc "MQTT message containing raw motor shaft encoder angle data."
    DTDFVocab:producedFrom MotorShaftEncoderSensor
]

instance GearboxOutputEncoderDataMQTT : DTDFVocab:DataTransmitted [
    base:desc "MQTT message containing raw gearbox output encoder angle data."
    DTDFVocab:producedFrom GearboxOutputEncoderSensor
]

instance MotorCurrentDataMQTT : DTDFVocab:DataTransmitted [
    base:desc "MQTT message containing raw motor input current data."
    DTDFVocab:producedFrom MotorCurrentSensor
]

// Data (internal representation)
instance MotorShaftEncoderData : DTDFVocab:Data [
    base:desc "Raw angle data from motor shaft encoder, received via MQTT."
    DTDFVocab:fromData MotorShaftEncoderDataMQTT
    DTDFVocab:inputTo MqttReceiverEnabler
]

instance GearboxOutputEncoderData : DTDFVocab:Data [
    base:desc "Raw angle data from gearbox output encoder, received via MQTT."
    DTDFVocab:fromData GearboxOutputEncoderDataMQTT
    DTDFVocab:inputTo MqttReceiverEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Current measurement data from PMSM drive, received via MQTT."
    DTDFVocab:fromData MotorCurrentDataMQTT
    DTDFVocab:inputTo MqttReceiverEnabler
]

// Enabler (MQTT Receiver)
instance MqttReceiverEnabler : DTDFVocab:Enabler [
    base:desc "MQTT receiver enabler that ingests sensor data into the digital twin's data acquisition layer."
    DTDFVocab:enables JointStateEstimationService
]

// Service (Joint State Estimation)
instance JointStateEstimationService : DTDFVocab:Service [
    base:desc "Service that processes encoder and current data to estimate joint angular position and detect encoder errors."
    DTDFVocab:provides UpdateTwinJointPositionAction
]

// Action (Automatic Update of Digital Twin)
instance UpdateTwinJointPositionAction : DTDFVocab:Action [
    base:desc "Automatic action to update the digital twin's joint state with the latest encoder data and apply error compensation."
    DTDFVocab:IsAutomatic true
]

// Environment (contains all physical components)
instance IndustrialDriveEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotorComponent, GearboxComponent, MotorShaftEncoderComponent, GearboxOutputEncoderComponent, MotorCurrentSensorComponent
]

// Computational Model (optional, linked to MQTT input)
instance JointStateEstimationModel : DTDFVocab:Model [
    base:desc "Computational model capturing the physics of motor and gearbox to estimate joint position, described in SysML, ACME, or AADL."
    DTDFVocab:inputTo MqttReceiverEnabler
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle is organised into four abstraction layers—requirements, functional architecture, logical architecture, and product/technical. Each layer is described with an appropriate model‑based engineering notation: SysML for requirements and functional models, ACME, AADL, and MontiArc for logical component–connector architectures, and Simulink (together with C++/Java implementation artefacts) for product‑level behaviours. Transitions between layers are guided by system‑engineering methodologies such as RFLP, OOSEM, SPES and SMArDT, which provide traceability and mapping rules to preserve consistency across layers."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data from the physical system are transmitted to the digital twin using the MQTT protocol over an internal network.  The document does not provide additional details on network topology, bandwidth, latency, redundancy, or security mechanisms."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system conforms to industry standards including SysML v1.7 for functional and behavioural modelling, UML for broader system design, the Asset Administration Shell (AAS) specification for semantic interoperability, and MQTT as the messaging protocol for real‑time data exchange."
]