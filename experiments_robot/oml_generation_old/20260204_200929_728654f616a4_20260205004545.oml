{ 
instance SysML : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering tool using SysML for system modeling"
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "RFLP methodology for requirements, functions, logics, physics abstraction levels"
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for object-oriented system engineering"
]

instance SPES : DTDFVocab:Enabler [
    base:desc "SPES methodology for system engineering"
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for smart digital twin"
]

instance ACME : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component modeling"
]

instance AADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for system architecture"
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component interconnections"
]

instance SysMLIBDs : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component interfaces"
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral modeling"
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation"
]

instance Cpp : DTDFVocab:Enabler [
    base:desc "C++ programming language for implementation"
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java programming language for implementation"
]

instance PhysicalSystemStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing physical system states",
    DTDFVocab:producedData PhysicalSystemStateDataTransmitted
]

instance ContextualDataAggregationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor aggregating contextual data traces",
    DTDFVocab:producedData ContextualDataTracesTransmitted
]

instance PhysicalSystemStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemStateSensor
]

instance ContextualDataTracesTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContextualDataAggregationSensor
]

instance PhysicalSystemStateData : DTDFVocab:Data [
    base:desc "Physical system state data from sensors",
    DTDFVocab:fromData PhysicalSystemStateDataTransmitted,
    DTDFVocab:inputTo Simulink, Cpp, Java
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces for specific purposes",
    DTDFVocab:fromData ContextualDataTracesTransmitted,
    DTDFVocab:inputTo Simulink, Cpp, Java
]

instance SysMLMultiLevelModel : DTDFVocab:Model [
    base:desc "SysML model for multi-level abstraction (requirements, functional, logical, technical layers)",
    DTDFVocab:inputTo SysML
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME model for component and interface definition",
    DTDFVocab:inputTo ACME
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL model for system architecture description",
    DTDFVocab:inputTo AADL
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc model for component interconnections",
    DTDFVocab:inputTo MontiArc
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram for component interfaces",
    DTDFVocab:inputTo SysMLIBDs
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral specification",
    DTDFVocab:inputTo MontiArcAutomaton
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavior specification",
    DTDFVocab:inputTo SysML
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "Simulink simulation model",
    DTDFVocab:inputTo Simulink
]

instance CppImplementation : DTDFVocab:Model [
    base:desc "C++ implementation code",
    DTDFVocab:inputTo Cpp
]

instance JavaImplementation : DTDFVocab:Model [
    base:desc "Java implementation code",
    DTDFVocab:inputTo Java
]
}