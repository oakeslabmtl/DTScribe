instance PhysicalSystemStateSensor : DTDFVocab:SensingComponent [
    base:desc "Physical system state data sources as described in digital shadow reference model"
    DTDFVocab:producedData PhysicalSystemStateDataTransmitted
]

instance PhysicalSystemStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemStateSensor
]

instance PhysicalSystemStateData : DTDFVocab:Data [
    base:desc "Heterogeneous data from physical system states integrated across multiple notations and tools to address stakeholder perspectives"
    DTDFVocab:fromData PhysicalSystemStateDataTransmitted
    DTDFVocab:inputTo Enabler_MBSE_SysML, Enabler_RFLP, Enabler_OOSEM, Enabler_SPES, Enabler_SMArDT, Enabler_ACME, Enabler_AADL, Enabler_MontiArc, Enabler_SysMLIBD, Enabler_MontiArcAutomaton, Enabler_SysMLStateMachines, Enabler_Simulink, Enabler_CPlusPlus, Enabler_Java
]

instance Model_Structural_SysML_IBD : DTDFVocab:Model [
    base:desc "Structural component model using SysML Internal Block Diagrams"
    DTDFVocab:inputTo Enabler_SysMLIBD
]

