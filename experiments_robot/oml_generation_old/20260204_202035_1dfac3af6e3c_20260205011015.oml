    base:desc "Behavioral model using MontiArc Automaton"
    DTDFVocab:inputTo Enabler_MontiArcAutomaton
]

instance Model_Behavioral_SysML_StateMachines : DTDFVocab:Model [
    base:desc "Behavioral model using SysML v1.7 state machines"
    DTDFVocab:inputTo Enabler_SysMLStateMachines
]

instance Model_Analytical_Simulink : DTDFVocab:Model [
    base:desc "Analytical model using MathWorks Simulink"
