// C1: Component of the system under study
instance RobotArmMABI100 : DTDFVocab:Component [
    base:desc "Six-axis serial industrial robot MABI MAX 100 with permanent-magnet synchronous motors and gear transmissions."
]

// C2: Acting Components
instance Joint1PMSMActuator : DTDFVocab:ActingComponent [
    base:desc "High-speed permanent‑magnet synchronous motor driving the first axis, governed by Siemens SINUMERIK 840D SL controller and PLC network."
]

// C3: Physical Sensing Components
instance Joint1MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑precision motor‑shaft encoder mounted directly on the PMSM shaft of joint 1, delivering 0.1 mm positional accuracy."
    DTDFVocab:producedData Joint1MotorShaftPositionDataTransmitted
]

instance Joint1GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located after the reduction gearbox of joint 1, complementing shaft encoder for high‑accuracy position measurement."
    DTDFVocab:producedData Joint1GearboxPositionDataTransmitted
]

// C4: DataTransmitted
instance Joint1MotorShaftPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Joint1MotorShaftEncoder
]

instance Joint1GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Joint1GearboxEncoder
]

// C5: Data
instance Joint1MotorShaftPositionData : DTDFVocab:Data [
    base:desc "Angular position data from joint 1 motor‑shaft encoder, accurate to 0.1 mm."
    DTDFVocab:fromData Joint1MotorShaftPositionDataTransmitted
    DTDFVocab:inputTo MontiArcTool
]

instance Joint1GearboxPositionData : DTDFVocab:Data [
    base:desc "Angular position data from joint 1 gearbox encoder, enhancing system repeatability."
    DTDFVocab:fromData Joint1GearboxPositionDataTransmitted
    DTDFVocab:inputTo SimulinkSimulator
]

// C10: Models
instance Joint1AnalyticalFrictionModel : DTDFVocab:Model [
    base:desc "White‑box analytical friction formulation for joint 1."
    DTDFVocab:inputTo MontiArcTool
]

instance Joint1DataDrivenSurrogateModel : DTDFVocab:Model [
    base:desc "Black‑box surrogate model trained on live sensor streams for joint 1 dynamics."
    DTDFVocab:inputTo CppCodeGenerator
]

instance Joint1SimulationModel : DTDFVocab:Model [
    base:desc "Simulink numerical solver model of joint 1 dynamics for real‑time simulation."
    DTDFVocab:inputTo SimulinkSimulator
]

// C11: Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML modeling environment capturing functional and logical architecture of the robot system."
    DTDFVocab:enables ModelGenerationService
]

instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc automaton tool for specifying component behavior and generating code."
    DTDFVocab:enables ModelGenerationService
]

instance SimulinkSimulator : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink used for dynamic simulation of the robot."
    DTDFVocab:enables SimulationService
]

instance CppCodeGenerator : DTDFVocab:Enabler [
    base:desc "C++ code generator for deploying models onto embedded controllers."
    DTDFVocab:enables DeploymentService
]

// C6: Services
instance ModelGenerationService : DTDFVocab:Service [
    base:desc "Generates structural and behavioral models for the Digital Twin using MBSE tools."
    DTDFVocab:provides ModelAccuracyInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs real‑time simulations of robot behavior in Simulink."
    DTDFVocab:provides RealTimeJointStateInsight
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Deploys generated C++/Java code to embedded controllers."
    DTDFVocab:provides AdjustMotorCommandAction
]

// C17: Insights and Actions
instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Insight on the accuracy of generated analytical and surrogate models."
]

instance RealTimeJointStateInsight : DTDFVocab:Insight [
    base:desc "Provides real‑time awareness of joint positions and velocities."
]

instance AdjustMotorCommandAction : DTDFVocab:Action [
    base:desc "Automatically adjusts motor commands to maintain trajectory precision in real time."
    DTDFVocab:IsAutomatic true
]

// C18: Environment
instance RobotWorkspace : DTDFVocab:Environment [
    base:contains RobotArmMABI100, Joint1PMSMActuator, Joint1MotorShaftEncoder, Joint1GearboxEncoder
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Digital Twin orchestration follows a multi‑level MBSE approach. The physical system is modeled at requirements, functional, logical and product/technical layers using SysML, with the logical architecture expressed via ADLs such as AADL and MontiArc. Behavior is captured in dynamic models, for example using MATLAB/Simulink, Simulink‑Automaton or state machines from SysML v1.7. Code generation in C++ or Java is performed to drive the digital twin, and the various modeling artefacts are integrated through model‑interchange and code‑generation tools supplied by MathWorks and system‑integrators."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital Twin lifecycle as described in the document comprises four core modeling phases conducted within Model‑Based Systems Engineering (MBSE). 1) **Requirements modeling** captured with SysML, 2) **Functional architecture** defined in SysML and refined through advanced Architecture Description Languages such as ACME or AADL, 3) **Logical architecture** mapped via methodologies like RFLP (Requirements‑Functions‑Logics‑Physics), OOSEM, SPES or SMArDT, and 4) **Product/technical implementation** produced by simulation and code generation tools (e.g., MathWorks Simulink, C++/Java code). Transition between phases is achieved by hierarchical model refinement and composition, and governance of the lifecycle is implied by the multi‑layered abstraction and stakeholder integration required for the manufacturing focus of the reference model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is validated through a continuous comparison of simulated joint trajectories—generated by the integrated engineering, data‑calculation, and simulation models—with real‑time encoder measurements. The root‑mean‑square deviation between simulation and measurement serves as an error indicator for backlash, elasticity, and friction in the drive train. The dual‑encoder arrangement reduces positional uncertainty by providing redundant position feedback, enabling the system to bound the residual error. Whenever the residual exceeds a tolerance inferred from empirical calibration, the friction model is updated; this loop ensures that the Digital Twin remains an accurate, data‑driven representation of the physical system."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adopts standardized modeling languages: SysML (requirements, functional, logical, behavioral modeling) and UML (for behavior such as state‑machine diagrams). No additional compliance, certification, or interoperability standards are mentioned in the provided document."
]