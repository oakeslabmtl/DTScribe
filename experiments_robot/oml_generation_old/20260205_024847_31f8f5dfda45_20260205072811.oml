// System Components
instance MotorComponent : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor of the first rotary axis."
]

instance GearwheelComponent : DTDFVocab:Component [
    base:desc "Gearwheel of the first motor gearbox."
]

instance CycloidalGearboxComponent : DTDFVocab:Component [
    base:desc "Cycloidal gearbox of the first rotary axis."
]

instance MotorEncoderComponent : DTDFVocab:Component [
    base:desc "Motor encoder attached to the motor."
]

instance SecondaryEncoderComponent : DTDFVocab:Component [
    base:desc "Secondary encoder positioned behind the gearbox."
]

// Environment
instance Axis1Environment : DTDFVocab:Environment [
    base:contains MotorComponent, GearwheelComponent, CycloidalGearboxComponent, MotorEncoderComponent, SecondaryEncoderComponent
]

// Sensing Components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) measuring the electrical current of the motor."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder attached to the motor providing motor angle information."
    DTDFVocab:producedData MotorEncoderAngleDataTransmitted
]

instance SecondaryEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind the gearbox providing secondary angle information."
    DTDFVocab:producedData SecondaryEncoderAngleDataTransmitted
]

instance AngularPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Angular position sensor measuring the overall axis position."
    DTDFVocab:producedData AngularPositionDataTransmitted
]

// Data Transmitted
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance SecondaryEncoderAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoderSensor
]

instance AngularPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularPositionSensor
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance AccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

// Data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Raw motor current measurement."
    DTDFVocab:inputTo MATLABSimulinkTool
    DTDFVocab:fromData MotorCurrentDataTransmitted
]

instance MotorEncoderAngleData : DTDFVocab:Data [
    base:desc "Motor encoder raw angle measurement."
    DTDFVocab:inputTo MATLABSimulinkTool
    DTDFVocab:fromData MotorEncoderAngleDataTransmitted
]

instance SecondaryEncoderAngleData : DTDFVocab:Data [
    base:desc "Secondary encoder raw angle measurement."
    DTDFVocab:inputTo MATLABSimulinkTool
    DTDFVocab:fromData SecondaryEncoderAngleDataTransmitted
]

instance AngularPositionData : DTDFVocab:Data [
    base:desc "Angular position sensor raw measurement."
    DTDFVocab:inputTo MATLABSimulinkTool
    DTDFVocab:fromData AngularPositionDataTransmitted
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque from motor current and gearbox characteristics."
    DTDFVocab:inputTo MATLABSimulinkTool
    DTDFVocab:fromData TorqueDataTransmitted
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity from encoder angles."
    DTDFVocab:inputTo MATLABSimulinkTool
    DTDFVocab:fromData AngularVelocityDataTransmitted
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived acceleration from encoder data."
    DTDFVocab:inputTo MATLABSimulinkTool
    DTDFVocab:fromData AccelerationDataTransmitted
]

// Enablers
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML tool for structural modeling of motor and gearboxes."
    DTDFVocab:enables FrictionModelIdentificationService
]

instance MATLABSimulinkTool : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for executable simulation models."
    DTDFVocab:enables ParameterEstimationService, ModelUpdatingService
]

instance UnifiedDashboard : DTDFVocab:Enabler [
    base:desc "Unified dashboard for real‑time diagnostic visualization."
    DTDFVocab:enables RealTimeDiagnosticDashboardService, FrictionAugmentedMotionModelService
]

// Services
instance RealTimeDiagnosticDashboardService : DTDFVocab:Service [
    base:desc "Real‑time dashboard visualising measured and simulated data."
    DTDFVocab:provides FrictionLossInsight
]

instance FrictionModelIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification and comparison of friction models (white‑box and black‑box)."
    DTDFVocab:provides FrictionLossInsight
]

instance ParameterEstimationService : DTDFVocab:Service [
    base:desc "Parameter estimation for friction model updating."
    DTDFVocab:provides ApplyParameterUpdateAction
]

instance ModelUpdatingService : DTDFVocab:Service [
    base:desc "Model updating based on newly estimated parameters."
    DTDFVocab:provides UpdateSimulationModelAction
]

instance FrictionAugmentedMotionModelService : DTDFVocab:Service [
    base:desc "Provision of friction‑augmented motion models to improve robot accuracy."
    DTDFVocab:provides EnhanceMotionAccuracyAction
]

// Insights / Actions
instance FrictionLossInsight : DTDFVocab:Insight [
    base:desc "Diagnostic insight into friction loss and its evolution, impacting motion accuracy."
]

instance ApplyParameterUpdateAction : DTDFVocab:Action [
    base:desc "Apply updated friction parameters to the control system."
    DTDFVocab:IsAutomatic true
]

instance UpdateSimulationModelAction : DTDFVocab:Action [
    base:desc "Update simulation model with newly estimated friction parameters."
    DTDFVocab:IsAutomatic true
]

instance EnhanceMotionAccuracyAction : DTDFVocab:Action [
    base:desc "Enhance robot motion accuracy by integrating friction‑augmented model."
    DTDFVocab:IsAutomatic true
]

// Models
instance SysMLModel_MotorGearboxes : DTDFVocab:Model [
    base:desc "SysML BDD/IBD of the motor and gearbox structure."
    DTDFVocab:inputTo SysMLTool
]

instance MATLABSimulinkModel_Motor : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the permanent‑magnet synchronous motor."
    DTDFVocab:inputTo MATLABSimulinkTool
]

instance MATLABSimulinkModel_Gearwheel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the gearwheel component."
    DTDFVocab:inputTo MATLABSimulinkTool
]

instance MATLABSimulinkModel_Gearbox : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the cycloidal gearbox."
    DTDFVocab:inputTo MATLABSimulinkTool
]

instance MATLABSimulinkModel_FrictionCoulombViscous : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction model: Coulomb‑Viscous."
    DTDFVocab:inputTo MATLABSimulinkTool
]

instance MATLABSimulinkModel_FrictionStribeck : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction model: Stribeck."
    DTDFVocab:inputTo MATLABSimulinkTool
]

instance MATLABSimulinkModel_FrictionDahl : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction model: Dahl."
    DTDFVocab:inputTo MATLABSimulinkTool
]

instance MATLABSimulinkModel_FrictionLuGre : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction model: LuGre."
    DTDFVocab:inputTo MATLABSimulinkTool
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation – data are acquired and processed continuously while the robot is running, with streaming rate defined by the sensor sampling (typically milliseconds to seconds, not explicitly quantified)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated set consisting of the physical robot first axis, MQTT‑based sensor data pipeline, a processing component that consumes data traces, executes the simulation models, and produces derived traces, and a visualization dashboard that presents the comparative data to users"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (engineering structural and simulation models) → Operated (continuous identification during robot operation); the DT covers the manufactured and operated states of the first robot axis"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Multi‑physics‑aware continuous identification of friction parameters, traceability of data traces back to sources and models, comparison of measured vs simulated data, and use of both white‑box analytical and black‑box data‑driven models to validate and refine the twin"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol for streaming time‑series data from the robot controller to the digital shadow; the Asset Administration Shell connects asset metadata to data traces"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for model‑based systems engineering, Asset Administration Shell (AAS) as an industrial standard for digital twins, and adherence to MBSE methodologies such as RFLP, OOSEM, and SPES in the development process"
]