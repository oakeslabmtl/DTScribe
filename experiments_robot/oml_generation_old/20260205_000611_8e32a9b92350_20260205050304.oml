// ------------------------------------------- // AAS Digital Shadow for the first axis of MABI MAX 100
// Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor I_M capturing motor electrical current of the first axis"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the motor shaft measuring angular position"
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind the gearbox measuring output angular position"
    DTDFVocab:producedData GearboxPositionDataTransmitted
]

// Data transmitted via MQTT
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

// Measured data traces
instance CurrentData : DTDFVocab:Data [
    base:desc "Measured motor current value transmitted via MQTT"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo MQTTDataStreaming, SimulinkSimulationTool, DashboardVisualizationPlatform
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Measured motor shaft angular position transmitted via MQTT"
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo MQTTDataStreaming, SimulinkSimulationTool, DashboardVisualizationPlatform
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Measured gearbox output angular position transmitted via MQTT"
    DTDFVocab:fromData GearboxPositionDataTransmitted
    DTDFVocab:inputTo MQTTDataStreaming, SimulinkSimulationTool, DashboardVisualizationPlatform
]

// Simulated data traces (derived from models)
instance SimulatedCurrentData : DTDFVocab:Data [
    base:desc "Simulated motor current generated by Simulink friction models"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationTool, DashboardVisualizationPlatform
]

instance SimulatedMotorPositionData : DTDFVocab:Data [
    base:desc "Simulated motor shaft angular position generated by Simulink models"
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationTool, DashboardVisualizationPlatform
]

instance SimulatedGearboxPositionData : DTDFVocab:Data [
    base:desc "Simulated gearbox output angular position generated by Simulink models"
    DTDFVocab:fromData GearboxPositionDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationTool, DashboardVisualizationPlatform
]

// Asset and behavior modeling (SysML)
instance MotorGearboxStructuralModel : DTDFVocab:Model [
    base:desc "SysML structural model of the permanent‑magnet synchronous motor and both gearboxes for the first axis of the MABI MAX 100 robot"
    DTDFVocab:inputTo SysMLModelingTool
]

// Simulation models (Simulink)
instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "Simulink executable model of the motor dynamics and gearbox friction"
    DTDFVocab:inputTo SimulinkSimulationTool
]

instance WhiteBoxCoulombViscousModel : DTDFVocab:Model [
    base:desc "White‑box analytic model describing Coulomb‑Viscous friction behaviour"
    DTDFVocab:inputTo SimulinkSimulationTool
]

instance WhiteBoxStribeckModel : DTDFVocab:Model [
    base:desc "White‑box analytic model describing Stribeck friction characteristics"
    DTDFVocab:inputTo SimulinkSimulationTool
]

instance WhiteBoxDahlModel : DTDFVocab:Model [
    base:desc "White‑box analytic model describing Dahl friction behaviour"
    DTDFVocab:inputTo SimulinkSimulationTool
]

instance WhiteBoxLuGreModel : DTDFVocab:Model [
    base:desc "White‑box analytic model describing LuGre friction behaviour"
    DTDFVocab:inputTo SimulinkSimulationTool
]

// Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML used for asset and behavior modeling of the robot axis"
    DTDFVocab:enables RealTimeVisualizationService
]

instance SimulinkSimulationTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for executable simulation of motor and gearbox friction models"
    DTDFVocab:enables FrictionIdentificationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell linking DT models and data with semantic support"
    DTDFVocab:enables DataLinkingService
]

instance MQTTDataStreaming : DTDFVocab:Enabler [
    base:desc "MQTT broker for real‑time streaming of sensor data from the robot PLC/CNC"
    DTDFVocab:enables DataLinkingService
]

instance DashboardVisualizationPlatform : DTDFVocab:Enabler [
    base:desc "Web‑UI dashboard for real‑time visualization of measured, reference and simulated data traces"
    DTDFVocab:enables RealTimeVisualizationService
]

// Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Aggregates measured, reference and simulated data traces for real‑time visualisation"
    DTDFVocab:provides FrictionLossDetectionInsight, BaselinePreparationInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuously identifies and updates friction model parameters using white‑box and black‑box models"
    DTDFVocab:provides UpdateFrictionModelAction, MaintenanceDecisionAction
]

instance DataLinkingService : DTDFVocab:Service [
    base:desc "Provides data linking and semantic support for debugging and model refinement"
    DTDFVocab:provides DataLinkageInsight
]

// Insights and Actions
instance FrictionLossDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection and quantification of friction loss in the gearbox"
]

instance BaselinePreparationInsight : DTDFVocab:Insight [
    base:desc "Providing a baseline for future comprehensive digital twins"
]

instance UpdateFrictionModelAction : DTDFVocab:Action [
    base:desc "Updating friction model parameters to improve control accuracy"
    DTDFVocab:IsAutomatic true
]

instance MaintenanceDecisionAction : DTDFVocab:Action [
    base:desc "Informing maintenance decisions based on identified wear patterns"
    DTDFVocab:IsAutomatic false
]

instance DataLinkageInsight : DTDFVocab:Insight [
    base:desc "Semantic support for debugging and refining models within the digital twin"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data ingestion and processing synchronized with the robot’s sampling rate (typical motor encoder rate, e.g., 1 kHz); continuous identification and analysis during operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Integration of SysML asset model, AAS integration component, Simulink simulation engine, MQTT data ingestion, processing component that consumes input traces and generates derived traces, and a web‑based dashboard presenting all data."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated phase – the digital shadow monitors and identifies friction losses during the robot’s operational life, using models derived from the as‑manufactured asset description."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of data points from source to processing component; validation by comparing simulated outputs (with friction models) to measured data; continuous parameter identification for white‑box and black‑box models; uncertainty handled via comparison of multiple frictionalisms (Coulomb‑Viscous, Stribeck, Dahl, LuGre)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data transmitted via MQTT protocol; asset and data linking through Asset Administration Shells (AAS) following IEC 6285; integration with robot PLC/CNC to obtain sensor streams."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for modeling, Asset Administration Shells conforming to IEC 6285, and adherence to the Digital Shadow Reference Model concept defined in the literature."
]