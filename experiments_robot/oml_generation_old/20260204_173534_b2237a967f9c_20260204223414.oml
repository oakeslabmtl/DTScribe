// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) on the permanent‑magnet synchronous motor"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted on the motor shaft providing shaft position (r_M)"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance SecondaryEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder placed after the gearwheel and cycloidal gearbox providing post‑gear position (r_G)"
    DTDFVocab:producedData SecondaryEncoderDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Robot controller output angle sensor delivering the final axis angle (r_out)"
    DTDFVocab:producedData OutputAngleDataTransmitted
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance SecondaryEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoderSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

// C10: Data captured from the transmitted streams
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor current (I_M) values streamed via MQTT"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance MotorEncoderPositionData : DTDFVocab:Data [
    base:desc "Time‑series of motor shaft position (r_M) values streamed via MQTT"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance SecondaryEncoderPositionData : DTDFVocab:Data [
    base:desc "Time‑series of post‑gear position (r_G) values streamed via MQTT"
    DTDFVocab:fromData SecondaryEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Time‑series of final axis angle (r_out) values streamed via MQTT"
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker used for live streaming of sensor time‑series from the robot controller"
    DTDFVocab:enables FrictionIdentificationService, VisualizationService, ControlImprovementService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for running motor, gearwheel and gearbox simulation models"
    DTDFVocab:enables SimulationExecutionService
]

// C10: Models
instance MotorSimModel : DTDFVocab:Model [
    base:desc "Executable simulation model of the permanent‑magnet synchronous motor in MATLAB/Simulink"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance GearwheelSimModel : DTDFVocab:Model [
    base:desc "Simulation model of the gearwheel gearbox component"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance CycloidalGearboxSimModel : DTDFVocab:Model [
    base:desc "Simulation model of the cycloidal gearbox driving the vertical axis"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance FrictionIdentificationModel : DTDFVocab:Model [
    base:desc "Data‑calculation model that processes measured and simulated torque/velocity to identify static, kinetic and viscous friction parameters"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Identifies static, kinetic and viscous friction by comparing simulated and measured torque/velocity"
    DTDFVocab:provides FrictionParameterInsight, UpdateFrictionModelAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualizes raw sensor data, simulation outputs and friction parameter deviations on a unified dashboard"
    DTDFVocab:provides DeviationInsight
]

instance ControlImprovementService : DTDFVocab:Service [
    base:desc "Feeds identified friction parameters back to the robot controller to improve motion accuracy"
    DTDFVocab:provides FeedFrictionParametersAction
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Executes motor, gearwheel and gearbox models to generate simulated torque and velocity traces"
    DTDFVocab:provides SimulationResultInsight
]

// C17: Insights
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters (static, kinetic, viscous) that characterize axis dynamics"
]

instance DeviationInsight : DTDFVocab:Insight [
    base:desc "Highlights deviations between simulated behavior and measured sensor data for engineering decisions"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Provides simulated torque and velocity traces for comparison with live measurements"
]

// C17: Actions
instance UpdateFrictionModelAction : DTDFVocab:Action [
    base:desc "Updates the friction identification model with newly derived parameters"
    DTDFVocab:IsAutomatic true
]

instance FeedFrictionParametersAction : DTDFVocab:Action [
    base:desc "Feeds updated friction parameters to the robot controller to refine motion control"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is defined as a passive one‑way data flow; no commands or control signals are sent from the virtual model back to the robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data acquisition and processing are performed in real‑time (continuous) during robot operation; the paper does not specify a numeric sampling rate."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow constellation follows the Digital Shadow Reference Model: a Purpose (FrictionDerivation), an Asset (MABI axis), Sources (sensors, MQTT channels), Processing components (Simulation_M, Simulation_GW, Simulation_GB) that consume input traces and produce output traces, and Models (engineering, simulation, data‑calculation) linked via explicit associations."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow spans the operated stage of the robot, using engineering models (SysML structural model) created during design and live operational data for runtime identification of friction."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability is ensured by linking each DataPoint to its originating sensor and processing component; friction models are validated by comparing simulated torque/velocity against measured references; the system supports continuous re‑identification to maintain model fidelity over wear."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot controller to the digital shadow via MQTT; the Asset Administration Shell provides structured metadata linking; no other network protocols are described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation uses the Asset Administration Shell (AAS) specification and SysML, which are established standards in Industry 4.0 for data and model representation."
]