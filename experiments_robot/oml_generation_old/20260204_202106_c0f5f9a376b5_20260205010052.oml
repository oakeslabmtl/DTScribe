import DTDFVocab from "http://www.example.org/DTDFVocab"
instance RequirementsSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for requirements phase data from system development",
    DTDFVocab:producedData RequirementsDataTransmitted
]
instance RequirementsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RequirementsSensor
]
instance FunctionalSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for functional architecture data from system development",
    DTDFVocab:producedData FunctionalDataTransmitted
]
instance FunctionalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FunctionalSensor
]
instance LogicalSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for logical architecture data from system development",
    DTDFVocab:producedData LogicalDataTransmitted
]
instance LogicalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LogicalSensor
]
instance ProductTechnicalSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for product/technical layer data from system development",
    DTDFVocab:producedData ProductTechnicalDataTransmitted
]
instance ProductTechnicalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProductTechnicalSensor
]
instance SysMLModelingInsight : DTDFVocab:Insight [
    base:desc "Insight into system structure and behavior from SysML models"
]
instance ACMEArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight into component interactions and system architecture using ACME"
]
instance AADLArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight into embedded system architecture using AADL"
]
instance MontiArcADLInsight : DTDFVocab:Insight [
    base:desc "Insight into component-based system architecture using MontiArc ADL"
]
instance SysMLStateMachinesInsight : DTDFVocab:Insight [
    base:desc "Insight into system behavior from SysML state machine models"
]
instance MontiArcAutomatonInsight : DTDFVocab:Insight [
    base:desc "Insight into system behavior from MontiArc Automaton simulations"
]
instance SimulinkSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight into system dynamics from Simulink simulation results"
]
instance RFLPInsight : DTDFVocab:Insight [
    base:desc "Insight from RFLP methodology application in system design"
]
instance OOSEMInsight : DTDFVocab:Insight [
    base:desc "Insight from OOSEM methodology application in system design"
]
instance SPESInsight : DTDFVocab:Insight [
    base:desc "Insight from SPES methodology application in embedded systems"
]
instance SMArDTInsight : DTDFVocab:Insight [
    base:desc "Insight from SMArDT methodology application in smart product development"
]
instance CppBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight into system behavior from C++ implementation details"
]
instance JavaBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight into system behavior from Java implementation details"
]
instance SysMLModelingService : DTDFVocab:Service [
    base:desc "Service for creating and managing SysML-based system models",
    DTDFVocab:provides SysMLModelingInsight
]
instance ACMEArchitectureService : DTDFVocab:Service [
    base:desc "Service for architectural design using ACME",
    DTDFVocab:provides ACMEArchitectureInsight
]
instance AADLArchitectureService : DTDFVocab:Service [
    base:desc "Service for embedded system architecture using AADL",
    DTDFVocab:provides AADLArchitectureInsight
]
instance MontiArcADLService : DTDFVocab:Service [
    base:desc "Service for component-based architecture using MontiArc ADL",
    DTDFVocab:provides MontiArcADLInsight
]
instance SysMLStateMachinesService : DTDFVocab:Service [
    base:desc "Service for state machine-based behavioral modeling",
    DTDFVocab:provides SysMLStateMachinesInsight
]
instance MontiArcAutomatonService : DTDFVocab:Service [
    base:desc "Service for automaton-based behavior simulation",
    DTDFVocab:provides MontiArcAutomatonInsight
]
instance SimulinkSimulationService : DTDFVocab:Service [
    base:desc "Service for dynamic system simulation and analysis",
    DTDFVocab:provides SimulinkSimulationInsight
]
instance RFLPService : DTDFVocab:Service [
    base:desc "Service for RFLP methodology implementation",
    DTDFVocab:provides RFLPInsight
]
instance OOSEMService : DTDFVocab:Service [
    base:desc "Service for OOSEM methodology implementation",
    DTDFVocab:provides OOSEMInsight
]
instance SPESService : DTDFVocab:Service [
    base:desc "Service for SPES methodology implementation",
    DTDFVocab:provides SPESInsight
]
instance SMArDTService : DTDFVocab:Service [
    base:desc "Service for SMArDT methodology implementation",
    DTDFVocab:provides SMArDTInsight
]
instance CppBehaviorService : DTDFVocab:Service [
    base:desc "Service for behavior specification using C++",
    DTDFVocab:provides CppBehaviorInsight
]
instance JavaBehaviorService : DTDFVocab:Service [
    base:desc "Service for behavior specification using Java",
    DTDFVocab:provides JavaBehaviorInsight
]
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering (MBSE) with SysML for multi-level abstraction modeling",
    DTDFVocab:enables SysMLModelingService
]
instance ACMEADLEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component and interface modeling",
    DTDFVocab:enables ACMEArchitectureService
]
instance AADLADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for embedded systems",
    DTDFVocab:enables AADLArchitectureService
]
instance MontiArcADLEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component-based systems",
    DTDFVocab:enables MontiArcADLService
]
instance SysMLStateMachinesEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 state machine modeling for behavioral specifications",
    DTDFVocab:enables SysMLStateMachinesService
]
instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavior modeling and simulation",
    DTDFVocab:enables MontiArcAutomatonService
]
instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for dynamic system simulation and analysis",
    DTDFVocab:enables SimulinkSimulationService
]
instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP methodology for model-based systems engineering",
    DTDFVocab:enables RFLPService
]
instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for object-oriented systems engineering",
    DTDFVocab:enables OOSEMService
]
instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for embedded systems engineering",
    DTDFVocab:enables SPESService
]
instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for smart product development",
    DTDFVocab:enables SMArDTService
]
instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior specification",
    DTDFVocab:enables CppBehaviorService
]
instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior specification",
    DTDFVocab:enables JavaBehaviorService
]
instance RequirementsData : DTDFVocab:Data [
    base:desc "Data derived from requirements phase",
    DTDFVocab:fromData RequirementsDataTransmitted,
    DTDFVocab:inputTo SysMLEnabler
]
instance FunctionalData : DTDFVocab:Data [
    base:desc "Data derived from functional architecture phase",
    DTDFVocab:fromData FunctionalDataTransmitted,
    DTDFVocab:inputTo SysMLEnabler
]
instance LogicalData : DTDFVocab:Data [
    base:desc "Data derived from logical architecture phase",
    DTDFVocab:fromData LogicalDataTransmitted,
    DTDFVocab:inputTo SysMLEnabler
]
instance ProductTechnicalData : DTDFVocab:Data [
    base:desc "Data derived from product/technical layer phase",
    DTDFVocab:fromData ProductTechnicalDataTransmitted,
    DTDFVocab:inputTo SysMLEnabler
]
instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "Structural representation using SysML Internal Block Diagrams",
    DTDFVocab:inputTo SysMLEnabler
]
instance ACMEModel : DTDFVocab:Model [
    base:desc "Architecture Description using ACME language",
    DTDFVocab:inputTo ACMEADLEnabler
]
instance AADLModel : DTDFVocab:Model [
    base:desc "Architecture Description using AADL language",
    DTDFVocab:inputTo AADLADLEnabler
]
instance MontiArcADLModel : DTDFVocab:Model [
    base:desc "Architecture Description using MontiArc ADL",
    DTDFVocab:inputTo MontiArcADLEnabler
]
instance SysMLStateMachinesModel : DTDFVocab:Model [
    base:desc "Behavioral model using SysML v1.7 state machines",
    DTDFVocab:inputTo SysMLStateMachinesEnabler
]
instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "Behavioral model using MontiArc Automaton",
    DTDFVocab:inputTo MontiArcAutomatonEnabler
]
instance SimulinkModel : DTDFVocab:Model [
    base:desc "Analytical model using MathWorks Simulink",
    DTDFVocab:inputTo SimulinkEnabler
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Industry standards and tools including SysML [17], ACME [23], AADL [24], MontiArc [25], [26], and MathWorks Simulink [28] are utilized for modeling system structure, behavior, and integration across multiple abstraction levels (requirements, functional architecture, logical architecture, product/technical layer) within Model-Based Systems Engineering (MBSE) frameworks."
]