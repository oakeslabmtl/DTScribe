// Sensors (C3)
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor position encoder on the drive shaft measuring angular position"
    DTDFVocab:producedData MotorPositionEncoderData
]

instance GearwheelPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Gearwheel position encoder measuring angular position at the gearstage"
    DTDFVocab:producedData GearwheelPositionEncoderData
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor armature current"
    DTDFVocab:producedData MotorCurrentSensorData
]

instance JointPositionMeasurement : DTDFVocab:SensingComponent [
    base:desc "Joint position measurement derived from encoders and streamed via MQTT"
    DTDFVocab:producedData JointPositionData
]

instance JointSpeedMeasurement : DTDFVocab:SensingComponent [
    base:desc "Joint speed measurement derived from position changes and streamed via MQTT"
    DTDFVocab:producedData JointSpeedData
]

instance JointAccelerationMeasurement : DTDFVocab:SensingComponent [
    base:desc "Joint acceleration measurement derived from speed changes and streamed via MQTT"
    DTDFVocab:producedData JointAccelerationData
]

// Data transmitted (C4)
instance MotorPositionEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearwheelPositionEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearwheelPositionEncoder
]

instance MotorCurrentSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance JointPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointPositionMeasurement
]

instance JointSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointSpeedMeasurement
]

instance JointAccelerationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointAccelerationMeasurement
]

// Data (C10)
instance DataMotorPositionEncoder : DTDFVocab:Data [
    base:desc "Processed motor position data trace"
    DTDFVocab:fromData MotorPositionEncoderData
    DTDFVocab:inputTo SimulinkSimulationEnabler, MQTTTransportEnabler
]

instance DataGearwheelPositionEncoder : DTDFVocab:Data [
    base:desc "Processed gearwheel position data trace"
    DTDFVocab:fromData GearwheelPositionEncoderData
    DTDFVocab:inputTo SimulinkSimulationEnabler, MQTTTransportEnabler
]

instance DataMotorCurrentSensor : DTDFVocab:Data [
    base:desc "Processed motor current data trace"
    DTDFVocab:fromData MotorCurrentSensorData
    DTDFVocab:inputTo SimulinkSimulationEnabler, MQTTTransportEnabler
]

instance DataJointPosition : DTDFVocab:Data [
    base:desc "Processed joint position data trace"
    DTDFVocab:fromData JointPositionData
    DTDFVocab:inputTo SimulinkSimulationEnabler, MQTTTransportEnabler
]

instance DataJointSpeed : DTDFVocab:Data [
    base:desc "Processed joint speed data trace"
    DTDFVocab:fromData JointSpeedData
    DTDFVocab:inputTo SimulinkSimulationEnabler, MQTTTransportEnabler
]

instance DataJointAcceleration : DTDFVocab:Data [
    base:desc "Processed joint acceleration data trace"
    DTDFVocab:fromData JointAccelerationData
    DTDFVocab:inputTo SimulinkSimulationEnabler, MQTTTransportEnabler
]

// Models (C10)
instance StructuralSysMLModel : DTDFVocab:Model [
    base:desc "Structural SysML model of the first axis derived from engineering design"
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink executable simulation model of the motor dynamics"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink executable simulation model of the gearbox dynamics"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SystemSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink executable simulation model of the overall first axis system dynamics"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Simulation friction model using Coulomb-Viscous formulation"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Simulation friction model using Stribeck formulation"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Simulation friction model using Dahl formulation"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "Simulation friction model using LuGre formulation"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance LiveSensorDataTraceModel : DTDFVocab:Model [
    base:desc "Model capturing live sensor data traces for realtime monitoring"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance DerivedDataTraceModel : DTDFVocab:Model [
    base:desc "Model capturing derived data traces from simulation outputs"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

// Enablers (C11)
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "Tool enabler for SysML modeling practices and producing structural models"
    DTDFVocab:enables StructuralSysMLModel
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Tool enabler for Simulink simulation execution and real-time updates"
    DTDFVocab:enables FrictionModelUpdateService, DataDrivenControlTuningService
]

instance MQTTTransportEnabler : DTDFVocab:Enabler [
    base:desc "Tool enabler for receiving MQTT data streams at robot control loop frequency"
    DTDFVocab:enables LiveRobotPerformanceMonitoringService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Tool enabler linking assets to semantic assets via Asset Administration Shells"
]

instance DigitalShadowReferenceModelEnabler : DTDFVocab:Enabler [
    base:desc "Tool enabler based on Digital Shadow Reference Model for structuring the twin"
]

instance MBSEPracticesEnabler : DTDFVocab:Enabler [
    base:desc "Tool enabler incorporating MBSE practices such as RFLP and SMArDT"
]

instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Tool enabler providing interactive dashboard for real-time visualization"
    DTDFVocab:enables RealTimeJointVisualizationService
]

instance DataDrivenControlEnabler : DTDFVocab:Enabler [
    base:desc "Tool enabler facilitating data-driven control tuning based on friction models"
    DTDFVocab:enables DataDrivenControlTuningService
]

// Services (C6)
instance RealTimeJointVisualizationService : DTDFVocab:Service [
    base:desc "Service providing real-time visualization of joint motion and friction states in the dashboard"
    DTDFVocab:provides DiscrepanciesVisualizationInsight
]

instance FrictionModelUpdateService : DTDFVocab:Service [
    base:desc "Service continuously identifying and updating white-box and black-box friction models"
    DTDFVocab:provides FrictionModelParametersInsight, AbnormalFrictionAlertInsight
]

instance LiveRobotPerformanceMonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring robot performance and detecting abnormal friction behavior"
    DTDFVocab:provides AbnormalFrictionAlertInsight
]

instance DataDrivenControlTuningService : DTDFVocab:Service [
    base:desc "Service enabling data-driven tuning of control based on updated friction models"
    DTDFVocab:provides DataDrivenControlTuningAction
]

// Insights & Actions (C17)
instance FrictionModelParametersInsight : DTDFVocab:Insight [
    base:desc "Derived friction model parameters for controller tuning"
]

instance AbnormalFrictionAlertInsight : DTDFVocab:Insight [
    base:desc "Alert for abnormal friction behavior indicating maintenance needs"
]

instance DiscrepanciesVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of discrepancies between simulated and measured signals to guide operator decisions"
]

instance DataDrivenControlTuningAction : DTDFVocab:Action [
    base:desc "Action to update control gains using updated friction model parameters"
    DTDFVocab:IsAutomatic false
]

// Components (C17)
instance MotorSimulationComponent : DTDFVocab:Component [
    base:desc "Component encapsulating motor simulation logic"
]

instance GearboxSimulationComponent : DTDFVocab:Component [
    base:desc "Component encapsulating gearbox simulation logic"
]

instance SystemSimulationComponent : DTDFVocab:Component [
    base:desc "Component encapsulating overall axis system simulation logic"
]

instance DataTraceComponent : DTDFVocab:Component [
    base:desc "Component responsible for collecting and storing data traces"
]

// Environment (C17)
instance FirstAxisDigitalShadowEnvironment : DTDFVocab:Environment [
    base:contains MotorSimulationComponent, GearboxSimulationComponent, SystemSimulationComponent, DataTraceComponent
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time, continuous synchronization with the physical robot’s sensor sampling (sub‑second or faster), enabling live monitoring and online model identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow architecture consists of a data ingestion layer (MQTT), a processing component that consumes sensor traces, runs simulation models, and outputs processed traces, and a visualization dashboard; all components conform to the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational phase (as‑built/operating) where the digital shadow monitors the robot during machining tasks."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured through traceability: each data trace can be linked back to its originating sensor or simulation component. Validation occurs by comparing simulated outputs against measured data traces (e.g., deviation of ˆrM versus rM). The combination of white‑box analytical friction models and black‑box data‑driven models allows for continuous re‑calibration to maintain accuracy over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT broker facilitates communication between the robot’s sensors and the digital shadow; Asset Administration Shells expose data interfaces; data traces include metadata such as timestamp and source."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Conformance to Asset Administration Shell (AAS) standards, SysML modeling language, MBSE practices, and reference modeling approach (DSRM)."
]