namespace DTDFVocab = "http://example.com/DTDFVocab"

instance RFLP : DTDFVocab:Enabler [
    base:desc "MBSE methodology for hierarchical system modeling across requirements, functional, logical, and technical layers"
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "MBSE methodology for hierarchical system modeling across requirements, functional, logical, and technical layers"
]

instance SPES : DTDFVocab:Enabler [
    base:desc "MBSE methodology for hierarchical system modeling across requirements, functional, logical, and technical layers"
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "MBSE methodology for hierarchical system modeling across requirements, functional, logical, and technical layers"
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Language (ADL) for component-based architecture modeling"
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Language (ADL) for component-based architecture modeling"
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Language (ADL) for component-based architecture modeling"
]

instance SysMLIBDs : DTDFVocab:Enabler [
    base:desc "SysML IBDs for component-based architecture modeling"
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral modeling"
]

instance SysMLStateMachines : DTDFVocab:Enabler [
    base:desc "SysML state machines for behavioral modeling"
]

instance MathWorksSimulink : DTDFVocab:Enabler [
    base:desc "Simulation tool for detailed behavior"
]

instance CPlusPlus : DTDFVocab:Enabler [
    base:desc "General-purpose programming language for detailed behavior implementation"
]

instance Java : DTDFVocab:Enabler [
    base:desc "General-purpose programming language for detailed behavior implementation"
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML for structural modeling including component & connector perspectives via IBDs",
    DTDFVocab:inputTo SysMLIBDs
]

instance ACMEArchitecturalModel : DTDFVocab:Model [
    base:desc "ACME for architectural descriptions",
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLArchitecturalModel : DTDFVocab:Model [
    base:desc "AADL for architectural descriptions",
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcArchitecturalModel : DTDFVocab:Model [
    base:desc "MontiArc for architectural descriptions",
    DTDFVocab:inputTo MontiArcEnabler
]

instance MontiArcAutomatonBehavioralModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling",
    DTDFVocab:inputTo MontiArcAutomaton, MathWorksSimulink, CPlusPlus, Java
]

instance SysMLStateMachineBehavioralModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines for behavioral modeling",
    DTDFVocab:inputTo SysMLStateMachines, MathWorksSimulink, CPlusPlus, Java
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system employs standardized modeling languages such as SysML [17], ACME [23], AADL [24], and MontiArc [25], [26] for architecture description, alongside methodologies including RFLP, OOSEM, SPES, and SMArDT to manage system complexity across abstraction levels (requirements, functional, logical, product/technical layers) during development."
]