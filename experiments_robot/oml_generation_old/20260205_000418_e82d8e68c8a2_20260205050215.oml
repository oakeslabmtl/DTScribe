// C3: Physical sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution rotary encoder mounted on the motor shaft"
    DTDFVocab:producedData MotorEncoderData
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution rotary encoder mounted on the gearbox output"
    DTDFVocab:producedData GearboxEncoderData
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor electrical input current"
    DTDFVocab:producedData MotorCurrentData
]

// C4: Data transmitted
instance MotorEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Models/Data (derived physical data)
instance MotorTorqueData : DTDFVocab:Data [
    base:desc "Estimated motor torque derived from motor current and motor encoder angle"
    DTDFVocab:fromData MotorCurrentData, MotorEncoderData
    DTDFVocab:inputTo SimulinkModelEnabler
]

instance MotorAngularVelocityData : DTDFVocab:Data [
    base:desc "Motor angular velocity derived from the derivative of motor encoder angle"
    DTDFVocab:fromData MotorEncoderData
    DTDFVocab:inputTo SimulinkModelEnabler
]

instance MotorAccelerationData : DTDFVocab:Data [
    base:desc "Motor angular acceleration derived from the second derivative of motor encoder angle"
    DTDFVocab:fromData MotorEncoderData
    DTDFVocab:inputTo SimulinkModelEnabler
]

// C11: Enablers
instance MQTTReceiverEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that receives MQTT telemetry streams and forwards them to the simulation"
    DTDFVocab:enables DashboardVisualizationService
]

instance SimulinkModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that loads executable Simulink blocks for motor, gearwheel, and gearbox"
    DTDFVocab:enables FrictionIdentificationService
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service that performs continuous multi‑physics‑aware identification of friction models (white‑box and black‑box)"
    DTDFVocab:provides FrictionParametersInsight, WearForecastInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Realtime dashboard that visualises friction estimation and model comparison"
    DTDFVocab:provides FrictionParametersInsight
]

// C17: Insights/Actions
instance FrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Updated friction parameters for the robot controller"
]

instance WearForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasts wear for maintenance planning"
]

instance AdjustMotionControlAction : DTDFVocab:Action [
    base:desc "Adjusts motion control algorithms based on updated friction parameters"
    DTDFVocab:IsAutomatic false
]

instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Schedules maintenance tasks on the robot base axis"
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time streaming of sensor data; the DT processes data at the same granularity as the robot controller updates, with no fixed period specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT consists of: an engineering model (SysML), processing component that consumes sensor traces, simulation and data‑calculation models, and outputs data traces that feed a real‑time dashboard. All components are orchestrated through the AAS and MQTT bus."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is engineered during operation; it captures the as‑operated behaviour of the physical robot. Design and manufacturing phases are not directly represented, although the structural model is derived from the robot’s engineering data."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "White‑box models incorporate parameters dependent on load, temperature, and time; black‑box models are updated online using live data. Model validity is assessed by comparing simulated traces against measured sensor data, with a focus on low‑frequency drift and high‑frequency noise. Traceability of data generation ensures verifiable updates."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data is transmitted over MQTT (publish/subscribe) to the DT. The DT may expose data via Asset Administration Shells (AAS) for interoperability."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of ISO/IEC 30141 AAS, SysML (ISO/IEC 15288 for MBSE), and MBSE methods such as RFLP, SMArDT. The digital shadow conforms to the AAS reference model and MBSE guidelines."
]