// C3: Physical Sensing Components
instance RobotStateSensor : DTDFVocab:SensingComponent [
    base:desc "Automated collection of state data from MABI MAX 100 robot including sensor inputs and operational logs via contextual data traces"
    DTDFVocab:producedData RobotStateDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors measuring input current for MABI MAX 100 robot motors via MQTT protocol"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors measuring torque output for MABI MAX 100 robot gearboxes via MQTT protocol"
    DTDFVocab:producedData TorqueDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors measuring angular velocity for MABI MAX 100 robot axes via MQTT protocol"
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance RobotStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotStateSensor
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

// C10: Models/Data
instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "Formalizes contextual data collection, aggregation, and abstraction for MABI MAX 100 robot as depicted in Fig. 1"
    DTDFVocab:inputTo SysMLModelingEnabler, MontiArcIntegrationEnabler
]

instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based functional architecture model of MABI MAX 100 robot using RFLP methodology"
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance SysMLLogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based logical architecture model of MABI MAX 100 robot using OOSEM methodology"
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance SysMLProductTechnicalModel : DTDFVocab:Model [
    base:desc "SysML-based product/technical architecture model of MABI MAX 100 robot using SPES methodology"
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance MontiArcComponentConnectorModel : DTDFVocab:Model [
    base:desc "MontiArc-based component-connector architecture model defining robot axes, gearboxes, and motor interfaces"
    DTDFVocab:inputTo MontiArcIntegrationEnabler
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for detailed dynamic simulation of motor-gearbox interactions"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance RobotStateData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted state data from MABI MAX 100 robot for monitoring and diagnostics"
    DTDFVocab:fromData RobotStateDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler, VisualizationEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Aggregated motor current data for analysis of operational efficiency"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Aggregated torque data for mechanical system analysis"
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Aggregated angular velocity data for kinematic analysis"
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7+ for multi-layered system architecture modeling including requirements, functional/logical layers, and product models with state machines for behavioral description"
    DTDFVocab:enables DataAcquisitionService, DataAbstractionService, VisualizationService
]

instance MontiArcIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for component-connector-based architecture modeling and integration"
    DTDFVocab:enables DataAbstractionService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed dynamic simulation of motor-gearbox interactions with C++/Java integration"
    DTDFVocab:enables DataAbstractionService
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "UML-based class diagrams for defining data trace aggregation and abstraction layers"
    DTDFVocab:enables DataAbstractionService
]

instance MQTTProtocolEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol for lightweight publish-subscribe messaging of sensor data from physical robot to digital shadow"
    DTDFVocab:enables DataAcquisitionService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shells for standardized data exchange and interoperability within manufacturing ecosystems"
    DTDFVocab:enables DataAcquisitionService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Presentation layer for aggregated data visualization for monitoring and diagnostic purposes"
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Automated one-way ingestion of state data from physical MABI MAX 100 robot via MQTT protocol"
    DTDFVocab:provides RobotStateInsight
]

instance DataAbstractionService : DTDFVocab:Service [
    base:desc "Aggregation and abstraction of raw sensor data into structured digital representations"
    DTDFVocab:provides SystemBehaviorInsight, OperationalEfficiencyInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Presentation of aggregated data for monitoring and diagnostic purposes without active intervention"
    DTDFVocab:provides SystemMonitoringInsight
]

// C17: Insights/Actions
instance RobotStateInsight : DTDFVocab:Insight [
    base:desc "Real-time operational state of MABI MAX 100 robot including sensor inputs and contextual traces"
]

instance SystemBehaviorInsight : DTDFVocab:Insight [
    base:desc "Structured digital representation of robot system behavior derived from aggregated sensor data"
]

instance OperationalEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Analysis of motor current and torque data to assess operational efficiency"
]

instance SystemMonitoringInsight : DTDFVocab:Insight [
    base:desc "Visual monitoring of robot system behavior and diagnostic information"
]

// C1: Acting Components (not specified in characteristics)
instance MABIMax100Robot : DTDFVocab:Component [
    base:desc "Physical MABI MAX 100 industrial robot with motors, gearboxes, and mechanical subsystems"
]

instance SiemensSINUMERIK840Dsl : DTDFVocab:Component [
    base:desc "Real-time motion control system for MABI MAX 100 robot axes interfacing with PMSM drives and gear transmission systems"
]

instance PMSMDriveSystem : DTDFVocab:Component [
    base:desc "Permanent Magnet Synchronous Motor drive system for MABI MAX 100 robot"
]

instance GearTransmissionSystem : DTDFVocab:Component [
    base:desc "Gear transmission system for MABI MAX 100 robot mechanical power transmission"
]

// C2: Acting Components (from tooling)
instance SysMLStateMachineBehavior : DTDFVocab:ActingComponent [
    base:desc "SysML v1.7 state machines for behavioral modeling of MABI MAX 100 robot components"
]

instance MontiArcAutomatonBehavior : DTDFVocab:ActingComponent [
    base:desc "MontiArc Automaton for behavioral modeling of component interactions"
]

instance SimulinkControlLogic : DTDFVocab:ActingComponent [
    base:desc "Simulink-based control logic implementation for robot motion control"
]

// C10: Additional Models
instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language model for system component definition"
    DTDFVocab:inputTo MontiArcIntegrationEnabler
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL Architecture Description Language model for system architecture definition"
    DTDFVocab:inputTo MontiArcIntegrationEnabler
]

instance HistoricalDataModel : DTDFVocab:Data [
    base:desc "Database backend storing historical data traces for long-term analysis"
    DTDFVocab:inputTo DataAggregationEnabler
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system’s orchestration and coordination are underpinned by **Model-Based Systems Engineering (MBSE)** frameworks, which employ **architecture description languages (ADLs)** (e.g., ACME, AADL, MontiArc, SysML IBDs) to define **component & connector perspectives**, including interfaces, interconnections, and composition. These ADLs enable **system-wide coordination** by modeling the structural and behavioral relationships between components. For dynamic behavior, MBSE integrates with tools like **MathWorks Simulink**, other simulation tools, or general-purpose languages (C++, Java) to implement **resource management** and **real-time coordination mechanisms**. The document does not specify exact architecture patterns (e.g., microservices, service-oriented) but implies a **modular, tool-agnostic orchestration** to handle heterogeneity across stakeholders and modeling notations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system validates model fidelity by comparing **simulated data against measured data** from the physical system, ensuring alignment between digital and physical states. Validation is supported by **Simulink-based simulations** and **friction models** to refine behavioral accuracy. The system adheres to **Digital Shadow principles**, where data traces are passively collected and aggregated for contextual abstraction, but no explicit **uncertainty quantification, error correction mechanisms, or quality assurance processes** are detailed in the provided documents. No specific **validation/verification methods** (e.g., statistical metrics, anomaly detection) or **adaptive control tuning** (e.g., PID parameters) are mentioned."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Shadow system leverages **MQTT** for streaming sensor data from the physical system (e.g., a robot controlled by a Siemens SINUMERIK 840D sl) to the digital representation. The communication infrastructure is not explicitly detailed beyond this protocol, and no information is provided regarding **network topology, bandwidth/latency requirements, redundancy mechanisms, or security protocols** for the connection. The system does not describe a control network or bidirectional communication architecture (e.g., OPC UA or proprietary industrial protocols)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **hosting and deployment infrastructure** for the Digital Shadow system is not explicitly detailed beyond the implementation of an **Asset Administration Shell (AAS)** and a **dashboard** for visualization. No information is provided regarding **hosting platforms** (cloud, edge, or on-premise), **computational/storage requirements**, **scalability mechanisms**, or **deployment models** (e.g., containerization via Docker/Kubernetes). The document focuses on the **digital shadow’s passive data collection role** rather than infrastructure specifics, leaving deployment details unspecified."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with external systems through **Model-Based Systems Engineering (MBSE)** frameworks, which facilitate **heterogeneous data aggregation and abstraction** via **architecture description languages (ADLs)**. While the document does not explicitly enumerate data exchange protocols or interoperability standards, it implies support for **contextual data traces** (e.g., sensor streams) and **active processing components** to interpret incoming data. The **Digital Shadow Reference Model** (Fig. 1) suggests a foundational role for **data aggregation and abstraction**, though no specific protocols (e.g., MQTT, OPC UA) or integration patterns (e.g., API gateways, enterprise service buses) are detailed. The system’s active components (e.g., those enabling real-time identification) may rely on **simulation tools (Simulink)** or **general-purpose code (C++, Java)** for cross-system interoperability."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE)** standards, including **SysML** (Systems Modeling Language) for system modeling and **architecture description languages (ADLs)** such as **ACME**, **AADL**, and **MontiArc**, which are standardized or widely adopted in systems engineering. **SysML v1.7** introduces state machines for behavioral modeling, aligning with broader **OMG (Object Management Group)** standards. The system may also leverage **interoperability standards** implied by the integration of heterogeneous tools (e.g., **MathWorks Simulink**, simulation tools, and general-purpose languages like **C++/Java**), though specific interoperability protocols (e.g., **OPC UA**, **FIXML**) are not mentioned. **Certification requirements** or **compliance frameworks** are not explicitly detailed, but adherence to **MBSE best practices** (e.g., [18]–[22]) suggests alignment with industry standards for system modeling and engineering."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system incorporates **safety cells** to restrict operational ranges, specifically limiting the **MAX-100-2-25-P robotic arm** to a **safety cell range of [−90°, 90°]** as per its functional specifications ([44]). Data from the physical asset is **streamed via MQTT** ([52]), a lightweight publish-subscribe protocol, though the documents do not specify encryption mechanisms (e.g., TLS/SSL) or granular cybersecurity controls like OAuth 2.0 or IEC 62443 compliance. The system leverages **Functional Mockup Interface (FMI)** ([51]) for simulation model exchange, which inherently supports interoperability but lacks explicit mention of security hardening for communication channels. No evidence of **access control mechanisms**, **authentication systems**, or **risk assessment methodologies** (e.g., ISO 27001, NIST SP 800-53) is provided in the referenced documents."
]