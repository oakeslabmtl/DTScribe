// C3: Physical sensing components
instance Axis1Encoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution position encoder mounted on Axis 1 of the MABI MAX 100 robot."
    DTDFVocab:producedData Axis1EncoderData
]
instance Axis2Encoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution position encoder mounted on Axis 2 of the MABI MAX 100 robot."
    DTDFVocab:producedData Axis2EncoderData
]
instance Axis3Encoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution position encoder mounted on Axis 3 of the MABI MAX 100 robot."
    DTDFVocab:producedData Axis3EncoderData
]
instance Axis4Encoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution position encoder mounted on Axis 4 of the MABI MAX 100 robot."
    DTDFVocab:producedData Axis4EncoderData
]
instance Axis5Encoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution position encoder mounted on Axis 5 of the MABI MAX 100 robot."
    DTDFVocab:producedData Axis5EncoderData
]
instance Axis6Encoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution position encoder mounted on Axis 6 of the MABI MAX 100 robot."
    DTDFVocab:producedData Axis6EncoderData
]

// C4: Physical-to-virtual interaction
instance Axis1EncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Axis1Encoder
]
instance Axis2EncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Axis2Encoder
]
instance Axis3EncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Axis3Encoder
]
instance Axis4EncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Axis4Encoder
]
instance Axis5EncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Axis5Encoder
]
instance Axis6EncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Axis6Encoder
]

// C10: Models/Data
instance Axis1EncoderMeasurementData : DTDFVocab:Data [
    base:desc "Encoder measurement data for Axis 1, obtained after filtering and validation."
    DTDFVocab:fromData Axis1EncoderData
    DTDFVocab:inputTo MQTTEdgeNode, AASRestAPI
]
instance Axis2EncoderMeasurementData : DTDFVocab:Data [
    base:desc "Encoder measurement data for Axis 2, obtained after filtering and validation."
    DTDFVocab:fromData Axis2EncoderData
    DTDFVocab:inputTo MQTTEdgeNode, AASRestAPI
]
instance Axis3EncoderMeasurementData : DTDFVocab:Data [
    base:desc "Encoder measurement data for Axis 3, obtained after filtering and validation."
    DTDFVocab:fromData Axis3EncoderData
    DTDFVocab:inputTo MQTTEdgeNode, AASRestAPI
]
instance Axis4EncoderMeasurementData : DTDFVocab:Data [
    base:desc "Encoder measurement data for Axis 4, obtained after filtering and validation."
    DTDFVocab:fromData Axis4EncoderData
    DTDFVocab:inputTo MQTTEdgeNode, AASRestAPI
]
instance Axis5EncoderMeasurementData : DTDFVocab:Data [
    base:desc "Encoder measurement data for Axis 5, obtained after filtering and validation."
    DTDFVocab:fromData Axis5EncoderData
    DTDFVocab:inputTo MQTTEdgeNode, AASRestAPI
]
instance Axis6EncoderMeasurementData : DTDFVocab:Data [
    base:desc "Encoder measurement data for Axis 6, obtained after filtering and validation."
    DTDFVocab:fromData Axis6EncoderData
    DTDFVocab:inputTo MQTTEdgeNode, AASRestAPI
]

// C11: Enablers
instance MQTTEdgeNode : DTDFVocab:Enabler [
    base:desc "Edge computing node receiving MQTT data, performing noise filtering and outlier rejection."
    DTDFVocab:enables DataProcessingService
]
instance AASRestAPI : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell REST API ingesting validated data into the Digital Twin state model."
    DTDFVocab:enables FrictionIdentificationService, LiveVisualizationService
]

// C6: Services
instance DataProcessingService : DTDFVocab:Service [
    base:desc "Service that cleans and aggregates raw encoder data before forwarding to higher-level services."
    DTDFVocab:provides DataProcessedInsight
]
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service that analyzes real-time encoder data to detect and quantify frictional forces across axial joints."
    DTDFVocab:provides FrictionMetricInsight
]
instance LiveVisualizationService : DTDFVocab:Service [
    base:desc "Service that supplies a live visualization dashboard enabling operators to view motion profiles, encoder velocity traces, and friction metrics."
    DTDFVocab:provides MotionProfileInsight, EncoderVelocityTraceInsight, FrictionMetricInsight
]

// C17: Insights
instance DataProcessedInsight : DTDFVocab:Insight [
    base:desc "Indicates that encoder data has been cleaned and aggregated by MQTTEdgeNode."
]
instance FrictionMetricInsight : DTDFVocab:Insight [
    base:desc "Friction forces measured across axial joints."
]
instance MotionProfileInsight : DTDFVocab:Insight [
    base:desc "Motion profiles of robot joints over time."
]
instance EncoderVelocityTraceInsight : DTDFVocab:Insight [
    base:desc "Encoder velocity traces for each joint."
]

// C5: Component
instance SixAxisIndustrialRobot : DTDFVocab:Component [
    base:desc "Six-axis industrial robot MABI MAX 100 used in advanced manufacturing tasks such as machining and milling."
]

// C5: Environment
instance HighPrecisionProductionCell : DTDFVocab:Environment [
    base:contains SixAxisIndustrialRobot
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data‑driven representation, with sensor data from the physical robot axis streamed to the twin via MQTT. The twin continuously processes incoming traces and updates its models (e.g., white‑ and black‑box friction models) during operation, effectively synchronizing with the physical system at the rate the data is produced. No explicit latency or frequency values are specified, but the architecture is designed for continuous, real‑time updates."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through Asset Administration Shells (AAS) to represent the physical and digital assets, and the twin streams data via MQTT. The AAS exposes the asset model and the twin subscribes/publishes to MQTT topics that carry trace data and state updates, enabling interoperability with enterprise systems that support AAS and MQTT."
]