// C3: Physical sensing components
instance JointCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real-time input current measurements from the MABI MAX 100 robot's joint actuators for digital shadowing purposes."
    DTDFVocab:producedData JointCurrentDataTransmitted
]

instance JointAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Measures output angle of the MABI MAX 100 robot's joints with high precision for motion analysis."
    DTDFVocab:producedData JointAngleDataTransmitted
]

instance JointTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Captures torque values from the MABI MAX 100 robot's joints to enable friction identification analysis."
    DTDFVocab:producedData JointTorqueDataTransmitted
]

instance JointAngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Records angular velocity measurements from the MABI MAX 100 robot's joints for dynamic system monitoring."
    DTDFVocab:producedData JointAngularVelocityDataTransmitted
]

// C4: Physical-to-virtual interaction
instance JointCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Automated one-way transmission of input current measurements via MQTT protocol from physical robot to digital shadow."
    DTDFVocab:producedFrom JointCurrentSensor
]

instance JointAngleDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Automated one-way transmission of joint angle measurements via MQTT protocol with event-triggered synchronization."
    DTDFVocab:producedFrom JointAngleSensor
]

instance JointTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Automated one-way transmission of torque measurements via MQTT protocol for friction analysis purposes."
    DTDFVocab:producedFrom JointTorqueSensor
]

instance JointAngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Automated one-way transmission of angular velocity measurements via MQTT protocol with periodic sampling."
    DTDFVocab:producedFrom JointAngularVelocitySensor
]

// C10: Models/Data
instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based model representing the MABI MAX 100 robot's functional architecture including components, interfaces, and interconnections."
    DTDFVocab:inputTo SysMLEnabler, SimulinkEnabler
]

instance SysMLLogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) model defining the MABI MAX 100 robot's logical architecture with component-connector perspectives."
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model capturing the behavioral dynamics of the MABI MAX 100 robot's joint operations."
    DTDFVocab:inputTo SysMLEnabler
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for detailed behavioral simulation of the MABI MAX 100 robot's dynamic system characteristics."
    DTDFVocab:inputTo SimulinkEnabler
]

instance JointFrictionAnalysisData : DTDFVocab:Data [
    base:desc "Structured aggregated data traces derived from sensor measurements specifically for joint friction identification analysis."
    DTDFVocab:fromData JointCurrentDataTransmitted, JointTorqueDataTransmitted, JointAngularVelocityDataTransmitted
    DTDFVocab:inputTo SysMLEnabler, SimulinkEnabler
]

instance OperationalLogData : DTDFVocab:Data [
    base:desc "Collected operational logs from the MABI MAX 100 robot including contextual data traces for passive monitoring."
    DTDFVocab:fromData JointAngleDataTransmitted, JointCurrentDataTransmitted
    DTDFVocab:inputTo SysMLEnabler
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling environment enabling structural and behavioral modeling of the MABI MAX 100 robot across multiple abstraction layers."
    DTDFVocab:enables DataAggregationService, VisualizationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for detailed behavioral simulation complementing SysML abstractions with executable models."
    DTDFVocab:enables DataAggregationService, FrictionAnalysisService
]

instance MQTTCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol implementation enabling lightweight, publish-subscribe based one-way data flow from physical robot to digital shadow."
    DTDFVocab:enables DataAggregationService
]

// C6: Services
instance DataAggregationService : DTDFVocab:Service [
    base:desc "Automated service for collecting, structuring, and aggregating contextual data traces from multiple sensor sources."
    DTDFVocab:provides JointFrictionInsight, OperationalContextInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service providing UML/SysML-based visualization of aggregated data traces for stakeholder interpretation."
    DTDFVocab:provides OperationalContextInsight
]

instance FrictionAnalysisService : DTDFVocab:Service [
    base:desc "Specialized service for identifying and analyzing joint friction patterns using aggregated sensor data."
    DTDFVocab:provides JointFrictionInsight
]

// C17: Insights/Actions
instance JointFrictionInsight : DTDFVocab:Insight [
    base:desc "Diagnostic insight identifying joint friction characteristics in the MABI MAX 100 robot based on aggregated sensor measurements."
]

instance OperationalContextInsight : DTDFVocab:Insight [
    base:desc "Contextual insight about the robot's operational state derived from aggregated data traces for manufacturing engineers."
]

// C1: System under study
instance MabiMax100Robot : DTDFVocab:Component [
    base:desc "High-precision manufacturing-oriented industrial robot with jointed mechanical components requiring real-time state monitoring."
]

instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:contains MabiMax100Robot
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin (DT) constellation** is implicitly described through the **Model-Based Systems Engineering (MBSE) framework**, which employs **architecture description languages (ADLs)** like ACME, AADL, or MontiArc to define **component integration, orchestration, and coordination**. These ADLs enable **system-wide coordination** via **component connectors** and **composition rules**, ensuring interoperability between heterogeneous models (e.g., SysML for architecture, Simulink for behavior, or C++/Java for implementation). The document does not specify exact **orchestration patterns** (e.g., microservices, event-driven) or **resource management** mechanisms, but it highlights the need to integrate **multiple modeling notations and tools** (e.g., simulation tools, general-purpose languages) under a unified MBSE approach. The **Digital Shadow Reference Model** (Fig. 1) further emphasizes **data aggregation and abstraction** as a foundational layer for DT coordination."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The document does not explicitly address **horizontal integration** with external systems, data exchange protocols, or interoperability standards. However, it implies **dependencies on external systems** through the use of **MBSE methodologies** (e.g., RFLP, OOSEM, SPES) and **heterogeneous toolchains** (e.g., SysML, Simulink, C++/Java), which require **interoperability** between modeling languages and simulation tools. The **Digital Shadow Reference Model** suggests **one-way data flows** (e.g., from physical objects to digital shadows), but does not detail **bidirectional integration patterns** (e.g., OPC UA, MQTT, REST APIs) or **enterprise system dependencies** (e.g., ERP, MES). Thus, the document lacks concrete specifications for **external system integration**."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adheres to **Model-Based Systems Engineering (MBSE) standards**, specifically leveraging **SysML** for modeling and **Architecture Description Languages (ADLs)** such as **ACME**, **AADL**, and **MontiArc** for component-based system design. Additionally, the system implements **Asset Administration Shells (AAS)** as a key interoperability standard, enabling standardized data exchange and integration. Sensor data is streamed via **MQTT**, a lightweight publish-subscribe protocol, ensuring real-time data acquisition and communication. While no explicit certification frameworks are mentioned, compliance with **industry-specific MBSE standards** and **AAS specifications** is implied for interoperability and governance."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The provided documents reference **safety-critical considerations** only in the context of the **MABI robotic arm (Max 100-2-25-P)** [44], which operates within a **physical safety cell** to ensure operator protection during motion control tasks. No explicit cybersecurity protocols (e.g., OAuth 2.0, TLS/SSL, IEC 62443), access control mechanisms, or threat mitigation strategies are detailed in the documents. The **Asset Administration Shell (AAS)** [46, 47, 50] is mentioned as a framework for asset lifecycle management but lacks specific security governance or privacy compliance (e.g., GDPR) in the provided excerpts. The **RAMI4.0 reference architecture** [48, 49] is cited for industrial interoperability but does not elaborate on data ownership policies or consent management in the given context."
]