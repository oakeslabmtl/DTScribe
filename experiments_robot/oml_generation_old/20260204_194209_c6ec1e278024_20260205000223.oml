// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Acquires time‑series sensor data for input current from the physical asset, transmitted via MQTT."
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Acquires time‑series sensor data for torque from the physical asset, transmitted via MQTT."
    DTDFVocab:producedData TorqueDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Acquires time‑series sensor data for angular velocity from the physical asset, transmitted via MQTT."
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

// C4: Physical-to-virtual interaction
instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
    base:desc "MQTT message (topic per sensor) carrying input current readings, validated against a JSON schema."
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
    base:desc "MQTT message (topic per sensor) carrying torque readings, validated against a JSON schema."
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
    base:desc "MQTT message (topic per sensor) carrying angular velocity readings, validated against a JSON schema."
]

// C10: Data
instance InputCurrentData : DTDFVocab:Data [
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo DataProcessingEngine
    base:desc "Time‑series input current data trace ingested into the digital twin."
]

instance TorqueData : DTDFVocab:Data [
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo DataProcessingEngine
    base:desc "Time‑series torque data trace ingested into the digital twin."
]

instance AngularVelocityData : DTDFVocab:Data [
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo DataProcessingEngine
    base:desc "Time‑series angular velocity data trace ingested into the digital twin."
]

// C11: Enablers
instance DataProcessingEngine : DTDFVocab:Enabler [
    base:desc "Processing component that consumes input data traces and executes data‑calculation or simulation models (e.g., Simulink, MontiArc) to generate higher‑level abstractions, retaining provenance via the ‘originates‑from’ association."
    DTDFVocab:enables DecisionSupportService
]

instance ModelingToolchainEnabler : DTDFVocab:Enabler [
    base:desc "MBSE toolchain (SysML, ACME, AADL, MontiArc) used to create structural and behavioral models and to generate C++ or Java code."
    // No direct service enablement required for this enabler in the current flow
]

// C10: Models/Data
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram representing geometric and structural aspects of the asset."
    DTDFVocab:inputTo DataProcessingEngine
]

instance SimulinkBehavioralModel : DTDFVocab:Model [
    base:desc "Executable simulation model in MathWorks Simulink describing dynamic behavior of the system."
    DTDFVocab:inputTo DataProcessingEngine
]

instance MontiArcSimulationModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model capturing component‑connector behavior for simulation."
    DTDFVocab:inputTo DataProcessingEngine
]

// C6: Services
instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Provides decision‑making insights based on processed model outputs, supporting stakeholders as described in Document 2."
    DTDFVocab:provides ComputedResultInsight, AutomatedDecisionAction
]

// C17: Insights/Actions
instance ComputedResultInsight : DTDFVocab:Insight [
    base:desc "Higher‑level abstraction output trace with retained provenance, enabling fine‑grained traceability for decision‑making."
]

instance AutomatedDecisionAction : DTDFVocab:Action [
    base:desc "Automatically initiates control actions based on computed results."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is defined as a passive entity that neither operates autonomously nor pushes data back to the physical system; therefore no control flow from the virtual representation to the physical object is described."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated using a Model‑Based Systems‑Engineering (MBSE) approach that leverages architecture description languages (ADLs) such as ACME, AADL, MontiArc and SysML internal block diagrams to define components, their interfaces, and connector topologies. Functional and logical architectures are captured in models (RFLP, OOSEM, SPES, SMArDT) and linked to processing components that implement data‑calculation or simulation models. Each processing component consumes input data traces and produces output traces, with traceability maintained through the ‘originates‑from’ association, enabling transitive provenance across components. The overall system conforms to a Digital Shadow Reference Model, instantiated through a concretization step that maps reference concepts to concrete classes and associations, thereby providing a structured constellation of components, models, and data‑flow pipelines."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin’s development follows the Model‑Based Systems‑Engineering (MBSE) lifecycle that is split into four abstraction levels: (1) requirements engineering, (2) functional architecture, (3) logical architecture, and (4) product/technical layer. At each level the twin is represented by appropriate models – e.g., SysML requirement diagrams, functional block diagrams, logical component‑connector models, and detailed product‑level designs – and transitions between levels are managed by mapping concepts forward (requirements → functions → logical components → physical realization) as described in Document 1."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by combining white‑box (physics‑based Simulink) models with data‑driven (black‑box) models, and by enforcing traceability of model transformations (e.g., from SysML to simulation models). Validation and verification activities focus on ensuring the correctness of these transformations and on maintaining the reliability of the Digital Twin; uncertainty sources are acknowledged, and verification methods are applied to guarantee that the integrated models faithfully represent the underlying physical processes."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The network layer relies on MQTT (TCP/IP) as the communication protocol for streaming sensor time‑series data. A Mosquitto broker is used to mediate publish‑subscribe interactions between the physical equipment (publishers) and the digital twin platform (subscribers). MQTT QoS levels (e.g., QoS 1) ensure at‑least‑once delivery, and broker persistence can be enabled to increase reliability. While the documents do not specify topology, bandwidth, or latency, MQTT provides a lightweight, low‑latency architecture suitable for high‑frequency sensor streams. Security aspects are not detailed beyond the typical use of TLS for MQTT, which is not explicitly mentioned in the source."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin relies on several established standards and modeling conventions. SysML, an OMG standard for systems engineering, is used for requirements and structural modeling. Architecture description languages such as ACME, AADL, and MontiArc provide standardised component‑connector specifications. The reference model approach introduces a formal conformance relation (as defined in [41]) that specifies which concrete class diagrams conform to the abstract domain model, thereby enforcing a standardized modeling contract across implementations."
]