instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted directly on the permanent magnet synchronous motor for the first axis of MABI MAX 100 robot"
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder positioned behind the gearbox for the first axis of MABI MAX 100 robot"
    DTDFVocab:producedData GearboxPositionDataTransmitted
]

instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor collecting input current data from the permanent magnet synchronous motor for performance monitoring"
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
    base:desc "Time series motor position angle data streamed via MQTT protocol"
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
    base:desc "Time series gearbox position angle data streamed via MQTT protocol"
]

instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
    base:desc "Time series motor input current data streamed via MQTT protocol"
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Time series position angle data from motor encoder"
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEnabler, MontiArcAutomatonEnabler, SysMLStateMachineEnabler, AnalyticsProcessingEnabler
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Time series position angle data from gearbox encoder"
    DTDFVocab:fromData GearboxPositionDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEnabler, MontiArcAutomatonEnabler, SysMLStateMachineEnabler, AnalyticsProcessingEnabler
]

instance InputCurrentData : DTDFVocab:Data [
    base:desc "Time series input current data from motor"
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEnabler, AnalyticsProcessingEnabler
]

instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor for the first axis of MABI MAX 100 robot"
]

instance GearTransmission : DTDFVocab:ActingComponent [
    base:desc "Gear transmission component for mechanical reduction in the first axis"
]

instance CycloidalGear : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear for mechanical reduction in the first axis"
]

instance SiemensSINUMERIK840DslController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl controller for processing commands and adjusting actuator movements through precise servo control loops"
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML-based structural model for requirements, functional, logical, and technical abstraction levels"
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME architecture description for component & connector perspectives"
    DTDFVocab:inputTo ACMEArchitectureEnabler
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL architecture description for component & connector perspectives"
    DTDFVocab:inputTo AADLArchitectureEnabler
]

instance MontiArcArchitectureModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description for component & connector perspectives"
    DTDFVocab:inputTo MontiArcArchitectureEnabler
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams for component & connector perspectives"
    DTDFVocab:inputTo SysMLIBDEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model for behavioral aspects"
    DTDFVocab:inputTo MontiArcAutomatonEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model for behavioral aspects"
    DTDFVocab:inputTo SysMLStateMachineEnabler
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink simulation model for detailed behavior"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance CPlusPlusImplementationModel : DTDFVocab:Model [
    base:desc "C++ code implementation for simulation and behavior"
    DTDFVocab:inputTo CPlusPlusImplementationEnabler
]

instance JavaImplementationModel : DTDFVocab:Model [
    base:desc "Java code implementation for simulation and behavior"
    DTDFVocab:inputTo JavaImplementationEnabler
]

instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based modeling for structural aspects across abstraction levels"
    DTDFVocab:enables FrictionModelingService
]

instance RFLPMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "RFLP methodology for Requirements, Functions, Logics, Physics across abstraction levels"
    DTDFVocab:enables FrictionModelingService
]

instance OOSEMMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for handling complexity across abstraction levels"
    DTDFVocab:enables FrictionModelingService
]

instance SPESMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for handling complexity across abstraction levels"
    DTDFVocab:enables FrictionModelingService
]

instance SMArDTMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for handling complexity across abstraction levels"
    DTDFVocab:enables FrictionModelingService
]

instance ACMEArchitectureEnabler : DTDFVocab:Enabler [
    base:desc "ACME-based architecture description for component & connector perspectives"
    DTDFVocab:enables FrictionModelingService
]

instance AADLArchitectureEnabler : DTDFVocab:Enabler [
    base:desc "AADL-based architecture description for component & connector perspectives"
    DTDFVocab:enables FrictionModelingService
]

instance MontiArcArchitectureEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc-based architecture description for component & connector perspectives"
    DTDFVocab:enables FrictionModelingService
]

instance SysMLIBDEnabler : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component & connector perspectives"
    DTDFVocab:enables FrictionModelingService
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavior modeling"
    DTDFVocab:enables FrictionModelingService
]

instance SysMLStateMachineEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 state machines for behavior modeling"
    DTDFVocab:enables FrictionModelingService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed simulation and behavior"
    DTDFVocab:enables FrictionModelingService
]

instance CPlusPlusImplementationEnabler : DTDFVocab:Enabler [
    base:desc "C++ code implementation for simulation and behavior"
    DTDFVocab:enables FrictionModelingService
]

instance JavaImplementationEnabler : DTDFVocab:Enabler [
    base:desc "Java code implementation for simulation and behavior"
    DTDFVocab:enables FrictionModelingService
]

instance AnalyticsProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Dedicated component for processing analytics to generate insights"
    DTDFVocab:enables FrictionModelingService, RealTimeMonitoringService, VisualizationService
]

instance FrictionModelingService : DTDFVocab:Service [
    base:desc "Friction modeling service for motion accuracy optimization"
    DTDFVocab:provides JointFrictionInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of mechanical component behavior"
    DTDFVocab:provides ComponentBehaviorMonitoringInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Unified dashboard visualization for operators and engineers to assess system performance and control"
    DTDFVocab:provides DashboardVisualization
]

instance JointFrictionInsight : DTDFVocab:Insight [
    base:desc "Insight generated from simulation models to understand joint friction characteristics"
]

instance ComponentBehaviorMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring insight for mechanical component behavior"
]

instance DashboardVisualization : DTDFVocab:Insight [
    base:desc "Visual representation of system performance and control options in the unified dashboard"
]

instance RobotFirstAxisEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotor, GearTransmission, CycloidalGear, SiemensSINUMERIK840DslController, MotorPositionEncoder, GearboxPositionEncoder, InputCurrentSensor
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is validated by comparing simulated data against measured physical system data, where deviation serves as the primary validation metric. The system addresses inaccuracies in robot motion through continuous calibration, as specified in the solution scope to improve overall motion accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for sensor data transmission; no details on network topology, bandwidth, latency, reliability, redundancy, or security protocols are specified in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with industry standards including SysML [17] for systems engineering modeling, ACME [23], AADL [24], MontiArc [25,26] for architecture description languages, and SysML Internal Block Diagrams (IBDs) [17,27], facilitating interoperability among heterogeneous stakeholders and systems [31]."
]