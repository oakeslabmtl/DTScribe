// Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures the electrical current draw of the permanent‑magnet synchronous motor on the first vertical axis."
    DTDFVocab:producedData MotorCurrentMQTTTopic
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Position encoder attached to the motor shaft, providing motor angle measurement."
    DTDFVocab:producedData MotorEncoderMQTTTopic
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Position encoder attached to the gearbox output shaft, providing gearbox angle measurement."
    DTDFVocab:producedData GearboxEncoderMQTTTopic
]

// Physical‑to‑virtual interaction
instance MotorCurrentMQTTTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderMQTTTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderMQTTTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

instance TorqueMQTTTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderMQTTTopic, GearboxEncoderMQTTTopic
]

instance AngularVelocityMQTTTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderMQTTTopic, GearboxEncoderMQTTTopic
]

// Data traces
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Current trace recorded from motor current sensor via MQTT."
    DTDFVocab:inputTo DataAggregationEnabler, ParameterEstimationEnabler
    DTDFVocab:fromData MotorCurrentMQTTTopic
]

instance MotorEncoderData : DTDFVocab:Data [
    base:desc "Motor encoder trace recorded from motor encoder sensor via MQTT."
    DTDFVocab:inputTo DataAggregationEnabler, ParameterEstimationEnabler
    DTDFVocab:fromData MotorEncoderMQTTTopic
]

instance GearboxEncoderData : DTDFVocab:Data [
    base:desc "Gearbox encoder trace recorded from gearbox encoder sensor via MQTT."
    DTDFVocab:inputTo DataAggregationEnabler, ParameterEstimationEnabler
    DTDFVocab:fromData GearboxEncoderMQTTTopic
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Computed torque trace derived from encoder data."
    DTDFVocab:inputTo DataAggregationEnabler, ParameterEstimationEnabler
    DTDFVocab:fromData TorqueMQTTTopic
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Computed angular velocity trace derived from encoder data."
    DTDFVocab:inputTo DataAggregationEnabler, ParameterEstimationEnabler
    DTDFVocab:fromData AngularVelocityMQTTTopic
]

// Engineering and simulation models
instance StructuralSysMLModel : DTDFVocab:Model [
    base:desc "Structural SysML representation of motor and gearboxes for the first vertical axis."
    DTDFVocab:inputTo EngineeringModelEnabler
]

instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink block model of the permanent‑magnet synchronous motor, integrated with motor friction models."
    DTDFVocab:inputTo SimulationEnabler
]

instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink block model of the gearbox, incorporating gear friction characteristics."
    DTDFVocab:inputTo SimulationEnabler
]

instance SystemDynamicsSimulinkModel : DTDFVocab:Model [
    base:desc "System‑level Simulink model combining motor, gearbox, and link dynamics with friction blocks."
    DTDFVocab:inputTo SimulationEnabler
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Data calculation model implementing Coulomb‑viscous friction law."
    DTDFVocab:inputTo FrictionLawEnabler
]

instance StribeckModel : DTDFVocab:Model [
    base:desc "Data calculation model implementing Stribeck friction law."
    DTDFVocab:inputTo FrictionLawEnabler
]

instance DahlModel : DTDFVocab:Model [
    base:desc "Data calculation model implementing Dahl friction law."
    DTDFVocab:inputTo FrictionLawEnabler
]

instance LuGreModel : DTDFVocab:Model [
    base:desc "Data calculation model implementing LuGre friction law."
    DTDFVocab:inputTo FrictionLawEnabler
]

// Enablers
instance EngineeringModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that loads the structural SysML model and performs component analysis."
    DTDFVocab:enables StructuralModelAnalysisService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that compiles and runs Simulink simulation models for real‑time evaluation."
    DTDFVocab:enables RealTimeSimulationService
]

instance FrictionLawEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that activates friction calculation models for identification and estimation."
    DTDFVocab:enables FrictionModelIdentificationService
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that aggregates raw sensor traces for processing and feature extraction."
    DTDFVocab:enables DataAggregationService
]

instance ParameterEstimationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that runs parameter estimation algorithms using aggregated data to inform controller tuning."
    DTDFVocab:enables ParameterEstimationService
]

// Services
instance StructuralModelAnalysisService : DTDFVocab:Service [
    base:desc "Service that performs analysis of the structural SysML model."
    DTDFVocab:provides StructuralModelInsight
]

instance FrictionModelIdentificationService : DTDFVocab:Service [
    base:desc "Service that performs continuous friction model identification using white‑box and black‑box techniques."
    DTDFVocab:provides FrictionEstimationInsight
]

instance RealTimeSimulationService : DTDFVocab:Service [
    base:desc "Service that runs real‑time simulation of the motor and gearbox dynamics."
    DTDFVocab:provides SimulationDeviationInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Service that provides a web‑based dashboard visualizing joint behavior and simulation results."
    DTDFVocab:provides VisualizationInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Service that aggregates and stores sensor traces for analysis."
    DTDFVocab:provides DataAggregationInsight
]

instance ParameterEstimationService : DTDFVocab:Service [
    base:desc "Service that estimates controller parameters from aggregated data to inform fine‑tuning."
    DTDFVocab:provides ParameterOptimizationInsight
]

// Insights
instance StructuralModelInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing structural analysis of the motor and gearbox system."
]

instance FrictionEstimationInsight : DTDFVocab:Insight [
    base:desc "Insight providing current estimates of joint friction components (static, kinetic, viscous)."
]

instance SimulationDeviationInsight : DTDFVocab:Insight [
    base:desc "Insight revealing deviations between simulated and measured behavior."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight visualizing real‑time joint trajectories and friction effects."
]

instance DataAggregationInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing aggregated sensor data and detected patterns."
]

instance ParameterOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting adjustments to control parameters for improved motion accuracy."
]

// Component and Environment
instance MABI_MAX100VerticalAxisDigitalTwin : DTDFVocab:Component [
    base:desc "Digital twin component representing the first vertical axis of the MABI MAX 100 industrial robot, including engineering, simulation, and data models."
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains MABI_MAX100VerticalAxisDigitalTwin, EngineeringModelEnabler, SimulationEnabler, FrictionLawEnabler, DataAggregationEnabler, ParameterEstimationEnabler, StructuralSysMLModel, MotorSimulinkModel, GearboxSimulinkModel, SystemDynamicsSimulinkModel, CoulombViscousFrictionModel, StribeckModel, DahlModel, LuGreModel, MotorCurrentData, MotorEncoderData, GearboxEncoderData, TorqueData, AngularVelocityData, MotorEncoderSensor, GearboxEncoderSensor, MotorCurrentSensor, MotorCurrentMQTTTopic, MotorEncoderMQTTTopic, GearboxEncoderMQTTTopic, TorqueMQTTTopic, AngularVelocityMQTTTopic, FrictionModelIdentificationService, RealTimeSimulationService, VisualizationDashboardService, DataAggregationService, ParameterEstimationService, StructuralModelAnalysisService, StructuralModelInsight, FrictionEstimationInsight, SimulationDeviationInsight, VisualizationInsight, DataAggregationInsight, ParameterOptimizationInsight
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data acquisition and model updates at the robot’s sensor sampling frequency (typically a few kHz), allowing continuous drift detection and incremental friction model refinement."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated DT comprising the asset definition, engineering models, simulation models, live data streams, processing components, and visualization services, all interconnected via AAS and MQTT to deliver a coherent digital shadow of the first robot axis."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Primarily used during the operational stage; the digital shadow captures as‑manufactured structure, models as‑designed dynamics, and updates as‑operated behavior through continuous data collection and model refinement."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceable data provenance through original recording channels and processing steps; transitive traceability between data traces, processing components, and models; comparison of measured versus simulated quantities to validate model accuracy; continuous parameter identification mitigating drift; acknowledgment of sensor uncertainties and model approximation errors."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT is used to stream sensor data from the robot to the digital shadow; no other protocols or network architectures are mentioned."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "SysML (used for modeling), Asset Administration Shells (AAS, part of Industrie 4.0 standards), and MQTT (standard MQTT protocol). No explicit mention of other standards such as ACME, AADL, or MontiArc."
]