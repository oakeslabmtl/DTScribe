// ===========================================================
// Data Transmitted (via MQTT)
// ===========================================================

instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

// ===========================================================
// Physical Sensing Components
// ===========================================================

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures motor phase current I_M from the robot controller",
    DTDFVocab:producedData CurrentDataTransmitted
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the permanent‑magnet synchronous motor delivering angular position r_M",
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located after the gearwheel gearbox delivering angular position r_G",
    DTDFVocab:producedData GearboxPositionDataTransmitted
]

// ===========================================================
// Virtual Data (time‑series traces)
// ===========================================================

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series trace of motor current I_M streamed from the controller",
    DTDFVocab:fromData CurrentDataTransmitted,
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance MotorAngularPositionData : DTDFVocab:Data [
    base:desc "Time‑series trace of motor angular position r_M",
    DTDFVocab:fromData MotorPositionDataTransmitted,
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance GearboxAngularPositionData : DTDFVocab:Data [
    base:desc "Time‑series trace of gearbox angular position r_G",
    DTDFVocab:fromData GearboxPositionDataTransmitted,
    DTDFVocab:inputTo MQTTBrokerEnabler
]

// ===========================================================
// Physical Acting Components
// ===========================================================

instance PMSMActuator : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor driven by current I_M"
]

instance GearwheelGearboxActuator : DTDFVocab:ActingComponent [
    base:desc "Gearwheel gearbox transmitting torque from the motor to the output shaft"
]

instance CycloidalGearboxActuator : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gearbox transmitting torque from the gearwheel gearbox to the robot axis"
]

// ===========================================================
// Engineering & Simulation Models
// ===========================================================

instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams describing the first axis architecture",
    DTDFVocab:inputTo SysMLToolEnabler
]

instance SimulinkFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of motor, gearwheel and cycloidal gearboxes with friction formulations (Coulomb‑Viscous, Stribeck, Dahl, LuGre)",
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance CalculationModelFrictionIdentification : DTDFVocab:Model [
    base:desc "Data‑driven calculation model that identifies static, kinetic and viscous friction parameters from measured data",
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

// ===========================================================
// Enablers (Tooling & Infrastructure)
// ===========================================================

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker used for live streaming of sensor data (I_M, r_M, r_G) to the digital shadow",
    DTDFVocab:enables FrictionIdentificationService, DashboardVisualizationService
]

instance SimulinkExecutionEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink runtime executing simulation and calculation models",
    DTDFVocab:enables FrictionIdentificationService, MotionControlUpdateService
]

instance DashboardAppEnabler : DTDFVocab:Enabler [
    base:desc "Custom web dashboard visualizing friction loss and model updates for operators",
    DTDFVocab:enables DashboardVisualizationService
]

instance SysMLToolEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling tool providing structural definitions for the digital twin"
]

// ===========================================================
// Services (DT Functions)
// ===========================================================

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Identifies static, kinetic and viscous friction parameters using combined white‑box (physics) and black‑box (data‑driven) models",
    DTDFVocab:provides InsightFrictionLossInsight, ActionAdjustMotionControl
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of friction loss, model predictions and parameter updates on the operator dashboard",
    DTDFVocab:provides InsightRealtimeVisualization
]

instance MotionControlUpdateService : DTDFVocab:Service [
    base:desc "Feeds updated friction parameters back to the robot motion‑control algorithm to improve positional accuracy",
    DTDFVocab:provides ActionAdjustMotionControl
]

// ===========================================================
// Insights & Actions
// ===========================================================

instance InsightFrictionLossInsight : DTDFVocab:Insight [
    base:desc "Insight that quantifies friction loss on the first axis, enabling operators to monitor efficiency"
]

instance InsightRealtimeVisualization : DTDFVocab:Insight [
    base:desc "Insight delivering live charts of sensor traces and friction model predictions in the dashboard"
]

instance ActionAdjustMotionControl : DTDFVocab:Action [
    base:desc "Automatically updates the motion‑control algorithm with newly identified friction parameters",
    DTDFVocab:IsAutomatic true
]

// ===========================================================
// Physical Components (System Under Study)
// ===========================================================

instance FirstAxisMotor : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor of the first axis"
]

instance FirstAxisGearwheelGearbox : DTDFVocab:Component [
    base:desc "Gearwheel gearbox situated between the motor and the cycloidal gearbox"
]

instance FirstAxisCycloidalGearbox : DTDFVocab:Component [
    base:desc "Cycloidal gearbox transmitting torque to the robot arm's first axis"
]

instance FirstAxisAssembly : DTDFVocab:Environment [
    base:contains FirstAxisMotor, FirstAxisGearwheelGearbox, FirstAxisCycloidalGearbox, PMSMActuator, GearwheelGearboxActuator, CycloidalGearboxActuator
]

// ===========================================================
// Digital Twin Instance (Shadow)
// ===========================================================

instance FirstAxisShadow : DTDFVocab:DigitalTwin [
    base:desc "Digital shadow representing the first axis of the MABI MAX 100 robot continuously refined with live sensor data and updated friction models"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None - the digital shadow follows a one-way data flow from the physical system to the virtual model and does not send commands back to the robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time operation; data are ingested continuously as the robot moves, enabling on-line model updating."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose-driven digital shadow architecture linking the physical first axis (asset) to engineering, simulation and data-calculation models via a Processing component that consumes input data traces and produces simulated outputs, all organized according to the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Applied during the operational phase of the robot to continuously identify friction; the digital shadow does not cover design or manufacturing stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability is ensured by linking each data point to its source and processing model; simulated outputs are compared against measured reference traces to validate friction models and quantify deviation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot controller to the digital shadow over MQTT; the Asset Administration Shell provides a standardized interface for model linking."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation follows the Asset Administration Shell (AAS) specification, a standard for Industry 4.0 digital twins."
]