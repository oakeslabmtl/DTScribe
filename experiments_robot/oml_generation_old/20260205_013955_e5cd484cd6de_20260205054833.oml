// C2: Acting Components
instance JointActuatorSubSystem : DTDFVocab:ActingComponent [
    base:desc "2‑stage gear train driven by a 2.8 kW PMSM, commanded via EtherCAT with velocity, torque, and position setpoints. Joint constrained to a Cartesian range of [‑90°, +90°] with a maximum angular velocity of 75°/s. Actuation limits: motor current ≤ 30 A; gear backlash ≤ 0.2°. PLC safety logic monitors current, speed, and position before motion."
]

// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor providing motor input current in Amps."
    DTDFVocab:producedData CurrentDataTransmitted
]

instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Primary position encoder mounted on the motor shaft, providing shaft angle feedback."
    DTDFVocab:producedData ShaftAngleDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder located behind the gearbox, providing output angle feedback."
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

// C4: Physical–to‑Virtual interaction
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance ShaftAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// C10: Models/Data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Motor current telemetry in Amps transmitted over MQTT."
    DTDFVocab:inputTo MQTTDataIntegrationEnabler
    DTDFVocab:fromData CurrentDataTransmitted
]

instance ShaftAngleData : DTDFVocab:Data [
    base:desc "Angle of motor shaft in degrees transmitted over MQTT."
    DTDFVocab:inputTo MQTTDataIntegrationEnabler
    DTDFVocab:fromData ShaftAngleDataTransmitted
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Angle of gearbox output in degrees transmitted over MQTT."
    DTDFVocab:inputTo MQTTDataIntegrationEnabler
    DTDFVocab:fromData GearboxAngleDataTransmitted
]

instance GeometricCadModel : DTDFVocab:Model [
    base:desc "Geometric model derived from 3D CAD linked via SysML block‑definition diagram."
    DTDFVocab:inputTo MRIReferenceModelEnabler
]

instance BehavioralStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state‑machine model representing joint behavior."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance BehavioralMontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc automaton model for component behavior."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance AnalyticalFrictionCoulombViscousModel : DTDFVocab:Model [
    base:desc "Coulomb‑Viscous friction model integrated within Simulink."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance AnalyticalFrictionStribeckModel : DTDFVocab:Model [
    base:desc "Stribeck friction formulation included in Simulink engine."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

// C11: Enablers
instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink used as the primary simulation engine."
    DTDFVocab:enables TelemetryProcessingService
]

instance MQTTDataIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker handling automated one‑way streams of sensor telemetry."
    DTDFVocab:enables TelemetryProcessingService
]

instance MRIReferenceModelEnabler : DTDFVocab:Enabler [
    base:desc "Model Reference Integration (MRI) architecture linking SysML and Simulink models."
    DTDFVocab:enables TelemetryProcessingService
]

// C6: Services
instance TelemetryProcessingService : DTDFVocab:Service [
    base:desc "Service processing sensor telemetry data to update Digital Twin state."
    DTDFVocab:provides JointStateInsight
]

// C17: Insights
instance JointStateInsight : DTDFVocab:Insight [
    base:desc "Insight into joint position, velocity, and safety status derived from current and angle telemetry."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "No virtual‑to‑physical control flow is provided. The digital shadow operates passively, refraining from issuing commands or pushing data back to the physical machine. Consequently, there are no command types, control message formats, validation mechanisms, or conflict resolution procedures inherent to this twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital Twin development follows a multi‑level depth of abstraction: (1) requirements capture, (2) functional architecture modeling with SysML and other ADLs such as ACME and AADL, (3) logical architecture using dedicated structural formats (e.g., MontiArc IBDs and SysML component diagrams), and (4) product‑/technical‑layer realization in code or simulation tools. Transition between levels is managed through systematic model mapping and code‑generation chains, while governance is achieved via a structured MBSE process that records each level’s artifacts and their dependencies."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation of the Digital Twin model is performed by measuring deviations between simulated data and sensor‑measured data (Section IV.A). The sensor arrangement is designed to reduce positional uncertainty (Section III). No explicit quantitative uncertainty bounds, error‑correction mechanisms, or formal verification procedures are detailed, and the document does not state any quality‑assurance processes beyond this comparative validation approach."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system’s network layer relies on the MQTT publish/subscribe protocol over standard TCP/IP. MQTT broker(s) manage the routing of sensor data; the specification does not detail further topology, bandwidth, latency or security settings."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Standards compliance encompasses SysML v1.7 for functional and component modeling, ACME and AADL architectures, MontiArc IBDs, and the SMArDT methodology for digital twin engineering. These standards together provide a foundation for traceability, interoperability, and model‑based data interchange across the twin lifecycle."
]