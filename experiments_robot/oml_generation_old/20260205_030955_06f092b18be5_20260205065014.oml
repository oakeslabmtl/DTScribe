// C2: Acting Components
instance PermanentMagnetSynchronousMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor driven by a Siemens SINUMERIK 840D SL servo drive; motor coupled to a gear train feeding a cycloidal gear assembly, with safety limits for position, torque, and emergency stop."
]

// C3: Physical sensing components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution encoder measuring motor shaft rotation."
    DTDFVocab:producedData MotorShaftEncoderData
]

instance OutputShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution encoder on the output shaft for mechanical backlash cancellation."
    DTDFVocab:producedData OutputShaftEncoderData
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor electrical current."
    DTDFVocab:producedData MotorCurrentData
]

// C4: Physical‑to‑virtual interaction
instance MotorShaftEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance OutputShaftEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputShaftEncoder
]

instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// Types of Data
instance MotorShaftEncoderReading : DTDFVocab:Data [
    base:desc "Telemetry of motor shaft encoder displacement, published to MQTT topic 'twin/telemetry/motor_encoder'."
    DTDFVocab:fromData MotorShaftEncoderData
    DTDFVocab:inputTo MQTTBroker
]

instance OutputShaftEncoderReading : DTDFVocab:Data [
    base:desc "Telemetry of output shaft encoder displacement, published to MQTT topic 'twin/telemetry/output_encoder'."
    DTDFVocab:fromData OutputShaftEncoderData
    DTDFVocab:inputTo MQTTBroker
]

instance MotorCurrentReading : DTDFVocab:Data [
    base:desc "Telemetry of motor current, published to MQTT topic 'twin/telemetry/motor_current'."
    DTDFVocab:fromData MotorCurrentData
    DTDFVocab:inputTo MQTTBroker
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker handling real‑time data exchange between the physical system and the digital twin."
    DTDFVocab:enables TelemetryProcessingService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation engine executing the dynamic model."
]

instance SysMLModeler : DTDFVocab:Enabler [
    base:desc "SysML modeling tool for the structural taxonomy."
]

instance ModelIntegratorTool : DTDFVocab:Enabler [
    base:desc "Tool linking the SysML structural model with the Simulink dynamic model via the RFLP methodology."
]

// C10: Models/Data
instance SimulinkDynamicsModel : DTDFVocab:Model [
    base:desc "Simulink model representing the dynamics of the permanent‑magnet synchronous motor, gear train, and cycloidal gear assembly."
    DTDFVocab:inputTo SimulinkEngine
    DTDFVocab:inputTo TelemetryProcessingService
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML model capturing the component‑connector architecture and functional topology of the twin."
    DTDFVocab:inputTo SysMLModeler
]

instance ModelRelationshipInterface : DTDFVocab:Model [
    base:desc "Interface linking the SysML structural model to the Simulink dynamic model."
    DTDFVocab:inputTo ModelIntegratorTool
]

// C6: Services
instance TelemetryProcessingService : DTDFVocab:Service [
    base:desc "Service that processes incoming telemetry, feeds the Simulink simulation, and derives insights."
    DTDFVocab:provides PositionAccuracyInsight, BacklashCancellationInsight, MotorEfficiencyInsight
]

// C17: Insights
instance PositionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating high‑accuracy position monitoring achieved through dual encoder cancellation."
]

instance BacklashCancellationInsight : DTDFVocab:Insight [
    base:desc "Insight demonstrating mechanical backlash cancellation via dual encoder alignment."
]

instance MotorEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight derived from motor current and torque data reflecting drive efficiency."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "No virtual‑to‑physical interaction is defined. The digital twin is a digital shadow that only observes and processes incoming sensor streams; it does not generate or send control commands, feedback, or any backward data to the physical robot. Consequently, there are no command types, control message formats, validation, authentication, conflict resolution or execution confirmation mechanisms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sensor data streams are transmitted from the physical machine to the digital shadow in a real‑time, continuous fashion over MQTT. The system processes each incoming time‑series message immediately, thereby synchronizing the digital representation with the physical state at the moment of arrival; explicit synchronization frequencies or latency thresholds are not specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin is organized using a layered reference model that merges MBSE practices. Functional and logical architecture is captured with SysML IBDs and ADLs, while the virtual model is built and validated through simulation in Simulink. The overall orchestration follows a concrete workflow in which sensor data traces are aggregated, processed by an active processing layer, and used to update a virtual asset model; communication and resource coordination are mediated through an MQTT broker serving as the data bus, and the architecture relies on UML‑style class diagrams to capture component integration."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Twin’s fidelity is evaluated by comparing simulated outputs from the Simulink model against measured telemetry from the physical system. Discrepancies are quantified using a root‑mean‑square error metric between simulated and real position/time data. Data uncertainty originates from sensor noise, encoder quantization, and MQTT network latency; the Twin tracks these uncertainties and flags parameters when error exceeds predefined thresholds, triggering a recalibration routine. No additional automated validation loops, fault detection algorithms, or periodic consistency checks are described beyond this error‑threshold monitoring."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The primary communication channel is an MQTT broker that receives telemetry from the physical asset and delivers it to the digital twin. Configuration details such as topic hierarchy, QoS levels, TLS, or network topology are not specified in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external equipment is achieved solely through the MQTT protocol, delivering raw sensor time series from a Siemens SINUMERIK 840D industrial controller to the digital twin. The data flow is strictly one‑way, as defined for a digital shadow; no commands or control data are sent back to the physical system."
]