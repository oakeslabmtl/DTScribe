instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "permanent magnet synchronous motor with current input (IM) and torque output (τM), coupled with a gear transmission followed by a cycloidal gear to achieve a low gear ratio"
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "motor encoder mounted directly on the motor shaft"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "secondary encoder positioned behind the gearbox"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
    base:desc "motor position data streamed via MQTT protocol"
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
    base:desc "gearbox position data streamed via MQTT protocol"
]

instance MotorEncoderData : DTDFVocab:Data [
    base:desc "raw motor position data from encoder"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo Simulink, SysML
]

instance GearboxEncoderData : DTDFVocab:Data [
    base:desc "raw gearbox position data from encoder"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo Simulink, SysML
]

instance SysML : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for structural modeling across requirements, functional, logical, and product layers"
    DTDFVocab:enables StructuralModelingService
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "RFLP methodology for complexity management in Digital Twin development"
    DTDFVocab:enables RequirementsTraceabilityService
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for complexity management in Digital Twin development"
    DTDFVocab:enables ObjectOrientedService
]

instance SPES : DTDFVocab:Enabler [
    base:desc "SPES methodology for complexity management in Digital Twin development"
    DTDFVocab:enables SystemEngineeringService
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for complexity management in Digital Twin development"
    DTDFVocab:enables ModelBasedService
]

instance ACME : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component & connector architecture modeling"
    DTDFVocab:enables ACMEModelingService
]

instance AADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component & connector architecture modeling"
    DTDFVocab:enables AADLModelingService
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component & connector architecture modeling"
    DTDFVocab:enables MontiArcModelingService
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for analytical modeling and detailed dynamics simulation"
    DTDFVocab:enables JointFrictionMonitoringService
]

instance Cpp : DTDFVocab:Enabler [
    base:desc "C++ programming language for integration of detailed system components"
    DTDFVocab:enables CppIntegrationService
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java programming language for integration of detailed system components"
    DTDFVocab:enables JavaIntegrationService
]

instance DashboardVisualizationTool : DTDFVocab:Enabler [
    base:desc "interactive dashboards and visualization tools for operational decision support"
    DTDFVocab:enables VisualizationService
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams for geometric representation of component & connector architecture"
    DTDFVocab:inputTo SysML
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language model for component & connector architecture"
    DTDFVocab:inputTo ACME
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL Architecture Description Language model for component & connector architecture"
    DTDFVocab:inputTo AADL
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc Architecture Description Language model for component & connector architecture"
    DTDFVocab:inputTo MontiArc
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machine model for behavioral representation"
    DTDFVocab:inputTo SysML
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model for behavioral representation"
    DTDFVocab:inputTo MontiArc
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for analytical dynamics simulation"
    DTDFVocab:inputTo Simulink
]

