// C3: Physical sensing component (digital shadow collector)
instance RobotContextDataCollector : DTDFVocab:SensingComponent [
    base:desc "Continuously collects contextual data traces from the MABI MAX 100 industrial robot as part of the digital shadow's one‑way data flow."
    DTDFVocab:producedData RobotContextDataTrace
]

// C4: Physical‑to‑virtual data transmission
instance RobotContextDataTrace : DTDFVocab:DataTransmitted [
    base:desc "One‑way data flow carrying contextual data traces from the robot to its digital representation (digital shadow)."
    DTDFVocab:producedFrom RobotContextDataCollector
]

// C10: Data (digital object)
instance RobotDigitalShadow : DTDFVocab:Data [
    base:desc "Aggregated digital object storing the abstracted contextual data of the MABI MAX 100 robot."
    DTDFVocab:fromData RobotContextDataTrace
    DTDFVocab:inputTo DigitalTwinPlatform
]

// C10: Models
instance StructuralGeometricModel : DTDFVocab:Model [
    base:desc "Structural and geometric representation of the robot captured in SysML block diagrams and internal block diagrams."
    DTDFVocab:inputTo DigitalTwinPlatform
]

instance BehavioralStateMachineModel : DTDFVocab:Model [
    base:desc "Behavioral model expressed as SysML state‑machine automata for robot operation."
    DTDFVocab:inputTo DigitalTwinPlatform
]

instance AnalyticalSimulinkDynamicModel : DTDFVocab:Model [
    base:desc "Physics‑based dynamic simulation model implemented in MathWorks Simulink."
    DTDFVocab:inputTo DigitalTwinPlatform
]

instance DataDrivenMLRegressorModel : DTDFVocab:Model [
    base:desc "Black‑box machine‑learning regressor model for predictive analytics derived from collected data."
    DTDFVocab:inputTo DigitalTwinPlatform
]

// C11: Enabler (digital‑twin platform)
instance DigitalTwinPlatform : DTDFVocab:Enabler [
    base:desc "Software platform that aggregates models and data, enabling twin services such as processing, decision support, and optimization."
    DTDFVocab:enables ContextDataProcessingService,
                         DecisionSupportService,
                         OptimizationService
]

// C6: Services
instance ContextDataProcessingService : DTDFVocab:Service [
    base:desc "Active component that interprets the one‑way data flow, processing contextual data traces for the twin."
    DTDFVocab:provides ContextualInsight
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Provides decision‑support based on processed data and synchronized model state."
    DTDFVocab:provides DecisionSupportInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Enables optimization functions and potential closed‑loop control for the robot."
    DTDFVocab:provides ControlOptimizationAction
]

// C17: Insights
instance ContextualInsight : DTDFVocab:Insight [
    base:desc "Insight derived from aggregated contextual data about robot state and performance."
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Insight offering recommendations for operational decisions of the robot."
]

// C17: Action
instance ControlOptimizationAction : DTDFVocab:Action [
    base:desc "Automatic action that triggers optimization algorithms or control adjustments based on twin analysis."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "A Digital Twin can provide active components that enable bidirectional communication, allowing the digital model to push data or commands back to the physical system. The documents mention that a digital twin may contain active components for control, but they do not describe command types, control message formats, validation/authentication mechanisms, feedback systems, conflict resolution, or command execution confirmation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows the Digital Shadow Reference Model, consisting of Asset, Model, DataTrace, Processing, and Source entities. A Processing component consumes input DataTraces, applies engineering or simulation models, and emits output DataTraces that become part of the shadow. Associations such as 'originates from' provide transitive traceability from output traces back to source components and models. This component‑&‑connector style orchestration integrates heterogeneous models (e.g., SysML, simulation tools) and manages resources through explicit data‑flow links, embodying a model‑driven integration pattern."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by combining white‑box (physics‑based Simulink) and black‑box (data‑driven) models, as recommended for accurate friction identification. The approach stresses traceability of data to model elements and verification of model transformations (e.g., from SysML to simulation models) to guarantee correctness. Uncertainty arising from model approximations and data preprocessing is acknowledged, and quality assurance relies on explicit traceability links and verification steps described in the literature."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between physical devices and the digital twin relies on the MQTT protocol, with sensors acting as MQTT clients publishing time‑series data to an MQTT broker (e.g., Mosquitto). The network follows a client‑broker topology over IP networks. The documents reference the use of an IoT platform (ThingsBoard) that can ingest MQTT streams, implying a layered architecture where MQTT feeds into the platform’s data processing modules. No explicit bandwidth, latency, reliability, redundancy, or security (e.g., TLS) specifications are provided in the sources."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The deployment environment for the digital shadow/Digital Twin includes cloud‑based IoT platforms such as ThingsBoard and may incorporate Asset Administration Shells (AAS) for standardized representation, as mentioned in the literature. Visualization is performed through a dashboard (e.g., Angular‑based front‑end). While the texts refer to cloud‑based technologies at the machine shop‑floor level, concrete details on compute/storage sizing, scalability mechanisms, deployment models (cloud, edge, on‑premise), or availability assurances are not provided."
]