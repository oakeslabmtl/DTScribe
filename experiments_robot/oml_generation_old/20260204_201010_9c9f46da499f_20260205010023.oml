instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "Structural modeling using Model-Based Systems Engineering (MBSE) with SysML"
    DTDFVocab:inputTo SysMLMethodology, SysMLIBDs
]

instance MontiArcBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral modeling using MontiArc Automaton"
    DTDFVocab:inputTo MontiArcADL
]

instance SysMLStateMachineBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral modeling using SysML state machines"
    DTDFVocab:inputTo SysMLMethodology
]

instance SimulinkAnalyticalSimulation : DTDFVocab:Model [
    base:desc "Analytical simulations using MathWorks Simulink"
    DTDFVocab:inputTo SimulinkSimulationTool
]

instance SysMLMethodology : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology using SysML"
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology RFLP"
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology OOSEM"
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology SPES"
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology SMArDT"
]

instance ACMEADL : DTDFVocab:Enabler [
    base:desc "Architecture Description Language ACME for component and connector modeling"
]

instance AADLADL : DTDFVocab:Enabler [
    base:desc "Architecture Description Language AADL for component and connector modeling"
]

instance MontiArcADL : DTDFVocab:Enabler [
    base:desc "Architecture Description Language MontiArc for component and connector modeling"
]

instance SysMLIBDs : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component and connector modeling"
]

instance SimulinkSimulationTool : DTDFVocab:Enabler [
    base:desc "Simulation tool MathWorks Simulink for analytical simulations"
]

instance CPlusPlusLanguage : DTDFVocab:Enabler [
    base:desc "General-purpose programming language C++ for detailed behavior description"
]

instance JavaLanguage : DTDFVocab:Enabler [
    base:desc "General-purpose programming language Java for detailed behavior description"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Asset Administration Shell (AAS) security submodel (Plattform Industrie 4.0, Document 50) specifies X.509 certificate-based authentication and role-based access control for asset data access. Mosquitto (Document 52) implements MQTT security with TLS encryption and username/password authentication. Thingsboard (Document 53) employs JWT token authentication and fine-grained role-based access control for IoT platform security."
]