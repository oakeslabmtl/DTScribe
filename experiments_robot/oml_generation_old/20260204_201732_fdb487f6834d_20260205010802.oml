instance PhysicalSystemDataSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for data from physical systems integrated via automated one-way flows"
    DTDFVocab:producedData PhysicalSystemDataTransmitted
]

instance PhysicalSystemDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemDataSensor
]

instance PhysicalSystemData : DTDFVocab:Data [
    base:desc "Data from physical systems integrated through automated one-way flows"
    DTDFVocab:fromData PhysicalSystemDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler, JavaEnabler, SysmlEnabler, AcmeEnabler, AadlEnabler, MontiArcEnabler
]

instance SysmlStructuralModel : DTDFVocab:Model [
    base:desc "SysML model for structural modeling (Internal Block Diagrams)"
    DTDFVocab:inputTo SysmlEnabler
]

instance SysmlStateMachineModel : DTDFVocab:Model [
    base:desc "SysML model for behavioral modeling (state machines)"
    DTDFVocab:inputTo SysmlEnabler
]

instance AcmeModel : DTDFVocab:Model [
    base:desc "ACME architecture description language model for components and interfaces"
    DTDFVocab:inputTo AcmeEnabler
]

instance AadlModel : DTDFVocab:Model [
    base:desc "AADL architecture description language model for components and interfaces"
    DTDFVocab:inputTo AadlEnabler
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description language model for components and interfaces"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SimulinkAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model generated using MathWorks Simulink"
    DTDFVocab:inputTo SimulinkEnabler
]

instance CppModel : DTDFVocab:Model [
    base:desc "Model implemented in C++ programming language"
    DTDFVocab:inputTo CppEnabler
]

instance JavaModel : DTDFVocab:Model [
    base:desc "Model implemented in Java programming language"
    DTDFVocab:inputTo JavaEnabler
]

instance SysmlEnabler : DTDFVocab:Enabler [
    base:desc "SysML for system modeling across abstraction levels (requirements, functional architecture, logical architecture, product/technical layer)"
]

instance AcmeEnabler : DTDFVocab:Enabler [
    base:desc "ACME architecture description language for component & connector perspectives"
]

instance AadlEnabler : DTDFVocab:Enabler [
    base:desc "AADL architecture description language for component & connector perspectives"
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc architecture description language for component & connector perspectives"
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for behavior modeling and analytical model generation"
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for behavior modeling and analytical model generation"
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for behavior modeling and analytical model generation"
]

instance RflpMethodology : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements, Functions, Logics, Physics) methodology for managing system complexity through hierarchical abstraction"
]

instance OosemMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for managing system complexity through hierarchical abstraction"
]

instance SpesMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for managing system complexity through hierarchical abstraction"
]

instance SmardtMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for managing system complexity through hierarchical abstraction"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to standards such as SysML [17] for Model-Based Systems Engineering (MBSE), ACME [23], AADL [24], MontiArc [25, 26], and SysML IBDs [17, 27] as Architecture Description Languages (ADLs) for component-based modeling. It integrates tools like MathWorks Simulink [28], simulation methods [29, 30], and general-purpose programming languages (C++, Java), while addressing heterogeneous stakeholder integration [31] through interoperability frameworks."
]