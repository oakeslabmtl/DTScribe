// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures motor current IM on the first axis of the MABI MAX 100 robot"
    DTDFVocab:producedData MotorCurrentTopic
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Measures motor encoder position on the first axis of the MABI MAX 100 robot"
    DTDFVocab:producedData MotorEncoderTopic
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Measures gearbox encoder position on the first axis of the MABI MAX 100 robot"
    DTDFVocab:producedData GearboxEncoderTopic
]

// C4: Physical-to-virtual interaction
instance MotorCurrentTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// C10: Models/Data
instance TorqueFromCurrent : DTDFVocab:Data [
    base:desc "Derived torque (τ) computed from motor current IM and encoder data streamed via MQTT"
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData MotorCurrentTopic
]

instance AngularVelocityFromEncoder : DTDFVocab:Data [
    base:desc "Derived angular velocity (ω) computed from motor encoder position"
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData MotorEncoderTopic
]

instance AccelerationFromEncoder : DTDFVocab:Data [
    base:desc "Derived angular acceleration (α) computed from changes in motor encoder position"
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData MotorEncoderTopic
]

instance MotorSysMLModel : DTDFVocab:Model [
    base:desc "Structural SysML model of the motor on the first axis of the MABI MAX 100 robot"
    DTDFVocab:inputTo MBSEEnabler
]

instance GearboxSysMLModel : DTDFVocab:Model [
    base:desc "Structural SysML model of the gearbox on the first axis of the MABI MAX 100 robot"
    DTDFVocab:inputTo MBSEEnabler
]

instance SystemSysMLModel : DTDFVocab:Model [
    base:desc "Structural SysML model of the integrated motor‑gearbox‑robot system on the first axis"
    DTDFVocab:inputTo MBSEEnabler
]

instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink executable model of the motor, including Coulomb, viscous, Stribeck, Dahl, and LuGre friction models"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink executable model of the gearbox, including friction models"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SystemSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink executable model of the full first axis system"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SensorToTorqueModel : DTDFVocab:Model [
    base:desc "Data‑calculation model converting raw motor current and encoder data into torque τ"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SensorToAngularVelocityModel : DTDFVocab:Model [
    base:desc "Data‑calculation model converting encoder position data into angular velocity ω"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating real‑time transmission of sensor data from the first axis of the MABI MAX 100 robot to the Digital Twin"
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Encapsulates MATLAB Simulink execution environment for simulating motor and gearbox dynamics"
    DTDFVocab:enables FrictionSimulationService, FrictionIdentificationService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Implements the unified dashboard framework for real‑time visualization and data comparison"
    DTDFVocab:enables RealTimeDashboardService, DataComparisonService
]

instance MBSEEnabler : DTDFVocab:Enabler [
    base:desc "Provides Multi‑Layer MBSE tooling for SysML modeling and semantic linking via AAS"
]

// C6: Services
instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of sensor data and simulation results on a unified dashboard"
    DTDFVocab:provides FrictionBehaviorInsight, MaintenanceDecisionInsight
]

instance FrictionSimulationService : DTDFVocab:Service [
    base:desc "Runs MATLAB Simulink simulations of ideal and friction‑laden motor/gearbox behavior using various friction models"
    DTDFVocab:provides FrictionParameterInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Performs dynamic identification and updating of friction parameters based on measured data"
    DTDFVocab:provides FrictionParameterInsight, UpdateMotionControlAction
]

instance DataComparisonService : DTDFVocab:Service [
    base:desc "Compares simulated output urt output with measured data to validate friction model accuracy"
    DTDFVocab:provides FrictionBehaviorInsight
]

// C17: Insights/Actions
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters (Coulomb, viscous coefficients) used to adjust control algorithms"
]

instance FrictionBehaviorInsight : DTDFVocab:Insight [
    base:desc "Visual insights into friction behavior over time, guiding maintenance decisions"
]

instance MaintenanceDecisionInsight : DTDFVocab:Insight [
    base:desc "Insight that informs maintenance scheduling based on friction analysis"
]

instance UpdateMotionControlAction : DTDFVocab:Action [
    base:desc "Automatically updates motion control parameters in the robot controller using newly identified friction values"
    DTDFVocab:IsAutomatic true
]

instance AdjustControlParametersAction : DTDFVocab:Action [
    base:desc "Manual adjustment of control parameters based on friction insights"
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time data exchange synchronized with the robot’s sensor polling (implied instantaneously during operation)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Asset (first axis) linked to its engineering model and sensor streams, a processing component that runs simulation models and generates data traces, an AAS for semantic description, and a dashboard aggregating the DT’s data points for user visualization."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the operated stage of the first axis, providing runtime data and friction model identification after manufacture, but does not involve design or production phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Use of continuous identification of white‑box and black‑box friction models; traceability of data creation via processing chain; simulation models based on measured motor and gearbox parameters; validation by comparing simulated torque/velocity with real sensor data and refining models; acknowledged uncertainty due to wear and changing operating conditions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical robot and DT communicate over MQTT, with sensor data published on topics (e.g., /robot/axis1/current, /robot/axis1/angle). Asset Administration Shells may expose further APIs. No other specific protocol details are given."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for system architecture, MATLAB Simulink for executable simulation, MQTT as standard communication protocol, and Asset Administration Shells (AAS) for semantic interoperability per industry standards."
]