// C3: Physical sensing components
instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted encoder measuring the motor shaft angle"
    DTDFVocab:producedData MotorMountedEncoderAngleTransmitted
]

instance GearboxSecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearwheel gearbox measuring output angle"
    DTDFVocab:producedData GearboxSecondaryEncoderAngleTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring the motor input current I_M"
    DTDFVocab:producedData MotorCurrentTransmitted
]

// C4: Physical-to-virtual interaction
instance MotorMountedEncoderAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder
]

instance GearboxSecondaryEncoderAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxSecondaryEncoder
]

instance MotorCurrentTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Data
instance MotorMountedAngleData : DTDFVocab:Data [
    base:desc "Motor shaft angle derived from motor‑mounted encoder"
    DTDFVocab:fromData MotorMountedEncoderAngleTransmitted
    DTDFVocab:inputTo SimulinkSimulationEngine, MQTTBroker
]

instance GearboxOutputAngleData : DTDFVocab:Data [
    base:desc "Output angle derived from gearbox secondary encoder"
    DTDFVocab:fromData GearboxSecondaryEncoderAngleTransmitted
    DTDFVocab:inputTo SimulinkSimulationEngine, MQTTBroker
]

instance MotorInputCurrentData : DTDFVocab:Data [
    base:desc "Motor input current I_M measured by current sensor"
    DTDFVocab:fromData MotorCurrentTransmitted
    DTDFVocab:inputTo SimulinkSimulationEngine, MQTTBroker
]

instance SimulatedTorqueData : DTDFVocab:Data [
    base:desc "Simulated torque τ output from friction model simulations"
    DTDFVocab:inputTo VisualizationDashboard, SimulinkSimulationEngine
]

instance SimulatedAngularVelocityData : DTDFVocab:Data [
    base:desc "Simulated angular velocity ω output from friction model simulations"
    DTDFVocab:inputTo VisualizationDashboard, SimulinkSimulationEngine
]

// C10: Models/Data (engineering models)
instance SysMLAxisModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagram of the robot axis"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SysMLMotorModel : DTDFVocab:Model [
    base:desc "SysML model of the drive motor"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SysMLGearboxModel : DTDFVocab:Model [
    base:desc "SysML model of the gearwheel and cycloidal gearboxes"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkFrictionFreeModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction‑free behavior model"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkCoulombViscousModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink Coulomb‑Viscous friction model"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkStribeckModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink Stribeck friction model"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkDahlModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink Dahl friction model"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkLuGreModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink LuGre friction model"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

// C11: Enablers
instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink simulation engine executing friction models in real time"
    DTDFVocab:enables FrictionIdentificationService, ParameterCalibrationService, SimulationComparisonService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker streaming live sensor data to the digital shadow"
    DTDFVocab:enables FrictionIdentificationService
]

instance VisualizationDashboard : DTDFVocab:Enabler [
    base:desc "Custom dashboard visualizing measured and simulated data and deviation analyses"
    DTDFVocab:enables DataVisualizationService, SimulationComparisonService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Industry 4.0 AAS providing standardized asset information exchange"
    DTDFVocab:enables ParameterCalibrationService
]

instance SiemensSinumerikController : DTDFVocab:Enabler [
    base:desc "Siemens SINUMERIK 840D controller that receives calibrated friction parameters"
    DTDFVocab:enables FrictionParameterFeedbackAction
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction parameters using combined white‑box and black‑box models"
    DTDFVocab:provides FrictionParameterInsight, FrictionParameterFeedbackAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Unified dashboard visualizing measured vs. simulated data and presenting deviation analyses"
    DTDFVocab:provides DashboardDeviationAnalysisAction
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Model‑based calibration of friction parameters to improve motion‑control accuracy"
    DTDFVocab:provides FrictionParameterInsight
]

instance SimulationComparisonService : DTDFVocab:Service [
    base:desc "Comparison of simulated and measured trace data for validation"
    DTDFVocab:provides DashboardDeviationAnalysisAction
]

// C17: Insights
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters (static, kinetic, viscous) fed back to controller improve model‑based motion control accuracy"
]

// C17: Actions
instance DashboardDeviationAnalysisAction : DTDFVocab:Action [
    base:desc "Display deviation analyses on the dashboard for operator decision support"
    DTDFVocab:IsAutomatic false
]

instance FrictionParameterFeedbackAction : DTDFVocab:Action [
    base:desc "Automatically feed back identified friction parameters to the robot controller"
    DTDFVocab:IsAutomatic true
]

// C2: Components (system under study)
instance MABIMAX100AxisComponent : DTDFVocab:Component [
    base:desc "First axis of the MABI MAX 100 six‑axis industrial robot comprising motor, gearwheel gearbox and cycloidal gearbox"
]

instance MotorComponent : DTDFVocab:Component [
    base:desc "Drive motor of the robot axis"
]

instance GearwheelGearboxComponent : DTDFVocab:Component [
    base:desc "Gearwheel gearbox transmitting motion from motor to output shaft"
]

instance CycloidalGearboxComponent : DTDFVocab:Component [
    base:desc "Cycloidal gearbox providing high reduction ratio"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow functions as a passive, one‑way data consumer and does not send commands or data back to the physical robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time acquisition and processing of sensor streams; the digital shadow updates its data traces at the same rate as the MQTT sensor feed (unspecified frequency)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A digital shadow composed of a Purpose (FrictionDerivation), an Asset (the first axis), Sources (sensor streams), Processing components (simulation models), Models (engineering, data‑calculation and simulation), and DataTraces/DataPoints that together provide friction insight and visualization."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated stage (runtime) of the robot, augmented by engineering models that represent the designed structure of the axis."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of every data point to its source and processing model; comparison of simulated friction‑free and friction‑included traces against measured data; continuous re‑identification of white‑box and black‑box friction parameters to maintain model validity over wear and changing operating conditions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow using the MQTT publish/subscribe protocol; models and metadata are encapsulated in Asset Administration Shells."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of Asset Administration Shells (Industry 4.0 standard) and SysML modeling language; integration of standard communication via MQTT."
]