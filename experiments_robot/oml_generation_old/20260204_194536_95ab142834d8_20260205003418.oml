// C1: System Component
instance RobotFirstAxisComponent : DTDFVocab:Component [
    base:desc "The first axis of the MABI MAX 100 six‑axis industrial robot, comprising a permanent‑magnet synchronous motor, a gearwheel gearbox and a cycloidal gearbox."
]

// C3: Physical sensing components
instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder measuring the motor shaft angle."
    DTDFVocab:producedData EncoderAngleDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder located behind the gearbox measuring gearbox output angle."
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor reading motor current I_M from the Siemens SINUMERIK 840D controller."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance EncoderAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Data
instance MeasuredEncoderAngle : DTDFVocab:Data [
    base:desc "Measured motor shaft angle trace from MotorMountedEncoder."
    DTDFVocab:fromData EncoderAngleDataTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

instance MeasuredGearboxAngle : DTDFVocab:Data [
    base:desc "Measured gearbox output angle trace from GearboxEncoder."
    DTDFVocab:fromData GearboxAngleDataTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

instance MeasuredMotorCurrent : DTDFVocab:Data [
    base:desc "Measured motor current I_M trace from MotorCurrentSensor."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

instance CalculatedTorqueData : DTDFVocab:Data [
    base:desc "Torque derived from motor current and motor model."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

instance CalculatedAngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity derived from encoder angle traces."
    DTDFVocab:fromData EncoderAngleDataTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

instance CalculatedAngularAccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration derived from angular velocity."
    DTDFVocab:fromData EncoderAngleDataTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker providing low‑latency streaming of sensor data to the digital shadow."
    DTDFVocab:enables RealTimeVisualizationService, FrictionIdentificationService, FrictionComparisonService, FrictionParameterGenerationService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for running motor, gearbox and friction models."
    DTDFVocab:enables RealTimeVisualizationService, FrictionIdentificationService, FrictionComparisonService, FrictionParameterGenerationService
]

instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML tool used for structural and behavioral modeling of the robot axis."
    DTDFVocab:enables RealTimeVisualizationService
]

instance DashboardApp : DTDFVocab:Enabler [
    base:desc "Dashboard application visualizing measured and simulated data in real time."
    DTDFVocab:enables RealTimeVisualizationService
]

instance AASRegistry : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell registry for standardized asset description."
    DTDFVocab:enables RealTimeVisualizationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of measured and simulated data in a dashboard."
    DTDFVocab:provides FrictionParameterInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Identification and quantification of static, kinetic and viscous friction in the gearbox."
    DTDFVocab:provides FrictionParameterInsight
]

instance FrictionComparisonService : DTDFVocab:Service [
    base:desc "Comparison of simulated friction‑free models with measured data."
    DTDFVocab:provides FrictionComparisonInsight
]

instance FrictionParameterGenerationService : DTDFVocab:Service [
    base:desc "Generation of friction parameters for improving robot motion control."
    DTDFVocab:provides FrictionParameterInsight, UpdateMotionControlAlgorithmAction
]

// C17: Insights
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters (static, kinetic, viscous) enable adjustment of the motion control algorithm, improving positional accuracy."
]

instance FrictionComparisonInsight : DTDFVocab:Insight [
    base:desc "Comparison reveals deviations between friction‑free simulations and actual behavior, highlighting the impact of gearbox friction."
]

// C17: Actions
instance UpdateMotionControlAlgorithmAction : DTDFVocab:Action [
    base:desc "Adjust the robot's motion control algorithm using the derived friction parameters."
    DTDFVocab:IsAutomatic true
]

// C10: Models/Data (additional model instances)
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML Block Definition and Internal Block diagrams describing the robot axis structure and signal flows."
    DTDFVocab:inputTo SysMLTool
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "Executable Simulink model of the permanent‑magnet synchronous motor."
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkGearwheelModel : DTDFVocab:Model [
    base:desc "Executable Simulink model of the gearwheel gearbox."
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkGearboxFrictionFreeModel : DTDFVocab:Model [
    base:desc "Simulink model of the cycloidal gearbox without friction."
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkGearboxFrictionCoulombViscousModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Coulomb‑viscous friction for the gearbox."
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkGearboxFrictionStribeckModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Stribeck friction for the gearbox."
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkGearboxFrictionDahlModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Dahl friction for the gearbox."
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkGearboxFrictionLuGreModel : DTDFVocab:Model [
    base:desc "Simulink model implementing LuGre friction for the gearbox."
    DTDFVocab:inputTo SimulinkEngine
]

instance FrictionParameterCalculationModel : DTDFVocab:Model [
    base:desc "Calculation model that derives static, kinetic and viscous friction parameters from measured torque and velocity data."
    DTDFVocab:inputTo SimulinkEngine
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The shadow operates in real‑time, ingesting sensor streams as they arrive (continuous, live data) and updating friction model parameters continuously during robot operation. The processing chain (MQTT ingestion → processing → Simulink simulation) runs at the same rate as the incoming data, enabling on‑line identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow consisting of the asset (first axis), a purpose (FrictionDerivation), multiple DataTraces sourced from sensors, Processing components that execute simulation models, and a dashboard that presents both measured and simulated traces for friction analysis."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the operated phase of the robot, i.e., runtime operation where live data are collected and used for continuous friction model identification."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability from DataPoints to their generating Processing component and underlying simulation or calculation model; comparison of simulated friction‑free behavior with measured data to validate friction models; ability to continuously update white‑box and black‑box friction parameters as wear occurs."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted to the digital shadow over MQTT; the connection is one‑way (physical‑to‑virtual)."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation employs the Asset Administration Shell (AAS) as a standardized digital representation of the asset, SysML as a standardized modeling language, and MQTT as a widely adopted messaging protocol for industrial IoT data exchange."
]