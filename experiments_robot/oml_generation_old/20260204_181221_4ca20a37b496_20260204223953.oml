// C3: Physical sensing component
instance RobotJointStateSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor that captures robot joint states as contextual data traces for the digital twin"
    DTDFVocab:producedData JointStateDataTransmitted
]

// C4: Physical-to-virtual interaction
instance JointStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotJointStateSensor
]

// C10: Data
instance JointStateData : DTDFVocab:Data [
    base:desc "Contextual data trace of robot joint states collected from the physical robot"
    DTDFVocab:fromData JointStateDataTransmitted
    DTDFVocab:inputTo SimulationEngine, MachineLearningEngine
]

// C10: Models/Data – physics‑based white‑box model
instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based white‑box model realized as a Simulink dynamic simulation derived from SysML logical architecture"
    DTDFVocab:inputTo SimulationEngine
]

// C10: Models/Data – data‑driven black‑box model
instance MachineLearningFrictionPredictorModel : DTDFVocab:Model [
    base:desc "Data‑driven black‑box machine‑learning model that predicts nonlinear robot friction from intrinsic robot state data"
    DTDFVocab:inputTo MachineLearningEngine
]

// C11: Enablers – simulation execution engine
instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Software engine that executes the Simulink dynamic simulation model"
    DTDFVocab:enables InsightComputationService
]

// C11: Enablers – machine‑learning inference engine
instance MachineLearningEngine : DTDFVocab:Enabler [
    base:desc "Inference engine that runs the machine‑learning friction predictor model"
    DTDFVocab:enables InsightComputationService
]

// C6: Service – insight computation
instance InsightComputationService : DTDFVocab:Service [
    base:desc "Service that consumes model outputs to compute up‑to‑date behavioral abstractions for decision support"
    DTDFVocab:provides RealTimeBehaviorInsight
]

// C17: Insight – real‑time behavior
instance RealTimeBehaviorInsight : DTDFVocab:Insight [
    base:desc "Derived insight representing the current robot behavior and friction state, traceable to original joint state data and processing components"
]

// C11: Enablers – MBSE toolchain
instance MBSEToolchain : DTDFVocab:Enabler [
    base:desc "Model‑Based Systems Engineering toolchain (SysML, ADLs) supporting model development and transformation"
    DTDFVocab:enables ModelManagementService
]

// C11: Enablers – ADL integration tool
instance ADLIntegrationTool : DTDFVocab:Enabler [
    base:desc "Architecture Description Language integration tool (ACME, AADL, MontiArc) used to capture system structure"
    DTDFVocab:enables ModelManagementService
]

// C11: Enablers – version control system
instance VersionControlSystem : DTDFVocab:Enabler [
    base:desc "Version control system managing model evolution and concretization steps"
    DTDFVocab:enables ModelManagementService
]

// C6: Service – model management
instance ModelManagementService : DTDFVocab:Service [
    base:desc "Service that manages model lifecycle, transformations, and versioning for the digital twin"
    DTDFVocab:provides ModelEvolutionInsight
]

// C17: Insight – model evolution
instance ModelEvolutionInsight : DTDFVocab:Insight [
    base:desc "Insight about the evolution state of twin models, enabling traceability of refinements and extensions"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin development follows the Model‑Based Systems Engineering (MBSE) lifecycle, beginning with abstract requirement models, proceeding to functional‑architecture models, then logical‑architecture models, and finally to the product/technical layer where concrete component‑and‑connector representations are realized. At early stages the Twin is represented by high‑level SysML requirement and block diagrams; during refinement it is detailed with ADL specifications (e.g., ACME, AADL, MontiArc) and IBDs, and at the implementation phase it is instantiated as executable simulation models (e.g., Simulink) or source code (C++, Java). Transitions between stages are managed by model refinement and composition, and lifecycle governance is achieved by maintaining traceability links among the artefacts across the abstraction levels."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by combining white‑box Simulink simulations (providing interpretable, high‑confidence predictions) with black‑box machine‑learning models (capturing complex nonlinearities). Validation and verification are performed through traceability of model transformations (e.g., SysML to simulation code) and verification of data preprocessing steps. Uncertainty sources such as model parameter errors and sensor noise are acknowledged, and the framework emphasizes traceability and verification methods to ensure correctness of transformations and overall quality assurance of models and data."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The documents reference several established modelling standards that are employed in the Twin: the Object Management Group’s SysML language, and architecture description languages such as ACME, AADL, and MontiArc, each defined by their respective specification bodies. These standards facilitate interoperability of models across tools and stakeholders. No explicit certification schemes, compliance frameworks, or industry‑specific standards (e.g., IEC 62832) are mentioned."
]