// Sensing component (Simulink simulation)
instance SimulinkSimulation : DTDFVocab:SensingComponent [
    base:desc "Simulink engine executing dynamic behaviour and generating simulation outputs"
    DTDFVocab:producedData SimulationOutputsTransmission
]

// Data transmission from simulation
instance SimulationOutputsTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkSimulation
]

// Simulation output data
instance SimulationOutputsData : DTDFVocab:Data [
    base:desc "Outputs produced by the Simulink simulation representing system dynamics"
    DTDFVocab:fromData SimulationOutputsTransmission
    DTDFVocab:inputTo SimulinkEngineEnabler
]

// Enabler for Simulink simulation engine
instance SimulinkEngineEnabler : DTDFVocab:Enabler [
    base:desc "Provides execution of MontiArc-derived models within the Simulink engine"
    DTDFVocab:enables SimulationService
]

// Service performing simulation
instance SimulationService : DTDFVocab:Service [
    base:desc "Runs Simulink simulations to validate logical consistency of the digital twin"
    DTDFVocab:provides SimulationBehaviorInsight
]

// Insight from simulation
instance SimulationBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight regarding the consistency of simulated system behaviour with requirements"
]

// Model for SysML Requirements
instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML model capturing hardware‑software and functional requirements"
    DTDFVocab:inputTo MontiArcEnabler
]

// Enabler for MontiArc component‑connector modelling
instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "Provides MontiArc modelling of component‑connector architecture"
    DTDFVocab:enables ModelVersioningService
]

// Service managing model versioning
instance ModelVersioningService : DTDFVocab:Service [
    base:desc "Manages hierarchical versioning, change‑log, and rollback of artefacts"
    DTDFVocab:provides ModelChangeLogInsight
]

// Insight into model evolution
instance ModelChangeLogInsight : DTDFVocab:Insight [
    base:desc "Insight on the evolution of model artefacts across version hierarchy"
]

// Enabler for C++/Java code generation
instance CodeGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Compiles MontiArc and SysML models into C++/Java executable code"
    DTDFVocab:enables CodeGenerationService
]

// Service for code generation
instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Generates compiled code targeting C++ or Java platforms"
    DTDFVocab:provides CodeArtifactInsight
]

// Insight regarding generated code artefacts
instance CodeArtifactInsight : DTDFVocab:Insight [
    base:desc "Insight into the generated code artefacts and their versions"
]

// Enabler for Git version control
instance VersionControlGitEnabler : DTDFVocab:Enabler [
    base:desc "Provides Git‑based version control for artefacts and source code"
    DTDFVocab:enables VersionControlService
]

// Service handling version control
instance VersionControlService : DTDFVocab:Service [
    base:desc "Tracks changes, manages rollback, and records change log in Git"
    DTDFVocab:provides VersionLogInsight
]

// Insight of version control logs
instance VersionLogInsight : DTDFVocab:Insight [
    base:desc "Insight into the history of artifact changes tracked by Git"
]

// Enabler for relational database storage
instance RelationalDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Stores simulation outputs, code artefacts, and version logs in a relational DB"
    DTDFVocab:enables DataStorageService
]

// Service for data persistence
instance DataStorageService : DTDFVocab:Service [
    base:desc "Persistently stores and retrieves DT data for analysis"
    DTDFVocab:provides DataPersistenceInsight
]

// Insight on data persistence
instance DataPersistenceInsight : DTDFVocab:Insight [
    base:desc "Insight into data integrity and availability within the database"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle follows a structured, MBSE‑driven sequence: 1) Requirements modelling in SysML, captured via UML requirement diagrams; 2) Functional architecture defined with SysML IBDs or ACME, detailing component interfaces and connectors; 3) Logical architecture modelled with MontiArc Automaton or AADL, incorporating state‑machine behaviour; 4) Product/technical layer realised through MathWorks Simulink simulation blocks translated to executable C++ or Java code. Transition between stages is achieved through model transformation (e.g., SysML to AADL) and round‑trip engineering. Governance is guided by formalised MBSE methodologies such as RFLP or SMArDT, which prescribe versioning, change‑impact analysis, and lifecycle checkpoints."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "As described in [52], Mosquitto implements MQTT authentication via user/password or X.509 client certificates, along with TLSv1.2/1.3 for transport encryption and support for anonymous access. In [53], Thingsboard uses role‑based access control, JWT‑based device authentication, TLS for MQTT and HTTPS, and fine‑grained permissions on dashboards, assets, and telemetry. The RAMI 4.0 reference model (see [48], [49]) situates security as a cross‑cutting layer, recommending adherence to IEC 62443, OPC UA secure channel and AuthC protocols, and the use of threat‑risk assessment matrices. Together, these mechanisms provide authentication, authorization, secure communication, threat mitigation, and fail‑safe configuration for the digital twin system."
]