// C3: Physical sensing component
instance PhysicalStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that captures physical state information (e.g., sensor readings and operational parameters) from the cyber‑physical system"
    DTDFVocab:producedData MqttDataTransmission
]

// C4: Physical‑to‑virtual interaction (data transmission)
instance MqttDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalStateSensor
]

// C10: Data (input trace)
instance PhysicalStateDataTrace : DTDFVocab:Data [
    base:desc "Input data trace representing contextual sensor readings collected from the physical object"
    DTDFVocab:fromData MqttDataTransmission
    DTDFVocab:inputTo ProcessingComponent
]

// C11: Enablers – processing component and tooling
instance ProcessingComponent : DTDFVocab:Enabler [
    base:desc "Processing component that consumes input data traces and, via encoded data‑calculation or simulation models, produces higher‑level abstraction traces"
    DTDFVocab:enables AnalyticalInsightService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "Matlab/Simulink simulation engine used to execute white‑box simulation models"
    DTDFVocab:enables AnalyticalInsightService
]

instance JavaRuntime : DTDFVocab:Enabler [
    base:desc "Java runtime environment used to execute data‑calculation and black‑box machine‑learning models"
    DTDFVocab:enables AnalyticalInsightService
]

// C6: Service
instance AnalyticalInsightService : DTDFVocab:Service [
    base:desc "Analytical service that derives performance indicators and anomaly detections from processed data traces"
    DTDFVocab:provides PerformanceIndicatorInsight, AnomalyDetectionInsight
]

// C17: Insights
instance PerformanceIndicatorInsight : DTDFVocab:Insight [
    base:desc "Insight providing performance indicator metrics computed from higher‑level abstraction data"
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting anomalies in the system behavior based on processed data lineage"
]

// C10: Models (engineering, simulation, data‑calculation)
instance SimulinkWhiteBoxModel : DTDFVocab:Model [
    base:desc "White‑box simulation model implemented in Simulink that generates dynamic system abstractions"
    DTDFVocab:inputTo ProcessingComponent, SimulinkEngine
]

instance MachineLearningBlackBoxModel : DTDFVocab:Model [
    base:desc "Black‑box machine‑learning model used for data‑driven predictions within the digital twin"
    DTDFVocab:inputTo ProcessingComponent, JavaRuntime
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Data‑calculation model that performs computational processing on input traces"
    DTDFVocab:inputTo ProcessingComponent, JavaRuntime
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Document 1 notes that a Digital Twin can provide active components that issue control commands back to the physical system, enabling bi‑directional interaction. No concrete details on command types, message formats, validation, authentication, or confirmation mechanisms are provided in the documents."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT development follows the MBSE hierarchy of abstraction levels described in Document 1: a requirements stage, a functional‑architecture stage, a logical‑architecture stage, and a product/technical stage. Models are refined across these stages, and the transition between stages is managed by constructing concrete realizations that map abstract concepts to detailed design artifacts, as defined by the reference model approach."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is governed by the need for correctness of underlying models and transformations, with verification methods such as traceability from SysML specifications to simulation models. Validation relies on the 'originates‑from' link to trace each output data trace back to its source models and input data, ensuring that uncertainties (e.g., modeling errors, data noise) can be identified and quantified. Error detection and correction mechanisms are based on this fine‑grained traceability, while quality assurance processes include verification of model transformations and conformance checking against reference models as stipulated for digital shadow and twin development."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on MQTT messaging, with Mosquitto cited as a server/client implementation (Document 2). MQTT serves as the protocol mediating data exchange between edge devices and higher‑level services such as the ThingsBoard IoT platform (Document 2). The documents do not describe network topology, bandwidth, latency, redundancy, or additional security protocols beyond the use of MQTT."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system can be hosted on an open‑source IoT platform like ThingsBoard (Document 2). The provided documents do not contain specific information about computational or storage requirements, scalability mechanisms, deployment models, or availability/reliability assurances."
]