instance MQTTTimeSeriesSensorData : DTDFVocab:DataTransmitted [
    base:desc "Time-series sensor data streamed via MQTT protocol from physical components to digital shadow"
]

instance FrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Insight identifying friction to improve robot control accuracy"
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Integrated visualization within unified dashboard for user interaction"
]

instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Insight for model validation against requirements"
]

instance SystemArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight for component & connector relationships management"
]

instance ControlAlgorithmInsight : DTDFVocab:Insight [
    base:desc "Insight for control algorithm performance"
]

instance SystemDesignInsight : DTDFVocab:Insight [
    base:desc "Insight for system design methodology application"
]

instance ProblemIdentificationInsight : DTDFVocab:Insight [
    base:desc "Insight for problem identification in physical system"
]

instance AssetAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight for asset and model analysis"
]

instance ModelCreationInsight : DTDFVocab:Insight [
    base:desc "Insight for creation of calculations or models"
]

instance DataIdentificationInsight : DTDFVocab:Insight [
    base:desc "Insight for data identification"
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service for identifying friction to improve robot control accuracy",
    DTDFVocab:provides FrictionIdentificationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Integrated visualization within unified dashboard for user interaction",
    DTDFVocab:provides DashboardVisualizationInsight
]

instance ModelValidationService : DTDFVocab:Service [
    base:desc "Service for validating system models against requirements",
    DTDFVocab:provides ModelValidationInsight
]

instance SystemArchitectureService : DTDFVocab:Service [
    base:desc "Service for managing component & connector relationships via ADLs",
    DTDFVocab:provides SystemArchitectureInsight
]

instance ControlAlgorithmService : DTDFVocab:Service [
    base:desc "Service for high-performance control algorithms using C++",
    DTDFVocab:provides ControlAlgorithmInsight
]

instance SystemDesignService : DTDFVocab:Service [
    base:desc "Service for system design using methodologies like RFLP, OOSEM, SPES, SMArDT",
    DTDFVocab:provides SystemDesignInsight
]

instance ProblemIdentificationService : DTDFVocab:Service [
    base:desc "Service for identifying problem in the physical system",
    DTDFVocab:provides ProblemIdentificationInsight
]

instance AssetAndModelAnalysisService : DTDFVocab:Service [
    base:desc "Service for asset and model analysis",
    DTDFVocab:provides AssetAnalysisInsight
]

instance CreationOfCalculationsService : DTDFVocab:Service [
    base:desc "Service for use or creation of calculations or models",
    DTDFVocab:provides ModelCreationInsight
]

instance DataIdentificationService : DTDFVocab:Service [
    base:desc "Service for data identification",
    DTDFVocab:provides DataIdentificationInsight
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML tool for systems engineering modeling across requirements, functional, logical, and product/technical abstraction levels",
    DTDFVocab:enables ModelValidationService, FrictionIdentificationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for analytical simulations of robot dynamics",
    DTDFVocab:enables FrictionIdentificationService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component & connector relationships",
    DTDFVocab:enables SystemArchitectureService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component & connector relationships",
    DTDFVocab:enables SystemArchitectureService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component & connector relationships",
    DTDFVocab:enables SystemArchitectureService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming for high-performance control algorithms",
    DTDFVocab:enables ControlAlgorithmService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java for developing unified dashboard visualization",
    DTDFVocab:enables VisualizationService
]

instance RFLPMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "RFLP methodology for handling complexity in digital twin development",
    DTDFVocab:enables SystemDesignService
]

instance OOSEMMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for handling complexity in digital twin development",
    DTDFVocab:enables SystemDesignService
]

instance SPESMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for handling complexity in digital twin development",
    DTDFVocab:enables SystemDesignService
]

instance SMArDTMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for handling complexity in digital twin development",
    DTDFVocab:enables SystemDesignService
]

instance MABIMAX100SensorData : DTDFVocab:Data [
    base:desc "Time-series sensor data from MABI MAX 100 robot encoders",
    DTDFVocab:fromData MQTTTimeSeriesSensorData,
    DTDFVocab:inputTo SysMLEnabler, SimulinkEnabler, ACMEEnabler, AADLEnabler, MontiArcEnabler, CppEnabler, JavaEnabler, RFLPMethodologyEnabler, OOSEMMethodologyEnabler, SPESMethodologyEnabler, SMArDTMethodologyEnabler
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML model for structural architecture across requirements, functional, logical, and product/technical abstraction levels",
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML model for functional architecture across abstraction levels",
    DTDFVocab:inputTo SysMLEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model for state machine behavior",
    DTDFVocab:inputTo MontiArcEnabler
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for analytical simulations",
    DTDFVocab:inputTo SimulinkEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language model for component & connector relationships",
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL Architecture Description Language model for component & connector relationships",
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcArchitectureModel : DTDFVocab:Model [
    base:desc "MontiArc Architecture Description Language model for component & connector relationships",
    DTDFVocab:inputTo MontiArcEnabler
]

instance MABIMAX100Motor : DTDFVocab:Component [
    base:desc "Motor in the MABI MAX 100 robot's six axes"
]

instance MABIMAX100Gearbox : DTDFVocab:Component [
    base:desc "Gearbox in the MABI MAX 100 robot's six axes"
]

instance MABIMAX100Controller : DTDFVocab:Component [
    base:desc "Controller for the MABI MAX 100 robot"
]

instance MABIMAX100Encoder : DTDFVocab:SensingComponent [
    base:desc "Encoders in the MABI MAX 100 robot's six axes for position and speed measurement",
    DTDFVocab:producedData MQTTTimeSeriesSensorData
]

instance MABIMAX100Environment : DTDFVocab:Environment [
    base:contains MABIMAX100Motor, MABIMAX100Gearbox, MABIMAX100Controller, MABIMAX100Encoder
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication protocol: MQTT for sensor data streaming; no details on network topology, bandwidth, latency, reliability, redundancy, or security protocols provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to industry standards such as SysML [17] for model-based systems engineering, ACME [23], AADL [24], and MontiArc [25], [26] for architecture description languages (ADLs) to define component interfaces and interconnections. Methodologies including RFLP, OOSEM, SPES, and SMArDT are applied across abstraction levels (requirements, functional, logical, product/technical). Behavior modeling integrates Simulink [28], simulation tools [29], [30], and general-purpose languages (C++, Java), with interoperability ensured through heterogeneous stakeholder integration [31]."
]