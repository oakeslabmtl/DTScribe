namespace DTDFVocab = "http://example.org/DTDFVocab"
namespace base = "http://www.w3.org/2004/02/skos/core#"

instance MABIMAX100Robot : DTDFVocab:Component [
    base:desc "Six-axis industrial robot with focus on first vertical axis for digital twin",
    base:isContainedIn ManufacturingEnvironment
]

instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:desc "Manufacturing environment for precise motion control and friction modeling",
    base:contains MABIMAX100Robot
]

instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures input current for MABI MAX 100 first vertical axis",
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Measures output angle for MABI MAX 100 first vertical axis",
    DTDFVocab:producedData OutputAngleDataTransmitted
]

instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

instance FrictionInsight : DTDFVocab:Insight [
    base:desc "Real-time friction model updates for joint dynamics"
]

instance MotionControlInsight : DTDFVocab:Insight [
    base:desc "Optimized motion control parameters for improved accuracy"
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous, multi-physics-aware identification of joint friction for MABI MAX 100 robot",
    DTDFVocab:provides FrictionInsight
]

instance MotionControlOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of robot motion control accuracy for manufacturing processes",
    DTDFVocab:provides MotionControlInsight
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "RFLP MBSE methodology for system modeling across abstraction levels",
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "OOSEM MBSE methodology for system modeling",
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance SPES : DTDFVocab:Enabler [
    base:desc "SPES MBSE methodology for system modeling",
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "SMArDT MBSE methodology for system modeling",
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance ACME : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component-and-connector architecture",
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance AADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for embedded systems",
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance MontiArcADL : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component-and-connector architecture",
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance SysML : DTDFVocab:Enabler [
    base:desc "SysML for structural modeling (IBDs) and behavior modeling (state machines)",
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral modeling",
    DTDFVocab:enables FrictionIdentificationService, MotionControlOptimizationService
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and analytical modeling",
    DTDFVocab:enables FrictionIdentificationService
]

instance Cpp : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior implementation",
    DTDFVocab:enables MotionControlOptimizationService
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior implementation",
    DTDFVocab:enables MotionControlOptimizationService
]

instance InputCurrentData : DTDFVocab:Data [
    base:desc "Real-time input current measurements from MABI MAX 100 robot",
    DTDFVocab:fromData InputCurrentDataTransmitted,
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT, ACME, AADL, MontiArcADL, SysML, MontiArcAutomaton, Simulink, Cpp, Java
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Real-time output angle measurements from MABI MAX 100 robot",
    DTDFVocab:fromData OutputAngleDataTransmitted,
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT, ACME, AADL, MontiArcADL, SysML, MontiArcAutomaton, Simulink, Cpp, Java
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams for structural modeling of MABI MAX 100 robot",
    DTDFVocab:inputTo SysML
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME-based component-and-connector architecture model",
    DTDFVocab:inputTo ACME
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL-based component-and-connector architecture model",
    DTDFVocab:inputTo AADL
]

instance MontiArcArchitectureModel : DTDFVocab:Model [
    base:desc "MontiArc-based component-and-connector architecture model",
    DTDFVocab:inputTo MontiArcADL
]

instance MontiArcBehavioralModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton-based behavioral model of MABI MAX 100 robot",
    DTDFVocab:inputTo MontiArcAutomaton
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machine model for robot control behavior",
    DTDFVocab:inputTo SysML
]

instance SimulinkAnalyticalModel : DTDFVocab:Model [
    base:desc "Simulink-based analytical model for friction identification and motion control",
    DTDFVocab:inputTo Simulink
]

instance CppImplementationModel : DTDFVocab:Model [
    base:desc "C++ implementation of detailed robot behavior",
    DTDFVocab:inputTo Cpp
]

instance JavaImplementationModel : DTDFVocab:Model [
    base:desc "Java implementation of detailed robot behavior",
    DTDFVocab:inputTo Java
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Shadow system employs the reference model defined in Fig. 1 (UML class diagram), integrating SysML for functional architecture modeling (IBDs), Simulink for behavior simulation, and Asset Administration Shells (AAS) for data exchange and visualization."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for sensor data streaming; no details on network topology, bandwidth, latency, reliability, redundancy, or security protocols beyond the protocol usage are provided."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Data exchange occurs via MQTT protocol for live measurements and Asset Administration Shells (AAS) for structured data representation and visualization."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to industry standards including SysML for model-based systems engineering, ACME, AADL, and MontiArc as architecture description languages for component & connector perspectives, and methodologies such as RFLP, OOSEM, SPES, and SMArDT for multi-level abstraction management. It integrates heterogeneous stakeholders through standardized modeling practices, utilizing tools like Simulink and general-purpose programming languages (C++, Java) for detailed behavior modeling and simulation."
]