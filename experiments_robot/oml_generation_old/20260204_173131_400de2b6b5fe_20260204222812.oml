// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures input current of the robot motor."
    DTDFVocab:producedData CurrentDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Measures angular velocity of the robot motor."
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

instance AxisPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Measures the position of the first robot axis."
    DTDFVocab:producedData AxisPositionDataTransmitted
]

// C4: Physical-to-virtual interaction – Data Transmitted
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

instance AxisPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AxisPositionSensor
]

// C10: Data (post‑processing, ready for DT)
instance CurrentData : DTDFVocab:Data [
    base:desc "Filtered current measurement after low‑pass preprocessing."
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo AASExecutor
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Filtered angular velocity measurement after low‑pass preprocessing."
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo AASExecutor
]

instance AxisPositionData : DTDFVocab:Data [
    base:desc "Filtered axis position measurement after low‑pass preprocessing."
    DTDFVocab:fromData AxisPositionDataTransmitted
    DTDFVocab:inputTo AASExecutor
]

// C11: Enablers
instance AASExecutor : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) executor that interprets AAS sub‑models, maps data traces to SysML identification points, and incorporates them into the digital shadow stored on the Thingsboard platform."
    DTDFVocab:enables RealTimeFrictionMonitoringService, PredictiveMaintenanceService, FrictionCompensationControlService, CentralDataMemoryService
]

instance ProcessingComponent : DTDFVocab:Enabler [
    base:desc "Processing component that consumes input traces, executes white‑box (simulation) and black‑box (data‑calculation) models, and emits output traces for the digital shadow."
    DTDFVocab:enables PhysicsModelUpdateService, NeuralNetworkModelUpdateService, MachiningParameterOptimizationService, CO2ReductionScenarioAnalysisService, ProductQualityPredictionService
]

// C6: Services
instance RealTimeFrictionMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of joint friction and load conditions."
    DTDFVocab:provides JointFrictionInsight
]

instance PhysicsModelUpdateService : DTDFVocab:Service [
    base:desc "Automatically updates the physics‑based white‑box friction model."
    DTDFVocab:provides UpdatePhysicsModelAction
]

instance NeuralNetworkModelUpdateService : DTDFVocab:Service [
    base:desc "Automatically updates the data‑driven black‑box neural network friction model."
    DTDFVocab:provides UpdateNeuralNetworkModelAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Performs predictive maintenance and early fault detection using sensor data."
    DTDFVocab:provides EarlyFaultDetectionInsight, ScheduleMaintenanceAction
]

instance FrictionCompensationControlService : DTDFVocab:Service [
    base:desc "Executes closed‑loop control for friction compensation."
    DTDFVocab:provides ApplyFrictionCompensationAction
]

instance MachiningParameterOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes machining parameters (cutting speed, feed) through simulation."
    DTDFVocab:provides OptimalMachiningParametersInsight
]

instance CO2ReductionScenarioAnalysisService : DTDFVocab:Service [
    base:desc "Analyzes CO₂‑reduction scenarios for the machining process."
    DTDFVocab:provides CO2EmissionReductionInsight
]

instance ProductQualityPredictionService : DTDFVocab:Service [
    base:desc "Predicts product quality based on real‑time process data."
    DTDFVocab:provides PredictedProductQualityInsight
]

instance CentralDataMemoryService : DTDFVocab:Service [
    base:desc "Provides a central data memory accessible by ancillary applications."
    DTDFVocab:provides DataMemoryAvailabilityInsight
]

// C17: Insights
instance JointFrictionInsight : DTDFVocab:Insight [
    base:desc "Insight into joint friction levels derived from sensor data."
]

instance EarlyFaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects early signs of faults based on trends in friction and load data."
]

instance OptimalMachiningParametersInsight : DTDFVocab:Insight [
    base:desc "Identifies optimal cutting speed and feed rates for reduced wear and energy consumption."
]

instance CO2EmissionReductionInsight : DTDFVocab:Insight [
    base:desc "Evaluates potential CO₂ emission reductions from optimized machining strategies."
]

instance PredictedProductQualityInsight : DTDFVocab:Insight [
    base:desc "Predicts final product quality based on current operation conditions."
]

instance DataMemoryAvailabilityInsight : DTDFVocab:Insight [
    base:desc "Indicates availability and status of the central data‑memory service."
]

// C17: Actions
instance UpdatePhysicsModelAction : DTDFVocab:Action [
    base:desc "Updates parameters of the physics‑based friction model."
    DTDFVocab:IsAutomatic true
]

instance UpdateNeuralNetworkModelAction : DTDFVocab:Action [
    base:desc "Retrains and updates the neural network friction model."
    DTDFVocab:IsAutomatic true
]

instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Schedules maintenance actions based on early fault detection."
    DTDFVocab:IsAutomatic false
]

instance ApplyFrictionCompensationAction : DTDFVocab:Action [
    base:desc "Applies computed compensation torque to joints in real‑time."
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance PhysicsFrictionModel : DTDFVocab:Model [
    base:desc "White‑box physics‑based friction model implemented in MATLAB/Simulink."
    DTDFVocab:inputTo ProcessingComponent
]

instance NeuralNetworkFrictionModel : DTDFVocab:Model [
    base:desc "Black‑box neural network model for data‑driven friction inference."
    DTDFVocab:inputTo ProcessingComponent
]

instance MachiningParameterSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model for machining parameter optimization."
    DTDFVocab:inputTo ProcessingComponent
]

instance CO2EmissionScenarioModel : DTDFVocab:Model [
    base:desc "Model to simulate CO₂ emission scenarios for the machining process."
    DTDFVocab:inputTo ProcessingComponent
]

instance ProductQualityPredictionModel : DTDFVocab:Model [
    base:desc "Model predicting product quality based on process data."
    DTDFVocab:inputTo ProcessingComponent
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin operates in real‑time synchronized with the robot’s control loop. Sensor data are streamed continuously to the twin, processed by the friction simulation, and the resulting model parameters are fed back before the control system’s dead‑time elapses. Thus the synchronization frequency matches the control cycle and latency must be lower than the control system’s dead‑time as required for high‑precision motion control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture consists of a physical robot feeding live sensor streams to an Asset Administration Shell (AAS) executor, which triggers processing components (SysML‑based structural model, Simulink‑based friction simulation wrapped as an FMI component). The processing component generates data traces that are stored in ThingsBoard via MQTT. An automated pipeline builds the digital shadow from the AAS, runs the simulation, and publishes results to a visualization dashboard, providing end‑to‑end orchestration of data acquisition, model execution, and result dissemination."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin lifecycle follows the MBSE development phase in which the system is modelled at successive abstraction levels – requirements, functional architecture, logical architecture, and product/technical layer. At each level a model is created using a suitable language (e.g., SysML for requirements and functional view, ADLs such as ACME, AADL, MontiArc for component‑connector view, and state‑machine or Simulink models for behavior). Transition between stages is managed by traceability links defined in the reference model, allowing propagation of changes from higher‑level specifications to lower‑level implementations. Governance is implied by the need to integrate heterogeneous stakeholders and tools across the abstraction hierarchy."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by combining verified white‑box Simulink models with data‑driven machine‑learning models and by maintaining strict traceability from raw data traces to the generated model outputs. Verification methods include checking the correctness of transformations from SysML specifications to simulation models, as highlighted in the literature. Uncertainty sources are identified in the underlying models and in data preprocessing; they are quantified through traceability links that allow error detection and correction at the level of individual data traces. Quality assurance is achieved by fine‑grained provenance tracking (originates‑from associations) and by enforcing verification of model transformations, as advocated for reliable digital shadow development."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on MQTT (implemented with Mosquitto) as the primary communication protocol. MQTT provides a publish‑subscribe architecture with hierarchical topics and optional read/write permission controls for users. Messages are encoded in JSON and transported over standard TCP/IP networks. Data originating from the robot are sent to the MQTT broker, then forwarded to the AAS Executor and finally to the ThingsBoard IoT platform for storage and visualization. The integration of the Asset Administration Shell ensures that the same data model is used across components, supporting interoperability between the MQTT layer, the AAS layer, and the ThingsBoard dashboard."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is achieved through the use of the Asset Administration Shell (AAS) as the integration backbone, MQTT as the messaging protocol, and ThingsBoard as the IoT data platform. Simulation models are integrated via the Functional Mock‑up Interface (FMI) linking SysML structural models with Simulink behavioral models. This combination enables seamless data exchange between the robot, the twin, and external enterprise systems such as dashboards or optimization services."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The described digital‑twin approach is built on established engineering standards. Structural and architectural models use SysML (OMG standard) for block diagrams, AADL for architecture analysis, ACME for component‑connector descriptions, and MontiArc/Automaton for behavior. Simulation and control logic are expressed in MathWorks Simulink, which is a de‑facto standard for dynamic system simulation. Interoperability between models is achieved through the traceability associations defined in the Digital Shadow Reference Model, but the documents do not specify additional certification or industry‑wide compliance frameworks."
]