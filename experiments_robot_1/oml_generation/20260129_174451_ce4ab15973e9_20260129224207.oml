instance PhysicalSystemStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors capturing physical system states for digital twin"
    DTDFVocab:producedData PhysicalSystemStateData
]

instance PhysicalSystemStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemStateSensor
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces from physical system"
    DTDFVocab:fromData PhysicalSystemStateData
    DTDFVocab:inputTo CPlusPlusEnabler, JavaEnabler
]

instance GeometricModel_SysMLIBD : DTDFVocab:Model [
    base:desc "Geometric representation using SysML Internal Block Diagrams"
    DTDFVocab:inputTo SysMLEnabler
]

instance BehavioralModel_MontiArcAutomaton : DTDFVocab:Model [
    base:desc "Behavioral model using MontiArc Automaton"
    DTDFVocab:inputTo MontiArcEnabler
]

instance BehavioralModel_SysMLStateMachines : DTDFVocab:Model [
    base:desc "Behavioral model using SysML v1.7 state machines"
    DTDFVocab:inputTo SysMLEnabler
]

instance AnalyticalModel_Simulink : DTDFVocab:Model [
    base:desc "Analytical model implemented in MathWorks Simulink"
    DTDFVocab:inputTo SimulinkEnabler
]

instance AnalyticalModel_CPlusPlus : DTDFVocab:Model [
    base:desc "Analytical model implemented in C++"
    DTDFVocab:inputTo CPlusPlusEnabler
]

instance AnalyticalModel_Java : DTDFVocab:Model [
    base:desc "Analytical model implemented in Java"
    DTDFVocab:inputTo JavaEnabler
]

instance MBSEEnabler : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering (MBSE) methodology for system modeling across requirements, functional architecture, logical architecture, and product/technical layers"
    DTDFVocab:enables SimulationService
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for system modeling across multiple abstraction levels"
    DTDFVocab:enables SimulationService
]

instance RFLPEnabler : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements, Functions, Logics, Physics) methodology for hierarchical modeling"
    DTDFVocab:enables SimulationService
]

instance OOSEMEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for managing system complexity"
    DTDFVocab:enables SimulationService
]

instance SPESEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for managing system complexity"
    DTDFVocab:enables SimulationService
]

instance SMArDTEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for managing system complexity"
    DTDFVocab:enables SimulationService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for modeling components, interfaces, interconnections"
    DTDFVocab:enables SimulationService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for modeling components, interfaces, interconnections"
    DTDFVocab:enables SimulationService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for modeling components, interfaces, interconnections"
    DTDFVocab:enables SimulationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and analytical modeling"
    DTDFVocab:enables SimulationService
]

instance CPlusPlusEnabler : DTDFVocab:Enabler [
    base:desc "C++ general-purpose programming language for implementing analytical models and simulation"
    DTDFVocab:enables SimulationService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java general-purpose programming language for implementing analytical models and simulation"
    DTDFVocab:enables SimulationService
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for system simulation using MathWorks Simulink and general-purpose languages"
    DTDFVocab:provides SimulationInsight
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight into system behavior derived from simulation results"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with industry standards including SysML for systems engineering modeling, ACME, AADL, and MontiArc for architecture description languages, ensuring structured representation of components, interfaces, and behaviors, and interoperability across heterogeneous modeling tools and stakeholder perspectives."
]