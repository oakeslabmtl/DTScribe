// C3: Physical sensing components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted directly on the motor shaft providing high-precision positional feedback for the MABI MAX 100's first vertical axis"
    DTDFVocab:producedData MotorShaftPositionData
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearbox providing redundant high-precision positional feedback for the MABI MAX 100's first vertical axis"
    DTDFVocab:producedData GearboxPositionData
]

// C4: Physical-to-virtual interaction
instance MotorShaftPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
    base:desc "High-precision positional data streamed from motor shaft encoder via MQTT protocol"
]

instance GearboxPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
    base:desc "High-precision positional data streamed from gearbox encoder via MQTT protocol"
]

// C10: Models/Data
instance MABIMax100MechanicalModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) representing the six-axis serial robot's mechanical architecture with focus on first vertical axis"
    DTDFVocab:inputTo SysMLModelingEnabler, MontiArcIntegrationEnabler
]

instance FrictionBehaviorModel : DTDFVocab:Model [
    base:desc "Physics-based model capturing friction characteristics in robotic motion for the MABI MAX 100's first vertical axis"
    DTDFVocab:inputTo SimulinkSimulationEnabler, MathWorksIntegrationEnabler
]

instance PositionalDataTrace : DTDFVocab:Data [
    base:desc "Aggregated time-series positional data from both encoders representing the physical system's state"
    DTDFVocab:fromData MotorShaftPositionData, GearboxPositionData
    DTDFVocab:inputTo DataAggregationEnabler, ContextualAnalysisEnabler
]

instance FrictionContextualData : DTDFVocab:Data [
    base:desc "Abstracted friction-related metrics derived from positional data traces for analytical purposes"
    DTDFVocab:fromData PositionalDataTrace
    DTDFVocab:inputTo PerformanceAnalysisEnabler, FailurePredictionEnabler
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 implementation for multi-layered abstraction modeling including requirements, functional architecture, and logical architecture"
    DTDFVocab:enables MechanicalModelingService
]

instance MontiArcIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc framework for component-connector based system decomposition and behavioral modeling"
    DTDFVocab:enables BehavioralModelingService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink integration for detailed dynamic behavior simulation of the robotic system"
    DTDFVocab:enables PhysicsSimulationService
]

instance MathWorksIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "General-purpose programming interface between Simulink models and C++/Java implementation"
    DTDFVocab:enables ModelExecutionService
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "MQTT-based data ingestion pipeline for real-time positional data aggregation from physical system"
    DTDFVocab:enables RealTimeMonitoringService
]

instance ContextualAnalysisEnabler : DTDFVocab:Enabler [
    base:desc "Multi-perspective modeling framework (RFLP/OOSEM) for contextual data abstraction"
    DTDFVocab:enables ContextualDataService
]

instance PerformanceAnalysisEnabler : DTDFVocab:Enabler [
    base:desc "Analytical framework for performance optimization using aggregated friction data"
    DTDFVocab:enables OptimizationService
]

instance FailurePredictionEnabler : DTDFVocab:Enabler [
    base:desc "Predictive analytics framework for failure mode identification in robotic motion systems"
    DTDFVocab:enables FailureDetectionService
]

// C6: Services
instance MechanicalModelingService : DTDFVocab:Service [
    base:desc "Service providing structural representation of the MABI MAX 100's mechanical components and their interconnections"
    DTDFVocab:provides MechanicalArchitectureInsight
]

instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Service implementing state machines and automata for dynamic behavior representation"
    DTDFVocab:provides DynamicBehaviorInsight
]

instance PhysicsSimulationService : DTDFVocab:Service [
    base:desc "Service executing physics-based simulations of the robotic system's motion characteristics"
    DTDFVocab:provides SimulationResultsInsight
]

instance ModelExecutionService : DTDFVocab:Service [
    base:desc "Service executing Simulink models and interfacing with C++/Java implementation"
    DTDFVocab:provides ModelExecutionInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service maintaining continuous monitoring of the physical system's operational state"
    DTDFVocab:provides SystemStateInsight
]

instance ContextualDataService : DTDFVocab:Service [
    base:desc "Service aggregating and abstracting contextual data traces from physical measurements"
    DTDFVocab:provides ContextualDataInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service analyzing friction data to identify performance optimization opportunities"
    DTDFVocab:provides OptimizationRecommendationAction
]

instance FailureDetectionService : DTDFVocab:Service [
    base:desc "Service monitoring system behavior for early failure detection patterns"
    DTDFVocab:provides FailureWarningInsight
]

// C17: Insights/Actions
instance MechanicalArchitectureInsight : DTDFVocab:Insight [
    base:desc "Structural representation of the MABI MAX 100's mechanical components and their spatial relationships"
]

instance DynamicBehaviorInsight : DTDFVocab:Insight [
    base:desc "Behavioral patterns captured through state machines representing the robotic system's operational states"
]

instance SimulationResultsInsight : DTDFVocab:Insight [
    base:desc "Physics simulation results showing predicted motion characteristics under various conditions"
]

instance ModelExecutionInsight : DTDFVocab:Insight [
    base:desc "Execution results of Simulink models interfaced with C++/Java implementation"
]

instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Real-time operational state of the physical robotic system including positional data"
]

instance ContextualDataInsight : DTDFVocab:Insight [
    base:desc "Abstracted contextual data traces representing friction behavior in the robotic motion system"
]

instance OptimizationRecommendationAction : DTDFVocab:Action [
    base:desc "Automated recommendations for performance optimization based on friction analysis"
    DTDFVocab:IsAutomatic true
]

instance FailureWarningInsight : DTDFVocab:Insight [
    base:desc "Identified failure patterns and potential system degradation indicators from operational data"
]

// C1: System under study
instance MABIMax100FirstVerticalAxis : DTDFVocab:Component [
    base:desc "First vertical axis of the six-axis serial robot MABI MAX 100 used for friction analysis in industrial automation"
]

instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:desc "Industrial manufacturing environment where the MABI MAX 100 operates"
    base:contains MABIMax100FirstVerticalAxis
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system emphasizes **model fidelity** through structured **MBSE methodologies**, ensuring alignment between abstract representations (e.g., SysML models) and physical implementations. **Validation and verification** are implicitly supported by the integration of **simulation tools (e.g., Simulink)** and **state machines (SysML v1.7)**, which allow for behavioral validation against expected system dynamics. However, explicit details on **uncertainty quantification, error detection/correction mechanisms, or formal quality assurance processes** are not provided in the document. The focus remains on **data-driven model creation** and **comparative analysis** between digital and physical states, rather than systematic fidelity metrics or validation protocols."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with external systems through standardized protocols such as **Asset Administration Shells (AAS)** and **MQTT** for data streaming. The document references these as part of the broader digital shadow reference model, where data exchange between physical objects and their digital representations is facilitated. However, no detailed specifications on interoperability standards, data exchange protocols beyond MQTT, or integration patterns with other Digital Twins or enterprise systems are provided."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system for the MABI MAX 100 serial robot incorporates **physical safety constraints** enforced by a **safety cell** limiting the operational range of the first vertical axis to **[-90°, 90°]** and the maximum achievable speed to **|q̇_max| = 75°/s**. **Sensor redundancy** is implemented via **two position encoders per drive**: a **motor encoder** mounted directly on the permanent magnet synchronous motor and a **secondary encoder** positioned behind the gearbox. This dual-encoder arrangement enables **backlash compensation** and **positional uncertainty reduction** by analyzing the differential signal between encoders to infer **elasticity and friction dynamics** in the drive train. The system leverages **Siemens SINUMERIK 840D sl CNC controller**, which supports **safety-critical control inputs** (position, speed, acceleration) and **output validation** (target/actual position, derivatives, and motor current). The **gear transmission and cycloidal gear** combination ensures torque conversion from **τ_M (motor torque)** to **τ_out (output torque)**, with the **safety cell** acting as a **hardware-based fail-safe mechanism** to prevent exceeding operational limits. No explicit cybersecurity protocols, access control, or risk assessment methodologies are documented."
]