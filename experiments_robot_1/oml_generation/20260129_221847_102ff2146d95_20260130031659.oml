// Sensing component capturing real‑time temperature measurements
instance RealTimeTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Real‑time temperature sensor feeding data for the Digital Twin analysis"
    DTDFVocab:producedData TemperatureSensorDataTransmitted
]

// Data transmitted by the temperature sensor
instance TemperatureSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RealTimeTemperatureSensor
]

// Data stored from the temperature sensor, to be used in analytics
instance TemperatureSensorData : DTDFVocab:Data [
    base:desc "Temperature measurement data stored in the SQL database"
    DTDFVocab:inputTo SQLDatabaseRepository
    DTDFVocab:fromData TemperatureSensorDataTransmitted
]

// Enabler for storing sensor data
instance SQLDatabaseRepository : DTDFVocab:Enabler [
    base:desc "SQL‑based repository for persisting real‑time sensor data"
    DTDFVocab:enables TemperatureDataAnalyticsService
]

// Service providing analytics on temperature data
instance TemperatureDataAnalyticsService : DTDFVocab:Service [
    base:desc "Analytics service that detects temperature anomalies and triggers actions"
    DTDFVocab:provides TemperatureAnomalyInsight, ActivateCoolingAction
]

// Insight derived from temperature analytics
instance TemperatureAnomalyInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature anomalies based on Kalman filter analysis of sensor data"
]

// Action to mitigate temperature anomalies
instance ActivateCoolingAction : DTDFVocab:Action [
    base:desc "Activate cooling system when a temperature anomaly is detected"
    DTDFVocab:IsAutomatic false
]

// Models used in the Multi‑layered MBSE approach

instance SysMLDesignModel : DTDFVocab:Model [
    base:desc "SysML v1.7 structural model capturing component relationships using component‑connector diagrams"
    DTDFVocab:inputTo SBEModellingTool
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton behavioral model describing state‑machine based control logic"
    DTDFVocab:inputTo SBEModellingTool
]

instance SimulinkBehaviouralModel : DTDFVocab:Model [
    base:desc "Simulink model for dynamic simulation of the physical system"
    DTDFVocab:inputTo SimulationEnvironmentEnabler
]

instance RFLPPartitioningModel : DTDFVocab:Model [
    base:desc "RFLP methodology model partitioning logical, functional, and product layers"
    DTDFVocab:inputTo SBEModellingTool
]

// Enablers for various engineering tools and platforms

instance SBEModellingTool : DTDFVocab:Enabler [
    base:desc "MBSE toolchain supporting SysML, ACME, AADL, and MontiArc modelling"
    DTDFVocab:enables SBEServices
]

instance SimulationEnvironmentEnabler : DTDFVocab:Enabler [
    base:desc "Simulation environment enabling execution of Simulink models"
    DTDFVocab:enables SimulationOrchestrationService
]

instance CodeGenerationTool : DTDFVocab:Enabler [
    base:desc "Toolchain generating executable C++ or Java code from MBSE models"
    DTDFVocab:enables CodeGenerationService
]

instance SoftwarePlatform : DTDFVocab:Enabler [
    base:desc "Runtime platform hosting the Digital Twin and deployed components"
    DTDFVocab:enables DeploymentService
]

// Services corresponding to each enabler

instance SBEServices : DTDFVocab:Service [
    base:desc "MBSE services providing model refinement and validation capabilities"
    DTDFVocab:provides ModelRefinementInsight
]

instance SimulationOrchestrationService : DTDFVocab:Service [
    base:desc "Service orchestrating simulation executions within the Simulink environment"
    DTDFVocab:provides SimulationResultInsight
]

instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Service that generates C++ or Java code from MBSE artefacts"
    DTDFVocab:provides CodeGenerationInsight
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Service deploying generated code onto target hardware via the Software Platform"
    DTDFVocab:provides DeploymentInsight, DeployCodeAction
]

// Insights and actions provided by higher‑level services

instance ModelRefinementInsight : DTDFVocab:Insight [
    base:desc "Insight into the status of model refinement within the MBSE process"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight into the outcomes of Simulink simulations"
]

instance CodeGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight into the success of the code generation pipeline"
]

instance DeploymentInsight : DTDFVocab:Insight [
    base:desc "Insight into the deployment status of the generated software"
]

instance DeployCodeAction : DTDFVocab:Action [
    base:desc "Action to deploy the generated executable onto the target platform"
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the typical MBSE multi‑layered abstraction hierarchy. Development begins with a Requirements layer that captures functional and performance constraints. Progressing to a Functional Architecture layer, SysML Interfaces and Block Definition Diagrams (BDDs) describe the component and connector structure, as well as the deterministic behavior via SysML state machines. A Logical Architecture layer refines the behavior into executable models, often represented by MontiArc Automata or Simulink block‑diagram models, providing a bridge between specification and implementation. The Product/Technical Architecture layer contains the physical system description and hardware‑software mapping, for instance using AADL component specifications or AADL architecture. Transitions between layers are managed through transformation rules that preserve semantics and map SysML diagrams to ADLs, allowing traceability and re‑use. Lifecycle governance is addressed implicitly by the heterogeneous stakeholder integration requirement, requiring version control, model‑library management and architecture reviews at each abstraction transition."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin implementation follows OMG standards such as SysML v1.7 for functional and logical architecture modelling, UML for class diagrams, and the Architecture Analysis and Design Language (AADL) for component‑level specification. These standards provide interoperability and traceability across the development life‑cycle."
]