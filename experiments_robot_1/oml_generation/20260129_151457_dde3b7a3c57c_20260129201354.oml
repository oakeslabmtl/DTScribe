// C2: Acting Components
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "The motor receives the current I_M and generates torque τ_M for the first axis of the MABI MAX 100 robot."
]

instance GearTransmissionActuator : DTDFVocab:ActingComponent [
    base:desc "The gear transmission (gearwheel) transforms motor torque and speed in the robot's first axis."
]

instance CycloidalGearboxActuator : DTDFVocab:ActingComponent [
    base:desc "The cycloidal gearbox delivers the final output torque τ_out to the robot axis."
]

// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring the current I_M on the PT."
    DTDFVocab:producedData MotorCurrentTransmitted
]

instance MotorSideEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor side providing angle r_M."
    DTDFVocab:producedData MotorSideEncoderTransmitted
]

instance GearboxSideEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the gearbox providing angle r_G."
    DTDFVocab:producedData GearboxSideEncoderTransmitted
]

instance CNCControllerSensor : DTDFVocab:SensingComponent [
    base:desc "CNC controller (Siemens SINUMERIK 840D) publishing measured position, speed and acceleration values."
    DTDFVocab:producedData CNCControllerTransmitted
]

// C4: Physical-to-virtual interaction
instance MotorCurrentTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorSideEncoderTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSideEncoderSensor
]

instance GearboxSideEncoderTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxSideEncoderSensor
]

instance CNCControllerTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CNCControllerSensor
]

// C10: Data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Live trace of motor current I_M streamed via MQTT."
    DTDFVocab:fromData MotorCurrentTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkEngineEnabler
]

instance MotorSideAngleData : DTDFVocab:Data [
    base:desc "Live trace of motor‑side encoder angle r_M."
    DTDFVocab:fromData MotorSideEncoderTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkEngineEnabler
]

instance GearboxSideAngleData : DTDFVocab:Data [
    base:desc "Live trace of gearbox‑side encoder angle r_G."
    DTDFVocab:fromData GearboxSideEncoderTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkEngineEnabler
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Derived output angle r_out obtained from CNC controller data."
    DTDFVocab:fromData CNCControllerTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkEngineEnabler
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque trace τ calculated from motor current and model."
    DTDFVocab:fromData CNCControllerTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkEngineEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω from angle traces."
    DTDFVocab:fromData CNCControllerTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkEngineEnabler
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration from velocity trace."
    DTDFVocab:fromData CNCControllerTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkEngineEnabler
]

// C11: Enablers (tooling and enablers)
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker used for live one‑way data streaming from PT to the digital shadow."
    DTDFVocab:enables RealTimeVisualizationService, FrictionParameterIdentificationService, ModelBasedControlImprovementService
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML tooling (Block Definition Diagram and Internal Block Diagram) for structural and behavioural modeling of the robot axis."
    DTDFVocab:enables RealTimeVisualizationService
]

instance SimulinkEngineEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment running motor, gearwheel, gearbox and friction simulation models."
    DTDFVocab:enables FrictionParameterIdentificationService, ModelBasedControlImprovementService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shells (AAS) providing model integration and standardized interface for the digital shadow."
    DTDFVocab:enables RealTimeVisualizationService
]

instance VisualizationDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Custom visualization dashboard delivering real‑time visualization of identified friction parameters and system states."
    DTDFVocab:enables RealTimeVisualizationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides continuous real‑time visualization of sensor traces, identified friction parameters and deviation alerts."
    DTDFVocab:provides FrictionParameterInsight, DeviationInsight
]

instance FrictionParameterIdentificationService : DTDFVocab:Service [
    base:desc "Continuously identifies static, kinetic and viscous friction parameters using white‑box and black‑box Simulink models."
    DTDFVocab:provides FrictionParameterInsight, AdjustControlGainsAction
]

instance ModelBasedControlImprovementService : DTDFVocab:Service [
    base:desc "Supports model‑based adjustment of controller gains to improve motion accuracy based on identified friction parameters."
    DTDFVocab:provides AdjustControlGainsAction, TriggerMaintenanceAction
]

// C17: Insights
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Identified friction parameters (static, kinetic, viscous) that can be fed back to the robot controller."
]

instance DeviationInsight : DTDFVocab:Insight [
    base:desc "Detected deviations between simulated and measured behavior indicating potential maintenance needs."
]

// C17: Actions
instance AdjustControlGainsAction : DTDFVocab:Action [
    base:desc "Automatic feedback of friction parameters to the robot controller to adjust control gains."
    DTDFVocab:IsAutomatic true
]

instance TriggerMaintenanceAction : DTDFVocab:Action [
    base:desc "Notification to maintenance personnel when significant deviations are observed."
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "SysML Block Definition and Internal Block Diagram representing motor, gearbox and connections."
    DTDFVocab:inputTo SysMLEnabler
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the permanent‑magnet synchronous motor."
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance SimulinkGearwheelModel : DTDFVocab:Model [
    base:desc "Simulink model of the gear transmission (gearwheel)."
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "Simulink model of the cycloidal gearbox."
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance SimulinkFrictionModel : DTDFVocab:Model [
    base:desc "Simulink friction models (Coulomb‑Viscous, Stribeck, Dahl, LuGre) used for parameter identification."
    DTDFVocab:inputTo SimulinkEngineEnabler
]

// C5: Component and Environment
instance FirstAxisComponent : DTDFVocab:Component [
    base:desc "First (vertical) axis of the MABI MAX 100 six‑axis industrial robot, containing motor, gear transmission, cycloidal gearbox, and two position encoders."
]

instance RobotEnvironment : DTDFVocab:Environment [
    base:contains MotorActuator, GearTransmissionActuator, CycloidalGearboxActuator, MotorCurrentSensor, MotorSideEncoderSensor, GearboxSideEncoderSensor, CNCControllerSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is a passive entity; no data or control commands are sent back to the robot. Interaction is strictly one‑way from PT to virtual model."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization with live sensor data; data are processed online as they are received, enabling on‑line friction identification during robot operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow follows the Digital Shadow Reference Model: a Purpose (FrictionDerivation) is linked to an Asset (Mabi robot), multiple DataTraces (measured and simulated), Processing components (Simulation_M, Simulation_GW, Simulation_GB) that consume input traces and produce simulated outputs, and a dashboard that visualizes the results."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow is created and operated in the runtime/maintenance phase of the robot to monitor and improve its behavior during actual machining tasks."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Both white‑box (analytical) and black‑box (data‑driven) friction models are continuously identified to capture wear and temperature effects. All data points are traceable to their origin and processing component, ensuring fine‑grained traceability and validation of model predictions against measured data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow using MQTT; the Asset Administration Shell (AAS) is used to expose model metadata."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation uses the Industry 4.0 Asset Administration Shell (AAS) standard and follows SysML modeling conventions, providing a standardized representation of the asset and its data."
]