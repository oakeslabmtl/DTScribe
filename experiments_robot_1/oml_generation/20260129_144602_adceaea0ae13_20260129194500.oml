// C3: Physical sensing component
instance PhysicalAssetTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Automated one‑way telemetry sensor capturing status and contextual data from the physical asset, transmitted via MQTT."
    DTDFVocab:producedData MQTTTelemetryStream
]

// C4: Physical-to-virtual interaction (data transmission)
instance MQTTTelemetryStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalAssetTelemetrySensor
]

// C5: Data produced from transmission
instance ProcessedSensorData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces collected from the digital‑shadow feed."
    DTDFVocab:fromData MQTTTelemetryStream
    DTDFVocab:inputTo ModelRepositoryEnabler, SimulationEngineEnabler
]

// C11: Enablers
instance ThingsBoardPlatform : DTDFVocab:Enabler [
    base:desc "ThingsBoard platform used to collect, aggregate, and store contextual data traces from MQTT streams."
    DTDFVocab:enables DigitalShadowIngestionService
]

instance ModelRepositoryEnabler : DTDFVocab:Enabler [
    base:desc "Repository service managing SysML, ADL, and code models and their transformations."
    DTDFVocab:enables ModelManagementService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulink engine executing physics‑based simulation models."
    DTDFVocab:enables SimulationExecutionService
]

// C6: Services
instance DigitalShadowIngestionService : DTDFVocab:Service [
    base:desc "Service ingesting MQTT telemetry into the digital shadow representation."
    DTDFVocab:provides AssetStateMonitoringInsight
]

instance ModelManagementService : DTDFVocab:Service [
    base:desc "Service ensuring consistency and traceability of heterogeneous models (SysML, ADL, executable code)."
    DTDFVocab:provides ModelConsistencyInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service running Simulink and MontiArc automaton simulations based on model inputs."
    DTDFVocab:provides SimulationResultInsight
]

// C17: Insights
instance AssetStateMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight into real‑time asset state derived from aggregated contextual telemetry."
]

instance ModelConsistencyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating consistency of model transformations across SysML, ADL, and executable code."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight delivering simulation outcomes for physics‑based and black‑box models."
]

// C10: Models/Data
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagram representing system structure."
    DTDFVocab:inputTo ModelRepositoryEnabler
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL model describing components, interfaces, and connectors of the system architecture."
    DTDFVocab:inputTo ModelRepositoryEnabler
]

instance SimulinkPhysicsModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink simulation model implementing physics‑based behavior of the system."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance MontiArcAutomatonBehaviorModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model capturing state‑machine behavior for component interactions."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance MachineLearningBlackBoxModel : DTDFVocab:Model [
    base:desc "Black‑box machine‑learning model (e.g., exported Java code) providing data‑driven predictions."
    DTDFVocab:inputTo ModelRepositoryEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "According to the digital‑shadow definition, the shadow is a passive entity that does not operate autonomously nor push data back to the physical system, implying that no virtual‑to‑physical control flow, command formats, validation, authentication, or execution confirmation mechanisms are specified in the provided documents."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by combining white‑box physics‑based Simulink simulations (high interpretability) with data‑driven machine‑learning models (capturing non‑linear effects). Validation and verification are performed through traceability of model transformations, e.g., from SysML specifications to executable simulation models. Uncertainty sources such as model‑parameter errors and sensor data noise are mitigated by systematic verification of transformation correctness and by applying scalable identification methods that avoid dedicated measurement setups. Quality assurance includes explicit traceability links, verification of model consistency, and verification of data processing pipelines, ensuring that the digital shadow’s aggregated data maintain correctness before being used by the Digital Twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The references cite MQTT (Mosquitto) as the communication protocol used for data transmission and ThingsBoard as an IoT platform that can be deployed on cloud or edge infrastructures. The documents do not provide details on network topology, bandwidth, latency, reliability, redundancy, or additional security protocols beyond the implied use of MQTT."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The cited works mention cloud‑based technologies for deploying a CNC‑machine digital shadow (e.g., using ThingsBoard) and generally refer to cloud or edge hosting for digital shadows. Specific computational and storage requirements, scalability mechanisms, deployment models, or availability assurances are not detailed in the provided documents."
]