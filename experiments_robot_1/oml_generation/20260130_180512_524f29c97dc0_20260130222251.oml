instance MABIMAX100System : DTDFVocab:Environment [
    base:desc "Physical system consisting of MABI MAX 100 serial robot with six axes"
    base:contains MABIMAX100Motor, MABIMAX100Gearbox, SiemensSINUMERIK840DController
]

instance MABIMAX100Motor : DTDFVocab:Component [
    base:desc "Motor component of MABI MAX 100 robot"
]

instance MABIMAX100Gearbox : DTDFVocab:Component [
    base:desc "Gearbox component of MABI MAX 100 robot"
]

instance SiemensSINUMERIK840DController : DTDFVocab:Component [
    base:desc "Siemens SINUMERIK 840D sl controller for MABI MAX 100 robot"
]

instance MotorPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor in MABI MAX 100 motor components"
    DTDFVocab:producedData MotorPositionData
]

instance MotorSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Speed sensor in MABI MAX 100 motor components"
    DTDFVocab:producedData MotorSpeedData
]

instance GearboxTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor in MABI MAX 100 gearbox components"
    DTDFVocab:producedData GearboxTemperatureData
]

instance ControllerStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Status sensor in Siemens SINUMERIK 840D sl controller"
    DTDFVocab:producedData ControllerStatusData
]

instance MotorPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionSensor
]

instance MotorSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSpeedSensor
]

instance GearboxTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxTemperatureSensor
]

instance ControllerStatusData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ControllerStatusSensor
]

instance MotorPositionRawData : DTDFVocab:Data [
    base:desc "Raw position data from MABI MAX 100 motor sensors"
    DTDFVocab:fromData MotorPositionData
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler
]

instance MotorSpeedRawData : DTDFVocab:Data [
    base:desc "Raw speed data from MABI MAX 100 motor sensors"
    DTDFVocab:fromData MotorSpeedData
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler
]

instance GearboxTemperatureRawData : DTDFVocab:Data [
    base:desc "Raw temperature data from MABI MAX 100 gearbox components"
    DTDFVocab:fromData GearboxTemperatureData
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler
]

instance ControllerStatusRawData : DTDFVocab:Data [
    base:desc "Raw status data from Siemens SINUMERIK 840D sl controller"
    DTDFVocab:fromData ControllerStatusData
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler
]

instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML model for requirements abstraction layer"
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML model for functional architecture layer"
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLLogicalModel : DTDFVocab:Model [
    base:desc "SysML model for logical architecture layer"
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLProductModel : DTDFVocab:Model [
    base:desc "SysML model for product/technical layer"
    DTDFVocab:inputTo SysMLEnabler
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME architecture description language for component-based structural modeling"
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL architecture description language for component-based structural modeling"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description language for component-based structural modeling"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams for component-based structural modeling"
    DTDFVocab:inputTo SysMLEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavioral modeling"
    DTDFVocab:inputTo SysMLEnabler
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink for dynamic simulations"
    DTDFVocab:inputTo SimulinkEnabler
]

instance CppSimulationModel : DTDFVocab:Model [
    base:desc "C++ for dynamic simulations"
    DTDFVocab:inputTo CppEnabler
]

instance JavaSimulationModel : DTDFVocab:Model [
    base:desc "Java for dynamic simulations"
    DTDFVocab:inputTo JavaEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML tool for system modeling across abstraction levels"
    DTDFVocab:enables SysMLModelingService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME tool for architecture description languages"
    DTDFVocab:enables ACMEModelingService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL tool for architecture description languages"
    DTDFVocab:enables AADLModelingService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc tool for architecture description languages"
    DTDFVocab:enables MontiArcModelingService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for behavior modeling and dynamic simulations"
    DTDFVocab:enables SimulationService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for behavior modeling"
    DTDFVocab:enables SimulationService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for behavior modeling"
    DTDFVocab:enables SimulationService
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP methodology for handling system complexity across abstraction layers"
    DTDFVocab:enables ProcessManagementService
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for handling system complexity across abstraction layers"
    DTDFVocab:enables ProcessManagementService
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for handling system complexity across abstraction layers"
    DTDFVocab:enables ProcessManagementService
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for handling system complexity across abstraction layers"
    DTDFVocab:enables ProcessManagementService
]

instance SysMLModelingService : DTDFVocab:Service [
    base:desc "Service for modeling system requirements, functional, logical, and product layers using SysML"
    DTDFVocab:provides RequirementsModelingInsight, FunctionalModelingInsight, LogicalModelingInsight, ProductModelingInsight
]

instance ACMEModelingService : DTDFVocab:Service [
    base:desc "Service for component-based structural modeling using ACME"
    DTDFVocab:provides ACMEModelingInsight
]

instance AADLModelingService : DTDFVocab:Service [
    base:desc "Service for component-based structural modeling using AADL"
    DTDFVocab:provides AADLModelingInsight
]

instance MontiArcModelingService : DTDFVocab:Service [
    base:desc "Service for component-based structural modeling using MontiArc"
    DTDFVocab:provides MontiArcModelingInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for dynamic simulation using Simulink, C++, or Java"
    DTDFVocab:provides SimulationInsight
]

instance ProcessManagementService : DTDFVocab:Service [
    base:desc "Service for managing evolution and version control of models across heterogeneous tools and stakeholder perspectives"
    DTDFVocab:provides ModelVersioningInsight, ProcessOptimizationInsight
]

instance RequirementsModelingInsight : DTDFVocab:Insight [
    base:desc "Insight into requirements modeling using SysML"
]

instance FunctionalModelingInsight : DTDFVocab:Insight [
    base:desc "Insight into functional architecture modeling using SysML"
]

instance LogicalModelingInsight : DTDFVocab:Insight [
    base:desc "Insight into logical architecture modeling using SysML"
]

instance ProductModelingInsight : DTDFVocab:Insight [
    base:desc "Insight into product/technical layer modeling using SysML"
]

instance ACMEModelingInsight : DTDFVocab:Insight [
    base:desc "Insight into component-based structural modeling using ACME"
]

instance AADLModelingInsight : DTDFVocab:Insight [
    base:desc "Insight into component-based structural modeling using AADL"
]

instance MontiArcModelingInsight : DTDFVocab:Insight [
    base:desc "Insight into component-based structural modeling using MontiArc"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from dynamic simulations using Simulink, C++, or Java"
]

instance ModelVersioningInsight : DTDFVocab:Insight [
    base:desc "Insight into model version control for digital twin evolution"
]

instance ProcessOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight into optimizing engineering processes using methodologies like RFLP, OOSEM, SPES, SMArDT"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system utilizes real-time, data-driven representations of robot joint behavior through live-data linking to maintain continuous synchronization between physical and digital components."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle stages encompass the development phase where modeling is structured across multiple abstraction levels including requirements, functional architecture, logical architecture, and product/technical layers. Methodologies such as RFLP (Requirements, Functions, Logics, Physics), OOSEM, SPES, and SMArDT are employed to manage complexity and transition between these abstraction layers during system development."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The system implements Asset Administration Shells (AAS) and streams data via MQTT protocol for integration with external systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system incorporates industry standards such as SysML for system modeling, AADL and ACME for architecture description, MontiArc for component-based modeling with behavior specification via Automaton or state machines, and utilizes MathWorks Simulink for simulation. Methodologies including RFLP, OOSEM, SPES, and SMArDT are applied to manage system complexity across abstraction levels (requirements, functional, logical, and product/technical layers), ensuring compliance with MBSE practices and interoperability."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Data is streamed via MQTT protocol, and a physical safety cell is implemented to restrict the working range of the robotic system."
]