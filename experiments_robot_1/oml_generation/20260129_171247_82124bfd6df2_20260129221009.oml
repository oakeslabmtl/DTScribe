instance SysMLModel : DTDFVocab:Model [
    base:desc "SysML for multi-level abstraction (requirements, functional architecture, logical architecture, product/technical layer)"
    DTDFVocab:inputTo MBSEEnabler
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language for component structures, interfaces, and compositions"
    DTDFVocab:inputTo MBSEEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL Architecture Description Language for component structures, interfaces, and compositions"
    DTDFVocab:inputTo MBSEEnabler
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc Architecture Description Language for component structures, interfaces, and compositions"
    DTDFVocab:inputTo MBSEEnabler
]

instance SysMLIBDsModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams (IBDs) for component structures and interconnections"
    DTDFVocab:inputTo MBSEEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MBSEEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines for behavior modeling"
    DTDFVocab:inputTo MBSEEnabler
]

instance MathWorksSimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink for analytical modeling and simulation"
    DTDFVocab:inputTo MathWorksSimulinkEnabler
]

instance CppCodeModel : DTDFVocab:Model [
    base:desc "C++ general-purpose programming code for simulation and analysis"
    DTDFVocab:inputTo CppIntegrationEnabler
]

instance JavaCodeModel : DTDFVocab:Model [
    base:desc "Java general-purpose programming code for simulation and analysis"
    DTDFVocab:inputTo JavaIntegrationEnabler
]

instance RequirementsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLModel
]

instance FunctionalArchitectureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLModel
]

instance LogicalArchitectureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLModel
]

instance ProductTechnicalLayerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLModel
]

instance RequirementsData : DTDFVocab:Data [
    base:desc "Requirements data aggregated from stakeholder perspectives"
    DTDFVocab:fromData RequirementsDataTransmitted
    DTDFVocab:inputTo RFLPMethodology, OOSEMMethodology, SPESMethodology, SMArDTMethodology
]

instance FunctionalArchitectureData : DTDFVocab:Data [
    base:desc "Functional architecture data aggregated from stakeholder perspectives"
    DTDFVocab:fromData FunctionalArchitectureDataTransmitted
    DTDFVocab:inputTo RFLPMethodology, OOSEMMethodology, SPESMethodology, SMArDTMethodology
]

instance LogicalArchitectureData : DTDFVocab:Data [
    base:desc "Logical architecture data aggregated from stakeholder perspectives"
    DTDFVocab:fromData LogicalArchitectureDataTransmitted
    DTDFVocab:inputTo RFLPMethodology, OOSEMMethodology, SPESMethodology, SMArDTMethodology
]

instance ProductTechnicalLayerData : DTDFVocab:Data [
    base:desc "Product/technical layer data aggregated from stakeholder perspectives"
    DTDFVocab:fromData ProductTechnicalLayerDataTransmitted
    DTDFVocab:inputTo RFLPMethodology, OOSEMMethodology, SPESMethodology, SMArDTMethodology
]

instance MBSEEnabler : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering (MBSE) methodology for systems modeling across abstraction levels (requirements, functional, logical, product/technical layers)"
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP methodology for complexity management in system design"
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for object-oriented systems engineering"
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for system engineering processes"
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for model-based system design"
]

instance MathWorksSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "Integration with MathWorks Simulink simulation tools"
]

instance OtherSimulationMethodsEnabler : DTDFVocab:Enabler [
    base:desc "Integration with other simulation methods"
]

instance CppIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Integration of C++ general-purpose programming languages"
]

instance JavaIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Integration of Java general-purpose programming languages"
]