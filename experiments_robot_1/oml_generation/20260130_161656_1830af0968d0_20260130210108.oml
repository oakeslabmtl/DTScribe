// C2: Acting Components
instance PermanentMagnetSynchronousMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor that drives the robot axis, commanded by a Siemens SINUMERIK 840D controller."
]

instance SiemensSINUMERIK840DControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D controller providing remote trajectory and force command interfaces, enforcing safety constraints and actuation limits."
]

// C3: Physical sensing components
instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder delivering high‑resolution angle measurements."
    DTDFVocab:producedData MotorEncoderAngleDataTransmitted
]

instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder delivering high‑resolution angle measurements."
    DTDFVocab:producedData SecondaryEncoderAngleDataTransmitted
]

// C4: Physical-to-virtual interaction – Data transmitted
instance MotorEncoderAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder
]

instance SecondaryEncoderAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoder
]

// C5: Data derived from transmitted sensor data
instance MotorEncoderAngleData : DTDFVocab:Data [
    base:desc "Time‑series angle data from the motor‑mounted encoder."
    DTDFVocab:fromData MotorEncoderAngleDataTransmitted
    DTDFVocab:inputTo EnablerDataRepository
]

instance SecondaryEncoderAngleData : DTDFVocab:Data [
    base:desc "Time‑series angle data from the secondary encoder."
    DTDFVocab:fromData SecondaryEncoderAngleDataTransmitted
    DTDFVocab:inputTo EnablerDataRepository
]

// C11: Enablers (modeling, simulation, repository, code generation)
instance EnablerSysML : DTDFVocab:Enabler [
    base:desc "SysML modeling environment (including IBDs and state machines) used to capture requirements, functions, and logical structures."
    DTDFVocab:enables TrajectoryControlService, ForceCommandService, SafetyConstraintService, PrecisePositioningService
]

instance EnablerSimulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for white‑box physics‑based dynamic simulation of the axis."
    DTDFVocab:enables TrajectoryControlService, PrecisePositioningService
]

instance EnablerACME : DTDFVocab:Enabler [
    base:desc "ACME architecture description language for component‑connector definitions."
    DTDFVocab:enables SafetyConstraintService
]

instance EnablerMontiArc : DTDFVocab:Enabler [
    base:desc "MontiArc for component‑connector architecture and automaton behavior specifications."
    DTDFVocab:enables ForceCommandService
]

instance EnablerCPlusPlus : DTDFVocab:Enabler [
    base:desc "C++ code generation from models for real‑time controller deployment."
    DTDFVocab:enables PrecisePositioningService
]

instance EnablerJava : DTDFVocab:Enabler [
    base:desc "Java code generation for higher‑level supervisory services."
    DTDFVocab:enables TrajectoryControlService
]

instance EnablerDataRepository : DTDFVocab:Enabler [
    base:desc "Central data repository aggregating sensor traces and contextual data for the digital twin."
    DTDFVocab:enables TrajectoryControlService, ForceCommandService, SafetyConstraintService, PrecisePositioningService
]

// C6: Services
instance TrajectoryControlService : DTDFVocab:Service [
    base:desc "Service executing trajectory commands on the axis via the SINUMERIK controller."
    DTDFVocab:provides InsightTrajectoryOptimization, ActionExecuteTrajectory
]

instance ForceCommandService : DTDFVocab:Service [
    base:desc "Service issuing force commands and monitoring force execution."
    DTDFVocab:provides InsightForceMonitoring, ActionAdjustForce
]

instance SafetyConstraintService : DTDFVocab:Service [
    base:desc "Service enforcing safety constraints and detecting violations."
    DTDFVocab:provides InsightSafetyViolationDetection, ActionEmergencyStop
]

instance PrecisePositioningService : DTDFVocab:Service [
    base:desc "Service ensuring precise positioning of the axis based on encoder feedback."
    DTDFVocab:provides InsightPositionAccuracy, ActionCalibratePosition
]

// C17: Insights
instance InsightTrajectoryOptimization : DTDFVocab:Insight [
    base:desc "Insight into optimal trajectory planning derived from simulation and sensor data."
]

instance InsightForceMonitoring : DTDFVocab:Insight [
    base:desc "Insight into real‑time force application and deviation from commanded force."
]

instance InsightSafetyViolationDetection : DTDFVocab:Insight [
    base:desc "Insight detecting breaches of configured safety limits."
]

instance InsightPositionAccuracy : DTDFVocab:Insight [
    base:desc "Insight reporting the accuracy of the axis positioning relative to setpoints."
]

// C17: Actions
instance ActionExecuteTrajectory : DTDFVocab:Action [
    base:desc "Automatically send trajectory command to the SINUMERIK controller."
    DTDFVocab:IsAutomatic true
]

instance ActionAdjustForce : DTDFVocab:Action [
    base:desc "Automatically adjust force command based on feedback."
    DTDFVocab:IsAutomatic true
]

instance ActionEmergencyStop : DTDFVocab:Action [
    base:desc "Automatically trigger emergency stop when safety violation is detected."
    DTDFVocab:IsAutomatic true
]

instance ActionCalibratePosition : DTDFVocab:Action [
    base:desc "Manually initiate calibration routine to improve position accuracy."
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance SysMLRequirementModel : DTDFVocab:Model [
    base:desc "SysML model capturing system requirements for the axis."
    DTDFVocab:inputTo EnablerSysML
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML functional model defining functions such as trajectory generation and force control."
    DTDFVocab:inputTo EnablerSysML
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME architecture model describing components, connectors, and interfaces of the twin."
    DTDFVocab:inputTo EnablerACME
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Simulink physics‑based simulation of the axis dynamics and motor behavior."
    DTDFVocab:inputTo EnablerSimulink
]

instance MachineLearningNonlinearModel : DTDFVocab:Model [
    base:desc "Data‑driven machine‑learning model capturing nonlinear effects not covered by physics models."
    DTDFVocab:inputTo EnablerDataRepository
]

// C5: Data artefacts derived from models (optional linking to services)
instance RequirementData : DTDFVocab:Data [
    base:desc "Formalized requirement data extracted from SysMLRequirementModel."
    DTDFVocab:fromData SysMLRequirementModel
    DTDFVocab:inputTo EnablerSysML
]

instance FunctionalData : DTDFVocab:Data [
    base:desc "Functional specification data extracted from SysMLFunctionalModel."
    DTDFVocab:fromData SysMLFunctionalModel
    DTDFVocab:inputTo EnablerSysML
]

instance ArchitectureData : DTDFVocab:Data [
    base:desc "Component‑connector architecture data obtained from ACMEArchitectureModel."
    DTDFVocab:fromData ACMEArchitectureModel
    DTDFVocab:inputTo EnablerACME
]

instance SimulationResultData : DTDFVocab:Data [
    base:desc "Simulation results (position, velocity, torque) from SimulinkDynamicSimulationModel."
    DTDFVocab:fromData SimulinkDynamicSimulationModel
    DTDFVocab:inputTo EnablerSimulink
]

instance MLModelData : DTDFVocab:Data [
    base:desc "Trained machine‑learning model artefact from MachineLearningNonlinearModel."
    DTDFVocab:fromData MachineLearningNonlinearModel
    DTDFVocab:inputTo EnablerDataRepository
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "According to the digital‑shadow reference model, the virtual entity is passive and does not issue commands to the physical system; therefore there is no virtual‑to‑physical interaction. The flow is strictly one‑way from physical to digital, and no control messages, validation, or feedback loops are defined."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The documents describe a MBSE‑driven lifecycle that is split into four abstraction levels: (1) requirements modeling, (2) functional architecture, (3) logical architecture, and (4) product/technical layer. Each level is represented with appropriate engineering models (e.g., SysML requirement diagrams, SysML internal block diagrams, ADL component‑connector diagrams, and implementation artefacts such as Simulink models or source code). Transition between the levels is performed by mapping concrete elements of a higher‑level model to the next‑level model, following the conformance relations defined by the reference model. Governance is implied by the need to keep the different stakeholder views consistent across the abstraction hierarchy."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by mixing physics‑based (white‑box) models (e.g., Simulink) with data‑driven (black‑box) models and by validating the combined Digital Twin against measured data traces to quantify deviation. The documents stress traceability of how data are generated and verification of model transformations (e.g., SysML → simulation models). Uncertainty sources such as model abstraction, sensor noise, and transformation errors are addressed through systematic verification methods and traceability links. Quality assurance relies on model‑based development practices that guarantee correctness of transformations and consistency between the digital shadow and the physical system."
]