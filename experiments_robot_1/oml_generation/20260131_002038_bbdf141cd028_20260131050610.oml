// C3: Physical sensing components
instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Absolute encoder mounted on the motor shaft, provides motor current (IM) and angular position for deriving torque, velocity, and acceleration."
    DTDFVocab:producedData MotorEncoderMQTTData
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Absolute encoder mounted on the gearbox output shaft, provides output angle for motion tracking."
    DTDFVocab:producedData GearboxEncoderMQTTData
]

// C4: Physical-to-virtual interaction (Data transmission)
instance MotorEncoderMQTTData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderMQTTData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// C10: Models/Data (Sensor-derived data)
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Motor current (IM) transmitted via MQTT from the motor encoder."
    DTDFVocab:fromData MotorEncoderMQTTData
]

instance MotorAngleData : DTDFVocab:Data [
    base:desc "Motor angular position transmitted via MQTT from the motor encoder."
    DTDFVocab:fromData MotorEncoderMQTTData
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Output shaft angle transmitted via MQTT from the gearbox encoder."
    DTDFVocab:fromData GearboxEncoderMQTTData
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Derived motor torque computed from motor current and motor encoder angle."
    DTDFVocab:fromData MotorEncoderMQTTData
]

instance DerivedAngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity calculated from motor encoder angle over time."
    DTDFVocab:fromData MotorEncoderMQTTData
]

instance DerivedAccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration calculated from angular velocity over time."
    DTDFVocab:fromData MotorEncoderMQTTData
]

// C10: Models/Data (Simulation models)
instance StructuralModelSysML : DTDFVocab:Model [
    base:desc "Engineering structural model: SysML component/connector diagram of motor and two cycloidal gearboxes."
    DTDFVocab:inputTo CentralProcessingUnit
]

instance DataCalcSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink executable of motor, gearwheel, and gearbox incorporating Coulomb-Viscous, Stribeck, Dahl, and LuGre friction models."
    DTDFVocab:inputTo CentralProcessingUnit
]

// C11: Enabler
instance CentralProcessingUnit : DTDFVocab:Enabler [
    base:desc "Central processing component that aggregates data traces, performs traceability, and feeds data into simulation models."
    DTDFVocab:enables RealTimeVisualizationDashboard, JointFrictionIdentificationService, ContextualDigitalShadowProvisionService
]

// C6: Services
instance RealTimeVisualizationDashboard : DTDFVocab:Service [
    base:desc "Real-time visualization dashboard displaying live sensor data, derived metrics, and simulation outputs."
    DTDFVocab:provides DashboardInsight, OperationalAdjustmentAction, MachiningAccuracyImprovementAction
]

instance JointFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service that continuously identifies joint friction using multi-physics models and live data."
    DTDFVocab:provides FrictionEstimationInsight, ControllerParameterUpdateAction, MotorTorqueAdjustmentAction, MaintenancePlanningAction
]

instance ContextualDigitalShadowProvisionService : DTDFVocab:Service [
    base:desc "Service that provides a contextual digital shadow for improved control accuracy."
    DTDFVocab:provides ContextualDigitalShadowInsight
]

// C17: Insights
instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Dashboard insight presenting live data, derived metrics, and simulation outputs to operators."
]

instance FrictionEstimationInsight : DTDFVocab:Insight [
    base:desc "Friction estimate that informs controller parameter updates and motor torque adjustments."
]

instance ContextualDigitalShadowInsight : DTDFVocab:Insight [
    base:desc "Contextual digital shadow that enhances control accuracy."
]

// C17: Actions
instance OperationalAdjustmentAction : DTDFVocab:Action [
    base:desc "Action enabling operators to adjust operational parameters based on dashboard insights."
    DTDFVocab:IsAutomatic false
]

instance MachiningAccuracyImprovementAction : DTDFVocab:Action [
    base:desc "Action to refine the machining process for improved accuracy using dashboard insights."
    DTDFVocab:IsAutomatic false
]

instance ControllerParameterUpdateAction : DTDFVocab:Action [
    base:desc "Automatic action updating controller parameters based on friction estimates."
    DTDFVocab:IsAutomatic true
]

instance MotorTorqueAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic action adjusting motor torque based on friction estimates."
    DTDFVocab:IsAutomatic true
]

instance MaintenancePlanningAction : DTDFVocab:Action [
    base:desc "Action for scheduling maintenance activities informed by friction estimates."
    DTDFVocab:IsAutomatic false
]

// Environment and components
instance FirstAxisComponent : DTDFVocab:Component [
    base:desc "First rotary axis of the MABI MAX 100 robot, comprising motor and two cycloidal gearboxes."
]

instance FirstAxisEnvironment : DTDFVocab:Environment [
    base:contains FirstAxisComponent, MotorEncoderSensor, GearboxEncoderSensor, StructuralModelSysML, DataCalcSimulinkModel
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous live streaming (every telemetry sample, typically milliseconds–seconds) with real‑time processing; simulation models run in parallel to generate instantaneous reference traces for comparison."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Asset (MABI robot) linked to engineering model via AAS, processing component that executes simulation models, data calculation models, and aggregates data traces into the digital shadow; all components orchestrated to produce a real‑time dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin spans the design (ideal frictionless simulation), manufacturing (parameterised robot model from manufacturer), and operation (runtime data, continuous friction model identification)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of each data point back to its source and computational model; continuous identification of both white‑box and black‑box friction models; validation against live sensor data and derived torque/velocity; uncertainty handled by combining multiple friction models and data‑driven identification."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT broker used to stream sensor data (current, angle) from the robot to the digital shadow; Asset Administration Shells expose semantic interfaces; dashboard communicates via HTTP/HTTPS to the processing component."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The twin follows SysML for modeling, employs Asset Administration Shells (AAS) as a data integration framework, and uses the MQTT protocol for real‑time data transport."
]