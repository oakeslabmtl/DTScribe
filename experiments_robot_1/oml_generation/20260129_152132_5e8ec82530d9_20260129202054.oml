// ------------------------------------------------------------
// 1. Physical Sensing Components
// ------------------------------------------------------------
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Primary position encoder mounted on the permanent‑magnet synchronous motor, provides motor shaft angle."
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the gearwheel and cycloidal gearboxes, provides gearbox output angle."
    DTDFVocab:producedData GearboxPositionDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current transducer measuring motor phase current I_M."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// ------------------------------------------------------------
// 2. Data Transmitted from Sensors (Physical → Virtual)
// ------------------------------------------------------------
instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// ------------------------------------------------------------
// 3. Data Objects (Stored Traces, Calculations)
// ------------------------------------------------------------
instance MotorAngleData : DTDFVocab:Data [
    base:desc "Time series of motor shaft angle derived from MotorPositionEncoder."
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Time series of gearbox output angle derived from GearboxPositionEncoder."
    DTDFVocab:fromData GearboxPositionDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current I_M stream from MotorCurrentSensor."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Calculated motor torque τ using current I_M and motor angle data."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MatlabSimulinkTool
]

instance DerivedAngularVelocityData : DTDFVocab:Data [
    base:desc "Computed angular velocity ω from successive angle measurements."
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo MatlabSimulinkTool
]

instance FrictionParameterData : DTDFVocab:Data [
    base:desc "Identified friction parameters (static, kinetic, viscous) from simulation models."
    DTDFVocab:fromData DerivedTorqueData
    DTDFVocab:inputTo MatlabSimulinkTool
]

// ------------------------------------------------------------
// 4. Engineering & Simulation Models
// ------------------------------------------------------------
instance EngineeringModelMotorGearbox : DTDFVocab:Model [
    base:desc "SysML block and internal block diagrams describing the motor, gearwheel gearbox and cycloidal gearbox."
    DTDFVocab:inputTo SysMLTool
]

instance SimulationModelFrictionless : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the robot axis without friction."
    DTDFVocab:inputTo MatlabSimulinkTool
]

instance SimulationModelCoulombViscous : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model implementing Coulomb‑Viscous friction."
    DTDFVocab:inputTo MatlabSimulinkTool
]

instance SimulationModelStribeck : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model implementing Stribeck friction behavior."
    DTDFVocab:inputTo MatlabSimulinkTool
]

instance SimulationModelLuGre : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model implementing the LuGre friction model."
    DTDFVocab:inputTo MatlabSimulinkTool
]

// ------------------------------------------------------------
// 5. Enablers (Tooling & Infrastructure)
// ------------------------------------------------------------
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML used for structural and behavioral modeling of the robot axis."
    DTDFVocab:enables RealTimeVisualizationDashboard
]

instance MatlabSimulinkTool : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for executable simulation and friction‑parameter identification."
    DTDFVocab:enables RealTimeVisualizationDashboard
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT protocol for live streaming of sensor data to the digital shadow."
    DTDFVocab:enables RealTimeVisualizationDashboard
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "AAS for integrating engineering models and simulation artifacts."
    DTDFVocab:enables RealTimeVisualizationDashboard
]

instance CustomDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Custom visualization dashboard for real‑time monitoring and model update."
    DTDFVocab:enables RealTimeVisualizationDashboard
]

// ------------------------------------------------------------
// 6. Services Offered by the Digital Twin
// ------------------------------------------------------------
instance RealTimeVisualizationDashboard : DTDFVocab:Service [
    base:desc "Dashboard that visualizes live sensor streams, identified friction parameters and updates friction models."
    DTDFVocab:provides FrictionParameterInsight
    DTDFVocab:provides UpdateRobotControllerAction
]

// ------------------------------------------------------------
// 7. Insights and Actions (Decision Support)
// ------------------------------------------------------------
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters are available for improving motion command accuracy."
]

instance UpdateRobotControllerAction : DTDFVocab:Action [
    base:desc "Adjust robot controller motion commands based on identified friction parameters to reduce positioning errors."
    DTDFVocab:IsAutomatic true
]

// ------------------------------------------------------------
// 8. Environment (Physical System Under Study)
// ------------------------------------------------------------
instance FirstAxisMABIMAX100 : DTDFVocab:Environment [
    base:contains MotorPositionEncoder, GearboxPositionEncoder, MotorCurrentSensor
    base:desc "First axis of the MABI MAX 100 six‑axis industrial robot, comprising a permanent‑magnet synchronous motor, a gearwheel gearbox and a cycloidal gearbox."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time continuous acquisition and processing of data during robot operation, enabling on‑line identification of friction model parameters."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestration that links the physical robot (asset) to a digital shadow comprising DataTraces, Processing components executing simulation models, and a dashboard; the shadow is instantiated as the FrictionShadow class with purpose FrictionDerivation, consuming live data and producing simulated outputs."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Combination of white‑box analytical friction models and black‑box data‑driven models; continuous re‑identification to account for wear, tool changes, or temperature; traceability of each DataTrace back to its source and processing component ensures validation of simulation vs measured data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow over MQTT; additionally, Asset Administration Shells are used to encapsulate model metadata and enable integration with other Industry 4.0 services."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation uses the Asset Administration Shell (AAS) specification, a standard of the Industry 4.0 framework, for model exchange and metadata handling."
]