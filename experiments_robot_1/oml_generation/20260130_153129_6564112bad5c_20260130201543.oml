// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures input current of the physical asset."
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures output angle of the physical asset."
    DTDFVocab:producedData OutputAngleDataTransmitted
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures torque of the physical asset."
    DTDFVocab:producedData TorqueDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures angular velocity of the physical asset."
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

// C4: Physical-to-virtual interaction
instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "MQTT streamed data of input current, transmitted using publish‑subscribe at the sensor sampling rate."
    DTDFVocab:producedFrom InputCurrentSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "MQTT streamed data of output angle, transmitted using publish‑subscribe at the sensor sampling rate."
    DTDFVocab:producedFrom OutputAngleSensor
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "MQTT streamed data of torque, transmitted using publish‑subscribe at the sensor sampling rate."
    DTDFVocab:producedFrom TorqueSensor
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "MQTT streamed data of angular velocity, transmitted using publish‑subscribe at the sensor sampling rate."
    DTDFVocab:producedFrom AngularVelocitySensor
]

// C11: Data artifacts
instance InputCurrentData : DTDFVocab:Data [
    base:desc "Validated and pre‑processed trace of input current."
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo SensorDataProcessingEnabler
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Validated and pre‑processed trace of output angle."
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo SensorDataProcessingEnabler
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Validated and pre‑processed trace of torque."
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo SensorDataProcessingEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Validated and pre‑processed trace of angular velocity."
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo SensorDataProcessingEnabler
]

// C10: Models/Data
instance SysMLArchitectureModel : DTDFVocab:Model [
    base:desc "SysML architecture model (including internal block diagrams) describing components, connectors, and interfaces of the system."
    DTDFVocab:inputTo SensorDataProcessingEnabler
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink white‑box dynamic simulation model used to compute physics‑based behavior."
    DTDFVocab:inputTo SensorDataProcessingEnabler
]

instance MachineLearningPredictionModel : DTDFVocab:Model [
    base:desc "Black‑box machine‑learning model that predicts derived parameters from sensor data."
    DTDFVocab:inputTo SensorDataProcessingEnabler
]

// C11: Enablers
instance SensorDataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that consumes validated sensor data and model artifacts to compute derived parameters via simulation and ML models."
    DTDFVocab:enables InsightGenerationService, InsightVisualizationService
]

// C6: Services
instance InsightGenerationService : DTDFVocab:Service [
    base:desc "Service that generates analytical insights by applying simulation and machine‑learning models to processed sensor data."
    DTDFVocab:provides DerivedPhysicalParametersInsight
]

instance InsightVisualizationService : DTDFVocab:Service [
    base:desc "Service that visualizes analytical insights for downstream applications."
    DTDFVocab:provides AssetStateUnderstandingInsight
]

// C17: Insights
instance DerivedPhysicalParametersInsight : DTDFVocab:Insight [
    base:desc "Higher‑level abstraction representing derived physical parameters (e.g., friction coefficient) computed from raw sensor traces."
]

instance AssetStateUnderstandingInsight : DTDFVocab:Insight [
    base:desc "Semantic interpretation of the asset's current state, enabling users to understand condition based on aggregated data."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The documents indicate that, unlike a digital shadow, a Digital Twin can provide active components that push data back to the physical system (Doc 1). However, no concrete details are given regarding command types, message formats, validation, authentication, feedback loops, conflict resolution, or execution confirmations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by coupling white‑box Simulink simulations with black‑box machine‑learning models, ensuring that both physical plausibility and empirical accuracy are retained. Validation and verification are performed through traceability of transformations (e.g., SysML to simulation models) and systematic verification of model correctness as highlighted in the literature. Uncertainty quantification and error detection are implied by the need for reliable digital shadows; the approach stresses traceability and verification of data‑driven transformations to detect inconsistencies. Quality assurance follows model‑based development practices that include verification of transformation correctness and alignment of aggregated contextual data with the physical system."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on the MQTT protocol for communication over standard IP networks. The documents do not specify the network topology, bandwidth or latency requirements, reliability/redundancy mechanisms, or security protocols beyond the use of MQTT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The documents reference several modelling standards and tools: SysML (OMG Systems Modeling Language) for requirements and architecture modelling; UML class diagrams for the Digital Shadow Reference Model; Architecture Description Languages (ADLs) ACME, AADL, and MontiArc for component‑connector specifications; and MathWorks Simulink for behavioural simulation. The notion of a “conformance relation” is used to ensure that concrete realizations adhere to the reference model, but no additional industry‑wide interoperability standards (e.g., Asset Administration Shell) are mentioned."
]