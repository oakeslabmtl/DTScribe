]

instance PerformanceVisualizationService : DTDFVocab:Service [
    base:desc "Renders KPI dashboards (e.g., OEE) and 3D/4D spatial-temporal representations for immersive analytics."
    DTDFVocab:provides VisualizationInsight
]

