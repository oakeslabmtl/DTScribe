// C2: Acting Components
instance ControlStateMachineActuator : DTDFVocab:ActingComponent [
    base:desc "Implements real-time control logic using SysML state machines (v1.7+) to adjust physical actuators (e.g., motor speeds, valve positions) based on Digital Twin-generated insights."
]

instance ArchitectureReconfigurationEngine : DTDFVocab:ActingComponent [
    base:desc "Dynamic architecture reconfiguration component using MontiArc automata to adapt logical architectures (e.g., adding/removing components) in response to operational changes."
]

instance SimulationControlInterface : DTDFVocab:ActingComponent [
    base:desc "Bridge component enabling bidirectional control between Simulink models and physical system actuators via OPC UA/MQTT protocols."
]

// C3: Physical Sensing Components
instance ContextualDataAggregatorSensor : DTDFVocab:SensingComponent [
    base:desc "Aggregates contextual data traces including sensor readings, operational logs, and environmental parameters for Digital Twin monitoring purposes."
    DTDFVocab:producedData ContextualDataTrace
]

instance OperationalPerformanceSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real-time operational metrics (e.g., equipment health, process efficiency) for performance analytics and anomaly detection."
    DTDFVocab:producedData OperationalPerformanceData
]

instance ProcessEventSensor : DTDFVocab:SensingComponent [
    base:desc "Detects physical events (e.g., sensor thresholds, operational states) triggering event-driven data collection for Digital Twin updates."
    DTDFVocab:producedData ProcessEventData
]

// C4: Physical-to-Virtual Interaction
instance ContextualDataTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContextualDataAggregatorSensor
]

instance OperationalPerformanceData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalPerformanceSensor
]

instance ProcessEventData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProcessEventSensor
]

// C10: Models/Data
instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "Behavioral model using SysML state machines (v1.7+) to represent component control logic and state transitions for simulation and validation."
    DTDFVocab:inputTo SimulationExecutionEngine
]

instance AADLComponentModel : DTDFVocab:Model [
    base:desc "Hardware/software co-design model using AADL with annexes for timing, fault tolerance, and performance analysis, exportable to Simulink for simulation."
    DTDFVocab:inputTo ArchitectureAnalysisTool
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "Dynamic architecture model using MontiArc automata to represent state transitions and component interactions for real-time reconfiguration."
    DTDFVocab:inputTo ArchitectureReconfigurationEngine
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "Dynamic system simulation model using MathWorks Simulink for state-space modeling, control system design, and real-time testing."
    DTDFVocab:inputTo SimulationExecutionEngine
]

instance ContextualDataRepository : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces stored in relational databases (e.g., PostgreSQL) for structured analytics."
    DTDFVocab:fromData ContextualDataTrace
    DTDFVocab:inputTo AnomalyDetectionEngine
]

instance PerformanceAnalyticsData : DTDFVocab:Data [
    base:desc "Processed operational performance data including KPIs (e.g., OEE) stored in time-series databases (e.g., InfluxDB) for visualization and trend analysis."
    DTDFVocab:fromData OperationalPerformanceData
    DTDFVocab:inputTo DashboardVisualizationEngine
]

instance EventTriggerData : DTDFVocab:Data [
    base:desc "Collected process event data used for triggering real-time simulations and reconfigurations in the Digital Twin system."
    DTDFVocab:fromData ProcessEventData
    DTDFVocab:inputTo EventProcessingEngine
]

// C11: Enablers
instance SimulationExecutionEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink execution engine for running dynamic system simulations, including state-space modeling and real-time testing."
    DTDFVocab:enables RealTimeSimulationService
]

instance ArchitectureAnalysisTool : DTDFVocab:Enabler [
    base:desc "AADL analysis tool with annex support for timing, fault tolerance, and performance analysis, integrated with Simulink for model validation."
    DTDFVocab:enables ArchitectureValidationService
]

instance MontiArcPluginSystem : DTDFVocab:Enabler [
    base:desc "MontiArc plugin architecture enabling interoperability between SysML, Simulink, and Java components for dynamic architecture modeling."
    DTDFVocab:enables ArchitectureReconfigurationService
]

instance KafkaStreamProcessing : DTDFVocab:Enabler [
    base:desc "Apache Kafka stream processing engine for real-time data aggregation, anomaly detection, and event-driven processing of Digital Twin data."
    DTDFVocab:enables AnomalyDetectionService
]

instance OPCUAProtocolAdapter : DTDFVocab:Enabler [
    base:desc "OPC UA protocol adapter enabling standardized industrial communication between physical systems and Digital Twin components."
    DTDFVocab:enables PhysicalSystemInteractionService
]

instance TensorFlowPredictiveEngine : DTDFVocab:Enabler [
    base:desc "TensorFlow-based predictive analytics engine for time-series forecasting (e.g., ARIMA, LSTM networks) on Digital Shadow data."
    DTDFVocab:enables FailureForecastingService
]

instance DashboardVisualizationEngine : DTDFVocab:Enabler [
    base:desc "Power BI/Tableau-based visualization platform rendering KPI dashboards (e.g., OEE) and 3D/4D spatial-temporal representations."
