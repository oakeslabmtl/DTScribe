// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) installed on the permanent‑magnet synchronous motor, measuring electrical current."
    DTDFVocab:producedData MotorCurrentMQTT
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted encoder that records the rotational angle of the motor shaft."
    DTDFVocab:producedData MotorPositionMQTT
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder positioned behind the gearbox, providing output angle of the gearbox."
    DTDFVocab:producedData GearboxPositionMQTT
]

// C4: Data transmitted from sensors via MQTT
instance MotorCurrentMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorPositionMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxPositionMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

// C10: Measurement data derived from transmitted data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Real‑time motor current time‑series data received via MQTT."
    DTDFVocab:fromData MotorCurrentMQTT
    DTDFVocab:inputTo SimulinkExecutionEngine
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Real‑time motor position time‑series data received via MQTT."
    DTDFVocab:fromData MotorPositionMQTT
    DTDFVocab:inputTo SimulinkExecutionEngine
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Real‑time gearbox position time‑series data received via MQTT."
    DTDFVocab:fromData GearboxPositionMQTT
    DTDFVocab:inputTo SimulinkExecutionEngine
]

// C10: Simulation and structural models
instance MotorStructuralModel : DTDFVocab:Model [
    base:desc "Engineered structural model of the permanent‑magnet synchronous motor, created in SysML."
    DTDFVocab:inputTo SimulinkExecutionEngine
]

instance GearboxStructuralModel : DTDFVocab:Model [
    base:desc "Engineered structural model of the cycloidal gearbox, created in SysML."
    DTDFVocab:inputTo SimulinkExecutionEngine
]

instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Executable Simulink model for motor output including friction models (Coulomb–Viscous, Stribeck, Dahl, LuGre)."
    DTDFVocab:inputTo SimulinkExecutionEngine
]

instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "Executable Simulink model for gearbox output with friction models (Coulomb–Viscous, Stribeck, Dahl, LuGre)."
    DTDFVocab:inputTo SimulinkExecutionEngine
]

instance SystemSimulinkModel : DTDFVocab:Model [
    base:desc "Executable Simulink model representing the overall rotary axis system, integrating motor and gearbox outputs."
    DTDFVocab:inputTo SimulinkExecutionEngine
]

// C11: Enabler
instance SimulinkExecutionEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink runtime that executes the motor, gearbox, and system simulation models."
    DTDFVocab:enables FrictionDashboardVisualizationService, FrictionIdentificationService, FrictionSimulationService, DataComparisonService
]

// C6: Services
instance FrictionDashboardVisualizationService : DTDFVocab:Service [
    base:desc "Service that visualizes real‑time friction data in a dashboard, enabling operators to monitor friction behavior."
    DTDFVocab:provides RealTimeFrictionDataInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service that continuously identifies static, kinetic, and viscous friction parameters from incoming sensor data."
    DTDFVocab:provides StaticFrictionParameterInsight, KineticFrictionParameterInsight, ViscousFrictionParameterInsight
]

instance FrictionSimulationService : DTDFVocab:Service [
    base:desc "Service that simulates frictionless ideal behavior and various friction models (Coulomb–Viscous, Stribeck, Dahl, LuGre) to evaluate impact."
    DTDFVocab:provides IdealFrictionSimulationInsight, FrictionModelComparisonInsight
]

instance DataComparisonService : DTDFVocab:Service [
    base:desc "Service that aggregates and compares simulated data with measured data to improve robot motion accuracy."
    DTDFVocab:provides MotionAccuracyImprovementInsight
]

// C17: Insights
instance RealTimeFrictionDataInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of friction data for immediate operational awareness."
]

instance StaticFrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived static friction coefficient for the gearbox as identified by the identification service."
]

instance KineticFrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived kinetic friction coefficient for the gearbox as identified by the identification service."
]

instance ViscousFrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived viscous friction coefficient for the gearbox as identified by the identification service."
]

instance IdealFrictionSimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation result of the system behavior under frictionless ideal conditions."
]

instance FrictionModelComparisonInsight : DTDFVocab:Insight [
    base:desc "Comparison between measured data and friction model simulations to validate model fidelity."
]

instance MotionAccuracyImprovementInsight : DTDFVocab:Insight [
    base:desc "Aggregated results showing improvement in robot motion accuracy after applying updated friction parameters."
]

// C17: Actions
instance UpdateControlAlgorithmAction : DTDFVocab:Action [
    base:desc "Automatic action to update robot control algorithms with newly derived friction parameters."
    DTDFVocab:IsAutomatic true
]

instance MaintenancePlanningAction : DTDFVocab:Action [
    base:desc "Automatic action that schedules maintenance based on wear and temperature insights."
    DTDFVocab:IsAutomatic true
]

instance ModelUpdateAction : DTDFVocab:Action [
    base:desc "Automatic action to refine simulation models with updated friction parameters and empirical data."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with continuous data acquisition and identification; synchronization at the motor current sampling rate (not explicitly stated, but implied to be continuous during robot operation)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow orchestrates data sources (sensor streams via MQTT) fed into a central processing component that runs the simulation models and outputs in a unified dashboard; the AAS provides semantic context and traceability between data traces, processing components, and models."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT encompasses both the as‑designed (ideal) simulation models and the as‑manufactured / as‑operated data; continuous monitoring during operation and an on‑line model refinement workflow."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous, real‑time identification of friction parameters; traceability of data points back to their generating processing component; comparison of simulated versus measured data for validation; multi‑physics‑aware approach through integration of white‑box and black‑box friction models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT is established via MQTT for sensor data; modeling components (Simulink) and AAS operate within the DT but specific intra‑DT protocols are not detailed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for system modelling and Asset Administration Shells (AAS) for semantic data linkage; these provide standardised ways to describe assets and data."
]