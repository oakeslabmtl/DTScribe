// C3: Physical sensing component
instance DigitalShadowReferenceModel : DTDFVocab:SensingComponent [
    base:desc "Harvests contextual data traces by the Digital Shadow reference model."
    DTDFVocab:producedData ContextualTracesDataTransmitted
]

// C4: Data transmitted
instance ContextualTracesDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DigitalShadowReferenceModel
]

// C10: Data
instance AggregatedContextualData : DTDFVocab:Data [
    base:desc "Aggregated contextual data abstracted and aggregated according to ADL artefacts (ACME, AADL, MontiArc) for pose estimation."
    DTDFVocab:fromData ContextualTracesDataTransmitted
    DTDFVocab:inputTo ADLArtifactProcessor
]

// C11: Enabler
instance ADLArtifactProcessor : DTDFVocab:Enabler [
    base:desc "Processes ADL artefacts (ACME, AADL, MontiArc) to prepare data for pose estimation."
    DTDFVocab:enables ADLDataProcessingService
]

// C6: Service
instance ADLDataProcessingService : DTDFVocab:Service [
    base:desc "Processes aggregated contextual data for pose estimation."
    DTDFVocab:provides PoseEstimationInsight
]

// C17: Insight
instance PoseEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated pose information derived from processed contextual data."
]

// ----- Additional Models and Enablers -----
instance SysMLArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model describing system architecture, components, interfaces, and connections."
    DTDFVocab:inputTo SysML2CCodeGenerator
]

instance MontiArcComponentConnectorModel : DTDFVocab:Model [
    base:desc "MontiArc model formalising component‑connector structures."
    DTDFVocab:inputTo MontiArc2CCodeGenerator
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "Simulink model for detailed behavioral simulation of continuous dynamics."
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

// Enablers for code generation
instance SysML2CCodeGenerator : DTDFVocab:Enabler [
    base:desc "Generates C++ code from SysML artefacts."
    DTDFVocab:enables CppCodeGenerationService
]

instance MontiArc2CCodeGenerator : DTDFVocab:Enabler [
    base:desc "Generates C++ code from MontiArc artefacts."
    DTDFVocab:enables CppCodeGenerationService
]

instance SimulinkRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Provides runtime environment for Simulink-generated models."
    DTDFVocab:enables SimulationService
]

// Services for code generation and simulation
instance CppCodeGenerationService : DTDFVocab:Service [
    base:desc "Generates optimized C++ code for runtime integration."
    DTDFVocab:provides CppCodeGenerationAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Executes simulation of continuous dynamics."
    DTDFVocab:provides SimulationInsight
]

// Actions and Insights
instance CppCodeGenerationAction : DTDFVocab:Action [
    base:desc "Runs generated C++ code for integration."
    DTDFVocab:IsAutomatic true
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insights from simulation runs."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Digital Twin constellation is orchestrated by integrating multiple MBSE artifacts: SysML models that capture functional and logical architecture via IBDs, ADLs (ACME, AADL, MontiArc) that model components and connectors, and simulation tools such as MathWorks Simulink for dynamic behavior. Components written in C++ or Java provide executable logic connected to the Simulink environment. These artifacts are combined in a product/technical layer, coordinating behavior across physical and digital domains, enabling collective simulation and runtime execution of the twin system."
]