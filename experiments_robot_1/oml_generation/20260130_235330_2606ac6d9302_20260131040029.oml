// Sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Measures ambient temperature via a digital temperature sensor"
    DTDFVocab:producedData TemperatureMeasurementTransmitted
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Measures hydraulic pressure via a pressure transducer"
    DTDFVocab:producedData PressureMeasurementTransmitted
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Captures vibration signals with a piezoelectric sensor"
    DTDFVocab:producedData VibrationMeasurementTransmitted
]

// Physical‑to‑virtual data transmissions
instance TemperatureMeasurementTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureMeasurementTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

instance VibrationMeasurementTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
]

instance TorqueMeasurementTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor, PressureSensor, VibrationSensor
]

// Imported data into the twin
instance TemperatureMeasurementData : DTDFVocab:Data [
    base:desc "Raw temperature measurement data streamed over MQTT, time‑series"
    DTDFVocab:inputTo IngestionLayerEnabler
    DTDFVocab:fromData TemperatureMeasurementTransmitted
]

instance PressureMeasurementData : DTDFVocab:Data [
    base:desc "Raw pressure measurement data streamed over MQTT, time‑series"
    DTDFVocab:inputTo IngestionLayerEnabler
    DTDFVocab:fromData PressureMeasurementTransmitted
]

instance VibrationMeasurementData : DTDFVocab:Data [
    base:desc "Raw vibration measurement data streamed over MQTT, time‑series"
    DTDFVocab:inputTo IngestionLayerEnabler
    DTDFVocab:fromData VibrationMeasurementTransmitted
]

instance TorqueDerivedData : DTDFVocab:Data [
    base:desc "Derived torque computed via ingestion layer from raw sensor values"
    DTDFVocab:inputTo IngestionLayerEnabler, SimulationEnabler
    DTDFVocab:fromData TorqueMeasurementTransmitted
]

// Enablers for ingestion and simulation
instance IngestionLayerEnabler : DTDFVocab:Enabler [
    base:desc "Lightweight ingestion layer that validates and aggregates MQTT sensor streams, computing derived metrics such as torque from raw sensor values"
    DTDFVocab:enables IngestionValidationService, IngestionAggregationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulink‑based simulation tool that executes structural and CAD models"
    DTDFVocab:enables SimulationExecutionService
]

// Services that operate on the ingested or simulated data
instance IngestionValidationService : DTDFVocab:Service [
    base:desc "Validates incoming sensor data against schema and threshold limits"
    DTDFVocab:provides DataValidityInsight
]

instance IngestionAggregationService : DTDFVocab:Service [
    base:desc "Aggregates and computes derived metrics such as torque from raw sensor readings"
    DTDFVocab:provides TorqueInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Runs analytical Simulink simulation models using sensor and derived data"
    DTDFVocab:provides StructuralModelResultAction
]

// Insights and actions derived from the services
instance DataValidityInsight : DTDFVocab:Insight [
    base:desc "Alert when sensor data fails validation checks"
]

instance TorqueInsight : DTDFVocab:Insight [
    base:desc "Insight derived from torque aggregation"
]

instance StructuralModelResultAction : DTDFVocab:Action [
    base:desc "Outputs structural analysis results to the operator"
    DTDFVocab:IsAutomatic true
]

// Models used by the simulation enabler
instance StructuralSimulationModel : DTDFVocab:Model [
    base:desc "Structural finite element model defined in Simulink block diagram"
    DTDFVocab:inputTo SimulationEnabler
]

instance CADModel : DTDFVocab:Model [
    base:desc "CAD block representation referenced in SysML block"
    DTDFVocab:inputTo SimulationEnabler
]

// Environment encapsulating all components
instance VirtualTwinEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, PressureSensor, VibrationSensor,
           IngestionLayerEnabler, SimulationEnabler,
           StructuralSimulationModel, CADModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The system is purely a digital shadow and does not send control messages back to the physical asset. Consequently, there are no active command flows, command formats, authentication or execution confirmation mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated through a layered architecture: an Asset Administration Shell (AAS) exposes a structured metadata contract for the twin, SysML component‑and‑connector models (IBDs) capture the logical architecture, and a Simulink model implements the dynamic behavior tied to live data. A middleware hook streams sensor packets from the robot into the AAS, forwards them to the Simulink engine, and publishes the resulting state as a JSON payload. A browser‑based dashboard consumes the AAS payload to render status, trends, and visualisations, following the Digital Shadow Reference Model’s UML diagram."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the physical device and the digital twin is implemented using MQTT.  The digital twin subscribes to topics published by the physical device, and the broker distributes messages to the consuming application.  No further details on topic hierarchy, QoS levels, bandwidth, latency, or security mechanisms are available in the source."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Utilization of established systems engineering modeling standards such as SysML (v1.7) for functional and logical architecture, ACME and AADL for component–connector modeling, and MontiArc (including its Automaton extension) for component‑based modeling and state machine behavior. These standards facilitate interoperability across tools including Simulink and general‑purpose programming languages."
]