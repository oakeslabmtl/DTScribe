// Acting Component
instance PermanentMagnetSynchronousMotorFirstAxisActuator : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor driving the first rotary axis of the MABI MAX100 robotic arm, coupled to a cycloidal gear train and limited to a maximum angular velocity of 75°/s."
]

// Sensing Components
instance AbsolutePositionEncoderFirstAxisPrimary : DTDFVocab:SensingComponent [
    base:desc "Absolute position encoder mounted on the first drive of the robotic arm to capture joint angle with high resolution."
    DTDFVocab:producedData JointAngleDataTransmitted
]

instance AbsolutePositionEncoderFirstAxisSecondary : DTDFVocab:SensingComponent [
    base:desc "Second absolute position encoder mounted on the same first drive to provide redundant joint angle measurement."
    DTDFVocab:producedData JointAngleDataTransmitted
]

// Data Transmitted
instance JointAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AbsolutePositionEncoderFirstAxisPrimary, AbsolutePositionEncoderFirstAxisSecondary
]

// Data
instance JointAngleData : DTDFVocab:Data [
    base:desc "Joint angle values streamed in real‑time over an MQTT broker, derived from the two absolute position encoders on the first drive."
    DTDFVocab:fromData JointAngleDataTransmitted
    DTDFVocab:inputTo SimulinkModelEnabler
]

// Models
instance SimulinkJointDynamicsModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model simulating the dynamics of the first rotary joint, receiving real‑time joint angle and motor torque as inputs."
    DTDFVocab:inputTo SimulinkModelEnabler
]

// Enablers
instance SimulinkModelEnabler : DTDFVocab:Enabler [
    base:desc "Runtime enabler that executes the Simulink Joint Dynamics model within a Model‑Based Systems Engineering workflow."
    DTDFVocab:enables JointAnglePredictionService
]

// Services
instance JointAnglePredictionService : DTDFVocab:Service [
    base:desc "Service exposing predicted joint angle trajectory of the first rotary axis based on current state and motor inputs."
    DTDFVocab:provides JointAngleDeviationInsight
]

// Insights
instance JointAngleDeviationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating deviation between measured joint angle from encoders and predicted joint angle from the Simulink model, useful for monitoring accuracy and safety."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The system is defined as a digital shadow and thus explicitly lacks a virtual‑to‑physical control channel. No command or control messages are generated by the digital twin; the physical device operates autonomously without receiving instructions from the digital representation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin operates on real‑time sensor streams that are delivered as time series via the MQTT publish/subscribe protocol. The DT models the physical system using data‑driven representations synchronized with the sensor data, but the source text does not specify explicit sampling rates, update cadences, or latency constraints."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin architecture follows the reference model of Kritzinger et al., comprising four core concepts: Asset (the physical entity), Source (data acquisition layer), Processing (data fusion and modeling), and Model (the digital representation). Data flow is enacted through MQTT topics; no explicit central orchestrator or resource management components are described in the source."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin development follows a multi‑level MBSE approach where the system is described at progressively finer abstractions: a requirements level, a functional architecture level, a logical architecture level, and a product/technical level. At each stage distinct modeling notations are employed – for instance SysML Schema and diagrams for structural and behavioral description, and architecture description languages (ADLs) such as ACME, AADL or MontiArc for component‑connector representation. Transition between stages is typically handled through model‑to‑model transformations or harmonisation of abstraction levels, while governance is exercised via MBSE practices that enforce consistency across diagrams, verification artefacts, and documentation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing simulated trajectories against measured data from the physical plant. The comparison is performed by computing the deviation of simulated outputs from reference values; deviations beyond an implicit tolerance would flag a validation failure. The document does not prescribe explicit quantitative thresholds, statistical tests, or uncertainty quantification methods, but it emphasizes that validation relies on measurable discrepancies between simulation and real‑world measurements."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance is achieved by adhering to model‑based standards: SysML is used as the primary modeling language for both structure and behavior, and components are described with industry ADLs such as ACME, AADL, and MontiArc. Simulation artifacts are produced with MathWorks Simulink, ensuring compatibility with standard simulation interfaces."
]