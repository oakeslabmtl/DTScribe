instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML for system modeling across multiple abstraction levels (requirements, functional, logical, technical layers)"
    DTDFVocab:enables SysMLModelingService
]

instance ACMETool : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component-connector architecture descriptions"
    DTDFVocab:enables ACMEArchitectureService
]

instance AADLTool : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component-connector architecture descriptions"
    DTDFVocab:enables AADLArchitectureService
]

instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component-connector architecture descriptions"
    DTDFVocab:enables MontiArcArchitectureService
]

instance MontiArcAutomatonTool : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavior specification"
    DTDFVocab:enables MontiArcBehaviorService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation"
    DTDFVocab:enables SimulationService
]

instance CPlusPlusTool : DTDFVocab:Enabler [
    base:desc "C++ programming language for implementation"
    DTDFVocab:enables CPlusPlusImplementationService
]

instance JavaTool : DTDFVocab:Enabler [
    base:desc "Java programming language for implementation"
    DTDFVocab:enables JavaImplementationService
]

instance MBSETool : DTDFVocab:Enabler [
    base:desc "MBSE tools for managing complexity and system modeling across various methodologies"
    DTDFVocab:enables ComplexityManagementService, StakeholderIntegrationService
]

instance SysMLModelingService : DTDFVocab:Service [
    base:desc "Modeling system structure and behavior using SysML across abstraction levels"
    DTDFVocab:provides SysMLModelingInsight
]

