]

instance JavaImplementationService : DTDFVocab:Service [
    base:desc "Implementation using Java programming language"
    DTDFVocab:provides JavaImplementationInsight
]

instance ComplexityManagementService : DTDFVocab:Service [
    base:desc "Management of system complexity using methodologies like RFLP, OOSEM, SPES, SMArDT"
    DTDFVocab:provides ComplexityManagementInsight
]

