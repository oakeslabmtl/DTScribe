instance PhysicalSystemStateTracesSensor : DTDFVocab:SensingComponent [
    base:desc "Sensing component for physical system state traces"
    DTDFVocab:producedData PhysicalSystemStateTraces
]

instance PhysicalSystemStateTraces : DTDFVocab:DataTransmitted [
    base:desc "Physical system state traces data originating from physical system"
    DTDFVocab:producedFrom PhysicalSystemStateTracesSensor
]

instance AggregatedPhysicalData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted physical system state traces for specific purposes"
    DTDFVocab:fromData PhysicalSystemStateTraces
    DTDFVocab:inputTo MBSETool, SimulinkTool, SysMLTool
]

instance SysMLModel : DTDFVocab:Model [
    base:desc "SysML for system structure and behavior description across abstraction levels including requirements, functional architecture, logical architecture, and product/technical layer"
    DTDFVocab:inputTo SysMLTool
]

