    base:desc "SMArDT methodology for managing complexity in MBSE"
    DTDFVocab:inputTo MBSETool
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language for defining components, interfaces, interconnections, and composition"
    DTDFVocab:inputTo ACMETool
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL Architecture Description Language for defining components, interfaces, interconnections, and composition"
    DTDFVocab:inputTo AADLTool
]

