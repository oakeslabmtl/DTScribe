    base:desc "MontiArc Automaton for behavior modeling"
    DTDFVocab:inputTo MontiArcAutomatonTool
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavior modeling"
    DTDFVocab:inputTo SysMLTool
