// C3: Physical sensing components (Digital Shadow as data source)
instance DigitalShadowDataProvider : DTDFVocab:SensingComponent [
    base:desc "Provides one‑way data streams from the Digital Shadow, enabling the DT to consume state information for autonomous operation"
    DTDFVocab:producedData ShadowDataStream
]

// C4: Physical-to-virtual interaction (data transmission)
instance ShadowDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DigitalShadowDataProvider
]

// C10: Data captured from the shadow
instance TwinInputData : DTDFVocab:Data [
    base:desc "Aggregated data received from the Digital Shadow, used as input for structural, behavioral, and statistical models"
    DTDFVocab:fromData ShadowDataStream
    DTDFVocab:inputTo MBSEToolchain, SimulationEngine, MLInferenceEngine
]

// C10: Models/Data – structural & architectural
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "Structural and architectural information captured in SysML internal block diagrams and ADLs such as ACME, AADL, MontiArc"
    DTDFVocab:inputTo MBSEToolchain
]

// C10: Models/Data – behavioral (state machines)
instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "Behavioral aspects modeled with SysML v1.7 state‑machine extensions and MontiArc Automaton"
    DTDFVocab:inputTo MBSEToolchain
]

// C10: Models/Data – physics (white‑box)
instance SimulinkPhysicsModel : DTDFVocab:Model [
    base:desc "Dynamic physics‑based white‑box representation created in MathWorks Simulink"
    DTDFVocab:inputTo SimulationEngine
]

// C10: Models/Data – statistical (black‑box)
instance MachineLearningRegressorModel : DTDFVocab:Model [
    base:desc "Data‑driven regression model derived from intrinsic robot state data"
    DTDFVocab:inputTo MLInferenceEngine
]

// C11: Enablers – MBSE toolchain
instance MBSEToolchain : DTDFVocab:Enabler [
    base:desc "Performs model transformations, code generation and integration across SysML, ADLs, and C++/Java artifacts"
    DTDFVocab:enables AutonomousOperationService
]

// C11: Enablers – simulation engine
instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Executes Simulink simulation models and provides runtime results to the DT"
    DTDFVocab:enables AutonomousOperationService
]

// C11: Enablers – machine‑learning inference engine
instance MLInferenceEngine : DTDFVocab:Enabler [
    base:desc "Runs machine‑learning regressors and supplies predictions for adaptive DT behavior"
    DTDFVocab:enables AutonomousOperationService
]

// C6: Services
instance AutonomousOperationService : DTDFVocab:Service [
    base:desc "Provides autonomous operation capabilities by consuming model outputs and coordinating active components"
    DTDFVocab:provides EvolutionInsight, DeployNewModelAction
]

// C17: Insights
instance EvolutionInsight : DTDFVocab:Insight [
    base:desc "Identifies opportunities for incremental evolution when new processing components or models are introduced"
]

// C17: Actions
instance DeployNewModelAction : DTDFVocab:Action [
    base:desc "Deploys newly generated simulation code or machine‑learning model to the active DT environment"
    DTDFVocab:IsAutomatic true
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and validity are ensured by traceability of model transformations (e.g., from SysML specifications to simulation or code artefacts) and by verification of each transformation step, as highlighted in the digital‑shadow reference approach. Reliability of the Digital Twin depends on the correctness of underlying white‑box (Simulink) and black‑box (machine‑learning) models; therefore verification activities such as model‑based testing, validation against recorded robot friction data, and uncertainty quantification of model parameters are required. The approach stresses systematic verification and validation procedures to detect and correct errors and to maintain quality assurance of both models and the associated data."
]