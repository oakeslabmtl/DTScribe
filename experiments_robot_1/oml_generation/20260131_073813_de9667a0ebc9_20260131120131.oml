// C1: Physical Sensing Components
instance SixAxisEncoderLeft : DTDFVocab:SensingComponent [
    base:desc "Positional encoder (two per drive axis) providing high-precision feedback for path repeatability (0.06 mm) and positional accuracy (0.1 mm) on MABI MAX 100 robot axes"
]

instance SixAxisEncoderRight : DTDFVocab:SensingComponent [
    base:desc "Positional encoder (two per drive axis) providing high-precision feedback for path repeatability (0.06 mm) and positional accuracy (0.1 mm) on MABI MAX 100 robot axes"
]

instance SINUMERIKControllerLogs : DTDFVocab:SensingComponent [
    base:desc "Controller logs capturing operational parameters from SINUMERIK controller for manufacturing processes"
]

// C2: Produced Data Types
instance EncoderPositionDataLeft : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SixAxisEncoderLeft
    base:desc "High-resolution positional data stream from left axis encoders via MQTT protocol"
]

instance EncoderPositionDataRight : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SixAxisEncoderRight
    base:desc "High-resolution positional data stream from right axis encoders via MQTT protocol"
]

instance ControllerOperationLogs : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SINUMERIKControllerLogs
    base:desc "Time-series operational logs from SINUMERIK controller via automated data collection"
]

// C3: Data Components
instance PositionalDataTrace : DTDFVocab:Data [
    DTDFVocab:fromData EncoderPositionDataLeft, EncoderPositionDataRight
    base:desc "Contextual positional data traces aggregated from dual-axis encoders for manufacturing path monitoring"
    DTDFVocab:inputTo DigitalShadowAggregator
]

instance OperationalContextTrace : DTDFVocab:Data [
    DTDFVocab:fromData ControllerOperationLogs
    base:desc "Contextual operational data traces from SINUMERIK controller logs for process monitoring"
    DTDFVocab:inputTo DigitalShadowAggregator
]

// C4: Digital Shadow Components
instance DigitalShadowAggregator : DTDFVocab:Enabler [
    base:desc "Passive data aggregation layer collecting contextual data traces (positional and operational) via one-way automated flows from physical MABI MAX 100 robot"
    DTDFVocab:enables DigitalShadowReferenceModel
]

instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "Reference model implementing passive digital shadow architecture with contextual data trace abstraction for manufacturing monitoring"
    DTDFVocab:inputTo DigitalShadowAggregator
    DTDFVocab:inputTo ActiveComponentProcessor
]

// C5: Acting Components
instance ActiveComponentProcessor : DTDFVocab:ActingComponent [
    base:desc "Software system interpreting and processing incoming data streams from digital shadows to enable DT functionality via autonomous processing"
]

// C6: Models/Data for Digital Twin
instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based functional architecture model defining system functions and decomposition for MABI MAX 100 robot using RFLP methodology"
    DTDFVocab:inputTo SysMLEditor
    DTDFVocab:inputTo SimulinkSimulation
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "MontiArc automata-based logical architecture model capturing components and connectors for MABI MAX 100 robot's state machine behavior"
    DTDFVocab:inputTo MontiArcEditor
    DTDFVocab:inputTo SimulinkSimulation
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model implementing dynamic behavior simulation for MABI MAX 100 robot's closed-loop control system"
    DTDFVocab:inputTo SimulinkSimulation
    DTDFVocab:inputTo ActiveComponentProcessor
]

// C7: Enablers for Digital Twin
instance SysMLEditor : DTDFVocab:Enabler [
    base:desc "SysML modeling tool for requirements, functional architecture, and behavioral modeling of MABI MAX 100 robot"
    DTDFVocab:enables FunctionalArchitectureModel, LogicalArchitectureModel
]

instance MontiArcEditor : DTDFVocab:Enabler [
    base:desc "MontiArc tool for component/interface modeling and automata-based logical architecture representation"
    DTDFVocab:enables LogicalArchitectureModel
]

instance SimulinkSimulation : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for dynamic validation and simulation of DT behavior under operational conditions"
    DTDFVocab:enables SimulationModel
]

instance ActiveComponentFramework : DTDFVocab:Enabler [
    base:desc "Software framework implementing active components for autonomous data processing and DT functionality (C++/Java implementation)"
    DTDFVocab:enables ActiveComponentProcessor
]

// C8: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service enabling real-time monitoring of MABI MAX 100 robot's positional accuracy and operational parameters via active DT components"
    DTDFVocab:provides PositionalAccuracyInsight, OperationalContextInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Service implementing predictive analytics using behavioral models to forecast maintenance needs based on operational data traces"
    DTDFVocab:provides MaintenancePredictionAction
]

instance AdaptiveControlService : DTDFVocab:Service [
    base:desc "Service enabling adaptive control adjustments via simulation-based optimization of robot's closed-loop control parameters"
    DTDFVocab:provides ControlParameterAdjustmentAction
]

// C9: Insights/Actions
instance PositionalAccuracyInsight : DTDFVocab:Insight [
    base:desc "Real-time insight generated from positional data traces showing current robot axis accuracy against specified tolerances (0.06 mm repeatability, 0.1 mm accuracy)"
]

instance OperationalContextInsight : DTDFVocab:Insight [
    base:desc "Contextual insight derived from operational logs showing process parameters (speed, cycle time, error rates) for manufacturing process optimization"
]

instance MaintenancePredictionAction : DTDFVocab:Action [
    base:desc "Automatic action triggering maintenance procedures based on predictive analytics identifying impending component failures"
    DTDFVocab:IsAutomatic true
]

instance ControlParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Autonomous adjustment of control parameters in Simulink simulation to optimize robot performance under varying operational conditions"
    DTDFVocab:IsAutomatic true
]

// C12: Environment
instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:contains SixAxisEncoderLeft, SixAxisEncoderRight, SINUMERIKControllerLogs,
    FunctionalArchitectureModel, LogicalArchitectureModel, SimulationModel,
    RealTimeMonitoringService, PredictiveMaintenanceService, AdaptiveControlService
]

instance MABIMAX100Robot : DTDFVocab:Component [
    base:desc "Six-axis industrial serial robot (MABI MAX 100) designed for precision machining and assembly tasks with motorized actuators, gearboxes, and dual-axis encoders"
    base:contains SixAxisEncoderLeft, SixAxisEncoderRight
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The provided documents do not explicitly detail synchronization frequencies, latency requirements, or temporal granularity for Digital Twin (DT) systems. However, the distinction between **digital shadows** and **digital twins** implies that while digital shadows operate as passive, one-way data flow entities (e.g., aggregating contextual data traces with aggregation and abstraction for specific purposes), **digital twins** inherently require active components to interpret and process data in real-time or near-real-time. This suggests that **twinning_time_scale** for DTs involves **active data processing cycles**, though no specific time scales (e.g., milliseconds, seconds) or synchronization protocols (e.g., time synchronization standards like NTP) are mentioned. Thus, while the documents emphasize the **asynchronous, passive nature of digital shadows**, the **active, bidirectional interaction** of DTs implies a need for **latency-sensitive synchronization** (e.g., <100ms for critical applications) and **temporal granularity** aligned with operational requirements (e.g., per-second updates for real-time monitoring). If unspecified, this characteristic remains **Not in Document** for exact values but reflects the implied need for **real-time or near-real-time synchronization** in DT systems based on the context of active data processing."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin constellation** is not explicitly defined in the documents, but the **Digital Shadow Reference Model** (Fig. 1) and the distinction between **digital shadows** (passive, one-way data flow) and **digital twins** (active, bidirectional) imply a **hierarchical or modular orchestration** of DT systems. Key aspects include:
  - **Architecture patterns**: The use of **architecture description languages (ADLs)** like **SysML IBDs** or **MontiArc** for describing components, interfaces, and interconnections in DT systems, enabling **modular integration** of physical and digital elements.
  - **Component integration**: DTs would leverage **behavioral models** (e.g., state machines in SysML v1.7, MontiArc Automata) combined with **simulation tools** (e.g., MathWorks Simulink, other simulation methods) to represent complex behaviors.
  - **Resource management**: The **heterogeneous stakeholders and perspectives** (Section A) suggest a **multi-tool environment** (e.g., mixing SysML, C++, Java, or simulation tools) for managing resources across abstraction layers (requirements → functional → logical → technical).
  - **System-wide coordination**: While not detailed, the **active components** in DTs (vs. passive digital shadows) imply **real-time coordination mechanisms** (e.g., via **event-driven architectures**, **service-oriented integration**, or **time-synchronized data pipelines**).
  Thus, **dt_constellation** is inferred to involve **modular ADL-based architectures**, **multi-tool integration**, and **real-time coordination**, but no specific constellation patterns (e.g., star, mesh, or hybrid topologies) or coordination protocols are mentioned. **Not in Document** for exact details."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "
  A Digital Twin (DT) lifecycle in the context of Model-Based Systems Engineering (MBSE) spans multiple abstraction levels and methodologies, structured through distinct phases:
  **1. Requirements Phase**: Defined via methodologies like **RFLP (Requirements, Functions, Logics, Physics)** or **OOSEM**, where functional and non-functional requirements are captured and decomposed into high-level specifications.
  **2. Functional/Logical Architecture Phase**: Utilizes **architecture description languages (ADLs)** such as **ACME, AADL, MontiArc, or SysML IBDs**, detailing components, interfaces, connectors, and composition. Behavior is further refined using **MontiArc Automata** or **state machines** in SysML v1.7.
  **3. Technical/Product Layer**: Involves implementation details in tools like **MathWorks Simulink, simulation tools, or general-purpose languages (e.g., C++, Java)** for detailed system modeling and simulation.
  **Lifecycle Governance**: Transition management between phases is handled via **heterogeneous stakeholder integration** and **multi-tool/model notation compatibility**, ensuring consistency across **SysML, ADLs, and simulation tools**. No explicit lifecycle governance framework is detailed, but the emphasis on **complexity reduction via abstraction** (e.g., RFLP) implies structured transitions.
  **Note**: The document does not specify explicit lifecycle stages or governance tools, but the described methodologies imply iterative refinement from high-level requirements to implementation.
"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
The Digital Twin’s **fidelity and validity** are ensured through **comparative validation** where simulated data (e.g., from MBSE models or simulation tools like Simulink) is directly compared against **measured data** from physical sensors. While uncertainty quantification and error detection mechanisms are not explicitly detailed, the system’s reliance on **real-time sensor feedback** and **closed-loop control** implies implicit validation processes. Quality assurance is implied to involve iterative refinement between model predictions and empirical data, particularly during system development phases (e.g., MBSE’s layered approach). No explicit mention of formal uncertainty models (e.g., Bayesian inference) or statistical error correction is provided.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical infrastructure for digital twin communication involves **MQTT** for sensor data streaming, enabling real-time transmission of time-series data. While the document mentions **further modeling tools** like **MathWorks Simulink** for behavior simulation, no explicit protocols for network communication (e.g., TCP/IP, Ethernet) or security mechanisms (e.g., encryption, TLS) are detailed. The focus remains on **data aggregation and passive data flow** rather than active control or bidirectional communication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The deployment infrastructure integrates **Asset Administration Shells (AAS)** for structured digital representations, combined with **live-data linking** and visualization in dashboards. The system leverages **Model-Based Systems Engineering (MBSE)** and **SysML** for multi-abstraction modeling (requirements, functional/logical architecture, product/technical layers). No explicit mention of cloud/edge/on-premise deployment models is provided, but the context implies a **hybrid or distributed architecture** supporting heterogeneous stakeholder perspectives via integrated modeling tools (e.g., ADLs like AADL, MontiArc). The emphasis is on **real-time data processing** and **visualization** rather than scalability or reliability guarantees."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "
  **Industry Standards and Compliance**:
  - **Modeling Languages**: **SysML** (for requirements/architecture), **AADL/ACME/MontiArc** (for component-based design), and **state machine/automata formalisms** (for behavior) are referenced but not standardized as part of a unified framework.
  - **Simulation Tools**: **MathWorks Simulink** and other simulation tools are mentioned as complementary but not standardized for DT integration.
  - **Digital Shadows/DTs**: The **Kritzinger et al. [32] definition** of digital shadows (passive data flow) and DTs (active processing) is context-specific but lacks formal standardization (e.g., IEEE or ISO standards).

  **Interoperability Standards**:
  The document does not mention interoperability frameworks (e.g., **OPC UA, ROS, or XML-based standards**) for DT data exchange. The focus is on **methodological integration** (e.g., MBSE tools) rather than protocol standardization.

  **Certification Requirements**:
  No explicit certification frameworks (e.g., ISO 27001 for DT security) or compliance mandates are detailed. The emphasis is on **methodological rigor** (e.g., RFLP, ADLs) rather than regulatory compliance.

  **Not in Document**: No evidence of standardization bodies (e.g., IEEE, OMG) or interoperability protocols for DTs/digital shadows.
"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "
The provided Digital Twin system leverages the **Asset Administration Shell (AAS)** framework (as referenced in [Document 50](https://www.plattform-i40.de/IP/Redaktion/EN/Downloads/Publikation/Details_of_the_Asset_Administration_Shell_Part1_V2.html)) to ensure structured cybersecurity and safety integration within Industry 4.0 environments. The system adheres to the **Reference Architecture Model Industrie 4.0 (RAMI 4.0)** ([Document 49](https://www.din.de/rami40)), which categorizes assets across four layers: **Physical, Technical, Business, and User**, enabling explicit safety-critical validation at the **Technical** and **Physical** layers.

Technical implementations include:
- **Traceability of data origin** (as discussed in [Document 42](https://doi.org/10.1016/j.dke.2025.xx)) for ensuring auditability and compliance with cybersecurity standards, though the documents do not specify explicit protocols like **MQTT** (as mentioned in [Document 52](https://journals.openaccessjournals.com/index.php/joss/article/view/265)) for secure data exchange—only that data traces are **streamed via IoT protocols** for real-time monitoring.
- **Friction modeling** ([Document 45](https://link.springer.com/chapter/10.1007/978-3-031-49854-3_25)) is used for **accurate robot motion control** and **physical relationship validation**, implicitly supporting safety-critical validation through structured simulation models (e.g., **Functional Mockup Interface (FMI)** ([Document 51](https://link.springer.com/chapter/10.5555/9781461475786_09)) for tool-independent exchange of simulation models).

No explicit mention of **fail-safe mechanisms**, **Thingsboard** ([Document 53](https://thingsboard.io)), or **compliance frameworks** (e.g., GDPR, ISO 27001) is present, nor are there details on **authentication systems**, **access control**, or **threat mitigation strategies**. The system’s **cybersecurity protocols** remain abstractly tied to AAS’s **semantic asset administration shell** ([Document 46](https://link.springer.com/chapter/10.1007/978-3-319-66166-7_10) and [Document 47](https://ieeexplore.ieee.org/document/8907562)) but lack granularity on encryption, intrusion detection, or risk assessment."
]