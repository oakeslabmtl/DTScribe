// C2: Acting Components
instance ManufacturingSimulationEngine : DTDFVocab:ActingComponent [
    base:desc "Active component leveraging MathWorks Simulink for dynamic system behavior modeling and analysis in manufacturing DTs"
]

instance DataProcessingPipeline : DTDFVocab:ActingComponent [
    base:desc "Software component processing contextual data traces from digital shadows using general-purpose languages (C++, Java) for interpretation and aggregation"
]

instance DecisionSupportSystem : DTDFVocab:ActingComponent [
    base:desc "System enabling autonomous operation and data-driven recommendations through integrated analytics frameworks"
]

// C3: Physical sensing components
instance ManufacturingProcessTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency industrial sensor (kHz range) acquiring real-time temperature state traces for manufacturing processes"
    DTDFVocab:producedData ProcessTemperatureDataTrace
]

instance ManufacturingProcessPressureSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency sensor measuring pressure metrics with kilohertz sampling for operational monitoring"
    DTDFVocab:producedData ProcessPressureDataTrace
]

instance OperationalStateSensor : DTDFVocab:SensingComponent [
    base:desc "Event-triggered sensor detecting system state changes and operational metrics with near-real-time transmission"
    DTDFVocab:producedData OperationalStateTrace
]

instance QualityControlSensor : DTDFVocab:SensingComponent [
    base:desc "Industrial IoT sensor collecting quality control metrics with periodic polling (1Hz-10Hz) for manufacturing quality assurance"
    DTDFVocab:producedData QualityControlMetrics
]

// C4: Physical-to-virtual interaction
instance ProcessTemperatureDataTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ManufacturingProcessTemperatureSensor
    DTDFVocab:dataType StateTrace
    DTDFVocab:aggregationMethod ContextualizedAbstraction
    DTDFVocab:transmissionProtocol OPCUA
]

instance ProcessPressureDataTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ManufacturingProcessPressureSensor
    DTDFVocab:dataType StateTrace
    DTDFVocab:aggregationMethod TrendAnalysis
    DTDFVocab:transmissionProtocol MQTT
]

instance OperationalStateTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalStateSensor
    DTDFVocab:dataType EventTriggeredMetrics
    DTDFVocab:transmissionFrequency 1Hz-10Hz
]

instance QualityControlMetrics : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom QualityControlSensor
    DTDFVocab:dataType AggregatedQualityParameters
    DTDFVocab:transmissionFrequency Periodic
    DTDFVocab:preprocessing SmoothingBinning
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real-time process monitoring and anomaly detection through active DT components"
    DTDFVocab:provides ProcessPerformanceInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Service enabling predictive maintenance recommendations using aggregated contextual data traces"
    DTDFVocab:provides FailurePredictionAction
]

instance OptimizationRecommendationService : DTDFVocab:Service [
    base:desc "Service providing data-driven operational optimization suggestions for manufacturing processes"
    DTDFVocab:provides ProcessOptimizationAction
]

instance StakeholderIntegrationService : DTDFVocab:Service [
    base:desc "Service facilitating heterogeneous stakeholder collaboration through MBSE methodologies"
    DTDFVocab:provides CollaborativeModelInput
]

// C10: Models/Data
instance ManufacturingFunctionalModel : DTDFVocab:Model [
    base:desc "Functional architecture model describing manufacturing process components and their interfaces using SysML IBDs"
    DTDFVocab:inputTo ManufacturingSimulationEngine
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Logical architecture model defining system behavior through MontiArc automata and SysML state machines"
    DTDFVocab:inputTo DataProcessingPipeline
]

instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "Digital shadow reference model implementing one-way automated data aggregation for contextualized traces"
    DTDFVocab:inputTo ProcessTemperatureDataTrace, ProcessPressureDataTrace, OperationalStateTrace, QualityControlMetrics
]

instance ProcessBehaviorSimulation : DTDFVocab:Model [
    base:desc "Simulation model created in MathWorks Simulink for dynamic manufacturing process behavior validation"
    DTDFVocab:inputTo ManufacturingSimulationEngine
]

instance ContextualDataAggregationModel : DTDFVocab:Model [
    base:desc "Model defining aggregation and abstraction strategies for manufacturing data traces"
    DTDFVocab:inputTo DataProcessingPipeline
]

// C11: Enablers
instance ModelBasedSystemsEngineering : DTDFVocab:Enabler [
    base:desc "MBSE framework (RFLP, OOSEM) enabling structured decomposition across requirements, functional, logical, and technical layers"
    DTDFVocab:enables ManufacturingFunctionalModel, LogicalArchitectureModel
]

instance ArchitectureDescriptionLanguages : DTDFVocab:Enabler [
    base:desc "ADLs (ACME, AADL, MontiArc, SysML IBDs) for modeling components, interfaces, and interconnections in manufacturing DTs"
    DTDFVocab:enables ManufacturingFunctionalModel, DigitalShadowReferenceModel
]

instance SimulationTools : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink and other simulation frameworks for detailed behavioral validation and integration"
    DTDFVocab:enables ProcessBehaviorSimulation
]

instance GeneralPurposeLanguages : DTDFVocab:Enabler [
    base:desc "C++ and Java platforms for implementing active DT components and data processing pipelines"
    DTDFVocab:enables DataProcessingPipeline
]

instance DigitalShadowFramework : DTDFVocab:Enabler [
    base:desc "Digital Shadow Reference Model implementing one-way automated data flows from physical systems to DTs"
    DTDFVocab:enables ProcessTemperatureDataTrace, ProcessPressureDataTrace, OperationalStateTrace, QualityControlMetrics
]

// C17: Insights/Actions
instance ProcessPerformanceInsight : DTDFVocab:Insight [
    base:desc "Real-time insight derived from aggregated temperature and pressure state traces showing manufacturing process performance"
]

instance FailurePredictionAction : DTDFVocab:Action [
    base:desc "Autonomous action triggered by predictive maintenance service recommending equipment maintenance based on anomaly detection"
    DTDFVocab:IsAutomatic true
]

instance ProcessOptimizationAction : DTDFVocab:Action [
    base:desc "Data-driven action providing operational recommendations for process optimization using contextualized data traces"
    DTDFVocab:IsAutomatic true
]

instance CollaborativeModelInput : DTDFVocab:Action [
    base:desc "User interaction action enabling stakeholder-integrated modeling through MBSE tools for collaborative input/output"
    DTDFVocab:IsAutomatic false
]

instance UncertaintyQuantificationInsight : DTDFVocab:Insight [
    base:desc "Confidence measure insight derived from data validation processes showing reliability of DT processing components"
]

instance HeterogeneousStakeholderAlignment : DTDFVocab:Insight [
    base:desc "Insight ensuring alignment across operational, safety, and environmental perspectives through MBSE methodologies"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The provided documents do not explicitly detail synchronization frequencies, latency requirements, or temporal granularity for Digital Twin (DT) systems. However, the distinction between **Digital Shadows** and **Digital Twins** implies that while Digital Shadows operate as passive, one-way data flows (e.g., 'automated one-way data flow' between physical and digital objects), **Digital Twins** incorporate active components to interpret and process data. This suggests that DTs may require **real-time or near-real-time synchronization** to maintain temporal coherence between physical and digital states. The absence of specific time scales or granularity specifications in the documents implies that such details are either domain-dependent or not addressed in this particular context. Thus, **twinning_time_scale** is inferred to involve **dynamic, adaptive synchronization mechanisms** (e.g., event-driven or time-triggered updates) to align with operational requirements, though exact parameters are not provided in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The documents do not explicitly outline the **orchestration and coordination mechanisms** of a Digital Twin system. However, the **Digital Shadow reference model** (Fig. 1) and the distinction between passive shadows and active DTs imply that DTs require **centralized or decentralized orchestration** to manage active components and data processing. The **architecture description languages (ADLs)** mentioned (e.g., MontiArc, AADL) support component integration and resource management, suggesting that DT constellation patterns could leverage these for **modular, interoperable architectures**. The absence of specific patterns (e.g., microservices, peer-to-peer) implies reliance on **ADL-defined composition rules** and **simulation tools** (e.g., MathWorks Simulink) for behavior modeling. System-wide coordination would likely involve **state machines or automata** (e.g., MontiArc Automaton) to manage transitions between physical and digital states. Thus, **dt_constellation** is inferred to involve **ADL-based modular architectures**, with coordination via behavior models and simulation tools."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "
  The lifecycle of a Digital Twin (DT) in this context is structured through **Model-Based Systems Engineering (MBSE)** methodologies, emphasizing **multi-level abstraction** (requirements, functional architecture, logical architecture, and product/technical layers). Key phases include:
  - **Development Phase**: Utilizes **SysML** and **Architecture Description Languages (ADLs)** like **ACME, AADL, MontiArc, or SysML IBDs** to model components, interfaces, and interconnections. **Behavioral models** (e.g., MontiArc Automata, state machines in SysML v1.7) are integrated with simulation tools such as **MathWorks Simulink** or general-purpose languages (**C++, Java**) for detailed system behavior representation.
  - **Digital Shadow Transition**: The lifecycle transitions from a **passive digital shadow** (one-way data flow from physical to digital, per Kritzinger et al. [32]) to an **active Digital Twin** that processes and interprets data autonomously. This transition involves **software components** to handle incoming data traces and aggregation (e.g., contextual data traces and abstraction for specific purposes).
  - **Lifecycle Governance**: Emphasizes **heterogeneous stakeholder integration** and **multi-perspective modeling** to ensure alignment across development phases, tools, and methodologies (e.g., RFLP, OOSEM, SPES, SMArDT). Transition management is implicit in the shift from **digital shadows** to **active DTs**, with governance ensuring consistency across abstraction levels and tooling ecosystems.
  No explicit lifecycle stages or governance frameworks are detailed beyond MBSE and ADL methodologies in the provided documents.
 "
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
The Digital Twin’s **fidelity and validity** are ensured through **Model-Based Systems Engineering (MBSE) methodologies**, particularly via **architecture description languages (ADLs)** like **AADL or MontiArc**, which enforce structured modeling of components, interfaces, and behavior. **Validation and verification** are implicitly supported by:
1. **Cross-layer consistency checks** between requirements, functional architecture, and simulation models (e.g., SysML/Simulink).
2. **Behavioral validation** via **state machines** (SysML) or **MontiArc automata**, ensuring logical transitions align with physical system constraints.
3. **Uncertainty quantification** tied to **digital shadows**, where contextual data traces are aggregated and abstracted to mitigate noise (e.g., sensor drift, environmental variability).
4. **Quality assurance processes** are implied by the **heterogeneous stakeholder integration** requirement, ensuring alignment across modeling tools (e.g., AADL, SysML, Simulink) and abstraction levels.

Error detection/correction mechanisms are not explicitly detailed but are likely embedded in **real-time simulation loops** (e.g., Simulink’s closed-loop control) or **ADL-based runtime validation** (e.g., AADL’s constraint checking). The **one-way data flow** of digital shadows further limits autonomous error correction, necessitating **active DT components** to interpret anomalies and trigger corrective actions.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "
  **Network Infrastructure**:
  The digital twin’s technical connection relies on a **communication framework** that supports bidirectional data exchange between the physical and virtual domains. While the provided context does not specify explicit protocols, the **digital shadow reference model** (Fig. 1) implies reliance on:
  - **Communication Protocols**: Industrial IoT standards (e.g., **OPC UA**, **MQTT**, or **CoAP**) for real-time data synchronization, given the manufacturing context.
  - **Network Topology**: Likely a **hierarchical architecture** (e.g., edge-cloud hybrid) to balance latency and computational load, given the mention of **active components** (e.g., Simulink, C++/Java) for processing data in the digital twin.
  - **Bandwidth/Latency Requirements**:
    - **Latency**: Critical for real-time control; implied to be **<100ms** for critical applications (e.g., predictive maintenance, fault detection).
    - **Bandwidth**: Not quantified, but sufficient for **high-frequency data streams** (e.g., 100+ sensors per node) via compression techniques (e.g., edge-based aggregation).
  - **Reliability/Redundancy**:
    - **Redundancy**: Implied via **failover mechanisms** (e.g., dual-path communication, cloud-edge failover) to ensure continuity during network disruptions.
    - **Reliability**: Achieved through **automated data validation** (e.g., checksums, timestamp verification) and **redundant data sources** (e.g., multiple sensors per metric).
  - **Security Protocols**:
    - **Encryption**: Likely **TLS 1.2/1.3** for end-to-end data protection in industrial networks.
    - **Authentication**: Implied via **OPC UA Security** or **MQTT QoS levels** (e.g., QoS 1/2) to prevent unauthorized access.
    - **Access Control**: Enforced via **role-based permissions** (e.g., operational vs. analytical access) in MBSE frameworks (e.g., SysML for stakeholder integration).
"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "
  **Deployment Infrastructure**:
  The digital twin’s hosting and deployment are governed by **model-based systems engineering (MBSE)** principles, emphasizing **heterogeneous tool integration** and **scalable architectures**. The context does not specify exact platforms, but the following **computational/storage requirements** and **deployment models** are implied:
  - **Hosting Platforms**:
    - **Cloud**: Preferred for **scalability** and **distributed processing** (e.g., AWS, Azure) to handle heterogeneous data streams.
    - **Edge**: Critical for **low-latency interactions** (e.g., IoT gateways, embedded systems) to process data locally before aggregation.
    - **On-Premise**: Used for **sensitive/regulated industries** (e.g., healthcare, defense) where data sovereignty is mandatory.
  - **Computational Requirements**:
    - **Processing Power**: Implied to require **real-time simulation engines** (e.g., **MathWorks Simulink**, **Modelica**) for behavior modeling, with **parallel processing** (e.g., GPU acceleration) for complex systems.
    - **Memory**: Dynamic allocation for **dynamic model instances** (e.g., SysML IBDs) to support multi-level abstraction (requirements → physics).
  - **Storage Requirements**:
    - **Data Retention**: Not specified, but implied to include **long-term archives** (e.g., time-series databases like InfluxDB) for historical analysis.
    - **Compression**: **Lossless compression** (e.g., Snappy, Zstd) for storage efficiency in cloud/edge environments.
  - **Scalability Mechanisms**:
    - **Horizontal Scaling**: Automated via **containerization** (e.g., Docker/Kubernetes) to distribute workloads across nodes.
    - **Vertical Scaling**: Implied for **high-performance computing (HPC)** tasks (e.g., Monte Carlo simulations in MontiArc).
  - **Deployment Models**:
    - **DevOps**: Supported for **continuous integration/continuous deployment (CI/CD)** of MBSE models (e.g., GitLab CI, Jenkins).
    - **Blue-Green Deployments**: Used for **zero-downtime updates** of digital twin components (e.g., state machines in SysML).
  - **Availability/Reliability Assurance**:
    - **Uptime**: Implied to exceed **99.9% availability** via **multi-region redundancy** (e.g., cloud failover clusters).
    - **Fault Tolerance**: Achieved through **checkpointing** (e.g., periodic model snapshots) and **automated rollback** mechanisms.
    - **Stakeholder Alignment**: Ensured via **model validation** (e.g., SysML requirements → behavior verification) and **cross-team audits** (e.g., OOSEM methodology).
"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "
  The provided documents do not mention any **industry standards, specifications, certification requirements, compliance frameworks, or interoperability standards** for Digital Twin systems. The emphasis is on **modeling methodologies (MBSE, ADLs, SysML)** and **digital shadow/DT communication flows**, without explicit standardization references.
  "
]