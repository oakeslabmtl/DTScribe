// C3: Physical sensing components (inferred from digital shadow description)
instance PhysicalAssetDataCollector : DTDFVocab:SensingComponent [
    base:desc "Collects contextual data traces from the physical asset as part of the digital shadow one‑way data flow"
    DTDFVocab:producedData ContextualDataTransmitted
]

// C4: Physical-to-virtual interaction
instance ContextualDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalAssetDataCollector
]

// C10: Data (contextual data feeding the models)
instance ContextualData : DTDFVocab:Data [
    base:desc "Contextual data traces collected from the physical asset, used as input for all DT models"
    DTDFVocab:fromData ContextualDataTransmitted
    DTDFVocab:inputTo Enabler_ModelComposition
]

// C10: Models – Structural (ADLs)
instance StructuralModelACME : DTDFVocab:Model [
    base:desc "Structural model expressed in ACME ADL, defining components, interfaces and connectors"
    DTDFVocab:inputTo Enabler_ACMETool
]

instance StructuralModelAADL : DTDFVocab:Model [
    base:desc "Structural model expressed in AADL, capturing architectural elements of the system"
    DTDFVocab:inputTo Enabler_AADLTool
]

instance StructuralModelMontiArc : DTDFVocab:Model [
    base:desc "Structural model expressed in MontiArc ADL, representing component hierarchies"
    DTDFVocab:inputTo Enabler_MontiArcTool
]

instance StructuralModelSysMLIBD : DTDFVocab:Model [
    base:desc "Structural model expressed in SysML Internal Block Diagram, detailing blocks and connections"
    DTDFVocab:inputTo Enabler_SysMLTool
]

// C10: Models – Behavioral (state‑machine specifications)
instance BehavioralModelSysMLStateMachine : DTDFVocab:Model [
    base:desc "Behavioral model specified as a SysML v1.7 state‑machine diagram"
    DTDFVocab:inputTo Enabler_SysMLTool
]

instance BehavioralModelMontiArcAutomaton : DTDFVocab:Model [
    base:desc "Behavioral model expressed in MontiArc Automaton, defining automata semantics"
    DTDFVocab:inputTo Enabler_MontiArcTool
]

// C10: Models – Simulation (execution artifacts)
instance SimulationModelSimulink : DTDFVocab:Model [
    base:desc "Simulation model implemented in MathWorks Simulink, linked to behavioral specifications"
    DTDFVocab:inputTo Enabler_SimulinkEngine
]

instance SimulationModelCppCode : DTDFVocab:Model [
    base:desc "Custom simulation code written in C++, generated from MBSE artifacts"
    DTDFVocab:inputTo Enabler_CppRuntime
]

instance SimulationModelJavaCode : DTDFVocab:Model [
    base:desc "Custom simulation code written in Java, derived from behavioral models"
    DTDFVocab:inputTo Enabler_JavaRuntime
]

// C11: Enablers
instance Enabler_ACMETool : DTDFVocab:Enabler [
    base:desc "ACME ADL processing tool that parses and validates structural models"
    DTDFVocab:enables Service_ModelIntegration
]

instance Enabler_AADLTool : DTDFVocab:Enabler [
    base:desc "AADL analysis tool for architectural validation"
    DTDFVocab:enables Service_ModelIntegration
]

instance Enabler_MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc toolchain handling both structural and behavioral models"
    DTDFVocab:enables Service_ModelIntegration
]

instance Enabler_SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML modeling environment (e.g., Cameo) processing structural and state‑machine models"
    DTDFVocab:enables Service_ModelIntegration
]

instance Enabler_SimulinkEngine : DTDFVocab:Enabler [
    base:desc "Simulink simulation engine executing dynamic models"
    DTDFVocab:enables Service_SimulationExecution
]

instance Enabler_CppRuntime : DTDFVocab:Enabler [
    base:desc "C++ runtime environment for executing compiled simulation code"
    DTDFVocab:enables Service_CodeGeneration
]

instance Enabler_JavaRuntime : DTDFVocab:Enabler [
    base:desc "Java Virtual Machine for running Java‑based simulation artefacts"
    DTDFVocab:enables Service_CodeGeneration
]

instance Enabler_ModelComposition : DTDFVocab:Enabler [
    base:desc "Composition engine that integrates contextual data with multiple DT models across abstraction layers"
    DTDFVocab:enables Service_ModelIntegration
]

// C6: Services
instance Service_ModelIntegration : DTDFVocab:Service [
    base:desc "Integrates heterogeneous DT models (structural, behavioral, simulation) with contextual data"
    DTDFVocab:provides Insight_ModelCoherence
]

instance Service_SimulationExecution : DTDFVocab:Service [
    base:desc "Executes simulation models (Simulink, C++, Java) to predict system behaviour"
    DTDFVocab:provides Action_RunSimulation
]

instance Service_CodeGeneration : DTDFVocab:Service [
    base:desc "Generates executable code from MBSE models for deployment on target platforms"
    DTDFVocab:provides Insight_CodeGenerationSuccess
]

// C17: Insights / Actions
instance Insight_ModelCoherence : DTDFVocab:Insight [
    base:desc "Ensures consistency and coherence among the combined structural, functional and product‑level models"
]

instance Insight_CodeGenerationSuccess : DTDFVocab:Insight [
    base:desc "Indicates successful generation of executable code from the MBSE model set"
]

instance Action_RunSimulation : DTDFVocab:Action [
    base:desc "Triggers execution of the integrated simulation model to obtain predictive results"
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system’s orchestration is defined through Model‑Based Systems‑Engineering (MBSE) using languages such as SysML and architecture description languages (ADLs) like ACME, AADL, MontiArc, and SysML internal block diagrams. These ADLs model components, their interfaces, interconnections, and composition, providing a component‑and‑connector view that constitutes the integration backbone. Behavioral aspects can be refined with state‑machine specifications, Simulink models, or executable code in C++/Java, allowing heterogeneous toolchains to be linked. Coordination follows methodologies such as RFLP, OOSEM, SPES, or SMArDT, aligning functional, logical, and physical layers, and integrates heterogeneous stakeholder perspectives through a shared MBSE repository, thereby achieving system‑wide resource and component management."
]