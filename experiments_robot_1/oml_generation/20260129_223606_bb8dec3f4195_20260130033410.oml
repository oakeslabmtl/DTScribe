// C3: Physical sensing component representing the Simulink model source
instance SimulinkModelComponent : DTDFVocab:SensingComponent [
    base:desc "Component representing the Simulink model used for dynamic analysis, producing simulated data."
    DTDFVocab:producedData SimulinkSimulationDataTransmitted
]

// C4: Data transmitted from the Simulink model component
instance SimulinkSimulationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkModelComponent
]

// C10: Data instances produced from Simulink simulation
instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Simulation output data from the Simulink model for dynamic analysis."
    DTDFVocab:inputTo SimulinkTool, SimulinkCodeGenTool
    DTDFVocab:fromData SimulinkSimulationDataTransmitted
]

instance ModelBasedSpecData : DTDFVocab:Data [
    base:desc "Model-based specification data derived from SysML and MontiArc specifications."
    DTDFVocab:inputTo SysMLTool, ACMEArchTool, MontiArcTool
]

// C10: Model instances capturing structure and behavior
instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "Structural and functional architecture captured using SysML v1.7."
    DTDFVocab:inputTo SysMLTool
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "Behavioral refinement using MontiArc Automaton encoded as SysML state‑machine."
    DTDFVocab:inputTo MontiArcTool
]

instance SimulinkDynamicalModel : DTDFVocab:Model [
    base:desc "Dynamic analysis performed using MathWorks Simulink."
    DTDFVocab:inputTo SimulinkTool
]

// C11: Enabler instances for tooling and code generation
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML v1.7 modeling tool for functional and logical architectures."
    DTDFVocab:enables ModelValidationService
]

instance ACMEArchTool : DTDFVocab:Enabler [
    base:desc "ACME architecture description language tool for capturing system structure."
    DTDFVocab:enables ModelValidationService
]

instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton tool for formal behavior modeling."
    DTDFVocab:enables ModelValidationService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink tool for dynamic simulation."
    DTDFVocab:enables SimulationService, CodeGenerationService
]

instance SimulinkCodeGenTool : DTDFVocab:Enabler [
    base:desc "Simulink code generation tool for creating C++/Java executables."
    DTDFVocab:enables CodeGenerationService
]

instance CppCompilerTool : DTDFVocab:Enabler [
    base:desc "C++ compiler for compiling generated executables for deployment."
    DTDFVocab:enables DeploymentService
]

instance JavaCompilerTool : DTDFVocab:Enabler [
    base:desc "Java compiler for compiling generated executables for deployment."
    DTDFVocab:enables DeploymentService
]

// C6: Services that perform simulation and code generation
instance SimulationService : DTDFVocab:Service [
    base:desc "Performs dynamic simulation of the digital twin using Simulink."
    DTDFVocab:provides PredictiveSimulationInsight
]

instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Generates executable C++ or Java code from Simulink models."
    DTDFVocab:provides GenerateExecutableAction
]

instance ModelValidationService : DTDFVocab:Service [
    base:desc "Validates SysML and MontiArc models against requirements."
    DTDFVocab:provides ModelConsistencyInsight
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Deploys compiled executables to edge or cloud platforms."
    DTDFVocab:provides DeployExecutableAction
]

// C17: Insights and Actions
instance PredictiveSimulationInsight : DTDFVocab:Insight [
    base:desc "Provides predictive simulation insights from Simulink outputs."
]

instance ModelConsistencyInsight : DTDFVocab:Insight [
    base:desc "Confirms consistency between models and requirements."
]

instance DeployExecutableInsight : DTDFVocab:Insight [
    base:desc "Confirms successful deployment of executable artifacts."
]

instance GenerateExecutableAction : DTDFVocab:Action [
    base:desc "Generates executable artifacts in C++ or Java based on Simulink model."
    DTDFVocab:IsAutomatic true
]

instance DeployExecutableAction : DTDFVocab:Action [
    base:desc "Deploys executable artifacts to edge or cloud platforms at runtime."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin’s life‑cycle is derived from a multi‑level Model‑Based Systems Engineering (MBSE) approach: 1) *Requirements* are captured in a requirements repository. 2) *Functional architecture* is modelled with SysML, defining system functions and high‑level behaviour. 3) *Logical architecture* is expressed in architecture description languages such as MontiArc, AADL, ACME or SysML IBDs, representing components, connectors, interfaces and interrelations. 4) *Product/technical layer* implements the logical plan using simulation tools (e.g., Simulink) or general‑purpose code in C++ or Java. Transitions between phases are managed through model‑to‑model transformations and versioned model repositories, while governance is exercised by the engineering team at each release, ensuring traceability from requirements to executable artifacts."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin architecture is compliant with standard modelling languages: SysML (ISO/IEC 19510), ACME, AADL, MontiArc and SysML IBDs. These standards provide structural, behavioural and inter‑connectivity specifications, enabling interoperability with other MBSE tools and facilitating integration into industry processes. No explicit compliance frameworks or certification requirements are mentioned in the document."
]