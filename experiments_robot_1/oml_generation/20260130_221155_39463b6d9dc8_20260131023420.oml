// C3: Physical sensing components // Return code: 1 | Stderr:
instance Axis1PositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution absolute position encoder on the first vertical axis of the MABIX MAX 100 robot"
    DTDFVocab:producedData PositionDataTransmitted
]

// C4: Physical-to-virtual interaction
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Axis1PositionEncoder
]

// C10: Models/Data
instance PositionData : DTDFVocab:Data [
    base:desc "Real-time position measurement streamed from the encoder via MQTT"
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

instance MATLABSimulinkDynamicsModel : DTDFVocab:Model [
    base:desc "High-fidelity joint-friction dynamics model implemented in MATLAB/Simulink"
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

// C11: Enablers
instance SimulinkExecutionEnvironment : DTDFVocab:Enabler [
    base:desc "Simulink runtime environment that executes the dynamics model and friction estimation"
    DTDFVocab:enables JointFrictionIdentificationService
]

// C6: Services
instance JointFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous, physics-based identification of joint-friction coefficients using live encoder data"
    DTDFVocab:provides FrictionEstimateInsight, MotionProfileAdjustmentAction
]

// C17: Insights/Actions
instance FrictionEstimateInsight : DTDFVocab:Insight [
    base:desc "Insight into the current friction coefficient estimate for each joint, updated in real time"
]

instance MotionProfileAdjustmentAction : DTDFVocab:Action [
    base:desc "Action for CNC operators to refine motion profiles and improve closed-loop positioning accuracy"
    DTDFVocab:IsAutomatic false
]

// C5: Environment
instance RobotTwinEnvironment : DTDFVocab:Environment [
    base:desc "Digital twin environment for the first vertical axis of MABIX MAX 100 robot"
    base:contains Axis1PositionEncoder, MATLABSimulinkDynamicsModel, SimulinkExecutionEnvironment, JointFrictionIdentificationService
]