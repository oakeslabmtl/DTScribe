// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor I_M measuring real-time motor current"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor-mounted position encoder providing motor shaft angle r_M"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxSecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind gearbox providing gearbox output angle r_out"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxSecondaryEncoder
]

// C10: Models/Data (raw and derived)
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Raw motor current measurement I_M from sensor"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance MotorEncoderAngleData : DTDFVocab:Data [
    base:desc "Raw motor encoder angle r_M"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance GearboxEncoderAngleData : DTDFVocab:Data [
    base:desc "Raw gearbox encoder angle r_out"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque τ calculated from I_M, r_M and r_out"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω calculated from encoder angle rate"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

// C10: DataCalculation models
instance TorqueCalculationModel : DTDFVocab:Model [
    base:desc "Model that computes torque τ from motor current and encoder angles"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance AngularVelocityCalculationModel : DTDFVocab:Model [
    base:desc "Model that computes angular velocity ω from encoder angle time series"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

// C10: Friction simulation models
instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "White‑box friction model implementing Coulomb and viscous friction for the gearbox"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Friction model with Stribeck effect for gearbox"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Dahl friction model for gearbox"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "LuGre friction model for gearbox"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

// C10: Engineering SysML model
instance AxisSysMLModel : DTDFVocab:Model [
    base:desc "SysML structural model describing Axis, Motor and Gearbox composition"
    DTDFVocab:inputTo AssetAdministrationShellEnabler
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker for live streaming of sensor data to the digital twin"
    DTDFVocab:enables RealTimeFrictionIdentificationService,
                     DataAggregationService,
                     DashboardVisualizationService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for friction and calculation models"
    DTDFVocab:enables RealTimeFrictionIdentificationService,
                     ModelSwappingService,
                     ParameterUpdateService
]

instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard for unified live and simulated data visualization"
    DTDFVocab:enables DashboardVisualizationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell layer for model integration and exchange"
    DTDFVocab:enables ModelSwappingService
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time friction identification (static, kinetic, viscous) for the gearbox"
    DTDFVocab:provides FrictionParameterInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Automatic aggregation of live and simulated data traces"
    DTDFVocab:provides DataAggregationInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Visualization of live and simulated data in a unified dashboard"
    DTDFVocab:provides DeviationInsight
]

instance ModelSwappingService : DTDFVocab:Service [
    base:desc "Model swapping between white‑box and black‑box friction models"
    DTDFVocab:provides ModelUpdateAction
]

instance ParameterUpdateService : DTDFVocab:Service [
    base:desc "Generation of parameter updates for the robot controller"
    DTDFVocab:provides ParameterUpdateAction
]

// C17: Insights
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Extracted friction parameters are fed back to the robot controller to improve motion accuracy"
]

instance DataAggregationInsight : DTDFVocab:Insight [
    base:desc "Aggregated data traces enable comprehensive analysis of system behavior"
]

instance DeviationInsight : DTDFVocab:Insight [
    base:desc "Dashboard highlights deviations between simulated and measured behavior, guiding adjustments of control strategies"
]

// C17: Actions
instance ModelUpdateAction : DTDFVocab:Action [
    base:desc "Automatic swapping of simulation models (white‑box ↔ black‑box) for friction representation"
    DTDFVocab:IsAutomatic true
]

instance ParameterUpdateAction : DTDFVocab:Action [
    base:desc "Update robot controller parameters with identified friction coefficients"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time streaming during robot operation (data sampled at the controller rate, up to the robot’s maximum speed of 75 °/s)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A digital shadow consisting of a set of DataTraces linked to their Sources, Processing components (Simulation M, GW, GB) that consume input traces and produce simulated traces, and the underlying Engineering, Simulation and DataCalculation models; all orchestrated to provide friction identification and visualization."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin covers (1) design stage – MBSE using SysML to model the axis structure and behavior, (2) deployment stage – integration of sensors and Asset Administration Shells to expose data, (3) operation stage – continuous real‑time data acquisition, model execution and friction identification during machining, and (4) maintenance stage – ongoing model updates to accommodate wear and tool changes."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each DataPoint to its originating sensor and processing model; use of manufacturer‑provided parameters for dynamics; validation by comparing simulated friction‑augmented outputs with measured reference traces; capability to swap between analytical (white‑box) and data‑driven (black‑box) models to assess accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Live data are transmitted from the robot controller to the digital shadow over MQTT; models and metadata are exchanged via the Asset Administration Shell (AAS) framework."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach follows standard modeling and integration frameworks: SysML for system architecture, UML class diagrams for the Digital Shadow Reference Model, and Asset Administration Shell (AAS) as an Industry 4.0 standard for asset information exchange."
]