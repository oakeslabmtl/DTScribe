// C3: Physical sensing component // Return code: 1 | Stderr:
instance PhysicalArtefactSensor : DTDFVocab:SensingComponent [
    base:desc "Captures data from a physical artefact via an automated one-way data flow using the digital‑shadow concept."
    DTDFVocab:producedData PhysicalArtefactDataTransmitted
]

// C4: Data transmitted from the sensor
instance PhysicalArtefactDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalArtefactSensor
]

// C10: Data produced (aggregated contextual traces)
instance AggregatedContextualData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces derived from PhysicalArtefactSensor, used to feed simulation and verification models."
    DTDFVocab:inputTo KafkaConsumerEnabler, PostgreSQLStorageEnabler
    DTDFVocab:fromData PhysicalArtefactDataTransmitted
]

// C11: Enablers for data ingestion
instance KafkaConsumerEnabler : DTDFVocab:Enabler [
    base:desc "Apache Kafka consumer that ingests aggregated twin data for real‑time processing."
    DTDFVocab:enables DataIngestionService
]

instance PostgreSQLStorageEnabler : DTDFVocab:Enabler [
    base:desc "PostgreSQL database that stores aggregated twin data for long‑term analysis."
    DTDFVocab:enables DataIngestionService
]

// C6: Service for ingesting data
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service that ingests and stores aggregated twin data using Kafka and PostgreSQL."
    DTDFVocab:provides RealTimeDataInsight
]

// C17: Insight from data ingestion
instance RealTimeDataInsight : DTDFVocab:Insight [
    base:desc "Insight that provides real‑time status of twin data flow and quality."
]

// C10: Structural SysML model
instance StructuralSysMLModel : DTDFVocab:Model [
    base:desc "SysML structural model (with IBDs) of the twin’s component connector architecture."
    DTDFVocab:inputTo SysMLArchitecturalEnabler
]

// C10: Logical MontiArc model
instance LogicalMontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc component‑and‑connector model representing logical architecture."
    DTDFVocab:inputTo MontiArcAutomatonEnabler
]

// C10: Behavioural Simulink model
instance BehaviouralSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink block diagram implementing continuous‑time and discrete event dynamics."
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

// C10: CAD geometric model
instance CADModelEnabler : DTDFVocab:Enabler [
    base:desc "CAD modeling tool enabling creation of geometric representations."
    DTDFVocab:enables CADProcessingService
]

instance CADProcessingService : DTDFVocab:Service [
    base:desc "Service that processes CAD geometry data for the twin."
    DTDFVocab:provides CADProcessingInsight
]

instance CADProcessingInsight : DTDFVocab:Insight [
    base:desc "Insight on status of CAD geometry processing."
]

instance CADGeomModel : DTDFVocab:Model [
    base:desc "CAD-based geometric representation of twin’s physical counterpart."
    DTDFVocab:inputTo CADModelEnabler
] 

// C11: Cmd: SysML architectural tool enabler
instance SysMLArchitecturalEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 tool for creating architectural models and IBDs."
    DTDFVocab:enables ModelingService
]

// C6: Service for managing SysML structural models
instance ModelingService : DTDFVocab:Service [
    base:desc "Service that manages SysML structural models within the twin."
    DTDFVocab:provides ModelingInsight
]

// C17: Insight on structural models
instance ModelingInsight : DTDFVocab:Insight [
    base:desc "Insight on completeness and correctness of structural models."
]

// C11: MontiArc automaton tooling enabler
instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc tool for modeling component‑connector and state‑machine behavior."
    DTDFVocab:enables MontiArcSimulationService
]

// C6: Service that simulates MontiArc behavioral models
instance MontiArcSimulationService : DTDFVocab:Service [
    base:desc "Service that simulates MontiArc behavioral models."
    DTDFVocab:provides MontiArcSimulationInsight
]

// C17: Insight from MontiArc simulation
instance MontiArcSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from MontiArc behavioral simulation."
]

// C11: Simulink runtime enabler
instance SimulinkRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for runtime simulation of the twin."
    DTDFVocab:enables SimulationService
]

// C6: Service that performs simulation with Simulink
instance SimulationService : DTDFVocab:Service [
    base:desc "Service that performs numerical simulation of control algorithms and validation using Simulink."
    DTDFVocab:provides SimulationResultInsight
]

// C17: Insight from Simulink simulation
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight deriving simulation results of the twin’s behavior."
]

// C11: C++ code generation enabler
instance CppCodeGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Tool that generates C++ code from Simulink models."
    DTDFVocab:enables CodeGenerationService
]

// C11: Java code generation enabler
instance JavaCodeGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Tool that generates Java code from Simulink models."
    DTDFVocab:enables CodeGenerationService
]

// C6: Service that generates implementation code
instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Service that compiles and packages generated C++ or Java code into executable artifacts."
    DTDFVocab:provides CodeGenerationAction
]

// C17: Action for code generation
instance CodeGenerationAction : DTDFVocab:Action [
    base:desc "Automated generation of implementation code from twin models."
    DTDFVocab:IsAutomatic true
]

// C11: OpenModelica compiler enabler
instance OpenModelicaCompilerEnabler : DTDFVocab:Enabler [
    base:desc "OpenModelica compiler used for physics‑based validation of models."
    DTDFVocab:enables ValidationService
]

// C6: Service for validation
instance ValidationService : DTDFVocab:Service [
    base:desc "Service that verifies twin models against physics‑based simulations."
    DTDFVocab:provides VerificationResultInsight
]

// C17: Insight from validation
instance VerificationResultInsight : DTDFVocab:Insight [
    base:desc "Insight indicating model verification status."
]

// C11: Docker container enabler
instance DockerContainerEnabler : DTDFVocab:Enabler [
    base:desc "Docker container runtime for deploying twin services."
    DTDFVocab:enables DeploymentService
]

// C11: Kubernetes cluster enabler
instance KubernetesClusterEnabler : DTDFVocab:Enabler [
    base:desc "Kubernetes cluster orchestrating twin deployment."
    DTDFVocab:enables DeploymentService
]

// C6: Service for deploying twin components
instance DeploymentService : DTDFVocab:Service [
    base:desc "Service that orchestrates deployment of twin components via Docker/Kubernetes."
    DTDFVocab:provides DeploymentAction
]

// C17: Action for deployment
instance DeploymentAction : DTDFVocab:Action [
    base:desc "Automated deployment of twin services to cloud infrastructure."
    DTDFVocab:IsAutomatic true
]

// C11: MQTT broker enabler
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker that publishes twin data streams in real‑time."
    DTDFVocab:enables RuntimeStreamingService
]

// C6: Service that streams data via MQTT
instance RuntimeStreamingService : DTDFVocab:Service [
    base:desc "Service that publishes real-time twin data to subscribed clients."
    DTDFVocab:provides RealTimeStreamAction
]

// C17: Action for streaming data
instance RealTimeStreamAction : DTDFVocab:Action [
    base:desc "Action that publishes twin data to MQTT topics."
    DTDFVocab:IsAutomatic true
]

// C11: GitLab CI/CD enabler
instance GitLabCICDEnabler : DTDFVocab:Enabler [
    base:desc "GitLab CI/CD pipeline that integrates model and code artifacts."
    DTDFVocab:enables ContinuousIntegrationService
]

// C6: Service for CI/CD
instance ContinuousIntegrationService : DTDFVocab:Service [
    base:desc "Service that triggers automated builds and tests for twin models and code."
    DTDFVocab:provides ContinuousIntegrationAction
]

// C17: Action for CI/CD execution
instance ContinuousIntegrationAction : DTDFVocab:Action [
    base:desc "Automated CI pipeline execution."
    DTDFVocab:IsAutomatic true
]