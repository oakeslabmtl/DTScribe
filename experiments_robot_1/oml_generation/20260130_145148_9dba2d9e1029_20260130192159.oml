// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Internal sensor measuring motor electric current of the robotic manipulator."
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance MotorAngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Internal sensor measuring motor angular velocity of the robot joints."
    DTDFVocab:producedData MotorAngularVelocityDataTransmitted
]

instance AxisPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Internal sensor measuring first‑axis position of the robot manipulator."
    DTDFVocab:producedData AxisPositionDataTransmitted
]

// C4: Physical-to-virtual interaction
instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance MotorAngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorAngularVelocitySensor
]

instance AxisPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AxisPositionSensor
]

// C10: Data
instance InputCurrentData : DTDFVocab:Data [
    base:desc "Raw measurement trace of motor current, filtered and forwarded via MQTT."
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo DataProcessingEngine
]

instance MotorAngularVelocityData : DTDFVocab:Data [
    base:desc "Raw measurement trace of motor angular velocity, filtered and forwarded via MQTT."
    DTDFVocab:fromData MotorAngularVelocityDataTransmitted
    DTDFVocab:inputTo DataProcessingEngine
]

instance AxisPositionData : DTDFVocab:Data [
    base:desc "Raw measurement trace of first‑axis position, filtered and forwarded via MQTT."
    DTDFVocab:fromData AxisPositionDataTransmitted
    DTDFVocab:inputTo DataProcessingEngine
]

// C10: Models/Data
instance LowPassFilterModel : DTDFVocab:Model [
    base:desc "Low‑pass filter applied to raw current signal during preprocessing before MQTT publishing."
    DTDFVocab:inputTo DataProcessingEngine
]

instance WhiteBoxFrictionSimulinkModel : DTDFVocab:Model [
    base:desc "Physics‑based white‑box friction model implemented in Simulink, capturing nonlinear joint friction dependent on load and environment."
    DTDFVocab:inputTo DataProcessingEngine
]

instance BlackBoxNeuralNetworkFrictionModel : DTDFVocab:Model [
    base:desc "Data‑driven black‑box friction model based on a neural network, retrained with newly arriving data."
    DTDFVocab:inputTo DataProcessingEngine
]

// C11: Enablers
instance DataProcessingEngine : DTDFVocab:Enabler [
    base:desc "Processing component that consumes input data traces, applies low‑pass filtering, and executes physics‑based Simulink and neural‑network friction models."
    DTDFVocab:enables RealTimeFrictionMonitoringService,
                     AdaptiveModelUpdateService,
                     PredictiveMaintenanceService,
                     VisualizationDashboardService,
                     SimulationOptimizationService
]

// C6: Services
instance RealTimeFrictionMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of internal joint friction using combined white‑box and black‑box model outputs."
    DTDFVocab:provides FrictionAnomalyInsight
]

instance AdaptiveModelUpdateService : DTDFVocab:Service [
    base:desc "Automatically adapts physics‑based and data‑driven friction models when deviations are detected."
    DTDFVocab:provides ModelAdaptationAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance and fault detection based on deviations in friction behavior."
    DTDFVocab:provides MaintenanceAlertAction
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Visualizes measured, simulated and reference values on a Thingsboard dashboard."
    DTDFVocab:provides VisualizationInsight
]

instance SimulationOptimizationService : DTDFVocab:Service [
    base:desc "Simulation‑driven optimization of machining parameters to reduce CO₂ emissions and improve product quality."
    DTDFVocab:provides OptimizationAction
]

// C17: Insights/Actions
instance FrictionAnomalyInsight : DTDFVocab:Insight [
    base:desc "Detection of abnormal friction behavior indicating potential wear or lubrication issues."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides visual representation of measured vs simulated friction data for operator analysis."
]

instance ModelAdaptationAction : DTDFVocab:Action [
    base:desc "Retrains or updates the friction models with latest sensor data."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceAlertAction : DTDFVocab:Action [
    base:desc "Generates maintenance work order when friction deviation exceeds thresholds."
    DTDFVocab:IsAutomatic true
]

instance OptimizationAction : DTDFVocab:Action [
    base:desc "Adjusts machining parameters based on simulation results to optimize CO₂ emissions and product quality."
    DTDFVocab:IsAutomatic false
]

// Additional context
instance RobotManufacturingEnvironment : DTDFVocab:Environment [
    base:contains InputCurrentSensor,
                     MotorAngularVelocitySensor,
                     AxisPositionSensor,
                     DataProcessingEngine
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin processes a continuous data stream from robot sensors in real time to identify joint friction during runtime. Calculations must respect the control system’s dead‑time, implying that latency must be low enough for the twin’s outputs to be used for immediate compensation within the control loop. Synchronisation is event‑driven, triggered by each sensor update, with no explicit fixed sampling period stated in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a model‑driven architecture: a SysML component‑connector model describes the robot’s structure, while executable Simulink friction models are encapsulated as FMUs and integrated via the Functional Mock‑up Interface (FMI). Both are wrapped inside an Asset Administration Shell (AAS). Live sensor data are streamed over MQTT into a ThingsBoard IoT platform, where a processing pipeline consumes the data, runs the simulation models, updates the AAS‑based digital shadow, and forwards the results to a visualization dashboard. Coordination is achieved by the AAS executor that triggers model execution upon new data, providing a unified orchestration of models, data ingestion, and storage."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The development lifecycle of a Digital Twin follows the MBSE abstraction hierarchy described in Document 1: (1) Requirements level, (2) Functional architecture, (3) Logical architecture, and (4) Product/technical layer. At each stage the twin is represented by a different modelling artefact – e.g., SysML requirement diagrams, functional block diagrams, logical component‑connector models (SysML IBDs, ACME, AADL, MontiArc) and finally concrete code or simulation models (Simulink, C++, Java). Transition between stages is governed by traceability links defined in the Digital Shadow reference model (Document 2) that map data traces to the processing components that generated them, preserving provenance across the lifecycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by combining validated white‑box simulation models (e.g., Simulink) with calibrated black‑box data‑driven models; the latter are updated continuously as new measurement data arrive, allowing parameter updates or retraining of neural‑network‑based models. Validation and verification are addressed through traceability of model transformations (e.g., from SysML to simulation models) and the ‘originates‑from’ association that links output data traces back to their generating processing components and input sources. Uncertainty arising from load, temperature or time‑dependent friction effects is mitigated by the dynamic adaptation loop, and real‑time execution constraints (dead‑time of the control system) are considered to guarantee that model updates meet the required latency for control. Quality‑assurance processes include continuous monitoring of traceability links and verification of transformations to maintain correctness of the digital twin’s computational artefacts."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system uses the MQTT protocol for data transport, forming a star‑like topology where a central MQTT broker mediates communication between the preprocessing component, the AAS Executor and the ThingsBoard visualization service. Data are published as untyped JSON payloads on hierarchically structured topics, exploiting MQTT’s publish‑subscribe semantics and optional read/write permissions per topic. No explicit bandwidth, latency, reliability, redundancy, or security specifications are provided in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration relies on MQTT for data exchange between the robot’s sensors and the ThingsBoard platform, enabling scalable IoT connectivity. The digital shadow is exposed through an Asset Administration Shell (AAS), conforming to emerging Industry 4.0 standards for interoperability. Model integration uses the FMI standard to combine SysML structural models with Simulink behavioral models, facilitating seamless coupling with external simulation tools and enterprise IT systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin relies on several modelling and communication standards. Structural and behavioural models are expressed with the Systems Modelling Language (SysML) and the Unified Modelling Language (UML) class diagrams, which are OMG standards. Component‑&‑connector architectures are represented with standardized ADLs such as ACME, AADL and MontiArc. Executable simulation models may be built with MathWorks Simulink, a widely adopted tool for continuous‑time simulation. Data exchange between the physical asset and the twin follows the MQTT messaging protocol; open‑source implementations such as Mosquitto (MQTT broker) and IoT platforms like ThingsBoard are cited as example technologies. Conformance to the Digital Shadow reference model is achieved through an explicit conformance relation, which aligns the concrete Digital Twin model with the abstract reference definitions."
]