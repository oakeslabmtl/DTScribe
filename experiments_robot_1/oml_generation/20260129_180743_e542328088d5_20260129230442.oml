instance PhysicalSystemMeasurementSensor : DTDFVocab:SensingComponent [
    base:desc "Sensing component for physical system measurements"
    DTDFVocab:producedData PhysicalMeasurementDataTransmitted
]

instance PhysicalMeasurementDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemMeasurementSensor
]

instance PhysicalMeasurementData : DTDFVocab:Data [
    base:desc "Data sourced from physical system measurements via automated one-way data flows"
    DTDFVocab:fromData PhysicalMeasurementDataTransmitted
    DTDFVocab:inputTo CppProgrammingLanguageEnabler, JavaProgrammingLanguageEnabler
]

instance SysMLModel : DTDFVocab:Model [
    base:desc "SysML for structural and behavioral modeling, including Internal Block Diagrams for component interfaces and state machines for dynamic behavior"
    DTDFVocab:inputTo SysMLEnabler
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME for component-based system architecture"
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL for component-based system architecture"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc for component-based system architecture"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink for analytical models"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for system modeling in Model-Based Systems Engineering (MBSE) methodologies"
    DTDFVocab:enables SystemModelingService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation"
    DTDFVocab:enables SimulationService
]

instance CppProgrammingLanguageEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for integrated heterogeneous modeling tools"
    DTDFVocab:enables DataProcessingService
]

instance JavaProgrammingLanguageEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for integrated heterogeneous modeling tools"
    DTDFVocab:enables DataProcessingService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component-based system architecture"
    DTDFVocab:enables ArchitectureDescriptionService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component-based system architecture"
    DTDFVocab:enables ArchitectureDescriptionService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component-based system architecture"
    DTDFVocab:enables ArchitectureDescriptionService
]

instance RFLPEnabler : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements, Functions, Logics, Physics) methodology for managing complexity across abstraction levels"
    DTDFVocab:enables ComplexityManagementService
]

instance OOSEMEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for managing complexity across abstraction levels"
    DTDFVocab:enables ComplexityManagementService
]

instance SPESEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for managing complexity across abstraction levels"
    DTDFVocab:enables ComplexityManagementService
]

instance SMArDTEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for managing complexity across abstraction levels"
    DTDFVocab:enables ComplexityManagementService
]

instance SystemModelingService : DTDFVocab:Service [
    base:desc "Service for system modeling using SysML"
    DTDFVocab:provides DynamicAnalysisInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for simulation using MathWorks Simulink"
    DTDFVocab:provides DynamicAnalysisInsight
]

instance DataProcessingService : DTDFVocab:Service [
    base:desc "Service for processing physical measurement data using C++ and Java"
    DTDFVocab:provides DataInsight
]

instance ArchitectureDescriptionService : DTDFVocab:Service [
    base:desc "Service for component-based system architecture description using ADLs"
    DTDFVocab:provides ArchitectureInsight
]

instance ComplexityManagementService : DTDFVocab:Service [
    base:desc "Service for managing complexity across abstraction levels using methodologies like RFLP, OOSEM, SPES, SMArDT"
    DTDFVocab:provides ComplexityInsight
]

instance DynamicAnalysisInsight : DTDFVocab:Insight [
    base:desc "Dynamic analysis of behavioral models combined with simulation environments for dynamic analysis"
]

instance DataInsight : DTDFVocab:Insight [
    base:desc "Insight from processed physical measurement data"
]

instance ArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight from component-based system architecture description"
]

instance ComplexityInsight : DTDFVocab:Insight [
    base:desc "Insight from managing complexity across abstraction levels"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to industry standards including SysML for model-based systems engineering, ACME, AADL, and MontiArc as architecture description languages (ADLs) to model components, interfaces, interconnections, and composition across multiple abstraction levels (requirements, functional architecture, logical architecture, and product/technical layer), ensuring interoperability and structured system description."
]