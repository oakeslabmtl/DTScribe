instance ContextualDataSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing contextual data traces from physical systems"
    DTDFVocab:producedData ContextualDataTransmission
]

instance ContextualDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContextualDataSensor
]

instance ContextualData : DTDFVocab:Data [
    base:desc "Contextual data traces from physical systems, aggregated and abstracted for specific purposes"
    DTDFVocab:fromData ContextualDataTransmission
    DTDFVocab:inputTo SysMLEnabler, ACMEEnabler, AADLEnabler, MontiArcEnabler, SimulinkEnabler, CppEnabler, JavaEnabler, AdditionalSimulationToolsEnabler
]

instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML model for requirements abstraction level"
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model for functional architecture abstraction level"
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLLogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model for logical architecture abstraction level"
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLProductTechnicalLayerModel : DTDFVocab:Model [
    base:desc "SysML model for product/technical layer abstraction level"
    DTDFVocab:inputTo SysMLEnabler
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME architecture description language for component & connector architecture"
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL architecture description language for component & connector architecture"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description language for component & connector architecture"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams for component & connector architecture"
    DTDFVocab:inputTo SysMLEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavioral modeling"
    DTDFVocab:inputTo SysMLEnabler
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink combined with C++ and Java for detailed behavior simulation"
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler, JavaEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for systems engineering modeling"
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME architecture description language for component & connector perspectives"
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL architecture description language for component & connector perspectives"
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc architecture description language for component & connector perspectives"
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for behavioral simulation"
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ general-purpose programming language"
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java general-purpose programming language"
]

instance AdditionalSimulationToolsEnabler : DTDFVocab:Enabler [
    base:desc "Additional simulation tools and methods referenced in [29], [30]"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved via architecture description languages (ADLs) including ACME, AADL, MontiArc, and SysML IBDs for defining component interfaces, interconnections, and composition; combined with MathWorks Simulink, simulation tools and methods, and general-purpose programming languages such as C++ or Java to handle heterogeneous stakeholders and perspectives across different modeling notations."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to industry standards including SysML [17] for systems engineering modeling, ACME [23], AADL [24], and MontiArc [25], [26] for architecture description languages (ADLs), with specific use of SysML v1.7 for state machine behavior modeling. These standards facilitate interoperability among heterogeneous stakeholders and perspectives [31]."
]