// C3: Physical sensing components
instance MotorPositionEncoderFront : DTDFVocab:SensingComponent [
    base:desc "Position encoder located on the motor shaft providing real-time angular measurements for the first axis of MABI MAX 100 robot"
    DTDFVocab:producedData MotorPositionDataFront
]

instance MotorPositionEncoderRear : DTDFVocab:SensingComponent [
    base:desc "Position encoder located behind the gearbox providing real-time angular measurements for the first axis of MABI MAX 100 robot"
    DTDFVocab:producedData MotorPositionDataRear
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input current to the permanent magnet synchronous motor for the first axis of MABI MAX 100 robot"
    DTDFVocab:producedData MotorCurrentData
]

// C4: Physical-to-virtual interaction
instance MotorPositionDataFront : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoderFront
    base:desc "Time-series data stream of angular position measurements from front encoder transmitted via MQTT protocol"
]

instance MotorPositionDataRear : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoderRear
    base:desc "Time-series data stream of angular position measurements from rear encoder transmitted via MQTT protocol"
]

instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
    base:desc "Time-series data stream of input current measurements transmitted via MQTT protocol"
]

// C10: Models/Data
instance FrictionIdentificationModel : DTDFVocab:Model [
    base:desc "Digital Shadow model implementing friction identification for the first axis using RFLP methodology (Requirements, Functions, Logics, Physics) with SysML state machines"
    DTDFVocab:inputTo SysMLModelingTool, SimulinkSimulationEngine
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces including joint friction parameters, operational logs, and environmental parameters for the first axis"
    DTDFVocab:fromData MotorPositionDataFront, MotorPositionDataRear, MotorCurrentData
    DTDFVocab:inputTo SysMLModelingTool, SimulinkSimulationEngine
]

// C11: Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML v1.7 toolset for multi-layered system description (requirements, functional/logical architecture) and behavioral modeling via state machines"
    DTDFVocab:enables MonitoringService, VisualizationService
]

instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed behavioral modeling, simulation, and code generation (C++/Java) of friction dynamics"
    DTDFVocab:enables MonitoringService
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for formal behavioral modeling and automated state transitions of the Digital Shadow system"
    DTDFVocab:enables MonitoringService
]

instance SiemensSinumerik840Dsl : DTDFVocab:Enabler [
    base:desc "Siemens SINUMERIK 840D sl controller accepting position, speed, and acceleration inputs with defined physical limitations for the permanent magnet synchronous motor"
    DTDFVocab:enables ActuationControlService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time acquisition and aggregation of contextual data traces (joint friction in first axis) via sensor-based data streams"
    DTDFVocab:provides FrictionIdentificationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Presentation of friction identification results in a dashboard for stakeholders leveraging aggregated and abstracted data"
    DTDFVocab:provides FrictionVisualizationInsight
]

instance ActuationControlService : DTDFVocab:Service [
    base:desc "Control interface accepting position, speed, and acceleration inputs with defined physical limitations (maximum working range and speed constraints)"
    DTDFVocab:provides MotorControlAction
]

// C17: Insights/Actions
instance FrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Identified friction characteristics and dynamics for the first axis of MABI MAX 100 robot based on aggregated sensor data"
]

instance FrictionVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of friction identification results in a stakeholder-accessible dashboard"
]

instance MotorControlAction : DTDFVocab:Action [
    base:desc "Automated control of permanent magnet synchronous motor based on position, speed, and acceleration inputs"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor controlled by Siemens SINUMERIK 840D sl with defined physical limitations including maximum working range and speed constraints"
]

// C1: Components
instance FirstAxisDigitalShadow : DTDFVocab:Component [
    base:desc "Digital Shadow instance for the first vertical axis of MABI MAX 100 robot implementing one-to-one mapping with physical component for friction identification"
]

instance MabiMax100Robot : DTDFVocab:Component [
    base:desc "Six-axis serial robot MABI MAX 100 designed for complex manufacturing tasks with high-precision motion control"
]

// C16: Environment
instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:desc "Complex manufacturing environment where MABI MAX 100 robot operates with high-precision motion requirements"
    base:contains MabiMax100Robot, PermanentMagnetSynchronousMotor, FirstAxisDigitalShadow
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin constellation** in this context is implicitly defined by the **Model-Based Systems Engineering (MBSE) framework**, which orchestrates the system through **multi-notation modeling** (e.g., SysML for architecture, Simulink/MontiArc for behavior, and general-purpose languages like C++/Java for implementation). The **architecture patterns** rely on **architecture description languages (ADLs)** such as ACME, AADL, or MontiArc to define **component integration** (interfaces, interconnections, and composition) and **behavioral modeling** (e.g., state machines in SysML v1.7 or MontiArc Automaton). **Resource management** is not explicitly detailed, but the integration of **heterogeneous tools and stakeholders** implies a **service-oriented or microservice-like coordination** mechanism to ensure consistency across layers. The document does not specify system-wide orchestration protocols (e.g., event-driven, publish-subscribe) but emphasizes the need for **active components** (e.g., DTs) to process and interpret data flows, contrasting with passive digital shadows."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed through **comparative analysis of simulated data versus measured data**, particularly to identify discrepancies like **friction effects**. No formal **validation and verification (V&V) methods**, **uncertainty quantification**, or **error correction mechanisms** are explicitly described. Quality assurance relies on **real-time data alignment** between the Digital Twin and physical system, with no mention of formal verification, statistical validation, or structured quality control processes."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with external systems through **MQTT-based streaming** of sensor time-series data from the physical machine (e.g., Siemens SINUMERIK 840D sl controller). This implies a **real-time data exchange protocol** for sensor telemetry, though no additional protocols (e.g., OPC UA, REST) are explicitly mentioned. The system’s dependency on the **Siemens SINUMERIK 840D sl** controller highlights a **hardware-specific integration** for manufacturing use cases. Interoperability with other Digital Twins or enterprise systems is not detailed, but the MBSE approach suggests potential for **standardized modeling notations (SysML, ADLs)** to facilitate cross-system compatibility. No explicit enterprise integration patterns (e.g., ERP, MES) are referenced."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE)** standards, particularly leveraging **SysML (Systems Modeling Language)** for system modeling and **Architecture Description Languages (ADLs)** such as **ACME**, **AADL**, and **MontiArc** for component-based architectural descriptions. Interoperability is facilitated through standardized modeling notations (e.g., **SysML IBDs**) and integration with simulation tools like **MathWorks Simulink**, ensuring compliance with industry practices for system modeling. While specific **certification frameworks** or **compliance requirements** are not explicitly mentioned, the use of **SysML v1.7** (which includes state machines for behavioral modeling) and **ADLs** suggests alignment with **ISO/IEC 15288 (Systems and Software Engineering)** and **IEEE standards** for systems engineering. **Interoperability standards** are implied through the integration of heterogeneous tools and methodologies, though no explicit protocols (e.g., OPC UA, MTConnect) are referenced in the provided context."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system described in the provided documents incorporates **safety-critical considerations** through the use of **safety cells** in robotic applications (e.g., the **MABI robotic arm**, referenced in [44]), which are physically enclosed workspaces designed to protect operators from hazardous motion. Additionally, the system leverages **MQTT (Message Queuing Telemetry Transport)** ([52]) for secure, lightweight data streaming between components, ensuring real-time communication while adhering to constrained network environments. However, the documents do not specify **cybersecurity protocols** (e.g., encryption, authentication, or compliance with standards like IEC 62443), **access control mechanisms**, **threat mitigation strategies**, or **risk assessment methodologies**. The **Automation Pyramid** ([42]) is referenced in the context of Digital Shadows but lacks explicit details on safety or security implementations. No evidence of **fail-safe mechanisms**, **data protection regulations**, or **consent management** is provided."
]