// C3: Physical sensing component
instance PhysicalStateSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Automated one‑way sensing that captures state information from the physical object to create a digital shadow consisting of contextual data traces."
    DTDFVocab:producedData PhysicalToDigitalShadowData
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance PhysicalToDigitalShadowData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalStateSensingComponent
]

// C5: Data
instance AggregatedContextualData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces derived from the digital shadow, used as input for MBSE models."
    DTDFVocab:fromData PhysicalToDigitalShadowData
    DTDFVocab:inputTo SysMLModelingEnabler, SimulinkSimulationEnabler, CodeExecutionEnabler
]

// C10: Models/Data – Structural and behavioral models
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram representing components, interfaces, and connectors."
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME model describing component hierarchy and connector topology."
    DTDFVocab:inputTo ACMEFrameworkEnabler
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL model capturing software and hardware architecture."
    DTDFVocab:inputTo AADLToolEnabler
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "MontiArc component model with automaton behavior."
    DTDFVocab:inputTo MontiArcFrameworkEnabler
]

instance StateMachineBehaviorModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state‑machine model (or MontiArc Automaton) defining system behavior."
    DTDFVocab:inputTo SysMLModelingEnabler, MontiArcFrameworkEnabler
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "Simulink simulation model refining behavior of the digital twin."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance CppExecutableModel : DTDFVocab:Model [
    base:desc "C++ executable implementation of model logic."
    DTDFVocab:inputTo CodeExecutionEnabler
]

instance JavaExecutableModel : DTDFVocab:Model [
    base:desc "Java executable implementation of model logic."
    DTDFVocab:inputTo CodeExecutionEnabler
]

// C11: Enablers – Tooling and technological enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML toolchain used for requirements, functional, logical and product layer modeling."
    DTDFVocab:enables ModelIntegrationService
]

instance ACMEFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "ACME architecture description language framework for component and connector definition."
    DTDFVocab:enables ModelIntegrationService
]

instance AADLToolEnabler : DTDFVocab:Enabler [
    base:desc "AADL toolset for modeling software and hardware architectures."
    DTDFVocab:enables ModelIntegrationService
]

instance MontiArcFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc framework for component and automaton modeling."
    DTDFVocab:enables ModelIntegrationService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed behavioral simulation."
    DTDFVocab:enables SimulationExecutionService
]

instance CodeExecutionEnabler : DTDFVocab:Enabler [
    base:desc "C++/Java runtime environment for executing compiled model code."
    DTDFVocab:enables CodeExecutionService
]

// C6: Services
instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Integrates heterogeneous MBSE models (SysML, ACME, AADL, MontiArc) ensuring consistency and traceability across layers."
    DTDFVocab:provides TraceabilityInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Executes simulation models (e.g., Simulink) to predict system behavior and validate fidelity."
    DTDFVocab:provides SimulationInsight
]

instance CodeExecutionService : DTDFVocab:Service [
    base:desc "Runs compiled C++ or Java model implementations for real‑time evaluation."
    DTDFVocab:provides ModelEvolutionAction
]

// C17: Insights
instance TraceabilityInsight : DTDFVocab:Insight [
    base:desc "Insight that preserves traceability from digital‑shadow data to model elements across requirements, functional and logical layers."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulation results that validates the correctness of behavioral models."
]

// C17: Actions
instance ModelEvolutionAction : DTDFVocab:Action [
    base:desc "Action to update underlying physics‑based or simulation models when the physical system evolves."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The document states that a Digital Twin can provide active components that interpret and process incoming data and can push data back to the physical system, unlike a digital shadow. However, it does not detail command types, control message formats, validation and authentication mechanisms, feedback systems, conflict resolution, or command execution confirmation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the Model‑Based Systems‑Engineering (MBSE) abstraction hierarchy: a requirements stage, a functional‑architecture stage, a logical‑architecture stage, and a product/technical stage. At the requirements stage the Twin is represented by SysML requirement diagrams; at the functional‑architecture stage by SysML internal block diagrams; at the logical‑architecture stage by component‑connector models expressed in ADLs such as ACME, AADL or MontiArc; and at the product/technical stage by detailed simulation models (e.g., MathWorks Simulink) or executable code (C++/Java). Transitions between stages are managed by traceability links that map artifacts from one abstraction to the next, following the R‑F‑L‑P (Requirements, Functions, Logics, Physics) methodology, and lifecycle governance is achieved through maintaining these links and stakeholder‑specific views."
]