// ------------------------------------------------------------
// C3: Physical sensing components
// ------------------------------------------------------------

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring input current I_M on the permanent‑magnet synchronous motor"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor shaft of the first vertical axis"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder located behind the cycloidal gearbox"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance ControllerDerivedSensor : DTDFVocab:SensingComponent [
    base:desc "Controller‑derived sensor providing torque, angular velocity and acceleration computed from motor current and encoder data"
    DTDFVocab:producedData DerivedMotionDataTransmitted
]

// ------------------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// ------------------------------------------------------------

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

instance DerivedMotionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ControllerDerivedSensor
]

// ------------------------------------------------------------
// C10: Data (traces) produced from sensors
// ------------------------------------------------------------

instance MeasuredCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current trace I_M streamed live via MQTT"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTEnabler, DashboardEnabler
]

instance MeasuredMotorPositionData : DTDFVocab:Data [
    base:desc "Measured motor shaft position from the motor encoder"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MQTTEnabler, DashboardEnabler
]

instance MeasuredGearboxPositionData : DTDFVocab:Data [
    base:desc "Measured gearbox output position from the secondary encoder"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MQTTEnabler, DashboardEnabler
]

instance MeasuredTorqueData : DTDFVocab:Data [
    base:desc "Derived torque trace computed by the controller"
    DTDFVocab:fromData DerivedMotionDataTransmitted
    DTDFVocab:inputTo MQTTEnabler, DashboardEnabler
]

instance MeasuredAngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity trace computed by the controller"
    DTDFVocab:fromData DerivedMotionDataTransmitted
    DTDFVocab:inputTo MQTTEnabler, DashboardEnabler
]

instance MeasuredAccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration trace computed by the controller"
    DTDFVocab:fromData DerivedMotionDataTransmitted
    DTDFVocab:inputTo MQTTEnabler, DashboardEnabler
]

// ------------------------------------------------------------
// C10: Models / Data (engineering, simulation, calculation)
// ------------------------------------------------------------

instance EngineeringModelSysMLBlockDef : DTDFVocab:Model [
    base:desc "SysML Block Definition Diagram describing structure of the first vertical axis of the MABI MAX 100 robot"
    DTDFVocab:inputTo SysMLEnabler
]

instance EngineeringModelSysMLIBD : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram showing flow ports of motor, gear transmission and cycloidal gearbox"
    DTDFVocab:inputTo SysMLEnabler
]

instance SimulationModelMotorSimulink : DTDFVocab:Model [
    base:desc "MathWorks Simulink model of the permanent‑magnet synchronous motor (with optional friction)"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulationModelGearwheelSimulink : DTDFVocab:Model [
    base:desc "Simulink model of the intermediate gearwheel (without friction) in the transmission"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulationModelGearboxSimulink : DTDFVocab:Model [
    base:desc "Simulink model of the cycloidal gearbox, supporting friction‑on and friction‑off configurations"
    DTDFVocab:inputTo SimulinkEnabler
]

instance CalculationModelCoulombViscous : DTDFVocab:Model [
    base:desc "Friction model combining Coulomb (static) and viscous components"
    DTDFVocab:inputTo MATLABEnabler
]

instance CalculationModelStribeck : DTDFVocab:Model [
    base:desc "Stribeck friction model capturing velocity‑dependent transition between static and kinetic friction"
    DTDFVocab:inputTo MATLABEnabler
]

instance CalculationModelDahl : DTDFVocab:Model [
    base:desc "Dahl friction model representing presliding hysteresis"
    DTDFVocab:inputTo MATLABEnabler
]

instance CalculationModelLuGre : DTDFVocab:Model [
    base:desc "LuGre friction model for dynamic friction behaviour"
    DTDFVocab:inputTo MATLABEnabler
]

// ------------------------------------------------------------
// C11: Enablers (tools & infrastructure)
// ------------------------------------------------------------

instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker enabling live streaming of sensor data to the digital shadow"
    DTDFVocab:enables RealTimeDashboardService, FrictionIdentificationService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Custom real‑time dashboard for visualisation of live and simulated data"
    DTDFVocab:enables RealTimeDashboardService, SimulationComparisonService
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML toolchain used for structural and functional engineering models"
    DTDFVocab:enables RealTimeDashboardService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink/MATLAB environment for executable simulation models"
    DTDFVocab:enables FrictionIdentificationService, SimulationComparisonService
]

instance MATLABEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB computational environment for friction calculation models and parameter extraction"
    DTDFVocab:enables ParameterExtractionService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) providing standardized data integration"
    DTDFVocab:enables RealTimeDashboardService
]

// ------------------------------------------------------------
// C6: Services
// ------------------------------------------------------------

instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Real‑time dashboard visualisation of live sensor traces and simulation results"
    DTDFVocab:provides InsightSimulationVsMeasuredComparison
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Friction identification using combined white‑box (model‑based) and black‑box (data‑driven) approaches"
    DTDFVocab:provides InsightFrictionParametersIdentified
]

instance ParameterExtractionService : DTDFVocab:Service [
    base:desc "Extraction of static, kinetic and viscous friction parameters for motion‑control calibration"
    DTDFVocab:provides ActionFeedParametersToController
]

instance SimulationComparisonService : DTDFVocab:Service [
    base:desc "Comparison of simulated versus measured torque, velocity and current data"
    DTDFVocab:provides InsightSimulationVsMeasuredComparison
]

// ------------------------------------------------------------
// C17: Insights & Actions
// ------------------------------------------------------------

instance InsightFrictionParametersIdentified : DTDFVocab:Insight [
    base:desc "Identified static, kinetic and viscous friction parameters from combined modelling"
]

instance ActionFeedParametersToController : DTDFVocab:Action [
    base:desc "Feed identified friction parameters back into the SINUMERIK 840D control loop to calibrate the motion controller"
    DTDFVocab:IsAutomatic true
]

instance InsightSimulationVsMeasuredComparison : DTDFVocab:Insight [
    base:desc "Comparison results between simulated and measured torque, angular velocity and current data"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time synchronization with the robot operation; data are acquired and processed continuously during robot motion (up to 75 °/s) and visualised instantly in the dashboard."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A digital shadow instantiated from the Digital Shadow Reference Model, comprising Purpose (FrictionDerivation), Asset (MABI robot first axis), Sources (sensor channels), Processing components (simulation models), Models (engineering, simulation, data‑calculation), and multiple Data Traces that are visualised in a unified dashboard."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each Data Trace to its generating Processing component and source; validation by comparing simulated friction‑free and friction‑included outputs against measured reference data; continuous identification to capture wear, temperature, and load variations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data are transmitted from the physical robot to the digital shadow using the MQTT protocol over a network connection."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of Asset Administration Shells (AAS) as a standardised information model for Industry 4.0 digital twins and shadows."
]