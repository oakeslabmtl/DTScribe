// C3: Physical sensing components
instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted encoder directly attached to the motor shaft, delivering high‑resolution angular position data."
    DTDFVocab:producedData MQTTPositionStream
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located after the gearbox, delivering high‑resolution angular position data."
    DTDFVocab:producedData MQTTPositionStream
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that captures torque (τ) from the CNC machine."
    DTDFVocab:producedData MQTTSensorStream
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that captures angular velocity (ω) from the CNC machine."
    DTDFVocab:producedData MQTTSensorStream
]

// C4: Physical-to-virtual interaction – data transmitted
instance MQTTPositionStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder, GearboxEncoder
]

instance MQTTSensorStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor, AngularVelocitySensor
]

// C10: Data artifacts
instance PositionData : DTDFVocab:Data [
    base:desc "Time‑stamped angular position measurements from both encoders."
    DTDFVocab:fromData MQTTPositionStream
    DTDFVocab:inputTo EnablerSimulink, EnablerMontiArcAutomaton
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Torque (τ) measurements streamed via MQTT."
    DTDFVocab:fromData MQTTSensorStream
    DTDFVocab:inputTo EnablerSimulink, EnablerMLFramework
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity (ω) measurements streamed via MQTT."
    DTDFVocab:fromData MQTTSensorStream
    DTDFVocab:inputTo EnablerSimulink, EnablerMLFramework
]

// C10: Models / data
instance GeometricStructuralModel : DTDFVocab:Model [
    base:desc "Geometric and structural description of the robot axis expressed in SysML block diagrams."
    DTDFVocab:inputTo EnablerMontiArcAutomaton
]

instance BehavioralStateMachineModel : DTDFVocab:Model [
    base:desc "State‑machine automaton model of the axis motion realized in MontiArc Automaton."
    DTDFVocab:inputTo EnablerMontiArcAutomaton
]

instance AnalyticalSimulinkModel : DTDFVocab:Model [
    base:desc "White‑box analytical model implemented in Simulink encoding physics‑based equations of the drive system."
    DTDFVocab:inputTo EnablerSimulink
]

instance DataDrivenFrictionModel : DTDFVocab:Model [
    base:desc "Black‑box machine‑learning regressor capturing nonlinear joint friction effects."
    DTDFVocab:inputTo EnablerMLFramework
]

// C11: Enablers
instance EnablerSimulink : DTDFVocab:Enabler [
    base:desc "Simulink simulation environment executing analytical models and processing sensor data."
    DTDFVocab:enables VisualizationDashboardService
]

instance EnablerMontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton framework executing behavioral state‑machine models."
    DTDFVocab:enables VisualizationDashboardService
]

instance EnablerMLFramework : DTDFVocab:Enabler [
    base:desc "Machine‑learning framework (e.g., TensorFlow/PyTorch) executing data‑driven friction models."
    DTDFVocab:enables VisualizationDashboardService
]

// C6: Services
instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Integrated visualization dashboard providing real‑time monitoring and decision support for robot motion."
    DTDFVocab:provides JointFrictionInsight, MotionAccuracyRecommendationInsight
]

// C17: Insights
instance JointFrictionInsight : DTDFVocab:Insight [
    base:desc "Identification of joint friction in robotic motion derived from sensor data and models."
]

instance MotionAccuracyRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation to improve robot motion accuracy based on friction analysis."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through traceability of data generation and transformation: every data trace used in the DT can be linked back to its source sensor and processing step. Validation is performed by comparing simulation outputs (e.g., from Simulink or black‑box friction models) against measured sensor data to quantify deviation. Particular attention is given to accurately representing friction effects, which are known to be difficult to model; iterative refinement is applied until simulated and measured behaviours converge within acceptable error bounds."
]