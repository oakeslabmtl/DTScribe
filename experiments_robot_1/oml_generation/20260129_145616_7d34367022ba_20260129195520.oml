// C3: Physical sensing component
instance AutomatedPhysicalDataCollector : DTDFVocab:SensingComponent [
    base:desc "Automated one-way data flow from the physical object to its digital counterpart, collecting contextual data traces as defined by the Digital Shadow Reference Model."
    DTDFVocab:producedData ContextualDataTrace
]

// C4: Physical-to-virtual interaction (data transmitted)
instance ContextualDataTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AutomatedPhysicalDataCollector
]

// C10: Data (aggregated and abstracted)
instance AggregatedContextData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces collected for a specific purpose, as described in the digital‑shadow reference model."
    DTDFVocab:fromData ContextualDataTrace
    DTDFVocab:inputTo MBSEExecutionEngine
]

// C10: Models
instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "SysML block and internal‑block diagrams capturing system structure across MBSE abstraction layers."
    DTDFVocab:inputTo MBSEExecutionEngine
]

instance StateMachineBehaviorModel : DTDFVocab:Model [
    base:desc "State‑machine automata (e.g., MontiArc Automaton, SysML v1.7 state machines) representing refined behavioral aspects."
    DTDFVocab:inputTo MBSEExecutionEngine
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "Executable simulation model linked to the behavioral state machines, implemented in MathWorks Simulink."
    DTDFVocab:inputTo MBSEExecutionEngine
]

// C11: Enabler
instance MBSEExecutionEngine : DTDFVocab:Enabler [
    base:desc "Model‑Based Systems‑Engineering execution environment that composes models and data to provide digital‑twin computational services."
    DTDFVocab:enables DigitalTwinSimulationService
]

// C6: Service
instance DigitalTwinSimulationService : DTDFVocab:Service [
    base:desc "Service that runs the integrated MBSE models and contextual data to simulate the twin and generate operational insights."
    DTDFVocab:provides SimulationBasedOperationalInsight
]

// C17: Insight
instance SimulationBasedOperationalInsight : DTDFVocab:Insight [
    base:desc "Insight derived from the simulation of the digital twin using aggregated contextual data and MBSE models."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle is aligned with MBSE abstraction layers: (1) requirements engineering, (2) functional architecture modeling, (3) logical architecture modeling, and (4) product/technical layer implementation. At each stage the DT is represented by appropriate models—requirements captured in SysML requirement diagrams, functional and logical structures described with ADLs such as SysML IBDs, ACME, AADL, or MontiArc, and the detailed product view realized with simulation models in Simulink or executable code in C++/Java. Transition between stages is managed by traceability links defined in the MBSE environment, but governance mechanisms are not detailed in the document."
]