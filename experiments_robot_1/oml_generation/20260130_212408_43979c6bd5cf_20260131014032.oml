// Sensing Component capturing continuous sensor measurements from the physical robot
instance PhysicalRobotSensor : DTDFVocab:SensingComponent [
    base:desc "Captures continuous time‑series sensor measurements and timestamps from the physical robot."
    DTDFVocab:producedData MQTTBrokerPayload
]

// MQTT payload transmitted over the MQTT broker
instance MQTTBrokerPayload : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalRobotSensor
    base:desc "MQTT message payload containing raw sensor measurements and associated timestamps."
]

// Aggregated contextual data trace derived from the MQTT payload
instance ContinuousDataTrace : DTDFVocab:Data [
    base:desc "Aggregated contextual data trace composed of time‑series streams after minimal preprocessing."
    DTDFVocab:fromData MQTTBrokerPayload
    DTDFVocab:inputTo DataProcessingEnabler
]

// Models describing structural composition and behavior using various ADLs and SysML
instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Interface Block Diagram model representing the system’s component–connector structure."
    DTDFVocab:inputTo SimulationEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME architecture description of the system components and connectors."
    DTDFVocab:inputTo SimulationEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model providing runtime behavior with embedded automata."
    DTDFVocab:inputTo SimulationEnabler
]

instance SimulinkThermalModel : DTDFVocab:Model [
    base:desc "Simulink model used for thermal simulation and analysis."
    DTDFVocab:inputTo SimulationEnabler
]

// Enabler for simulation execution
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that orchestrates the execution of simulation models within the Simulink environment."
    DTDFVocab:enables SimulationExecutionService
]

// Enabler for data processing and aggregation
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that handles preprocessing, aggregation, and conditioning of continuous data traces."
    DTDFVocab:enables DataProcessingService
]

// Service that executes simulation models
instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service responsible for executing SysML, ACME, MontiArc, and Simulink models."
    DTDFVocab:provides SimulinkSimulationInsight
]

// Service that processes data into actionable insights
instance DataProcessingService : DTDFVocab:Service [
    base:desc "Service that aggregates raw sensor data into contextual traces, enabling insights and automated actions."
    DTDFVocab:provides ContextualDataTraceInsight, AggregateSensorDataAction
]

// Insight derived from aggregated data traces
instance ContextualDataTraceInsight : DTDFVocab:Insight [
    base:desc "Provides analytical insight into aggregated contextual data traces for downstream analysis and visualization."
]

// Automated action that aggregates sensor data
instance AggregateSensorDataAction : DTDFVocab:Action [
    base:desc "Automated aggregation of raw sensor data into continuous contextual traces."
    DTDFVocab:IsAutomatic true
]

// Simulation insight exposed by the simulation execution service
instance SimulinkSimulationInsight : DTDFVocab:Insight [
    base:desc "Generates insight regarding the behavior and stability of simulated models within Simulink."
]

// Additional enablers for code execution and runtime
instance CppRuntime : DTDFVocab:Enabler [
    base:desc "C++ runtime environment for executing compiled behavioral models."
    DTDFVocab:enables CodeGenerationService
]

instance JavaRuntime : DTDFVocab:Enabler [
    base:desc "Java runtime environment for executing generated behavioral models."
    DTDFVocab:enables CodeGenerationService
]

// Service for code generation of behavioral models
instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Service that generates C++ or Java code from SysML and MontiArc models."
    DTDFVocab:provides CodeGenerationInsight
]

// Insight obtained from code generation
instance CodeGenerationInsight : DTDFVocab:Insight [
    base:desc "Provides details on the generated code, including performance metrics and compatibility notes."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital shadow operates in real‑time, continuously ingesting live sensor time‑series from the physical asset via MQTT and immediately mapping them to the in‑memory cosim model representation. The model update loop is triggered by incoming measurement events, but the document does not specify mandatory update frequencies, maximum latencies, or temporal granularity for specific services."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration follows a Digital Shadow Reference Model (DSRM) expressed as a UML class diagram, integrating three core layers: Asset (physical descriptors), Model (formal SysML/ADL architecture), and Processing (runtime logic). The processing layer applies state‑machine models (MontiArc Automaton or SysML v1.7) and interfaces with simulation engines such as MathWorks Simulink or compiled C++/Java code. Component composition and interconnection are defined using architecture description languages (ACME, AADL, MontiArc) in compliance with MBSE best practices, enabling resource management via component instantiation semantics and system‑wide coordination through the processing engine dispatching sensor events to the digital model."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The communication between the physical robot and the digital twin is performed over MQTT (Message Queuing Telemetry Transport) using the standard TCP/IP stack. Sensor streams are published by the robot to MQTT topics; the digital twin subscribes to these topics to receive the data. No specific details about QoS level, TLS encryption, broker topology, or network bandwidth are specified."
]