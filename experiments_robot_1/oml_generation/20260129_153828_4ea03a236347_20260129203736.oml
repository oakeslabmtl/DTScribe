// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor current I_M on the first vertical axis of the MABI MAX 100 robot"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder providing motor angle r_M for the vertical axis"
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder located behind the gearbox providing gearbox output angle r_out"
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// C10: Data
instance CurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor current I_M streamed via MQTT"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo RealTimeFrictionIdentificationService, DataTransportService
]

instance MotorAngleData : DTDFVocab:Data [
    base:desc "Time‑series of motor angle r_M streamed via MQTT"
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo RealTimeFrictionIdentificationService, DataTransportService
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Time‑series of gearbox output angle r_out streamed via MQTT"
    DTDFVocab:fromData GearboxAngleDataTransmitted
    DTDFVocab:inputTo RealTimeFrictionIdentificationService, DataTransportService
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker transporting live sensor data (current, encoder angles) to the digital shadow"
    DTDFVocab:enables DataTransportService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell used for semantic integration and traceability of data traces"
    DTDFVocab:enables DataTransportService, DashboardVisualizationService
]

instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML for system modelling (block definition and internal block diagrams) of the vertical axis"
    DTDFVocab:enables SimulationComparisonService
]

instance MatlabSimulinkSimulator : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for executable simulation of friction‑less behaviour and various friction laws"
    DTDFVocab:enables RealTimeFrictionIdentificationService, SimulationComparisonService
]

instance WebDashboard : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard visualising simulated vs measured torque and velocity and supporting operator decisions"
    DTDFVocab:enables DashboardVisualizationService
]

// C6: Services
instance DataTransportService : DTDFVocab:Service [
    base:desc "Real‑time transport of sensor data via MQTT to the digital twin"
    DTDFVocab:provides DataAvailabilityInsight
]

instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction using combined white‑box and black‑box models"
    DTDFVocab:provides FrictionParameterInsight, ControllerFeedbackAction
]

instance SimulationComparisonService : DTDFVocab:Service [
    base:desc "Comparison of simulated torque and velocity with measured values for validation"
    DTDFVocab:provides DeviationHighlightInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Integrated dashboard visualisation of friction identification results and deviation highlights"
    DTDFVocab:provides DeviationHighlightInsight, OperatorDecisionAction
]

// C17: Insights
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters (static, kinetic, viscous coefficients) are fed back to the robot controller to improve motion accuracy"
]

instance DeviationHighlightInsight : DTDFVocab:Insight [
    base:desc "Dashboard highlights deviations between simulated and measured torque and velocity for operator decisions"
]

instance DataAvailabilityInsight : DTDFVocab:Insight [
    base:desc "Indicates successful reception of live sensor data in the digital shadow"
]

// C17: Actions
instance ControllerFeedbackAction : DTDFVocab:Action [
    base:desc "Automatic update of the robot controller with newly identified friction parameters"
    DTDFVocab:IsAutomatic true
]

instance OperatorDecisionAction : DTDFVocab:Action [
    base:desc "Operator decides on corrective actions based on dashboard deviation insights"
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance StructuralSysMLModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams describing the vertical axis, motor, gear transmission, and cycloidal gearbox"
    DTDFVocab:inputTo SysMLModelingTool
]

instance FrictionlessSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of friction‑less behaviour of the vertical axis"
    DTDFVocab:inputTo MatlabSimulinkSimulator
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Coulomb‑Viscous friction law"
    DTDFVocab:inputTo MatlabSimulinkSimulator
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Stribeck friction law"
    DTDFVocab:inputTo MatlabSimulinkSimulator
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Dahl friction law"
    DTDFVocab:inputTo MatlabSimulinkSimulator
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "Simulink model implementing LuGre friction law"
    DTDFVocab:inputTo MatlabSimulinkSimulator
]

instance TorqueCalculationModel : DTDFVocab:Model [
    base:desc "Data calculation model deriving torque from motor current and motor parameters"
    DTDFVocab:inputTo MatlabSimulinkSimulator
]

instance AngularVelocityCalculationModel : DTDFVocab:Model [
    base:desc "Data calculation model deriving angular velocity from encoder position data"
    DTDFVocab:inputTo MatlabSimulinkSimulator
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time streaming at the native sensor sampling rate, enabling on‑line model updating during robot operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow composed of the asset (first axis), a Processing component that consumes measured Data Traces, runs Simulation models, and produces simulated Data Traces; all elements are linked via the Digital Shadow Reference Model and presented in a dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow is instantiated for the operational stage of the robot, with engineering models (SysML) defined earlier in the design phase and continuously refined during runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Both analytical (white‑box) and data‑driven (black‑box) friction models are continuously identified; traceability of each Data Trace to its source and processing model ensures validation by comparing simulated torque/velocity with measured values."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor streams are published over MQTT; the Asset Administration Shell provides a standardized interface, potentially based on OPC UA, for linking data to the digital shadow."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation follows the Asset Administration Shell (AAS) standard for asset description and uses the Digital Shadow Reference Model as defined in prior research."
]