instance SysML : dt:Enabler [
    base:desc "Model-Based Systems Engineering (MBSE) tool using SysML for system modeling"
]

instance ACME : dt:Enabler [
    base:desc "Architecture Description Language for component and connector descriptions"
]

instance AADL : dt:Enabler [
    base:desc "Architecture Description Language for component and connector descriptions"
]

instance MontiArc : dt:Enabler [
    base:desc "Architecture Description Language for component and connector descriptions"
]

instance Simulink : dt:Enabler [
    base:desc "MathWorks Simulink simulation engine for behavior modeling"
]

instance CPlusPlus : dt:Enabler [
    base:desc "General-purpose programming language for detailed logic implementation"
]

instance Java : dt:Enabler [
    base:desc "General-purpose programming language for detailed logic implementation"
]

instance ContextualDataTracesDataTransmitted : dt:DataTransmitted [
    dt:producedFrom ManufacturingSystemSensor
]

instance ContextualDataTraces : dt:Data [
    base:desc "Contextual data traces from physical systems, aggregated and abstracted as per digital shadow concepts",
    dt:fromData ContextualDataTracesDataTransmitted,
    dt:inputTo SysML, Simulink, CPlusPlus, Java
]

instance GeometricModel_SysMLIBDs : dt:Model [
    base:desc "Geometric model using SysML IBDs for structural representation",
    dt:inputTo SysML
]

instance BehavioralModel_SysMLStateMachines : dt:Model [
    base:desc "Behavioral model using SysML state machines for dynamic behavior",
    dt:inputTo SysML
]

instance BehavioralModel_MontiArcAutomaton : dt:Model [
    base:desc "Behavioral model using MontiArc Automaton for dynamic behavior",
    dt:inputTo MontiArc
]

instance AnalyticalModel_Simulink : dt:Model [
    base:desc "Analytical model using MathWorks Simulink for simulation-based analysis",
    dt:inputTo Simulink
]

instance ManufacturingSystemSensor : dt:SensingComponent [
    base:desc "Sensing component capturing contextual data traces from the manufacturing system",
    dt:producedData ContextualDataTracesDataTransmitted
]

instance ManufacturingSystem : dt:SystemUnderStudy [
    base:desc "Manufacturing system comprising physical objects and processes within a manufacturing environment. Key characteristics include real-time data generation, multi-level abstraction (requirements, functional architecture, logical architecture, product/technical layer), and integration of heterogeneous stakeholders, making it suitable for digital twinning through Model-Based Systems Engineering (MBSE) methodologies.",
    dt:hasEnvironment ManufacturingSystemEnvironment
]

instance ManufacturingSystemEnvironment : dt:Environment [
    base:contains ManufacturingSystemSensor
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to industry standards including SysML for systems engineering modeling, ACME, AADL, and MontiArc as architecture description languages (ADLs), and methodologies such as RFLP (Requirements, Functions, Logics, Physics), OOSEM, SPES, and SMArDT for managing system complexity across abstraction levels (requirements, functional architecture, logical architecture, product/technical layer)."
]