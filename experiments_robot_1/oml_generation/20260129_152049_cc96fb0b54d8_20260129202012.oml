// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring input current I_M of the permanent‑magnet synchronous motor"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor side of the first vertical axis"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder located after the cycloidal gearbox of the first vertical axis"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// C10: Data instances
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of measured motor current I_M"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBroker, MATLABSimulinkTool
]

instance MotorEncoderPositionData : DTDFVocab:Data [
    base:desc "Time‑series of motor‑side angular position from the motor encoder"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBroker, MATLABSimulinkTool
]

instance GearboxEncoderPositionData : DTDFVocab:Data [
    base:desc "Time‑series of gearbox‑side angular position from the secondary encoder"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBroker, MATLABSimulinkTool
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Calculated torque derived from current, motor parameters and controller data"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkTool
]

instance DerivedAngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity computed from successive position measurements"
    DTDFVocab:fromData MotorEncoderDataTransmitted, GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkTool
]

instance DerivedAccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration derived from velocity data"
    DTDFVocab:fromData DerivedAngularVelocityData
    DTDFVocab:inputTo MATLABSimulinkTool
]

// C10: Engineering and simulation models
instance AxisEngineeringModel : DTDFVocab:Model [
    base:desc "SysML block‑definition and internal‑block diagram of the first vertical axis (motor, gearbox, encoders)"
    DTDFVocab:inputTo SysMLTool
]

instance FrictionFreeSimModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model representing friction‑free behavior of the axis"
    DTDFVocab:inputTo MATLABSimulinkTool
]

instance CoulombViscousFrictionSimModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model implementing Coulomb‑Viscous friction for the axis"
    DTDFVocab:inputTo MATLABSimulinkTool
]

instance StribeckFrictionSimModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model implementing Stribeck friction characteristics"
    DTDFVocab:inputTo MATLABSimulinkTool
]

instance DahlFrictionSimModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model implementing Dahl friction dynamics"
    DTDFVocab:inputTo MATLABSimulinkTool
]

instance LuGreFrictionSimModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model implementing LuGre friction behavior"
    DTDFVocab:inputTo MATLABSimulinkTool
]

// C11: Enablers (tools/platforms)
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML used for structural and behavioral modeling of the robot axis"
    DTDFVocab:enables RealTimeFrictionIdentificationService
]

instance MATLABSimulinkTool : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for executable simulation and friction model identification"
    DTDFVocab:enables RealTimeFrictionIdentificationService, ContinuousModelUpdatingService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker streaming live sensor data (current, positions) to the digital shadow"
    DTDFVocab:enables RealTimeFrictionIdentificationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell encapsulating the digital twin models and services"
    DTDFVocab:enables RealTimeFrictionIdentificationService, ContinuousModelUpdatingService, DashboardVisualizationService
]

instance DashboardVisualizationTool : DTDFVocab:Enabler [
    base:desc "Dashboard for integrated visualization of friction loss insights and model performance"
    DTDFVocab:enables DashboardVisualizationService
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction using combined white‑box analytical and black‑box data‑driven models"
    DTDFVocab:provides FrictionLossInsight
]

instance ContinuousModelUpdatingService : DTDFVocab:Service [
    base:desc "Continuous updating of friction model parameters based on incoming sensor streams"
    DTDFVocab:provides ModelPerformanceComparisonInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Integrated visualization of friction identification results and motion‑accuracy metrics"
    DTDFVocab:provides MotionAccuracyImprovementInsight, AdjustRobotControllerAction
]

// C17: Insights
instance FrictionLossInsight : DTDFVocab:Insight [
    base:desc "Insight on friction loss (static, kinetic, viscous) derived from live data"
]

instance ModelPerformanceComparisonInsight : DTDFVocab:Insight [
    base:desc "Insight comparing simulated friction‑free behavior with measured data to evaluate model accuracy"
]

instance MotionAccuracyImprovementInsight : DTDFVocab:Insight [
    base:desc "Insight showing improved motion accuracy after applying identified friction compensation"
]

// C17: Action
instance AdjustRobotControllerAction : DTDFVocab:Action [
    base:desc "Automatically adjust robot controller parameters using identified friction coefficients"
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A one‑way digital shadow architecture where physical sensor streams feed a Processing component that consumes Engineering/Simulation models and produces derived DataTraces; the shadow is organized around Purpose, Asset, Sources, Models, Processing and DataTrace classes as defined in the Digital Shadow Reference Model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Combination of white‑box analytical friction models with black‑box data‑driven models; continuous re‑identification during operation to account for wear, tool changes, and temperature; traceability of data points to source and processing models ensures validation against measured data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data is transmitted from the robot to the digital shadow over MQTT; the Asset Administration Shell (AAS) provides a standardized interface for model and metadata exchange."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) standard and SysML modeling language to ensure interoperability and model conformity."
]