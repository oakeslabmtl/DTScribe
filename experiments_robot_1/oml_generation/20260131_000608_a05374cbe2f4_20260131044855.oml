// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current measurement of the permanent–magnet synchronous motor."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder providing positional information of the motor shaft."
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary gear encoder behind the gearwheel gearbox."
    DTDFVocab:producedData GearboxPositionDataTransmitted
]

// C4: Data transmitted from sensors over MQTT
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// Simulated data transmitted (internal simulation output, still modeled as transmitted)
instance SimulatedMotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance SimulatedMotorTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance SimulatedMotorAngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance SimulatedGearboxAngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// C1: Physical acting components (none for this twin)
instance NoActingComponent : DTDFVocab:ActingComponent [
    base:desc "No passive or active actuators are provided by the digital twin; the twin is purely observational."
]

// C10: Models/Data (Engineering and Simulation)
instance EngineeringSysMLModel : DTDFVocab:Model [
    base:desc "Engineering model defined in SysML describing the first axis hardware and mechanical configuration."
    DTDFVocab:inputTo AssetAdministrationShell
]

instance SimulinkMotorGearboxModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink simulation model of motor, gearwheel and cycloidal gearbox, including friction representations."
    DTDFVocab:inputTo SimulationEngine
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Data‑calculation model for Coulomb‑Viscous friction identification."
    DTDFVocab:inputTo DataProcessingEngine
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Data‑calculation model for Stribeck friction identification."
    DTDFVocab:inputTo DataProcessingEngine
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Data‑calculation model for Dahl friction identification."
    DTDFVocab:inputTo DataProcessingEngine
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "Data‑calculation model for LuGre friction identification."
    DTDFVocab:inputTo DataProcessingEngine
]

// C5: Data instances
instance MeasuredMotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current supplied by MotorCurrentSensor."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo DataProcessingEngine
]

instance MeasuredMotorTorqueData : DTDFVocab:Data [
    base:desc "Measured motor torque derived from current measurement and motor model."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo DataProcessingEngine
]

instance MeasuredMotorAngularVelocityData : DTDFVocab:Data [
    base:desc "Measured angular velocity derived from motor encoder position."
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo DataProcessingEngine
]

instance MeasuredGearboxAngularVelocityData : DTDFVocab:Data [
    base:desc "Measured gearbox angular velocity derived from gearwheel encoder position."
    DTDFVocab:fromData GearboxPositionDataTransmitted
    DTDFVocab:inputTo DataProcessingEngine
]

instance SimulatedMotorCurrentData : DTDFVocab:Data [
    base:desc "Simulated motor current generated by the SimulinkMotorGearboxModel."
    DTDFVocab:fromData SimulatedMotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulationEngine
]

instance SimulatedMotorTorqueData : DTDFVocab:Data [
    base:desc "Simulated motor torque from the Simulink model."
    DTDFVocab:fromData SimulatedMotorTorqueDataTransmitted
    DTDFVocab:inputTo SimulationEngine
]

instance SimulatedMotorAngularVelocityData : DTDFVocab:Data [
    base:desc "Simulated motor angular velocity from the Simulink model."
    DTDFVocab:fromData SimulatedMotorAngularVelocityDataTransmitted
    DTDFVocab:inputTo SimulationEngine
]

instance SimulatedGearboxAngularVelocityData : DTDFVocab:Data [
    base:desc "Simulated gearbox angular velocity from the Simulink model."
    DTDFVocab:fromData SimulatedGearboxAngularVelocityDataTransmitted
    DTDFVocab:inputTo SimulationEngine
]

// C11: Enablers
instance MQTTBrokerEngine : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating live sensor data streaming from the robot to the digital twin."
    DTDFVocab:enables DataProcessingEngine, SimulationEngine, DashboardPlatform
]

instance DataProcessingEngine : DTDFVocab:Enabler [
    base:desc "Engine that processes raw sensor data and applies friction identification models."
    DTDFVocab:enables FrictionIdentificationService, DataTraceabilityService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink simulation engine executing mechanical and friction models."
    DTDFVocab:enables FrictionVisualizationService, ControllerTuningService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell providing metadata, source associations, and traceability."
]

instance DashboardPlatform : DTDFVocab:Enabler [
    base:desc "Dashboard platform for visualizing joint friction, motion data, and insights."
    DTDFVocab:enables FrictionVisualizationService, DataTraceabilityService, ControllerTuningService
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service performing continuous identification of friction values using white-box and black-box models."
    DTDFVocab:provides FrictionEstimationInsight, DegradationTrendInsight
]

instance FrictionVisualizationService : DTDFVocab:Service [
    base:desc "Service visualizing joint friction and motion data in a dashboard."
    DTDFVocab:provides FrictionVisualizationInsight
]

instance DataTraceabilityService : DTDFVocab:Service [
    base:desc "Service providing traceability of data origins via the Asset Administration Shell."
    DTDFVocab:provides DataOriginInsight
]

instance ControllerTuningService : DTDFVocab:Service [
    base:desc "Service supporting controller tuning and quality assurance of robot motion."
    DTDFVocab:provides SuggestControllerParameterUpdateAction
]

// C17: Insights / Actions
instance FrictionEstimationInsight : DTDFVocab:Insight [
    base:desc "Friction estimates derived from continuous identification."
]

instance DegradationTrendInsight : DTDFVocab:Insight [
    base:desc "Degradation trends indicating increasing friction over time."
]

instance FrictionVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of joint friction dynamics."
]

instance DataOriginInsight : DTDFVocab:Insight [
    base:desc "Insight tracing the origin of each data point back to its physical sensor."
]

instance SuggestControllerParameterUpdateAction : DTDFVocab:Action [
    base:desc "Suggested controller parameter update to compensate for identified friction changes."
    DTDFVocab:IsAutomatic true
]

// C7: Physical system components
instance PermanentMagneticSynchronousMotorComponent : DTDFVocab:Component [
    base:desc "Permanent–magnet synchronous motor driving the first axis."
]

instance GearwheelGearboxComponent : DTDFVocab:Component [
    base:desc "Gearwheel gearbox reducing motor speed for joint actuation."
]

instance CycloidalGearboxComponent : DTDFVocab:Component [
    base:desc "Cycloidal gearbox providing high torque density for the axis."
]

instance RobotFirstAxisComponent : DTDFVocab:Component [
    base:desc "The first axis of the Serial MABI MAX 100 industrial robot."
]

// C6: Environment containing all system components
instance RobotFirstAxisEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagneticSynchronousMotorComponent, GearwheelGearboxComponent, CycloidalGearboxComponent, RobotFirstAxisComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The described digital twin does not issue control commands or other signals back to the physical robot; therefore no virtual‑to‑physical interactions are implemented."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time or near‑real‑time operation; live data ingestion and dashboard updates occur continuously during robot execution, maintaining synchronization between PT and DT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of the asset (robot axis), sensors (current and encoders), a processing unit (Simulink friction models), data traces, and a dashboard; all components are linked through the AAS and communicate via MQTT, forming a coherent digital twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT focuses on the operated phase of the physical robot, monitoring, calibrating, and improving performance during operation; it complements the designed/modeled representation but primarily supports runtime operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Data points are traceable to their originating sensors and processing steps; friction models are continuously validated against measured data; combining white‑box analytical models with black‑box data‑driven approaches mitigates drift due to wear, temperature, and other uncertainties; uncertainty is acknowledged in model parameters."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication from the physical system to the digital twin occurs over MQTT; the digital twin uses the Asset Administration Shell as the standard interface for data exchange; no two‑way communication with the PT is described."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Not in Document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "No explicit integration with external information systems outside the robot’s own sensors is described."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "No explicit statement; it is presumed that data remain owned by the physical system operator and are not shared with third parties."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of industry standards such as SysML for modeling, Asset Administration Shell for semantic interoperability, SQL / MQTT message format adherence, and SMArDT reference model guidelines."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Not in Document."
]