    base:desc "Current state of manufacturing components as modeled in SysML, including functional architecture and logical connections."
]

instance FunctionalArchitectureVisualization : DTDFVocab:Insight [
    base:desc "Visual representation of manufacturing system architecture using SysML Internal Block Diagrams (IBDs), showing components, interfaces, and interconnections."
]

instance BehavioralForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted behavioral trends for manufacturing processes based on MontiArc Automaton or SysML state machines."
]

instance ProcessOptimizationAction : DTDFVocab:Action [
    base:desc "Optimized process parameters for manufacturing operations to improve efficiency, reduce waste, or enhance product quality."
