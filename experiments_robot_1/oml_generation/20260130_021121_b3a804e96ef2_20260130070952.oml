instance ManufacturingIoTSensor : DTDFVocab:SensingComponent [
    base:desc "Automated data acquisition system capturing real-time state data from physical manufacturing components via IoT sensors, PLCs, or SCADA systems. Supports heterogeneous data sources including operational logs and environmental metrics."
    DTDFVocab:producedData ManufacturingDataTransmitted
]

instance ProcessControlSensor : DTDFVocab:SensingComponent [
    base:desc "Specialized sensor capturing dynamic process parameters in manufacturing environments, including temperature, pressure, and material flow metrics. Enables real-time monitoring of operational states."
    DTDFVocab:producedData ProcessParameterDataTransmitted
]

instance ManufacturingDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Aggregated contextual data traces from manufacturing IoT sensors, including operational logs and environmental metrics. Transmitted via middleware to the Digital Shadow for preprocessing."
    DTDFVocab:producedFrom ManufacturingIoTSensor
]

instance ProcessParameterDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Real-time process parameters from control sensors, including temperature, pressure, and material flow metrics. Passively mirrored to the Digital Shadow for state synchronization."
    DTDFVocab:producedFrom ProcessControlSensor
]

instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based functional architecture model describing system behaviors across requirements, functions, and logical layers. Defines component interfaces and interconnections using SysML Internal Block Diagrams (IBDs)."
    DTDFVocab:inputTo SysMLModelingEnabler, ModelTransformationEnabler
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "MontiArc architecture model defining components, connectors, and composition hierarchies for manufacturing systems. Supports behavioral modeling via MontiArc Automaton extensions."
    DTDFVocab:inputTo MontiArcEnabler, ModelTransformationEnabler
]

instance SimulinkBehavioralModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for detailed behavioral simulations of manufacturing processes, including dynamic system modeling and control system design. Integrates with MBSE workflows for validation."
    DTDFVocab:inputTo SimulinkEnabler, ModelTransformationEnabler
]

instance PhysicsBasedSimulationModel : DTDFVocab:Model [
    base:desc "Domain-specific physics-based simulation model (e.g., manufacturing process simulations) complementing ADL and SysML models. Used for predictive analytics and failure mode forecasting."
    DTDFVocab:inputTo SimulationEnabler, ModelTransformationEnabler
]

instance AggregatedContextualData : DTDFVocab:Data [
    base:desc "Preprocessed and abstracted data from Digital Shadow, including filtered, normalized, and validated sensor traces. Serves as semantic input for DT services and predictive models."
    DTDFVocab:fromData ManufacturingDataTransmitted, ProcessParameterDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler, DataIntegrationEnabler
]

instance HistoricalOperationalLogs : DTDFVocab:Data [
    base:desc "Structured historical data from manufacturing operations, including maintenance records, performance metrics, and failure events. Used for trend analysis and predictive maintenance."
    DTDFVocab:fromData ManufacturingDataTransmitted
    DTDFVocab:inputTo DataStorageEnabler
]

instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based toolchain (e.g., Cameo Systems Modeler) for multi-layered system modeling across requirements, functional/logical architectures, and product layers. Supports state machines (SysML v1.7) for behavioral modeling."
    DTDFVocab:enables SysMLMonitoringService, ModelValidationService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc framework for component-connector architecture modeling, including MontiArc Automaton for behavioral modeling. Enables scalable, modular DT deployments with defined interfaces."
    DTDFVocab:enables ComponentCoordinationService, BehavioralSimulationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed behavioral simulations, dynamic system modeling, and control system design. Integrates with MBSE workflows via model-to-code transformations."
    DTDFVocab:enables PredictiveSimulationService, ControlAlgorithmService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Domain-specific simulation tools (e.g., [29], [30]) for physics-based or manufacturing process simulations. Complements ADL and SysML models for validation and forecasting."
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "Middleware and preprocessing layers (e.g., Kafka, custom Python scripts) for aggregating, filtering, and normalizing raw sensor data into semantic representations for the DT."
    DTDFVocab:enables RealTimeMonitoringService, AnomalyDetectionService
]

instance DataIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Integration framework (e.g., model transformation tools) to reconcile heterogeneous data sources (SysML, Simulink, C++/Java) and ensure consistency across DT models."
    DTDFVocab:enables CrossDomainValidationService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Databases or data lakes storing contextual data traces, aggregated metrics, and historical logs from manufacturing operations. Supports real-time and batch data access."
    DTDFVocab:enables HistoricalAnalysisService
]

instance ModelTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Model transformation techniques (e.g., SysML-to-Simulink converters) to unify disparate notations and bridge modeling tools with executable implementations."
    DTDFVocab:enables UnifiedModelService
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous state monitoring of manufacturing processes via real-time data synchronization, enabling performance tracking and health assessment."
    DTDFVocab:provides ManufacturingStateInsight, OperationalAnomalyInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Physics-based predictive modeling using Simulink or domain-specific tools to forecast system behavior, failure modes, and resource utilization in manufacturing."
    DTDFVocab:provides FailurePredictionInsight, ResourceOptimizationAction
]

instance ControlAlgorithmService : DTDFVocab:Service [
    base:desc "Closed-loop control services generating commands for physical manufacturing systems via actuators, PLCs, or IoT interfaces. Enables autonomous adjustments to operational parameters."
    DTDFVocab:provides ControlParameterAction, AutonomousAdjustmentAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Real-time anomaly detection in manufacturing processes using aggregated sensor data and machine learning techniques."
    DTDFVocab:provides AnomalyAlertInsight
]

instance ComponentCoordinationService : DTDFVocab:Service [
    base:desc "Dynamic orchestration of manufacturing components via MontiArc-defined interfaces, enabling scalable and modular DT deployments."
    DTDFVocab:provides ComponentInteractionInsight, InterfaceManagementAction
]

instance ModelValidationService : DTDFVocab:Service [
    base:desc "Simulation-based validation of SysML and ADL models against real-world manufacturing operations, ensuring alignment between digital and physical systems."
    DTDFVocab:provides ModelAccuracyInsight, ValidationReportAction
]

instance CrossDomainValidationService : DTDFVocab:Service [
    base:desc "Validation of heterogeneous models (SysML, Simulink, C++/Java) to ensure consistency across manufacturing system representations."
    DTDFVocab:provides CrossDomainConsistencyInsight, IntegrationRecommendationAction
]

instance SysMLMonitoringService : DTDFVocab:Service [
    base:desc "Monitoring of manufacturing system states using SysML-based models, including visualization of operational metrics and component interactions."
    DTDFVocab:provides SysMLStateInsight, FunctionalArchitectureVisualization
]

instance BehavioralSimulationService : DTDFVocab:Service [
    base:desc "Behavioral simulations of manufacturing processes using MontiArc Automaton or SysML state machines, enabling predictive and optimization capabilities."
    DTDFVocab:provides BehavioralForecastInsight, ProcessOptimizationAction
]

instance ManufacturingStateInsight : DTDFVocab:Insight [
    base:desc "Real-time operational state of manufacturing components, including performance metrics, component interactions, and environmental conditions."
]

instance OperationalAnomalyInsight : DTDFVocab:Insight [
    base:desc "Detected anomalies in manufacturing processes, including deviations from expected behavior, sensor failures, or performance degradation."
]

instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted failure modes and timelines for manufacturing components based on physics-based simulations and historical data."
]

