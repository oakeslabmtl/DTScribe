    base:desc "Dynamic interactions between manufacturing components, including interface states, data flows, and composition hierarchies."
]

instance InterfaceManagementAction : DTDFVocab:Action [
    base:desc "Dynamic management of component interfaces in manufacturing systems to ensure proper coordination and data exchange."
    DTDFVocab:IsAutomatic true
]

