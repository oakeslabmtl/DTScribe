    base:desc "Recommended adjustments to resource allocation (e.g., energy, materials) in manufacturing processes to improve efficiency."
    DTDFVocab:IsAutomatic false
]

instance ControlParameterAction : DTDFVocab:Action [
    base:desc "Generated control commands for manufacturing actuators, PLCs, or IoT devices to adjust operational parameters autonomously."
    DTDFVocab:IsAutomatic true
]

instance AutonomousAdjustmentAction : DTDFVocab:Action [
    base:desc "Autonomous adjustments to manufacturing process parameters based on real-time data and predictive models."
    DTDFVocab:IsAutomatic true
]

