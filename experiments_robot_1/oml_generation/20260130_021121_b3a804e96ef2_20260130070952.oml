    base:desc "Validation results comparing SysML/ADL models against real-world manufacturing operations, including accuracy metrics and discrepancies."
]

instance ValidationReportAction : DTDFVocab:Action [
    base:desc "Generated validation reports for manufacturing system models, including recommendations for corrections or updates."
