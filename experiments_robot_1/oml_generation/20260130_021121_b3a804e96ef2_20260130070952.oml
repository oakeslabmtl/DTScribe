    base:desc "Service generating executable code from system models for implementation in manufacturing systems."
    DTDFVocab:provides CodeGenerationInsight
]

instance CodeGenerationInsight : DTDFVocab:Insight [
    base:desc "Information about generated code, including compatibility, performance metrics, and implementation recommendations."
]

instance TrendVisualizationService : DTDFVocab:Service [
    base:desc "Service providing visual representations of trends in manufacturing data for analysis and decision making."
    DTDFVocab:provides TrendVisualizationInsight
