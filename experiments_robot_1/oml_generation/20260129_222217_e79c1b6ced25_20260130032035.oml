instance SysMLTooling : DTDFVocab:Enabler [
    base:desc "Model‑Based Systems Engineering artifact used to model functional and logical architecture, including Inter‑Block Diagrams and state machines (SysML v1.7)."
    DTDFVocab:enables SysMLModelingService
]

instance SysMLModelingService : DTDFVocab:Service [
    base:desc "Service providing creation and editing of SysML models."
    DTDFVocab:provides SysMLModelInsight
]

instance SysMLModelInsight : DTDFVocab:Insight [
    base:desc "Insight into the SysML model completeness and consistency."
]

instance MontiArcTooling : DTDFVocab:Enabler [
    base:desc "MontiArc specified component and connector relationships; MontiArc‑Automaton defines behavioral relations."
    DTDFVocab:enables MontiArcSimulationService
]

instance MontiArcSimulationService : DTDFVocab:Service [
    base:desc "Service providing MontiArc component and connector modeling."
    DTDFVocab:provides MontiArcModelInsight
]

instance MontiArcModelInsight : DTDFVocab:Insight [
    base:desc "Insight into the MontiArc model structure."
]

instance SimulinkSimulation : DTDFVocab:Enabler [
    base:desc "Behavioral simulation performed with MathWorks Simulink."
    DTDFVocab:enables SimulinkSimulationService
]

instance SimulinkSimulationService : DTDFVocab:Service [
    base:desc "Service providing simulation execution and analysis with Simulink."
    DTDFVocab:provides SimulinkSimulationInsight
]

instance SimulinkSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight into simulation results and behavior."
]

instance ACMEIntegration : DTDFVocab:Enabler [
    base:desc "Integration framework may use ACME architecture description language."
    DTDFVocab:enables ACMEArchitectureService
]

instance ACMEArchitectureService : DTDFVocab:Service [
    base:desc "Service providing ACME architecture modeling."
    DTDFVocab:provides ACMEArchitectureInsight
]

instance ACMEArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight into ACME architecture compliance."
]

instance AADLIntegration : DTDFVocab:Enabler [
    base:desc "Integration framework may use AADL architecture description language."
    DTDFVocab:enables AADLArchitectureService
]

instance AADLArchitectureService : DTDFVocab:Service [
    base:desc "Service providing AADL architecture modeling."
    DTDFVocab:provides AADLArchitectureInsight
]

instance AADLArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight into AADL architecture compliance."
]

instance SysMLModel : DTDFVocab:Model [
    base:desc "SysML v1.7 model containing Inter‑Block Diagrams and state machines."
    DTDFVocab:inputTo SysMLTooling
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc component and connector model."
    DTDFVocab:inputTo MontiArcTooling
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "Simulink behavioral model for simulation."
    DTDFVocab:inputTo SimulinkSimulation
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME architecture description model."
    DTDFVocab:inputTo ACMEIntegration
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL architecture description model."
    DTDFVocab:inputTo AADLIntegration
]