// C3: Physical sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor of the MABI MAX 100 robot axis"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder placed behind the cycloidal gearbox of the MABI MAX 100 robot axis"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current measurement I_M obtained from the Siemens SINUMERIK 840D controller"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Data (raw and derived)
instance MotorEncoderAngleData : DTDFVocab:Data [
    base:desc "Raw angular position data from the motor‑mounted encoder"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance GearboxEncoderAngleData : DTDFVocab:Data [
    base:desc "Raw angular position data from the secondary encoder behind the gearbox"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current I_M from the SINUMERIK 840D controller"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance CalculatedTorqueData : DTDFVocab:Data [
    base:desc "Derived torque τ calculated from current and encoder data"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

instance CalculatedAngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω calculated from successive encoder angles"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

// C10: Models
instance AxisEngineeringModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams of the first axis of the MABI MAX 100 robot"
    DTDFVocab:inputTo SysMLModelingTool
]

instance MotorGearSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink simulation model of motor, gearwheel and cycloidal gearbox (with/without friction)"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

instance FrictionModelCoulombViscous : DTDFVocab:Model [
    base:desc "Coulomb‑Viscous friction model used for parameter identification"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

instance FrictionModelStribeck : DTDFVocab:Model [
    base:desc "Stribeck friction model used for parameter identification"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

instance FrictionModelDahl : DTDFVocab:Model [
    base:desc "Dahl friction model used for parameter identification"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

instance FrictionModelLuGre : DTDFVocab:Model [
    base:desc "LuGre friction model used for parameter identification"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

// C11: Enablers (tooling and integration)
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML tool for structural and behavioral modeling of the robot axis"
    DTDFVocab:enables RealTimeVisualizationService
]

instance MatlabSimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for executable simulation and friction‑parameter calculation"
    DTDFVocab:enables FrictionParameterIdentificationService
]

instance MqttBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker used for streaming live sensor data as time‑stamped traces"
    DTDFVocab:enables RealTimeVisualizationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) for model integration and digital‑shadow representation"
    DTDFVocab:enables RealTimeVisualizationService, FrictionParameterIdentificationService
]

instance SinumerikController : DTDFVocab:Enabler [
    base:desc "Siemens SINUMERIK 840D controller that provides current measurement and receives updated friction models"
    DTDFVocab:enables FrictionParameterIdentificationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of measured and simulated data in a dashboard"
    DTDFVocab:provides PositionErrorReductionInsight
]

instance FrictionParameterIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of static, kinetic and viscous friction parameters and provision of updated friction models"
    DTDFVocab:provides FrictionParameterExtractionInsight, UpdateFrictionModelAction
]

// C17: Insights
instance FrictionParameterExtractionInsight : DTDFVocab:Insight [
    base:desc "Extraction of friction parameters (static, kinetic, viscous) from sensor and simulation data"
]

instance PositionErrorReductionInsight : DTDFVocab:Insight [
    base:desc "Reduced positioning errors due to updated friction models fed back to the robot controller"
]

// C17: Actions
instance UpdateFrictionModelAction : DTDFVocab:Action [
    base:desc "Feed the newly identified friction model back to the SINUMERIK 840D controller to adjust motion control algorithms"
    DTDFVocab:IsAutomatic true
]

// Additional Component definitions (optional context)
instance MabiMax100Axis : DTDFVocab:Component [
    base:desc "First axis of the MABI MAX 100 industrial robot, comprising motor, gearwheel and cycloidal gearbox"
]

instance Motor : DTDFVocab:Component [
    base:desc "Electric motor driving the robot axis"
]

instance Gearwheel : DTDFVocab:Component [
    base:desc "Gearwheel coupled to the motor"
]

instance CycloidalGearbox : DTDFVocab:Component [
    base:desc "Cycloidal gearbox transmitting motion to the robot arm"
]

instance RobotEnvironment : DTDFVocab:Environment [
    base:contains MabiMax100Axis, Motor, Gearwheel, CycloidalGearbox
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, near‑real‑time operation during robot runtime; data are processed as they arrive from the MQTT stream."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow consisting of a purpose object (FrictionDerivation), an asset object (MABI axis), processing components (Simulation_M, Simulation_GW, Simulation_GB), models (engineering, simulation, data‑calculation) and linked data traces (I_M, r_M, r_G, r_out, ̂r_M, ̂r_G, ̂r_out) assembled according to the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operative stage – the digital shadow is created and used while the robot is in operation to monitor and improve performance."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Combination of white‑box (analytical) and black‑box (data‑driven) friction models, continuous re‑identification to account for wear and tool changes, and validation by comparing simulated outputs with measured reference data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data are transmitted from the physical robot to the digital shadow over MQTT; the connection is unidirectional (one‑way)."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach follows several standards: Asset Administration Shells (AAS) for asset representation, SysML (OMG specification) for systems modeling, UML (OMG) for class diagrams, and MQTT (OASIS) as the standardized messaging protocol for data transport."
]