// C1: Digital Twin Instance
instance FrictionShadow : DTDFVocab:DigitalTwin [
    base:desc "Digital shadow of the first axis of the MABI MAX 100 robot, representing static, kinetic and viscous friction parameters."
    DTDFVocab:hasEnvironment RobotEnvironment
]

// C2: Acting Components (none for this shadow)

// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) measuring the drive current of the robot axis."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder providing motor shaft angular position."
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary gearbox encoder delivering output shaft angular position."
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance DerivedTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Calculation unit deriving torque from current and motor parameters."
    DTDFVocab:producedData DerivedTorqueDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor (or calculation) yielding angular velocity of the axis."
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

instance AngularAccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor (or calculation) yielding angular acceleration of the axis."
    DTDFVocab:producedData AngularAccelerationDataTransmitted
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

instance DerivedTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DerivedTorqueSensor
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

instance AngularAccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularAccelerationSensor
]

// C10: Data instances (one per transmitted stream)
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor current I_M streamed via MQTT."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, MQTTEnabler
]

instance MotorEncoderData : DTDFVocab:Data [
    base:desc "Time‑series of motor shaft angle r_M streamed via MQTT."
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, MQTTEnabler
]

instance GearboxEncoderData : DTDFVocab:Data [
    base:desc "Time‑series of gearbox output angle r_out streamed via MQTT."
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, MQTTEnabler
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Calculated torque values derived from current and motor parameters."
    DTDFVocab:fromData DerivedTorqueDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, MQTTEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity ω of the axis, computed from encoder data."
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, MQTTEnabler
]

instance AngularAccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration α of the axis, computed from velocity data."
    DTDFVocab:fromData AngularAccelerationDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, MQTTEnabler
]

// C11: Enablers
instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker used for real‑time streaming of sensor traces."
    DTDFVocab:enables DashboardVisualizationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for friction model simulation."
    DTDFVocab:enables FrictionIdentificationService, ModelComparisonService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) linking MQTT data to SysML and Simulink models."
    DTDFVocab:enables DataIntegrationService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Custom dashboard platform presenting live visualisation of twin data."
    DTDFVocab:enables DashboardVisualizationService
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML tooling for structural and behavioral model management."
    DTDFVocab:enables ModelManagementService
]

// C6: Services
instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time dashboard visualisation of simulated versus measured behaviour."
    DTDFVocab:provides DeviationHighlightInsight, DashboardUpdateAction
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of static, kinetic and viscous friction parameters."
    DTDFVocab:provides FrictionParametersInsight, ModelUpdateAction
]

instance ModelComparisonService : DTDFVocab:Service [
    base:desc "Automatic comparison of simulated data with measured sensor traces."
    DTDFVocab:provides DeviationHighlightInsight
]

instance MotionControlImprovementService : DTDFVocab:Service [
    base:desc "Provision of model‑based insights to improve robot motion control accuracy."
    DTDFVocab:provides ControlAdjustmentAction
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Integration of streamed data into the Asset Administration Shell for model access."
    DTDFVocab:provides DataIntegrationInsight
]

instance ModelManagementService : DTDFVocab:Service [
    base:desc "Management of SysML block definition and internal block diagrams of the axis."
    DTDFVocab:provides ModelConsistencyInsight
]

// C17: Insights
instance FrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Extracted friction parameters (static, kinetic, viscous) fed back to controller."
]

instance DeviationHighlightInsight : DTDFVocab:Insight [
    base:desc "Highlight of deviations between simulated and measured behaviour for operator awareness."
]

instance DataIntegrationInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data are successfully linked to engineering models via AAS."
]

instance ModelConsistencyInsight : DTDFVocab:Insight [
    base:desc "Verification that SysML structural models are consistent with physical asset."
]

// C17: Actions
instance ModelUpdateAction : DTDFVocab:Action [
    base:desc "Automatic updating of white‑box and black‑box friction models with new parameters."
    DTDFVocab:IsAutomatic true
]

instance DashboardUpdateAction : DTDFVocab:Action [
    base:desc "Refresh of dashboard visualisation with latest simulation and measurement data."
    DTDFVocab:IsAutomatic true
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjustment of robot controller set‑points based on identified friction parameters."
    DTDFVocab:IsAutomatic true
]

// C9: Models / Data
instance SysMLAxisStructuralModel : DTDFVocab:Model [
    base:desc "SysML block definition diagram of the first robot axis including motor, gearboxes and controller."
    DTDFVocab:inputTo SysMLEnabler
]

instance SimulinkFrictionSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model comprising Coulomb‑Viscous, Stribeck, Dahl and LuGre friction formulations."
    DTDFVocab:inputTo SimulinkEnabler
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Model that converts raw sensor traces into torque, velocity and acceleration data."
    DTDFVocab:inputTo SimulinkEnabler
]

// C5: Physical Components
instance FirstAxisRobot : DTDFVocab:Component [
    base:desc "First axis of the MABI MAX 100 six‑axis industrial robot."
]

instance MotorComponent : DTDFVocab:Component [
    base:desc "Electric motor driving the first axis."
    base:contains MotorCurrentSensor, MotorEncoderSensor
]

instance Gearbox1Component : DTDFVocab:Component [
    base:desc "First gear stage (cycloidal gear) of the axis."
]

instance Gearbox2Component : DTDFVocab:Component [
    base:desc "Second gear stage of the axis."
    base:contains GearboxEncoderSensor
]

instance ControllerComponent : DTDFVocab:Component [
    base:desc "Siemens SINUMERIK 840D controller for motion execution."
]

// C12: Environment
instance RobotEnvironment : DTDFVocab:Environment [
    base:contains FirstAxisRobot, MotorComponent, Gearbox1Component, Gearbox2Component, ControllerComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None; the digital shadow does not transmit commands or data back to the physical robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time operation during robot motion; data are captured and processed on‑the‑fly to support live friction identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow composed of a defined purpose (FrictionDerivation), the asset (MABI first axis), data traces, sources, processing components (Simulation_M, Simulation_GW, Simulation_GB), and models; all integrated via the Digital Shadow Reference Model and visualized in a unified dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational stage – the digital shadow is applied while the robot is in use to monitor and improve performance; it is not limited to design or manufacturing phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability from data points to their generating processing component and models; continuous validation by comparing simulated data against measured sensor data; use of both white‑box (analytical) and black‑box (data‑driven) friction models to ensure model fidelity across operating conditions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data are transmitted from the robot to the digital shadow using the MQTT protocol; the Asset Administration Shell provides a standardized interface for model linkage."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Uses the Industry 4.0 Asset Administration Shell (AAS) standard and SysML (an OMG standard) for modeling; simulation models follow MATLAB/Simulink conventions."
]