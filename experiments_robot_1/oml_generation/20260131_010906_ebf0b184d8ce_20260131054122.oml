// C3: Physical sensing components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution motor encoder mounted directly on the motor of MABI MAX 100's first axis, providing precise position feedback for closed-loop control."
    DTDFVocab:producedData MotorPositionDataStream
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder positioned behind the gearbox of MABI MAX 100's first axis, providing redundant high-resolution position feedback."
    DTDFVocab:producedData GearboxPositionDataStream
]

instance OperationalLogCollector : DTDFVocab:SensingComponent [
    base:desc "Component collecting operational logs from MABI MAX 100's first axis, including system events and operational parameters."
    DTDFVocab:producedData OperationalLogDataStream
]

// C4: Physical-to-virtual interaction
instance MotorPositionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxPositionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

instance OperationalLogDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalLogCollector
]

instance ContextualDataTraces : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder, GearboxPositionEncoder, OperationalLogCollector
    base:desc "Aggregated contextual data traces from MABI MAX 100's first axis including sensor telemetry and operational logs."
]

// C10: Models/Data
instance TimeSeriesNormalizedData : DTDFVocab:Data [
    base:desc "Normalized time-series data from sensor telemetry and operational logs, structured for downstream analysis."
    DTDFVocab:fromData MotorPositionDataStream, GearboxPositionDataStream, OperationalLogDataStream
    DTDFVocab:inputTo DataAggregationEnabler, FeatureExtractionEnabler
]

instance FeatureExtractedData : DTDFVocab:Data [
    base:desc "Feature-extracted data from raw sensor telemetry and operational logs, enabling higher-level analysis."
    DTDFVocab:fromData TimeSeriesNormalizedData
    DTDFVocab:inputTo ContextualAnalysisEnabler
]

instance DigitalObjectStateModel : DTDFVocab:Model [
    base:desc "UML-based class diagram representing the digital object mirroring MABI MAX 100's first axis state (position, velocity, torque)."
    DTDFVocab:inputTo StateRepresentationEnabler
]

instance HeterogeneousDataIntegrationModel : DTDFVocab:Model [
    base:desc "Model supporting stakeholder-specific perspectives through heterogeneous data integration for engineers and operators."
    DTDFVocab:inputTo ContextualAnalysisEnabler
]

// C11: Enablers
instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "Automated ingestion and aggregation of contextual data traces from MABI MAX 100's first axis."
    DTDFVocab:enables DataCollectionService
]

instance FeatureExtractionEnabler : DTDFVocab:Enabler [
    base:desc "Feature extraction from time-series sensor data and operational logs using abstraction layers."
    DTDFVocab:enables DataCollectionService
]

instance StateRepresentationEnabler : DTDFVocab:Enabler [
    base:desc "Maintenance of digital object state mirroring physical system's state (position, velocity, torque)."
    DTDFVocab:enables StateRepresentationService
]

instance ContextualAnalysisEnabler : DTDFVocab:Enabler [
    base:desc "Support for stakeholder-specific perspectives through heterogeneous data integration."
    DTDFVocab:enables ContextualAnalysisService
]

instance MQTTCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "Low-latency, high-efficiency streaming of sensor/actuator data using MQTT protocol."
    DTDFVocab:enables DataCollectionService, StateRepresentationService
]

instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based modeling for system descriptions across requirements, functional, logical, and technical layers."
    DTDFVocab:enables DigitalObjectStateModel, HeterogeneousDataIntegrationModel
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for executable simulation models validating digital shadow behavior."
    DTDFVocab:enables StateRepresentationService, ContextualAnalysisService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Standardized digital representation framework encapsulating metadata, interfaces, and data models per Industry 4.0 standards."
    DTDFVocab:enables DataCollectionService, StateRepresentationService
]

// C6: Services
instance DataCollectionService : DTDFVocab:Service [
    base:desc "Automated ingestion of contextual data traces (sensor telemetry, operational logs) from MABI MAX 100's first axis with time-series normalization and feature extraction."
    DTDFVocab:provides DataCollectionInsight
]

instance StateRepresentationService : DTDFVocab:Service [
    base:desc "Maintenance of digital object mirroring physical system's state (position, velocity, torque) via UML-based class diagrams."
    DTDFVocab:provides StateObservationInsight
]

instance ContextualAnalysisService : DTDFVocab:Service [
    base:desc "Support for stakeholder-specific perspectives through heterogeneous data integration without autonomous decision-making."
    DTDFVocab:provides ContextualInsight
]

// C17: Insights/Actions
instance DataCollectionInsight : DTDFVocab:Insight [
    base:desc "Aggregated and structured contextual data traces from MABI MAX 100's first axis for downstream analysis."
]

instance StateObservationInsight : DTDFVocab:Insight [
    base:desc "Passive observation of dynamic behaviors of MABI MAX 100's first axis via digital object state representation."
]

instance ContextualInsight : DTDFVocab:Insight [
    base:desc "Stakeholder-specific perspectives (engineers, operators) enabled through heterogeneous data integration."
]

// C2: Acting Components
instance FirstAxisMotor : DTDFVocab:ActingComponent [
    base:desc "Motor component of MABI MAX 100's first vertical axis with defined operational constraints and safety mechanisms."
]

instance FirstAxisGearbox : DTDFVocab:ActingComponent [
    base:desc "Gearbox component of MABI MAX 100's first vertical axis with defined operational constraints and safety mechanisms."
]

instance SafetyCell : DTDFVocab:ActingComponent [
    base:desc "Safety mechanism ensuring operational integrity of MABI MAX 100's first axis with emergency stop protocols."
]

// C10: Additional Models/Data (Actuator-related)
instance ActuatorOperationalConstraintsModel : DTDFVocab:Model [
    base:desc "Model defining maximum working ranges and maximum achievable speeds for actuators in MABI MAX 100's first axis."
    DTDFVocab:inputTo ControlValidationEnabler
]

instance SimulatedDataDeviationModel : DTDFVocab:Model [
    base:desc "Model for dynamically validating actuation ranges against simulated data deviations."
    DTDFVocab:inputTo ControlValidationEnabler
]

// C11: Additional Enablers
instance ControlValidationEnabler : DTDFVocab:Enabler [
    base:desc "Validation of actuation ranges against simulated data deviations to ensure alignment with physical performance."
    DTDFVocab:enables ActuationControlService
]

// C6: Additional Services
instance ActuationControlService : DTDFVocab:Service [
    base:desc "Remote interface enabling real-time or scheduled actuation with safety constraints and addressing mechanisms."
    DTDFVocab:provides ActuationValidationInsight
]

// C17: Additional Insights/Actions
instance ActuationValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results of actuation ranges against simulated data deviations for MABI MAX 100's first axis."
]

// C10: Environment
instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:contains FirstAxisMotor, FirstAxisGearbox, SafetyCell, MotorPositionEncoder, GearboxPositionEncoder, OperationalLogCollector
]

instance DigitalShadowSystem : DTDFVocab:Environment [
    base:contains DataAggregationEnabler, FeatureExtractionEnabler, StateRepresentationEnabler, ContextualAnalysisEnabler,
                MQTTCommunicationEnabler, SysMLModelingEnabler, SimulinkSimulationEnabler, AssetAdministrationShellEnabler,
                DigitalObjectStateModel, HeterogeneousDataIntegrationModel, TimeSeriesNormalizedData, FeatureExtractedData
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system leverages a **Digital Shadow Reference Model** (as depicted in Fig. 1) to define its orchestration, where the digital shadow is structured as a UML class diagram to represent key concepts in manufacturing. The model emphasizes **automated one-way data flow** from the physical object to the digital representation, ensuring passive data aggregation and abstraction for specific purposes. The system does not explicitly describe hierarchical multiplicities or decentralized architectures but focuses on **contextual data traces** and their structured aggregation within a single digital shadow instance. The coordination mechanism is implicit in the **passive data collection** and abstraction process, with no active feedback loop to the physical system."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system emphasizes **model fidelity** through detailed **physical modeling**, including efforts to accurately describe **friction** in mechanical components. Validation is implied via comparisons of **simulated data versus measured data**, though no explicit methodologies (e.g., SysML formal verification, Simulink model-in-the-loop testing) are described. Uncertainty sources such as **sensor noise** or **abstraction errors** are not quantified, nor are error detection/correction mechanisms or quality assurance processes for models and data explicitly detailed. The text does not provide technical specifics on uncertainty quantification or validation frameworks."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with external systems via **MQTT-based data streaming** for real-time communication between the physical object and its digital shadow. The document specifies that the digital shadow operates as a **passive entity**, relying on external software components to interpret and process incoming data, but does not detail further interoperability standards or dependencies on other Digital Twins or enterprise systems. The integration is limited to the **one-way data flow** mechanism defined in the Digital Shadow Reference Model, with no explicit mention of bidirectional protocols or enterprise system interactions."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system incorporates **safety-critical considerations** through the **safety cell** of the robotic system (e.g., MABI robotic arm), which restricts the maximum working range to ensure operator and equipment safety. Data streaming within the system leverages **MQTT (Message Queuing Telemetry Transport)** as a lightweight protocol for real-time communication, though explicit cybersecurity protocols (e.g., OAuth, JWT, or TLS configurations) are not detailed in the provided documents. No evidence of formal **risk assessment methodologies**, **access control mechanisms**, or **fail-safe architectures** is present in the referenced materials. The absence of discussions on **data encryption**, **authentication systems**, or **compliance frameworks** (e.g., ISO 27001, GDPR) further limits the scope of security considerations."
]