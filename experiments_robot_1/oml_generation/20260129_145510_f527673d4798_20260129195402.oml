// ====================
// 1. Sensing Component (Virtual extraction of MBSE artifacts)
// ====================
instance ModelExtractionEngine : DTDFVocab:SensingComponent [
    base:desc "Virtual component that extracts structural, architectural and behavioural models from the MBSE workflow (SysML, ACME, AADL, MontiArc, Simulink)."
    DTDFVocab:producedData ModelExtractionDataTransmission
]

// ====================
// 2. Data Transmission for extracted models
// ====================
instance ModelExtractionDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ModelExtractionEngine
]

// ====================
// 3. Data Artifact representing the extracted models
// ====================
instance ExtractedModelData : DTDFVocab:Data [
    base:desc "Aggregated model artifacts (SysML diagrams, ADL specifications, state‑machine automata, Simulink blocks) produced by the ModelExtractionEngine."
    DTDFVocab:fromData ModelExtractionDataTransmission
    DTDFVocab:inputTo RFLPMethodology, OOSEMMethodology, SPESMethodology, SMArDTMethodology
]

// ====================
// 4. Enablers (Methodologies and Tools)
// ====================
instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements‑Functions‑Logics‑Physics) methodology guiding the development of the Digital Twin."
    DTDFVocab:enables ModelVerificationService, RuntimeSimulationService
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "Object‑oriented Systems Engineering Methodology (OOSEM) used to organise system decomposition."
    DTDFVocab:enables ModelVerificationService
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "Systems‑Product‑Engineering‑Synthesis (SPES) approach applied during twin engineering."
    DTDFVocab:enables ModelVerificationService
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT framework supporting the end‑to‑end Digital Twin lifecycle."
    DTDFVocab:enables ModelVerificationService, RuntimeSimulationService
]

instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML toolchain used for high‑level specification (requirements, functional, logical, physical layers)."
    DTDFVocab:enables ModelVerificationService
]

instance ACMEADLTool : DTDFVocab:Enabler [
    base:desc "ACME architecture description language tool for component‑connector definition."
    DTDFVocab:enables ModelVerificationService
]

instance AADLTool : DTDFVocab:Enabler [
    base:desc "AADL toolset for defining real‑time and embedded system architectures."
    DTDFVocab:enables ModelVerificationService
]

instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc language and tooling for component and connector modelling."
    DTDFVocab:enables ModelVerificationService
]

instance SimulinkSimulator : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for continuous‑time behavioural simulation."
    DTDFVocab:enables RuntimeSimulationService
]

instance CppCodeGenerator : DTDFVocab:Enabler [
    base:desc "C++ code generator for compiled behavioural implementations."
    DTDFVocab:enables RuntimeSimulationService
]

instance JavaCodeGenerator : DTDFVocab:Enabler [
    base:desc "Java code generator for compiled behavioural implementations."
    DTDFVocab:enables RuntimeSimulationService
]

// ====================
// 5. Services
// ====================
instance ModelVerificationService : DTDFVocab:Service [
    base:desc "Service performing model verification (e.g., checking SysML constraints) before twin deployment."
    DTDFVocab:provides ModelConsistencyInsight, DeployTwinAction
]

instance RuntimeSimulationService : DTDFVocab:Service [
    base:desc "Service executing runtime simulation of behavioural models (Simulink, compiled code) for validation."
    DTDFVocab:provides SimulationValidityInsight, DeployTwinAction
]

// ====================
// 6. Insights / Actions
// ====================
instance ModelConsistencyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that structural and architectural models satisfy all defined constraints."
]

instance SimulationValidityInsight : DTDFVocab:Insight [
    base:desc "Insight confirming that the simulated behavioural model behaves within expected physical limits."
]

instance DeployTwinAction : DTDFVocab:Action [
    base:desc "Action to deploy the validated Digital Twin into the operational environment."
    DTDFVocab:IsAutomatic false
]

// ====================
// 7. Models (Structural, Architectural, Behavioural)
// ====================
instance StructuralSysMLModel : DTDFVocab:Model [
    base:desc "Structural model expressed in SysML (including internal block diagrams) describing components and their connections."
    DTDFVocab:inputTo SysMLTool, RFLPMethodology
]

instance ArchitectureACMEModel : DTDFVocab:Model [
    base:desc "Architecture model defined in ACME ADL capturing component composition and connector topology."
    DTDFVocab:inputTo ACMEADLTool, RFLPMethodology
]

instance ArchitectureAADLModel : DTDFVocab:Model [
    base:desc "Architecture model defined in AADL detailing real‑time and embedded system properties."
    DTDFVocab:inputTo AADLTool, RFLPMethodology
]

instance ArchitectureMontiArcModel : DTDFVocab:Model [
    base:desc "Architecture model defined in MontiArc describing component interfaces and data flow."
    DTDFVocab:inputTo MontiArcTool, RFLPMethodology
]

instance BehaviouralStateMachineModel : DTDFVocab:Model [
    base:desc "Behavioural model captured as state‑machine specifications (MontiArc Automaton, SysML v1.7)."
    DTDFVocab:inputTo MontiArcTool, RFLPMethodology, SMArDTMethodology
]

instance SimulationSimulinkModel : DTDFVocab:Model [
    base:desc "Continuous‑time simulation model implemented in MathWorks Simulink for detailed dynamic behaviour."
    DTDFVocab:inputTo SimulinkSimulator, SMArDTMethodology
]

instance CppImplementationModel : DTDFVocab:Model [
    base:desc "Behavioural model translated into C++ source code for execution."
    DTDFVocab:inputTo CppCodeGenerator, SMArDTMethodology
]

instance JavaImplementationModel : DTDFVocab:Model [
    base:desc "Behavioural model translated into Java source code for execution."
    DTDFVocab:inputTo JavaCodeGenerator, SMArDTMethodology
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the Model‑Based Systems‑Engineering (MBSE) development ladder: (1) Requirements engineering using SysML requirement diagrams, (2) Functional architecture modelling with SysML internal block diagrams (IBDs), (3) Logical architecture captured by component‑connector ADLs (e.g., ACME, AADL, MontiArc), and (4) Product/technical implementation represented by executable simulation models (MathWorks Simulink) or source code (C++, Java). Transition between stages is managed through traceability links and model integration across abstraction layers, while lifecycle governance is achieved by the MBSE process that coordinates heterogeneous stakeholders and enforces model consistency."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin model adopts industry‑wide standards: SysML (OMG specification) for requirements and architecture diagrams, Architecture Description Languages such as ACME, AADL and MontiArc for component‑connector specifications, and UML class diagrams for the digital‑shadow reference model. By conforming to these standards, the twin ensures interoperability across modelling tools and facilitates integration with other engineering artefacts."
]