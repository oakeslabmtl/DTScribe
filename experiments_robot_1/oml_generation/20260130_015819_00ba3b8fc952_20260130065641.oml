// C3: Physical sensing components (implied from Digital Shadow context)
instance IndustrialIotSensor : DTDFVocab:SensingComponent [
    base:desc "Collects raw operational data traces from physical system components via IIoT protocols, supporting one-way data flow to Digital Shadow infrastructure."
    DTDFVocab:producedData IndustrialIotDataStream
]

instance OperationalLogCollector : DTDFVocab:SensingComponent [
    base:desc "Aggregates structured operational logs and environmental metrics from physical system components for contextual data enrichment."
    DTDFVocab:producedData OperationalLogDataStream
]

// C4: Physical-to-virtual interaction
instance IndustrialIotDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndustrialIotSensor
    base:desc "One-way data flow containing sensor readings and actuator states transmitted from physical system to Digital Shadow infrastructure."
]

instance OperationalLogDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalLogCollector
    base:desc "Structured operational logs and contextual metrics transmitted from physical system components for Digital Shadow aggregation."
]

// C10: Models/Data
instance PhysicalSystemGeometricModel : DTDFVocab:Model [
    base:desc "SysML-compatible geometric model representing physical system structures across multiple abstraction layers (requirements to product layers)."
    DTDFVocab:inputTo SysMLToolchain, MontiArcComponentModeler
]

instance ComponentInteractionModel : DTDFVocab:Model [
    base:desc "Architecture Description Language model (ACME/AADL/MontiArc) capturing component interfaces, connectors, and compositions for system decomposition."
    DTDFVocab:inputTo MontiArcComponentModeler, AADLToolchain
]

instance BehavioralStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine or MontiArc Automaton model defining system behavioral dynamics and transition logic."
    DTDFVocab:inputTo MontiArcComponentModeler
]

instance PhysicsBasedSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink or equivalent simulation model integrating physics-based behaviors for dynamic system analysis."
    DTDFVocab:inputTo SimulinkEngine, CustomSimulationFramework
]

instance DigitalShadowDataRepository : DTDFVocab:Data [
    base:desc "Passive repository of contextual data traces from physical system, aggregated and abstracted via one-way data ingestion."
    DTDFVocab:fromData IndustrialIotDataStream, OperationalLogDataStream
    DTDFVocab:inputTo DigitalShadowProcessor, DataQualityValidator
]

instance ProcessedSystemStateData : DTDFVocab:Data [
    base:desc "Normalized and validated system state data derived from Digital Shadow traces, ready for active DT processing."
    DTDFVocab:fromData DigitalShadowDataRepository
    DTDFVocab:inputTo OptimizationEngine, ControlLogicExecutor
]

// C11: Enablers
instance SysMLToolchain : DTDFVocab:Enabler [
    base:desc "SysML-based modeling environment supporting requirements, functional, logical, and product architecture layers with Internal Block Diagrams."
    DTDFVocab:enables SystemDesignService, RequirementsTraceabilityService
]

instance MontiArcComponentModeler : DTDFVocab:Enabler [
    base:desc "MontiArc architecture description tool enabling component/connector modeling with behavioral extensions via MontiArc Automaton."
    DTDFVocab:enables ComponentInteractionService, BehavioralModelingService
]

instance AADLToolchain : DTDFVocab:Enabler [
    base:desc "AADL-based architecture description for safety-critical system modeling with formal component interfaces."
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink dynamic system simulation platform for control algorithm prototyping and physics-based modeling."
    DTDFVocab:enables PhysicsSimulationService, ClosedLoopValidationService
]

instance CustomSimulationFramework : DTDFVocab:Enabler [
    base:desc "Generic discrete-event or continuous-time simulation framework for behavioral validation across heterogeneous tools."
]

instance DigitalShadowProcessor : DTDFVocab:Enabler [
    base:desc "Data processing pipeline for Digital Shadow infrastructure handling one-way data ingestion, aggregation, and contextual abstraction."
    DTDFVocab:enables DataAggregationService, ContextualAbstractionService
]

instance DataQualityValidator : DTDFVocab:Enabler [
    base:desc "Quality assurance module for Digital Shadow data ensuring normalization, filtering, and error correction before active processing."
    DTDFVocab:enables DataValidationService, AnomalyDetectionService
]

instance OptimizationEngine : DTDFVocab:Enabler [
    base:desc "Model-based optimization component integrating simulation tools to refine system parameters via closed-loop feedback."
    DTDFVocab:enables ParameterOptimizationService, ResourceAllocationService
]

instance PredictionServiceEngine : DTDFVocab:Enabler [
    base:desc "Behavioral forecasting engine using state machines and historical data traces to predict system transitions and failures."
    DTDFVocab:enables FailurePredictionService, OperationalForecastingService
]

instance ControlLogicExecutor : DTDFVocab:Enabler [
    base:desc "Active component executing autonomous decision-making logic in C++/Java for corrective actions and adaptive control policies."
    DTDFVocab:enables AutonomousControlService, ClosedLoopExecutionService
]

instance VisualizationDashboard : DTDFVocab:Enabler [
    base:desc "Multi-abstraction visualization platform rendering system models across layers (requirements to physics) with stakeholder-specific views."
    DTDFVocab:enables SystemVisualizationService, StakeholderDashboardService
]

// C6: Services
instance SystemDesignService : DTDFVocab:Service [
    base:desc "MBSE-based system design service leveraging SysML across requirements, functional, and product architecture layers."
    DTDFVocab:provides SystemDesignInsight
]

instance RequirementsTraceabilityService : DTDFVocab:Service [
    base:desc "Service ensuring traceability between system requirements and implemented components via SysML modeling."
    DTDFVocab:provides RequirementsComplianceInsight
]

instance ComponentInteractionService : DTDFVocab:Service [
    base:desc "Service managing component interfaces, connectors, and compositions using MontiArc/ACME/AADL architecture models."
    DTDFVocab:provides ComponentInteractionInsight
]

instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Service capturing system behavior via state machines (SysML v1.7/MontiArc Automaton) integrated with simulation tools."
    DTDFVocab:provides BehavioralModelInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Service handling one-way data ingestion from physical system sensors/actuators for Digital Shadow infrastructure."
    DTDFVocab:provides DataAggregationInsight
]

instance ContextualAbstractionService : DTDFVocab:Service [
    base:desc "Service performing contextual aggregation and abstraction of raw sensor/operational data traces."
    DTDFVocab:provides ContextualDataInsight
]

instance DataValidationService : DTDFVocab:Service [
    base:desc "Service ensuring data quality through normalization, filtering, and error correction of Digital Shadow traces."
    DTDFVocab:provides DataQualityInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Service identifying deviations from expected operational profiles using aggregated Digital Shadow data."
    DTDFVocab:provides AnomalyDetectionInsight
]

instance PhysicsSimulationService : DTDFVocab:Service [
    base:desc "Service providing physics-based system simulation using MathWorks Simulink or equivalent frameworks."
    DTDFVocab:provides PhysicsSimulationInsight
]

instance ClosedLoopValidationService : DTDFVocab:Service [
    base:desc "Service validating system behavior through co-simulation between physical system and digital twin models."
    DTDFVocab:provides ValidationInsight
]

instance ParameterOptimizationService : DTDFVocab:Service [
    base:desc "Service refining system parameters (control logic, resource allocation) via model-based optimization."
    DTDFVocab:provides OptimizationInsight
]

instance ResourceAllocationService : DTDFVocab:Service [
    base:desc "Service optimizing resource allocation based on multi-objective trade-off analysis across stakeholder perspectives."
    DTDFVocab:provides ResourceAllocationInsight
]

instance FailurePredictionService : DTDFVocab:Service [
    base:desc "Service predicting system failures and transitions using state machines and historical data traces."
    DTDFVocab:provides FailurePredictionInsight
]

instance OperationalForecastingService : DTDFVocab:Service [
    base:desc "Service forecasting operational scenarios and system behavior based on processed Digital Shadow data."
    DTDFVocab:provides OperationalForecastInsight
]

instance AutonomousControlService : DTDFVocab:Service [
    base:desc "Service executing autonomous decision-making and corrective actions based on Digital Twin insights."
    DTDFVocab:provides ControlAction
]

instance ClosedLoopExecutionService : DTDFVocab:Service [
    base:desc "Service enabling continuous validation and adjustment of physical system behavior via closed-loop control."
    DTDFVocab:provides ClosedLoopAction
]

instance SystemVisualizationService : DTDFVocab:Service [
    base:desc "Service rendering multi-abstraction system models across requirements to physics layers for visualization."
    DTDFVocab:provides SystemVisualizationInsight
]

instance StakeholderDashboardService : DTDFVocab:Service [
    base:desc "Service providing customized visualizations for engineers (component diagrams), managers (KPIs), and operators (telemetry)."
    DTDFVocab:provides StakeholderDashboardInsight
]

