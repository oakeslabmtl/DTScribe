// Environment containing all components of the first rotary axis
instance MABIMax100IndustrialRobotEnvironment : DTDFVocab:Environment [
    base:contains Motor, GearwheelGearbox, CycloidalGearbox, PMSMSynchronousMotorCurrentSensor,
            MotorSideEncoder, PostGearboxEncoder, DigitalShadowProcessingUnit
]

// Structural components
instance Motor : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor of the first rotary axis of MABI MAX 100 industrial robot"
]

instance GearwheelGearbox : DTDFVocab:Component [
    base:desc "Gearwheel gearbox connected to the motor in the first rotary axis of MABI MAX 100"
]

instance CycloidalGearbox : DTDFVocab:Component [
    base:desc "Cycloidal gearbox forming part of the first rotary axis of MABI MAX 100"
]

instance DigitalShadowProcessingUnit : DTDFVocab:Component [
    base:desc "Processing component of the digital twin that consumes measurement traces and generates computed traces"
]

// Physical sensing components
instance PMSMSynchronousMotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor for the permanent‑magnet synchronous motor (measures I_M)"
    DTDFVocab:producedData MotorCurrentMQTTTopic
]

instance MotorSideEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor side of the first rotary axis"
    DTDFVocab:producedData MotorSideEncoderMQTTTopic
]

instance PostGearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder located after the gearbox, providing joint angle for the first rotary axis"
    DTDFVocab:producedData PostGearboxEncoderMQTTTopic
]

// Data transmitted via MQTT topics
instance MotorCurrentMQTTTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PMSMSynchronousMotorCurrentSensor
]

instance MotorSideEncoderMQTTTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSideEncoder
]

instance PostGearboxEncoderMQTTTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PostGearboxEncoder
]

// Measured data (from sensor streams)
instance MeasuredMotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current trace I_M received from the current sensor via MQTT"
    DTDFVocab:fromData MotorCurrentMQTTTopic
    DTDFVocab:inputTo SimulinkTool, AssetAdministrationShell
]

instance MeasuredMotorSideEncoderData : DTDFVocab:Data [
    base:desc "Measured motor‑side encoder angle trace r_M via MQTT"
    DTDFVocab:fromData MotorSideEncoderMQTTTopic
    DTDFVocab:inputTo SimulinkTool, AssetAdministrationShell
]

instance MeasuredPostGearboxEncoderData : DTDFVocab:Data [
    base:desc "Measured post‑gearbox encoder angle trace r_G via MQTT"
    DTDFVocab:fromData PostGearboxEncoderMQTTTopic
    DTDFVocab:inputTo SimulinkTool, AssetAdministrationShell
]

// Derived computed data
instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Calculated joint torque derived from current and encoder data"
    DTDFVocab:inputTo SimulinkTool
]

instance DerivedAngularVelocityData : DTDFVocab:Data [
    base:desc "Calculated joint angular velocity derived from encoder data"
    DTDFVocab:inputTo SimulinkTool
]

instance DerivedAccelerationData : DTDFVocab:Data [
    base:desc "Calculated joint acceleration derived from encoder data"
    DTDFVocab:inputTo SimulinkTool
]

// Simulated data from models
instance SimulatedMotorSideData : DTDFVocab:Data [
    base:desc "Simulated motor‑side trace r_M from the motor model"
    DTDFVocab:inputTo SimulinkTool
]

instance SimulatedPostGearboxData : DTDFVocab:Data [
    base:desc "Simulated post‑gearbox trace r_G from the gearbox model"
    DTDFVocab:inputTo SimulinkTool
]

instance SimulatedJointOutputData : DTDFVocab:Data [
    base:desc "Simulated joint output trace r_out from the complete assembly model"
    DTDFVocab:inputTo SimulinkTool
]

// Simulation models
instance MotorModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink block model of the permanent‑magnet synchronous motor"
    DTDFVocab:inputTo SimulinkTool
]

instance GearwheelGearboxModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink block model of the gearwheel gearbox"
    DTDFVocab:inputTo SimulinkTool
]

instance CycloidalGearboxModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink block model of the cycloidal gearbox"
    DTDFVocab:inputTo SimulinkTool
]

instance FrictionModelCoulombViscous : DTDFVocab:Model [
    base:desc "White‑box Coulomb‑Viscous friction model implemented in Simulink"
    DTDFVocab:inputTo SimulinkTool
]

instance FrictionModelStribeck : DTDFVocab:Model [
    base:desc "White‑box Stribeck friction model implemented in Simulink"
    DTDFVocab:inputTo SimulinkTool
]

instance FrictionModelDahl : DTDFVocab:Model [
    base:desc "Black‑box Dahl friction model implemented in Simulink"
    DTDFVocab:inputTo SimulinkTool
]

instance FrictionModelLuGre : DTDFVocab:Model [
    base:desc "Black‑box LuGre friction model implemented in Simulink"
    DTDFVocab:inputTo SimulinkTool
]

// Enablers
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML used for structural modeling of the robot components and connections"
    DTDFVocab:enables SysMLModelingService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink used to execute simulation models of the motor, gearbox, and friction"
    DTDFVocab:enables FrictionModelIdentification, RealTimeAnalysisService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker responsible for streaming real‑time sensor data from the controller"
    DTDFVocab:enables DataStreamService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell used to link physical assets and data traces"
    DTDFVocab:enables DataTraceabilityService
]

instance WebDashboard : DTDFVocab:Enabler [
    base:desc "Generic web stack dashboard visualising real‑time torque, velocity, and model comparison"
    DTDFVocab:enables RealTimeTorqueVelocityDashboard
]

// Services
instance RealTimeTorqueVelocityDashboard : DTDFVocab:Service [
    base:desc "Realtime dashboard comparing measured torque and simulated joint torque with angular velocity"
    DTDFVocab:provides RealTimeTorqueVelocityMatchInsight
]

instance FrictionModelIdentification : DTDFVocab:Service [
    base:desc "Continuous multi‑physics‑aware identification of white‑box and black‑box friction models"
    DTDFVocab:provides FrictionModelIdentificationInsight, AutomaticFrictionParameterUpdateAction
]

instance DataTraceabilityService : DTDFVocab:Service [
    base:desc "Data linking, aggregation, and traceability service improving controller tuning"
    DTDFVocab:provides DataTraceabilityInsight
]

instance DataStreamService : DTDFVocab:Service [
    base:desc "Opens MQTT topic streams for sensor data ingestion"
    DTDFVocab:provides DataIngestionInsight
]

instance RealTimeAnalysisService : DTDFVocab:Service [
    base:desc "Realtime simulation analysis service for motor, gearbox, and friction models"
    DTDFVocab:provides RealTimeSimulationInsight
]

instance SysMLModelingService : DTDFVocab:Service [
    base:desc "Structural model creation and validation using SysML"
    DTDFVocab:provides SysMLModelingInsight
]

// Insights
instance RealTimeTorqueVelocityMatchInsight : DTDFVocab:Insight [
    base:desc "Insight indicating whether measured torque matches simulated torque in real time"
]

instance FrictionModelIdentificationInsight : DTDFVocab:Insight [
    base:desc "Insight containing identified friction model parameters for white‑ and black‑box models"
]

instance AutomaticFrictionParameterUpdateAction : DTDFVocab:Action [
    base:desc "Automatically updates friction parameters in the simulation models based on latest identification"
    DTDFVocab:IsAutomatic true
]

instance DataTraceabilityInsight : DTDFVocab:Insight [
    base:desc "Insight linking data traces to physical assets for traceability"
]

instance DataIngestionInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful ingestion of data from MQTT streams"
]

instance RealTimeSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight on simulation health and performance during realtime analysis"
]

instance SysMLModelingInsight : DTDFVocab:Insight [
    base:desc "Insight on the completeness and consistency of SysML structural models"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the DT does not send control commands back to the robot; it serves only as a passive observer and visualizer."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous operation; data ingestion and processing at the robot’s run‑time (milliseconds to seconds); friction model updates are performed online during machining cycles."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated by a central processing component that ingests MQTT streams, runs Simulink simulations, aggregates data traces, and provides a unified dashboard; AAS links the physical asset to the digital shadow; simulation, data‑calculation and processing models are interconnected via the digital shadow reference model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Designed using structural SysML models (hardware layout); implemented as an operational digital shadow during the robot’s runtime; includes continuous improvement by updating friction parameters; does not cover manufacturing or design‑time stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of every data point back to its originating measurement or simulation; continuous identification of white‑box vs. black‑box models; multi‑physics‑aware friction identification; validation achieved by comparing simulated torque/velocity against measured data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data transferred over MQTT protocol to the processing unit; topics correspond to sensor channels; the digital shadow optionally exposes an AAS interface for metadata and provenance."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted on an industrial PC or edge server within the robot’s safety cell that runs the MQTT broker, simulation backend (Simulink), and dashboard; no cloud deployment specified."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "SysML (v1.7) for system modelling, Asset Administration Shell specification for digital twin representation, MQTT (ISO/IEC 20922) for data exchange."
]