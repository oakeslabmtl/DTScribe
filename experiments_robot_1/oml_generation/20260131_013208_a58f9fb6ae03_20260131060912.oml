// C3: Physical sensing components
instance MotorShaftPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted directly on the motor shaft to measure angular position with high precision for joint friction analysis."
    DTDFVocab:producedData MotorShaftPositionData
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder located behind the gearbox to mitigate backlash and positional uncertainty in the transmission system."
    DTDFVocab:producedData GearboxPositionData
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor current, converted to applied torque using known PMSM parameters for friction estimation."
    DTDFVocab:producedData MotorCurrentData
]

// C4: Physical-to-virtual interaction
instance MotorShaftPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftPositionEncoder
]

instance GearboxPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Models/Data
instance JointFrictionModel : DTDFVocab:Model [
    base:desc "Mathematical model representing joint friction dynamics in the PMSM-gear transmission system, incorporating backlash compensation."
    DTDFVocab:inputTo SysMLModelingEnabler, SimulinkSimulationEnabler
]

instance TimeSeriesSensorData : DTDFVocab:Data [
    base:desc "Aggregated time-series data traces from all sensors (position and current) streamed via MQTT for real-time analysis."
    DTDFVocab:fromData MotorShaftPositionData, GearboxPositionData, MotorCurrentData
    DTDFVocab:inputTo MQTTDataStreamingEnabler, SysMLModelingEnabler
]

instance RobotAxisPhysicalModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) representing the first axis of MABI MAX 100 robot with PMSM, gearbox, and controller components."
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance FrictionCompensationLogic : DTDFVocab:Model [
    base:desc "Behavioral model implemented in MathWorks Simulink for friction compensation and motion optimization."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

// C11: Enablers
instance MQTTDataStreamingEnabler : DTDFVocab:Enabler [
    base:desc "MQTT-based real-time data streaming infrastructure for transmitting sensor time-series traces from physical system to Digital Shadow."
    DTDFVocab:enables DataAggregationService
]

instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML toolchain for multi-layer modeling (requirements, functional, logical, physical) using Internal Block Diagrams and state machines."
    DTDFVocab:enables JointFrictionAnalysisService, SystemMonitoringService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for behavioral modeling and simulation of friction dynamics and control logic."
    DTDFVocab:enables MotionOptimizationService
]

instance UMLClassDiagramEnabler : DTDFVocab:Enabler [
    base:desc "UML class diagram defining the Digital Shadow reference model with data traces, aggregation, and abstraction concepts."
    DTDFVocab:enables DataAggregationService
]

// C6: Services
instance DataAggregationService : DTDFVocab:Service [
    base:desc "Service responsible for collecting, preprocessing, and aggregating raw sensor data into meaningful time-series traces."
    DTDFVocab:provides SensorDataInsight
]

instance JointFrictionAnalysisService : DTDFVocab:Service [
    base:desc "Service analyzing joint friction patterns using position and torque data to identify wear and operational anomalies."
    DTDFVocab:provides FrictionPatternInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Dashboard service presenting aggregated data traces and friction analysis results for stakeholder monitoring."
    DTDFVocab:provides SystemStateInsight
]

instance SystemMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of robot axis state using SysML models and sensor data for operational integrity."
    DTDFVocab:provides OperationalHealthInsight
]

instance MotionOptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing robot motion trajectories based on friction compensation models and real-time sensor data."
    DTDFVocab:provides FrictionPatternInsight
]

instance FrictionCompensationService : DTDFVocab:Service [
    base:desc "Service implementing real-time friction compensation algorithms using Simulink models and sensor feedback."
    DTDFVocab:provides OperationalHealthInsight
]

// C17: Insights/Actions
instance SensorDataInsight : DTDFVocab:Insight [
    base:desc "Aggregated time-series data traces from position encoders and current sensors with backlash compensation applied."
]

instance FrictionPatternInsight : DTDFVocab:Insight [
    base:desc "Identified joint friction characteristics including static/dynamic friction, stiction, and wear progression patterns."
]

instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Visualized operational state of robot axis including position accuracy, torque application, and friction-induced deviations."
]

instance OperationalHealthInsight : DTDFVocab:Insight [
    base:desc "Assessment of robot axis health based on friction analysis and sensor data consistency."
]

// C1: Digital Twin Services
instance PassiveDigitalShadowService : DTDFVocab:Service [
    base:desc "Passive Digital Shadow service providing one-way data flow from physical robot axis to digital representation without active control."
    DTDFVocab:provides SystemStateInsight, OperationalHealthInsight
]

// C5: Environment
instance RobotAxisEnvironment : DTDFVocab:Environment [
    base:desc "Physical environment containing the first axis of MABI MAX 100 robot with PMSM motor, gear transmission, and Siemens SINUMERIK 840D sl controller."
    base:contains MotorShaftPositionEncoder, GearboxPositionEncoder, MotorCurrentSensor
]

instance DigitalShadowEnvironment : DTDFVocab:Environment [
    base:desc "Digital environment hosting the Digital Shadow with SysML models, Simulink simulations, and visualization dashboards."
    base:contains JointFrictionModel, RobotAxisPhysicalModel, FrictionCompensationLogic, TimeSeriesSensorData
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin constellation** in the document is implicitly defined through **Model-Based Systems Engineering (MBSE)** methodologies, which rely on **multi-notation modeling** (e.g., SysML for architecture, ADLs like MontiArc or AADL for component-connector views, and simulation tools like Simulink for behavior). The **orchestration** involves integrating **heterogeneous models** (e.g., functional/logical architectures via ADLs) with **behavioral descriptions** (e.g., state machines in SysML v1.7 or code in C++/Java). **Resource management** is not explicitly detailed, but the document suggests **coordination mechanisms** are required to handle **complexity across abstraction layers** (e.g., RFLP, OOSEM, or SMArDT methodologies). The **architecture pattern** leans toward **modular, component-based integration**, where components (e.g., MontiArc Automaton) describe behavior, and connectors ensure interoperability between tools."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin’s **fidelity** is evaluated through the **deviation of simulated data versus measured data**, with a defined **solution scope** focused on **detecting friction loss in the robot’s first axis**. **Uncertainty sources** include **positional uncertainty**, mitigated by the **dual-encoder arrangement** (motor + gearbox). **Validation methods** implicitly rely on:
  - **Sensor redundancy** (two encoders per axis) to cross-validate positional data.
  - **Comparison of simulated vs. real-world behavior** (e.g., torque estimation from current sensors).
  No explicit **error correction mechanisms, uncertainty quantification metrics, or formal quality assurance processes** (e.g., ISO standards, statistical tests) are documented."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for the Digital Shadow system includes the use of **MQTT** as the communication protocol for streaming sensor data from physical assets to the digital representation. While the document does not specify network topology, bandwidth requirements, or redundancy mechanisms, the reliance on MQTT indicates a lightweight, publish-subscribe architecture suitable for IoT and industrial environments. Security protocols are not explicitly mentioned, nor are details about latency or reliability mechanisms provided."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The document does not provide explicit details on **horizontal integration** with external systems (e.g., data exchange protocols, interoperability standards, or dependencies). However, it implies **integration patterns** are necessary to bridge **heterogeneous modeling tools** (e.g., SysML, ADLs, Simulink) and **general-purpose languages** (C++, Java). While no specific protocols (e.g., OPC UA, MQTT) or standards are mentioned, the need to **aggregate and abstract contextual data traces** (as defined in the digital shadow reference model) suggests **interoperability challenges** must be addressed for seamless data exchange between **Digital Twins and enterprise systems** or other **Digital Twins**. The document does not specify whether integration is **push-based (digital shadow)** or **bidirectional (Digital Twin)**."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE) standards**, including the use of **SysML (Systems Modeling Language)** for system architecture and behavior modeling. **Architecture Description Languages (ADLs)** such as **ACME**, **AADL**, and **MontiArc** are employed for component-based system design, ensuring compliance with **component & connector perspectives** for interoperability. The system integrates with **simulation tools** (e.g., **MathWorks Simulink**) and **general-purpose programming languages** (e.g., C++, Java), which may align with industry standards like **IEC 61131-3** (for PLC programming) or **OMG standards** (for modeling languages). While **interoperability standards** are implied through the use of ADLs and MBSE, no explicit **certification frameworks** or **compliance specifications** (e.g., ISO 26262 for automotive, IEC 62443 for cybersecurity) are mentioned. The **Digital Shadow Reference Model** (as per Kritzinger et al.) does not directly address standardization but defines foundational concepts for data aggregation and abstraction, which may indirectly influence compliance."
]