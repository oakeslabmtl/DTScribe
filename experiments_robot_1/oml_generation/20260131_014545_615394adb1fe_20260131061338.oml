// C3: Physical sensing components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted directly on the motor shaft to measure input angles for positional feedback in the MABI MAX 100 robot."
    DTDFVocab:producedData MotorShaftEncoderData
]

instance GearboxOutputEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearbox to measure output angles, used for friction loss analysis and uncertainty reduction."
    DTDFVocab:producedData GearboxOutputEncoderData
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor monitoring input current to the motor for performance and fault detection in the robotic system."
    DTDFVocab:producedData MotorCurrentData
]

// C4: Physical-to-virtual interaction
instance MotorShaftEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxOutputEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxOutputEncoder
]

instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Models/Data
instance GeometricModel : DTDFVocab:Model [
    base:desc "Implicit geometric representation of the MABI MAX 100 robot's kinematic structure, leveraging SysML or CAD tools for structural description."
    DTDFVocab:inputTo SysMLModelingTool
]

instance BehavioralModel : DTDFVocab:Model [
    base:desc "Component-based behavioral model defined using MontiArc Automaton for state-based behavior, describing interfaces, interconnections, and composition."
    DTDFVocab:inputTo MontiArcADL
]

instance PhysicsBasedSimulationModel : DTDFVocab:Model [
    base:desc "Physics-based analytical model integrated with MathWorks Simulink for detailed system analysis, including control logic implementation."
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "UML class diagram-based Digital Shadow Reference Model aggregating raw sensor data into structured representations for abstraction."
    DTDFVocab:inputTo SysMLModelingTool
]

instance SensorDataTrace : DTDFVocab:Data [
    base:desc "Time-series data from all sensors (angles, currents) aggregated for friction loss analysis and uncertainty reduction."
    DTDFVocab:fromData MotorShaftEncoderData, GearboxOutputEncoderData, MotorCurrentData
    DTDFVocab:inputTo DigitalShadowIntegrationFramework
]

instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces (sensor logs, operational events) derived from physical system for higher-level insights."
    DTDFVocab:fromData SensorDataTrace
    DTDFVocab:inputTo DataAggregationService
]

// C11: Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML v1.7+ used for multi-layered system modeling (requirements, functional/logical architectures, product layers) and behavioral descriptions via state machines."
    DTDFVocab:enables DigitalShadowMonitoringService, SystemSimulationService
]

instance MontiArcADL : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component-based system decomposition, interface definitions, and composition rules."
    DTDFVocab:enables BehavioralModelSimulationService
]

instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for dynamic system simulation, control logic implementation, and real-time testing of behavioral models."
    DTDFVocab:enables PhysicsBasedSimulationService
]

instance DigitalShadowIntegrationFramework : DTDFVocab:Enabler [
    base:desc "Framework for passive data collection and aggregation from physical objects (Digital Shadow) into structured digital representations."
    DTDFVocab:enables DataAggregationService
]

instance DataAggregationService : DTDFVocab:Enabler [
    base:desc "Service handling aggregation and abstraction of raw sensor data into meaningful digital representations for analysis."
    DTDFVocab:enables ContextualDataAnalysisService
]

// C6: Services
instance DigitalShadowMonitoringService : DTDFVocab:Service [
    base:desc "Real-time collection, aggregation, and abstraction of contextual data traces (sensor readings, operational logs) for performance tracking."
    DTDFVocab:provides RealTimePerformanceInsight
]

instance SystemSimulationService : DTDFVocab:Service [
    base:desc "Passive data-driven simulations (replaying operational states, trend analysis) using aggregated data without active intervention."
    DTDFVocab:provides OperationalStateInsight
]

instance BehavioralModelSimulationService : DTDFVocab:Service [
    base:desc "Simulation of component-based behavioral models using MontiArc Automaton for state-based behavior analysis."
    DTDFVocab:provides ComponentBehaviorInsight
]

instance PhysicsBasedSimulationService : DTDFVocab:Service [
    base:desc "Physics-based simulations for detailed system analysis, including control logic implementation and real-time testing."
    DTDFVocab:provides PhysicsBasedAnalysisInsight
]

instance ContextualDataAnalysisService : DTDFVocab:Service [
    base:desc "Analysis of aggregated contextual data traces for deriving higher-level insights (e.g., friction analysis, predictive maintenance)."
    DTDFVocab:provides MaintenanceRecommendationInsight
]

// C17: Insights/Actions
instance RealTimePerformanceInsight : DTDFVocab:Insight [
    base:desc "Observational insights into real-time performance metrics derived from aggregated sensor data traces."
]

instance OperationalStateInsight : DTDFVocab:Insight [
    base:desc "Replayed operational states and trend analysis for understanding system behavior over time."
]

instance ComponentBehaviorInsight : DTDFVocab:Insight [
    base:desc "Behavioral insights from MontiArc Automaton simulations, including component interactions and state transitions."
]

instance PhysicsBasedAnalysisInsight : DTDFVocab:Insight [
    base:desc "Physics-based analysis results, including control logic validation and system performance optimization."
]

instance MaintenanceRecommendationInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance recommendations based on aggregated contextual data and friction analysis."
]

// C1: Acting Components (from system_under_study)
instance MABIMax100RobotController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl controller managing motion control for the MABI MAX 100 six-axis serial robot."
]

instance RobotMotorDrive : DTDFVocab:ActingComponent [
    base:desc "Motor drive system integrating motors, gearboxes, and encoders for positional feedback in the robotic system."
]

// C2: Environment (from system_under_study)
instance ManufacturingAutomationEnvironment : DTDFVocab:Environment [
    base:desc "Industrial manufacturing/automation domain where the MABI MAX 100 robot operates, requiring high-precision motion and friction modeling."
    base:contains MABIMax100RobotController, RobotMotorDrive
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system's orchestration and coordination are implicitly supported by Model-Based Systems Engineering (MBSE) methodologies, which utilize architecture description languages (ADLs) such as ACME, AADL, MontiArc, or SysML Internal Block Diagrams (IBDs) to define component-based structures. These ADLs describe systems from a **component & connector perspective**, detailing components, their interfaces, interconnections, and composition. Behavioral aspects may be modeled using extensions like MontiArc Automaton or SysML state machines (v1.7), while detailed behavior is often implemented via simulation tools (e.g., MathWorks Simulink) or general-purpose programming languages (e.g., C++, Java). The document does not explicitly address **orchestration patterns** (e.g., service-oriented or microservices-based architectures) or **system-wide coordination mechanisms** for Digital Twins but suggests a structured, modular approach to system modeling."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle encompasses **development phase** (as referenced in Model-Based Systems Engineering (MBSE) methodologies) and **operational phase**, where the twin continuously evolves alongside the physical asset. During the **development phase**, the lifecycle includes structured modeling using **SysML** (e.g., requirements, functional architecture, logical architecture, and product/technical layers) and methodologies like **RFLP (Requirements, Functions, Logics, Physics)**, **OOSEM**, **SPES**, or **SMArDT** to manage complexity. The **operational phase** involves real-time data integration (e.g., via **MQTT** for streaming) and iterative refinement, ensuring the Digital Twin remains synchronized with the physical system's state. Transition management between phases relies on **traceability** (e.g., linking models to physical components) and **version control** (implicit in MBSE toolchains like **Simulink** or **MontiArc**). Lifecycle governance is supported by **architecture description languages (ADLs)** such as **AADL**, **ACME**, or **SysML IBDs**, which define component interfaces, interconnections, and composition, ensuring consistency across phases. The Digital Twin’s evolution is driven by **contextual data traces** (as defined in the Digital Shadow Reference Model) aggregated for specific purposes, enabling adaptive updates during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system ensures **fidelity** through **multi-layered abstraction** (e.g., requirements to product/technical layers) and **validation via deviation analysis** between **simulated data** (generated using tools like **MathWorks Simulink** or **C++/Java-based models**) and **measured data** from physical systems. **Uncertainty quantification** is implicitly addressed by comparing model outputs against real-world observations, though explicit methods (e.g., statistical error propagation or probabilistic modeling) are not detailed. The system relies on **tool-specific validation** (e.g., **SysML for structural correctness** via IBDs or **ADLs for component/interface consistency**) and **behavioral validation** through simulation tools. No explicit mention of **automated anomaly detection**, **error correction mechanisms**, or **quality assurance processes** (e.g., ISO/IEC standards) is provided in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with external systems through **MQTT-based data streaming** for sensor data acquisition, as referenced in Section IV.A. The physical system (e.g., an industrial robot) is controlled by an external **Siemens SINUMERIK 840d sl** controller, indicating dependency on enterprise-level manufacturing execution systems (MES) or supervisory control systems. Interoperability is implied via **heterogeneous modeling tools and notations** (e.g., SysML, Simulink, C++/Java), requiring standardized data exchange formats or middleware to bridge disparate platforms. The system’s design acknowledges the need to integrate **multiple stakeholder perspectives** and **external enterprise systems**, though specific interoperability standards (e.g., OPC UA, REST APIs) or integration patterns (e.g., API gateways, message brokers) are not explicitly detailed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **standardized modeling and interoperability frameworks**, including:
  - **Modeling Standards**: **SysML** (for systems engineering), **ADLs (ACME, AADL, MontiArc)** for architecture description, and **SysML IBDs** for component-connector modeling.
  - **Data/Communication Protocols**: While not explicitly named, the **Digital Shadow Reference Model** implies **one-way data flows** (e.g., sensor-to-digital object), which may align with **industry protocols like MQTT** (though not explicitly stated).
  - **Interoperability**: The use of **heterogeneous tools (Simulink, C++, Java)** suggests adherence to **open standards for model exchange** (e.g., **XMI for SysML**), though no specific **Industry 4.0 or certification frameworks** (e.g., **Asset Administration Shells (AAS)**) are mentioned in the provided context.
  The document does not reference **certification requirements, traceability-based compliance, or industry-specific regulations** beyond the aforementioned modeling standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system leverages **MQTT (Message Queuing Telemetry Transport)** via the **Mosquitto** implementation ([52]) for secure, lightweight communication between components, ensuring real-time data exchange with minimal overhead. The system integrates **safety cells** (as referenced in [43]) to enforce physical safety boundaries during robot operation, particularly in manufacturing environments. While no explicit encryption protocols (e.g., TLS/SSL) or detailed cybersecurity frameworks (e.g., IEC 62443, ISO 26262) are specified, the use of **Asset Administration Shell (AAS)** ([46], [47], [50]) implies adherence to **RAMI4.0** ([48], [49]) for standardized asset lifecycle management, including security metadata and access control. The **Functional Mockup Interface (FMI)** ([51]) enables tool-independent simulation model exchange, which may incorporate safety-critical validation mechanisms. However, no granular details on authentication systems, threat mitigation strategies, or compliance with safety standards (e.g., ISO 10218-1) are provided in the documents."
]