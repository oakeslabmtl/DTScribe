// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor providing I_M for the permanent magnet synchronous motor."
    DTDFVocab:producedData CurrentDataTransmitted
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor shaft to measure the motor angle."
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder placed behind the gearbox to capture the output angle."
    DTDFVocab:producedData GearboxPositionDataTransmitted
]

// C4: Physical‑to‑virtual interaction (data transmission)
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorPositionEncoder
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance AccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

// C10: Models/Data – sensor data traces
instance CurrentData : DTDFVocab:Data [
    base:desc "Timestamped current trace I_M transmitted via MQTT."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData CurrentDataTransmitted
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Timestamped motor encoder angle trace transmitted via MQTT."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData MotorPositionDataTransmitted
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Timestamped gearbox encoder angle trace transmitted via MQTT."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData GearboxPositionDataTransmitted
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque trace τ_M calculated from current and motor angle."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData TorqueDataTransmitted
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity trace ω_M computed from motor position."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData AngularVelocityDataTransmitted
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived acceleration trace α_M calculated from angular velocity changes."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData AccelerationDataTransmitted
]

// C10: Models/Data – simulation outputs
instance SimulatedMotorTorqueData : DTDFVocab:Data [
    base:desc "Simulated motor torque trace τ_M from the motor Simulink model."
    DTDFVocab:inputTo SimulinkTool
    DTDFVocab:fromData TorqueDataTransmitted
]

instance SimulatedGearboxTorqueData : DTDFVocab:Data [
    base:desc "Simulated gearbox torque trace τ_G from the gearbox Simulink model."
    DTDFVocab:inputTo SimulinkTool
    DTDFVocab:fromData TorqueDataTransmitted
]

instance SimulatedOutputTorqueData : DTDFVocab:Data [
    base:desc "Simulated output torque trace τ_out from the system Simulink model."
    DTDFVocab:inputTo SimulinkTool
    DTDFVocab:fromData TorqueDataTransmitted
]

// C10: Models – structural and executable
instance StructuralSysMLModel : DTDFVocab:Model [
    base:desc "Structural SysML representation of motor and gearbox mechanical configuration."
    DTDFVocab:inputTo SysMLTool
]

instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Executable MATLAB/Simulink model of the permanent magnet synchronous motor."
    DTDFVocab:inputTo SimulinkTool
]

instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "Executable MATLAB/Simulink model of the gearwheel and cycloidal gearbox."
    DTDFVocab:inputTo SimulinkTool
]

instance SystemSimulinkModel : DTDFVocab:Model [
    base:desc "Executable MATLAB/Simulink model of the first rotary axis system behaviour."
    DTDFVocab:inputTo SimulinkTool
]

// C11: Enablers – MBSE, simulation, MQTT, AAS
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "Model‑Based Systems Engineering tool used for creating and editing SysML models (e.g., SBD, IBD)."
    DTDFVocab:enables FrictionIdentificationService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment that executes motor, gearbox, and system simulation models."
    DTDFVocab:enables FrictionIdentificationService, ParameterEstimationService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating real‑time data transport from PT sensors to DT components."
    DTDFVocab:enables RealTimeDataAggregationService, VisualizationDashboardService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell framework providing semantic asset description and context."
    DTDFVocab:enables FrictionIdentificationService, ParameterEstimationService, VisualizationDashboardService
]

// C6: Services – analytics and visualization
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service that identifies friction loss using white‑box analytical and black‑box data‑driven models."
    DTDFVocab:provides FrictionLossEstimateInsight
]

instance ParameterEstimationService : DTDFVocab:Service [
    base:desc "Service that performs continuous multi‑physics friction parameter estimation to improve robot motion accuracy."
    DTDFVocab:provides ControllerGainAdjustmentInsight, WearDetectionInsight, MaintenanceScheduleInsight
]

instance RealTimeDataAggregationService : DTDFVocab:Service [
    base:desc "Real‑time aggregation service linking sensor traces and simulation data for semantic comparison."
    DTDFVocab:provides FrictionLossEstimateInsight, WearDetectionInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Unified web‑based dashboard visualizing sensor data, simulation outputs, and friction insights."
]

// C17: Insights
instance FrictionLossEstimateInsight : DTDFVocab:Insight [
    base:desc "Quantitative estimate of friction loss within the rotary axis, computed by the FrictionIdentificationService."
]

instance ControllerGainAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Recommendation to adjust controller gains based on updated friction parameters."
]

instance WearDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of wear in motor or gearbox components inferred from parameter drift."
]

instance MaintenanceScheduleInsight : DTDFVocab:Insight [
    base:desc "Suggested maintenance schedule derived from wear detection and friction trends."
]

// C17: Actions
instance AdjustControllerGainsAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of controller gains in the motion planner."
    DTDFVocab:IsAutomatic true
]

instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Automatic scheduling of maintenance tasks when wear thresholds are exceeded."
    DTDFVocab:IsAutomatic true
]

instance DetectWearAction : DTDFVocab:Action [
    base:desc "Trigger alert for manual inspection when wear detection insight is active."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with live data streams; processing and simulation performed at the same rate as sensor sampling (typically sub‑millisecond to millisecond domain), enabling on‑the‑fly friction model refinement"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration of robot hardware, MQTT broker, sensor interfaces, data trace collection, AAS asset registry, simulation engines, processing components, and web dashboard forming a cohesive DT architecture that flows sensor data into simulation and visualization services"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (structural SysML modeling of first axis), Integration (creation of simulation and data trace models), Deployment (digital shadow instantiated with live sensor data), Operation (continuous friction monitoring and model updating during robot work)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Multiple friction models (Coulomb‑Viscous, Stribeck, Dahl, LuGre) are implemented and their simulated outputs are compared to reference sensor data to assess validity; traceability of data generation is maintained via associations and metadata; continuous identification ensures model fidelity over time despite wear or tool changes"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data transmission between PT and DT is performed over MQTT protocol via a broker; the physical asset is described using Asset Administration Shell (AAS) with semantic identifiers; the digital shadow consumes these data streams through the AAS interface"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to SysML for structural and behavioral modeling, Asset Administration Shell (AAS) standards for asset representation, MQTT messaging standard for data exchange, and MBSE methodologies (RFLP, SMArDT) for systematic engineering"
]