// C3: Physical sensing components
instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Input current sensor I_M measuring motor current in real time"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor shaft position encoder providing motor angle r_M"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind the gearbox providing gearbox angle r_G"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Measured output angle sensor providing r_out"
    DTDFVocab:producedData OutputAngleDataTransmitted
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

// C10: Data
instance CurrentData : DTDFVocab:Data [
    base:desc "Time‑series of input current I_M streamed from the robot"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkEngineEnabler
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Time‑series of motor shaft angle r_M from the motor encoder"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkEngineEnabler
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Time‑series of gearbox angle r_G from the secondary encoder"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkEngineEnabler
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Time‑series of output angle r_out measured at the robot axis"
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkEngineEnabler
]

// C10: Models/Data
instance EngineeringSysMLModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams describing motor, gearboxes and data flow"
    DTDFVocab:inputTo SysMLToolEnabler
]

instance FrictionSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of motor, gearwheel and cycloidal gearbox with friction (Coulomb‑Viscous, Stribeck, Dahl, LuGre)"
    DTDFVocab:inputTo SimulinkEngineEnabler
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker streaming sensor time‑series from robot to the digital shadow"
    DTDFVocab:enables RealTimeVisualizationService, FrictionParameterIdentificationService
]

instance SimulinkEngineEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink runtime executing friction simulation models"
    DTDFVocab:enables FrictionParameterIdentificationService, MotionControlUpdateService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Custom dashboard visualizing measured and simulated torque/velocity traces in real time"
    DTDFVocab:enables RealTimeVisualizationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell integrating models and enabling data exchange with the robot controller"
    DTDFVocab:enables MotionControlUpdateService
]

instance SysMLToolEnabler : DTDFVocab:Enabler [
    base:desc "SysML tooling used for engineering model definition"
    DTDFVocab:enables RealTimeVisualizationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time unified dashboard of measured and simulated torque/velocity traces"
    DTDFVocab:provides TorqueVelocityTraceInsight
]

instance FrictionParameterIdentificationService : DTDFVocab:Service [
    base:desc "Continuously identifies static, kinetic and viscous friction parameters from sensor data"
    DTDFVocab:provides IdentifiedFrictionParametersInsight
]

instance MotionControlUpdateService : DTDFVocab:Service [
    base:desc "Updates the robot motion‑control model with newly identified friction parameters to improve positional accuracy"
    DTDFVocab:provides UpdateMotionControlAlgorithmAction
]

// C17: Insights/Actions
instance TorqueVelocityTraceInsight : DTDFVocab:Insight [
    base:desc "Visualization of torque and velocity traces for monitoring robot performance"
]

instance IdentifiedFrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Identified static, kinetic and viscous friction parameters used to refine motion control"
]

instance UpdateMotionControlAlgorithmAction : DTDFVocab:Action [
    base:desc "Feeds identified friction parameters back to the robot controller to adjust motion‑control algorithms"
    DTDFVocab:IsAutomatic true
]

// Component representing the digital twin
instance FrictionShadow : DTDFVocab:Component [
    base:desc "Digital shadow representing the first axis of the MABI MAX 100 robot, integrating sensor streams, models and services"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "According to the Digital Shadow Reference Model the flow is one‑way; the digital shadow does not send commands or data back to the robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates in real‑time, ingesting live data during robot operation and updating the friction identification continuously."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of the physical asset (MABI first axis), data sources (sensors), processing components (Simulation_M, Simulation_GW, Simulation_GB) that consume input traces and produce simulated traces, models (engineering, simulation), and the dashboard that visualizes the combined data."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow is created for the operational stage of the robot (as‑operated) to compare simulated behavior with live measurements."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability is ensured by linking each DataTrace to its originating source and processing component; validation is performed by comparing simulated friction‑free and friction‑included models against measured data to assess deviation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow over MQTT; the Asset Administration Shells provide a standardized interface for model access."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach uses the Asset Administration Shell (industry‑4.0 standard), SysML (OMG standard), MQTT (standard messaging protocol), and MATLAB/Simulink models adhering to standard simulation practices."
]