// Digital Twin Component
instance DigitalShadowFirstAxis : DTDFVocab:Component [
    base:desc "Digital shadow instantiated for the first rotary axis of MABI MAX 100, represented as a twin in this use case."
]

// Environment containing the twin
instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains DigitalShadowFirstAxis
]

// =============================
// C3: Physical sensing components
// =============================

// 1. Permanent‑magnet synchronous motor current sensor (IM)
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Permanent‑magnet synchronous motor current sensor (IM) provides electrical current input to the homogenous mechanical model."
    DTDFVocab:producedData MotorCurrentTransmission
]

// 2. Motor encoder mounted on the rotor
instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted on the rotor captures motor angular position and velocity."
    DTDFVocab:producedData MotorEncoderTransmission
]

// 3. Secondary encoder positioned behind the high‑ratio gearbox
instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the high‑ratio gearbox measures gearbox output position to infer elasticity and friction."
    DTDFVocab:producedData GearboxEncoderTransmission
]

// 4. System‑level position encoder on the axis output shaft
instance AxisPositionEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "System‑level position encoder on the axis output shaft delivers actual angular position used for control and reference generation."
    DTDFVocab:producedData AxisPositionEncoderTransmission
]

// =============================
// C4: Physical‑to‑virtual interaction (Data Transmitted)
// =============================

// 1. Motor current transmission
instance MotorCurrentTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// 2. Motor encoder transmission
instance MotorEncoderTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

// 3. Gearbox encoder transmission
instance GearboxEncoderTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// 4. Axis position encoder transmission
instance AxisPositionEncoderTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AxisPositionEncoderSensor
]

// 5. Derived torque transmission (τ)
instance TorqueTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorEncoderSensor, GearboxEncoderSensor, AxisPositionEncoderSensor
]

// 6. Derived angular velocity transmission (ω)
instance AngularVelocityTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorEncoderSensor, GearboxEncoderSensor, AxisPositionEncoderSensor
]

// 7. Derived angular acceleration transmission (α)
instance AngularAccelerationTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorEncoderSensor, GearboxEncoderSensor, AxisPositionEncoderSensor
]

// =============================
// C5: Data Traces
// =============================

// Motor current data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measurement trace of motor current IM with timestamps and source metadata."
    DTDFVocab:fromData MotorCurrentTransmission
    DTDFVocab:inputTo DataProcessingEngine
]

// Motor encoder data
instance MotorEncoderData : DTDFVocab:Data [
    base:desc "Motor encoder trace capturing angular position and velocity with timestamps."
    DTDFVocab:fromData MotorEncoderTransmission
    DTDFVocab:inputTo DataProcessingEngine
]

// Gearbox encoder data
instance GearboxEncoderData : DTDFVocab:Data [
    base:desc "Gearbox encoder trace measuring output position with timestamps."
    DTDFVocab:fromData GearboxEncoderTransmission
    DTDFVocab:inputTo DataProcessingEngine
]

// Axis position encoder data
instance AxisPositionEncoderData : DTDFVocab:Data [
    base:desc "Axis output shaft position encoder trace with timestamps."
    DTDFVocab:fromData AxisPositionEncoderTransmission
    DTDFVocab:inputTo DataProcessingEngine
]

// Torque data
instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque trace (τ) computed from sensor readings and dynamics model with timestamps."
    DTDFVocab:fromData TorqueTransmission
    DTDFVocab:inputTo DataProcessingEngine
]

// Angular velocity data
instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity (ω) trace computed from sensor readings with timestamps."
    DTDFVocab:fromData AngularVelocityTransmission
    DTDFVocab:inputTo DataProcessingEngine
]

// Angular acceleration data
instance AngularAccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration (α) trace computed from sensor readings with timestamps."
    DTDFVocab:fromData AngularAccelerationTransmission
    DTDFVocab:inputTo DataProcessingEngine
]

// =============================
// C10: Models/Data
// =============================

// System structural model captured in SysML
instance SysMLEngineeringModel : DTDFVocab:Model [
    base:desc "SysML block diagram and internal block diagram of the first rotary axis, including motor, gearbox, cycloidal gearbox, and encoders."
    DTDFVocab:inputTo MATLABSimulinkPlatform, DataProcessingEngine
]

// MATLAB/Simulink simulation models
instance MATLABSimulinkMotorModel : DTDFVocab:Model [
    base:desc "Simulink model representing the permanent‑magnet synchronous motor dynamics."
    DTDFVocab:inputTo MATLABSimulinkPlatform, DataProcessingEngine
]

instance MATLABSimulinkGearboxModel : DTDFVocab:Model [
    base:desc "Simulink model representing the high‑ratio gearbox dynamics."
    DTDFVocab:inputTo MATLABSimulinkPlatform, DataProcessingEngine
]

instance MATLABSimulinkCycloidalGearboxModel : DTDFVocab:Model [
    base:desc "Simulink model representing the cycloidal gearbox dynamics."
    DTDFVocab:inputTo MATLABSimulinkPlatform, DataProcessingEngine
]

instance MATLABSimulinkSystemModel : DTDFVocab:Model [
    base:desc "Simulink model integrating motor, gearbox, cycloidal gearbox, and encoder dynamics for the axis."
    DTDFVocab:inputTo MATLABSimulinkPlatform, DataProcessingEngine
]

// Executable friction models
instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Executable Coulomb‑Viscous friction model for dynamic simulation."
    DTDFVocab:inputTo DataProcessingEngine
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Executable Stribeck friction model capturing velocity‑dependent behavior."
    DTDFVocab:inputTo DataProcessingEngine
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Executable Dahl friction model for stick‑slip representation."
    DTDFVocab:inputTo DataProcessingEngine
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "Executable LuGre friction model for comprehensive multi‑physics friction identification."
    DTDFVocab:inputTo DataProcessingEngine
]

// =============================
// C11: Enablers
// =============================

// Processing engine performing data calculations and simulation model execution
instance DataProcessingEngine : DTDFVocab:Enabler [
    base:desc "Processing engine performing data calculations and simulation model execution."
    DTDFVocab:enables FrictionIdentificationService, CalibrationExportService
]

// MATLAB/Simulink platform for executable simulation
instance MATLABSimulinkPlatform : DTDFVocab:Enabler [
    base:desc "MATLAB & Simulink platform used to build executable simulation models."
    DTDFVocab:enables SimulationService
]

// Dashboard web interface for real‑time visualization
instance DashboardWebInterface : DTDFVocab:Enabler [
    base:desc "Custom web interface that visualizes real‑time joint‑friction monitoring."
    DTDFVocab:enables RealTimeVisualizationService
]

// MQTT broker for live telemetry
instance MQTTPublisher : DTDFVocab:Enabler [
    base:desc "MQTT broker used to transmit telemetry from the physical robot to the digital shadow."
]

// Asset Administration Shell (AAS) to represent asset context
instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell representing the asset’s context and metadata."
]

// =============================
// C6: Services
// =============================

// Real‑time visualization service
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Service provides a real‑time dashboard for joint‑friction monitoring."
    DTDFVocab:provides FrictionTrendAnalyticsInsight, MaintenanceScheduleInsight
]

// Multi‑physics friction identification service
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service performs continuous, multi‑physics‑aware identification of static, kinetic, and viscous friction parameters."
    DTDFVocab:provides FrictionParameterCalibrationInsight, ControllerParameterUpdateAction
]

// Calibration export service
instance CalibrationExportService : DTDFVocab:Service [
    base:desc "Service exports calibrated friction models for downstream motion‑control improvement."
    DTDFVocab:provides CalibrationExportAction
]

// ==============================
// Simulation Service
// =============================

instance SimulationService : DTDFVocab:Service [
    base:desc "Service facilitates execution of simulation models on MATLAB/Simulink platform."
]

// =================-----
// C17: Insights & Actions
// ---------------------

instance FrictionTrendAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Trend analytics on friction extracted from the real‑time dashboard."
]

instance MaintenanceScheduleInsight : DTDFVocab:Insight [
    base:desc "Maintenance schedule inference by detecting drift in friction characteristics."
]

instance FrictionParameterCalibrationInsight : DTDFVocab:Insight [
    base:desc "Calibration of friction parameters to be exported to the robot controller."
]

instance ControllerParameterUpdateAction : DTDFVocab:Action [
    base:desc "Trigger controller parameter updates based on calibrated friction parameters."
    DTDFVocab:IsAutomatic true
]

instance CalibrationExportAction : DTDFVocab:Action [
    base:desc "Export calibrated friction models to the robot controller."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation synchronized with live MQTT sensor streams.  The document does not specify an explicit sampling period or control cycle, only that identification occurs continuously during robot operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A hierarchical architecture: Asset ➜ Engineering Model → Simulation and Data‑Calculation Models → Processing Component → Data Traces → Dashboard. The DT executes in a data‑pipeline that ingests live sensor streams, feeds them into the Simulink models, compares simulated outputs with measured data, and updates the dashboard, forming an end‑to‑end system for friction analysis."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational (in‑service) – the DT captures live operating data and identifies changes in friction over the robot’s lifetime; the models represent the manufactured robot as experienced during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "White‑box friction models are calibrated against live data to capture load, temperature, and wear effects; validation performed by comparing simulated torque/velocity traces with measured ones per cycle; traceability of all data points to their source (sensor or model) ensures consistency; uncertainty quantification is planned via guard conditions in the simulation; model fidelity is maintained through continuous self‑learning of the friction parameters."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Live data transmitted from the robot to the digital shadow via MQTT topics. No mention of additional protocols or network architecture beyond MQTT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for engineering models; Asset Administration Shell (AAS) for asset description; MQTT for data streaming; reference methodology RFLP (Requirements, Functions, Logics, Physics) and SMArDT for structuring the system, but no specific ISO/IEC standard numbers are cited."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The robot operates within a safety cell limiting its working range to –90° to 90° and to a maximum speed of 75°/s, reducing risk to operators. No mention of cybersecurity measures or remote command execution; the digital shadow is passive and does not control the robot."
]