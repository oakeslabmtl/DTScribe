// Acting Component
instance FirstAxisActuator : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor coupled to a cycloidal gearbox driving the first axis of MABI MAX 100, reachable via real‑time control registers for position, speed, acceleration, max speed |q̇_max| = 75°/s, with safety limits enforced by firmware."
]

// Sensing Components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted high‑resolution angular position encoder directly on the motor shaft, sampled up to 1 kHz and streamed via MQTT."
    DTDFVocab:producedData MotorShaftEncoderDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary high‑resolution angular position encoder located behind the gearbox, sampled up to 1 kHz and streamed via MQTT."
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

// Data Transmitted
instance MotorShaftEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// Data
instance MotorShaftPositionData : DTDFVocab:Data [
    base:desc "Time‑series of motor‑side angular position samples."
    DTDFVocab:fromData MotorShaftEncoderDataTransmitted
    DTDFVocab:inputTo FrictionEstimationEngine
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Time‑series of load‑side angular position samples."
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo FrictionEstimationEngine
]

// Models
instance WhiteBoxFrictionModel : DTDFVocab:Model [
    base:desc "Physics‑based white‑box joint friction model implemented in Simulink, used for multi‑physics identification."
    DTDFVocab:inputTo FrictionEstimationEngine
]

instance MachineLearningFrictionModel : DTDFVocab:Model [
    base:desc "Data‑driven black‑box friction model learned from sensor traces, continuously updated during operation."
    DTDFVocab:inputTo FrictionEstimationEngine
]

// Enablers
instance FrictionEstimationEngine : DTDFVocab:Enabler [
    base:desc "Processing component that fuses sensor data and friction models to estimate joint friction in real time."
    DTDFVocab:enables FrictionMonitoringService
]

instance ControlOptimizationEngine : DTDFVocab:Enabler [
    base:desc "Processing component that uses estimated friction to optimise control parameters and generate adjustment actions."
    DTDFVocab:enables ControlOptimizationService , VisualizationDashboardService
]

// Services
instance FrictionMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring service providing real‑time friction estimates for the first axis."
    DTDFVocab:provides FrictionEstimateInsight
]

instance ControlOptimizationService : DTDFVocab:Service [
    base:desc "Service that computes optimized motion control parameters based on current friction estimates."
    DTDFVocab:provides ControlAdjustmentAction
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Dashboard service visualising friction estimates, motion deviations and recommended control adjustments for operators."
    DTDFVocab:provides MotionDeviationInsight , ControlAdjustmentAction
]

// Insights
instance FrictionEstimateInsight : DTDFVocab:Insight [
    base:desc "Real‑time quantified joint friction value derived from sensor data and model inference."
]

instance MotionDeviationInsight : DTDFVocab:Insight [
    base:desc "Detected deviation between desired and actual motion caused by friction, presented to operators."
]

// Actions
instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of motor set‑point registers to compensate for estimated friction."
    DTDFVocab:IsAutomatic true
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is achieved by coupling a white‑box analytical model (e.g., a Simulink dynamic simulation of the robot mechanics) with a black‑box data‑driven model (e.g., a machine‑learning friction estimator). The combined approach leverages the interpretability of the analytical model and the expressive power of the data‑driven model to capture nonlinear friction phenomena. Validation is performed by comparing simulated outputs against measured sensor traces, using the traceability links provided by the ‘originates‑from’ association to pinpoint sources of deviation. Uncertainty sources include modelling errors in the analytical dynamics and inaccuracies in the sensor data traces; these are quantified through residual analysis between simulated and measured data. Error detection relies on automatic consistency checks of transformation steps (e.g., SysML‑to‑Simulink conversion), and correction mechanisms involve re‑training the data‑driven model or updating model parameters. Overall quality assurance is supported by systematic verification of model transformations and by maintaining full provenance metadata for each data trace and model artifact."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on established industry standards. Model‑Based Systems‑Engineering is performed with SysML, an OMG standard modeling language. The Digital Twin is built on the Digital Shadow Reference Model, which defines a conformance relation that precisely identifies the set of conforming models within the same language. Asset Administration Shells (AAS) are employed to encapsulate asset metadata, supporting interoperability in Industry 4.0 environments."
]