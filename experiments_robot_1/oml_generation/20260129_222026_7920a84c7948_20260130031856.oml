// Sensing Component
instance PhysicalStateSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Captures automated one-way state data from the physical object, producing contextual data traces and aggregations"
    DTDFVocab:producedData PhysicalStateDataTransmitted
]

// Data Transmitted
instance PhysicalStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalStateSensingComponent
    base:desc "Automated one-way transmission of physical state from the physical object to the digital twin"
]

// Data
instance PhysicalStateData : DTDFVocab:Data [
    base:desc "Digital twin representation of the physical state data aggregated and traced"
    DTDFVocab:fromData PhysicalStateDataTransmitted
    DTDFVocab:inputTo ModelIntegrationEnabler
]

// Models
instance RequirementLevelModel : DTDFVocab:Model [
    base:desc "Model representing the requirements level using RFLP, OOSEM, or SMArDT expressed in SysML v1.7 diagrams"
    DTDFVocab:inputTo ModelIntegrationEnabler
]

instance FunctionalArchitecturalModel : DTDFVocab:Model [
    base:desc "Model representing the functional architecture expressed in SysML or MontiArc"
    DTDFVocab:inputTo ModelIntegrationEnabler
]

instance LogicalArchitecturalModel : DTDFVocab:Model [
    base:desc "Model representing the logical architecture expressed in ACME, AADL, or MontiArc"
    DTDFVocab:inputTo ModelIntegrationEnabler
]

instance ProductTechnicalModel : DTDFVocab:Model [
    base:desc "Model representing the product/technical layer expressed in ACME, AADL, or MontiArc"
    DTDFVocab:inputTo ModelIntegrationEnabler
]

// Enabler
instance ModelIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that integrates models using MBSE frameworks (RFLP, OOSEM, SPES, SMArDT) and links them to simulation environments such as MathWorks Simulink through MontiArc Automata or SysML State Machines"
    DTDFVocab:enables IncrementalUpdateService, SimulationExecutionService
]

// Services
instance IncrementalUpdateService : DTDFVocab:Service [
    base:desc "Service that manages incremental model updates, synchronization, and versioning between the digital twin and the physical counterpart"
    DTDFVocab:provides VersionControlInsight, UpdateInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service that executes behavioral simulations of the digital twin in MathWorks Simulink or other simulation tools"
    DTDFVocab:provides SimulationInsight
]

// Insights
instance VersionControlInsight : DTDFVocab:Insight [
    base:desc "Insight showing the version history of the digital twin models"
]

instance UpdateInsight : DTDFVocab:Insight [
    base:desc "Insight indicating when a model is updated and synchronized with the physical system"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight visualizing the results of the digital twin's behavioral simulations"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows a Model‑Based Systems Engineering (MBSE) approach. Development is segmented into successive abstraction layers: Requirements, Functional Architecture, Logical Architecture, and Product/Technical Layer. Each layer is represented using appropriate modeling languages—SysML for system structure and behavior, ADLs such as ACME, AADL, and MontiArc for component & connector descriptions, and SysML IBDs for interface definitions. Transition between phases is managed through iterative refinement of models, stakeholder review, and integration of behavior models (e.g., state machines, MontiArc automata) to ensure consistency across layers."
]