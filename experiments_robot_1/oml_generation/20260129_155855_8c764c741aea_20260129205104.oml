// C3: Physical sensing component
instance PhysicalObjectStateSensor : DTDFVocab:SensingComponent [
    base:desc "Captures the state of the physical object for the digital shadow, providing contextual data traces."
    DTDFVocab:producedData PhysicalToDigitalDataFlow
]

// C4: Physical-to-virtual interaction
instance PhysicalToDigitalDataFlow : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalObjectStateSensor
]

// C10: Data
instance AggregatedContextualData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces collected from the physical object as defined in the digital‑shadow reference model."
    DTDFVocab:fromData PhysicalToDigitalDataFlow
    DTDFVocab:inputTo SysMLEnabler, SimulinkEnabler, CppEnabler, JavaEnabler
]

// C10: Models
instance StructuralModelSysML : DTDFVocab:Model [
    base:desc "Structural model captured with SysML internal block diagrams defining components and interfaces."
    DTDFVocab:inputTo SysMLEnabler
]

instance StructuralModelACME : DTDFVocab:Model [
    base:desc "Structural model expressed in the ACME architecture description language."
    DTDFVocab:inputTo ACMEEnabler
]

instance BehavioralModelSysMLStateMachine : DTDFVocab:Model [
    base:desc "Behavioral model using SysML v1.7 state‑machine extensions."
    DTDFVocab:inputTo SysMLEnabler
]

instance BehavioralModelMontiArcAutomaton : DTDFVocab:Model [
    base:desc "Behavioral model using MontiArc Automaton extensions."
    DTDFVocab:inputTo MontiArcEnabler
]

instance SimulationModelSimulink : DTDFVocab:Model [
    base:desc "Analytical/simulation model refined in MathWorks Simulink."
    DTDFVocab:inputTo SimulinkEnabler
]

instance CodeModelCpp : DTDFVocab:Model [
    base:desc "Executable logic expressed in C++ generated from MBSE artifacts."
    DTDFVocab:inputTo CppEnabler
]

instance CodeModelJava : DTDFVocab:Model [
    base:desc "Executable logic expressed in Java generated from MBSE artifacts."
    DTDFVocab:inputTo JavaEnabler
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "Modeling environment using SysML for structural and behavioral specifications."
    DTDFVocab:enables ModelingSupportService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "Architecture description tool for ACME models."
    DTDFVocab:enables ArchitectureAnalysisService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "Tool supporting MontiArc and MontiArc Automaton specifications."
    DTDFVocab:enables ArchitectureAnalysisService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation environment."
    DTDFVocab:enables SimulationExecutionService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ code generation and execution environment."
    DTDFVocab:enables CodeUnitTestService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java code generation and execution environment."
    DTDFVocab:enables CodeUnitTestService
]

// C6: Services
instance ModelingSupportService : DTDFVocab:Service [
    base:desc "Provides support for model integration and consistency checks across MBSE artifacts."
    DTDFVocab:provides ModelingInsight
]

instance ArchitectureAnalysisService : DTDFVocab:Service [
    base:desc "Analyzes architectural models expressed in ADLs such as ACME and MontiArc."
    DTDFVocab:provides ArchitectureInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Executes simulation models (e.g., Simulink) for validation of functional and logical behavior."
    DTDFVocab:provides ModelValidationInsight
]

instance CodeUnitTestService : DTDFVocab:Service [
    base:desc "Runs code‑level unit tests on generated C++/Java executables for validation."
    DTDFVocab:provides ExecuteUnitTestsAction
]

// C17: Insights
instance ModelingInsight : DTDFVocab:Insight [
    base:desc "Insight regarding consistency and completeness of integrated SysML models."
]

instance ArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight on architectural compliance and interface correctness of ACME/MontiArc models."
]

instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Insight obtained by executing simulation models to validate functional and logical behavior."
]

// C17: Actions
instance ExecuteUnitTestsAction : DTDFVocab:Action [
    base:desc "Action to run automated unit tests on generated C++ or Java code."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "According to the digital shadow reference model, the interaction is strictly one‑way; the digital shadow does not generate commands or push data back to the physical object. Therefore no control messages, command formats, validation, or feedback mechanisms are defined."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle follows the MBSE abstraction hierarchy described in the document: (1) requirements stage where the physical system’s requirements are captured in SysML requirement diagrams; (2) functional‑architecture stage where functional blocks and interfaces are modeled (SysML IBDs, ACME, AADL); (3) logical‑architecture stage where component‑connector structure and behaviour are defined using ADLs such as MontiArc and state‑machine extensions; (4) product/technical stage where detailed product models, simulation models (Simulink) and executable code are created. Transitions between stages are managed through traceability links between the models and are governed by MBSE process guidelines."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection between physical assets and the digital shadow relies on MQTT, an IP‑based publish‑subscribe messaging protocol. The document does not specify network topology, bandwidth, latency, redundancy, or security mechanisms beyond the use of MQTT over the underlying network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach complies with established modeling standards. SysML is used as the primary MBSE language, and component‑connector designs employ standard ADLs including ACME, AADL, MontiArc, and SysML internal‑block diagrams. No additional industry certification schemes or interoperability frameworks are mentioned in the document."
]