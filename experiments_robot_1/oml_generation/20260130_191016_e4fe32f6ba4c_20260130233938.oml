instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensing component for input current data of the MABI MAX 100 robot"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance AngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensing component for output angle data of the MABI MAX 100 robot"
    DTDFVocab:producedData AngleDataTransmitted
]

instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
    base:desc "MQTT-streamed input current data"
]

instance AngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngleSensor
    base:desc "MQTT-streamed output angle data"
]

instance CurrentData : DTDFVocab:Data [
    base:desc "Real-time input current data from robot joints"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo Simulink
]

instance AngleData : DTDFVocab:Data [
    base:desc "Real-time output angle data from robot joints"
    DTDFVocab:fromData AngleDataTransmitted
    DTDFVocab:inputTo Simulink
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP MBSE methodology for system abstraction"
    DTDFVocab:enables ModelAbstractionService
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM MBSE methodology for system abstraction"
    DTDFVocab:enables ModelAbstractionService
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES MBSE methodology for system abstraction"
    DTDFVocab:enables ModelAbstractionService
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT MBSE methodology for system abstraction"
    DTDFVocab:enables ModelAbstractionService
]

instance ACME : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component and connector perspectives"
    DTDFVocab:enables ModelAbstractionService
]

instance AADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component and connector perspectives"
    DTDFVocab:enables ModelAbstractionService
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component and connector perspectives"
    DTDFVocab:enables ModelAbstractionService
]

instance SysMLIBD : DTDFVocab:Enabler [
    base:desc "SysML Interface Block Diagrams for component interfaces and interconnections"
    DTDFVocab:enables ModelAbstractionService
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:enables ModelAbstractionService
]

instance SysMLStateMachine : DTDFVocab:Enabler [
    base:desc "SysML State Machines for behavioral modeling"
    DTDFVocab:enables ModelAbstractionService
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and multi-physics analysis"
    DTDFVocab:enables JointFrictionIdentificationService, PredictiveMaintenanceService
]

instance CppProgrammingLanguage : DTDFVocab:Enabler [
    base:desc "C++ for general-purpose programming and simulation"
    DTDFVocab:enables DashboardService
]

instance JavaProgrammingLanguage : DTDFVocab:Enabler [
    base:desc "Java for general-purpose programming and simulation"
    DTDFVocab:enables DashboardService
]

instance SysML : DTDFVocab:Enabler [
    base:desc "SysML for requirements, functional, logical, and product/technical layers"
    DTDFVocab:enables ModelAbstractionService
]

instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML model for requirements specification of the MABI MAX 100 robot"
    DTDFVocab:inputTo SysML, RFLPMethodology
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML model for functional specification of the MABI MAX 100 robot"
    DTDFVocab:inputTo SysML, OOSEMMethodology
]

instance SysMLLogicalModel : DTDFVocab:Model [
    base:desc "SysML model for logical design of the MABI MAX 100 robot"
    DTDFVocab:inputTo SysML, SPESMethodology
]

instance SysMLProductModel : DTDFVocab:Model [
    base:desc "SysML model for product/technical design of the MABI MAX 100 robot"
    DTDFVocab:inputTo SysML, SMArDTMethodology
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME architecture model for component and connector perspectives"
    DTDFVocab:inputTo ACME
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL architecture model for component and connector perspectives"
    DTDFVocab:inputTo AADL
]

instance MontiArcArchitectureModel : DTDFVocab:Model [
    base:desc "MontiArc architecture model for component and connector perspectives"
    DTDFVocab:inputTo MontiArc
]

instance SysMLIBDArchitectureModel : DTDFVocab:Model [
    base:desc "SysML Interface Block Diagram for component interfaces and interconnections"
    DTDFVocab:inputTo SysMLIBD
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton behavioral model for robot joints"
    DTDFVocab:inputTo MontiArcAutomaton
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML State Machine behavioral model for robot control"
    DTDFVocab:inputTo SysMLStateMachine
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink simulation model for multi-physics analysis"
    DTDFVocab:inputTo Simulink
]

instance CppCodeModel : DTDFVocab:Model [
    base:desc "C++ code model for simulation and control logic"
    DTDFVocab:inputTo CppProgrammingLanguage
]

instance JavaCodeModel : DTDFVocab:Model [
    base:desc "Java code model for simulation and control logic"
    DTDFVocab:inputTo JavaProgrammingLanguage
]

instance ModelAbstractionService : DTDFVocab:Service [
    base:desc "System abstraction using MBSE methodologies for integrated model management"
    DTDFVocab:provides ModelAbstractionInsight
]

instance JointFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous multi-physics-aware identification of joint friction parameters to enhance motion accuracy"
    DTDFVocab:provides FrictionLossDetectionInsight, MotionAccuracyImprovementInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance capabilities derived from sensor data analysis"
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Integrated dashboard for real-time monitoring and visualization"
    DTDFVocab:provides DashboardVisualizationInsight
]

instance ModelAbstractionInsight : DTDFVocab:Insight [
    base:desc "Integration of heterogeneous models and stakeholder perspectives using MBSE methodologies"
]

instance FrictionLossDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of friction loss in robot joints using sensor data analytics"
]

instance MotionAccuracyImprovementInsight : DTDFVocab:Insight [
    base:desc "Enhancement of robot motion accuracy through friction parameter identification"
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance alerts based on sensor data trends"
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "User interaction via dashboard visualization for decision support"
]

instance MABIMAX100Robot : DTDFVocab:Component [
    base:desc "Serial robot MABI MAX 100 with six axes, permanent magnet synchronous motors, and gear transmission mechanisms for precision machining tasks"
]

instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:desc "Industrial environment for precision machining tasks"
    base:contains MABIMAX100Robot
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Model-Based Systems Engineering (MBSE) splits modeling into abstraction levels including requirements, functional architecture, logical architecture, and product/technical layer, with methodologies such as RFLP (Requirements, Functions, Logics, Physics), OOSEM, SPES, and SMArDT used to manage complexity across these phases."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for data streaming between physical and digital components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with industry standards including SysML [17], AADL [24], ACME [23], and MontiArc [25], [26] for architecture description languages, methodologies such as RFLP [18], OOSEM [20], SPES [21], and SMArDT [22] for system complexity management, and simulation tools like MathWorks Simulink [28] along with general-purpose programming languages (C++, Java) for detailed behavior modeling."
]