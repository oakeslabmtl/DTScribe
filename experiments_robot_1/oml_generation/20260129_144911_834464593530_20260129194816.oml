// C3: Physical sensing components (model exporters acting as virtual sensors)
instance SysMLModelExporter : DTDFVocab:SensingComponent [
    base:desc "Exports SysML (requirements, functional, logical) models as artefacts for downstream processing, as described in the MBSE workflow."
    DTDFVocab:producedData SysMLModelDataTransmitted
]

instance ADLModelExporter : DTDFVocab:SensingComponent [
    base:desc "Exports architecture description language (ACME, AADL, MontiArc) models for simulation and code generation."
    DTDFVocab:producedData ADLModelDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmitted)
instance SysMLModelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLModelExporter
]

instance ADLModelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ADLModelExporter
]

// C5: Data
instance SysMLModelData : DTDFVocab:Data [
    base:desc "Serialized representation of SysML system specifications (requirements, functional and logical architectures)."
    DTDFVocab:fromData SysMLModelDataTransmitted
    DTDFVocab:inputTo ModelTransformationEngine
]

instance ADLModelData : DTDFVocab:Data [
    base:desc "Serialized representation of ADL component‑connector models (ACME, AADL, MontiArc)."
    DTDFVocab:fromData ADLModelDataTransmitted
    DTDFVocab:inputTo SimulationEngine
]

// C10: Models/Data (artifact models)
instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML Requirement diagram capturing stakeholder requirements, part of the RFLP methodology."
    DTDFVocab:inputTo ModelTransformationEngine
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML functional architecture (block diagram) linking requirements to functions."
    DTDFVocab:inputTo ModelTransformationEngine
]

instance SysMLLogicalModel : DTDFVocab:Model [
    base:desc "SysML logical architecture (internal block diagram) defining component interfaces."
    DTDFVocab:inputTo ModelTransformationEngine
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME ADL model describing component‑connector composition of the system."
    DTDFVocab:inputTo SimulationEngine
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL model expressing hardware‑software binding and timing properties."
    DTDFVocab:inputTo SimulationEngine
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "MontiArc component model capturing structural aspects of the system."
    DTDFVocab:inputTo SimulationEngine
]

instance MontiArcAutomatonBehaviorModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton extension describing state‑machine behaviour of components."
    DTDFVocab:inputTo SimulationEngine
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model used for executable validation of the digital twin."
    DTDFVocab:inputTo SimulationEngine
]

// C11: Enablers (tools/engines)
instance ModelTransformationEngine : DTDFVocab:Enabler [
    base:desc "Engine that transforms SysML artefacts into ADL specifications (ACME, AADL, MontiArc) as part of the MBSE pipeline."
    DTDFVocab:enables ModelIntegrationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink runtime that executes behavioural and analytical models for validation."
    DTDFVocab:enables SimulationExecutionService
]

instance CodeGenerationEngine : DTDFVocab:Enabler [
    base:desc "C++/Java code generator that produces executable implementations from refined logical/physical models."
    DTDFVocab:enables CodeGenerationService
]

// C6: Services
instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Service that integrates heterogeneous MBSE models into a coherent digital twin artefact."
    DTDFVocab:provides IntegrationInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service that runs simulation models (Simulink, MontiArc Automaton) and produces validation results."
    DTDFVocab:provides SimulationResultInsight
]

instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Service that compiles generated C++/Java code into executable twin components."
    DTDFVocab:provides CodeGenerationAction
]

// C17: Insights/Actions
instance IntegrationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful integration of SysML and ADL models, supporting traceability across abstraction layers."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulation runs that validates system behaviour against functional requirements."
]

instance CodeGenerationAction : DTDFVocab:Action [
    base:desc "Action that automatically generates and compiles source code for the twin from refined models."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle follows the MBSE abstraction hierarchy: starting with requirements models, progressing to functional architecture models, then logical architecture models, and finally product/technical layer models. At each stage the DT representation shifts from high‑level requirement traces to detailed component‑connector specifications (e.g., SysML internal block diagrams, ADL models) and may be coupled with simulation artefacts (Simulink, MontiArc Automaton). Transitions between phases are managed by model‑based traceability links and governance defined by the MBSE process."
]