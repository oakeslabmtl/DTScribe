instance RequirementsModel : DTDFVocab:Model [
    base:desc "SysML model for requirements abstraction level"
    DTDFVocab:inputTo SysMLEnabler
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model for functional architecture abstraction level"
    DTDFVocab:inputTo SysMLEnabler
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model for logical architecture abstraction level"
    DTDFVocab:inputTo SysMLEnabler
]

instance ProductTechnicalLayerModel : DTDFVocab:Model [
    base:desc "SysML model for product/technical layer abstraction level"
    DTDFVocab:inputTo SysMLEnabler
]

instance MontiArcBehavioralModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcBehavioralEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines for behavioral modeling"
    DTDFVocab:inputTo SysMLStateMachineEnabler
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language for component-based architecture"
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL Architecture Description Language for component-based architecture"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcADLModel : DTDFVocab:Model [
    base:desc "MontiArc Architecture Description Language for component-based architecture"
    DTDFVocab:inputTo MontiArcADLEnabler
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams for component and connector perspectives"
    DTDFVocab:inputTo SysMLIBDEnabler
]

instance RFLPMethodology : DTDFVocab:Model [
    base:desc "RFLP (Requirements, Functions, Logics, Physics) methodology for system complexity management"
    DTDFVocab:inputTo RFLPEnabler
]

instance OOSEMMethodology : DTDFVocab:Model [
    base:desc "OOSEM methodology for system complexity management"
    DTDFVocab:inputTo OOSEMEnabler
]

instance SPESMethodology : DTDFVocab:Model [
    base:desc "SPES methodology for system complexity management"
    DTDFVocab:inputTo SPESEnabler
]

instance SMArDTMethodology : DTDFVocab:Model [
    base:desc "SMArDT methodology for system complexity management"
    DTDFVocab:inputTo SMArDTEnabler
]

instance SimulinkSimulationComponent : DTDFVocab:Component [
    base:desc "MathWorks Simulink simulation tool for detailed behavior specification"
]

instance CppCompilerComponent : DTDFVocab:Component [
    base:desc "C++ compiler for behavior specification"
]

instance JavaCompilerComponent : DTDFVocab:Component [
    base:desc "Java compiler for behavior specification"
]

instance SimulinkDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkSimulationComponent
]

instance CppDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CppCompilerComponent
]

instance JavaDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JavaCompilerComponent
]

instance SimulinkData : DTDFVocab:Data [
    base:desc "Simulation data from MathWorks Simulink"
    DTDFVocab:fromData SimulinkDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler
]

instance CppCodeData : DTDFVocab:Data [
    base:desc "Compiled C++ code data"
    DTDFVocab:fromData CppDataTransmitted
    DTDFVocab:inputTo CppEnabler
]

instance JavaCodeData : DTDFVocab:Data [
    base:desc "Compiled Java code data"
    DTDFVocab:fromData JavaDataTransmitted
    DTDFVocab:inputTo JavaEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for structural modeling across requirements, functional architecture, logical architecture, and product/technical layers"
    DTDFVocab:enables SysMLService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component-based architecture"
    DTDFVocab:enables ACMEService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component-based architecture"
    DTDFVocab:enables AADLService
]

instance MontiArcADLEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component-based architecture"
    DTDFVocab:enables MontiArcADLService
]

instance SysMLIBDEnabler : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component and connector perspectives"
    DTDFVocab:enables SysMLIBDService
]

instance MontiArcBehavioralEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:enables MontiArcBehavioralService
]

instance SysMLStateMachineEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 state machines for behavioral modeling"
    DTDFVocab:enables SysMLStateMachineService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation tool for detailed behavior specification and execution"
    DTDFVocab:enables SimulationService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior specification"
    DTDFVocab:enables CppService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior specification"
    DTDFVocab:enables JavaService
]

instance RFLPEnabler : DTDFVocab:Enabler [
    base:desc "RFLP methodology enabler for system complexity management"
    DTDFVocab:enables RFLPService
]

instance OOSEMEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology enabler for system complexity management"
    DTDFVocab:enables OOSEMService
]

instance SPESEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology enabler for system complexity management"
    DTDFVocab:enables SPESService
]

instance SMArDTEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology enabler for system complexity management"
    DTDFVocab:enables SMArDTService
]

