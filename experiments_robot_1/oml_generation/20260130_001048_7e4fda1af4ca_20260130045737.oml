// Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "first axis permanent‑magnet synchronous motor driving the robot's vertical joint"
]
instance GearTransmission : DTDFVocab:ActingComponent [
    base:desc "gear train coupling the motor to the load at the first axis"
]
instance CycloidalGear : DTDFVocab:ActingComponent [
    base:desc "cycloidal gear providing the precise angular transmission for the first vertical axis"
]
instance SiemensSinumerikCNCController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D SL CNC controller managing motion and safety limits"
]
instance VariableFrequencyDrive : DTDFVocab:ActingComponent [
    base:desc "variable‑frequency drive supplying electrical drive to the permanent‑magnet motor"
]
instance SafetyCell : DTDFVocab:ActingComponent [
    base:desc "safety cell limiting the geometric working envelope to –90° to +90° and enforcing maximum angular speed constraints"
]

// Sensing Components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "incremental encoder located on the motor shaft, sampling 1 ms"
    DTDFVocab:producedData MQTTMessage_Encoder
]
instance SecondaryGearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "incremental encoder positioned after the gearbox, sampling 1 ms"
    DTDFVocab:producedData MQTTMessage_Encoder
]
instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "current sensor on the electrical drive, sampling 1 ms"
    DTDFVocab:producedData MQTTMessage_Current
]
instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "torque sensor at the motor shaft, sampling 1 ms"
    DTDFVocab:producedData MQTTMessage_Torque
]
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "temperature sensor at the motor assembly, sampling 1 ms"
    DTDFVocab:producedData MQTTMessage_Temperature
]

// Data Transmitted
instance MQTTMessage_Encoder : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder, SecondaryGearboxEncoder
]
instance MQTTMessage_Current : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
]
instance MQTTMessage_Torque : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
]
instance MQTTMessage_Temperature : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// Data
instance PositionData : DTDFVocab:Data [
    base:desc "robotic position data sampled from the two encoders"
    DTDFVocab:inputTo DataManagementMiddleware
    DTDFVocab:fromData MQTTMessage_Encoder
]
instance CurrentData : DTDFVocab:Data [
    base:desc "current measurement imported from the electrical drive"
    DTDFVocab:inputTo DataManagementMiddleware
    DTDFVocab:fromData MQTTMessage_Current
]
instance TorqueData : DTDFVocab:Data [
    base:desc "torque measurement imported from the torque sensor"
    DTDFVocab:inputTo DataManagementMiddleware
    DTDFVocab:fromData MQTTMessage_Torque
]
instance TemperatureData : DTDFVocab:Data [
    base:desc "temperature measurement imported from the motor sensor"
    DTDFVocab:inputTo DataManagementMiddleware
    DTDFVocab:fromData MQTTMessage_Temperature
]

// Models
instance AnalyticalFrictionModel : DTDFVocab:Model [
    base:desc "analytical friction model derived from first‑principle equations and calibrated with measured data"
    DTDFVocab:inputTo SimulinkEnvironment
]
instance DataDrivenFrictionModel : DTDFVocab:Model [
    base:desc "black‑box friction model trained by supervised regression on sensor time‑series"
    DTDFVocab:inputTo SimulinkEnvironment
]
instance MotorDynamicsSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink executable model coupling differential equations of the motor dynamics with friction models"
    DTDFVocab:inputTo SimulinkEnvironment
]

// Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating message exchange between the robot and the cloud platform"
    DTDFVocab:enables RealTimeIdentificationService
]
instance RealTimeDatabase : DTDFVocab:Enabler [
    base:desc "real‑time database ingesting MQTT messages for state estimation"
    DTDFVocab:enables RealTimeIdentificationService
]
instance DataManagementMiddleware : DTDFVocab:Enabler [
    base:desc "middleware mapping simulation variables to corresponding physical measurements, enabling closed‑loop identification and validation"
    DTDFVocab:enables RealTimeIdentificationService
]
instance SimulinkEnvironment : DTDFVocab:Enabler [
    base:desc "executable Simulink environment performing motor dynamics and friction modeling"
    DTDFVocab:enables RealTimeIdentificationService, WebDashboardService
]

// Services
instance RealTimeIdentificationService : DTDFVocab:Service [
    base:desc "real‑time identification of motor dynamics using Simulink, triggered by incoming sensor data"
    DTDFVocab:provides FrictionAnalysisInsight, ConditionMonitoringAction, ModelValidationInsight
]
instance WebDashboardService : DTDFVocab:Service [
    base:desc "web‑based dashboard exposing the real‑time identification results"
    DTDFVocab:provides ConditionMonitoringAction
]

// Insights
instance FrictionAnalysisInsight : DTDFVocab:Insight [
    base:desc "analysis of friction dynamics derived from analytical and data‑driven models"
]
instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "validation of simulation models against real‑time measurements"
]

// Actions
instance ConditionMonitoringAction : DTDFVocab:Action [
    base:desc "real‑time monitoring of joint condition based on friction analysis"
    DTDFVocab:IsAutomatic true
]

// Environment
instance RobotBaseEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotor, GearTransmission, CycloidalGear, SiemensSinumerikCNCController, VariableFrequencyDrive, SafetyCell
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "During the creation of a Digital Twin, the lifecycle follows a model‑based systems engineering (MBSE) approach that spans multiple abstraction levels. The process starts at the requirements level, where the functional intent of the Twin is defined. It then proceeds to the functional architecture level, typically captured in SysML requirement diagrams and feature models. The next stage is the logical architecture, where system behavior is expressed through ADLs such as ACME, AADL, MontiArc, or SysML IBDs, including state‑machine diagrams for behavior modeling. Finally, the product/technical layer brings the design to concrete software components that interface with the physical system, often implemented in C++/Java or Simulink blocks. Transition management between levels is accomplished through model transformations and traceability links established in MBSE tools, but detailed governance mechanisms are not specified in the document."
]