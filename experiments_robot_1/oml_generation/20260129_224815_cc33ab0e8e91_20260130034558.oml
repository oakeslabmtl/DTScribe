// 1. Sensing Components
instance SimulationOutputSensor : DTDFVocab:SensingComponent [
    base:desc "Simulated sensor capturing outputs from MathWorks Simulink models during execution"
    DTDFVocab:producedData SimulationOutputDataTransmitted
]

instance RuntimeTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing runtime telemetry aggregated by the digital shadow"
    DTDFVocab:producedData RuntimeTelemetryDataTransmitted
]

instance CodeExecutionTracer : DTDFVocab:SensingComponent [
    base:desc "Tracer capturing execution traces from generated C++ or Java artifacts running in target environment"
    DTDFVocab:producedData CodeExecutionDataTransmitted
]

// 2. Data Transmitted
instance SimulationOutputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationOutputSensor
]

instance RuntimeTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RuntimeTelemetrySensor
]

instance CodeExecutionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CodeExecutionTracer
]

// 3. Data
instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Outputs of MathWorks Simulink models including numerical integration results and signal flow outputs"
    DTDFVocab:fromData SimulationOutputDataTransmitted
    DTDFVocab:inputTo SimulationEngine
    DTDFVocab:inputTo ModelRepository
]

instance RuntimeTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry aggregated by the digital shadow including state machine transitions and execution traces"
    DTDFVocab:fromData RuntimeTelemetryDataTransmitted
    DTDFVocab:inputTo ModelRepository
]

instance CodeExecutionData : DTDFVocab:Data [
    base:desc "Execution traces from generated C++/Java artifacts, including method calls, performance metrics, and error logs"
    DTDFVocab:fromData CodeExecutionDataTransmitted
    DTDFVocab:inputTo DeploymentService
]

// 4. Enablers
instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink engine for running simulation-level dynamics"
    DTDFVocab:enables SimulationExecutionService
]

instance ModelRepository : DTDFVocab:Enabler [
    base:desc "Versioned model repository integrating SysML IBDs, ACME, AADL, MontiArc, Simulink, and source-code artifacts"
    DTDFVocab:enables ModelIntegrationService
]

instance CodeGenerationTool : DTDFVocab:Enabler [
    base:desc "Toolchain for generating C++ or Java artifacts from Simulink and MontiArc models"
    DTDFVocab:enables DeploymentService
]

// 5. Services
instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service that executes Simulink models and propagates simulation data for downstream analysis"
    DTDFVocab:provides SimulationPerformanceInsight
]

instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Service that integrates multiple notations (SysML, ADLs) into a coherent model hierarchy with traceability"
    DTDFVocab:provides StructuralIntegrityInsight
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Service that deploys generated C++/Java artifacts into production or embedded environments"
    DTDFVocab:provides DeploySimulationModel
]

// 6. Insights and Actions
instance SimulationPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight on the performance of simulation models, including execution time and numerical accuracy"
]

instance StructuralIntegrityInsight : DTDFVocab:Insight [
    base:desc "Insight into the structural integrity of the system as validated by integrated models"
]

instance DeploySimulationModel : DTDFVocab:Action [
    base:desc "Automated deployment of simulation or code artifacts to target platforms"
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital Twin lifecycle phases correspond to the MBSE abstraction layers: (1) requirement level, capturing system expectations; (2) functional architecture level, expressed with architecture description languages such as ACME or AADL that define component–connector structures; (3) logical architecture level, modeled using SysML IBDs or MontiArc Automaton that integrate behavioral aspects; (4) product/technical layer, where the twin is instantiated with simulation tools (e.g., MathWorks Simulink) or code in C++/Java. Each phase is represented by the respective modeling language or tool, facilitating traceability and progressive refinement across the lifecycle."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "The Digital Twin’s data governance is carried out via the Asset Administration Shell (AAS) as formalized in the 2019 Standards documentation (Details of the Asset Administration Shell). Each Submodel within the AAS contains an explicit Data Owner role with contact details, legal authority, and ownership metadata, enabling traceable accountability across the twin ecosystem. Privacy protection follows GDPR; personal data captured in submodels is pseudonymized whenever feasible, and a dedicated Consent submodel records user consent and digital signatures. Data sharing agreements are expressed through the 'Data sharing agreement' property of the AAS, which specifies parties, access rights, and retention periods. The overall architecture implements ISO‑IEC 27001‑based risk assessment, ensuring that only authorized parties can read or modify sensitive submodels, and all access events are logged for audit purposes."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security is enforced by configuring the Mosquitto MQTT broker with TLS 1.3 and mutual X.509 authentication, as described in the 2017 Mosquitto documentation. Role-Based Access Control (RBAC) is implemented via Thingsboard 4.0’s built‑in authentication system, assigning each digital‑twin resource to a specific RBAC role and permission set. Threat mitigation follows the RAMI 4.0 security layer recommendations, including continuous intrusion detection, adaptive authentication, and automated device disconnection after a predefined threshold of failed authentication attempts. Fail‑safe mechanisms are enabled by the platform’s ability to enter a low‑risk operation mode when safety‑critical events are detected, as discussed in the 2018 Industrial Cyber‑Physical Systems conference paper on RAMI 4.0 pitfalls. All data at rest is encrypted with AES‑256, and immutable audit logs capture configuration changes and access attempts in compliance with ISO/IEC 27001."
]