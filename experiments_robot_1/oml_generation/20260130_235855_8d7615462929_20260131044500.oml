// C3: Physical sensing components
instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor feeding motor controller"
    DTDFVocab:producedData CurrentDataTransmission
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder attached to motor providing position and velocity measurements"
    DTDFVocab:producedData MotorEncoderDataTransmission
]

instance GearboxSecondaryEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind gearbox providing position and velocity measurements"
    DTDFVocab:producedData GearboxEncoderDataTransmission
]

// C4: Physical‑to‑virtual interaction - data transmitted
instance CurrentDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
]

instance MotorEncoderDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxSecondaryEncoderSensor
]

// C10: Models/Data - measured data
instance MeasuredCurrentData : DTDFVocab:Data [
    base:desc "Measured current trace Iτ"
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData CurrentDataTransmission
]

instance MeasuredMotorEncoderAngleData : DTDFVocab:Data [
    base:desc "Measured motor encoder angle rτ"
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData MotorEncoderDataTransmission
]

instance MeasuredGearboxEncoderAngleData : DTDFVocab:Data [
    base:desc "Measured gearbox encoder angle rG"
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData GearboxEncoderDataTransmission
]

// C10: Models/Data - simulated data transmissions
instance SimRtauDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationModelMotor
]

instance SimRGDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationModelGearbox
]

instance SimRoutDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationModelSystem
]

// C10: Models/Data - simulated data
instance SimulatedMotorTorqueData : DTDFVocab:Data [
    base:desc "Simulated motor torque trace from motor model"
    DTDFVocab:inputTo SimulinkToolEnabler
    DTDFVocab:fromData SimRtauDataTransmission
]

instance SimulatedGearboxTorqueData : DTDFVocab:Data [
    base:desc "Simulated gearbox torque trace from gearbox model"
    DTDFVocab:inputTo SimulinkToolEnabler
    DTDFVocab:fromData SimRGDataTransmission
]

instance SimulatedSystemOutputData : DTDFVocab:Data [
    base:desc "Simulated system output trace r_out from system model"
    DTDFVocab:inputTo SimulinkToolEnabler
    DTDFVocab:fromData SimRoutDataTransmission
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating real‑time sensor data streaming"
    DTDFVocab:enables RealTimeDashboardService, FrictionIdentificationService
]

instance SimulinkToolEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink tool executing simulation models"
    DTDFVocab:enables SimulationService, FrictionIdentificationService
]

instance DashboardFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard framework providing real‑time data visualization"
    DTDFVocab:enables RealTimeDashboardService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell linking data with semantic enrichment"
    DTDFVocab:enables FrictionParameterProvisionService
]

// C10: Models
instance EngineeringModelMotorGearboxes : DTDFVocab:Model [
    base:desc "SysML structural model of motor and dual gearboxes for first axis of MABI MAX 100"
    DTDFVocab:inputTo AssetAdministrationShellEnabler
]

instance SimulationModelMotor : DTDFVocab:Model [
    base:desc "Simulink model of motor integrating friction models (Coulomb‑Viscous, Stribeck, Dahl, LuGre)"
    DTDFVocab:inputTo SimulinkToolEnabler
]

instance SimulationModelGearbox : DTDFVocab:Model [
    base:desc "Simulink model of gearbox integrating friction models (Coulomb‑Viscous, Stribeck, Dahl, LuGre)"
    DTDFVocab:inputTo SimulinkToolEnabler
]

instance SimulationModelSystem : DTDFVocab:Model [
    base:desc "Simulink model of entire first axis system combining motor and gearboxes"
    DTDFVocab:inputTo SimulinkToolEnabler
]

// C6: Services
instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Real‑time data visualization dashboard showing measured and simulated traces"
    DTDFVocab:provides VisualizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Dynamic simulation service running motor, gearbox, and system models"
    DTDFVocab:provides SimulationInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of joint friction using white‑box and black‑box models"
    DTDFVocab:provides FrictionParameterInferenceInsight, AbnormalBehaviorDetectionInsight
]

instance FrictionParameterProvisionService : DTDFVocab:Service [
    base:desc "Provision of updated friction parameters for improving robot control accuracy"
    DTDFVocab:provides UpdateControlParamsAction, ScheduleMaintenanceAction
]

// C17: Insights
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Live visualization of measured and simulated data traces on dashboard"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insights derived from dynamic comparison of simulations versus real data"
]

instance FrictionParameterInferenceInsight : DTDFVocab:Insight [
    base:desc "Inference of friction parameters by monitoring deviation between simulated and measured torque and velocity trajectories"
]

instance AbnormalBehaviorDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of abnormal behavior based on deviation trends between simulated and measured data"
]

// C17: Actions
instance UpdateControlParamsAction : DTDFVocab:Action [
    base:desc "Automatic update of robot control compensation law with newly inferred friction parameters"
    DTDFVocab:IsAutomatic true
]

instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Scheduled maintenance action triggered by detected abnormal behavior"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time data exchange (sensor streams) and continuous identification; synchronization occurs at each sensor sample as data is ingested."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized digital shadow consisting of an engineering model, simulation models, data processing component, and a unified dashboard, all connected via AAS and MQTT."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (engineering model creation) → Implementation (simulation and data linkage) → Operation (continuous identification during robot use) → Maintenance (model refinement); the DT covers the robot as operated."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of each data point to its source and processing component, comparison of simulated frictionless and friction‑laden models against measurement data, continuous validity checks during operation, and use of white‑box and black‑box models to capture uncertainty."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data transmitted to the digital shadow via MQTT; data structures linked via Asset Administration Shell (AAS), enabling semantic routing and aggregation."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for modeling, Asset Administration Shell (AAS) as a standard for digital twins, and Simulink for executable simulation; adherence to industry modeling standards as described in the paper."
]