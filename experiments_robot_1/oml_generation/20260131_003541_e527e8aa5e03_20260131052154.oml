// Sensing components for the first axial joint of the MABI MAX 100
instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Permanent‑magnet synchronous motor encoder mounted on the motor housing; provides absolute motor angle (r_M) and derived torque, angular velocity, and acceleration"
    DTDFVocab:producedData MotorEncoderMQTT
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder positioned behind the first gearwheel and cycloidal gearbox; provides absolute joint angle (r_G) of the gearbox output"
    DTDFVocab:producedData GearboxEncoderMQTT
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Electrical current sensor on the motor windings; provides motor current (I_M) stream"
    DTDFVocab:producedData MotorCurrentMQTT
]

// Data transmitted via MQTT from the sensing components
instance MotorEncoderMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

instance MotorCurrentMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// Data traces ingested by the processing component
instance MotorAngleData : DTDFVocab:Data [
    base:desc "Time‑series of the motor angle (r_M) streamed via MQTT from the motor encoder"
    DTDFVocab:inputTo DataAggregationComponent
    DTDFVocab:fromData MotorEncoderMQTT
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Time‑series of the gearbox output angle (r_G) streamed via MQTT from the gearbox encoder"
    DTDFVocab:inputTo DataAggregationComponent
    DTDFVocab:fromData GearboxEncoderMQTT
]

instance MotorCurrentTrace : DTDFVocab:Data [
    base:desc "Time‑series of the motor current (I_M) streamed via MQTT"
    DTDFVocab:inputTo DataAggregationComponent
    DTDFVocab:fromData MotorCurrentMQTT
]

instance TorqueTrace : DTDFVocab:Data [
    base:desc "Estimated torque (τ) computed from motor current and angle; supplied by the processing component"
    DTDFVocab:inputTo DataAggregationComponent
    DTDFVocab:fromData MotorEncoderMQTT
]

instance AngularVelocityTrace : DTDFVocab:Data [
    base:desc "Angular velocity (ω) derived from encoder data; supplied by the processing component"
    DTDFVocab:inputTo DataAggregationComponent
    DTDFVocab:fromData MotorEncoderMQTT
]

instance AccelerationTrace : DTDFVocab:Data [
    base:desc "Angular acceleration derived from encoder data; supplied by the processing component"
    DTDFVocab:inputTo DataAggregationComponent
    DTDFVocab:fromData MotorEncoderMQTT
]

// Engineering models used for friction estimation
instance FirstAxisSysMLModel : DTDFVocab:Model [
    base:desc "Structural SysML model describing the permanent‑magnet synchronous motor, gearwheel, and cycloidal gearbox of the first axial joint"
    DTDFVocab:inputTo DataAggregationComponent
]

instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Executable MATLAB Simulink model of the permanent‑magnet synchronous motor dynamics"
    DTDFVocab:inputTo DataAggregationComponent
]

instance GearWheelSimulinkModel : DTDFVocab:Model [
    base:desc "Executable MATLAB Simulink model of the first gearwheel"
    DTDFVocab:inputTo DataAggregationComponent
]

instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "Executable MATLAB Simulink model of the cycloidal gearbox"
    DTDFVocab:inputTo DataAggregationComponent
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "White‑box analytical model representing Coulomb‑viscous joint friction"
    DTDFVocab:inputTo DataAggregationComponent
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "White‑box analytical model representing Stribeck joint friction"
    DTDFVocab:inputTo DataAggregationComponent
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "White‑box analytical model representing Dahl joint friction"
    DTDFVocab:inputTo DataAggregationComponent
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "White‑box analytical model representing LuGre joint friction"
    DTDFVocab:inputTo DataAggregationComponent
]

// Processing component that aggregates data and runs models
instance DataAggregationComponent : DTDFVocab:Enabler [
    base:desc "Central processing component that ingests physical sensor streams and simulation outputs to compute joint friction models and parameters"
    DTDFVocab:enables RealTimeDashboardService, JointFrictionIdentificationService
]

// Services provided by the digital twin
instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Real‑time visualization of sensor data and model outputs via a dashboard"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance JointFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous multi‑physics‑aware identification of joint friction parameters using live data and analytical models"
    DTDFVocab:provides JointFrictionParameterInsight, UpdateControlParametersAction
]

// Insights derived from the services
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight into current motor angle, joint angle, torque, and velocity for monitoring purposes"
]

instance JointFrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Insight into estimated friction parameters (Coulomb, viscous, Stribeck, Dahl, LuGre) used for control parameter updates"
]

// Action that can be triggered by the twin
instance UpdateControlParametersAction : DTDFVocab:Action [
    base:desc "Automated adjustment of the robot’s joint control parameters based on updated friction models (requires manual confirmation)"
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A passive digital shadow framework anchored around an Asset (MABI robot), an engineering model layer, a processing component that consumes sensor traces and simulation models, and a visualization dashboard. The constellation follows the Digital Shadow Reference Model (DSRM) and uses AAS to bind data traces to the asset."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin covers the 'as operated' lifecycle stage: live operational data is streamed and analysed during robot operation. The twin also originates from the ideal model (white‑box analytical friction models) and incorporates real‑world measurements to update the model during use."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by combining analytical white‑box models with data‑driven black‑box models and by continuously validating simulation outputs against live sensor data. Traceability of each data trace to its source (sensor, simulation, calculation) allows verification and validation of the twin. Uncertainty arising from wear, load, temperature, and changing tools is addressed by continuous identification of model parameters."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data is transmitted from the robot to the DT via MQTT packets. The processing component and dashboard subscribe to relevant topics. Asset Administration Shells serve as semantic adapters linking physical data to virtual models."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Standards used are SysML, UML, and the Asset Administration Shell (AAS) as reference models; no ISO or IEEE numbers mentioned."
]