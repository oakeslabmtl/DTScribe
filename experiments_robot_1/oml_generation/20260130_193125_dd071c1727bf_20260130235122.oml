import DTDFVocab
instance RFLP : DTDFVocab:Enabler [
    base:desc "MBSE methodology for Requirements, Functions, Logics, Physics across abstraction levels"
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "MBSE methodology for Object-Oriented Software Engineering Management"
]

instance SPES : DTDFVocab:Enabler [
    base:desc "MBSE methodology for System Process Engineering and Simulation"
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "MBSE methodology for Smart Digital Twin"
]

instance ACME : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for modeling system components and interfaces"
]

instance AADL : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for embedded systems architecture"
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component-based architectures"
]

instance SysML : DTDFVocab:Enabler [
    base:desc "Systems Modeling Language for multi-layered system modeling"
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral modeling"
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink tool for analytical simulations"
]

instance Cpp : DTDFVocab:Enabler [
    base:desc "C++ programming language for simulation implementation"
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java programming language for simulation implementation"
]

instance MotorShaftPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted directly on the motor shaft for measuring angular position",
    DTDFVocab:producedData MQTTDataStream
]

instance GearOutputPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the gear output stage for measuring angular position",
    DTDFVocab:producedData MQTTDataStream
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input current to the motor",
    DTDFVocab:producedData MQTTDataStream
]

instance MQTTDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftPositionEncoder, GearOutputPositionEncoder, MotorCurrentSensor
    base:desc "Real-time time-series sensor data transmitted via MQTT protocol including target and actual position values, derivatives of position, and motor current measurements"
]

instance ProcessedMotorData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted sensor data including position, velocity, and current measurements from physical system",
    DTDFVocab:fromData MQTTDataStream,
    DTDFVocab:inputTo Simulink, Cpp, Java
]

instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving the first axis of the physical system"
]

instance CycloidalGearTransmission : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear stage transmission for precise motion control"
]

instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML model for system requirements layer",
    DTDFVocab:inputTo RFLP
]

instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model for functional architecture layer",
    DTDFVocab:inputTo OOSEM
]

instance SysMLLogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model for logical architecture layer",
    DTDFVocab:inputTo SPES
]

instance SysMLProductTechnicalLayerModel : DTDFVocab:Model [
    base:desc "SysML model for product/technical layer",
    DTDFVocab:inputTo SMArDT
]

instance AADLComponentModel : DTDFVocab:Model [
    base:desc "AADL model for component and interface descriptions",
    DTDFVocab:inputTo AADL
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "MontiArc model for component and connector perspectives",
    DTDFVocab:inputTo MontiArc
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram for component interconnections",
    DTDFVocab:inputTo SysML
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling",
    DTDFVocab:inputTo MontiArcAutomaton
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine for behavior modeling",
    DTDFVocab:inputTo SysML
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for analytical simulations",
    DTDFVocab:inputTo Simulink
]

instance CppSimulationModel : DTDFVocab:Model [
    base:desc "C++ code for simulation implementation",
    DTDFVocab:inputTo Cpp
]

instance JavaSimulationModel : DTDFVocab:Model [
    base:desc "Java code for simulation implementation",
    DTDFVocab:inputTo Java
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "No virtual-to-physical interaction occurs; the digital shadow functions as a passive entity that neither operates autonomously nor pushes data back to the physical system."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sensor data is streamed via MQTT protocol, providing live measurements as stated in the abstract and Section IV.A. Specific synchronization frequencies, latency requirements, and temporal granularity details are not provided in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system architecture is defined by the Digital Shadow Reference Model as a UML class diagram, with a Processing component that consumes and produces data traces to orchestrate component integration and resource management."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data transmission uses MQTT protocol for sensor streaming. Network topology, bandwidth requirements, latency specifications, reliability mechanisms, redundancy, and security protocols are not specified in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems uses MQTT for data streaming, Asset Administration Shells (AAS) for standardized interoperability, and interfaces with the Siemens SINUMERIK 840D sl controller for industrial control systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with SysML, AADL, ACME, MontiArc, and SysML IBDs for architecture description and modeling."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Data is streamed via MQTT protocol, and a physical safety cell restricts the robot's working range to ensure operational safety."
]