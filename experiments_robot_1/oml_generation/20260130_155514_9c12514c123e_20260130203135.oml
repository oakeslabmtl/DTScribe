// C3: Physical sensing component (joint encoder)
instance JointEncoder : DTDFVocab:SensingComponent [
    base:desc "Joint encoder sensor of the six‑axis MABI MAX 100 robot, providing joint position feedback."
    DTDFVocab:producedData EncoderTrace
]

// C4: Data transmitted from the sensor (one‑way automated trace)
instance EncoderTrace : DTDFVocab:DataTransmitted [
    base:desc "One‑way automated data trace generated by the JointEncoder, representing contextual trace of joint position."
    DTDFVocab:producedFrom JointEncoder
]

// C10: Aggregated contextual trace data
instance AggregatedContextualTrace : DTDFVocab:Data [
    base:desc "Aggregated contextual trace data collected from the physical robot, used for processing and model execution."
    DTDFVocab:fromData EncoderTrace
    DTDFVocab:inputTo TraceProcessingEnabler
]

// C11: Enablers
instance TraceProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Software component that consumes aggregated traces and forwards them to processing pipelines, as defined in the digital‑shadow processing components."
    DTDFVocab:enables TraceProcessingService
]

instance ModelExecutionEnabler : DTDFVocab:Enabler [
    base:desc "Component that executes computational models (SysML, Simulink, ML) based on processed data."
    DTDFVocab:enables ModelExecutionService
]

// C6: Services
instance TraceProcessingService : DTDFVocab:Service [
    base:desc "Service that establishes traceability links between input traces, processing components and generated output traces."
    DTDFVocab:provides RequirementTraceabilityInsight
]

instance ModelExecutionService : DTDFVocab:Service [
    base:desc "Service that runs the selected simulation or machine‑learning models and produces output results."
    DTDFVocab:provides ModelUpdateAction
]

// C17: Insight
instance RequirementTraceabilityInsight : DTDFVocab:Insight [
    base:desc "Insight providing fine‑grained traceability from requirements through functions, logic and physics models."
]

// C17: Action
instance ModelUpdateAction : DTDFVocab:Action [
    base:desc "Action that updates or adds new processing components or models while preserving transitive traceability links."
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML block and internal block diagrams describing functional and logical architecture of the robot, captured during MBSE."
    DTDFVocab:inputTo ModelExecutionEnabler
]

instance SimulinkDynamicPhysicsModel : DTDFVocab:Model [
    base:desc "White‑box physics‑based dynamic simulation of the robot's drive and gear transmission realized in MATLAB/Simulink."
    DTDFVocab:inputTo ModelExecutionEnabler
]

instance MachineLearningBlackBoxModel : DTDFVocab:Model [
    base:desc "Black‑box data‑driven model learned from historical trace data to capture nonlinear relationships."
    DTDFVocab:inputTo ModelExecutionEnabler
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Reliability of the digital shadow depends on the correctness of its underlying models and the transformations applied to the data. The documents emphasise traceability: every model element and data point is linked to its origin (e.g., requirement or measurement). Validation is performed by comparing simulated outputs from the white‑box Simulink models against measured sensor data, quantifying deviations. Verification of model transformations (e.g., SysML to simulation model) is advocated to guarantee semantic preservation. Sources of uncertainty include model simplifications and measurement noise, which are monitored through deviation analysis. Quality assurance is achieved by maintaining full provenance of models and data throughout the development lifecycle."
]