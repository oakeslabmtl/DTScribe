// ------------------------------------------------------------ // Return code: 1 | Stderr:
// Sensing Components
// ------------------------------------------------------------
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring input current I_M of the first vertical axis of the MABI MAX 100 robot."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder providing the motor shaft angle (r_M) for the first vertical axis."
    DTDFVocab:producedData MotorEncoderAngleDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Gearbox (secondary) encoder providing the gearbox output angle (r_G) for the first vertical axis."
    DTDFVocab:producedData GearboxEncoderAngleDataTransmitted
]

// ------------------------------------------------------------
// Data Transmitted (one‑way MQTT streams)
// ------------------------------------------------------------
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// ------------------------------------------------------------
// Raw Measured Data
// ------------------------------------------------------------
instance MeasuredCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of measured motor current I_M received via MQTT."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance MeasuredMotorAngleData : DTDFVocab:Data [
    base:desc "Time‑series of measured motor shaft angle r_M received via MQTT."
    DTDFVocab:fromData MotorEncoderAngleDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance MeasuredGearboxAngleData : DTDFVocab:Data [
    base:desc "Time‑series of measured gearbox output angle r_G received via MQTT."
    DTDFVocab:fromData GearboxEncoderAngleDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

// ------------------------------------------------------------
// Derived / Calculated Data
// ------------------------------------------------------------
instance CalculatedTorqueData : DTDFVocab:Data [
    base:desc "Torque values derived from current and angle data by the TorqueCalculationModel."
    DTDFVocab:fromData MeasuredCurrentData
    DTDFVocab:inputTo SimulinkSimulationTool
]

instance CalculatedVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity values derived from angle data by the VelocityCalculationModel."
    DTDFVocab:fromData MeasuredMotorAngleData
    DTDFVocab:inputTo SimulinkSimulationTool
]

instance CalculatedAccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration derived from velocity data."
    DTDFVocab:fromData CalculatedVelocityData
    DTDFVocab:inputTo SimulinkSimulationTool
]

// ------------------------------------------------------------
// Engineering Models (SysML)
// ------------------------------------------------------------
instance MotorEngineeringModel : DTDFVocab:Model [
    base:desc "SysML block‑definition and internal‑block diagram of the permanent‑magnet synchronous motor."
    DTDFVocab:inputTo SysMLModelingTool
]

instance GearboxEngineeringModel : DTDFVocab:Model [
    base:desc "SysML representation of the cycloidal gearbox and gear transmission."
    DTDFVocab:inputTo SysMLModelingTool
]

instance FrictionEngineeringModel : DTDFVocab:Model [
    base:desc "SysML model of friction phenomena (Coulomb‑Viscous, Stribeck, Dahl, LuGre) within the gearbox."
    DTDFVocab:inputTo SysMLModelingTool
]

// ------------------------------------------------------------
// Simulation Models (MATLAB/Simulink)
// ------------------------------------------------------------
instance SimulinkMotorSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model of the motor dynamics used for real‑time simulation."
    DTDFVocab:inputTo SimulinkSimulationTool
]

instance SimulinkGearboxSimulationModel : DTDFVocab:Model [
    base:desc "Simulink model of the gear transmission and cycloidal gearbox."
    DTDFVocab:inputTo SimulinkSimulationTool
]

instance SimulinkFrictionSimulationModel : DTDFVocab:Model [
    base:desc "Simulink implementation of the selected friction model (e.g., LuGre) for the gearbox."
    DTDFVocab:inputTo SimulinkSimulationTool
]

// ------------------------------------------------------------
// Data‑Calculation Models
// ------------------------------------------------------------
instance TorqueCalculationModel : DTDFVocab:Model [
    base:desc "Model that converts motor current I_M and angle data into torque values."
    DTDFVocab:inputTo SimulinkSimulationTool
]

instance VelocityCalculationModel : DTDFVocab:Model [
    base:desc "Model that computes angular velocity from successive angle measurements."
    DTDFVocab:inputTo SimulinkSimulationTool
]

// ------------------------------------------------------------
// Enablers (Tools & Infrastructure)
// ------------------------------------------------------------
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML modeling tool used to create engineering block diagrams."
    DTDFVocab:enables EngineeringModelManagementService
]

instance SimulinkSimulationTool : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink environment for executable simulation of motor, gearbox and friction models."
    DTDFVocab:enables RealTimeFrictionIdentificationService,
                     SimulationVsMeasuredComparisonService,
                     FrictionParameterProvisionService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker that streams live sensor data from the robot to the digital shadow."
    DTDFVocab:enables RealTimeFrictionIdentificationService,
                     SimulationVsMeasuredComparisonService,
                     DashboardVisualizationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) used for model integration and semantic interoperability."
    DTDFVocab:enables EngineeringModelManagementService,
                     DataIntegrationService
]

instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Custom dashboard for visualizing measured and simulated data and for interaction with operators."
    DTDFVocab:enables DashboardVisualizationService
]

// ------------------------------------------------------------
// Services
// ------------------------------------------------------------
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction parameters in the gearbox."
    DTDFVocab:provides StaticFrictionInsight,
                     KineticFrictionInsight,
                     ViscousFrictionInsight
]

instance SimulationVsMeasuredComparisonService : DTDFVocab:Service [
    base:desc "Comparison of simulated torque/velocity against measured values to locate friction losses."
    DTDFVocab:provides FrictionLossLocationInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Visualization of sensor streams, simulation results and identified parameters in the operator dashboard."
]

instance FrictionParameterProvisionService : DTDFVocab:Service [
    base:desc "Provision of updated friction parameters to the robot controller for model‑based motion control."
    DTDFVocab:provides UpdateFrictionParametersAction
]

instance EngineeringModelManagementService : DTDFVocab:Service [
    base:desc "Management and versioning of SysML engineering models via the AAS."
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Integration of raw sensor DataTraces with simulation and calculation models."
]

// ------------------------------------------------------------
// Insights
// ------------------------------------------------------------
instance StaticFrictionInsight : DTDFVocab:Insight [
    base:desc "Identified static friction coefficient from live data."
]

instance KineticFrictionInsight : DTDFVocab:Insight [
    base:desc "Identified kinetic friction coefficient from live data."
]

instance ViscousFrictionInsight : DTDFVocab:Insight [
    base:desc "Identified viscous friction coefficient from live data."
]

instance FrictionLossLocationInsight : DTDFVocab:Insight [
    base:desc "Detected locations and magnitude of friction losses within the gearbox based on simulation‑measurement mismatches."
]

// ------------------------------------------------------------
// Actions
// ------------------------------------------------------------
instance UpdateFrictionParametersAction : DTDFVocab:Action [
    base:desc "Automatic update of the robot controller with newly identified friction parameters."
    DTDFVocab:IsAutomatic true
]

// ------------------------------------------------------------
// Digital Twin Instance (Passive Shadow)
// ------------------------------------------------------------
instance FrictionShadow : DTDFVocab:Component [
    base:desc "Passive digital shadow of the first vertical axis, aggregating DataTraces, models and services."
    base:contains MotorCurrentSensor,
                   MotorEncoderSensor,
                   GearboxEncoderSensor,
                   MotorEngineeringModel,
                   GearboxEngineeringModel,
                   FrictionEngineeringModel,
                   SimulinkMotorSimulationModel,
                   SimulinkGearboxSimulationModel,
                   SimulinkFrictionSimulationModel,
                   TorqueCalculationModel,
                   VelocityCalculationModel,
                   MQTTBrokerEnabler,
                   SimulinkSimulationTool,
                   DashboardVisualizationEnabler,
                   RealTimeFrictionIdentificationService,
                   SimulationVsMeasuredComparisonService,
                   DashboardVisualizationService,
                   FrictionParameterProvisionService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow does not push data back to the robot; it only consumes incoming measurements."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Online, real‑time during robot operation; data are streamed continuously and processed on‑the‑fly for immediate friction identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of the physical asset (first axis), the digital shadow (FrictionShadow) with its Purpose (FrictionDerivation), Processing components (Simulation M, GW, GB), the associated engineering and simulation models, DataTraces, and the visualization dashboard; all linked via a one‑way data flow."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated/runtime stage – the digital shadow is created and used while the robot is running to improve control accuracy; it also supports post‑run analysis."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Combination of white‑box analytical friction models and black‑box data‑driven models; continuous identification to capture wear, temperature and load effects; traceability of each DataTrace to its source and processing model; validation by comparing simulated outputs with measured reference data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow using the MQTT protocol; processing components consume these MQTT topics to generate DataTraces."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) standard for model encapsulation and reference to the Digital Shadow Reference Model (UML class diagram) as a standardized meta‑model."
]