prefix DTDFVocab: http://example.com/DTDFVocab
prefix base: http://www.w3.org/2000/01/rdf-schema#

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "No virtual-to-physical interaction; digital shadows function as passive entities with one-way data flow from physical to virtual, as defined by Kritzinger et al. [32] in Section II.B."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization, as the digital shadow processes live measurements during robot operation to enable continuous model refinement, explicitly stated in the abstract as 'real-time, data-driven representations of robot joint behavior'."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Integration of physical sensors (MQTT data stream), SysML structural models, Simulink simulation models, AAS for asset description, and dashboard for unified visualization of friction data, as described in Section IV.B."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "As operated; the digital shadow is built using live operational data to model the robot's current state during use, as specified in the abstract: 'continuous identification of friction models... over the operating time of the robot'."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation through comparison of simulated vs. measured data to identify friction loss; models validated against real-time operational data for accuracy, as stated in Section IV.A: 'deviation of simulated data versus measured data' for friction detection."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol for real-time data transmission from physical sensors to the digital shadow, as explicitly stated in Section IV: 'time series of all sensors, which are streamed via MQTT'."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Asset Administration Shells (AAS) and SysML standards for modeling and asset description, as explicitly mentioned in the abstract and Section II.A."
]