// ------------------------------ // Return code: 1 | Stderr:
// Sensing Components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor mounted on the PMSM shaft, providing voltage-derived current readings."
    DTDFVocab:producedData CurrentDataTransmitted
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the motor shaft, reporting joint angle with high resolution."
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the cycloidal gearbox, reporting angle of the gearbox side."
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

// ------------------------------
// Data Transmitted (Live one-way MQTT stream)
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// ------------------------------
// Derived Data (calculated from transmitted data)
instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque calculated from motor current and motor angle."
    DTDFVocab:fromData CurrentDataTransmitted, MotorAngleDataTransmitted
    DTDFVocab:inputTo MQTT_Protocol
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity calculated from motor and gearbox angles."
    DTDFVocab:fromData MotorAngleDataTransmitted, GearboxAngleDataTransmitted
    DTDFVocab:inputTo MQTT_Protocol
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration calculated from consecutive angular velocity samples."
    DTDFVocab:fromData AngularVelocityData
    DTDFVocab:inputTo MQTT_Protocol
]

// ------------------------------
// Simulation Models
instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Matlab/Simulink model of the permanent‑magnet synchronous motor without friction."
    DTDFVocab:inputTo Simulink_Enabler
]

instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "Matlab/Simulink model of the cycloidal gearbox without friction."
    DTDFVocab:inputTo Simulink_Enabler
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Coulomb‑Viscous friction model for the rotational axis."
    DTDFVocab:inputTo Simulink_Enabler
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Stribeck friction model for low‑velocity startup behavior."
    DTDFVocab:inputTo Simulink_Enabler
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Dahl friction model capturing hysteresis effects."
    DTDFVocab:inputTo Simulink_Enabler
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "LuGre friction model for comprehensive surface‑contact dynamics."
    DTDFVocab:inputTo Simulink_Enabler
]

// ------------------------------
// Enablers (tooling & infrastructure)
instance ModelManagementService : DTDFVocab:Service [
    base:desc "Service providing model management capabilities in the MBSE workflow."
]

instance MBSE_SysML : DTDFVocab:Enabler [
    base:desc "System Engineering MBSE using SysML for architectural modeling."
    DTDFVocab:enables ModelManagementService
]

instance Simulink_Enabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink providing executable simulation of mechanical subsystems."
    DTDFVocab:enables ContinuousSimulationService, FrictionIdentificationService
]

instance MQTT_Protocol : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating live one‑way data streaming from the robot to the digital twin."
    DTDFVocab:enables DataStreamingService
]

instance DataStreamingService : DTDFVocab:Service [
    base:desc "Service handling data streaming functionality for MQTT broker."
]

instance AAS_MetadataShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell enabling metadata management and traceability."
    DTDFVocab:enables MetadataTraceabilityService
]

instance MetadataTraceabilityService : DTDFVocab:Service [
    base:desc "Service enabling metadata traceability for digital twin assets."
]

instance Dashboard_Visualization : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard application for live data visualization."
    DTDFVocab:enables DashboardVisualizationService
]

// ------------------------------
// Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time jack‑up friction identification using a white‑ and black‑box combination."
    DTDFVocab:provides DriftDetectionInsight, FrictionParameterUpdateInsight, WearNotificationInsight
]

instance ContinuousSimulationService : DTDFVocab:Service [
    base:desc "Continuous multi‑physics simulation of motor and gearbox dynamics."
    DTDFVocab:provides SimulationAccuracyInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Live visualization of sensor and simulation data in a dashboard."
    DTDFVocab:provides VisualDataInsight
]

instance ModelBasedAnalysisService : DTDFVocab:Service [
    base:desc "Automated model‑based analysis to improve motion accuracy."
    DTDFVocab:provides ModelAccuracyInsight, ModelBasedAnalysisInsight
]

instance ProblemIdentificationService : DTDFVocab:Service [
    base:desc "Service for identifying problem conditions in the rotational axis."
]

instance AssetModelAnalysisService : DTDFVocab:Service [
    base:desc "Service for analyzing the model accuracy against physical assets."
]

instance SimulationModelSelectionService : DTDFVocab:Service [
    base:desc "Service for selecting and configuring simulation models."
]

instance DataTraceIdentificationService : DTDFVocab:Service [
    base:desc "Service for establishing data trace connections between physical and virtual domains."
]

instance FrictionModelRefinementService : DTDFVocab:Service [
    base:desc "Service for iterative refinement of friction models during operation."
]

instance QualityAssuranceService : DTDFVocab:Service [
    base:desc "Service ensuring continuous comparison of simulated and measured data for quality assurance."
]

// ------------------------------
// Insights
instance DriftDetectionInsight : DTDFVocab:Insight [
    base:desc "Drift detection of joint friction based on deviations between simulated and measured torques."
]

instance FrictionParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Automatic updating of friction model parameters during operation."
]

instance WearNotificationInsight : DTDFVocab:Insight [
    base:desc "Notification of wear or unexpected load changes detected via friction estimation."
]

instance ControllerTuningRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation for controller tuning derived from friction model and motion accuracy analysis."
]

instance SimulationAccuracyInsight : DTDFVocab:Insight [
    base:desc "Assessment of simulation accuracy by comparing simulated torque and measured torque."
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Assessment of model accuracy based on comparison of derived modal states."
]

instance VisualDataInsight : DTDFVocab:Insight [
    base:desc "Visualization of live sensor and simulation data on the dashboard."
]

instance ModelBasedAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight generated by model‑based analysis to improve motion accuracy."
]

// ------------------------------
// Actions
instance AutomaticFrictionParameterUpdateAction : DTDFVocab:Action [
    base:desc "Automatically update the parameters of the friction model when drift is detected."
    DTDFVocab:IsAutomatic true
]

instance ControllerTuningRecommendationAction : DTDFVocab:Action [
    base:desc "Action to adjust controller settings based on tuning recommendations."
    DTDFVocab:IsAutomatic false
]

instance ModelBasedAnalysisAction : DTDFVocab:Action [
    base:desc "Automated execution of model‑based analysis to refine motion accuracy."
    DTDFVocab:IsAutomatic true
]

// ------------------------------
// Components (physical system)
instance PermanentMagnetSynchronousMotor : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor driving the first rotational axis of the MABI MAX 100 robot."
]

instance Gearwheel : DTDFVocab:Component [
    base:desc "Motor gearwheel connecting the PMSM to the cycloidal gearbox."
]

instance CycloidalGearbox : DTDFVocab:Component [
    base:desc "Cycloidal gearbox translating motor rotation to the joint shaft."
]

// ------------------------------
// Sub‑twin components
instance MotorSubTwin : DTDFVocab:Component [
    base:desc "Digital twin sub‑instance representing the motor dynamics."
]

instance GearwheelSubTwin : DTDFVocab:Component [
    base:desc "Digital twin sub‑instance representing gearwheel dynamics."
]

instance AxisSubTwin : DTDFVocab:Component [
    base:desc "Digital twin sub‑instance representing the overall rotational axis."
]

// ------------------------------
// Environment (centralized processing architecture)
instance RobotAxisEnvironment : DTDFVocab:Environment [
    base:desc "Centralized environment managing the motor, gearwheel, and axis digital twin instances."
    base:contains MotorSubTwin, GearwheelSubTwin, AxisSubTwin
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow produces simulated motor, gearbox, and system‑level torque and angular‑velocity traces which are used to update the friction model parameters in the SINUMERIK 840D sl controller, thereby influencing the motor current commands issued by the PLC."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time operation synchronized with the robot’s control loop; data are streamed and processed at the controller’s sampling rate (implicitly 1 kHz or higher)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A processing core that consumes AAS‑described data traces, runs the simulation models, generates output traces, and exposes a dashboard; all components are interconnected via MQTT and the AAS framework."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (ideal white‑box models), Manufacturing (engineering structural model of the first axis), and Operated (continuous online friction identification during robot use). The twin evolves from a static simulation to a dynamic, data‑driven model as operation proceeds."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of every data point to its origin and generating model via conforms‑to and originates‑from associations; continuous validation by comparing simulated torque against measured torque; use of both analytical (white‑box) and data‑driven (black‑box) models to mitigate model uncertainty."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "One‑way MQTT communication from the robot to the digital shadow; the processing component consumes these streams and produces CSV/JSON outputs consumed by the dashboard; the AAS component maintains metadata."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Implemented on a local workstation or server hosting the Simulink simulation engine and the MQTT broker; the dashboard runs as a web application served locally or on the same machine."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adoption of SysML for modeling, AAS for asset metadata, MQTT for data transport, and MBSE best practices (RFLP, OOSEM)."
]