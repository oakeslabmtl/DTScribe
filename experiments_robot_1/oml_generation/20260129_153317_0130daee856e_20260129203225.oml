// C2: Acting components (none specified)

// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor providing the motor drive current I_M of the first axis, streamed via MQTT"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor shaft of the first axis"
    DTDFVocab:producedData MotorShaftEncoderDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearwheel gearbox of the first axis"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance JointAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting the joint angle of the first axis (output of the cycloidal gearbox)"
    DTDFVocab:producedData JointAngleDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorShaftEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance JointAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointAngleSensor
]

// C10: Data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Raw motor current measurement I_M"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance MotorShaftEncoderData : DTDFVocab:Data [
    base:desc "Raw angle reading from the motor shaft encoder"
    DTDFVocab:fromData MotorShaftEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance GearboxEncoderData : DTDFVocab:Data [
    base:desc "Raw angle reading from the gearbox encoder"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance JointAngleData : DTDFVocab:Data [
    base:desc "Measured joint angle of the first axis"
    DTDFVocab:fromData JointAngleDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Computed torque τ derived from motor current and motor parameters"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

instance DerivedAngularVelocityData : DTDFVocab:Data [
    base:desc "Computed angular velocity ω derived from encoder angle differences"
    DTDFVocab:fromData MotorShaftEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

// C11: Enablers (tooling and enablers)
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker for real‑time data streaming from robot sensors to the digital shadow"
    DTDFVocab:enables RealTimeVisualizationService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment running friction models and data calculations"
    DTDFVocab:enables FrictionParameterIdentificationService, ControlImprovementService
]

instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML modeling tool used for structural block definition and internal block diagrams"
    DTDFVocab:enables StructuralModelingService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell used to integrate SysML and Simulink models into the digital shadow"
    DTDFVocab:enables ModelIntegrationService
]

instance CustomDashboard : DTDFVocab:Enabler [
    base:desc "Custom dashboard for visualization of measured and simulated data"
    DTDFVocab:enables RealTimeVisualizationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of measured and simulated data in the custom dashboard"
    DTDFVocab:provides VisualizedDataInsight
]

instance FrictionParameterIdentificationService : DTDFVocab:Service [
    base:desc "Identifies static, kinetic, and viscous friction parameters from sensor data"
    DTDFVocab:provides IdentifiedFrictionParametersInsight
]

instance ControlImprovementService : DTDFVocab:Service [
    base:desc "Feeds identified friction parameters back to the SINUMERIK 840D controller to improve positioning accuracy"
    DTDFVocab:provides AdjustControlAlgorithmAction
]

instance StructuralModelingService : DTDFVocab:Service [
    base:desc "Provides structural model information to the digital shadow"
    DTDFVocab:provides StructuralModelInsight
]

instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Integrates engineering models (SysML, Simulink) into the digital shadow environment"
    DTDFVocab:provides IntegrationInsight
]

// C17: Insights / Actions
instance VisualizedDataInsight : DTDFVocab:Insight [
    base:desc "Visualization of live sensor measurements and simulation results on the dashboard"
]

instance IdentifiedFrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Static, kinetic and viscous friction parameters identified for the first axis"
]

instance StructuralModelInsight : DTDFVocab:Insight [
    base:desc "Structural composition of the MABI MAX 100 robot first vertical axis"
]

instance IntegrationInsight : DTDFVocab:Insight [
    base:desc "Integrated view of structural and simulation models within the digital shadow"
]

instance AdjustControlAlgorithmAction : DTDFVocab:Action [
    base:desc "Adjusts the SINUMERIK 840D controller algorithms using the identified friction parameters"
    DTDFVocab:IsAutomatic true
]

// C10: Models / Data (engineering models)
instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams describing the robot's structural composition"
    DTDFVocab:inputTo SysMLTool
]

instance SimulinkFrictionFreeModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the first axis without friction effects"
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkFrictionAugmentedModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the first axis including static, kinetic and viscous friction"
    DTDFVocab:inputTo SimulinkEngine
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Calculates derived torque τ and angular velocity ω from current and encoder data"
    DTDFVocab:inputTo SimulinkEngine
]

// C2: Physical components (system under study)
instance MabiMax100Robot : DTDFVocab:Component [
    base:desc "MABI MAX 100 six‑axis industrial robot"
]

instance FirstVerticalAxis : DTDFVocab:Component [
    base:desc "First vertical axis of the robot comprising a PMSM, gearwheel gearbox and cycloidal gearbox"
    base:contains PMSSynMotor, GearwheelGearbox, CycloidalGearbox
]

instance PMSSynMotor : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor driving the first vertical axis"
]

instance GearwheelGearbox : DTDFVocab:Component [
    base:desc "Gearwheel gearbox of the first vertical axis"
]

instance CycloidalGearbox : DTDFVocab:Component [
    base:desc "Cycloidal gearbox of the first vertical axis"
]

// C18: Environment
instance IndustrialAutomationEnvironment : DTDFVocab:Environment [
    base:contains MabiMax100Robot
]

// C17: Insight from twinning process & evolution (optional)
instance FrictionShadow : DTDFVocab:Component [
    base:desc "Digital shadow instance (FrictionShadow) representing the first axis, refined iteratively as new data arrive"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation consists of the physical first axis, the MQTT data acquisition layer, processing components that invoke Simulink simulation models, data trace storage, and a dashboard visualization service, all linked through the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow is created and used during the operational phase of the robot to continuously identify friction while the machine is running."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability is ensured by linking each DataTrace to its source and processing component; friction models (white‑box analytical and black‑box data‑driven) are continuously validated by comparing simulated outputs with measured reference data, enabling identification of model drift due to wear or temperature."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow over Ethernet using the MQTT publish/subscribe protocol; Asset Administration Shells provide metadata about the assets."
]