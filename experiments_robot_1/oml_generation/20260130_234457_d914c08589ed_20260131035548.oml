// C2: Acting Components
instance JointA1Motor : DTDFVocab:ActingComponent [
    base:desc "Brushed DC motor (48 V, 30 A) driving joint A1 with 100:1 planetary gearbox."
]
instance JointA2Motor : DTDFVocab:ActingComponent [
    base:desc "Brushed DC motor (48 V, 30 A) driving joint A2 with 100:1 planetary gearbox."
]
instance JointA3Motor : DTDFVocab:ActingComponent [
    base:desc "Brushed DC motor (48 V, 30 A) driving joint A3 with 100:1 planetary gearbox."
]
instance JointA4Motor : DTDFVocab:ActingComponent [
    base:desc "Brushed DC motor (48 V, 30 A) driving joint A4 with 100:1 planetary gearbox."
]
instance JointA5Motor : DTDFVocab:ActingComponent [
    base:desc "Brushed DC motor (48 V, 30 A) driving joint A5 with 100:1 planetary gearbox."
]
instance JointA6Motor : DTDFVocab:ActingComponent [
    base:desc "Brushed DC motor (48 V, 30 A) driving joint A6 with 100:1 planetary gearbox."
]

// C3: Physical sensing components
instance JointA1Encoder : DTDFVocab:SensingComponent [
    base:desc "14‑bit quadrature encoder mounted on joint A1 shaft, sampled at 1 kHz via EtherCAT."
    DTDFVocab:producedData JointEncoderDataTransmitted
]
instance JointA2Encoder : DTDFVocab:SensingComponent [
    base:desc "14‑bit quadrature encoder mounted on joint A2 shaft, sampled at 1 kHz via EtherCAT."
    DTDFVocab:producedData JointEncoderDataTransmitted
]
instance JointA3Encoder : DTDFVocab:SensingComponent [
    base:desc "14‑bit quadrature encoder mounted on joint A3 shaft, sampled at 1 kHz via EtherCAT."
    DTDFVocab:producedData JointEncoderDataTransmitted
]
instance JointA4Encoder : DTDFVocab:SensingComponent [
    base:desc "14‑bit quadrature encoder mounted on joint A4 shaft, sampled at 1 kHz via EtherCAT."
    DTDFVocab:producedData JointEncoderDataTransmitted
]
instance JointA5Encoder : DTDFVocab:SensingComponent [
    base:desc "14‑bit quadrature encoder mounted on joint A5 shaft, sampled at 1 kHz via EtherCAT."
    DTDFVocab:producedData JointEncoderDataTransmitted
]
instance JointA6Encoder : DTDFVocab:SensingComponent [
    base:desc "14‑bit quadrature encoder mounted on joint A6 shaft, sampled at 1 kHz via EtherCAT."
    DTDFVocab:producedData JointEncoderDataTransmitted
]
instance MotorA1TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor on motor A1, sampled at 1 Hz."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance MotorA2TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor on motor A2, sampled at 1 Hz."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance MotorA3TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor on motor A3, sampled at 1 Hz."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance MotorA4TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor on motor A4, sampled at 1 Hz."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance MotorA5TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor on motor A5, sampled at 1 Hz."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance MotorA6TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor on motor A6, sampled at 1 Hz."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Physical-to-virtual interaction
instance JointEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointA1Encoder, JointA2Encoder, JointA3Encoder,
                          JointA4Encoder, JointA5Encoder, JointA6Encoder
]
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorA1TemperatureSensor, MotorA2TemperatureSensor,
                          MotorA3TemperatureSensor, MotorA4TemperatureSensor,
                          MotorA5TemperatureSensor, MotorA6TemperatureSensor
]

// C10: Models/Data
instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "SysML v1.7 block definition and internal block diagrams defining the physical architecture."
    DTDFVocab:inputTo ModelDataRepository, MQTTBroker
]
instance SimulinkKinematicModel : DTDFVocab:Model [
    base:desc "Simulink block model providing real‑time kinematic simulation synchronized with SysML."
    DTDFVocab:inputTo ModelDataRepository, MQTTBroker
]
instance JointEncoderData : DTDFVocab:Data [
    base:desc "Absolute joint angle, velocity, and hysteresis compensation signals derived from the 14‑bit encoders."
    DTDFVocab:inputTo SimulinkKinematicModel, SysMLStructureModel
    DTDFVocab:fromData JointEncoderDataTransmitted
]
instance TemperatureData : DTDFVocab:Data [
    base:desc "Current temperature readings from the motor temperature sensors."
    DTDFVocab:inputTo SimulinkKinematicModel, SysMLStructureModel
    DTDFVocab:fromData TemperatureDataTransmitted
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker handling EtherCAT data streams over TLS‑based confidentiality, QoS 1."
    DTDFVocab:enables JointStateMonitoringService, TemperatureMonitoringService
]
instance RESTAPI : DTDFVocab:Enabler [
    base:desc "RESTful API exposing telemetry and model data for external analytics."
    DTDFVocab:enables JointStateMonitoringService, TemperatureMonitoringService
]
instance ModelDataRepository : DTDFVocab:Enabler [
    base:desc "Database repository for persisting joint encoder and temperature telemetry streams."
    DTDFVocab:enables JointStateMonitoringService, TemperatureMonitoringService
]

// C6: Services
instance JointStateMonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring joint states, detecting anomalies, and controlling speed limits."
    DTDFVocab:provides JointAnomalyInsight, AdjustJointSpeedAction
]
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring motor temperatures, detecting overheating trends."
    DTDFVocab:provides TemperatureTrendInsight
]

// C17: Insights/Actions
instance JointAnomalyInsight : DTDFVocab:Insight [
    base:desc "Insight detecting abnormal joint angles or velocities beyond ±0.05° repeatability."
]
instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Insight predicting temperature rise trends that may indicate motor overheating."
]
instance AdjustJointSpeedAction : DTDFVocab:Action [
    base:desc "Action automatically reducing joint drive current when encoder velocity exceeds limits."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall twin architecture is coordinated through model‑based artifacts.  Functional and logical components are defined in SysML, with dynamic behavior captured in Simulink models that are executed alongside the twin to drive simulation and validation.  Sensor data stream into the twin via an MQTT broker (the broker acts as the data ingestion layer), and the twin aggregates and processes the data within its asset‑administration‑shell (AAS) framework.  The enriched digital model is then exposed to a generic web‑based dashboard that visualizes key metrics using standard UI libraries."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Life cycle of the Digital Twin follows a multi‑level MBSE approach. It begins with a *requirements abstraction* layer where functional needs of the physical system are captured and encoded in a requirement model. Development then proceeds to a *functional architecture* phase where component boundaries, interfaces and connectors are defined using ADLs such as ACME or AADL. In the *logical architecture* phase, functional roles are translated into abstract, platform‑independent elements, often represented with SysML activity or state‑machine diagrams to capture behavior. At the *product/technical* layer, concrete instances of components are instantiated and generated into executable artefacts or simulation models, using C++/Java code generation or Simulink simulation. Transitions between stages are managed by model synchronization, traceability links, and configuration control that ensure changes at higher levels propagate correctly to lower levels. The life cycle is governed by MBSE best practices and methodologies such as RFLP, OOSEM, SPES, and SMArDT, providing structured change management, validation, and verification throughout the process."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed by comparing Simulink simulation outputs to measured encoder data over a 5‑minute burn‑in; any deviation beyond ±0.05° triggers a recalibration of kinematic parameters. Uncertainty is quantified via Monte‑Carlo analysis of gear backlash and encoder quantization noise, yielding a joint‑position standard deviation of ±0.02°. Residual monitoring detects discrepancies between predicted and measured states; exceeding thresholds flags drift events and initiates automatic re‑calibration. Quality assurance employs a test matrix covering static pose verification, dynamic torque profiling, and workspace coverage, with results recorded in versioned configuration files."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital shadow’s technical network is based on a hierarchical MQTT publish/subscribe architecture. Sensors publish time‑series data to broker topics; the shadow subscribes to these topics. MQTT over TLS provides secure, low‑latency communication with QoS 1. The broker topology can be clustered for scalability, but explicit redundancy or load‑balancing mechanisms are not detailed. Security is enforced through TLS encryption and the broker’s authentication services."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system description is grounded in MBSE languages. SysML is used for functional and logical architecture specifications; ADLs such as ACME, AADL, and MontiArc provide component‑connector architectural views, with MontiArc supporting state‐machine extensions for behavior. Behavioral models feed into Simulink for simulation or generate executable code in C++ or Java. The digital shadow component is defined as an automated one‑way data‑flow model; the document does not specify a communication protocol, certification process, or explicit compliance with industry standards such as IEC or ISO, and therefore no formal standard numbers are referenced."
]