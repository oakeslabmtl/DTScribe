// C3: Physical sensing components
instance PhysicalSystemTraceCollector : DTDFVocab:SensingComponent [
    base:desc "Collects contextual data traces from the physical system including sensor readings, operational logs, and environmental parameters for Digital Shadow integration. Supports data validation, filtering, and normalization to ensure quality assurance before digital model integration."
    DTDFVocab:producedData PhysicalSystemTraceDataTransmitted
]

// C4: Physical-to-virtual interaction
instance PhysicalSystemTraceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemTraceCollector
]

// C10: Models/Data
instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "UML-class-based framework defining concepts for data trace aggregation, abstraction, and contextualization in manufacturing/industrial contexts. Enables one-way data flow from physical to digital objects as precursor to Digital Twin implementation."
    DTDFVocab:inputTo SysMLModelingTool, MontiArcADLTool
]

instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated and abstracted data from physical system traces, including sensor readings, operational logs, and environmental parameters. Processed according to Digital Shadow Reference Model for specific use cases like monitoring, diagnostics, or predictive analytics."
    DTDFVocab:fromData PhysicalSystemTraceDataTransmitted
    DTDFVocab:inputTo SysMLModelingTool, MontiArcADLTool, SimulinkSimulationEngine
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based functional architecture model capturing system requirements, functions, and logical components using Internal Block Diagrams (IBDs) and state machines (v1.7). Supports multi-perspective modeling across heterogeneous stakeholders."
    DTDFVocab:inputTo SysMLModelingTool
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Component-based logical architecture model defined using Architecture Description Languages (ADLs) like ACME, AADL, or MontiArc. Focuses on components, interfaces, interconnections, and composition with behavioral extensions via state machines or automata."
    DTDFVocab:inputTo MontiArcADLTool, AADLTool, ACMETool
]

instance PhysicsBasedSimulationModel : DTDFVocab:Model [
    base:desc "Physics-based analytical model implemented in MathWorks Simulink or general-purpose code (C++/Java) for dynamic system simulation, control system prototyping, and real-time testing. Used for predictive modeling and optimization scenarios."
    DTDFVocab:inputTo SimulinkSimulationEngine, CustomCodeEnabler
]

// C11: Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "Systems Modeling Language (SysML) toolchain supporting multi-layered modeling (requirements, functional/logical architecture, physical design) via Internal Block Diagrams (IBDs) and state machines (v1.7). Enables cross-tool integration with simulation engines."
    DTDFVocab:enables DataInterpretationService, BehavioralSimulationService, VisualizationService
]

instance MontiArcADLTool : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language tool for component-based system architecture with automaton-based behavior modeling. Supports interfaces, interconnections, and composition for logical architecture modeling."
    DTDFVocab:enables DataInterpretationService, BehavioralSimulationService
]

instance AADLTool : DTDFVocab:Enabler [
    base:desc "Architecture Analysis & Design Language (AADL) tool for defining component-based architectures with interfaces, interconnections, and composition. Used for logical architecture modeling in complex engineered systems."
    DTDFVocab:enables DataInterpretationService
]

instance ACMETool : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language tool for component-based system architecture modeling. Supports interfaces and interconnections for logical architecture definition."
    DTDFVocab:enables DataInterpretationService
]

instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink model-based design tool for dynamic system simulation, control system prototyping, and real-time testing. Integrates with SysML for co-simulation and digital twin validation."
    DTDFVocab:enables BehavioralSimulationService, ControlOptimizationService, PredictiveModelingService
]

instance CustomCodeEnabler : DTDFVocab:Enabler [
    base:desc "General-purpose programming languages (C++/Java) for implementing custom logic, real-time control algorithms, and performance-critical components within the Digital Twin ecosystem."
    DTDFVocab:enables ControlOptimizationService
]

// C6: Services
instance DataInterpretationService : DTDFVocab:Service [
    base:desc "Active service for interpreting and processing incoming data from the physical system. Includes aggregation, abstraction, and contextual analysis of data traces according to Digital Shadow Reference Model."
    DTDFVocab:provides DataAggregationInsight, ContextualAnalysisInsight
]

instance BehavioralSimulationService : DTDFVocab:Service [
    base:desc "Service providing state machine/automaton execution and simulation integration for dynamic behavioral modeling and real-time response. Uses MontiArc Automaton or SysML v1.7 state machines."
    DTDFVocab:provides BehavioralStateInsight, SimulationValidationInsight
]

instance ControlOptimizationService : DTDFVocab:Service [
    base:desc "Service enabling autonomous decision-making and real-time optimization through closed-loop control and adaptive adjustments. Integrates with simulation engines and custom code for execution."
    DTDFVocab:provides OptimizationRecommendationInsight, ControlParameterAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service providing multi-perspective views and integrated visualization across functional, logical, and technical layers. Supports heterogeneous stakeholders with purpose-driven data abstraction."
    DTDFVocab:provides SystemStateVisualizationInsight, StakeholderDashboardInsight
]

instance PredictiveModelingService : DTDFVocab:Service [
    base:desc "Service for prognostic modeling including failure prediction, demand forecasting, and scenario testing using simulation and machine learning capabilities integrated with Simulink."
    DTDFVocab:provides FailurePredictionInsight, DemandForecastInsight
]

// C17: Insights/Actions
instance DataAggregationInsight : DTDFVocab:Insight [
    base:desc "Aggregated and validated data traces from physical system monitoring, ready for contextual analysis and further processing."
]

instance ContextualAnalysisInsight : DTDFVocab:Insight [
    base:desc "Contextually analyzed data providing operational context, environmental factors, and system state interpretation for decision-making."
]

instance BehavioralStateInsight : DTDFVocab:Insight [
    base:desc "Current behavioral state of the system as modeled by state machines or automata, including transition events and dynamic responses."
]

instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results from simulation scenarios testing control strategies, failure modes, and optimization parameters against physical system behavior."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimized parameters and recommendations for resource allocation, energy efficiency, or production scheduling derived from real-time optimization algorithms."
]

instance ControlParameterAction : DTDFVocab:Action [
    base:desc "Autonomous adjustment of physical system parameters based on Digital Twin insights, enabling closed-loop control and corrective actions."
    DTDFVocab:IsAutomatic true
]

instance SystemStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Multi-layered visualization of system state across functional, logical, and technical perspectives for stakeholder communication and monitoring."
]

instance StakeholderDashboardInsight : DTDFVocab:Insight [
    base:desc "Purpose-driven data abstraction tailored to specific stakeholder roles (engineers, operators, managers) for strategic optimization and KPI tracking."
]

instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Prognostic predictions of component failures or system degradation based on simulation and machine learning analysis of operational data."
]

instance DemandForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasted demand patterns and resource requirements derived from predictive modeling and historical data analysis."
]

// C2: Acting Components
instance AutonomousControlActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator component enabling closed-loop control and autonomous decision-making by pushing optimized parameters back to the physical system based on Digital Twin insights."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin (DT) constellation** in this context is implicitly defined through **Model-Based Systems Engineering (MBSE)** frameworks, which orchestrate system modeling via **multi-layered abstraction** (requirements, functional, logical, and physical layers). Orchestration relies on **architecture description languages (ADLs)** such as ACME, AADL, MontiArc, or SysML IBDs, which define **component-connector architectures** to model interconnections, interfaces, and composition. For behavioral coordination, ADLs may integrate with **state machines (SysML v1.7)** or **automata (MontiArc Automaton)** to manage dynamic interactions. Resource management is not explicitly detailed, but the document suggests **heterogeneous tool integration** (e.g., MathWorks Simulink, simulation tools, or general-purpose languages like C++/Java) to handle complexity. System-wide coordination is implied through **MBSE methodologies** (e.g., RFLP, OOSEM) that enforce structured development workflows, though no specific orchestration patterns (e.g., microservices, service-oriented) are mentioned."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **fidelity and validity considerations** primarily through **Model-Based Systems Engineering (MBSE) validation and verification (V&V) processes**. While the document does not specify exact uncertainty quantification methods, it implies that **model fidelity** is ensured by aligning computational models (e.g., behavioral, analytical) with physical system requirements via structured methodologies like **RFLP, OOSEM, or SMArDT**. **Validation** is achieved through **cross-tool integration** (e.g., SysML, Simulink, or general-purpose code) to verify behavioral and logical consistency. **Error detection and correction mechanisms** are not explicitly detailed, but the use of **ADLs (e.g., AADL, MontiArc)** and **state machines** suggests formalized interfaces and state transitions to mitigate discrepancies. **Quality assurance** is implicitly tied to the **heterogeneous stakeholder integration** and **traceability** across abstraction layers, ensuring that models and data adhere to defined system specifications."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The document does not provide explicit details on **horizontal integration** (e.g., data exchange protocols, interoperability standards, or dependencies on external systems). However, it highlights the need for **interoperability** between **heterogeneous modeling tools** (e.g., SysML, ADLs, Simulink, C++/Java) and **stakeholder perspectives**, suggesting the use of **standardized interfaces** or **adapters** to bridge disparate systems. While no specific protocols (e.g., OPC UA, MQTT, REST) or enterprise integration patterns (e.g., EAI, API gateways) are mentioned, the **Digital Shadow Reference Model** (Fig. 1) implies a **one-way data flow** from physical to digital objects, which may require **protocol-based synchronization** for external system integration. The document does not address integration with other Digital Twins or enterprise systems beyond this implicit need for data aggregation and abstraction."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE) standards**, including **SysML (Systems Modeling Language)** for system architecture and behavior modeling, as well as **Architecture Description Languages (ADLs)** like **ACME**, **AADL**, and **MontiArc** for component-based system design. Interoperability is facilitated through **multi-tool integration**, such as combining SysML with **MathWorks Simulink** or other **simulation tools/methods** for behavioral analysis. While no explicit **certification frameworks** or **compliance standards** (e.g., ISO, IEC, or industry-specific regulations) are mentioned, the use of **standardized modeling languages** (SysML, ADLs) ensures alignment with **engineering best practices** and **interoperability protocols**. The **Digital Shadow Reference Model** (Fig. 1) suggests adherence to **data aggregation and abstraction standards** for manufacturing contexts, though specific compliance requirements (e.g., GDPR, sector-specific norms) are not detailed."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system for the MABI MAX 100 serial robot incorporates **safety-critical system considerations** through the implementation of a **safety cell** that restricts the maximum working range of the first vertical axis to **[-90°, 90°]**, ensuring operational boundaries are enforced. **Threat mitigation strategies** are indirectly addressed via the **dual encoder system** (motor encoder and secondary encoder behind the gearbox), which reduces **backlash** and **positional uncertainty** by analyzing encoder discrepancies to infer **elasticity and friction** in the drive train. This sensor arrangement enhances **fail-safe mechanisms** by improving positional accuracy to **0.1 mm** and repeatability to **0.06 mm**, critical for safety in subtractive manufacturing tasks. The **Siemens SINUMERIK 840D sl CNC controller** provides **access control mechanisms** for axis-specific operations, with inputs/outputs including **position, speed, acceleration, motor current (converted to torque via motor constants), and target/actual values**, ensuring controlled and monitored execution. However, explicit **cybersecurity protocols**, **authentication systems**, or **compliance with data protection regulations** are not detailed in the provided documents."
]