instance MABIMAX100System : DTDFVocab:Environment [
    base:desc "Serial robot MABI MAX 100 with six axes, featuring motors and gearboxes for each axis, controlled by a Siemens SINUMERIK 840D sl controller, operating in a machining domain requiring precise motion control for manufacturing processes."
    base:contains MABIMAX100PositionEncoder, MABIMAX100CurrentSensor, PermanentMagnetSynchronousMotor, SiemensSINUMERIK840DController
]

instance MABIMAX100PositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Two position encoders per drive for precise angular measurement, sensor data streamed in real-time via MQTT protocol"
    DTDFVocab:producedData AngularPositionDataTransmitted
]

instance MABIMAX100CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures input current (I_M) for motor torque control, collected at high sampling frequencies to ensure accurate system state monitoring"
    DTDFVocab:producedData MotorInputCurrentDataTransmitted
]

instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving the first axis, with input current (I_M) controlling torque (τ_M) output"
]

instance SiemensSINUMERIK840DController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl CNC controller handling actuation commands and integrating with simulation models for motor and gearbox dynamics actuation precise within specified operational ranges with safety constraints enforced by firmware"
]

instance AngularPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MABIMAX100PositionEncoder
]

instance MotorInputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MABIMAX100CurrentSensor
]

instance AngularPositionData : DTDFVocab:Data [
    base:desc "Angular position measurements from position encoders"
    DTDFVocab:fromData AngularPositionDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, SysMLEnabler
]

instance MotorInputCurrentData : DTDFVocab:Data [
    base:desc "Input current (I_M) measurements for motor control"
    DTDFVocab:fromData MotorInputCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, SysMLEnabler
]

instance SysMLModel : DTDFVocab:Model [
    base:desc "SysML for structural modeling including Interface Block Diagrams"
    DTDFVocab:inputTo SysMLEnabler
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink for dynamic simulation"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for structural modeling and data management across abstraction levels"
    DTDFVocab:enables StructuralModelingService, DataManagementService
]

instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Behavior modeling using MontiArc Automaton and C++"
    DTDFVocab:provides BehaviorModelingInsight
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral modeling and simulation"
    DTDFVocab:enables BehavioralModelingService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for dynamic simulation and real-time analysis"
    DTDFVocab:enables PredictiveMotionService
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP methodology for managing data across abstraction levels (requirements, functional, logical, technical)"
    DTDFVocab:enables DataManagementService
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for system engineering processes"
    DTDFVocab:enables SystemDesignService
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for model-based development"
    DTDFVocab:enables SystemDevelopmentService
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for digital twin development"
    DTDFVocab:enables DigitalTwinDevelopmentService
]

instance ACMEADL : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component & connector perspectives"
    DTDFVocab:enables SystemArchitectureService
]

instance AADLADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for real-time systems"
    DTDFVocab:enables RealTimeSystemService
]

instance MontiArcADL : DTDFVocab:Enabler [
    base:desc "MontiArc for component & connector modeling"
    DTDFVocab:enables ComponentModelingService
]

instance SysMLIBD : DTDFVocab:Enabler [
    base:desc "SysML Interface Block Diagrams for structural modeling"
    DTDFVocab:enables StructuralModelingService
]

instance CppProgramming : DTDFVocab:Enabler [
    base:desc "C++ for detailed behavior specification and simulation"
    DTDFVocab:enables BehavioralModelingService
]

instance JavaProgramming : DTDFVocab:Enabler [
    base:desc "Java for detailed behavior specification and heterogeneous stakeholder integration"
    DTDFVocab:enables IntegrationService
]

instance LiveDataLinkingService : DTDFVocab:Service [
    base:desc "Live-data linking from physical robot to digital model via MQTT protocol"
    DTDFVocab:provides LiveDataStreamInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Visualization via dashboards to monitor joint friction dynamics"
    DTDFVocab:provides JointFrictionMonitoringInsight
]

instance PredictiveMotionService : DTDFVocab:Service [
    base:desc "Predictive capabilities to improve motion accuracy through real-time analysis and adjustment recommendations"
    DTDFVocab:provides MotionAccuracyInsight, RealTimeAdjustmentRecommendation
]

instance StructuralModelingService : DTDFVocab:Service [
    base:desc "Structural modeling using SysML Interface Block Diagrams"
    DTDFVocab:provides StructuralModelInsight
]

instance DataManagementService : DTDFVocab:Service [
    base:desc "Data management across abstraction levels (requirements, functional, logical, technical) using methodologies like RFLP, OOSEM, SPES, SMArDT"
    DTDFVocab:provides DataAbstractionInsight
]

instance SystemDesignService : DTDFVocab:Service [
    base:desc "System design using OOSEM methodology"
    DTDFVocab:provides SystemDesignInsight
]

instance SystemDevelopmentService : DTDFVocab:Service [
    base:desc "System development using SPES methodology"
    DTDFVocab:provides SystemDevelopmentInsight
]

instance DigitalTwinDevelopmentService : DTDFVocab:Service [
    base:desc "Digital twin development using SMArDT methodology"
    DTDFVocab:provides DigitalTwinDevelopmentInsight
]

instance SystemArchitectureService : DTDFVocab:Service [
    base:desc "System architecture modeling using ACME ADL"
    DTDFVocab:provides SystemArchitectureInsight
]

instance RealTimeSystemService : DTDFVocab:Service [
    base:desc "Real-time system modeling using AADL"
    DTDFVocab:provides RealTimeSystemInsight
]

instance ComponentModelingService : DTDFVocab:Service [
    base:desc "Component modeling using MontiArc ADL"
    DTDFVocab:provides ComponentModelingInsight
]

instance IntegrationService : DTDFVocab:Service [
    base:desc "Heterogeneous stakeholder integration using Java"
    DTDFVocab:provides IntegrationInsight
]

instance LiveDataStreamInsight : DTDFVocab:Insight [
    base:desc "Real-time data stream from physical robot to digital model for monitoring"
]

instance JointFrictionMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of joint friction dynamics through dashboard visualization"
]

instance MotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Insights to improve robot motion accuracy through analytical processing"
]

instance RealTimeAdjustmentRecommendation : DTDFVocab:Action [
    base:desc "Actionable recommendations for real-time motion adjustment"
    DTDFVocab:IsAutomatic true
]

instance StructuralModelInsight : DTDFVocab:Insight [
    base:desc "Structural model insights from SysML Interface Block Diagrams"
]

instance DataAbstractionInsight : DTDFVocab:Insight [
    base:desc "Data abstraction across requirements, functional, logical, and technical layers"
]

instance SystemDesignInsight : DTDFVocab:Insight [
    base:desc "System design insights using OOSEM methodology"
]

instance SystemDevelopmentInsight : DTDFVocab:Insight [
    base:desc "System development insights using SPES methodology"
]

instance DigitalTwinDevelopmentInsight : DTDFVocab:Insight [
    base:desc "Digital twin development insights using SMArDT methodology"
]

instance SystemArchitectureInsight : DTDFVocab:Insight [
    base:desc "System architecture insights using ACME ADL"
]

instance RealTimeSystemInsight : DTDFVocab:Insight [
    base:desc "Real-time system insights using AADL"
]

instance ComponentModelingInsight : DTDFVocab:Insight [
    base:desc "Component modeling insights using MontiArc ADL"
]

instance BehaviorModelingInsight : DTDFVocab:Insight [
    base:desc "Behavior modeling insights using MontiArc Automaton and C++"
]

instance IntegrationInsight : DTDFVocab:Insight [
    base:desc "Integration insights for heterogeneous stakeholders using Java"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Shadow reference model (Fig. 1) defines important concepts for digital shadows in manufacturing, where the shadow functions as a passive entity with one-way data flow from the physical object to the digital object, requiring active components from a Digital Twin to interpret and process incoming data without autonomous operation or data pushback to the physical system."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for communication between physical sensors and digital entities for time series data streaming."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adoption of architecture description languages (ADLs) such as SysML, AADL, ACME, and MontiArc for system modeling, alongside simulation tools like MathWorks Simulink and general-purpose programming languages (C++, Java) for behavior description and implementation."
]