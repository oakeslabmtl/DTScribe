instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Detects anomalies in system behavior using contextual data traces and behavioral models."
    DTDFVocab:provides FaultPredictionInsight, DegradationPatternInsight
]

instance DataIntegrationService : DTDFVocab:Service [
