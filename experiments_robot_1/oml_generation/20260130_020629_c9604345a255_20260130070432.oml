// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real-time temperature readings from manufacturing equipment or environmental sensors as part of contextual data traces for Digital Shadow Reference Model integration."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real-time pressure readings from manufacturing processes or system components, contributing to operational logs for Digital Shadow aggregation."
    DTDFVocab:producedData PressureDataTransmitted
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors vibration patterns in rotating machinery or structural components, providing operational health indicators for Digital Shadow data traces."
    DTDFVocab:producedData VibrationDataTransmitted
]

instance OperationalLogCollector : DTDFVocab:SensingComponent [
    base:desc "Aggregates system operational logs including process parameters, event triggers, and system state transitions for Digital Shadow contextual data."
    DTDFVocab:producedData OperationalLogDataTransmitted
]

instance EnvironmentalParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Collects environmental parameters such as humidity, ambient temperature, or atmospheric conditions affecting system performance."
    DTDFVocab:producedData EnvironmentalParameterDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "One-way automated data flow containing real-time temperature readings from TemperatureSensor, aggregated and abstracted for Digital Shadow integration."
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "One-way automated data flow containing real-time pressure readings from PressureSensor, processed for Digital Shadow contextual analysis."
    DTDFVocab:producedFrom PressureSensor
]

instance VibrationDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "One-way automated data flow containing vibration data from VibrationSensor, used for anomaly detection in Digital Shadow."
    DTDFVocab:producedFrom VibrationSensor
]

instance OperationalLogDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "One-way automated data flow containing operational logs from OperationalLogCollector, aggregated for Digital Shadow system state tracking."
    DTDFVocab:producedFrom OperationalLogCollector
]

instance EnvironmentalParameterDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "One-way automated data flow containing environmental parameters from EnvironmentalParameterSensor, integrated into Digital Shadow for contextual analysis."
    DTDFVocab:producedFrom EnvironmentalParameterSensor
]

// C10: Models/Data
instance GeometricModel : DTDFVocab:Model [
    base:desc "Structural representation of the physical system using SysML or ADLs (e.g., AADL) for component-connector architecture definition."
    DTDFVocab:inputTo MontiArcIntegrationEnabler, SysMLModelingEnabler
]

instance BehavioralStateMachineModel : DTDFVocab:Model [
    base:desc "Dynamic behavior model using SysML v1.7 state machines or MontiArc Automaton for system state transitions and control logic."
    DTDFVocab:inputTo MontiArcAutomatonEnabler, SimulinkSimulationEnabler
]

instance PhysicsBasedAnalyticalModel : DTDFVocab:Model [
    base:desc "Physics-based analytical model derived from simulation tools (e.g., Simulink) for predictive validation and failure mode analysis."
    DTDFVocab:inputTo SimulinkSimulationEnabler, CppJavaImplementationEnabler
]

instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces from Digital Shadow Reference Model, including sensor readings and operational logs."
    DTDFVocab:fromData TemperatureDataTransmitted, PressureDataTransmitted, VibrationDataTransmitted, OperationalLogDataTransmitted, EnvironmentalParameterDataTransmitted
    DTDFVocab:inputTo DigitalShadowAggregationEnabler, DataQualityAssuranceEnabler
]

instance HeterogeneousDataSource : DTDFVocab:Data [
    base:desc "Integrated data from disparate sources including real-time IoT streams, historical databases, and legacy system logs for unified analysis."
    DTDFVocab:fromData OperationalLogDataTransmitted, EnvironmentalParameterDataTransmitted
    DTDFVocab:inputTo DataIntegrationMiddlewareEnabler, DatabaseBackendEnabler
]

// C11: Enablers
instance MontiArcIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Enables logical architecture modeling and dynamic reconfiguration using MontiArc ADL for component-connector systems."
    DTDFVocab:enables RealTimeStateSynchronizationService, AdaptiveReconfigurationService
]

instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "Supports multi-layered abstraction modeling (requirements to physical) using SysML for structured system engineering."
    DTDFVocab:enables SystemDesignValidationService, MultiPerspectiveDashboardService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Facilitates detailed behavioral simulation and control system design using MathWorks Simulink for real-time execution."
    DTDFVocab:enables ProactiveFaultForecastingService, ResourceAllocationService
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "Implements state machines and behavioral models using MontiArc Automaton for dynamic system behavior analysis."
    DTDFVocab:enables ClosedLoopAutomationService, AutomatedDecisionSupportService
]

instance CppJavaImplementationEnabler : DTDFVocab:Enabler [
    base:desc "Enables implementation of system components using general-purpose languages (C++/Java) for cross-validation and execution."
    DTDFVocab:enables ScenarioSimulationService, ControlLoopExecutionService
]

instance DigitalShadowAggregationEnabler : DTDFVocab:Enabler [
    base:desc "Aggregates and abstracts contextual data traces from physical system sensors into structured Digital Shadow data."
    DTDFVocab:enables PassiveDataIngestionService, AnomalyDetectionService
]

instance DataQualityAssuranceEnabler : DTDFVocab:Enabler [
    base:desc "Ensures data consistency and validation through schema validation and normalization for heterogeneous data sources."
    DTDFVocab:enables RealTimeStateSynchronizationService, DataIntegrationService
]

instance DataIntegrationMiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "Provides standardized APIs and middleware for integrating real-time IoT streams, historical databases, and legacy systems."
    DTDFVocab:enables HeterogeneousDataIntegrationService
]

instance DatabaseBackendEnabler : DTDFVocab:Enabler [
    base:desc "Stores structured models (SysML/AADL) and unstructured data traces (time-series sensor data) in scalable repositories."
    DTDFVocab:enables DataPersistenceService
]

instance VersionControlEnabler : DTDFVocab:Enabler [
    base:desc "Manages model evolution and traceability across abstraction layers using Git for SysML/AADL artifacts."
    DTDFVocab:enables ModelConsistencyService
]

// C6: Services
instance PassiveDataIngestionService : DTDFVocab:Service [
    base:desc "Acts as an active interpreter of one-way automated data flows from the physical system, processing contextual data traces for Digital Shadow."
    DTDFVocab:provides DigitalShadowDataInsight
]

instance RealTimeStateSynchronizationService : DTDFVocab:Service [
    base:desc "Maintains a dynamic digital replica of the physical system's state for anomaly detection and performance tracking through heterogeneous data integration."
    DTDFVocab:provides SystemStateInsight, PerformanceTrackingInsight
]

instance AutomatedDecisionSupportService : DTDFVocab:Service [
    base:desc "Uses model-based reasoning (SysML functional/logical architectures) to propose corrective actions or process improvements based on analyzed data trends."
    DTDFVocab:provides OptimizationRecommendationAction, ProcessImprovementAction
]

instance ResourceAllocationService : DTDFVocab:Service [
    base:desc "Optimizes component interactions (modeled via ADLs like MontiArc or AADL) to enhance efficiency using simulation tools (e.g., Simulink) for predictive validation."
    DTDFVocab:provides EfficiencyOptimizationInsight, PredictiveValidationInsight
]

instance ProactiveFaultForecastingService : DTDFVocab:Service [
    base:desc "Employs behavioral models (e.g., state machines in SysML v1.7) and simulation engines to predict failure modes or degradation patterns before physical manifestation."
    DTDFVocab:provides FaultPredictionInsight, DegradationPatternInsight
]

instance ScenarioSimulationService : DTDFVocab:Service [
    base:desc "Evaluates 'what-if' scenarios using combined modeling tools (e.g., Simulink + ADLs) to assess system resilience under varying conditions."
    DTDFVocab:provides ResilienceAssessmentInsight, ScenarioOutcomeInsight
]

instance ClosedLoopAutomationService : DTDFVocab:Service [
    base:desc "Integrates with physical actuators via active components to execute real-time adjustments (e.g., process parameter tuning in manufacturing)."
    DTDFVocab:provides RealTimeAdjustmentAction, ActuatorControlAction
]

instance AdaptiveReconfigurationService : DTDFVocab:Service [
    base:desc "Dynamically modifies logical architectures (e.g., via MontiArc) to respond to operational deviations or external constraints."
    DTDFVocab:provides DynamicReconfigurationAction, ConstraintAdaptationAction
]

instance MultiPerspectiveDashboardService : DTDFVocab:Service [
    base:desc "Provides stakeholder-specific views (e.g., engineers see SysML IBDs, operators see real-time KPIs) using heterogeneous model notations consolidated into a unified interface."
    DTDFVocab:provides StakeholderViewInsight, UnifiedInterfaceInsight
]

instance SystemDesignValidationService : DTDFVocab:Service [
    base:desc "Utilizes MBSE tools (e.g., SysML, MontiArc) for design validation and architecture analysis by system engineers."
    DTDFVocab:provides DesignValidationInsight, ArchitectureAnalysisInsight
]

instance HeterogeneousDataIntegrationService : DTDFVocab:Service [
    base:desc "Bridges disparate modeling notations (e.g., ADLs, SysML, Simulink) via standardized interfaces for seamless interoperability."
    DTDFVocab:provides InteroperabilityInsight, NotationBridgingInsight
]

// C17: Insights/Actions
instance DigitalShadowDataInsight : DTDFVocab:Insight [
    base:desc "Aggregated and abstracted contextual data traces from the physical system for Digital Shadow purposes."
]

instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Dynamic digital replica of the physical system's state, synchronized in real-time for monitoring."
]

instance PerformanceTrackingInsight : DTDFVocab:Insight [
    base:desc "Continuous performance metrics and KPIs derived from synchronized digital twin data."
]

