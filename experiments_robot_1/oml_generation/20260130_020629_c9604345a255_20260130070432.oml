]

// C2: Acting Components
instance ProcessParameterActuator : DTDFVocab:ActingComponent [
    base:desc "Executes real-time adjustments to manufacturing process parameters based on Digital Twin recommendations."
]

instance SystemReconfigurationAgent : DTDFVocab:ActingComponent [
    base:desc "Dynamically modifies logical architecture components via MontiArc to adapt to operational deviations."
]

instance ControlLoopExecutor : DTDFVocab:ActingComponent [
    base:desc "Implements closed-loop control logic using Simulink or C++/Java for real-time system adjustments."
]

// C1: Environment
instance ManufacturingSystemEnvironment : DTDFVocab:Environment [
    base:desc "Complex engineered system environment characterized by multi-layered abstraction (requirements to physical) and heterogeneous stakeholder integration."
    base:contains ManufacturingProcessComponent, OperationalLogCollector, TemperatureSensor, PressureSensor, VibrationSensor, EnvironmentalParameterSensor
]

instance ManufacturingProcessComponent : DTDFVocab:Component [
    base:desc "Core component of the manufacturing system under study, modeled using MBSE methodologies (RFLP, OOSEM, SPES)."
]

