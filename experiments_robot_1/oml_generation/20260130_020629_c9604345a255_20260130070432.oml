    base:desc "Automated suggestions for process improvements based on analyzed data trends."
    DTDFVocab:IsAutomatic true
]

instance ProcessImprovementAction : DTDFVocab:Action [
    base:desc "Corrective actions proposed by the Digital Twin to enhance system efficiency."
    DTDFVocab:IsAutomatic true
]

instance EfficiencyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Analysis of component interactions and resource allocation efficiency."
]

instance PredictiveValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results from simulation-based predictive analysis of system behavior."
]

instance FaultPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted failure modes and degradation patterns identified through behavioral modeling."
]

instance DegradationPatternInsight : DTDFVocab:Insight [
    base:desc "Detected patterns of system degradation before physical manifestation."
]

instance ResilienceAssessmentInsight : DTDFVocab:Insight [
    base:desc "Evaluation of system resilience under varying operational conditions."
]

instance ScenarioOutcomeInsight : DTDFVocab:Insight [
    base:desc "Outcomes of 'what-if' scenario simulations for system behavior analysis."
]

