    DTDFVocab:IsAutomatic true
]

instance DynamicReconfigurationAction : DTDFVocab:Action [
    base:desc "Automated modification of logical architecture in response to operational deviations."
    DTDFVocab:IsAutomatic true
]

instance ConstraintAdaptationAction : DTDFVocab:Action [
    base:desc "Adaptation of system behavior to external constraints or operational deviations."
    DTDFVocab:IsAutomatic true
]

instance StakeholderViewInsight : DTDFVocab:Insight [
    base:desc "Customized views for different stakeholders (engineers, operators, managers) based on their roles."
]

instance UnifiedInterfaceInsight : DTDFVocab:Insight [
    base:desc "Consolidated interface combining heterogeneous model notations into a single view."
]

instance DesignValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results of system design using MBSE tools and methodologies."
]

instance ArchitectureAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analysis of system architecture using SysML and ADLs for structural and behavioral validation."
]

instance InteroperabilityInsight : DTDFVocab:Insight [
    base:desc "Assessment of seamless integration between disparate modeling notations and tools."
]

instance NotationBridgingInsight : DTDFVocab:Insight [
