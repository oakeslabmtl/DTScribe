// C3: Physical sensing components
instance PhysicalTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that collects contextual data traces from the physical object as described in the Digital Twin model."
    DTDFVocab:producedData TelemetryDataTransmitted
]

// C4: Data transmitted from sensing components
instance TelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalTelemetrySensor
]

// C10: Data objects
instance TelemetryData : DTDFVocab:Data [
    base:desc "Contextual telemetry data abstracted according to the Digital Shadow reference model."
    DTDFVocab:fromData TelemetryDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEngine
]

// C10: Model instances
instance SysMLBlockDiagramModel : DTDFVocab:Model [
    base:desc "Geometric and analytical representation captured in SysML block definition diagrams."
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "Component‑connector architecture described using the ACME architecture description language."
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model realized as a Simulink simulation (state‑machine/automaton)."
    DTDFVocab:inputTo SimulinkSimulationEngine
]

// C11: Enabler instances
instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation tool used to execute behavioral models and process telemetry data."
    DTDFVocab:enables RealTimeMonitoringService,
                     AutomatedDecisionSupportService,
                     ClosedLoopControlService
]

instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML modeling environment employed for requirements, functional, logical and physical layers."
    DTDFVocab:enables ModelingSupportService
]

instance CppRuntimeEngine : DTDFVocab:Enabler [
    base:desc "C++ runtime executing generated code from MBSE transformations."
    DTDFVocab:enables ClosedLoopControlService
]

// C6: Service instances
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of the physical object's state using processed telemetry data."
    DTDFVocab:provides SystemStateInsight
]

instance AutomatedDecisionSupportService : DTDFVocab:Service [
    base:desc "Offers automated decision support by interpreting model predictions and recommending actions."
    DTDFVocab:provides DecisionRecommendationInsight
]

instance ClosedLoopControlService : DTDFVocab:Service [
    base:desc "Executes closed‑loop control actions feeding back decisions to the physical system."
    DTDFVocab:provides ControlAdjustmentAction
]

instance ModelingSupportService : DTDFVocab:Service [
    base:desc "Supports creation, transformation and traceability of MBSE artifacts across abstraction layers."
    DTDFVocab:provides ModelingInsight
]

// C17: Insight and Action instances
instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Insight about the current operational state derived from real‑time monitoring."
]

instance DecisionRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal decisions based on model analysis."
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment command sent to actuators to maintain desired system behavior."
    DTDFVocab:IsAutomatic true
]

instance ModelingInsight : DTDFVocab:Insight [
    base:desc "Insight regarding consistency and traceability of MBSE artifacts."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by combining white‑box (e.g., Simulink dynamic simulation) and black‑box (e.g., machine‑learning) approaches, ensuring each contributes complementary accuracy. Validation and verification are performed through traceability of model transformations (e.g., from SysML to simulation models) and verification of the correctness of data‑model mappings. Uncertainty sources such as sensor noise or model simplifications are acknowledged, and their quantification is implied by the emphasis on traceability and verification methods. Quality assurance includes systematic verification of transformation steps and continuous validation of the DT against the physical system to detect and correct errors in the aggregated data traces."
]