instance SysMLIBDStructuralModel : DTDFVocab:Model [
    base:desc "Structural component model using SysML IBDs"
    DTDFVocab:inputTo SysMLIBDADL, SysMLMBSE, RFLPMethodology, OOSEMMethodology, SPESMethodology, SMArDTMethodology
]

instance ACMEStructuralModel : DTDFVocab:Model [
    base:desc "Structural component model using ACME"
