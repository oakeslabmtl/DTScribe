// C3: Physical sensing components
instance AssetTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Provides raw sensor and operational data traces from the physical asset as described by the digital shadow."
    DTDFVocab:producedData AssetTelemetryDataTransmitted
]

// C4: Physical-to-virtual interaction
instance AssetTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AssetTelemetrySensor
]

// C10: Data
instance AggregatedSensorData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data streams collected for MBSE model inputs."
    DTDFVocab:fromData AssetTelemetryDataTransmitted
    DTDFVocab:inputTo SysMLTool, SimulinkSimulator
]

// C11: Enablers
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML modeling environment used to capture requirements, functional, logical and physical architectures (RFLP, OOSEM, SPES, SMArDT)."
    DTDFVocab:enables ModelValidationService
]

instance SimulinkSimulator : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment executing physics‑based and analytical models."
    DTDFVocab:enables SimulationExecutionService
]

instance CodeGenerator : DTDFVocab:Enabler [
    base:desc "Automated generation of C++/Java implementation code from MBSE models."
    DTDFVocab:enables ImplementationProvisionService
]

// C6: Services
instance ModelValidationService : DTDFVocab:Service [
    base:desc "Validates MBSE models for consistency, completeness and traceability across abstraction levels."
    DTDFVocab:provides ModelTraceabilityInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Executes state‑machine and Simulink models to produce simulation results."
    DTDFVocab:provides SimulationResultInsight
]

instance ImplementationProvisionService : DTDFVocab:Service [
    base:desc "Provides generated C++/Java artifacts for deployment of the Digital Twin."
    DTDFVocab:provides ImplementationReadinessInsight
]

// C17: Insights
instance ModelTraceabilityInsight : DTDFVocab:Insight [
    base:desc "Shows traceability links between requirements, functions, logical models and physics models."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Delivers simulation outcomes that support validation of behavioural and analytical models."
]

instance ImplementationReadinessInsight : DTDFVocab:Insight [
    base:desc "Indicates readiness of generated code for integration with the physical asset."
]

// C10: Models
instance SysMLRequirementModel : DTDFVocab:Model [
    base:desc "SysML requirement model capturing system requirements per RFLP methodology."
    DTDFVocab:inputTo SysMLTool
]

instance SysMLLogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram describing logical components, ports and connectors."
    DTDFVocab:inputTo SysMLTool
]

instance ACMEComponentModel : DTDFVocab:Model [
    base:desc "ACME architecture description defining component composition and connectors."
    DTDFVocab:inputTo SysMLTool
]

instance AADLComponentModel : DTDFVocab:Model [
    base:desc "AADL model specifying hardware/software components and interfaces."
    DTDFVocab:inputTo SysMLTool
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "MontiArc ADL model representing component hierarchies and data flows."
    DTDFVocab:inputTo SysMLTool
]

instance SimulinkPhysicsModel : DTDFVocab:Model [
    base:desc "Simulink model encapsulating physics‑based equations for analytical analysis."
    DTDFVocab:inputTo SimulinkSimulator
]

instance StateMachineModel : DTDFVocab:Model [
    base:desc "SysML state‑machine (or MontiArc Automaton) model describing system behaviour."
    DTDFVocab:inputTo SimulinkSimulator, CodeGenerator
]

instance CPPImplementationModel : DTDFVocab:Model [
    base:desc "C++ implementation model generated from MBSE artifacts."
    DTDFVocab:inputTo CodeGenerator
]

instance JavaImplementationModel : DTDFVocab:Model [
    base:desc "Java implementation model generated from MBSE artifacts."
    DTDFVocab:inputTo CodeGenerator
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the MBSE development chain split into abstraction levels: (1) requirements modeling, (2) functional architecture, (3) logical architecture, and (4) product/technical layer. At each stage the twin is represented by corresponding models – requirements captured in SysML requirement diagrams, functional blocks in SysML internal block diagrams or ADL component‑connector graphs, logical behavior encoded in state‑machine or automaton extensions (e.g., MontiArc Automaton), and detailed product models in simulation tools such as Simulink or executable code (C++, Java). Transition between stages is managed by integrating heterogeneous stakeholder models and by mapping components across notations, while governance follows the MBSE practice of traceability across the RFLP (Requirements, Functions, Logics, Physics) methodology."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin adopts several established modeling standards: SysML (OMG), Architecture Description Languages such as ACME, AADL (ASME/OMG), and MontiArc, as well as simulation standards embodied in MathWorks Simulink. These standards provide a common semantics for component‑connector structures, interfaces and behavior description, enabling interoperability between tools and stakeholders. No specific certification or regulatory compliance frameworks are mentioned."
]