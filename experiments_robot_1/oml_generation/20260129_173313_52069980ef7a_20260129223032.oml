instance PhysicalSystemStateSensor : DTDFVocab:SensingComponent [
    base:desc "Physical system state data source for one-way digital shadow data flows"
    DTDFVocab:producedData PhysicalSystemStateData
]

instance PhysicalSystemStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemStateSensor
]

instance PhysicalSystemStateRawData : DTDFVocab:Data [
    base:desc "Raw data from physical system states via one-way digital shadow"
    DTDFVocab:fromData PhysicalSystemStateData
    DTDFVocab:inputTo Simulink, Cpp, Java
]

instance ACME_StructuralModel : DTDFVocab:Model [
    base:desc "Structural model using ACME Architecture Description Language"
    DTDFVocab:inputTo ACME
]

instance AADL_StructuralModel : DTDFVocab:Model [
    base:desc "Structural model using AADL Architecture Description Language"
    DTDFVocab:inputTo AADL
]

instance MontiArc_StructuralModel : DTDFVocab:Model [
    base:desc "Structural model using MontiArc Architecture Description Language"
    DTDFVocab:inputTo MontiArc
]

instance SysMLIBDs_StructuralModel : DTDFVocab:Model [
    base:desc "Structural model using SysML Internal Block Diagrams"
    DTDFVocab:inputTo SysML
]

instance SysMLv17_StateMachines : DTDFVocab:Model [
    base:desc "Behavioral model using SysML v1.7 state machines"
    DTDFVocab:inputTo SysML
]

instance MontiArc_Automaton : DTDFVocab:Model [
    base:desc "Behavioral model using MontiArc Automaton"
    DTDFVocab:inputTo MontiArc
]

instance Simulink_AnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model implemented with MathWorks Simulink"
    DTDFVocab:inputTo Simulink
]

instance Cpp_AnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model implemented with C++ programming language"
    DTDFVocab:inputTo Cpp
]

instance Java_AnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model implemented with Java programming language"
    DTDFVocab:inputTo Java
]

instance RequirementsModel : DTDFVocab:Model [
    base:desc "Model at requirements abstraction level"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "Model at functional architecture abstraction level"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Model at logical architecture abstraction level"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance ProductTechnicalLayerModel : DTDFVocab:Model [
    base:desc "Model at product/technical layer abstraction level"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for Requirements, Functions, Logics, Physics management"
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "Object-Oriented Systems Engineering Methodology for system complexity management"
]

instance SPES : DTDFVocab:Enabler [
    base:desc "System Product Engineering Specification methodology for system complexity management"
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "Smart Systems Engineering Methodology for system complexity management"
]

instance SysML : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for structural modeling via SysML Internal Block Diagrams"
]

instance ACME : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component & connector modeling"
]

instance AADL : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for embedded systems modeling"
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component-based modeling"
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and detailed behavior modeling"
]

instance Cpp : DTDFVocab:Enabler [
    base:desc "C++ programming language for simulation and analytical modeling"
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java programming language for simulation and analytical modeling"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Industry standards such as SysML [17], AADL [24], ACME [23], and MontiArc [25], [26] are used for architecture description languages (ADLs) to model components, interfaces, and interconnections. Methodologies including RFLP [18], [19], OOSEM [20], SPES [21], and SMArDT [22] are applied for handling system complexity across abstraction levels (requirements, functional architecture, logical architecture, product/technical layer)."
]