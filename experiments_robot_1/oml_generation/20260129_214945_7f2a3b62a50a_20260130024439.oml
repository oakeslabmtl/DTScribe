import "http://www.example.org/DTDFVocab" as DTDFVocab
import "http://www.example.org/base" as base
instance FrictionModelIdentificationInsight : DTDFVocab:Insight [
    base:desc "Friction model identification leading to adjustments in robot control algorithms for improved motion accuracy"
]
instance AdjustRobotControlAlgorithms : DTDFVocab:Action [
    base:desc "Automatic adjustments to robot control algorithms based on friction model identification",
    DTDFVocab:IsAutomatic true
]
instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time dashboard visualization of sensor data and model outputs"
]
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Purpose-driven methodology with steps: problem identification, asset and model analysis, use or creation of calculations or models, data identification ongoing refinement through research collaborations as per [15], continuous multi-physics-aware identification of joint friction using white-box and black-box models",
    DTDFVocab:provides FrictionModelIdentificationInsight
]
instance MotionAccuracyImprovementService : DTDFVocab:Service [
    base:desc "Adjustments in robot control algorithms for improved motion accuracy",
    DTDFVocab:provides AdjustRobotControlAlgorithms
]
instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Integrated dashboard visualization for real-time monitoring",
    DTDFVocab:provides DashboardVisualizationInsight
]
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for structural modeling",
    DTDFVocab:enables FrictionIdentificationService
]
instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks MATLAB Simulink for friction modeling",
    DTDFVocab:enables FrictionIdentificationService, MotionAccuracyImprovementService
]
instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shells (AAS) for asset management",
    DTDFVocab:enables DashboardVisualizationService
]
instance MQTTProtocolEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol for data streaming",
    DTDFVocab:enables FrictionIdentificationService, MotionAccuracyImprovementService, DashboardVisualizationService
]
instance SINUMERIKControllerEnabler : DTDFVocab:Enabler [
    base:desc "Siemens SINUMERIK 840D sl controller for motion control",
    DTDFVocab:enables MotionAccuracyImprovementService
]
instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard visualization for real-time monitoring",
    DTDFVocab:enables DashboardVisualizationService
]
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder providing real-time sensor data streamed via MQTT"
]
instance SecondaryPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder providing real-time sensor data streamed via MQTT"
]
instance MQTTDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder, SecondaryPositionEncoder,
    base:desc "MQTT streaming of sensor data including input current, position, velocity, torque, and acceleration from robot encoders and controller"
]
instance InputCurrentData : DTDFVocab:Data [
    base:desc "Input current data trace from robot encoders and controller",
    DTDFVocab:fromData MQTTDataStream,
    DTDFVocab:inputTo SimulinkEnabler, SysMLEnabler
]
instance TorqueData : DTDFVocab:Data [
    base:desc "Torque data trace from robot encoders and controller",
    DTDFVocab:fromData MQTTDataStream,
    DTDFVocab:inputTo SimulinkEnabler
]
instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity data trace from robot encoders and controller",
    DTDFVocab:fromData MQTTDataStream,
    DTDFVocab:inputTo SimulinkEnabler
]
instance SimulatedValuesData : DTDFVocab:Data [
    base:desc "Simulated values data trace from friction models",
    DTDFVocab:inputTo DashboardVisualizationEnabler
]
instance SysMLBDD : DTDFVocab:Model [
    base:desc "SysML Block Definition Diagram for structural modeling of the robot's first axis",
    DTDFVocab:inputTo SysMLEnabler
]
instance SysMLIBD : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram for structural modeling of the robot's first axis",
    DTDFVocab:inputTo SysMLEnabler
]
instance SimulinkCoulombViscous : DTDFVocab:Model [
    base:desc "Coulomb-Viscous friction model using MathWorks MATLAB Simulink",
    DTDFVocab:inputTo SimulinkEnabler
]
instance SimulinkStribeck : DTDFVocab:Model [
    base:desc "Stribeck friction model using MathWorks MATLAB Simulink",
    DTDFVocab:inputTo SimulinkEnabler
]
instance SimulinkDahl : DTDFVocab:Model [
    base:desc "Dahl friction model using MathWorks MATLAB Simulink",
    DTDFVocab:inputTo SimulinkEnabler
]
instance SimulinkLuGre : DTDFVocab:Model [
    base:desc "LuGre friction model using MathWorks MATLAB Simulink",
    DTDFVocab:inputTo SimulinkEnabler
]
instance AASModel : DTDFVocab:Model [
    base:desc "Asset Administration Shell for the robot's first axis",
    DTDFVocab:inputTo AASEnabler
]
instance FirstAxisSystem : DTDFVocab:Component [
    base:desc "Single digital shadow instance for the first axis of the MABI MAX 100 industrial robot with six axes from MABI Robotic AG"
]
instance MABIRobotFirstAxisEnvironment : DTDFVocab:Environment [
    base:desc "Environment containing the first axis of the MABI MAX 100 robot",
    base:contains FirstAxisSystem
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time data streaming via MQTT"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Digital shadow integrating SysML structural models, Simulink simulation models, live sensor data via MQTT, and dashboard visualization for friction analysis and motion accuracy improvement"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "As operated phase (real-time operational data usage)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Comparison of simulated data versus measured data to validate friction models and improve motion accuracy"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol for real-time data streaming from physical sensors to digital shadow"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Asset Administration Shell (AAS) and SysML standards"
]