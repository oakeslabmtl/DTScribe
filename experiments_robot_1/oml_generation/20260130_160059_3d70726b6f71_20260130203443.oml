// C3: Physical sensing component
instance PhysicalAssetMQTTSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that collects time‑series measurements from the physical asset and streams them via MQTT to the digital shadow."
    DTDFVocab:producedData MQTTDataStream
]

// C4: Physical‑to‑virtual interaction
instance MQTTDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalAssetMQTTSensor
]

// C10: Data
instance TimeSeriesMeasurementData : DTDFVocab:Data [
    base:desc "Aggregated time‑series measurement data received from the physical asset via MQTT."
    DTDFVocab:fromData MQTTDataStream
    DTDFVocab:inputTo SysMLModelProcessor, ADLArchitectureProcessor, StateMachineExecutor,
                 MontiArcAutomatonExecutor, SimulinkSimulator, MLInferenceEngine
]

// C10: Models
instance GeometricStructuralModel : DTDFVocab:Model [
    base:desc "Geometric and structural description expressed in SysML block and internal block diagrams."
    DTDFVocab:inputTo SysMLModelProcessor
]

instance ComponentConnectorArchitectureModel : DTDFVocab:Model [
    base:desc "Component‑and‑connector architecture captured using ADLs such as ACME, AADL, MontiArc, and SysML internal block diagrams."
    DTDFVocab:inputTo ADLArchitectureProcessor
]

instance BehavioralStateMachineModel : DTDFVocab:Model [
    base:desc "Behavioral model realized as a SysML state‑machine diagram."
    DTDFVocab:inputTo StateMachineExecutor
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "Behavioral model realized as a MontiArc Automaton."
    DTDFVocab:inputTo MontiArcAutomatonExecutor
]

instance SimulinkDynamicPhysicsModel : DTDFVocab:Model [
    base:desc "Analytical white‑box model implemented in MathWorks Simulink for dynamic physics simulation."
    DTDFVocab:inputTo SimulinkSimulator
]

instance MachineLearningFrictionRegressorModel : DTDFVocab:Model [
    base:desc "Black‑box data‑driven machine‑learning regressor modeling robot friction."
    DTDFVocab:inputTo MLInferenceEngine
]

// C11: Enablers
instance SysMLModelProcessor : DTDFVocab:Enabler [
    base:desc "Processor that transforms SysML geometric/structural models into executable representations."
    DTDFVocab:enables DecisionSupportService, DashboardVisualizationService
]

instance ADLArchitectureProcessor : DTDFVocab:Enabler [
    base:desc "Processor that interprets component‑connector architectures described in ADLs."
    DTDFVocab:enables DecisionSupportService
]

instance StateMachineExecutor : DTDFVocab:Enabler [
    base:desc "Engine that executes SysML state‑machine behavior models."
    DTDFVocab:enables DecisionSupportService
]

instance MontiArcAutomatonExecutor : DTDFVocab:Enabler [
    base:desc "Engine that executes MontiArc Automaton behavioral models."
    DTDFVocab:enables DecisionSupportService
]

instance SimulinkSimulator : DTDFVocab:Enabler [
    base:desc "Simulator that runs Simulink dynamic physics models."
    DTDFVocab:enables DecisionSupportService
]

instance MLInferenceEngine : DTDFVocab:Enabler [
    base:desc "Inference engine that evaluates machine‑learning friction regressor models."
    DTDFVocab:enables DecisionSupportService
]

// C6: Services
instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Service that aggregates model outputs and sensor data to generate performance indicators for decision making."
    DTDFVocab:provides PerformanceIndicatorInsight, UpdateDigitalTwinAction
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Service that presents analytical results on dashboards for stakeholder interaction."
    DTDFVocab:provides PerformanceIndicatorInsight
]

// C17: Insight
instance PerformanceIndicatorInsight : DTDFVocab:Insight [
    base:desc "Computed performance indicators derived from simulation and data‑driven models, linked to originating sensor traces."
]

// C17: Action
instance UpdateDigitalTwinAction : DTDFVocab:Action [
    base:desc "Action that updates the digital twin's active components with the latest analytical results."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The lifecycle of the Digital Twin is anchored in a Model‑Based Systems‑Engineering (MBSE) development phase that is split into four abstraction levels often referred to as RFLP: (1) Requirements modeling, (2) Functional‑architecture modeling, (3) Logical‑architecture modeling, and (4) Product/technical‑layer modeling. At each level a concrete representation is created with SysML artifacts (requirement diagrams, block definition diagrams, internal block diagrams, parametric diagrams). After the abstract models are defined, a Digital‑Shadow Reference Model (a UML class diagram) is instantiated; this concretization step maps reference concepts to concrete classes and relations, producing a concrete digital shadow. The digital shadow then serves as the basis for the full Digital Twin by adding active processing components, simulation or data‑calculation models, and traceability links (the ‘originates‑from’ association) that connect generated data traces back to their originating processing component and input traces. Transition between stages is governed by the conformance relation defined in the reference model, ensuring that each concrete realization satisfies the structural and semantic constraints of the abstract model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and validity are ensured through explicit traceability of all model artefacts and data transformations. The approach stresses verification of model transformations, for example the correctness of converting SysML specifications into executable Simulink simulation models. By maintaining a traceable link between the original SysML artefacts, the derived simulation code, and the resulting data outputs, the Digital Twin can be validated against the physical system. The methodology advocates the combination of white‑box (physics‑based Simulink) and black‑box (data‑driven) models to improve predictive accuracy, and mandates verification steps that confirm that each transformation preserves intended semantics."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The only technical connection explicitly mentioned is the use of MQTT (a lightweight publish/subscribe messaging protocol) for streaming sensor time‑series data from the physical asset to the digital shadow. No information is given about network topology, bandwidth, latency, redundancy, or additional security protocols."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The system employs the Asset Administration Shell (AAS) as the interoperability standard and streams sensor data via the MQTT protocol, allowing connection to external equipment such as the Siemens SINUMERIK controller. This enables standardized data exchange and integration with other enterprise systems and Digital Twins."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on several established standards: SysML (OMG Systems Modeling Language) for MBSE models; UML class diagrams for the Digital‑Shadow Reference Model; ADLs including ACME, AADL, and MontiArc for component‑connector specifications; and the concept of a conformance relation as defined in reference‑model theory [41]. These standards provide interoperability, tool‑chain compatibility, and certify that concrete digital shadow realizations conform to the abstract reference model."
]