// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) measuring real-time current of the first axis motor"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder providing position feedback for the first axis motor"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary gearbox encoder delivering gearwheel position data"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmitted)
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// C10: Data instances
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Raw motor current trace streamed via MQTT"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkEngine, DataCalculationModel
]

instance MotorEncoderData : DTDFVocab:Data [
    base:desc "Raw motor encoder positions streamed via MQTT"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEngine, DataCalculationModel
]

instance GearboxEncoderData : DTDFVocab:Data [
    base:desc "Raw gearbox encoder positions streamed via MQTT"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEngine, DataCalculationModel
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Derived torque calculated from current and encoder traces"
    DTDFVocab:fromData MotorCurrentDataTransmitted, MotorEncoderDataTransmitted, GearboxEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEngine, DashboardApp
]

instance DerivedAngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity computed from encoder and torque data"
    DTDFVocab:fromData MotorEncoderDataTransmitted, GearboxEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEngine, DashboardApp
]

instance DerivedAccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration obtained from velocity data"
    DTDFVocab:fromData MotorEncoderDataTransmitted, GearboxEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEngine, DashboardApp
]

// C10: Model instances
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML block definition diagram describing motor, gearwheel and cycloidal gearbox structure"
    DTDFVocab:inputTo SimulinkEngine, AssetAdministrationShell
]

instance SysMLBehaviorModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram modeling energy flows and dynamic behavior of the first axis"
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink executable model of the motor including electrical dynamics"
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "Simulink model of the gearwheel and cycloidal gearbox, configurable with friction parameters"
    DTDFVocab:inputTo SimulinkEngine
]

instance FrictionIdentificationModel : DTDFVocab:Model [
    base:desc "Simulation model used for real‑time identification of static, kinetic and viscous friction"
    DTDFVocab:inputTo SimulinkEngine
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Model that calculates derived torque, velocity and acceleration from raw sensor traces"
    DTDFVocab:inputTo SimulinkEngine
]

// C11: Enabler instances
instance MqttBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker handling live sensor streams from the robot to the digital shadow"
    DTDFVocab:enables RealTimeFrictionIdentificationService, SimulationComparisonService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink execution environment running the engineering and friction models"
    DTDFVocab:enables RealTimeFrictionIdentificationService, SimulationComparisonService, FrictionParameterGenerationService
]

instance DashboardApp : DTDFVocab:Enabler [
    base:desc "Integrated web dashboard visualizing data, model results and friction trends"
    DTDFVocab:enables DashboardVisualizationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell providing standardized asset description for the first axis"
]

instance Sinumerik840DController : DTDFVocab:Enabler [
    base:desc "Siemens SINUMERIK 840D controller governing robot motion"
    DTDFVocab:enables FrictionParameterGenerationService
]

// C6: Service instances
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction from streamed data"
    DTDFVocab:provides FrictionParameterInsight, FrictionTrendInsight
]

instance SimulationComparisonService : DTDFVocab:Service [
    base:desc "Compares simulated torque/velocity from Simulink models with measured data"
    DTDFVocab:provides FrictionTrendInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Visualizes data and model outcomes in the web dashboard"
    DTDFVocab:provides FrictionTrendInsight
]

instance FrictionParameterGenerationService : DTDFVocab:Service [
    base:desc "Generates updated friction parameters for motion‑control improvement"
    DTDFVocab:provides UpdateFrictionParametersAction
]

// C17: Insight and Action instances
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived static, kinetic and viscous friction parameters"
]

instance FrictionTrendInsight : DTDFVocab:Insight [
    base:desc "Trend visualization of friction parameters over operation time"
]

instance UpdateFrictionParametersAction : DTDFVocab:Action [
    base:desc "Feeds updated friction parameters back to the SINUMERIK controller to improve motion accuracy"
    DTDFVocab:IsAutomatic true
]

// C8: Component instances (physical)
instance MotorComponent : DTDFVocab:Component [
    base:desc "Electric motor of the first axis of the MABI MAX 100 robot"
]

instance GearwheelComponent : DTDFVocab:Component [
    base:desc "Gearwheel coupling the motor to the cycloidal gearbox"
]

instance CycloidalGearboxComponent : DTDFVocab:Component [
    base:desc "Cycloidal gearbox providing high reduction and torque transmission for the first axis"
]

// C9: Environment instance
instance MabiMax100FirstAxisEnvironment : DTDFVocab:Environment [
    base:contains MotorComponent, GearwheelComponent, CycloidalGearboxComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None; the digital shadow follows a one‑way data flow and does not send commands back to the robot."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow consisting of the asset (first robot axis), a processing layer that runs Simulink friction models, engineering and simulation models, data traces linked to sources, and a dashboard service; all components are integrated via MQTT and described through an AAS."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated (runtime) stage – the digital shadow is created to continuously identify friction during the robot’s actual machining operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability from data points to source and processing model, use of both white‑box (analytical) and black‑box (data‑driven) friction models, continuous comparison of simulated outputs with measured data to validate model accuracy, and explicit metadata to support validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used to stream sensor data from the robot to the digital shadow; the data are then consumed by processing components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) standard for asset description and SysML as a standardized modeling language."
]