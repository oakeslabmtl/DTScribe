// Models // Return code: 1 | Stderr:
instance RequirementsModel : DTDFVocab:Model [
    base:desc "Captures the highest‑level requirements for the digital twin as specified in the MBSE process."
    DTDFVocab:inputTo MBSEStackEnabler
]

instance FunctionalLogicalModel : DTDFVocab:Model [
    base:desc "Expresses functional and logical detail using ADLs such as ACME, AADL, MontiArc, and SysML IBDs."
    DTDFVocab:inputTo MBSEStackEnabler
]

instance ProductTechnicalArchitectureModel : DTDFVocab:Model [
    base:desc "Details the product‑technical architecture through component composition, interfacing, and hierarchy."
    DTDFVocab:inputTo MBSEStackEnabler
]

instance SimulationWorkflowModel : DTDFVocab:Model [
    base:desc "Represents the simulation workflow executed in MathWorks Simulink, integrating ADLs and behavioral models."
    DTDFVocab:inputTo SimulationEnabler
]

instance DigitalShadowUMLModel : DTDFVocab:Model [
    base:desc "UML class diagram aggregating contextual data traces from real‑time sensor streams, log files, or simulation outputs."
    DTDFVocab:inputTo DataPersistenceEnabler
]

// Data Transmitted
instance SimulationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationWorkflowModel
]

// Data
instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Captures contextual data traces extracted from real‑time sensor streams, log files, or simulation outputs."
    DTDFVocab:fromData SimulationDataTransmitted
    DTDFVocab:inputTo DataPersistenceEnabler
]

instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Simulation output data generated by MathWorks Simulink."
    DTDFVocab:fromData SimulationDataTransmitted
    DTDFVocab:inputTo SimulationEnabler
]

// Enablers
instance MBSEStackEnabler : DTDFVocab:Enabler [
    base:desc "Facilitates use of SysML v1.7, MontiArc, and MontiArc Automaton in the MBSE stack for model creation and verification."
    DTDFVocab:enables SimulationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabling simulation capabilities using MathWorks Simulink environment."
    DTDFVocab:enables SimulationService
]

instance CodeGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Enables code generation in C++ or Java from MontiArc and SysML models."
    DTDFVocab:enables CodeGenerationService
]

instance DataPersistenceEnabler : DTDFVocab:Enabler [
    base:desc "Supports persistence of data and models in relational or NoSQL databases within enterprise platforms."
    DTDFVocab:enables DataPersistenceService
]

instance EnterprisePlatformEnabler : DTDFVocab:Enabler [
    base:desc "Provides the enterprise platform that hosts and orchestrates modeling, simulation, code generation, and execution."
    DTDFVocab:enables SystemIntegrationService
]

// Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Runs simulations via Simulink, returning system behavior insights."
    DTDFVocab:provides SimulationOutcomeInsight
]

instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Generates executable code from models for runtime integration."
    DTDFVocab:provides ExecutableDeploymentAction
]

instance DataPersistenceService : DTDFVocab:Service [
    base:desc "Persists the digital twin's data and models into databases for integrity and traceability."
    DTDFVocab:provides DataArchiveInsight
]

instance SystemIntegrationService : DTDFVocab:Service [
    base:desc "Integrates modeling, simulation, and execution components within the enterprise platform."
    DTDFVocab:provides SystemIntegrationAction
]

// Insights
instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulation outputs capturing system behavior under defined scenarios."
]

instance DataArchiveInsight : DTDFVocab:Insight [
    base:desc "Insight into data persistence quality and database integrity for historical and contextual data."
]

// Actions
instance ExecutableDeploymentAction : DTDFVocab:Action [
    base:desc "Deploys generated C++ or Java runtime to target environment."
    DTDFVocab:IsAutomatic true
]

instance SystemIntegrationAction : DTDFVocab:Action [
    base:desc "Action that orchestrates integration of system components delivering a coherent digital twin."
    DTDFVocab:IsAutomatic false
]

// Component
instance DigitalTwinSystem : DTDFVocab:Component [
    base:desc "Core digital twin system encompassing models, enablers, services, and runtime actions."
]

// Environment
instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains DigitalTwinSystem,
    MBSEStackEnabler,
    SimulationEnabler,
    CodeGenerationEnabler,
    DataPersistenceEnabler,
    EnterprisePlatformEnabler,
    SimulationService,
    CodeGenerationService,
    DataPersistenceService,
    SystemIntegrationService
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin lifecycle is delineated along the typical MBSE abstraction hierarchy: beginning with requirement capture, advancing through functional architecture, logical architecture, and culminating in the product/technical layer. Each stage is represented by distinct modelling artefacts, e.g., SysML requirement diagrams for the requirements stage, SysML block definition and internal block diagrams for the functional architecture, and SysML interaction or sequence diagrams for the logical architecture. Transition between stages is managed via refinement and traceability links intrinsic to MBSE not explicitly elaborated in the document, while governance is implied through modelling discipline and the use of standardised modelling languages such as SysML and MontiArc."
]