// ----------------------------------------------------
// Physical sensing component and data flow
// ----------------------------------------------------
instance PhysicalAssetDataCollector : DTDFVocab:SensingComponent [
    base:desc "Collects contextual data traces gathered from the physical asset as defined in the digital‑shadow reference model."
    DTDFVocab:producedData AssetTraceDataTransmitted
]

instance AssetTraceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalAssetDataCollector
]

instance AssetContextualTraceData : DTDFVocab:Data [
    base:desc "Contextual data traces gathered from the physical asset, aggregated and abstracted for a specific purpose."
    DTDFVocab:fromData AssetTraceDataTransmitted
    DTDFVocab:inputTo VersionControlRepositoryEnabler
]

// ----------------------------------------------------
// MBSE and simulation models
// ----------------------------------------------------
instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML diagram capturing the requirements layer of the asset."
    DTDFVocab:inputTo VersionControlRepositoryEnabler
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML diagram capturing the functional layer of the asset."
    DTDFVocab:inputTo VersionControlRepositoryEnabler
]

instance SysMLLogicalModel : DTDFVocab:Model [
    base:desc "SysML diagram capturing the logical layer of the asset."
    DTDFVocab:inputTo VersionControlRepositoryEnabler
]

instance SysMLPhysicalModel : DTDFVocab:Model [
    base:desc "SysML diagram capturing the physical layer of the asset."
    DTDFVocab:inputTo VersionControlRepositoryEnabler
]

instance ADLComponentArchitectureModel : DTDFVocab:Model [
    base:desc "Architecture Description Language model (e.g., ACME, AADL, MontiArc) defining components, interfaces and connectors."
    DTDFVocab:inputTo VersionControlRepositoryEnabler
]

instance StateMachineBehaviourModel : DTDFVocab:Model [
    base:desc "State‑machine specification (SysML v1.7 or MontiArc Automaton) describing behavioural aspects."
    DTDFVocab:inputTo VersionControlRepositoryEnabler, SimulationEngineEnabler
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink simulation model linked to behavioural specifications."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance ExecutableCodeModelCpp : DTDFVocab:Model [
    base:desc "Generated C++ executable code derived from MBSE models."
    DTDFVocab:inputTo CodeGenerationEnabler
]

instance ExecutableCodeModelJava : DTDFVocab:Model [
    base:desc "Generated Java executable code derived from MBSE models."
    DTDFVocab:inputTo CodeGenerationEnabler
]

// ----------------------------------------------------
// Enablers (tooling, repositories, execution platforms)
// ----------------------------------------------------
instance VersionControlRepositoryEnabler : DTDFVocab:Enabler [
    base:desc "Version‑controlled repository storing MBSE models and generated code (C++/Java)."
    DTDFVocab:enables SimulationValidationService, UnitTestingService, DTEvolutionUpdateService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine (MATLAB/Simulink) executing behavioural and system models."
    DTDFVocab:enables SimulationValidationService, UnitTestingService
]

instance CodeGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Automated code‑generation toolchain producing C++ and Java artifacts from MBSE models."
    DTDFVocab:enables DTEvolutionUpdateService
]

// ----------------------------------------------------
// Services
// ----------------------------------------------------
instance SimulationValidationService : DTDFVocab:Service [
    base:desc "Runs integrated model simulations to validate behavior across abstraction levels."
    DTDFVocab:provides ConsistencyInsight
]

instance UnitTestingService : DTDFVocab:Service [
    base:desc "Executes unit tests on generated C++/Java code to ensure correctness."
    DTDFVocab:provides CorrectnessInsight
]

instance DTEvolutionUpdateService : DTDFVocab:Service [
    base:desc "Updates underlying MBSE models and re‑generates simulation or executable components for DT evolution."
    DTDFVocab:provides EvolutionAction
]

// ----------------------------------------------------
// Insights and Actions
// ----------------------------------------------------
instance ConsistencyInsight : DTDFVocab:Insight [
    base:desc "Ensures consistency across abstraction levels after model updates."
]

instance CorrectnessInsight : DTDFVocab:Insight [
    base:desc "Detects mismatches between generated code and model specifications."
]

instance EvolutionAction : DTDFVocab:Action [
    base:desc "Triggers re‑generation of simulation and executable components when MBSE models change."
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated through a Model‑Based Systems‑Engineering (MBSE) methodology. Structural and functional aspects are captured with SysML (including internal block diagrams) and component‑connector Architecture Description Languages such as ACME, AADL, or MontiArc. Behavioural detail can be added via state‑machine extensions (e.g., MontiArc Automaton) or external simulation environments like MATLAB/Simulink. This heterogeneous set of models is integrated across different tooling chains, enabling multiple stakeholder viewpoints and supporting the composition of the twin’s components, interfaces, and behaviours within a unified orchestration framework."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle is represented through MBSE modeling layers: a requirements stage where functional needs are captured; a functional architecture stage describing functions and interfaces; a logical architecture stage defining component‑connector structures using ADLs (e.g., ACME, AADL, MontiArc) and SysML Internal Block Diagrams; and a product/technical stage that links the logical model to concrete implementation artifacts such as Simulink models or C++/Java code. Transitions between stages are managed by traceability links defined in the SysML model, and governance is provided by the MBSE process that ensures each model artifact is reviewed at its respective stage."
]