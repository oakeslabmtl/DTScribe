// Sensing Components
instance SimulinkSimulationSensor : DTDFVocab:SensingComponent [
    base:desc "Simulink model provides simulation results output"
    DTDFVocab:producedData SimulinkOutput
]

instance RuntimeStreamSensor : DTDFVocab:SensingComponent [
    base:desc "Collects runtime execution streams from deployed models"
    DTDFVocab:producedData RuntimeStreamOutput
]

instance ExternalDataExchangeSensor : DTDFVocab:SensingComponent [
    base:desc "Receives stakeholder data exchanges from the MBSE repository"
    DTDFVocab:producedData ExternalDataExchangeOutput
]

// Data Transmitted
instance SimulinkOutput : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkSimulationSensor
]

instance RuntimeStreamOutput : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RuntimeStreamSensor
]

instance ExternalDataExchangeOutput : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalDataExchangeSensor
]

// Data
instance SimulationResultData : DTDFVocab:Data [
    base:desc "Simulation results generated by Simulink model"
    DTDFVocab:fromData SimulinkOutput
]

instance RuntimeStreamData : DTDFVocab:Data [
    base:desc "Runtime execution streams from deployed models"
    DTDFVocab:fromData RuntimeStreamOutput
]

instance ExternalDataExchangeData : DTDFVocab:Data [
    base:desc "External stakeholder data exchanged via the MBSE repository"
    DTDFVocab:fromData ExternalDataExchangeOutput
]

// Models
instance SysMLComponentDiagramModel : DTDFVocab:Model [
    base:desc "SysML component diagram capturing geometric structure and component hierarchies"
    DTDFVocab:inputTo SysMLTool
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc automaton modeling of functional and logical architectures"
    DTDFVocab:inputTo MontiArcTool
]

instance SimulinkStateMachineModel : DTDFVocab:Model [
    base:desc "Simulink state machine modeling control logic"
    DTDFVocab:inputTo SimulinkTool
]

instance CppCodeGenerationModel : DTDFVocab:Model [
    base:desc "C++ code generated from MBSE models"
    DTDFVocab:inputTo CppCodeGeneratorTool
]

instance JavaCodeGenerationModel : DTDFVocab:Model [
    base:desc "Java code generated from MBSE models"
    DTDFVocab:inputTo JavaCodeGeneratorTool
]

// Enablers
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML v1.7 modeling tool for requirements, functional, logical, and product-level modeling"
    DTDFVocab:enables ModelTransformationService
]

instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc tool for ADL-style connector modeling"
    DTDFVocab:enables ModelTransformationService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation and execution environment"
    DTDFVocab:enables ModelTransformationService, SimulationValidationService
]

instance CppCodeGeneratorTool : DTDFVocab:Enabler [
    base:desc "Code generator emitting C++ models"
    DTDFVocab:enables CodeEvolutionService
]

instance JavaCodeGeneratorTool : DTDFVocab:Enabler [
    base:desc "Code generator emitting Java models"
    DTDFVocab:enables CodeEvolutionService
]

// Services
instance ModelTransformationService : DTDFVocab:Service [
    base:desc "Manages model transformations across abstraction layers and ensures traceability"
    DTDFVocab:provides ModelValidationInsight
]

instance SimulationValidationService : DTDFVocab:Service [
    base:desc "Runs simulation validation of models against data streams"
    DTDFVocab:provides ModelValidationInsight
]

instance CodeEvolutionService : DTDFVocab:Service [
    base:desc "Tracks code evolution and synchronizes generated code across the lifecycle"
    DTDFVocab:provides GenerateExecutableAction
]

// Insights and Actions
instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful model validation against simulation data"
]

instance GenerateExecutableAction : DTDFVocab:Action [
    base:desc "Automatically generates executable code from C++ or Java models"
    DTDFVocab:IsAutomatic true
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Standardization in the described Digital Twin system is anchored in the adoption of the SysML modeling language (currently at its 1.7 release) and cross‑compatibility with other architecture description languages such as ACME, AADL, and MontiArc. While explicit certification or interoperability frameworks are not enumerated, the usage of these widely accepted engineering tools aligns with established industry guidelines for system modelling and architecture description."
]