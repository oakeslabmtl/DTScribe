instance PhysicalSystemDataSource : DTDFVocab:SensingComponent [
    base:desc "Data sources originate from the physical system via a one-way digital shadow data flow"
    DTDFVocab:producedData PhysicalSystemDataTransmitted
]

instance PhysicalSystemDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemDataSource
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Contextual data traces aggregated and abstracted for specific purposes"
    DTDFVocab:fromData PhysicalSystemDataTransmitted
    DTDFVocab:inputTo SysMLEnabler, SimulinkEnabler, CppEnabler, JavaEnabler
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "MBSE with SysML for structural modeling, including Interface Block Diagrams (IBDs)"
    DTDFVocab:inputTo SysMLEnabler
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language for component-based architectures with explicit interfaces and interconnections"
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL Architecture Description Language for component-based architectures with explicit interfaces and interconnections"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc Architecture Description Language for component-based architectures with explicit interfaces and interconnections"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavioral modeling"
    DTDFVocab:inputTo SysMLEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink for analytical simulations"
    DTDFVocab:inputTo SimulinkEnabler
]

instance CppJavaSimulationModel : DTDFVocab:Model [
    base:desc "General-purpose programming languages (C++, Java) for analytical simulations"
    DTDFVocab:inputTo CppEnabler, JavaEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for multi-level abstraction modeling (requirements, functional, logical, product/technical layers)"
    DTDFVocab:enables RealTimeInterpretationService, DecisionMakingService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component-based architectures with explicit interfaces and interconnections"
    DTDFVocab:enables RealTimeInterpretationService, DecisionMakingService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component-based architectures with explicit interfaces and interconnections"
    DTDFVocab:enables RealTimeInterpretationService, DecisionMakingService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component-based architectures with explicit interfaces and interconnections"
    DTDFVocab:enables RealTimeInterpretationService, DecisionMakingService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for analytical simulations"
    DTDFVocab:enables RealTimeInterpretationService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for analytical simulations"
    DTDFVocab:enables DecisionMakingService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for analytical simulations"
    DTDFVocab:enables DecisionMakingService
]

instance RFLPEnabler : DTDFVocab:Enabler [
    base:desc "RFLP methodology for Model-Based Systems Engineering"
    DTDFVocab:enables RealTimeInterpretationService, DecisionMakingService
]

instance OOSEMEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for Model-Based Systems Engineering"
    DTDFVocab:enables RealTimeInterpretationService, DecisionMakingService
]

instance SPESEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for Model-Based Systems Engineering"
    DTDFVocab:enables RealTimeInterpretationService, DecisionMakingService
]

instance SMArDTEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for Model-Based Systems Engineering"
    DTDFVocab:enables RealTimeInterpretationService, DecisionMakingService
]

instance RealTimeInterpretationService : DTDFVocab:Service [
    base:desc "Active processing of incoming data to enable real-time interpretation"
    DTDFVocab:provides RealTimeInterpretationInsight
]

instance DecisionMakingService : DTDFVocab:Service [
    base:desc "Decision-making based on processed data"
    DTDFVocab:provides DecisionMakingAction
]

instance RealTimeInterpretationInsight : DTDFVocab:Insight [
    base:desc "Real-time interpretation of system state"
]

instance DecisionMakingAction : DTDFVocab:Action [
    base:desc "Automated decisions based on analysis"
    DTDFVocab:IsAutomatic true
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with industry standards including SysML [17], ACME [23], AADL [24], MontiArc [25], [26], and SysML IBDs [17], [27] for system modeling, architecture description, and integration of heterogeneous stakeholders and perspectives."
]