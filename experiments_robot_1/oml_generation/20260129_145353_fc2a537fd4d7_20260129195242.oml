// C3: Physical sensing components (software data ingest component)
instance AssetDataIngestor : DTDFVocab:SensingComponent [
    base:desc "Software component that ingests the one‑way automated data flow from the physical asset (digital shadow), capturing contextual data traces."
    DTDFVocab:producedData AssetDataStream
]

// C4: Physical-to-virtual interaction (data transmission)
instance AssetDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AssetDataIngestor
]

// C10: Data
instance AssetContextData : DTDFVocab:Data [
    base:desc "Aggregated contextual data derived from the asset’s automated data flow, used to enrich structural and analytical models."
    DTDFVocab:fromData AssetDataStream
    DTDFVocab:inputTo MBSEToolchain
]

// C10: Models
instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram capturing component, interface, and connector structures of the twin."
    DTDFVocab:inputTo MBSEToolchain
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL model describing software components, threads, and connections for the twin."
    DTDFVocab:inputTo MBSEToolchain
]

instance MontiArcAutomatonBehaviorModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton state‑machine model encoding behavioral semantics of components."
    DTDFVocab:inputTo MBSEToolchain
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model used for dynamic simulation of the twin's physical behavior."
    DTDFVocab:inputTo SimulinkEngine
]

// C11: Enablers
instance MBSEToolchain : DTDFVocab:Enabler [
    base:desc "Model‑Based Systems‑Engineering toolchain integrating SysML and ADLs (ACME, AADL, MontiArc) and supporting RFLP, OOSEM, SPES, SMArDT methodologies."
    DTDFVocab:enables ModelIntegrationService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine executing Simulink models and exposing results to the twin."
    DTDFVocab:enables SimulationExecutionService
]

// C6: Services
instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Service that consolidates structural and behavioral models into a coherent digital twin representation."
    DTDFVocab:provides ModelConsistencyInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service that runs simulations (e.g., Simulink) and delivers actionable outcomes."
    DTDFVocab:provides SimulationResultAction
]

// C17: Insights/Actions
instance ModelConsistencyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that integrated models satisfy consistency checks defined by RFLP and SMArDT."
]

instance SimulationResultAction : DTDFVocab:Action [
    base:desc "Automatic action that triggers downstream decision support based on simulation results."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated through a Model‑Based Systems‑Engineering (MBSE) approach. System architecture is captured with SysML (including internal block diagrams) and component‑connector architecture description languages (ADLs) such as ACME, AADL and MontiArc. These models define components, their interfaces, interconnections and hierarchical composition across abstraction layers (requirements, functional, logical, physical). Behavioral aspects are linked to simulation tools (e.g., MATLAB/Simulink) or implementation code in C++/Java. Coordination among heterogeneous models and stakeholders is achieved by integrating these artifacts, providing a system‑wide orchestration and resource‑management framework."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the Model‑Based Systems Engineering (MBSE) abstraction ladder described in the document: (1) requirements stage, (2) functional architecture stage, (3) logical architecture stage, and (4) product/technical stage. At each stage the representation shifts from high‑level requirement specifications to functional block diagrams, then to component‑connector models (e.g., SysML IBDs, ACME, AADL) and finally to executable artifacts such as Simulink models or source code. Transitions are managed by mapping artifacts across the layers, enabling traceability from requirements to implementation."
]