// C2: Acting Components
instance ServoDriveController : DTDFVocab:ActingComponent [
    base:desc "Closed-loop control system for trajectory planning and execution in the MABI MAX 100 robot arm, interfacing with high-precision motors and gearbox mechanisms for dynamic load handling."
]

// C3: Physical Sensing Components
instance CycloidalGearboxPositionEncoderLeft : DTDFVocab:SensingComponent [
    base:desc "High-precision absolute position encoder mounted at the output shaft of the left cycloidal gear transmission, providing 0.06 mm path repeatability and 0.1 mm positional accuracy via MQTT over real-time Ethernet."
    DTDFVocab:producedData CycloidalGearboxPositionDataLeft
]

instance CycloidalGearboxPositionEncoderRight : DTDFVocab:SensingComponent [
    base:desc "High-precision absolute position encoder mounted at the output shaft of the right cycloidal gear transmission, providing 0.06 mm path repeatability and 0.1 mm positional accuracy via MQTT over real-time Ethernet."
    DTDFVocab:producedData CycloidalGearboxPositionDataRight
]

instance JointTorqueSensorAxis1 : DTDFVocab:SensingComponent [
    base:desc "Embedded torque sensor at the first axis joint measuring dynamic load variations for predictive maintenance analysis, synchronized with servo drive update rates via MQTT."
    DTDFVocab:producedData JointTorqueDataAxis1
]

instance JointTorqueSensorAxis2 : DTDFVocab:SensingComponent [
    base:desc "Embedded torque sensor at the second axis joint measuring dynamic load variations for predictive maintenance analysis, synchronized with servo drive update rates via MQTT."
    DTDFVocab:producedData JointTorqueDataAxis2
]

// C4: Physical-to-Virtual Interaction
instance CycloidalGearboxPositionDataLeft : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CycloidalGearboxPositionEncoderLeft
]

instance CycloidalGearboxPositionDataRight : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CycloidalGearboxPositionEncoderRight
]

instance JointTorqueDataAxis1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointTorqueSensorAxis1
]

instance JointTorqueDataAxis2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointTorqueSensorAxis2
]

// C10: Models/Data
instance SysMLInternalBlockDiagram : DTDFVocab:Model [
    base:desc "Component-connector architecture model of the MABI MAX 100 robot arm using SysML IBDs to represent hierarchical decomposition of physical components (motors, gearboxes, joints) and their interfaces."
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "Behavioral automaton model for operational modes and failure states of the robot arm using MontiArc, integrated with simulation tools for real-time validation."
    DTDFVocab:inputTo MontiArcEnabler
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "High-fidelity dynamic simulation model of the robot arm's kinematic and friction behavior implemented in MathWorks Simulink for predictive analysis."
    DTDFVocab:inputTo SimulinkEnabler
]

instance GearboxFrictionCharacteristicsData : DTDFVocab:Data [
    base:desc "Aggregated time-series data representing nonlinear friction characteristics (stiction, Coulomb, viscous) extracted from sensor telemetry for data-driven calibration."
    DTDFVocab:fromData CycloidalGearboxPositionDataLeft, CycloidalGearboxPositionDataRight, JointTorqueDataAxis1, JointTorqueDataAxis2
    DTDFVocab:inputTo DataProcessingEnabler
]

instance OperationalStateTraces : DTDFVocab:Data [
    base:desc "Contextual data traces capturing real-time operational conditions (position, torque, load) for state tracking and anomaly detection."
    DTDFVocab:fromData CycloidalGearboxPositionDataLeft, CycloidalGearboxPositionDataRight, JointTorqueDataAxis1, JointTorqueDataAxis2
    DTDFVocab:inputTo DataProcessingEnabler
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling framework enabling component-connector architecture modeling and state machine definitions for behavioral specification."
    DTDFVocab:enables SysMLVisualizationService, SysMLArchitectureAnalysisService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc platform supporting component-based architecture and automaton models for system behavior specification and simulation."
    DTDFVocab:enables MontiArcBehavioralAnalysisService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for dynamic system simulation, behavioral validation, and predictive modeling of friction and kinematic responses."
    DTDFVocab:enables SimulinkPredictiveAnalysisService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Custom C++/Java pipeline for automated aggregation, abstraction, and preprocessing of sensor data into structured digital shadow traces."
    DTDFVocab:enables DataAggregationService, StateTrackingService
]

instance MQTTDataTransmissionEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol implementation for real-time Ethernet-based transmission of sensor data from physical components to digital twin with low-latency requirements."
    DTDFVocab:enables DataTransmissionService
]

// C6: Services
instance SysMLVisualizationService : DTDFVocab:Service [
    base:desc "Model-based visualization service presenting SysML architecture diagrams and state machines for system architecture and behavioral analysis."
    DTDFVocab:provides ArchitectureInsight, BehavioralInsight
]

instance SysMLArchitectureAnalysisService : DTDFVocab:Service [
    base:desc "Component-connector analysis service enabling hierarchical decomposition and interface validation of the robot arm's physical architecture."
    DTDFVocab:provides ComponentInteractionInsight
]

instance MontiArcBehavioralAnalysisService : DTDFVocab:Service [
    base:desc "Automaton-based behavioral analysis service simulating system responses under operational modes and failure scenarios."
    DTDFVocab:provides OperationalModeInsight
]

instance SimulinkPredictiveAnalysisService : DTDFVocab:Service [
    base:desc "Predictive modeling service using Simulink to simulate friction compensation and kinematic responses under dynamic load conditions."
    DTDFVocab:provides FrictionCompensationInsight, KinematicResponseInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Automated data aggregation service transforming raw sensor telemetry into structured digital shadow traces for specific analysis purposes."
    DTDFVocab:provides AggregatedDataInsight
]

instance StateTrackingService : DTDFVocab:Service [
    base:desc "Real-time state tracking service maintaining alignment between physical system operational conditions and digital twin replica states."
    DTDFVocab:provides SystemStateInsight
]

instance DataTransmissionService : DTDFVocab:Service [
    base:desc "MQTT-based real-time data transmission service ensuring low-latency streaming of sensor data from physical components to digital twin."
    DTDFVocab:provides TransmissionQualityInsight
]

// C17: Insights/Actions
instance ArchitectureInsight : DTDFVocab:Insight [
    base:desc "Visual and analytical insight into the hierarchical component-connector architecture of the MABI MAX 100 robot arm derived from SysML IBDs."
]

instance BehavioralInsight : DTDFVocab:Insight [
    base:desc "Behavioral analysis insight showing system responses to operational modes and failure states through SysML state machines."
]

instance ComponentInteractionInsight : DTDFVocab:Insight [
    base:desc "Analysis of component interactions and interface validations within the robot arm's physical architecture."
]

instance OperationalModeInsight : DTDFVocab:Insight [
    base:desc "Insight into system behavior under different operational modes and failure scenarios using MontiArc automaton models."
]

instance FrictionCompensationInsight : DTDFVocab:Insight [
    base:desc "Predictive insights into friction compensation strategies derived from Simulink dynamic simulations of gearbox behavior."
]

instance KinematicResponseInsight : DTDFVocab:Insight [
    base:desc "Analysis of kinematic responses under dynamic load conditions using Simulink-based predictive modeling."
]

instance AggregatedDataInsight : DTDFVocab:Insight [
    base:desc "Structured insights derived from aggregated digital shadow traces representing system operational conditions."
]

instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Real-time insight into the current state of the physical system as represented in the digital twin replica."
]

instance TransmissionQualityInsight : DTDFVocab:Insight [
    base:desc "Monitoring insight into the quality and latency of MQTT-based data transmission from physical sensors to digital twin."
]

// C1: Environment
instance IndustrialManufacturingEnvironment : DTDFVocab:Environment [
    base:desc "Industrial automation environment for precision motion control and gearbox friction analysis, characterized by high update rates and real-time control requirements."
    base:contains MABIMax100RobotArm
]

instance MABIMax100RobotArm : DTDFVocab:Component [
    base:desc "6-axis articulated robot arm with high-precision motors, cycloidal gearboxes, and embedded sensors for dynamic load handling in industrial automation tasks."
    base:isContainedIn IndustrialManufacturingEnvironment
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system’s temporal aspects are governed by the need for synchronized bidirectional data flows between physical and digital components, though explicit synchronization frequencies or latency requirements are not detailed in the provided documents. However, the context implies that **Model-Based Systems Engineering (MBSE)** methodologies (e.g., SysML, AADL, or MontiArc) are used to model system behavior at varying abstraction levels (requirements, functional, logical, and physical layers), which inherently require temporal alignment for simulation and validation. For behavior modeling, tools like **MathWorks Simulink** or other simulation methods (e.g., [29], [30]) are integrated to ensure temporal granularity in digital representations. The Digital Shadow reference model (Fig. 1) emphasizes **one-way data aggregation** with no explicit time-scale constraints, but a Digital Twin (DT) would extend this to include **active feedback loops**, necessitating real-time or near-real-time synchronization for closed-loop control or predictive analytics. Latency requirements would depend on the specific use case (e.g., manufacturing, IoT, or industrial automation) but are not quantified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a **Model-Based Systems Engineering (MBSE)** framework, integrating **heterogeneous modeling tools** (e.g., SysML for architecture, Simulink for behavior) and **general-purpose languages** (C++, Java) for implementation. Orchestration relies on **active Digital Twin components** that process aggregated data traces (unlike passive digital shadows) to enable **real-time interactions** with physical systems. The system architecture emphasizes **component integration** via ADLs (e.g., MontiArc Automaton, SysML state machines) and **closed-loop control mechanisms** (implied by active data processing). Resource management and system-wide coordination are not explicitly detailed, but the need for **interoperability between modeling notations** suggests a **modular, service-oriented** approach to system-wide coordination."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "
The lifecycle of a Digital Twin (DT) system is structured through **Model-Based Systems Engineering (MBSE)** methodologies, encompassing distinct abstraction layers: **requirements, functional architecture, logical architecture, and product/technical layers**. The lifecycle transitions between these stages are governed by methodologies such as **RFLP (Requirements, Functions, Logics, Physics)**, **OOSEM**, **SPES**, or **SMArDT**, which ensure systematic progression from conceptual design to implementation. **Architecture Description Languages (ADLs)** like **ACME, AADL, MontiArc**, and **SysML Internal Block Diagrams (IBDs)** are employed to formalize component-connector perspectives, including interfaces, interconnections, and composition, while **SysML state machines** or **MontiArc Automaton** define behavioral dynamics. Transition management between stages involves **heterogeneous tool integration** (e.g., **MathWorks Simulink**, simulation tools, or general-purpose languages like **C++/Java**) to maintain consistency across modeling notations. Lifecycle governance adheres to **stakeholder-integrated perspectives**, ensuring alignment between technical models and operational requirements, with explicit attention to **abstraction granularity** and **interoperability** across tools and layers.
"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
Fidelity in the Digital Twin system is ensured through **deviation analysis** between simulated data (e.g., friction models in Simulink) and measured sensor data (e.g., encoder readings). Validation is implicitly supported by **traceability mechanisms** linking MBSE layers (e.g., SysML IBDs to simulation outputs), enabling meaningful comparisons. Uncertainty quantification is inferred from discrepancies between modeled and observed behaviors, though explicit error detection/correction mechanisms or quality assurance processes (e.g., statistical validation, uncertainty propagation) are not detailed. The system’s passive nature (one-way data flow) restricts active fidelity adjustments, relying instead on **post-hoc analysis** of aggregated sensor traces for contextual validation.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The document explicitly mentions **MQTT** as the communication protocol for streaming time-series sensor data between physical systems and their digital representations. No other protocols (e.g., OPC UA, RESTful APIs), network topologies, redundancy mechanisms, or security protocols (e.g., TLS, IPSec) are referenced. The system’s network infrastructure is not detailed beyond the one-way data flow described for digital shadows, which lacks bidirectional control or command execution mechanisms. Performance metrics (e.g., latency, bandwidth) are not provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The document does not specify hosting platforms (cloud/edge/on-premise), computational/storage requirements, scalability mechanisms, or deployment models. It only mentions a **dashboard** for visualization and **live-data linking** to the digital representation, without detailing the underlying infrastructure (e.g., servers, orchestration tools, or hardware). No references to Kubernetes, Docker, or hardware specifications (e.g., FPGAs, GPUs) are made."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system implements **horizontal integration** through **Asset Administration Shells (AAS)** for standardized data exchange and **MQTT** for live-data streaming between physical sensors and digital representations. While the document does not enumerate external system dependencies or enterprise integration patterns, the use of **AAS** (a key interoperability standard) and **MQTT** (a lightweight protocol for IoT/data streaming) indicates compliance with **industrial data exchange protocols**. No explicit mention of integration with other Digital Twins or enterprise systems (e.g., ERP/MES) is provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE) standards** through the use of **SysML, AADL, MontiArc, and ACME** for architecture modeling. While specific **interoperability standards** (e.g., ISO 24744, XMI) or **certification frameworks** are not mentioned, the system relies on **architecture description languages (ADLs)** and **SysML-based methodologies** for structured modeling. No explicit mention of ontology-driven semantics, formal compliance frameworks, or standardized exchange formats (e.g., Simulink Model Exchange) is provided."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "
The Digital Twin system incorporates **physical safety mechanisms** through the robotic arm's **safety cell**, which restricts the maximum working range to **[-90°, 90°]** to prevent collisions or operator exposure. **Sensor data traces** (e.g., friction modeling inputs) are transmitted via **MQTT protocol** (as referenced in [52]), though explicit cybersecurity protocols (e.g., TLS encryption, authentication) are not documented. The **Asset Administration Shell (AAS)** framework ([46], [47], [50]) provides a structured metadata model for asset management but does not explicitly detail **cybersecurity hardening** or **threat mitigation strategies** (e.g., isolation of critical submodels). **Fail-safe mechanisms** are implied by the safety cell’s physical constraints but are not described in terms of **safety-critical standards** (e.g., IEC 61511). No references to **risk assessment frameworks**, **access control systems**, or **data anonymization techniques** are present in the provided documents."
]