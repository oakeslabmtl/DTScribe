// Acting components: six permanent‑magnet synchronous motors
instance MotorAxis1 : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor on axis 1, driven by a Siemens SINUMERIK 840D SL controller."
]
instance MotorAxis2 : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor on axis 2, driven by a Siemens SINUMERIK 840D SL controller."
]
instance MotorAxis3 : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor on axis 3, driven by a Siemens SINUMERIK 840D SL controller."
]
instance MotorAxis4 : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor on axis 4, driven by a Siemens SINUMERIK 840D SL controller."
]
instance MotorAxis5 : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor on axis 5, driven by a Siemens SINUMERIK 840D SL controller."
]
instance MotorAxis6 : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor on axis 6, driven by a Siemens SINUMERIK 840D SL controller."
]

// Physical sensing components: absolute position encoders
instance EncoderAxis1 : DTDFVocab:SensingComponent [
    base:desc "Absolute position encoder mounted on the shaft of MotorAxis1, sampling at ~200 Hz."
    DTDFVocab:producedData JointPositionTopicAxis1
]
instance EncoderAxis2 : DTDFVocab:SensingComponent [
    base:desc "Absolute position encoder mounted on the shaft of MotorAxis2, sampling at ~200 Hz."
    DTDFVocab:producedData JointPositionTopicAxis2
]
instance EncoderAxis3 : DTDFVocab:SensingComponent [
    base:desc "Absolute position encoder mounted on the shaft of MotorAxis3, sampling at ~200 Hz."
    DTDFVocab:producedData JointPositionTopicAxis3
]
instance EncoderAxis4 : DTDFVocab:SensingComponent [
    base:desc "Absolute position encoder mounted on the shaft of MotorAxis4, sampling at ~200 Hz."
    DTDFVocab:producedData JointPositionTopicAxis4
]
instance EncoderAxis5 : DTDFVocab:SensingComponent [
    base:desc "Absolute position encoder mounted on the shaft of MotorAxis5, sampling at ~200 Hz."
    DTDFVocab:producedData JointPositionTopicAxis5
]
instance EncoderAxis6 : DTDFVocab:SensingComponent [
    base:desc "Absolute position encoder mounted on the shaft of MotorAxis6, sampling at ~200 Hz."
    DTDFVocab:producedData JointPositionTopicAxis6
]

// Physical‑to‑virtual interaction: MQTT topics for joint positions
instance JointPositionTopicAxis1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderAxis1
]
instance JointPositionTopicAxis2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderAxis2
]
instance JointPositionTopicAxis3 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderAxis3
]
instance JointPositionTopicAxis4 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderAxis4
]
instance JointPositionTopicAxis5 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderAxis5
]
instance JointPositionTopicAxis6 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderAxis6
]

// Data aggregated by the digital twin for state estimation
instance JointPositionDataAxis1 : DTDFVocab:Data [
    base:desc "Aggregated joint position data for MotorAxis1 used by the twin for state estimation."
    DTDFVocab:fromData JointPositionTopicAxis1
    DTDFVocab:inputTo AssetAdministrationShell
]
instance JointPositionDataAxis2 : DTDFVocab:Data [
    base:desc "Aggregated joint position data for MotorAxis2 used by the twin for state estimation."
    DTDFVocab:fromData JointPositionTopicAxis2
    DTDFVocab:inputTo AssetAdministrationShell
]
instance JointPositionDataAxis3 : DTDFVocab:Data [
    base:desc "Aggregated joint position data for MotorAxis3 used by the twin for state estimation."
    DTDFVocab:fromData JointPositionTopicAxis3
    DTDFVocab:inputTo AssetAdministrationShell
]
instance JointPositionDataAxis4 : DTDFVocab:Data [
    base:desc "Aggregated joint position data for MotorAxis4 used by the twin for state estimation."
    DTDFVocab:fromData JointPositionTopicAxis4
    DTDFVocab:inputTo AssetAdministrationShell
]
instance JointPositionDataAxis5 : DTDFVocab:Data [
    base:desc "Aggregated joint position data for MotorAxis5 used by the twin for state estimation."
    DTDFVocab:fromData JointPositionTopicAxis5
    DTDFVocab:inputTo AssetAdministrationShell
]
instance JointPositionDataAxis6 : DTDFVocab:Data [
    base:desc "Aggregated joint position data for MotorAxis6 used by the twin for state estimation."
    DTDFVocab:fromData JointPositionTopicAxis6
    DTDFVocab:inputTo AssetAdministrationShell
]

// Enablers
instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell acting as the twin's data hub, conforming to ISA‑95/IEC 62443."
    DTDFVocab:enables LiveUpdateService, MonitoringService, ControlLoopService
]
instance MqttBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating real‑time data exchange via publish/subscribe between sensors, the twin, and control systems."
]
instance SimulinkExecutionEngine : DTDFVocab:Enabler [
    base:desc "Execution engine compiling Simulink models into in‑the‑loop (MiL) code for real‑time simulation."
]

// Services
instance LiveUpdateService : DTDFVocab:Service [
    base:desc "Service providing live updates of the twin state to monitoring tools."
    DTDFVocab:provides StateEstimationInsight
]
instance MonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring joint positions and system health for anomaly detection."
    DTDFVocab:provides StateEstimationInsight
]
instance ControlLoopService : DTDFVocab:Service [
    base:desc "Service feeding control‑loop commands back to the physical system via MQTT."
    DTDFVocab:provides PublishControlCommandAction
]

// Insights and Actions
instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from aggregated joint position data used for state estimation and monitoring."
]
instance PublishControlCommandAction : DTDFVocab:Action [
    base:desc "Action publishing control‑loop commands to the Siemens controller via MQTT topics."
    DTDFVocab:IsAutomatic true
]

// Models
instance FirstAxisMontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model defining the physical behaviour of the first axis, translated into Simulink for simulation."
    DTDFVocab:inputTo SimulinkExecutionEngine
]
instance FirstAxisSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of the first axis incorporating multi‑physics fidelity, compiled into MiL executable code."
    DTDFVocab:inputTo SimulinkExecutionEngine
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows the Digital Shadow Reference Model (DSRM) as defined by Kritzinger et al. It consists of three layers: the Asset layer representing the physical robot axis, the Model layer containing a SysML-based model and a UML class diagram (Fig. 1) that defines the conceptual relationships, and the Processing layer that performs contextual data aggregation and abstraction. The architecture is expressed through SysML IBDs and UML class diagrams, enabling integration of functional and logical descriptions in a single model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validity is ensured by continuous comparison between Simulink simulation outputs and the live encoder measurements collected on the twin. Any statistically significant divergence over successive samples is flagged for investigation, and the twin logs the discrepancy. Data integrity checks on the MQTT stream include packet sequence verification to detect loss or reordering. Periodic re‑initialization of the simulation state aligns the model with the measured system, mitigating drift over long runs."
]