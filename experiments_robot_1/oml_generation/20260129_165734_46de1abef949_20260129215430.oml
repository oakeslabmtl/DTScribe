instance PhysicalSystemMeasurementSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors capturing physical system measurements as per data sources in dt_models_and_data"
    DTDFVocab:producedData PhysicalSystemMeasurementsDataTransmitted
]

instance PhysicalSystemMeasurementsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemMeasurementSensor
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Contextual data traces aggregated from physical system measurements for specific purposes"
    DTDFVocab:fromData PhysicalSystemMeasurementsDataTransmitted
    DTDFVocab:inputTo SysMLEnabler, ACMEEnabler, AADLEnabler, MontiArcEnabler, SimulinkEnabler, CppEnabler, JavaEnabler, RFLPEnabler, OOSEMEnabler, SPESEnabler, SMArDTEnabler
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams for structural modeling in MBSE"
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLBehavioralModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavioral modeling (v1.7)"
    DTDFVocab:inputTo SysMLEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SimulinkAnalyticalModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink analytical models for simulation"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for system modeling in MBSE methodologies"
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component-based architecture descriptions"
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component-based architecture descriptions"
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc for component-based architecture descriptions and behavioral modeling"
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and analytical modeling"
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ for detailed behavior specification"
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java for detailed behavior specification"
]

instance RFLPEnabler : DTDFVocab:Enabler [
    base:desc "RFLP methodology for managing system complexity across abstraction levels"
]

instance OOSEMEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for managing system complexity across abstraction levels"
]

instance SPESEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for managing system complexity across abstraction levels"
]

instance SMArDTEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for managing system complexity across abstraction levels"
]