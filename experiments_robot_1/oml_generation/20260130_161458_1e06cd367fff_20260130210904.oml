// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring input current I_M of the first axis motor"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorPositionEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder providing motor angle r_M"
    DTDFVocab:producedData MotorPositionEncoderDataTransmitted
]

instance GearboxSecondaryEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the gearbox providing gearbox angle r_G and output angle r_out"
    DTDFVocab:producedData GearboxSecondaryEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorPositionEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoderSensor
]

instance GearboxSecondaryEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxSecondaryEncoderSensor
]

// C10: Data
instance CurrentTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of input current I_M streamed from MotorCurrentSensor"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkExecutionEnabler
]

instance TorqueTimeSeriesData : DTDFVocab:Data [
    base:desc "Derived torque τ time‑series calculated from current and motor angle"
    DTDFVocab:fromData MotorCurrentDataTransmitted, MotorPositionEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkExecutionEnabler
]

instance AngularVelocityTimeSeriesData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω time‑series calculated from encoder signals"
    DTDFVocab:fromData MotorPositionEncoderDataTransmitted, GearboxSecondaryEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkExecutionEnabler
]

instance FrictionEstimatesData : DTDFVocab:Data [
    base:desc "Real‑time friction estimates (static, kinetic, viscous coefficients) produced by identification models"
    DTDFVocab:fromData MotorCurrentDataTransmitted, MotorPositionEncoderDataTransmitted, GearboxSecondaryEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkExecutionEnabler, DashboardVisualizationEnabler
]

// C10: Models
instance SysMLMotorGearboxBlockModel : DTDFVocab:Model [
    base:desc "SysML Block Definition Diagram describing motor, gearbox and cycloidal transmission"
    DTDFVocab:inputTo SysMLModelRepositoryEnabler
]

instance SysMLMotorGearboxIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram detailing connections of motor, gearboxes and sensors"
    DTDFVocab:inputTo SysMLModelRepositoryEnabler
]

instance SimulinkFrictionlessModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of frictionless behavior for the first axis"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance SimulinkCoulombViscousModel : DTDFVocab:Model [
    base:desc "Simulink white‑box model implementing Coulomb‑Viscous friction"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance SimulinkStribeckModel : DTDFVocab:Model [
    base:desc "Simulink black‑box model implementing Stribeck friction characteristic"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance SimulinkDahlModel : DTDFVocab:Model [
    base:desc "Simulink model of Dahl friction for dynamic stick‑slip behavior"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance SimulinkLuGreModel : DTDFVocab:Model [
    base:desc "Simulink implementation of LuGre friction model"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance FrictionIdentificationModel : DTDFVocab:Model [
    base:desc "Data‑driven identification model that extracts static, kinetic and viscous friction coefficients from current, torque and velocity data"
    DTDFVocab:inputTo SimulinkExecutionEnabler, AssetAdministrationShellEnabler
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker used for live streaming of sensor data (current, angle) from the robot to the digital twin"
    DTDFVocab:enables RealTimeFrictionIdentificationService, DashboardVisualizationService
]

instance SimulinkExecutionEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink execution environment for running engineering and friction models"
    DTDFVocab:enables RealTimeFrictionIdentificationService, FrictionParameterUpdateService
]

instance SysMLModelRepositoryEnabler : DTDFVocab:Enabler [
    base:desc "Repository for storing and retrieving SysML engineering models"
    DTDFVocab:enables DashboardVisualizationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) providing model integration and communication with the robot control system"
    DTDFVocab:enables FrictionParameterUpdateService
]

instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Custom dashboard used for visualizing measured and simulated data and interacting with the digital twin"
    DTDFVocab:enables DashboardVisualizationService
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuously identifies static, kinetic and viscous friction coefficients from live data"
    DTDFVocab:provides FrictionCoefficientsInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Provides a visual dashboard for real‑time display of measured, simulated and identified friction data"
    DTDFVocab:provides VisualizedFrictionDataInsight
]

instance FrictionParameterUpdateService : DTDFVocab:Service [
    base:desc "Generates updated friction model parameters and pushes them to the robot control system to improve motion accuracy"
    DTDFVocab:provides UpdateRobotControlParametersAction
]

// C17: Insights/Actions
instance FrictionCoefficientsInsight : DTDFVocab:Insight [
    base:desc "Derived static, kinetic and viscous friction coefficients for the gearbox"
]

instance VisualizedFrictionDataInsight : DTDFVocab:Insight [
    base:desc "Visual representation of current measurements, simulated responses and identified friction estimates"
]

instance UpdateRobotControlParametersAction : DTDFVocab:Action [
    base:desc "Feeds updated friction coefficients back to the robot controller to reduce positioning errors"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital shadow operates in real‑time: sensor data are continuously streamed via MQTT at the robot controller’s sampling rate, and the shadow updates its DataTraces and performs friction identification instantly, enabling live monitoring and on‑the‑fly model refinement."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow constellation consists of a Purpose element (FrictionDerivation), an Asset element (the first axis of the MABI robot), Processing components (Simulation_M, Simulation_GW, Simulation_GB) that consume input data traces and produce simulated outputs, and various DataTrace and DataPoint instances (I_M, r_M, r_G, r_out, ˆr_M, ˆr_G, ˆr_out) linked to their Sources and Models."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow integrates engineering models created during the design phase (SysML structural model) with operational data collected during the runtime phase, thus covering both the design and operated life‑cycle stages of the robot."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The approach ensures traceability of every data point to its source and processing model, uses both white‑box analytical and black‑box data‑driven friction models, and validates model accuracy by comparing simulated friction‑free behavior with measured data, enabling multi‑physics‑aware identification of friction."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data are transmitted from the robot to the digital shadow over MQTT, establishing a one‑way automated data flow as defined for digital shadows. Asset Administration Shells are used to bind the physical asset metadata with the virtual models."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation references the Asset Administration Shell (AAS) standard for Industry 4.0 asset representation and follows SysML modelling conventions for engineering models."
]