// C3: Physical sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution position encoder mounted directly on the motor shaft providing real-time positional feedback for closed-loop control of the MABI MAX 100 robot's first axis."
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary high-resolution position encoder positioned behind the gearbox to provide additional positional feedback for improved actuation precision and dynamic response in the MABI MAX 100 robot's first axis."
    DTDFVocab:producedData GearboxPositionDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor current (I_M) for the MABI MAX 100 robot's first axis, providing input for torque calculation and friction analysis."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance SINUMERIK840DController : DTDFVocab:SensingComponent [
    base:desc "Siemens SINUMERIK 840D sl controller outputting time-series data for target and actual position values, velocity, acceleration, and motor current for the MABI MAX 100 robot's first axis."
    DTDFVocab:producedData ControllerDataTransmitted
]

// C4: Physical-to-virtual interaction
instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
    base:desc "Time-series positional data from the motor encoder transmitted via MQTT protocol for real-time synchronization with the digital twin model."
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
    base:desc "Time-series positional data from the gearbox encoder transmitted via MQTT protocol for real-time synchronization with the digital twin model."
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
    base:desc "Time-series motor current data transmitted via MQTT protocol for torque calculation and friction analysis in the digital twin."
]

instance ControllerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SINUMERIK840DController
    base:desc "Time-series data including target/actual position, velocity, acceleration, and motor current transmitted via MQTT protocol for comprehensive system monitoring."
]

// C10: Models/Data
instance JointFrictionModel : DTDFVocab:Model [
    base:desc "Multi-physics friction model integrating kinematic constraints and torque calculations to improve robot control accuracy in machining tasks."
    DTDFVocab:inputTo SysMLEnabler, MontiArcEnabler
]

instance KinematicConstraintModel : DTDFVocab:Model [
    base:desc "Behavioral model capturing kinematic constraints of the MABI MAX 100 robot's first axis for precise motion control."
    DTDFVocab:inputTo SysMLEnabler, SimulinkEnabler
]

instance CADGeometricModel : DTDFVocab:Model [
    base:desc "Geometric model representing the mechanical components (motor, gearbox, safety cell) of the MABI MAX 100 robot's first axis for spatial analysis."
    DTDFVocab:inputTo SysMLEnabler
]

instance RobotControlParametersData : DTDFVocab:Data [
    base:desc "Aggregated operational parameters including motor currents, gearbox torque, and derived metrics like angular velocity for real-time control monitoring."
    DTDFVocab:fromData MotorCurrentDataTransmitted, ControllerDataTransmitted
    DTDFVocab:inputTo SysMLEnabler, MontiArcEnabler
]

instance JointPositionData : DTDFVocab:Data [
    base:desc "Processed positional data from both motor and gearbox encoders representing the actual joint state of the MABI MAX 100 robot's first axis."
    DTDFVocab:fromData MotorPositionDataTransmitted, GearboxPositionDataTransmitted
    DTDFVocab:inputTo SysMLEnabler, SimulinkEnabler
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based modeling framework enabling multi-layered system representation across requirements, functional, logical, and product/technical architectures for the MABI MAX 100 robot."
    DTDFVocab:enables DataAggregationService, MultiPhysicsModelingService, LiveDataVisualizationService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language enabling component-connector-based system modeling with behavioral extensions for the MABI MAX 100 robot's control system."
    DTDFVocab:enables DataAggregationService, MultiPhysicsModelingService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation environment for detailed behavioral modeling of the MABI MAX 100 robot's kinematic constraints and control dynamics."
    DTDFVocab:enables MultiPhysicsModelingService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell framework providing standardized data structuring and interoperability for the MABI MAX 100 robot's digital twin within industrial IoT ecosystems."
    DTDFVocab:enables DataAggregationService
]

instance MQTTProtocolEnabler : DTDFVocab:Enabler [
    base:desc "MQTT publish-subscribe messaging protocol enabling low-latency, event-driven streaming of sensor data from the physical robot to the digital twin."
    DTDFVocab:enables DataAggregationService
]

// C6: Services
instance DataAggregationService : DTDFVocab:Service [
    base:desc "Automated one-way data flow service collecting and preprocessing contextual data traces from the physical MABI MAX 100 robot's sensors for digital representation."
    DTDFVocab:provides FrictionIdentificationInsight, ControlParameterInsight
]

instance MultiPhysicsModelingService : DTDFVocab:Service [
    base:desc "Service integrating friction models and kinematic constraints to improve robot control accuracy in machining tasks through multi-physics-aware analysis."
    DTDFVocab:provides FrictionCompensationInsight, KinematicAccuracyInsight
]

instance LiveDataVisualizationService : DTDFVocab:Service [
    base:desc "Real-time monitoring service providing visualization of joint friction dynamics and control performance metrics for engineers and maintenance teams."
    DTDFVocab:provides VisualFrictionAnalysisInsight
]

// C17: Insights/Actions
instance FrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Continuous, multi-physics-aware identification of joint friction states in the MABI MAX 100 robot's first axis through live-data linking."
]

instance ControlParameterInsight : DTDFVocab:Insight [
    base:desc "Real-time operational parameters including motor currents, gearbox torque, and derived metrics for control refinement."
]

instance FrictionCompensationInsight : DTDFVocab:Insight [
    base:desc "Improved control accuracy through integrated friction models and kinematic constraints for the MABI MAX 100 robot's machining tasks."
]

instance KinematicAccuracyInsight : DTDFVocab:Insight [
    base:desc "Enhanced kinematic precision through behavioral modeling of the robot's first axis constraints."
]

instance VisualFrictionAnalysisInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of joint friction dynamics and control performance metrics for engineering analysis."
]

// C1: Acting Components
instance MABIMax100Robot : DTDFVocab:ActingComponent [
    base:desc "Six-axis serial robot (MABI MAX 100) operating in manufacturing domain with precision requirements for multi-physics interactions and real-time monitoring."
]

instance FirstAxisActuator : DTDFVocab:ActingComponent [
    base:desc "First axis actuator of the MABI MAX 100 robot including motor, gearbox, and safety cell components critical for operational functionality."
]

// C10: Additional Models/Data
instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "Digital Shadow Reference Model defining foundational concepts for data aggregation and abstraction from physical objects to digital representations."
    DTDFVocab:inputTo AssetAdministrationShellEnabler
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces from sensor inputs representing the digital shadow of the MABI MAX 100 robot's operational state."
    DTDFVocab:fromData MotorPositionDataTransmitted, GearboxPositionDataTransmitted, MotorCurrentDataTransmitted, ControllerDataTransmitted
    DTDFVocab:inputTo AssetAdministrationShellEnabler, MQTTProtocolEnabler
]

// C11: Additional Enablers
instance RFLPMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements, Functions, Logics, Physics) methodology enabling multi-layered system complexity management for the MABI MAX 100 robot's digital twin."
    DTDFVocab:enables DataAggregationService, MultiPhysicsModelingService
]

instance OOSEMMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM (Object-Oriented Systems Engineering Method) framework supporting component-based system modeling for the MABI MAX 100 robot."
    DTDFVocab:enables DataAggregationService
]

// C17: Additional Actions
instance FrictionCompensationAction : DTDFVocab:Action [
    base:desc "Automated friction compensation in robot control based on real-time friction identification."
    DTDFVocab:IsAutomatic false
]

instance ControlRefinementAction : DTDFVocab:Action [
    base:desc "Engineering-focused control parameter adjustments based on live data visualization and analysis."
    DTDFVocab:IsAutomatic false
]

// C2: Environment
instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:desc "Industrial manufacturing environment where the MABI MAX 100 robot operates with precision requirements."
    base:contains MABIMax100Robot
]

instance RobotControlSystem : DTDFVocab:Environment [
    base:desc "Control system environment for the MABI MAX 100 robot including actuators, sensors, and controllers."
    base:contains FirstAxisActuator, MotorEncoder, GearboxEncoder, MotorCurrentSensor, SINUMERIK840DController
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system leverages **real-time, data-driven representations** of physical objects, relying on **live measurements** and **time-series data** streamed from sensors. While the document does not specify exact synchronization frequencies or latency requirements, the system is designed to handle **continuous data flows** between physical and digital components, implying a need for **low-latency processing** to maintain alignment between the twin and its physical counterpart. The temporal granularity is implicitly tied to the **sampling rate of sensor data**, which is critical for accurate behavioral modeling and decision-making in the twin's operational context. The integration of simulation tools (e.g., MathWorks Simulink) further suggests support for **time-synchronized simulations**, though explicit time-scale constraints (e.g., microseconds, milliseconds) are not detailed in the provided text."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system’s orchestration and coordination are influenced by Model-Based Systems Engineering (MBSE) methodologies and architecture description languages (ADLs). The system may adopt component-based architectures (e.g., component & connector perspectives in ACME, AADL, or SysML IBDs) to define interactions, interfaces, and composition of digital twin components. Behavioral descriptions can be integrated using tools like MontiArc Automaton or SysML state machines, while detailed behavior modeling may leverage simulation tools (e.g., MathWorks Simulink) or general-purpose programming languages (e.g., C++, Java). The document emphasizes the need to integrate heterogeneous stakeholders and perspectives, suggesting a system-wide coordination mechanism that bridges multiple modeling notations and tools. However, no specific architecture patterns (e.g., microservices, service-oriented) or resource management strategies are explicitly detailed in the provided context."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system enforces **fidelity requirements** through **MBSE-driven validation and verification (V&V) processes**, where model accuracy is assessed via **deviation analysis between simulated data and measured data traces** collected from the physical system. **Uncertainty quantification** is implicitly addressed through **traceability links** across abstraction layers (e.g., from functional architecture to product/technical implementations), ensuring consistency in behavioral and structural representations. While the document does not specify explicit **error correction mechanisms** (e.g., PID tuning or adaptive control), the **Digital Shadow Reference Model** provides a foundation for **contextual data aggregation**, which inherently supports **quality assurance** by validating the alignment between digital and physical states. The system’s reliance on **heterogeneous modeling tools** (e.g., SysML, Simulink) implies **cross-validation protocols** to reconcile discrepancies between model types (e.g., geometric vs. behavioral)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Shadow system relies on **MQTT** as the sole communication protocol for streaming sensor data from the physical robot to the digital representation. No details are provided regarding **network topology, architecture, bandwidth/latency requirements, reliability mechanisms (e.g., redundancy, failover), or security protocols (e.g., encryption, authentication)**. The document does not specify whether the connection is direct or routed through intermediaries, nor does it describe **network segmentation, QoS policies, or protocol extensions** (e.g., MQTT-SN, CoAP)."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system supports **horizontal integration** through **data exchange protocols** such as **MQTT**, as explicitly stated for streaming **sensor time-series data** to the digital shadow/twin. Interoperability is achieved via **heterogeneous modeling tools and notations** (e.g., SysML, Simulink, C++/Java), necessitating **standardized interfaces** to bridge disparate systems. The document distinguishes between **passive digital shadows** (one-way data flow) and **active Digital Twins** (bidirectional interaction), implying dependencies on **external enterprise systems** or **other Digital Twins** for broader operational context. While no specific enterprise integration patterns (e.g., REST APIs, OPC UA) are detailed beyond MQTT, the system’s design inherently requires **protocol-agnostic adaptors** to ensure seamless data flow across tools and stakeholders."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Asset Administration Shells (AAS)** as a key specification for interoperability and data exchange. Modeling standards include **SysML** (for system architecture and behavior) and **UML** (for class diagrams, e.g., Fig. 1). Communication protocols such as **MQTT** are referenced for data transmission between physical and digital entities. Compliance frameworks are not explicitly detailed, but the use of standardized modeling languages (SysML, UML) and protocols (MQTT) ensures alignment with industry best practices for modularity, reusability, and interoperability in manufacturing and systems engineering contexts."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system incorporates **safety-critical constraints** through the **safety cell of the robot**, which physically restricts the maximum working range to prevent collisions or unauthorized access to hazardous areas. Data exchange between the Digital Twin and physical assets is facilitated via **MQTT (Message Queuing Telemetry Transport)**, a lightweight publish-subscribe protocol (as referenced in [52]), ensuring real-time streaming of operational data. However, the provided documents do not specify explicit **cybersecurity protocols** (e.g., OAuth 2.0, JWT, TLS/SSL), **access control mechanisms**, or **formal risk assessment methodologies** (e.g., IEC 62443, ISO 27001). The focus is primarily on **functional modeling** (e.g., friction compensation in robot dynamics [45]) and **interoperability** via standards like **Asset Administration Shell (AAS)** ([46], [47], [50]) and **RAMI4.0** ([48], [49]), which define asset metadata and lifecycle management but do not address security governance or privacy compliance."
]