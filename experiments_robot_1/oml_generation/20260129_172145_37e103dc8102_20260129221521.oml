namespace DTDFVocab
instance ModelingInsight : DTDFVocab:Insight [
    base:desc "Insight from system modeling across abstraction levels"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from analytical simulations"
]

instance DataInsight : DTDFVocab:Insight [
    base:desc "Insight from integrated heterogeneous models"
]

instance ModelingService : DTDFVocab:Service [
    base:desc "Modeling service for system architecture and behavior",
    DTDFVocab:provides ModelingInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service for analytical simulations",
    DTDFVocab:provides SimulationInsight
]

instance DataManagementService : DTDFVocab:Service [
    base:desc "Data management service for integrating heterogeneous models",
    DTDFVocab:provides DataInsight
]

instance SysML_MBSE : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology using SysML for system modeling across abstraction levels",
    DTDFVocab:enables ModelingService, DataManagementService
]

instance RFLP_Methodology : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements, Functions, Logics, Physics) methodology for complexity management",
    DTDFVocab:enables DataManagementService
]

instance OOSEM_Methodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for complexity management",
    DTDFVocab:enables DataManagementService
]

instance SPES_Methodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for complexity management",
    DTDFVocab:enables DataManagementService
]

instance SMArDT_Methodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for complexity management",
    DTDFVocab:enables DataManagementService
]

instance ACME_ADL : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component interfaces and composition",
    DTDFVocab:enables ModelingService
]

instance AADL_ADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component interfaces and composition",
    DTDFVocab:enables ModelingService
]

instance MontiArc_ADL : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component interfaces and composition",
    DTDFVocab:enables ModelingService
]

instance MontiArc_Automaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavior description",
    DTDFVocab:enables ModelingService
]

instance SysML_StateMachines_Tool : DTDFVocab:Enabler [
    base:desc "SysML v1.7 state machines for behavior description",
    DTDFVocab:enables ModelingService
]

instance Simulink_Simulation : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation",
    DTDFVocab:enables SimulationService
]

instance Cpp_Programming : DTDFVocab:Enabler [
    base:desc "C++ general-purpose programming language",
    DTDFVocab:enables SimulationService
]

instance Java_Programming : DTDFVocab:Enabler [
    base:desc "Java general-purpose programming language",
    DTDFVocab:enables SimulationService
]

instance PhysicalObjectStatesSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for physical object states in digital shadow data flows",
    DTDFVocab:producedData PhysicalObjectStates_Transmitted
]

instance ContextualDataSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for contextual data traces aggregated and abstracted",
    DTDFVocab:producedData ContextualDataTraces_Transmitted
]

instance PhysicalObjectStates_Transmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalObjectStatesSensor
]

instance ContextualDataTraces_Transmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContextualDataSensor
]

instance PhysicalObjectStates_Data : DTDFVocab:Data [
    base:desc "Physical object states transmitted through one-way digital shadow data flows",
    DTDFVocab:fromData PhysicalObjectStates_Transmitted,
    DTDFVocab:inputTo SysML_MBSE, RFLP_Methodology, OOSEM_Methodology, SPES_Methodology, SMArDT_Methodology, ACME_ADL, AADL_ADL, MontiArc_ADL
]

instance ContextualDataTraces_Data : DTDFVocab:Data [
    base:desc "Contextual data traces aggregated and abstracted for specific purposes",
    DTDFVocab:fromData ContextualDataTraces_Transmitted,
    DTDFVocab:inputTo SysML_MBSE, RFLP_Methodology, OOSEM_Methodology, SPES_Methodology, SMArDT_Methodology, ACME_ADL, AADL_ADL, MontiArc_ADL
]

instance SysML_IBD_Geometric : DTDFVocab:Model [
    base:desc "Geometric representations using SysML IBDs",
    DTDFVocab:inputTo SysML_MBSE, ACME_ADL, AADL_ADL, MontiArc_ADL
]

instance MontiArc_Behavioral : DTDFVocab:Model [
    base:desc "Behavioral models using MontiArc Automaton",
    DTDFVocab:inputTo MontiArc_ADL, MontiArc_Automaton
]

instance SysML_StateMachines_Model : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines for behavior description",
    DTDFVocab:inputTo SysML_MBSE, SysML_StateMachines_Tool
]

instance Simulink_Analytical : DTDFVocab:Model [
    base:desc "Analytical simulations using MathWorks Simulink",
    DTDFVocab:inputTo Simulink_Simulation
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Industry standards such as SysML [17], ACME [23], AADL [24], and MontiArc [25,26] are utilized as architecture description languages (ADLs) for component and connector-based system modeling, while methodologies including RFLP [18,19], OOSEM [20], SPES [21], and SMArDT [22] are applied for managing complexity across abstraction levels (requirements, functional, logical, and product/technical layers) in Digital Twin development."
]