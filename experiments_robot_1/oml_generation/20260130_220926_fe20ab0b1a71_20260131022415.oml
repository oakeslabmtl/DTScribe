// Sensors
instance MotorShaftPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Quadrature position encoder located on the motor shaft, providing high-resolution angular position feedback."
    DTDFVocab:producedData CombinedEncoderDataMQTT
]

instance GearboxOutputPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Quadrature position encoder mounted on the gearbox output, delivering absolute position measurement."
    DTDFVocab:producedData CombinedEncoderDataMQTT
]

// Data transmitted via MQTT
instance CombinedEncoderDataMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftPositionEncoder, GearboxOutputPositionEncoder
]

// Data fed into Twin
instance CombinedPositionData : DTDFVocab:Data [
    base:desc "High-rate position data derived from both encoders, transported to the Digital Twin through the MQTT broker."
    DTDFVocab:fromData CombinedEncoderDataMQTT
    DTDFVocab:inputTo MqttBrokerEnabler, SimulinkBridgeEnabler, StructuralValidationEnabler
]

// Enablers
instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker that routes encoder position data into the Digital Twin for real-time monitoring."
    DTDFVocab:enables DataIngestionService
]

instance SimulinkBridgeEnabler : DTDFVocab:Enabler [
    base:desc "Bridge enabler that feeds position data into Simulink blocks for continuous physical simulation."
    DTDFVocab:enables SimulationExecutionService
]

instance StructuralValidationEnabler : DTDFVocab:Enabler [
    base:desc "Validation enabler that provides SysML structural model data to analytical verification tools."
    DTDFVocab:enables StructuralVerificationService
]

// Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service that ingests MQTT data streams and provisions them to the Twin’s analytics layer."
    DTDFVocab:provides MotorPositionInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service that executes Simulink-based simulation models driven by live sensor data."
    DTDFVocab:provides SimulationResultInsight
]

instance StructuralVerificationService : DTDFVocab:Service [
    base:desc "Service that verifies the SysML structural model against defined design constraints."
    DTDFVocab:provides StructuralModelInsight
]

// Insights
instance MotorPositionInsight : DTDFVocab:Insight [
    base:desc "Insight into real-time motor and gearbox position for performance monitoring."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight comparing simulated physical behavior with live sensor data for validation."
]

instance StructuralModelInsight : DTDFVocab:Insight [
    base:desc "Insight on the structural validity of the SysML topology relative to specified constraints."
]

// Models
instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Analytical Coulomb–viscous friction law parameterised from encoder measurements."
    DTDFVocab:inputTo SimulinkBridgeEnabler
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML structural representation of hardware components, interfaces, and interconnections."
    DTDFVocab:inputTo StructuralValidationEnabler
]

instance SimulinkContinuousModel : DTDFVocab:Model [
    base:desc "Simulink continuous-time model simulating the physical dynamics of the system."
    DTDFVocab:inputTo SimulinkBridgeEnabler
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing simulated signals (position, velocity, torque, friction) with measured data from the physical system. Discrepancies are identified by inspecting differences between simulated and live traces. Analytical model parameters, such as friction coefficients, are tuned until the simulated torque closely matches the measured torque during controlled test campaigns. Validation relies on continuous streaming comparisons and expert review rather than formal statistical metrics. No automated error‑detection thresholds are defined in the presented approach."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system employs widely accepted modelling and description languages, notably SysML (v1.7 with IBDs and state‑machine extensions), MontiArc for component‑connector and automaton modelling, ACME and AADL for alternative ADL approaches, and MathWorks Simulink for dynamic simulation. These represent standardised engineering artefacts that are broadly recognised within the systems engineering community. The document does not explicitly reference compliance with ISO/IEC certification schemes, regulatory standards, or interoperability specifications such as OPC UA or MQTT, and therefore no such standards are asserted for the system."
]