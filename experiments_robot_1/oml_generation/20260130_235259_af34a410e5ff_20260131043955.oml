// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Motor of the first axis of the MABI MAX 100 industrial robot."
]
instance GearWheel : DTDFVocab:ActingComponent [
    base:desc "Gearwheel forming part of the gear train of the first axis."
]
instance CycloidalGearbox : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gearbox downstream of the gearwheel in the first axis."
]
instance CoulombViscousFrictionModel : DTDFVocab:ActingComponent [
    base:desc "Coulomb‑Viscous friction model used in the simulation."
]
instance StribeckFrictionModel : DTDFVocab:ActingComponent [
    base:desc "Stribeck friction model used in the simulation."
]
instance DahlFrictionModel : DTDFVocab:ActingComponent [
    base:desc "Dahl friction model used in the simulation."
]
instance LuGreFrictionModel : DTDFVocab:ActingComponent [
    base:desc "LuGre friction model used in the simulation."
]

// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the motor current (I_M) streamed over MQTT."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]
instance AxisPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Dual rotary encoder providing angular position from the axis."
    DTDFVocab:producedData AxisPositionDataTransmitted
]

// C4: Physical-to-virtual interaction
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]
instance AxisPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AxisPositionEncoder
]

// C10: Models/Data
instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink block representing the permanent magnet synchronous motor."
    DTDFVocab:inputTo SimulinkExecutionEngine
]
instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink block modeling the gearwheel and cycloidal gearbox."
    DTDFVocab:inputTo SimulinkExecutionEngine
]
instance FrictionIdentifierSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink block combining white‑box friction models with black‑box data‑driven identification."
    DTDFVocab:inputTo RealTimeFrictionIdentificationService
]
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current I_M from MotorCurrentSensor."
    DTDFVocab:inputTo RealTimeFrictionIdentificationService
    DTDFVocab:fromData MotorCurrentDataTransmitted
]
instance AxisPositionData : DTDFVocab:Data [
    base:desc "Measured encoder angle from the first axis."
    DTDFVocab:inputTo RealTimeFrictionIdentificationService
    DTDFVocab:fromData AxisPositionDataTransmitted
]

// C11: Enablers
instance MQTTConnector : DTDFVocab:Enabler [
    base:desc "MQTT client facilitating real‑time sensor data streaming from the PLC."
    DTDFVocab:enables RealTimeFrictionIdentificationService
]
instance SimulinkExecutionEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink engine executing motor, gearwheel and gearbox simulation models."
    DTDFVocab:enables SimulationExecutionService
]
instance DataAggregationProcessor : DTDFVocab:Enabler [
    base:desc "Processor aggregating raw data traces from sensors and simulation outputs."
    DTDFVocab:enables DataAggregationService
]
instance DashboardVisualizationTool : DTDFVocab:Enabler [
    base:desc "Unified dashboard visualizing friction diagnostics and wear trends."
    DTDFVocab:enables DashboardDeploymentService
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time friction identification combining white‑box analytical and black‑box data‑driven models."
    DTDFVocab:provides UpdatedFrictionParametersInsight, ControlAlgorithmTuningRecommendationInsight
]
instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Simulation of motor, gearwheel, and gearbox dynamics using multiple friction models."
    DTDFVocab:provides JointPerformanceVisibilityInsight, MaintenanceDecisionSupportInsight
]
instance DataAggregationService : DTDFVocab:Service [
    base:desc "Aggregation of data traces for analysis and storage."
    DTDFVocab:provides JointPerformanceVisibilityInsight
]
instance DashboardDeploymentService : DTDFVocab:Service [
    base:desc "Deployment of visualization dashboards for user interaction."
    DTDFVocab:provides JointPerformanceVisibilityInsight
]

// C17: Insights/Actions
instance UpdatedFrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Updated friction parameters derived from real‑time identification."
]
instance ControlAlgorithmTuningRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for control algorithm tuning based on friction diagnostics."
]
instance JointPerformanceVisibilityInsight : DTDFVocab:Insight [
    base:desc "Visibility into joint performance and wear trends for maintenance decisions."
]
instance MaintenanceDecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Decision support for maintenance and tool change."
]
instance UpdateFrictionParametersAction : DTDFVocab:Action [
    base:desc "Action to update friction parameters in the motor controller."
    DTDFVocab:IsAutomatic true
]
instance TuneControlAlgorithmAction : DTDFVocab:Action [
    base:desc "Manual action to tune the control algorithm parameters."
    DTDFVocab:IsAutomatic false
]

// Environment and Components
instance FirstAxisMEContainerEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotor, GearWheel, CycloidalGearbox, MotorCurrentSensor, AxisPositionEncoder
]

instance FirstAxisMEContainer : DTDFVocab:Component [
    base:desc "First axis of the MABI MAX 100 industrial robot comprising motor, gear train, encoders, and sensors."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time data streaming at the sampling rate of the motor current and encoder signals. Simulation and friction identification run at the same rate to provide up‑to‑date model parameters.
"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized digital twin architecture where sensor data from the robot is collected via MQTT, processed by simulation and data‑calculation components, and visualized in a dashboard. The DT comprises Engineering, Simulation, and Data‑Calculation models interconnected through Processing components.
"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (ideal structural and behavioral models specified in SysML), Operation (live data integration, continuous friction identification and twin refinement)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity friction models (analytical and data‑driven) with continuous identification; traceability of data generation; comparison of simulated vs. measured traces; uncertainties handled via model parameters; validation through real‑time sensor comparison.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol used to stream sensor data from Siemens SINUMERIK 840D sl controller; Asset Administration Shell (AAS) provides application and serialization of data traces for the digital shadow."
]