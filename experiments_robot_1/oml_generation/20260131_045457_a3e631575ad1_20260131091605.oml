instance PermanentMagnetSynchronousMotorActuator : DTDFVocab:ActingComponent [
    base:desc "A permanent magnet synchronous motor driving the first axis of the robot, complemented by a gear system for torque amplification"
]

instance GearSystemActuator : DTDFVocab:ActingComponent [
    base:desc "Gear system providing torque amplification for the motor's output to the robotic axis"
]

instance SiemensSinumerik840DSController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl control system providing advanced real-time feedback and adaptive adjustments for robotic control"
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted directly on the permanent magnet synchronous motor for precise motion tracking"
    DTDFVocab:producedData MotorEncoderData
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder positioned behind the gearbox for high-resolution feedback across robotic axes"
    DTDFVocab:producedData GearboxEncoderData
]

instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input current from the motor power supply"
    DTDFVocab:producedData CurrentData
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the mechanical output angle of the robotic axis"
    DTDFVocab:producedData AngleData
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring torque applied to the robotic axis"
    DTDFVocab:producedData TorqueData
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring angular velocity of the robotic axis"
    DTDFVocab:producedData VelocityData
]

instance MotorEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

instance CurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance AngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

instance TorqueData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
]

instance VelocityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

instance DigitalShadowDataAggregator : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces from physical sensors (input current, output angle, torque, angular velocity) for digital shadow purposes"
    DTDFVocab:fromData MotorEncoderData, GearboxEncoderData, CurrentData, AngleData, TorqueData, VelocityData
]

instance SystemRequirementsModel : DTDFVocab:Model [
    base:desc "Requirements model capturing system specifications using RFLP methodology (Requirements, Functions, Logics, Physics)"
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "Functional architecture model defined using SysML IBDs to represent components, interfaces, and compositions"
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Logical architecture model using MontiArc ADL to define system behavior and component interactions"
]

instance ProductTechnicalModel : DTDFVocab:Model [
    base:desc "Product/technical layer model representing physical system characteristics and constraints"
]

instance BehavioralStateMachineModel : DTDFVocab:Model [
    base:desc "Behavioral model using SysML state machines (v1.7) to represent system state transitions and operational workflows"
    DTDFVocab:inputTo MontiArcAutomataFramework
]

instance MontiArcAutomataModel : DTDFVocab:Model [
    base:desc "Automata-based behavioral model using MontiArc for detailed system behavior representation"
    DTDFVocab:inputTo MontiArcAutomataFramework
]

instance SimulationResultsData : DTDFVocab:Data [
    base:desc "Simulation results data generated from MathWorks Simulink or general-purpose simulation tools for behavioral validation"
    DTDFVocab:fromData DigitalShadowDataAggregator
    DTDFVocab:inputTo SimulationValidationFramework
]

instance ModelBasedSystemsEngineeringFramework : DTDFVocab:Enabler [
    base:desc "MBSE framework implementing RFLP and OOSEM methodologies for multi-abstraction level modeling"
    DTDFVocab:enables SystemRequirementsModel, FunctionalArchitectureModel, LogicalArchitectureModel, ProductTechnicalModel
]

instance MontiArcAutomataFramework : DTDFVocab:Enabler [
    base:desc "MontiArc framework for automata-based behavioral modeling and system interaction representation"
    DTDFVocab:enables BehavioralStateMachineModel, MontiArcAutomataModel
]

instance SimulationValidationFramework : DTDFVocab:Enabler [
    base:desc "Simulation tools (MathWorks Simulink, general-purpose languages) for behavioral validation and performance analysis"
    DTDFVocab:enables SimulationResultsData
]

instance MQTTProtocolBroker : DTDFVocab:Enabler [
    base:desc "MQTT protocol implementation for real-time bidirectional data communication between physical sensors and digital twin"
]

instance DataPreprocessingGateway : DTDFVocab:Enabler [
    base:desc "Edge-level data preprocessing component ensuring data quality and abstraction for digital shadow aggregation"
    DTDFVocab:enables DigitalShadowDataAggregator
]

instance FunctionalAnomalyInsight : DTDFVocab:Insight [
    base:desc "Detected functional anomalies through state machine transition analysis in SysML behavioral models"
]

instance PerformanceDegradationAlert : DTDFVocab:Insight [
    base:desc "Performance degradation alerts generated from simulation results comparing physical and virtual system behavior"
]

instance RealTimeControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic real-time control adjustment executed by Siemens SINUMERIK 840D sl system based on sensor feedback and simulation predictions"
    DTDFVocab:IsAutomatic true
]

instance SimulationValidationFeedbackAction : DTDFVocab:Action [
    base:desc "Action to validate and adjust digital twin models based on simulation results and physical system performance"
    DTDFVocab:IsAutomatic true
]

instance DigitalShadow : DTDFVocab:Component [
    base:desc "Passive digital shadow implementing one-way automated data flow from physical sensors (input current, output angle, torque, angular velocity) for contextual data aggregation"
    DTDFVocab:fromData MotorEncoderData, GearboxEncoderData, CurrentData, AngleData, TorqueData, VelocityData
]

instance DataTransmissionService : DTDFVocab:Service [
    base:desc "Real-time data transmission service using MQTT protocol to send sensor data (input current, output angle, torque, angular velocity) from physical system to digital twin"
    DTDFVocab:provides FunctionalAnomalyInsight, PerformanceDegradationAlert
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system in the provided context operates with a **unidirectional, one-way data flow** between the physical system (e.g., a robot axis) and its digital representation (digital shadow). This flow is **automated and passive**, meaning the digital shadow aggregates and abstracts contextual data traces without active feedback or bidirectional synchronization. The temporal aspects are not explicitly quantified in the documents, but the system relies on **live measurements** and real-time processing to maintain alignment between the physical and digital states. No specific synchronization frequencies, latency requirements, or granularity specifications are detailed beyond the passive data aggregation model described in the Digital Shadow Reference Model (Kritzinger et al. [32])."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A **Digital Twin constellation** is not explicitly defined in the provided documents. However, the context implies an **orchestration framework** where digital twins are integrated with digital shadows (passive data flows) and potentially other active components (e.g., software systems with active interpretation). The **Digital Shadow Reference Model** (Fig. 1) suggests a foundational structure for digital shadows, but the **Digital Twin system** itself is described as providing active components to process data autonomously. The absence of explicit details on architecture patterns, component integration, or system-wide coordination mechanisms (e.g., middleware, protocols like MQTT, or orchestration tools) means this characteristic is **not in Document**. The documents reference **Model-Based Systems Engineering (MBSE)** methodologies (e.g., SysML, ADLs) for describing system architectures, which may imply a structured integration but lacks specifics on constellation-level coordination."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "
  A Digital Twin (DT) lifecycle in the described context is structured through **Model-Based Systems Engineering (MBSE)** frameworks, spanning multiple abstraction layers: **requirements, functional architecture, logical architecture, and product/technical layers**. The lifecycle is governed by methodologies such as **RFLP (Requirements, Functions, Logics, Physics)**, **OOSEM**, **SPES**, or **SMArDT**, which systematically manage transitions between these stages. Each phase employs **architecture description languages (ADLs)** like **ACME, AADL, MontiArc, or SysML IBDs** to define components, interfaces, and interconnections, with behavior detailed via **MontiArc Automata, state machines in SysML v1.7**, or simulation tools such as **MathWorks Simulink**. The lifecycle transitions are facilitated by integrating heterogeneous stakeholder perspectives and ensuring interoperability across disparate modeling notations and tools. Transition management involves iterative refinement and validation, ensuring alignment with evolving system requirements and technical specifications.

  **Note:** The document does not explicitly detail specific lifecycle stages (e.g., creation, operation, retirement) or lifecycle governance frameworks (e.g., ISO/IEC standards), but the described MBSE and ADL methodologies implicitly imply structured phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
The Digital Twin’s **fidelity and validity** are addressed through **Model-Based Systems Engineering (MBSE)** practices, ensuring consistency across heterogeneous models (e.g., SysML, MontiArc, Simulink) and tools. While explicit validation protocols are not detailed, the system’s scope includes quantifying the **deviation of simulated data versus measured data** (e.g., encoder feedback vs. physical motion) to assess fidelity. Uncertainty sources are implicitly managed via MBSE’s abstraction layers and cross-verification between physical and digital components. Safety constraints are implicitly enforced through the **Siemens SINUMERIK 840d sl** control system, which integrates with the DT for closed-loop actuation. Quality assurance processes are implied by the structured MBSE workflow but not explicitly detailed in the documents.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **digital twin’s technical connection** employs the **MQTT protocol** for real-time data exchange, as explicitly mentioned in the context. The network infrastructure is not explicitly described for topology (e.g., centralized vs. edge-based), but the reference model implies a **processing component** that handles incoming data streams. No details on bandwidth requirements, latency constraints, reliability mechanisms (e.g., redundancy), or security protocols (e.g., TLS, authentication) are provided in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with external systems via **MQTT protocol** for real-time sensor data streaming, ensuring lightweight, event-driven communication. The **Asset Administration Shell (AAS)** framework is employed for interoperability, enabling standardized data exchange between digital twins and enterprise systems. Dependencies include **AAS-based architectures**, where components like *FrictionShadow* are embedded within AAS structures to facilitate seamless integration with legacy or third-party systems. The integration pattern is **unidirectional** (digital shadow → physical object), with no explicit mention of bidirectional coordination or multi-DT orchestration."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "
The document references **modeling languages and frameworks** without explicit standardization details:
- **Architecture Description Languages (ADLs)**: **SysML** (implied via [17]), **AADL** ([24]), and **MontiArc** ([25], [26]) for component/behavior modeling.
- **Digital Shadow Reference Model (DSRM)**: Expressed via **UML class diagrams** ([32]) for conceptual modeling.
- **No explicit standards** (e.g., ISO/IEC 19450 for SysML, ISO/IEC 26511 for AADL) or **Asset Administration Shell (AAS)** are mentioned in the provided context.
"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The provided documents do not explicitly detail comprehensive security and safety measures for a Digital Twin system. However, the following **partial** technical references from the context are relevant to **specific safety and security aspects** within the context of manufacturing and automation:

  **1. Safety-Critical System Considerations (Industrie 4.0 Framework - RAMI4.0):**
  The **Reference Architecture Model Industrie 4.0 (RAMI4.0)** outlines layers for Digital Twin integration, including the **Safety Layer**, which ensures compliance with safety standards in cyber-physical systems. While RAMI4.0 itself does not prescribe specific protocols, it establishes a structured approach to integrating safety mechanisms (e.g., fail-safe mechanisms) into the automation pyramid (e.g., **Digital Shadows** at different levels). This framework is critical for ensuring safety in industrial Digital Twin deployments, particularly in manufacturing environments where robotic systems (e.g., MABI robotic arms) operate within constrained motion spaces (e.g., **[-90°, 90°] joint limits** for safety cells).

  **2. Cybersecurity Protocols (Digital Shadows & Conformance Relations):**
  The **Digital Shadows** approach (Heithoff et al., 2025) involves projecting real-time data onto virtual models, but no explicit mention of **OPC UA Security** or **role-based access control (RBAC)** is found. However, the **conformance relations** in reference models (Konersmann et al., 2024) imply standardized security frameworks for validating Digital Twin structures, ensuring integrity and authenticity of data exchanges. This aligns with the **Asset Administration Shell (AAS)** concept (Wei et al., 2019; Plattform Industrie 4.0, 2019), where security is implicitly assumed through structured data modeling and validation.

  **3. Fail-Safe Mechanisms (Model-Driven Engineering):**
  The **Model-Driven Engineering (MDE) method** for Digital Twins in manufacturing (Heithoff et al., 2025) emphasizes **fail-safe design** by integrating simulation models (e.g., **Functional Mockup Interface (FMI)** for tool-independent exchange of simulation models, Blochwitz et al., 2011). This ensures that Digital Twin systems can automatically trigger corrective actions in case of deviations (e.g., robotic arm motion violations), mitigating risks without explicit mention of ISO 13849 compliance.

  **Key Limitation:** The documents do not address **data governance policies, privacy regulations (e.g., GDPR), or consent management**, which are critical for broader data ownership and privacy. Thus, while **safety and basic cybersecurity principles** are implied via RAMI4.0, MDE, and Digital Shadows, **full compliance with advanced security protocols (e.g., OPC UA Security, RBAC) or privacy frameworks is not documented.**
}"
]