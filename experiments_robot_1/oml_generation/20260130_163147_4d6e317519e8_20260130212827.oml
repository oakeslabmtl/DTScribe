// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current I_M sensor on the first axis motor, providing time‑series of torque‑related current values via MQTT."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted encoder delivering raw angular position r_M of the motor shaft."
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Gearbox‑mounted encoder delivering raw angular position r_G of the gearbox output shaft."
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

instance SimulatedMotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MATLABMotorSimulinkModel
]

instance SimulatedGearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MATLABGearboxSimulinkModel
]

instance SimulatedOutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MATLABFrictionSimulinkModel_LuGre
]

// C10: Data
instance MeasuredCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current trace I_M collected from MotorCurrentSensor."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance MeasuredMotorAngleData : DTDFVocab:Data [
    base:desc "Measured motor angle trace r_M collected from MotorEncoderSensor."
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance MeasuredGearboxAngleData : DTDFVocab:Data [
    base:desc "Measured gearbox angle trace r_G collected from GearboxEncoderSensor."
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance SimulatedMotorAngleData : DTDFVocab:Data [
    base:desc "Simulated motor angle trace ŕ_M generated by MATLABMotorSimulinkModel."
    DTDFVocab:fromData SimulatedMotorAngleDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEngineEnabler
]

instance SimulatedGearboxAngleData : DTDFVocab:Data [
    base:desc "Simulated gearbox angle trace ŕ_G generated by MATLABGearboxSimulinkModel."
    DTDFVocab:fromData SimulatedGearboxAngleDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEngineEnabler
]

instance SimulatedOutputAngleData : DTDFVocab:Data [
    base:desc "Simulated output angle trace ŕ_out generated by MATLABFrictionSimulinkModel_LuGre."
    DTDFVocab:fromData SimulatedOutputAngleDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEngineEnabler
]

// C10: Models
instance SysMLFirstAxisBlockDefinitionModel : DTDFVocab:Model [
    base:desc "SysML block‑definition model describing the structure of the first rotational axis."
    DTDFVocab:inputTo AssetAdministrationShellEnabler
]

instance SysMLFirstAxisInternalBlockDiagramModel : DTDFVocab:Model [
    base:desc "SysML internal‑block diagram of the first axis, detailing connections between motor, gearbox and sensors."
    DTDFVocab:inputTo AssetAdministrationShellEnabler
]

instance MATLABMotorSimulinkModel : DTDFVocab:Model [
    base:desc "Executable MATLAB/Simulink model of the permanent‑magnet synchronous motor."
    DTDFVocab:inputTo MATLABSimulinkEngineEnabler
]

instance MATLABGearboxSimulinkModel : DTDFVocab:Model [
    base:desc "Executable MATLAB/Simulink model of the gearbox (including cycloidal gear set)."
    DTDFVocab:inputTo MATLABSimulinkEngineEnabler
]

instance MATLABFrictionSimulinkModel_CoulombViscous : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction model using Coulomb‑Viscous formulation."
    DTDFVocab:inputTo MATLABSimulinkEngineEnabler
]

instance MATLABFrictionSimulinkModel_Stribeck : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction model using the Stribeck curve."
    DTDFVocab:inputTo MATLABSimulinkEngineEnabler
]

instance MATLABFrictionSimulinkModel_Dahl : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction model using the Dahl formulation."
    DTDFVocab:inputTo MATLABSimulinkEngineEnabler
]

instance MATLABFrictionSimulinkModel_LuGre : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction model using the LuGre formulation."
    DTDFVocab:inputTo MATLABSimulinkEngineEnabler
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker that streams live sensor time‑series (current, encoder angles) from the Siemens SINUMERIK 840D controller to the digital twin."
    DTDFVocab:enables RealTimeVisualizationService
]

instance MATLABSimulinkEngineEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution engine used for running motor, gearbox and friction simulation models."
    DTDFVocab:enables FrictionIdentificationService, FrictionParameterGenerationService
]

instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Custom web dashboard that visualizes real‑time traces and identification results."
    DTDFVocab:enables RealTimeVisualizationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) linking engineering models (SysML) with the digital twin runtime."
    DTDFVocab:enables RealTimeVisualizationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Service providing real‑time visualization of measured and simulated torque/velocity traces on a unified dashboard."
    DTDFVocab:provides MotionAccuracyInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Automated service that identifies static, kinetic and viscous friction parameters by comparing simulated and measured torque/velocity traces."
    DTDFVocab:provides FrictionParametersInsight
]

instance FrictionParameterGenerationService : DTDFVocab:Service [
    base:desc "Service that generates updated friction parameters and feeds them back to the robot controller for improved motion control."
    DTDFVocab:provides UpdateControllerAction
]

// C17: Insights
instance FrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters (static, kinetic, viscous) obtained from the identification service."
]

instance MotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Insight into motion accuracy improvements based on real‑time visualization of torque and velocity deviations."
]

// C17: Actions
instance UpdateControllerAction : DTDFVocab:Action [
    base:desc "Action that transmits the newly identified friction parameters to the Siemens SINUMERIK 840D controller to enhance motion accuracy."
    DTDFVocab:IsAutomatic true
]

// C16: Environment and Components
instance FirstAxisEnvironment : DTDFVocab:Environment [
    base:contains FirstAxisComponent, PermanentMagnetSynchronousMotorComponent, GearboxComponent, CycloidalGearboxComponent
]

instance FirstAxisComponent : DTDFVocab:Component [
    base:desc "Physical first rotational axis of the MABI MAX 100 robot, integrating motor, gearbox and sensor hardware."
]

instance PermanentMagnetSynchronousMotorComponent : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor driving the first axis."
]

instance GearboxComponent : DTDFVocab:Component [
    base:desc "Standard gearbox coupling the motor to the cycloidal gear set."
]

instance CycloidalGearboxComponent : DTDFVocab:Component [
    base:desc "Cycloidal gearbox that transmits motion from the gearbox to the robot’s output shaft."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data acquisition and processing occur continuously in real‑time during robot operation, enabling on‑line model updating at the robot’s control cycle (up to 75 °/s joint speed)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A single digital shadow instance (FrictionShadow) aggregates DataTraces, Processing components (Simulation M, GW, GB) and Models, all linked to the asset ‘Mabi’ via the Digital Shadow Reference Model, forming a one‑way PT‑to‑VT architecture."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow is created for and used in the operated stage of the robot life‑cycle, consuming live operational data to refine models after design and manufacturing."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Each DataTrace is traceable to its source and processing component via the ‘originates‑from’ association, allowing verification of simulated versus measured torque/velocity; the methodology supports continuous validation of white‑box and black‑box friction models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow using the MQTT protocol; the Asset Administration Shell (AAS) provides a standardized interface for model‑data integration."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital shadow employs the Asset Administration Shell, a standardized Industrie 4.0 information model, to encapsulate the asset description and facilitate interoperability."
]