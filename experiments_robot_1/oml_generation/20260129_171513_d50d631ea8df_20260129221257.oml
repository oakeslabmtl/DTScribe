instance PhysicalSystemSensor : DTDFVocab:SensingComponent [
    base:desc "Physical system sensors providing data to digital shadow"
    DTDFVocab:producedData PhysicalSystemDataTransmitted
]

instance PhysicalSystemDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemSensor
]

instance PhysicalSystemData : DTDFVocab:Data [
    base:desc "Data sourced from physical systems through digital shadow's one-way data flow"
    DTDFVocab:fromData PhysicalSystemDataTransmitted
]

instance SysMLGeometricModel : DTDFVocab:Model [
    base:desc "SysML for geometric modeling of component structures and interfaces via IBDs"
    DTDFVocab:inputTo SysMLEnabler
]

instance MontiArcBehavioralModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcAutomatonEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavioral modeling"
    DTDFVocab:inputTo SysMLEnabler
]

instance SimulinkAnalyticalModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink combined with C++/Java code for analytical simulations"
    DTDFVocab:inputTo SimulinkEnabler, CPPEnabler, JavaEnabler
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME architecture description language for system descriptions"
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL architecture description language for system descriptions"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcADLModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description language for system descriptions"
    DTDFVocab:inputTo MontiArcADLEnabler
]

instance RFLPModel : DTDFVocab:Model [
    base:desc "RFLP modeling methodology"
    DTDFVocab:inputTo RFLPEnabler
]

instance OOSEMModel : DTDFVocab:Model [
    base:desc "OOSEM modeling methodology"
    DTDFVocab:inputTo OOSEMEnabler
]

instance SPESModel : DTDFVocab:Model [
    base:desc "SPES modeling methodology"
    DTDFVocab:inputTo SPESEnabler
]

instance SMArDTModel : DTDFVocab:Model [
    base:desc "SMArDT modeling methodology"
    DTDFVocab:inputTo SMArDTEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for system modeling across abstraction levels (requirements, functional, logical, technical layers)"
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME architecture description language for component & connector-based system descriptions"
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL architecture description language for component & connector-based system descriptions"
]

instance MontiArcADLEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc architecture description language for component & connector-based system descriptions"
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral modeling"
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and analytical modeling"
]

instance CPPEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed system behavior specification"
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed system behavior specification"
]

instance RFLPEnabler : DTDFVocab:Enabler [
    base:desc "RFLP modeling methodology"
]

instance OOSEMEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM modeling methodology"
]

instance SPESEnabler : DTDFVocab:Enabler [
    base:desc "SPES modeling methodology"
]

instance SMArDTEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT modeling methodology"
]