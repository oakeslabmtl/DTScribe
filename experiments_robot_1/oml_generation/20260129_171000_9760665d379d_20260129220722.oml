instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "Structural modeling across abstraction levels (requirements, functional architecture, logical architecture, product/technical layer) using SysML"
    DTDFVocab:inputTo MBSE
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language for component interfaces, interconnections, and composition"
    DTDFVocab:inputTo ACME
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL Architecture Description Language for component interfaces, interconnections, and composition"
    DTDFVocab:inputTo AADL
]

instance MontiArcADLModel : DTDFVocab:Model [
    base:desc "MontiArc Architecture Description Language for component interfaces, interconnections, and composition"
    DTDFVocab:inputTo MontiArc
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams for component interfaces and interconnections"
    DTDFVocab:inputTo SysMLIBD
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArc
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavioral modeling"
    DTDFVocab:inputTo MBSE
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink for detailed simulation"
    DTDFVocab:inputTo Simulink
]

instance CppSimulationModel : DTDFVocab:Model [
    base:desc "C++ for detailed behavior specification in simulation"
    DTDFVocab:inputTo Cpp
]

instance JavaSimulationModel : DTDFVocab:Model [
    base:desc "Java for detailed behavior specification in simulation"
    DTDFVocab:inputTo Java
]

instance MBSE : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering (MBSE) methodology for system modeling"
    DTDFVocab:enables ModelManagementService
]

instance ACME : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component interfaces, interconnections, and composition"
    DTDFVocab:enables ModelManagementService
]

instance AADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component interfaces, interconnections, and composition"
    DTDFVocab:enables ModelManagementService
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component interfaces, interconnections, and composition"
    DTDFVocab:enables ModelManagementService
]

instance SysMLIBD : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component interfaces and interconnections"
    DTDFVocab:enables ModelManagementService
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "RFLP methodology (Requirements, Functions, Logics, Physics) for managing complexity"
    DTDFVocab:enables ModelManagementService
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "Object-Oriented Software Engineering Method for managing complexity"
    DTDFVocab:enables ModelManagementService
]

instance SPES : DTDFVocab:Enabler [
    base:desc "System Product Engineering Specification methodology for managing complexity"
    DTDFVocab:enables ModelManagementService
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "Smart Digital Twin methodology for managing complexity"
    DTDFVocab:enables ModelManagementService
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed simulation"
    DTDFVocab:enables SimulationService
]

instance Cpp : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior specification"
    DTDFVocab:enables SimulationService
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior specification"
    DTDFVocab:enables SimulationService
]

instance ModelManagementService : DTDFVocab:Service [
    base:desc "Service for managing system models and architectures"
    DTDFVocab:provides ModelingInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for conducting detailed simulations of system behavior"
    DTDFVocab:provides SimulationInsight
]

instance ModelingInsight : DTDFVocab:Insight [
    base:desc "Insight derived from system model analysis"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulation results"
]