// C3: Physical sensing component (derived from data aggregation description)
instance PhysicalAssetDataAggregator : DTDFVocab:SensingComponent [
    base:desc "Aggregates contextual data traces from the physical asset (digital shadow) for the digital twin"
    DTDFVocab:producedData AggregatedContextualDataTransmitted
]

// C4: Data transmitted from sensing component
instance AggregatedContextualDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalAssetDataAggregator
]

// C10: Abstracted contextual data
instance AbstractedContextualData : DTDFVocab:Data [
    base:desc "Abstracted contextual data derived from aggregated traces of the physical asset"
    DTDFVocab:fromData AggregatedContextualDataTransmitted
    DTDFVocab:inputTo MBSEToolchainEnabler
]

// C11: Enablers

// MBSE toolchain enabler (SysML, ADLs, IBDs)
instance MBSEToolchainEnabler : DTDFVocab:Enabler [
    base:desc "MBSE toolchain supporting SysML, architecture description languages (ACME, AADL, MontiArc) and internal block diagrams for model capture"
    DTDFVocab:enables ArchitectureModelingService
]

// Simulation environment enabler (MathWorks Simulink, other simulators)
instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation environment linking behavioral models to MathWorks Simulink or other domain‑specific simulators"
    DTDFVocab:enables BehaviourSimulationService
]

// Code generation enabler (C++ / Java)
instance CodeGenEnabler : DTDFVocab:Enabler [
    base:desc "General‑purpose programming tools (C++ and Java) used for automatic code generation from models"
    DTDFVocab:enables CodeGenerationService
]

// Methodology/process enabler (RFLP, OOSEM, SPES, SMArDT)
instance MethodologyEnabler : DTDFVocab:Enabler [
    base:desc "Methodological engineering processes RFLP, OOSEM, SPES and SMArDT managing abstraction layers from requirements through physics"
    DTDFVocab:enables EngineeringProcessService
]

// C6: Services

instance ArchitectureModelingService : DTDFVocab:Service [
    base:desc "Provides architecture modeling, analysis and validation across multiple model layers"
    DTDFVocab:provides ModelConsistencyInsight
]

instance BehaviourSimulationService : DTDFVocab:Service [
    base:desc "Executes behavioural models in simulation environments to obtain system‑level behavior insights"
    DTDFVocab:provides SystemBehaviourInsight
]

instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Generates executable C++ or Java code from validated models for twin runtime execution"
    DTDFVocab:provides RuntimeAction
]

instance EngineeringProcessService : DTDFVocab:Service [
    base:desc "Supports engineering processes and methodological guidance throughout the twin development lifecycle"
    DTDFVocab:provides DesignInsight
]

// C17: Insights / Actions

instance ModelConsistencyInsight : DTDFVocab:Insight [
    base:desc "Insight into consistency of multi‑layer models (requirements, functional, logical, product) across the digital twin"
]

instance SystemBehaviourInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulation of behavioural models (state machines, MontiArc Automaton) regarding system dynamics"
]

instance RuntimeAction : DTDFVocab:Action [
    base:desc "Executes generated C++/Java code within the twin runtime environment"
    DTDFVocab:IsAutomatic true
]

instance DesignInsight : DTDFVocab:Insight [
    base:desc "Insight on managing abstraction layers from requirements through physics as governed by RFLP, OOSEM, SPES, SMArDT processes"
]

// C10: Models (each inputs to appropriate enabler)

instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML model capturing system requirements"
    DTDFVocab:inputTo MBSEToolchainEnabler
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML model describing functional architecture"
    DTDFVocab:inputTo MBSEToolchainEnabler
]

instance SysMLLogicalModel : DTDFVocab:Model [
    base:desc "SysML model representing logical architecture"
    DTDFVocab:inputTo MBSEToolchainEnabler
]

instance SysMLProductModel : DTDFVocab:Model [
    base:desc "SysML model for product (physical) architecture"
    DTDFVocab:inputTo MBSEToolchainEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "Architecture description using ACME language"
    DTDFVocab:inputTo MBSEToolchainEnabler
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "Architecture description using AADL language"
    DTDFVocab:inputTo MBSEToolchainEnabler
]

instance MontiArcArchitectureModel : DTDFVocab:Model [
    base:desc "Architecture description using MontiArc language"
    DTDFVocab:inputTo MBSEToolchainEnabler
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram capturing component‑connector structures and interfaces"
    DTDFVocab:inputTo MBSEToolchainEnabler
]

instance MontiArcAutomatonBehaviourModel : DTDFVocab:Model [
    base:desc "Behavioural model expressed with MontiArc Automaton"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SysMLStateMachineBehaviourModel : DTDFVocab:Model [
    base:desc "Behavioural model expressed with SysML v1.7 state machines"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model refined in MathWorks Simulink"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance CppExecutableModel : DTDFVocab:Model [
    base:desc "Executable model generated as C++ code"
    DTDFVocab:inputTo CodeGenEnabler
]

instance JavaExecutableModel : DTDFVocab:Model [
    base:desc "Executable model generated as Java code"
    DTDFVocab:inputTo CodeGenEnabler
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle is expressed through the MBSE abstraction hierarchy described in the document: (1) Requirements stage – captured with SysML requirement diagrams; (2) Functional architecture stage – modelled with SysML functional views (activity, sequence diagrams); (3) Logical architecture stage – represented as component‑connector models using architecture description languages such as ACME, AADL, MontiArc, or SysML internal block diagrams; (4) Product/technical layer stage – realized in executable artefacts such as MATLAB/Simulink models, C++ or Java code. Transition between these stages is governed by the selected MBSE methodology (e.g., RFLP, OOSEM, SPES, SMArDT) which defines traceability, refinement and integration rules."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach adopts standardized modelling languages and ADLs cited in the document: SysML (OMG specification), AADL (ASME standard), ACME, MontiArc, and other open architecture description languages. Simulation and implementation tools such as MATLAB/Simulink, C++, and Java are also industry‑standard. By relying on these openly defined specifications, the Digital Twin architecture aims for interoperability and compliance with established modelling standards."
]