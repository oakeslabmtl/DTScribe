prefix DTDFVocab = "http://www.example.com/DTDFVocab"
instance SystemArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight into system architecture structure"
]

instance BehaviorAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight into system behavior"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from simulation results"
]

instance CppInsight : DTDFVocab:Insight [
    base:desc "Insight from C++ analytical models"
]

instance JavaInsight : DTDFVocab:Insight [
    base:desc "Insight from Java analytical models"
]

instance ACMEInsight : DTDFVocab:Insight [
    base:desc "Insight from ACME architecture description"
]

instance AADLInsight : DTDFVocab:Insight [
    base:desc "Insight from AADL analysis"
]

instance SystemArchitectureService : DTDFVocab:Service [
    base:desc "Service for system architecture modeling and analysis",
    DTDFVocab:provides SystemArchitectureInsight
]

instance BehaviorAnalysisService : DTDFVocab:Service [
    base:desc "Service for behavior modeling and analysis",
    DTDFVocab:provides BehaviorAnalysisInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for simulation and analytical modeling",
    DTDFVocab:provides SimulationInsight
]

instance CppAnalysisService : DTDFVocab:Service [
    base:desc "Service for C++-based analytical models",
    DTDFVocab:provides CppInsight
]

instance JavaAnalysisService : DTDFVocab:Service [
    base:desc "Service for Java-based analytical models",
    DTDFVocab:provides JavaInsight
]

instance ArchitectureService : DTDFVocab:Service [
    base:desc "Service for ACME-based architecture description",
    DTDFVocab:provides ACMEInsight
]

instance AADLAnalysisService : DTDFVocab:Service [
    base:desc "Service for AADL-based analysis",
    DTDFVocab:provides AADLInsight
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for multi-level abstraction modeling (requirements, functional, logical, product layers)",
    DTDFVocab:enables SystemArchitectureService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc for architecture description and behavior modeling",
    DTDFVocab:enables BehaviorAnalysisService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and analytical modeling",
    DTDFVocab:enables SimulationService
]

instance CPlusPlusEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for analytical models",
    DTDFVocab:enables CppAnalysisService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for analytical models",
    DTDFVocab:enables JavaAnalysisService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME architecture description language for system architecture",
    DTDFVocab:enables ArchitectureService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL architecture description language for embedded systems",
    DTDFVocab:enables AADLAnalysisService
]

instance SimulationSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for simulation data generation from modeling tools"
]

instance SimulationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationSensor
]

instance RequirementsData : DTDFVocab:Data [
    base:desc "Data at requirements abstraction level",
    DTDFVocab:fromData SimulationDataTransmitted,
    DTDFVocab:inputTo SysMLEnabler
]

instance FunctionalData : DTDFVocab:Data [
    base:desc "Data at functional abstraction level",
    DTDFVocab:fromData SimulationDataTransmitted,
    DTDFVocab:inputTo SysMLEnabler
]

instance LogicalData : DTDFVocab:Data [
    base:desc "Data at logical abstraction level",
    DTDFVocab:fromData SimulationDataTransmitted,
    DTDFVocab:inputTo SysMLEnabler
]

instance TechnicalData : DTDFVocab:Data [
    base:desc "Data at technical abstraction level",
    DTDFVocab:fromData SimulationDataTransmitted,
    DTDFVocab:inputTo SysMLEnabler
]

instance ACMEData : DTDFVocab:Data [
    base:desc "Data using ACME architecture description notation",
    DTDFVocab:fromData SimulationDataTransmitted,
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLData : DTDFVocab:Data [
    base:desc "Data using AADL architecture description notation",
    DTDFVocab:fromData SimulationDataTransmitted,
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcData : DTDFVocab:Data [
    base:desc "Data using MontiArc architecture description notation",
    DTDFVocab:fromData SimulationDataTransmitted,
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams for structural modeling of components and interfaces",
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLBehavioralModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavioral modeling",
    DTDFVocab:inputTo SysMLEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling",
    DTDFVocab:inputTo MontiArcEnabler
]

instance SimulinkAnalyticalModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink for analytical modeling",
    DTDFVocab:inputTo SimulinkEnabler
]

instance CPlusPlusModel : DTDFVocab:Model [
    base:desc "C++ programming for analytical models",
    DTDFVocab:inputTo CPlusPlusEnabler
]

instance JavaModel : DTDFVocab:Model [
    base:desc "Java programming for analytical models",
    DTDFVocab:inputTo JavaEnabler
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system utilizes industry standards such as SysML for model-based systems engineering, ACME and AADL as architecture description languages for component & connector modeling, MontiArc for behavior specification via automata and state machines (SysML v1.7), and integrates with MathWorks Simulink, simulation tools, and general-purpose programming languages (C++, Java) for detailed behavior description."
]