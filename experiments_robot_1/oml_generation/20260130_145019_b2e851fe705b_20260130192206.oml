// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Robot internal sensor measuring input current of the motor"
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance MotorAngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Robot internal sensor measuring angular velocity of the motor"
    DTDFVocab:producedData MotorAngularVelocityDataTransmitted
]

instance AxisPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Robot internal sensor measuring position of the first axis"
    DTDFVocab:producedData AxisPositionDataTransmitted
]

// C4: Physical-to-virtual interaction
instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance MotorAngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorAngularVelocitySensor
]

instance AxisPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AxisPositionSensor
]

// C10: Data (filtered)
instance FilteredInputCurrentData : DTDFVocab:Data [
    base:desc "Low‑pass filtered input current data after preprocessing"
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo FrictionComputationEnabler
]

instance FilteredMotorAngularVelocityData : DTDFVocab:Data [
    base:desc "Low‑pass filtered motor angular velocity data after preprocessing"
    DTDFVocab:fromData MotorAngularVelocityDataTransmitted
    DTDFVocab:inputTo FrictionComputationEnabler
]

instance FilteredAxisPositionData : DTDFVocab:Data [
    base:desc "Low‑pass filtered axis position data after preprocessing"
    DTDFVocab:fromData AxisPositionDataTransmitted
    DTDFVocab:inputTo FrictionComputationEnabler
]

// C10: Models/Data
instance PhysicsBasedFrictionModel : DTDFVocab:Model [
    base:desc "White‑box physics‑based friction simulation model (Simulink dynamic model)"
    DTDFVocab:inputTo FrictionComputationEnabler
]

instance NeuralNetworkFrictionModel : DTDFVocab:Model [
    base:desc "Black‑box neural network model for data‑driven friction adaptation"
    DTDFVocab:inputTo FrictionComputationEnabler
]

// C11: Enablers
instance FrictionComputationEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that consumes filtered sensor data and friction models to compute multi‑physics joint friction estimates and generate output data traces"
    DTDFVocab:enables RealTimeFrictionMonitoringService,
                 ModelUpdateService,
                 PredictiveMaintenanceAlertService,
                 ClosedLoopControlSupportService,
                 MachiningParameterOptimizationService,
                 ProductQualityPredictionService
]

// C6: Services
instance RealTimeFrictionMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of joint friction and sensor data"
    DTDFVocab:provides RealTimeFrictionInsight
]

instance ModelUpdateService : DTDFVocab:Service [
    base:desc "Continuously updates both physics‑based (white‑box) and data‑driven (black‑box) friction models"
    DTDFVocab:provides ModelAccuracyInsight
]

instance PredictiveMaintenanceAlertService : DTDFVocab:Service [
    base:desc "Generates predictive‑maintenance alerts by detecting anomalies in friction behaviour"
    DTDFVocab:provides FrictionAnomalyInsight,
                 ScheduleMaintenanceAction
]

instance ClosedLoopControlSupportService : DTDFVocab:Service [
    base:desc "Supplies compensated friction values to the robot controller for closed‑loop control"
    DTDFVocab:provides ControlCompensationInsight,
                 AdjustControlParametersAction
]

instance MachiningParameterOptimizationService : DTDFVocab:Service [
    base:desc "Performs simulation‑based optimisation of machining parameters to reduce CO₂ emissions"
    DTDFVocab:provides OptimizationOpportunityInsight,
                 ApplyOptimizationParametersAction
]

instance ProductQualityPredictionService : DTDFVocab:Service [
    base:desc "Predicts product quality using accumulated production data"
    DTDFVocab:provides QualityPredictionInsight
]

// C17: Insights
instance RealTimeFrictionInsight : DTDFVocab:Insight [
    base:desc "Current joint friction estimate derived from sensor data and models"
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Confidence indicator reflecting traceability depth of the friction model update"
]

instance FrictionAnomalyInsight : DTDFVocab:Insight [
    base:desc "Detection of deviations from expected friction behaviour indicating potential failure"
]

instance ControlCompensationInsight : DTDFVocab:Insight [
    base:desc "Compensated friction value to be injected into the robot controller"
]

instance OptimizationOpportunityInsight : DTDFVocab:Insight [
    base:desc "Recommended machining parameters (cutting speed, feed) that minimize CO₂ emissions"
]

instance QualityPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted product quality metric based on accumulated production data"
]

// C17: Actions
instance AdjustControlParametersAction : DTDFVocab:Action [
    base:desc "Automatically adjust robot control parameters based on friction compensation"
    DTDFVocab:IsAutomatic true
]

instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Create a maintenance work order for human operators"
    DTDFVocab:IsAutomatic false
]

instance ApplyOptimizationParametersAction : DTDFVocab:Action [
    base:desc "Apply recommended cutting speed and feed to the machining controller"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The robot digital twin processes a continuous data stream from the physical robot. Real‑time requirements are emphasized; calculations must respect the control‑system dead time. Data are transmitted using MQTT, enabling near‑real‑time synchronization between physical measurements and the digital shadow. The system updates at the sensor sampling rate, providing low‑latency, continuous synchronization."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a pipeline architecture: physical robot measurements are published via MQTT and received by an Asset Administration Shell (AAS) executor, which stores measured, simulated and reference values in a digital shadow hosted on ThingsBoard. The digital shadow combines a SysML model of the robot’s structure with executable simulation models (e.g., Simulink) that compute friction behavior. The pipeline automatically triggers the simulation runs, updates the shadow, and forwards results to a visualization dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the MBSE abstraction hierarchy described in Document 1: (i) Requirements stage, (ii) Functional‑architecture stage, (iii) Logical‑architecture stage, and (iv) Product/Technical (implementation) stage. Early‑stage artefacts are expressed as high‑level SysML requirement and block diagrams; the functional stage adds SysML internal‑block diagrams and behavioural state‑machine extensions; the logical stage refines the system into component‑connector ADL models such as ACME, AADL or MontiArc (including MontiArc‑Automaton for behaviour); the product stage materialises the models in simulation tools (e.g., Simulink) or executable code and generates concrete data‑trace artifacts that constitute the digital shadow. Transition between stages is governed by explicit traceability links – the “originates‑from” association defined in Document 2 – which map each data‑trace to its generating processing component, input traces and the underlying calculation or simulation model. Conformance to the Digital‑Shadow Reference Model is ensured by a mapping relation that binds concrete class‑diagrams to the reference concepts (Document 2), providing lifecycle governance through model‑to‑model conformance checking and traceability."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by combining physics‑based (white‑box) models with data‑driven (black‑box) models. The reliability of the shadow depends on the correctness of the underlying models and the data transformations applied. The approach emphasizes traceability of data traces to the models and processing components via the ‘originates‑from’ association, which supports verification of model transformations (e.g., from SysML to simulation models). Validation activities focus on ensuring transformation correctness and maintaining traceability throughout the data processing chain."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the physical robot and the digital shadow is realised through an MQTT publish‑subscribe network. An MQTT broker mediates the exchange, using JSON‑encoded messages on hierarchically organised topics; the broker can enforce read/write permissions per topic. The AAS Executor accesses the Asset Administration Shell via its defined interfaces (e.g., standard AAS APIs) to retrieve the incoming sensor data and to publish the constructed digital‑shadow model. Processed shadow data are forwarded to the ThingsBoard IoT platform for persistence and visualisation. The described stack thus comprises MQTT as the transport protocol, JSON as the payload format, hierarchical topic naming for logical separation, and AAS‑based integration for semantic linking."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration uses MQTT as the data‑exchange protocol, allowing IoT devices to stream sensor data to the digital twin. The digital shadow is persisted and visualized in ThingsBoard, an open‑source IoT platform. Interoperability is achieved through the Asset Administration Shell (AAS) as a standardized container, and model integration is performed by coupling SysML structural models with Simulink behavioral models via the Functional Mock‑up Interface (FMI). These standards enable the digital twin to interoperate with enterprise IoT infrastructure and other digital twins."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The described Digital Twin framework relies on several established standards. Structural and behavioural models are expressed with SysML (an OMG standard) and with architecture description languages such as ACME, AADL (SAE standard) and MontiArc, which are referenced in Document 1. Data exchange between physical assets and the twin can use the MQTT protocol, for which an open‑source implementation (Mosquitto) is cited in Document 6, indicating compliance with the OASIS MQTT standard. The processing component model references simulation and data‑calculation models that may be executed in tools such as MathWorks Simulink, a de‑facto industry standard for dynamic system modelling (Document 1). No explicit certification or conformity assessment procedures are mentioned."
]