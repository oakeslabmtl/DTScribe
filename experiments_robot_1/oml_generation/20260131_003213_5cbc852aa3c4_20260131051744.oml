// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring current I_M for the first axis motor."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance FrontEndMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Front‑end motor encoder mounted on the synchronous motor measuring motor position."
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder mounted behind the gearbox measuring output position of the gearwheel."
    DTDFVocab:producedData GearboxPositionDataTransmitted
]

// C4: Physical-to-virtual interaction
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FrontEndMotorEncoder
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoder
]

// C10: Models/Data
instance MeasuredMotorCurrentTimeSeries : DTDFVocab:Data [
    base:desc "Time series of measured motor current I_M, sourced via MQTT transmission of MotorCurrentDataTransmitted."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData MotorCurrentDataTransmitted
]

instance MeasuredMotorPositionTimeSeries : DTDFVocab:Data [
    base:desc "Time series of measured motor position from FrontEndMotorEncoder."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData MotorPositionDataTransmitted
]

instance MeasuredGearboxPositionTimeSeries : DTDFVocab:Data [
    base:desc "Time series of measured gearwheel output position from SecondaryEncoder."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData GearboxPositionDataTransmitted
]

instance CalculatedMotorTorqueTimeSeries : DTDFVocab:Data [
    base:desc "Calculated motor torque τ_M over time using current and position data."
    DTDFVocab:inputTo MATLABSimulink
    DTDFVocab:fromData MeasuredMotorCurrentTimeSeries
]

instance CalculatedMotorAngularVelocityTimeSeries : DTDFVocab:Data [
    base:desc "Calculated motor angular velocity ω_M over time from position derivative."
    DTDFVocab:inputTo MATLABSimulink
    DTDFVocab:fromData MeasuredMotorPositionTimeSeries
]

// Structural SysML models
instance SysMLMotorStructuralModel : DTDFVocab:Model [
    base:desc "SysML structural model of the first‑axis motor."
    DTDFVocab:inputTo SysMLTool
]

instance SysMLGearboxStructuralModel1 : DTDFVocab:Model [
    base:desc "SysML structural model of gearbox component #1 in the motor drive."
    DTDFVocab:inputTo SysMLTool
]

instance SysMLGearboxStructuralModel2 : DTDFVocab:Model [
    base:desc "SysML structural model of gearbox component #2 in the motor drive."
    DTDFVocab:inputTo SysMLTool
]

// Simulink executable models
instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the motor for real‑time simulation."
    DTDFVocab:inputTo MATLABSimulink
]

instance SimulinkGearwheelModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the gearwheel."
    DTDFVocab:inputTo MATLABSimulink
]

instance SimulinkOverallSystemModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the complete first‑axis system."
    DTDFVocab:inputTo MATLABSimulink
]

// Friction calculation models
instance FrictionModelCoulombViscous : DTDFVocab:Model [
    base:desc "Coulomb‑Viscous friction model used for joint friction analysis."
    DTDFVocab:inputTo FrictionModelEnabler
]

instance FrictionModelStribeck : DTDFVocab:Model [
    base:desc "Stribeck friction model used for joint friction analysis."
    DTDFVocab:inputTo FrictionModelEnabler
]

instance FrictionModelDahl : DTDFVocab:Model [
    base:desc "Dahl friction model used for joint friction analysis."
    DTDFVocab:inputTo FrictionModelEnabler
]

instance FrictionModelLuGre : DTDFVocab:Model [
    base:desc "LuGre friction model used for joint friction analysis."
    DTDFVocab:inputTo FrictionModelEnabler
]

// C11: Enablers
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML (UML) tool used for building structural models of the motor and gearbox."
    DTDFVocab:enables StructuralModelService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker for streaming real‑time telemetry from sensors."
    DTDFVocab:enables RealTimeVisualizationDashboard, DataAggregationService
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink runtime environment for executing motor, gearwheel, and overall system models."
    DTDFVocab:enables ComparativeAnalysisService, FrictionModelRefinementService
]

instance FrictionModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for running friction calculation models (Coulomb‑Viscous, Stribeck, Dahl, LuGre)."
    DTDFVocab:enables FrictionModelRefinementService
]

instance ControlParameterUpdater : DTDFVocab:Enabler [
    base:desc "Enabler that performs computation and delivery of control parameter adjustments."
    DTDFVocab:enables ControlParameterUpdateService
]

instance DataAggregationTool : DTDFVocab:Enabler [
    base:desc "Toolchain for data aggregation and abstraction from transmitted data."
    DTDFVocab:enables DataAggregationService
]

// C6: Services
instance StructuralModelService : DTDFVocab:Service [
    base:desc "Service for managing SysML structural models of the motor and gearbox."
    DTDFVocab:provides StructuralModelInsight
]

instance RealTimeVisualizationDashboard : DTDFVocab:Service [
    base:desc "Real‑time visualization dashboard aggregating sensor traces and simulation outcomes."
    DTDFVocab:provides VisualizationInsight
]

instance ComparativeAnalysisService : DTDFVocab:Service [
    base:desc "Service comparing measured and simulated data to identify joint friction characteristics."
    DTDFVocab:provides FrictionAnalysisInsight
]

instance FrictionModelRefinementService : DTDFVocab:Service [
    base:desc "Service for continuous refinement of white‑box and black‑box friction models (Coulomb‑Viscous, Stribeck, Dahl, LuGre)."
    DTDFVocab:provides FrictionModelImprovementInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Service aggregating and abstracting data from physical sensors for processing."
    DTDFVocab:provides DataAggregationInsight
]

instance ControlParameterUpdateService : DTDFVocab:Service [
    base:desc "Service recommending control parameter updates to improve motion accuracy."
    DTDFVocab:provides ControlParameterUpdateAction
]

// C17: Insights/Actions
instance StructuralModelInsight : DTDFVocab:Insight [
    base:desc "Insight into the current state of structural models."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight showing real‑time sensor data alongside simulation outputs."
]

instance FrictionAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight comparing measured and simulated joint torque to identify friction characteristics."
]

instance FrictionModelImprovementInsight : DTDFVocab:Insight [
    base:desc "Insight on how refinements of friction models improve robot control accuracy."
]

instance DataAggregationInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing aggregated data from sensors for further analysis."
]

instance ControlParameterUpdateAction : DTDFVocab:Action [
    base:desc "Action to update control parameters to improve motion accuracy based on friction analysis."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with live sensor streams; data is processed continuously during robot operation, with timestamps recorded for each data point and synchronized between physical and virtual states."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestration comprising the physical asset (robot), data sources (encoders, current sensor), a processing component that consumes sensor traces and executes simulation models to produce simulated traces, all connected via MQTT and curated within the Digital Shadow Reference Model framework, with a dedicated dashboard presenting the aggregated data."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the robot in its operated state, encompassing design (structural and simulation models), deployment (dashboards, MQTT streaming), runtime monitoring and continuous parameter adaptation during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fine‑grained traceability of every data point back to its source and processing component; verification through comparison of simulated frictionless baseline against measured data; validation via continuous adjustment of white‑box and black‑box parameters to account for wear, load, and temperature variations; uncertainty management through iterative model refinement."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange between PT and DT occurs over MQTT, a lightweight publish/subscribe protocol commonly used in industrial IoT; the DT consumes data from physical channels and produces simulation data for the dashboard."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for system architecture and behavior, and Asset Administration Shell (AAS) for data description; no other specific ISO/IEC standards referenced."
]