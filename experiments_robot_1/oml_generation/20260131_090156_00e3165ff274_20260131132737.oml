// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Electric motor with permanent magnets used for precise motion control in the MABI MAX 100 industrial robot, interfaced with a cycloidal gear transmission system for torque amplification. Operates within defined torque and speed safety constraints."
]

instance CycloidalGearTransmission : DTDFVocab:ActingComponent [
    base:desc "Mechanical transmission system paired with the permanent magnet synchronous motor to achieve precise motion control with minimal backlash, enabling high-resolution positioning for industrial automation tasks."
]

instance SiemensSinumerik840DslController : DTDFVocab:ActingComponent [
    base:desc "Industrial control system providing remote actuation capabilities for the MABI MAX 100 robot, supporting closed-loop control through feedback from position encoders and implementing safety constraints for torque and speed."
]

// C3: Physical Sensing Components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution position encoder mounted directly on the permanent magnet synchronous motor to provide real-time feedback for closed-loop control and motion tracking."
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution position encoder positioned behind the cycloidal gear transmission system to provide precise feedback for motion control and gearbox alignment verification."
    DTDFVocab:producedData GearboxPositionDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

// C10: Models/Data
instance SysMLInternalBlockDiagramModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram representing the component-connector architecture of the MABI MAX 100 robot system, including the motor, gearbox, and controller components with their defined interfaces."
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance SimulinkMotorControlModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model implementing the control logic for the permanent magnet synchronous motor, including closed-loop control algorithms and gearbox dynamics simulation."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance DigitalShadowDataStore : DTDFVocab:Data [
    base:desc "Structured data repository aggregating and abstracting raw sensor data traces (position, torque, temperature) from the physical system into time-series logs and event-based alerts for manufacturing monitoring purposes."
    DTDFVocab:fromData MotorPositionDataTransmitted, GearboxPositionDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Processed contextual data traces derived from raw sensor measurements, including operational health indicators, performance trends, and anomaly detection patterns for manufacturing decision support."
    DTDFVocab:fromData DigitalShadowDataStore
    DTDFVocab:inputTo VisualizationEnabler
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling tool enabling the creation and management of functional and logical architecture models (e.g., Internal Block Diagrams) for the MABI MAX 100 robot system."
    DTDFVocab:enables DigitalShadowMonitoringService, DigitalShadowVisualizationService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for behavioral modeling and simulation of the robot's motor control systems, including closed-loop dynamics and gearbox mechanics validation."
    DTDFVocab:enables DigitalShadowMonitoringService
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "Processing pipeline for aggregating and abstracting raw sensor data into structured contextual traces, implementing MQTT-based data ingestion and time-series database storage."
    DTDFVocab:enables DigitalShadowMonitoringService, DigitalShadowVisualizationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard visualization tool presenting aggregated metrics and performance trends to manufacturing stakeholders for diagnostic and observational purposes."
    DTDFVocab:enables DigitalShadowVisualizationService
]

// C6: Services
instance DigitalShadowMonitoringService : DTDFVocab:Service [
    base:desc "Passive data aggregation service collecting real-time contextual data traces from the physical robot system via one-way MQTT data flows, abstracting raw sensor measurements into structured operational logs."
    DTDFVocab:provides OperationalHealthInsight, PerformanceTrendInsight, AnomalyDetectionInsight
]

instance DigitalShadowVisualizationService : DTDFVocab:Service [
    base:desc "Read-only dashboard service presenting aggregated metrics and contextual data traces to manufacturing operators and analysts for diagnostic purposes, without enabling system intervention."
    DTDFVocab:provides ManufacturingDashboardInsight
]

// C17: Insights/Actions
instance OperationalHealthInsight : DTDFVocab:Insight [
    base:desc "Real-time operational health indicators derived from processed sensor data, including motor temperature, gearbox alignment status, and controller performance metrics for predictive maintenance."
]

instance PerformanceTrendInsight : DTDFVocab:Insight [
    base:desc "Historical performance trends analysis showing system efficiency, cycle time variations, and energy consumption patterns for capacity planning and process optimization."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Pattern recognition results identifying potential issues such as friction loss, misalignment, or component wear based on contextual data traces from the physical system."
]

instance ManufacturingDashboardInsight : DTDFVocab:Insight [
    base:desc "Visual representation of aggregated metrics and contextual data traces presented through a read-only dashboard interface for manufacturing stakeholders."
]

// C1: Environment
instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:desc "Industrial manufacturing environment where the MABI MAX 100 robot performs precision tasks such as assembly, welding, or material handling under real-time control from the Digital Shadow system."
    base:contains PermanentMagnetSynchronousMotor, CycloidalGearTransmission, SiemensSinumerik840DslController, MotorPositionEncoder, GearboxPositionEncoder
]

// C5: Components
instance RobotControlSystem : DTDFVocab:Component [
    base:desc "Modular component representing the integrated control system of the MABI MAX 100 robot, combining the Siemens Sinumerik 840Dsl controller with motor and gearbox actuation mechanisms for closed-loop operation."
    base:isContainedIn ManufacturingEnvironment
]

instance SensorFeedbackSystem : DTDFVocab:Component [
    base:desc "Modular component aggregating all sensing components (position encoders) and their data transmission mechanisms for providing real-time feedback to the control system."
    base:isContainedIn ManufacturingEnvironment
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system's temporal aspects are governed by the synchronization requirements between physical and digital components, which are implicitly derived from Model-Based Systems Engineering (MBSE) methodologies such as RFLP (Requirements, Functions, Logics, Physics), OOSEM, SPES, or SMArDT. These methodologies emphasize hierarchical abstraction levels (e.g., requirements, functional architecture, logical architecture, and product/technical layers), where temporal granularity is often defined by the underlying architecture description languages (ADLs) like SysML IBDs, AADL, or MontiArc. Behavior modeling in these frameworks may integrate with simulation tools (e.g., MathWorks Simulink) or general-purpose languages (e.g., C++, Java), which dictate synchronization frequencies and latency requirements. For instance, state machines in SysML v1.7 or MontiArc Automaton enforce discrete-time or event-driven temporal semantics, while continuous-time simulations (e.g., in Simulink) require precise time-step synchronization with physical systems. The Digital Shadow Reference Model (Kritzinger et al.) implies that one-way data flows between physical and digital entities necessitate low-latency aggregation and abstraction mechanisms, though explicit temporal scales (e.g., Hz, ms, or sampling intervals) are not specified in the provided documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system's orchestration and coordination are framed within MBSE frameworks, which leverage architecture description languages (ADLs) like SysML IBDs, AADL, or MontiArc to define component-based architectures with explicit connectors and composition rules. Integration patterns include combining ADLs with simulation tools (e.g., Simulink) or general-purpose languages (e.g., C++, Java) for behavior modeling. Resource management is implied through the hierarchical decomposition of models, where each layer (e.g., functional, logical, physical) may allocate resources (e.g., computational, memory) independently. System-wide coordination is facilitated by the aggregation of data traces in digital shadows, which require active software components (e.g., interpreters, processors) to handle one-way data flows. However, no specific orchestration patterns (e.g., microservices, event-driven architectures) or resource management frameworks (e.g., Kubernetes, Docker) are detailed in the documents."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "
The lifecycle of a Digital Twin (DT) system is structured through **Model-Based Systems Engineering (MBSE)** methodologies, encompassing distinct abstraction layers: **requirements, functional architecture, logical architecture, and product/technical layers**. These phases are governed by methodologies such as **RFLP (Requirements, Functions, Logics, Physics)**, **OOSEM**, **SPES**, or **SMArDT**, which systematically decompose system complexity. The lifecycle transitions between phases involve **architecture description languages (ADLs)** like **SysML (Systems Modeling Language)**, **ACME**, **AADL (Architecture Analysis & Design Language)**, and **MontiArc**, which define **component-connector perspectives** (e.g., interfaces, interconnections, and composition). Behavioral modeling is further refined using **SysML Internal Block Diagrams (IBDs)**, **MontiArc Automaton**, or **state machines in SysML v1.7**, often integrated with simulation tools like **MathWorks Simulink**, **general-purpose languages (C++, Java)**, or domain-specific simulation methods. Lifecycle governance ensures **heterogeneous stakeholder integration** (e.g., engineers, analysts, operators) via **interoperable modeling tools**, with explicit transition management between layers to maintain consistency and traceability. No explicit governance frameworks (e.g., ISO/IEC standards) are referenced in the document, but the lifecycle implicitly adheres to **MBSE best practices** for iterative refinement and validation.
"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
Model fidelity is ensured through **MBSE methodologies** (e.g., **RFLP, OOSEM, SPES, SMArDT**) that enforce **layered abstraction** from requirements to physical implementation. **Validation** is conducted via **MathWorks Simulink** simulations to verify expected behavior against **friction loss detection** and **control accuracy improvements**. **Uncertainty quantification** is implicitly addressed through **encoder-based feedback** to refine motor control parameters. **Error detection mechanisms** are embedded in the **SINUMERIK 840D sl** system for **real-time adjustments**, though explicit **predictive maintenance** or **anomaly detection algorithms** are not documented. **Quality assurance** relies on **closed-loop validation** between physical actuators and digital models, ensuring consistency across **functional and technical layers**.

"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The document does not provide explicit details on the **technical network infrastructure** for the Digital Twin system. It only mentions that **sensor data is streamed via MQTT**, without elaborating on communication protocols, network topology, bandwidth requirements, latency constraints, or security protocols. The text focuses on **modeling languages (e.g., SysML, ADLs)** and **system architecture (component-connector perspective)** but does not describe the underlying network architecture or connectivity mechanisms between physical and digital components."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "The Digital Twin system leverages the **Asset Administration Shell (AAS)** framework, as defined in the **Reference Architecture Model Industrie 4.0 (RAMI 4.0)**, to ensure **traceability of data origins** by explicitly linking both **physical asset models** (e.g., robotic systems like the MABI robot) and **generated data** (e.g., sensor readings, simulation outputs) to their source entities. While the documents do not explicitly detail **data ownership policies** (e.g., GDPR compliance, consent management, or anonymization techniques), the AAS structure inherently supports **structured metadata management**, including **data lineage** and **provenance tracking**, which can be extended to enforce governance. The **Digital Shadow** concept (as described in [42]) ensures that **real-time data synchronization** between physical assets and their digital counterparts maintains **auditability**, though explicit **data sharing agreements** or **privacy protection measures** (e.g., encryption at rest/transit) are not specified in the provided documents."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "
The provided documents highlight **safety-critical considerations** in Digital Twin systems through the **safety cell concept** (Document 44), where robotic systems like the **MABI Max-100 robotic arm** operate within predefined spatial and operational boundaries to mitigate physical risks. **Cybersecurity protocols** are not explicitly detailed, but **MQTT (Document 52)** is referenced as a communication protocol for **data streaming**, which—while not inherently secure—could be integrated with **TLS encryption** (though this is not mentioned). The **automation pyramid (Document 42)** describes **Digital Shadows** applied across hierarchical levels, implying **multi-layered security** (e.g., isolation of control vs. monitoring layers), though specific **authentication systems** (e.g., OAuth, biometrics) or **threat mitigation strategies** (e.g., intrusion detection) are absent. **Fail-safe mechanisms** are implied in robotic safety standards (e.g., emergency stop systems for MABI robots), but **risk assessment frameworks** (e.g., ISO 31000) or **safety-critical system certifications** (e.g., SIL/TL levels) are not documented. The **Functional Mockup Interface (FMI, Document 51)** is noted for **simulation model exchange**, but its role in **safety validation** or **security hardening** is not elaborated.
"
]