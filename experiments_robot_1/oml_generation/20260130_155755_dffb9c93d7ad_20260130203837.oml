// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor (PMSM) that provides actuation for the robot's first axis."
]

instance SiemensSinumerik840DCNCController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl CNC controller that issues motion commands (position, velocity, torque) over Ethernet and enforces safety via limit switches and interlocks."
]

// C3: Physical sensing components
instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted encoder directly on the PMSM shaft delivering high‑resolution position feedback."
    DTDFVocab:producedData EncoderPositionDataTransmitted
]

instance GearboxSecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located after the gearbox providing additional high‑resolution position feedback."
    DTDFVocab:producedData EncoderPositionDataTransmitted
]

// C4: Physical‑to‑virtual interaction
instance EncoderPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder, GearboxSecondaryEncoder
]

// C9: Data (time‑series)
instance PositionTimeSeriesData : DTDFVocab:Data [
    base:desc "Aggregated time‑series position data streamed via MQTT and used by both white‑box and black‑box models."
    DTDFVocab:fromData EncoderPositionDataTransmitted
    DTDFVocab:inputTo SimulationEngineEnabler, MLInferenceEnabler
]

// C10: Models/Data
instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based white‑box model realized as a Simulink dynamic simulation of the motor‑drive system."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance MachineLearningPredictiveModel : DTDFVocab:Model [
    base:desc "Data‑driven black‑box machine‑learning model that predicts performance metrics from sensor traces."
    DTDFVocab:inputTo MLInferenceEnabler
]

// C11: Enablers
instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Execution engine that runs physics‑based simulations (e.g., Simulink) on incoming data."
    DTDFVocab:enables DecisionSupportService
]

instance MLInferenceEnabler : DTDFVocab:Enabler [
    base:desc "Inference engine that evaluates machine‑learning models on streamed sensor data."
    DTDFVocab:enables DecisionSupportService
]

// C6: Services
instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Processing service that executes simulation or ML models on received data traces and produces higher‑level abstractions."
    DTDFVocab:provides PhysicalQuantityComputationInsight, SystemStateAssessmentInsight
]

// C17: Insights
instance PhysicalQuantityComputationInsight : DTDFVocab:Insight [
    base:desc "Computed physical quantities (e.g., torque, angular velocity) derived from raw sensor data via model execution."
]

instance SystemStateAssessmentInsight : DTDFVocab:Insight [
    base:desc "Assessment of the system state based on model outputs, enabling stakeholders to query provenance through ‘originates‑from’ relationships."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Shadow Reference Model specifies core concepts (Purpose, DataTrace, DataPoint, Metadata, Asset, Model) and their relationships. A concrete realization maps these reference classes to concrete elements via a conformance relation (e.g., class diagram mappings). At runtime, a Processing component consumes input DataTraces, executes the associated Model (simulation or data‑calculation), and produces output DataTraces that become part of the digital shadow. The 'originates‑from' association enables transitive traceability from generated traces back to the processing component, input traces, and models involved, thereby coordinating the flow of information within the Digital Twin system."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained through traceability from SysML requirements to Simulink simulation models and to the data‑driven ML models. Validation is performed by comparing simulated friction responses with measured sensor data, using deviation metrics to assess accuracy. Correctness of model transformations is verified with model‑based verification techniques, and sources of uncertainty such as sensor noise and model approximation are monitored to support quality assurance and corrective updates."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data are transmitted from the physical system to the digital shadow using the MQTT protocol. A dashboard component is used to visualise the received data. The documents do not specify network topology, bandwidth, latency requirements, redundancy mechanisms, or additional security protocols for the communication layer."
]