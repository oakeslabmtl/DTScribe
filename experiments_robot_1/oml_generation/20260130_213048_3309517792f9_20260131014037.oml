// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for measuring input current of the physical asset, data streamed continuously via MQTT."
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for measuring output angle of the physical asset, data streamed continuously via MQTT."
    DTDFVocab:producedData OutputAngleDataTransmitted
]

// C4: Physical-to-virtual interaction
instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

// C10: Models/Data
instance InputCurrentTelemetry : DTDFVocab:Data [
    base:desc "Telemetry stream for input current, obtained from the physical sensor via MQTT."
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo DataPreprocessor, ModelMapper
]

instance OutputAngleTelemetry : DTDFVocab:Data [
    base:desc "Telemetry stream for output angle, obtained from the physical sensor via MQTT."
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo DataPreprocessor, ModelMapper
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker handling one-way data flow from physical asset to digital twin."
    DTDFVocab:enables DataIntegrationService
]

instance DataPreprocessor : DTDFVocab:Enabler [
    base:desc "Preprocessor aligning timestamps and standardizing numeric types before aggregation."
    DTDFVocab:enables TelemetryProcessingService
]

instance SimulatorExecution : DTDFVocab:Enabler [
    base:desc "Executes MathWorks Simulink simulations representing behavioural aspects."
    DTDFVocab:enables SimulationService
]

instance CodeExecutor : DTDFVocab:Enabler [
    base:desc "Executes compiled C++/Java code for product-layer model validation."
    DTDFVocab:enables CodeExecutionService
]

instance ModelMapper : DTDFVocab:Enabler [
    base:desc "Maps hierarchical MBSE models (SysML IBDs, MontiArc Automata) to telemetry for traceability."
    DTDFVocab:enables DataIntegrationService
]

// C6: Services
instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Service orchestrating ingestion of telemetry via MQTT and preprocessing."
    DTDFVocab:provides RealTimeMonitoringInsight, ModelUpdateAction
]

instance TelemetryProcessingService : DTDFVocab:Service [
    base:desc "Service processing raw telemetry for real-time monitoring."
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service executing Simulink models for behavioral validation as part of MBSE."
    DTDFVocab:provides SimulationInsight
]

instance CodeExecutionService : DTDFVocab:Service [
    base:desc "Service executing C++/Java code for product-layer validation."
    DTDFVocab:provides CodeExecutionInsight
]

// C17: Insights/Actions
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Live monitoring of system state based on processed telemetry."
]

instance ModelUpdateAction : DTDFVocab:Action [
    base:desc "Updates logical and product layer models with new telemetry data."
    DTDFVocab:IsAutomatic true
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Results and diagnostics from Simulink simulation."
]

instance CodeExecutionInsight : DTDFVocab:Insight [
    base:desc "Output and validation results from executing compiled C++/Java code."
]

// C10: Additional Models
instance RequirementModel : DTDFVocab:Model [
    base:desc "Requirements level specification for the digital twin."
    DTDFVocab:inputTo ModelMapper
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "Functional architecture described using MontiArc Automaton and SysML state machines."
    DTDFVocab:inputTo ModelMapper
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Logical architecture expressed via SysML IBDs and ADLs."
    DTDFVocab:inputTo ModelMapper
]

instance ProductLayerModel : DTDFVocab:Model [
    base:desc "Product-layer model realized in C++/Java code."
    DTDFVocab:inputTo CodeExecutor, SimulatorExecution
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "Behavioral model implemented in MathWorks Simulink."
    DTDFVocab:inputTo SimulatorExecution
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "Architectural model expressed in MontiArc Automaton."
    DTDFVocab:inputTo ModelMapper
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Development of a Digital Twin is carried out through Model‑Based Systems Engineering (MBSE) using SysML and other modeling notations. The process is divided into nested abstraction levels—requirements, functional architecture, logical architecture, and product/technical layers—each level building on the previous one. Transition between phases is managed by cascading models: refined requirements inform functional design, which in turn guides logical design and finally the product/technical realization. Governance across lifecycle stages is implicitly supported by standard MBSE practices such as RFLP, OOSEM, SPES and SMArDT, and by tool chains including MathWorks Simulink for simulation and MontiArc for automaton modeling."
]