// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) measuring the stator current of the permanent‑magnet synchronous motor."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Proximal motor encoder providing angular position measurements of the rotor."
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Remote gearbox encoder providing angular position measurements of the cycloidal gearbox output."
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance AngularPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Dedicated angular position encoder capturing the absolute position of the rotary axis."
    DTDFVocab:producedData AngularPositionDataTransmitted
]

instance DerivedTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Derived torque sensor computed from current and position measurements to obtain torque (τ)."
    DTDFVocab:producedData DerivedTorqueDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Derived angular velocity sensor providing ω, calculated from successive position samples."
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

instance AccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Derived acceleration sensor providing α, obtained from differentiating velocity."
    DTDFVocab:producedData AccelerationDataTransmitted
]

// C4: Physical-to-virtual interaction
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance AngularPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularPositionEncoder
]

instance DerivedTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DerivedTorqueSensor
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

instance AccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AccelerationSensor
]

// C10: Models/Data (measured)
instance MeasuredCurrentData : DTDFVocab:Data [
    base:desc "Array of measured motor currents (I_M) over time τ, transmitted via MQTT."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo ProcessingComponent
]

instance MeasuredMotorPositionData : DTDFVocab:Data [
    base:desc "Array of measured motor angular positions (r_M) over time τ, transmitted via MQTT."
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo ProcessingComponent
]

instance MeasuredGearboxPositionData : DTDFVocab:Data [
    base:desc "Array of measured gearbox angular positions (r_G) over time τ, transmitted via MQTT."
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo ProcessingComponent
]

instance MeasuredAngularVelocityData : DTDFVocab:Data [
    base:desc "Array of measured angular velocities (ω) over time τ, transmitted via MQTT."
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo ProcessingComponent
]

instance MeasuredAccelerationData : DTDFVocab:Data [
    base:desc "Array of measured accelerations (α) over time τ, transmitted via MQTT."
    DTDFVocab:fromData AccelerationDataTransmitted
    DTDFVocab:inputTo ProcessingComponent
]

instance MeasuredTorqueData : DTDFVocab:Data [
    base:desc "Array of derived torque (τ) measurements over time τ, transmitted via MQTT."
    DTDFVocab:fromData DerivedTorqueDataTransmitted
    DTDFVocab:inputTo ProcessingComponent
]

// C10: Models/Data (simulated)
instance SimulatedMotorTorqueData : DTDFVocab:Data [
    base:desc "Simulated motor torque (τ̂_M) generated by the MotorDynamicsModel."
    DTDFVocab:inputTo ProcessingComponent
]

instance SimulatedGearboxTorqueData : DTDFVocab:Data [
    base:desc "Simulated gearbox torque (τ̂_G) generated by the GearboxDynamicsModel."
    DTDFVocab:inputTo ProcessingComponent
]

instance SimulatedOutputTorqueData : DTDFVocab:Data [
    base:desc "Simulated output torque (τ̂_out) from the combined motor‑gearbox system."
    DTDFVocab:inputTo ProcessingComponent
]

instance SimulatedMotorVelocityData : DTDFVocab:Data [
    base:desc "Simulated motor angular velocity (ω̂_M) generated by the MotorDynamicsModel."
    DTDFVocab:inputTo ProcessingComponent
]

instance SimulatedGearboxVelocityData : DTDFVocab:Data [
    base:desc "Simulated gearbox angular velocity (ω̂_G) generated by the GearboxDynamicsModel."
    DTDFVocab:inputTo ProcessingComponent
]

instance SimulatedOutputVelocityData : DTDFVocab:Data [
    base:desc "Simulated output velocity (ω̂_out) of the rotary axis."
    DTDFVocab:inputTo ProcessingComponent
]

// C10: Models
instance StructuralSysMLModel : DTDFVocab:Model [
    base:desc "SysML structural model of MABI MAX 100 robot rotary axis including motor, gearwheel, cycloidal gearbox, and encoders."
    DTDFVocab:inputTo ProcessingComponent
]

instance MotorDynamicsModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model of permanent‑magnet synchronous motor dynamics."
    DTDFVocab:inputTo ProcessingComponent
]

instance GearboxDynamicsModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model of cycloidal gearbox dynamics."
    DTDFVocab:inputTo ProcessingComponent
]

instance FrictionModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink white‑box friction models (Coulomb‑Viscous, Stribeck, Dahl, LuGre)."
    DTDFVocab:inputTo ProcessingComponent
]

instance ReferenceModel : DTDFVocab:Model [
    base:desc "Reference model linking structural SysML model to dynamic simulation models."
    DTDFVocab:inputTo ProcessingComponent
]

// C11: Enablers
instance ProcessingComponent : DTDFVocab:Enabler [
    base:desc "Processing component consuming sensor streams and simulation models, producing processed traces."
    DTDFVocab:enables RealTimeDashboardService, FrictionIdentificationService, ModelRefinementService
]

// C6: Services
instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Real‑time visualization dashboard providing trend plots of measured vs simulated torque and velocity."
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous friction model identification service implementing white‑box and black‑box methods."
    DTDFVocab:provides FrictionLossDetectionInsight, RealTimeParameterUpdateInsight
]

instance ModelRefinementService : DTDFVocab:Service [
    base:desc "Data‑driven model refinement service to improve motion accuracy of the robotic axis."
    DTDFVocab:provides ControllerTuningRecommendationInsight, MaintenanceScheduleRecommendationInsight, ToolExchangeDecisionInsight
]

// C17: Insights
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight showing real‑time comparison between measured and simulated torque and velocity."
]

instance FrictionLossDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting friction loss and dynamics from model‑based residuals."
]

instance RealTimeParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time updates to white‑box model parameters."
]

instance ControllerTuningRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight offering recommendations for controller tuning based on friction identification."
]

instance MaintenanceScheduleRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting maintenance schedules inferred from friction trends."
]

instance ToolExchangeDecisionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating when tool exchange decisions should be considered."
]

// C17: Actions
instance UpdateControllerTuningAction : DTDFVocab:Action [
    base:desc "Automatic action to update controller parameters according to real‑time friction model updates."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time acquisition and processing of live sensor data synchronized with the robot’s operation; no fixed sampling period is specified in the document, only that data is streamed via MQTT and processed in near real‑time."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A passive digital shadow comprising a data acquisition layer (MQTT), a processing layer (Simulink simulations and model calculations), a semantic layer (AAS linking models and traces), and a presentation layer (dashboard), orchestrated to provide a single coherent view of friction behavior on the first robot axis."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design/ideal engineering model (structural and behavioral), Manufacturing (parameter acquisition), Operational (live data integration and continuous identification), followed by iterative refinement of the friction models during runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of every data point to its source (sensor, simulation, calculation), comparison of simulated vs measured time‑series for validation, continuous identification of friction parameters to adapt to wear, temperature, and load changes, and semantic linking via AAS ensuring model validity across life‑cycle stages."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol used to transmit sensor data streams from the robot’s controllers to the digital shadow; Asset Administration Shell (AAS) instances provide semantic descriptions and enable further integration."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for modeling, MQTT protocol, Asset Administration Shell (AAS) as open standard; no ISO/IEC numbers explicitly cited."
]