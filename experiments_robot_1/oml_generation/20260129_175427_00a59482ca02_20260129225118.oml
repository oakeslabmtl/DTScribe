    DTDFVocab:fromData JavaCodeDataTransmitted
    DTDFVocab:inputTo JavaProgrammingEnabler
]

instance StakeholderPerspectiveData : DTDFVocab:Data [
    base:desc "Data aggregated from heterogeneous stakeholder perspectives"
    DTDFVocab:fromData StakeholderPerspectiveDataTransmitted
    DTDFVocab:inputTo SysMLMethodologyEnabler, RFLPMethodologyEnabler, OOSEMMethodologyEnabler, SPESMethodologyEnabler, SMArDTMethodologyEnabler, ACMEADLEnabler, AADLADLEnabler, MontiArcADLEnabler, SysMLIBDADLEnabler, MontiArcAutomatonEnabler, SysMLStateMachinesEnabler, SimulinkIntegrationEnabler, CppProgrammingEnabler, JavaProgrammingEnabler
]

instance SysMLStructuralDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLStructuralModel
]

instance ACMEArchitectureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ACMEArchitectureModel
]

instance AADLArchitectureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AADLArchitectureModel
]

instance MontiArcArchitectureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MontiArcArchitectureModel
]

instance SysMLIBDDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLIBDModel
]

instance MontiArcBehavioralDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MontiArcAutomatonModel
]

instance SysMLStateMachinesDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLStateMachinesModel
]

instance SimulinkSimulationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkModel
]

instance CppCodeDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CppCodeModel
]

instance JavaCodeDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JavaCodeModel
]

instance StakeholderPerspectiveDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ModelRepository
]

instance ModelRepository : DTDFVocab:Component [
    base:desc "Integrated model repository for managing heterogeneous modeling tools and stakeholder perspectives"
]

instance SysMLMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "MBSE methodology SysML for system complexity management"
    DTDFVocab:enables DetailedBehaviorDescriptionService
]

