instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML model for structural modeling across requirements, functional, logical, and product/technical abstraction levels"
    DTDFVocab:inputTo SysMLMethodologyEnabler, SysMLIBDADLEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME architecture description for component interfaces and composition"
    DTDFVocab:inputTo ACMEADLEnabler
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL architecture description for component interfaces and composition"
    DTDFVocab:inputTo AADLADLEnabler
]

instance MontiArcArchitectureModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description for component interfaces and composition"
    DTDFVocab:inputTo MontiArcADLEnabler
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams for component interfaces and composition"
    DTDFVocab:inputTo SysMLIBDADLEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcAutomatonEnabler
]

instance SysMLStateMachinesModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines for behavioral modeling"
    DTDFVocab:inputTo SysMLStateMachinesEnabler
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for detailed behavior description"
    DTDFVocab:inputTo SimulinkIntegrationEnabler
]

instance CppCodeModel : DTDFVocab:Model [
    base:desc "C++ code for detailed behavior description"
    DTDFVocab:inputTo CppProgrammingEnabler
]

instance JavaCodeModel : DTDFVocab:Model [
    base:desc "Java code for detailed behavior description"
    DTDFVocab:inputTo JavaProgrammingEnabler
]

instance SysMLStructuralData : DTDFVocab:Data [
    base:desc "Structural data from SysML modeling across abstraction levels"
    DTDFVocab:fromData SysMLStructuralDataTransmitted
    DTDFVocab:inputTo SysMLMethodologyEnabler
]

instance ACMEArchitectureData : DTDFVocab:Data [
    base:desc "ACME architecture data for component interfaces and composition"
    DTDFVocab:fromData ACMEArchitectureDataTransmitted
    DTDFVocab:inputTo ACMEADLEnabler
]

