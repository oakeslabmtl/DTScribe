    DTDFVocab:fromData MontiArcBehavioralDataTransmitted
    DTDFVocab:inputTo MontiArcAutomatonEnabler
]

instance SysMLStateMachinesData : DTDFVocab:Data [
    base:desc "SysML v1.7 state machines behavioral data"
    DTDFVocab:fromData SysMLStateMachinesDataTransmitted
    DTDFVocab:inputTo SysMLStateMachinesEnabler
]

