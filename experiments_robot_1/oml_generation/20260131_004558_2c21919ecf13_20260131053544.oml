// Components
instance MABIMax100FirstRotaryAxis : DTDFVocab:Component [
    base:desc "First rotary axis of the MABI MAX 100 industrial robot comprising a permanent‑magnet synchronous motor, a gear wheel gearbox and a cycloidal gearbox."
]

instance SynchronisedPMMotor : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor driving the rotary axis."
]

instance GearWheelGearbox : DTDFVocab:Component [
    base:desc "Gear wheel gearbox connecting the motor to the cycloidal gearbox."
]

instance CycloidalGearbox : DTDFVocab:Component [
    base:desc "Cycloidal gearbox providing the final drive to the axis."
]

instance IntegratedSystem : DTDFVocab:Component [
    base:desc "Integrated system comprising motor, gear wheel gearbox and cycloidal gearbox."
]

// Sensing Components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) providing input current via MQTT stream."
    DTDFVocab:producedData MotorCurrentTransmission
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder per axis providing output angle via MQTT stream."
    DTDFVocab:producedData MotorEncoderTransmission
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary gearbox encoder providing output angle via MQTT stream."
    DTDFVocab:producedData GearboxEncoderTransmission
]

// Data Transmitted
instance MotorCurrentTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// Measured Data (derived from sensor streams)
instance MotorTorqueMeasured : DTDFVocab:Data [
    base:desc "Measured motor torque derived from motor current."
    DTDFVocab:fromData MotorCurrentTransmission
    DTDFVocab:inputTo MathProcessingEnabler
]

instance MotorVelocityMeasured : DTDFVocab:Data [
    base:desc "Measured motor angular velocity derived from motor encoder."
    DTDFVocab:fromData MotorEncoderTransmission
    DTDFVocab:inputTo MathProcessingEnabler
]

instance MotorAccelerationMeasured : DTDFVocab:Data [
    base:desc "Measured motor angular acceleration derived from motor encoder."
    DTDFVocab:fromData MotorEncoderTransmission
    DTDFVocab:inputTo MathProcessingEnabler
]

// Simulated Data (generated by simulation models)
instance MotorTorqueSimulated : DTDFVocab:Data [
    base:desc "Simulated motor torque generated by MATLAB/Simulink model."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance MotorVelocitySimulated : DTDFVocab:Data [
    base:desc "Simulated motor angular velocity generated by MATLAB/Simulink model."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance MotorAccelerationSimulated : DTDFVocab:Data [
    base:desc "Simulated motor angular acceleration generated by MATLAB/Simulink model."
    DTDFVocab:inputTo SimulationEngineEnabler
]

// Friction Parameter Update Data
instance FrictionParametersUpdated : DTDFVocab:Data [
    base:desc "Updated friction parameters derived from continuous identification."
    DTDFVocab:inputTo MathProcessingEnabler
]

// Simulation Models
instance MotorSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the permanent‑magnet synchronous motor with Coulomb‑Viscous friction."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance GearBoxSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the gear wheel gearbox including Stribeck friction."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance CycloidalGearboxSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the cycloidal gearbox with Dahl friction."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance SystemSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the complete axis system with LuGre friction."
    DTDFVocab:inputTo SimulationEngineEnabler
]

// Enablers
instance MQTTClientEnabler : DTDFVocab:Enabler [
    base:desc "MQTT client handling real‑time sensor streams from the robotic base."
    DTDFVocab:enables DataAggregationService, RealTimeDashboardService
]

instance MathProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing component computing derived quantities and performing friction identification."
    DTDFVocab:enables FrictionIdentificationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink simulation engine running the asset models."
    DTDFVocab:enables SimulationDataProductionService
]

// Services
instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Real‑time dashboard displaying measured and simulated motor data."
    DTDFVocab:provides MotorMeasuredDataInsight, MotorSimulatedDataInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous friction identification service subtracting measured from simulated values."
    DTDFVocab:provides FrictionParameterUpdatedInsight, UpdateControllerAction
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Aggregates and abstracts sensor data for analysis."
    DTDFVocab:provides DataArchivalInsight
]

instance SimulationDataProductionService : DTDFVocab:Service [
    base:desc "Service that provides simulated data streams to the dashboard."
    DTDFVocab:provides MotorSimulationDataInsight
]

// Insights
instance MotorMeasuredDataInsight : DTDFVocab:Insight [
    base:desc "Visualization of measured motor torque, velocity, and acceleration."
]

instance MotorSimulatedDataInsight : DTDFVocab:Insight [
    base:desc "Visualization of simulated motor torque, velocity, and acceleration."
]

instance FrictionParameterUpdatedInsight : DTDFVocab:Insight [
    base:desc "Display of updated friction parameters after identification."
]

instance DataArchivalInsight : DTDFVocab:Insight [
    base:desc "Insight into aggregated historical sensor data for trend analysis."
]

instance MotorSimulationDataInsight : DTDFVocab:Insight [
    base:desc "Insight into simulated motor data streams fed into the dashboard."
]

// Action
instance UpdateControllerAction : DTDFVocab:Action [
    base:desc "Automatic update of bot controller parameters with new friction model."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time operation during robot execution; data streams and simulation models run synchronously with physical operation, enabling on‑the‑fly friction model identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration of component models and data traces in a digital shadow: AAS defines asset and models; processing component consumes sensor data, runs simulation models, produces simulated outputs, and feeds a unified dashboard; all interfaces described by the digital shadow reference model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital shadow covers the operated phase of the first axis; the models represent the manufactured robot and are used during runtime operation for monitoring and identification."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of each data point back to its source via AAS; comparison of simulated frictionless behavior with measured data for validation; continuous identification ensures model adaption to wear and operating conditions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol for live data streams between PT and DT; Asset Administration Shells define data contracts; data traces linked to models via AAS associations."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Followed standards and frameworks include SysML for modeling, MBSE practice, AADL/ACME for architecture descriptions, and Asset Administration Shells (AAS) for digital asset representation."
]