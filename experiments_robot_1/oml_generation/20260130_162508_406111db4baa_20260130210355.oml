// C3: Physical sensing components
instance JointStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing the six‑axis robot joint positions and velocities for the first vertical axis"
    DTDFVocab:producedData JointStateDataTransmitted
]

instance FrictionForceSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring joint friction forces on the first vertical axis"
    DTDFVocab:producedData FrictionForceDataTransmitted
]

// C4: Physical-to-virtual interaction
instance JointStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointStateSensor
]

instance FrictionForceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FrictionForceSensor
]

// C10: Data
instance JointStateData : DTDFVocab:Data [
    base:desc "Aggregated robot state traces (positions, velocities) from the physical robot"
    DTDFVocab:fromData JointStateDataTransmitted
    DTDFVocab:inputTo SimulinkEngine, CodeGeneratorCPP
]

instance FrictionMeasurementData : DTDFVocab:Data [
    base:desc "Aggregated friction measurement traces from the joint"
    DTDFVocab:fromData FrictionForceDataTransmitted
    DTDFVocab:inputTo MLRuntime
]

// C10: Models/Data (models)
instance RobotDynamicsSimulinkModel : DTDFVocab:Model [
    base:desc "White‑box Simulink dynamic simulation of the robot mechanics, gearbox, and motor for the first vertical axis"
    DTDFVocab:inputTo SimulinkEngine
]

instance FrictionMLLatentModel : DTDFVocab:Model [
    base:desc "Black‑box machine‑learning latent‑variable model predicting friction based on historical measurements"
    DTDFVocab:inputTo MLRuntime
]

// C11: Enablers
instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink runtime executing the RobotDynamicsSimulinkModel"
    DTDFVocab:enables RealTimeFrictionIdentificationService
]

instance MLRuntime : DTDFVocab:Enabler [
    base:desc "Machine‑learning runtime (e.g., TensorFlow) executing the FrictionMLLatentModel"
    DTDFVocab:enables AnomalyDetectionService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for semantic data exchange via OPC‑UA"
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating one‑way data streaming from the physical robot to the digital twin"
]

instance CodeGeneratorCPP : DTDFVocab:Enabler [
    base:desc "Model‑driven C++ code generator for simulation and data‑processing pipelines"
    DTDFVocab:enables PerformanceOptimizationService
]

instance DashboardApp : DTDFVocab:Enabler [
    base:desc "Java‑based dashboard application visualising sensor streams and friction trends"
    DTDFVocab:enables DashboardVisualizationService, PredictiveMaintenanceService
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous multi‑physics aware identification of joint friction to improve robot motion accuracy"
    DTDFVocab:provides FrictionTrendInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Detects anomalies in friction measurements and robot state"
    DTDFVocab:provides DiagnosticExplanationAction
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualisation of sensor streams and friction trends on operator dashboard"
    DTDFVocab:provides FrictionTrendInsight
]

instance PerformanceOptimizationService : DTDFVocab:Service [
    base:desc "Optimises robot motion parameters based on identified friction trends"
    DTDFVocab:provides OptimizationRecommendationAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predicts maintenance needs using friction trend analysis"
    DTDFVocab:provides MaintenanceAlertAction
]

// C17: Insights/Actions
instance FrictionTrendInsight : DTDFVocab:Insight [
    base:desc "Insight into evolving friction values indicating wear and affecting motion accuracy"
]

instance DiagnosticExplanationAction : DTDFVocab:Action [
    base:desc "Explains causes of detected data changes in friction or robot state"
    DTDFVocab:IsAutomatic true
]

instance OptimizationRecommendationAction : DTDFVocab:Action [
    base:desc "Recommends parameter adjustments to improve motion accuracy based on friction trends"
    DTDFVocab:IsAutomatic false
]

instance MaintenanceAlertAction : DTDFVocab:Action [
    base:desc "Generates maintenance alerts when friction exceeds predefined thresholds"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "According to the digital shadow reference model, the digital shadow does not include any control or feedback loop toward the physical system; it functions as a passive entity that never pushes data or commands back to the physical object."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is organized according to the Digital Shadow Reference Model, which adopts a component‑and‑connector perspective (as used in ADLs such as ACME, AADL, MontiArc and SysML internal block diagrams). Core elements are Processing components that consume input data traces, invoke engineering, simulation or data‑calculation models, and emit output data traces that become part of the digital shadow. The model captures associations like ‘originates‑from’ that preserve transitive traceability from each data trace back to the generating processing component, the input traces consumed and the models involved. Concretization is performed by mapping concrete classes and relations to the abstract reference concepts, enabling integration of heterogeneous tools (e.g., Simulink, C++, Java) and supporting fine‑grained traceability across the full system."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The development lifecycle described in the documents follows the typical MBSE abstraction hierarchy: a requirements stage, a functional‑architecture stage, a logical‑architecture stage, and a product/technical (implementation) stage. Models are created with SysML (including internal block diagrams and state machines) and refined through architecture description languages such as ACME, AADL or MontiArc. Transition between stages is managed by a conformance relation defined in the Digital‑Shadow Reference Model, whereby abstract reference concepts are incarnated into concrete classes and associations (mapping of incarnations to reference concepts). Lifecycle governance is achieved by enforcing this conformance and by maintaining traceability of data traces through the “originates‑from” association from processing components to input traces and models."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is linked to the correctness of both the white‑box simulation and the black‑box learning models; reliability depends on accurate transformations from SysML specifications to simulation or code artifacts. The documentation stresses traceability of data and model transformations as a means of verification, and highlights the need to quantify uncertainties arising from model approximations and data inaccuracies. Quality assurance is achieved through verification of model‑to‑simulation (and model‑to‑code) transformations and by ensuring that the combined hybrid model yields improved accuracy for friction representation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The documents reference the MQTT protocol (Mosquitto) as a communication mechanism for streaming sensor data, implying that MQTT may be used for the one‑way data transmission from physical to virtual. No additional information on network topology, bandwidth, latency, redundancy, or security protocols is provided in the source material."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on established modeling standards: SysML (an OMG standard) is used for requirements, functional and logical architecture models; UML class diagrams are employed for the Digital Shadow Reference Model; and architecture description languages such as ACME, AADL and MontiArc provide standardized component‑connector specifications. Conformance relations and mappings between the reference model and concrete incarnations ensure that all models adhere to these standards, supporting interoperability within the MBSE ecosystem."
]