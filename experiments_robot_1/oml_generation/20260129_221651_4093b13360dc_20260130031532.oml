// Sensing Component
instance TelemetryStreamSensor : DTDFVocab:SensingComponent [
    base:desc "Telemetry producer for video‑time‑series or telemetry streams feeding the state variables of behavioral models"
    DTDFVocab:producedData TelemetryDataArray
]

// Data Transmitted
instance TelemetryDataArray : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TelemetryStreamSensor
]

// Data
instance TelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data stream used as input to behavioral and simulation models"
    DTDFVocab:inputTo SimulinkExecutionEnabler, CppCodeGenerationEnabler
    DTDFVocab:fromData TelemetryDataArray
]

// Models
instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model capturing contingency logic and control flows"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state‑machine model representing control flows"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance SimulinkContinuousModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for continuous‑time simulation of system dynamics"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance SimulinkCoSimulationModel : DTDFVocab:Model [
    base:desc "Simulink co‑simulation model linking to hardware‑in‑the‑loop contexts"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

// Enablers
instance SimulinkExecutionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler to run MathWorks Simulink simulations and co‑simulations"
    DTDFVocab:enables SimulationService
]

instance CppCodeGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for generating C++ executable code from high‑level models"
    DTDFVocab:enables CodeGenerationService
]

// Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Service providing simulation results and continuous‑time behavior insights"
    DTDFVocab:provides ContinuousBehaviorInsight
]

instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Service generating executable C++ code and configuration for control software"
    DTDFVocab:provides ExecutableCodeInsight
]

// Insights
instance ContinuousBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight into continuous‑time behavior derived from Simulink simulation"
]

instance ExecutableCodeInsight : DTDFVocab:Insight [
    base:desc "Insight into generated executable C++ code for deployment"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital Twin lifecycle is structured around four principal abstraction levels—requirements, functional architecture, logical architecture, and product/technical layer—identified within the MBSE framework. Each level leverages specific modeling notations: SysML supports functional and logical architecture descriptions, while component–connector perspectives are captured using architecture description languages such as ACME, AADL, or MontiArc. Behavior refinement at the logical level is realized through state machine constructs in SysML v1.7 or MontiArc Automaton extensions. To transition from architecture to implementation, models are integrated with simulation tools (e.g., MathWorks Simulink) and code generators targeting general‑purpose languages like C++ or Java, ensuring traceability and governance throughout all lifecycle stages."
]