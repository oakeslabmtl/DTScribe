// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring real-time motor current from the physical system, streamed via MQTT"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance JointAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring joint angle of the robot, streamed via MQTT"
    DTDFVocab:producedData JointAngleDataTransmitted
]

// C4: Physical-to-virtual interaction
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance JointAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointAngleSensor
]

// C10: Data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series motor current measurements received from MotorCurrentSensor"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkEngine, DataProcessingEngine
]

instance JointAngleData : DTDFVocab:Data [
    base:desc "Time‑series joint angle measurements received from JointAngleSensor"
    DTDFVocab:fromData JointAngleDataTransmitted
    DTDFVocab:inputTo SimulinkEngine, DataProcessingEngine
]

instance AggregatedSensorData : DTDFVocab:Data [
    base:desc "Aggregated contextual data trace combining current and angle measurements for purpose‑driven analysis"
    DTDFVocab:fromData MotorCurrentDataTransmitted, JointAngleDataTransmitted
    DTDFVocab:inputTo DataAggregationEngine
]

// C10: Models/Data
instance SimulinkFrictionModel : DTDFVocab:Model [
    base:desc "Physics‑based white‑box dynamic model of joint friction implemented in MathWorks Simulink"
    DTDFVocab:inputTo SimulinkEngine
]

instance MachineLearningFrictionRegressor : DTDFVocab:Model [
    base:desc "Black‑box machine‑learning regressor trained on sensor traces to estimate robot friction"
    DTDFVocab:inputTo MachineLearningEngine
]

instance MontiArcBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioural specification model expressed as MontiArc Automaton"
    DTDFVocab:inputTo MontiArcEngine
]

instance SysMLArchitectureModel : DTDFVocab:Model [
    base:desc "SysML architecture description (requirements, functional and logical blocks) defining components and connectors"
    DTDFVocab:inputTo DataAggregationEngine
]

// C11: Enablers
instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation engine executing white‑box physics models"
    DTDFVocab:enables FrictionIdentificationService
]

instance MachineLearningEngine : DTDFVocab:Enabler [
    base:desc "Inference engine executing the machine‑learning friction regressor"
    DTDFVocab:enables WearDiagnosticsService
]

instance MontiArcEngine : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton runtime executing behavioural automata"
    DTDFVocab:enables MotorMonitoringService
]

instance DataAggregationEngine : DTDFVocab:Enabler [
    base:desc "Component that aggregates sensor traces for purpose‑driven analysis"
    DTDFVocab:enables VisualizationService
]

instance DataProcessingEngine : DTDFVocab:Enabler [
    base:desc "General‑purpose processing engine handling real‑time data streams for monitoring and diagnostics"
    DTDFVocab:enables MotorMonitoringService, WearDiagnosticsService
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuously identifies joint friction through multi‑physics aware data analysis"
    DTDFVocab:provides FrictionParameterInsight, UpdateFrictionModel
]

instance MotorMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of motor currents and torques"
    DTDFVocab:provides CurrentTorqueInsight, AlertHighCurrent
]

instance WearDiagnosticsService : DTDFVocab:Service [
    base:desc "Predictive diagnostics of wear based on learned friction parameters"
    DTDFVocab:provides WearPredictionInsight, ScheduleMaintenance
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualizes identified parameters and system state in a unified dashboard for operators and engineers"
    DTDFVocab:provides SystemStateVisualizationInsight, RenderDashboard
]

// C17: Insights
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Insight into the currently estimated joint friction coefficients"
]

instance CurrentTorqueInsight : DTDFVocab:Insight [
    base:desc "Insight into instantaneous motor current and torque values"
]

instance WearPredictionInsight : DTDFVocab:Insight [
    base:desc "Insight predicting component wear based on friction trends"
]

instance SystemStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight representing overall system state for the operator dashboard"
]

// C17: Actions
instance UpdateFrictionModel : DTDFVocab:Action [
    base:desc "Automatically updates the friction model parameters in the digital twin"
    DTDFVocab:IsAutomatic true
]

instance AlertHighCurrent : DTDFVocab:Action [
    base:desc "Triggers an alarm when motor current exceeds safety threshold"
    DTDFVocab:IsAutomatic false
]

instance ScheduleMaintenance : DTDFVocab:Action [
    base:desc "Generates a maintenance work order based on predicted wear"
    DTDFVocab:IsAutomatic false
]

instance RenderDashboard : DTDFVocab:Action [
    base:desc "Renders the unified dashboard visualizing system parameters"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is characterized as a passive entity that neither operates autonomously nor pushes data back to the physical system; therefore no virtual‑to‑physical control flow, command issuance, or feedback loop is defined."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the MBSE hierarchy described in the paper: early development uses requirement‑level models, followed by functional‑architecture models, then logical‑architecture models, and finally product/technical‑layer models. At each stage the representation is instantiated with appropriate modeling notations (e.g., SysML requirement diagrams, SysML block definition and internal‑block diagrams, ADL component‑connector specifications such as ACME or AADL, and simulation models in Simulink). Transition between stages is managed by a conformance mapping that links concrete model elements to the corresponding abstract concepts of the Digital Shadow Reference Model, thereby providing traceability and governance through the reference‑model conformance relation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The fidelity of a digital shadow is tied to the correctness of its underlying models and the transformations applied to the data. The approach stresses traceability from high‑level SysML specifications down to simulation or data‑driven models, and verification of model transformations (e.g., SysML → Simulink). Validation is performed by comparing model outputs with the aggregated contextual data traces; any divergence triggers model correction. Thus, explicit traceability links and verification steps are employed to ensure that both white‑box physics simulations and black‑box data models remain accurate representations of the physical system."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection between the physical asset and its digital shadow relies on MQTT as the communication protocol. Sensor time‑series are published by the physical devices and subscribed to by the digital twin components, using MQTT’s lightweight publish/subscribe mechanism over TCP/IP to transport the data from the physical layer to the virtual model."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Data from the physical system is streamed using the MQTT protocol and the twin is realized as an Asset Administration Shell (AAS), providing a standardized interface for exchange with external services. These mechanisms constitute the horizontal integration layer, enabling interoperability with other enterprise systems that support MQTT or AAS, without further elaborated integration patterns."
]