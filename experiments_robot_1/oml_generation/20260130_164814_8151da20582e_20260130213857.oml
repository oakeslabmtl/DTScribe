// ---------------------------------------------------
// C3: Physical sensing components
// ---------------------------------------------------
instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted on the motor, providing motor shaft angle (r_M)"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the gearbox, providing gearbox output angle (r_G)"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance CurrentSensorIm : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring input motor current I_M"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Angle sensor providing the final output shaft angle (r_out)"
    DTDFVocab:producedData OutputAngleDataTransmitted
]

// ---------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// ---------------------------------------------------
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensorIm
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

// ---------------------------------------------------
// C10: Data
// ---------------------------------------------------
instance MotorEncoderAngleData : DTDFVocab:Data [
    base:desc "Time‑series of motor shaft angle r_M streamed via MQTT"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkTool
]

instance GearboxEncoderAngleData : DTDFVocab:Data [
    base:desc "Time‑series of gearbox encoder angle r_G streamed via MQTT"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkTool
]

instance InputCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor input current I_M streamed via MQTT"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkTool
]

instance OutputShaftAngleData : DTDFVocab:Data [
    base:desc "Time‑series of final output shaft angle r_out streamed via MQTT"
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkTool
]

// ---------------------------------------------------
// C10: Models / Engineering & Simulation
// ---------------------------------------------------
instance AxisSysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML block definition diagram of the first robot axis (motor, gearbox, cycloidal gearbox)"
    DTDFVocab:inputTo SysMLTool
]

instance MotorSysMLBlockModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram of the motor sub‑assembly"
    DTDFVocab:inputTo SysMLTool
]

instance GearboxSysMLBlockModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram of the gearwheel and gearbox sub‑assembly"
    DTDFVocab:inputTo SysMLTool
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the motor dynamics"
    DTDFVocab:inputTo SimulinkTool
]

instance SimulinkGearboxFrictionModel_CoulombViscous : DTDFVocab:Model [
    base:desc "Simulink friction model implementing Coulomb‑Viscous friction for the gearbox"
    DTDFVocab:inputTo SimulinkTool
]

instance SimulinkGearboxFrictionModel_Stribeck : DTDFVocab:Model [
    base:desc "Simulink friction model implementing the Stribeck effect for the gearbox"
    DTDFVocab:inputTo SimulinkTool
]

instance SimulinkGearboxFrictionModel_Dahl : DTDFVocab:Model [
    base:desc "Simulink friction model implementing Dahl friction for the gearbox"
    DTDFVocab:inputTo SimulinkTool
]

instance SimulinkGearboxFrictionModel_LuGre : DTDFVocab:Model [
    base:desc "Simulink friction model implementing LuGre friction for the gearbox"
    DTDFVocab:inputTo SimulinkTool
]

// ---------------------------------------------------
// C11: Enablers (tools & platforms)
// ---------------------------------------------------
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker used for real‑time streaming of sensor data to the digital twin"
    DTDFVocab:enables FrictionIdentificationService, SimulationComparisonService, DashboardVisualizationService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment executing friction models and simulation comparisons"
    DTDFVocab:enables FrictionIdentificationService, SimulationComparisonService, ModelIntegrationService
]

instance DashboardVisualizationTool : DTDFVocab:Enabler [
    base:desc "Dashboard visualization tools presenting identified friction parameters and motion‑control accuracy"
    DTDFVocab:enables DashboardVisualizationService
]

instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML modeling environment hosting the structural and block diagrams of the robot axis"
    DTDFVocab:enables ModelIntegrationService
]

instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Service for integrating SysML and Simulink models into the Asset Administration Shell"
    DTDFVocab:provides ModelIntegrationInsight
]

instance ModelIntegrationInsight : DTDFVocab:Insight [
    base:desc "Consistent digital‑shadow representation of engineering and simulation models within the AAS"
]

// ---------------------------------------------------
// C6: Services
// ---------------------------------------------------
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction from streamed sensor data"
    DTDFVocab:provides FrictionParameterInsight, UpdateMotionControlAction
]

instance SimulationComparisonService : DTDFVocab:Service [
    base:desc "Comparison of simulated torque and angular velocity from Simulink models with measured data"
    DTDFVocab:provides MotionControlAccuracyInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Unified dashboard visualizing identified friction parameters and resulting motion‑control accuracy"
    DTDFVocab:provides MotionControlAccuracyInsight
]

// ---------------------------------------------------
// C17: Insights / Actions
// ---------------------------------------------------
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Identified static, kinetic and viscous friction parameters derived from sensor data"
]

instance UpdateMotionControlAction : DTDFVocab:Action [
    base:desc "Feed back the identified friction parameters to the robot controller to improve motion‑control algorithms"
    DTDFVocab:IsAutomatic true
]

instance MotionControlAccuracyInsight : DTDFVocab:Insight [
    base:desc "Improved positional accuracy of the robot axis as a result of updated friction parameters and controller tuning"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is intentionally passive; no commands or data are sent from the virtual model back to the physical robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital shadow operates in real‑time, continuously ingesting live sensor streams and performing immediate friction identification and model comparison during robot operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow consisting of a Purpose element (FrictionDerivation), an Asset element (Mabi robot first axis), Processing components (Simulation M, Simulation GW, Simulation GB) that consume input DataTraces and produce simulated output traces, and a Dashboard that aggregates and visualizes the resulting data."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow is created and used during the operational phase of the robot, i.e., while the robot is running and performing machining tasks."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each DataPoint to its originating sensor or model via the originates‑from association; comparison of simulated friction‑free and friction‑included models against measured data to validate model accuracy; continuous update of white‑box and black‑box friction parameters during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted to the digital shadow over MQTT; the Asset Administration Shell provides a standardized interface for model and data linking; Processing components consume MQTT streams."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Uses the Asset Administration Shell (AAS) specification, a standardized Industry 4.0 representation, and follows SysML modeling conventions."
]