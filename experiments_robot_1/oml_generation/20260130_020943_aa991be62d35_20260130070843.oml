// C3: Physical sensing components (implied from Digital Shadow integration)
instance PhysicalSystemSensor : DTDFVocab:SensingComponent [
    base:desc "Aggregates contextual data traces from the physical system for Digital Shadow integration, supporting one-way data flow to digital representations"
    DTDFVocab:producedData PhysicalSystemDataTransmitted
]

// C4: Physical-to-virtual interaction
instance PhysicalSystemDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemSensor
]

// C10: Models/Data
instance RequirementsModel : DTDFVocab:Model [
    base:desc "Structured requirements layer modeled using MBSE methodologies (RFLP, OOSEM, SPES) across multiple abstraction layers"
    DTDFVocab:inputTo SysMLModelingEnabler, ADLIntegrationEnabler
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "Functional architecture layer describing system functions and their relationships using MBSE methodologies"
    DTDFVocab:inputTo SysMLModelingEnabler, MontiArcEnabler
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Logical architecture layer modeling components, interfaces, and compositions using SysML IBDs and ADLs"
    DTDFVocab:inputTo SysMLModelingEnabler, ADLIntegrationEnabler
]

instance ProductTechnicalModel : DTDFVocab:Model [
    base:desc "Product/technical layer with detailed system specifications and physics-based descriptions"
    DTDFVocab:inputTo SysMLModelingEnabler, SimulinkEnabler
]

instance StateMachineBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model using SysML v1.7 state machines or MontiArc Automaton for dynamic system behavior"
    DTDFVocab:inputTo SysMLModelingEnabler, MontiArcEnabler
]

instance DigitalShadowData : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces from physical system sensors, processed for Digital Shadow representation"
    DTDFVocab:fromData PhysicalSystemDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Output data from behavioral simulations (Simulink, MontiArc Automaton) representing system dynamics"
    DTDFVocab:inputTo SimulationEnabler
]

instance CodeGeneratedData : DTDFVocab:Data [
    base:desc "Data generated from C++/Java implementations integrated with modeling tools"
    DTDFVocab:inputTo ProgrammingIntegrationEnabler
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based modeling toolchain supporting multi-layered abstraction (requirements, functional, logical, product layers) via IBDs and state machines"
    DTDFVocab:enables DataInterpretationService, BehavioralSimulationService, MultiToolIntegrationService
]

instance ADLIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Language integration (ACME, AADL, MontiArc) for component-connector modeling and system composition"
    DTDFVocab:enables DataInterpretationService, MultiToolIntegrationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for dynamic system simulation and control logic implementation"
    DTDFVocab:enables BehavioralSimulationService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc framework for component-connector modeling and behavioral automation (MontiArc Automaton)"
    DTDFVocab:enables BehavioralSimulationService, MultiToolIntegrationService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Middleware/data pipeline for contextual aggregation and abstraction of raw sensor data into actionable insights"
    DTDFVocab:enables DataInterpretationService
]

instance ProgrammingIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Integration layer for C++/Java custom logic and control algorithms with modeling tools"
    DTDFVocab:enables MultiToolIntegrationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for simulation tools integration and execution"
    DTDFVocab:enables BehavioralSimulationService
]

// C6: Services
instance DataInterpretationService : DTDFVocab:Service [
    base:desc "Active service interpreting and processing incoming data from physical system, performing contextual aggregation and purpose-driven analysis"
    DTDFVocab:provides SystemStateInsight, DataQualityInsight
]

instance BehavioralSimulationService : DTDFVocab:Service [
    base:desc "Service leveraging simulation tools (Simulink, MontiArc Automaton) to simulate, predict, and optimize system behavior dynamically"
    DTDFVocab:provides PredictiveBehaviorInsight, OptimizationRecommendation
]

instance MultiToolIntegrationService : DTDFVocab:Service [
    base:desc "Service enabling heterogeneous toolchain integration (SysML, ADLs, simulation tools, C++/Java) for comprehensive system representation"
    DTDFVocab:provides ToolchainInteroperabilityInsight, StakeholderIntegrationInsight
]

// C17: Insights/Actions
instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Real-time or near-real-time representation of the physical system's current state derived from processed sensor data"
]

instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Assessment of data quality and contextual relevance for decision-making purposes"
]

instance PredictiveBehaviorInsight : DTDFVocab:Insight [
    base:desc "Predictive analysis of system behavior based on simulation models and historical data"
]

instance OptimizationRecommendation : DTDFVocab:Action [
    base:desc "Automated recommendations for system optimization derived from behavioral simulations"
    DTDFVocab:IsAutomatic true
]

instance ToolchainInteroperabilityInsight : DTDFVocab:Insight [
    base:desc "Verification of seamless integration between heterogeneous modeling tools and data sources"
]

instance StakeholderIntegrationInsight : DTDFVocab:Insight [
    base:desc "Assessment of multi-perspective modeling coverage across diverse stakeholder requirements"
]

// C2: Acting Components (implied from active services)
instance DataProcessingActuator : DTDFVocab:ActingComponent [
    base:desc "Active component performing contextual aggregation and abstraction of raw sensor data for Digital Twin consumption"
]

instance SimulationController : DTDFVocab:ActingComponent [
    base:desc "Component executing behavioral simulations (Simulink, MontiArc Automaton) to generate predictive insights"
]

instance ToolchainIntegrator : DTDFVocab:ActingComponent [
    base:desc "Component managing heterogeneous toolchain integration and data exchange between SysML, ADLs, simulation tools, and programming languages"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin (DT) system’s orchestration and coordination are implicitly defined through **Model-Based Systems Engineering (MBSE) methodologies** and **architecture description languages (ADLs)**. The document describes a **component-connector-based architecture** (e.g., ACME, AADL, MontiArc, SysML IBDs) where systems are decomposed into **modular components** with well-defined **interfaces, interconnections, and compositions**. Behavior is modeled using **state machines (SysML v1.7) or MontiArc Automaton**, enabling **dynamic coordination** between components. For complex systems, **heterogeneous tools** (e.g., MathWorks Simulink, simulation tools, C++/Java code) are integrated, suggesting a **hybrid orchestration pattern** combining **model-driven and code-based execution**. The document does not specify exact architecture patterns (e.g., microservices, service-oriented) but emphasizes **integration of diverse stakeholders and perspectives**, implying a **federated or loosely coupled constellation** with **resource management** handled via ADL-defined interfaces and MBSE methodologies like **RFLP (Requirements, Functions, Logics, Physics)**."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system addresses **fidelity and validity considerations** through **Model-Based Systems Engineering (MBSE) validation and verification (V&V) methodologies**, though specific technical details (e.g., uncertainty quantification, error correction mechanisms) are not explicitly outlined in the provided context. The system’s **model fidelity** is inherently tied to the **abstraction layers** (requirements to technical implementation) and the **integration of heterogeneous models** (e.g., SysML, Simulink, ADLs). Validation processes likely involve **cross-checking simulation outputs (e.g., MathWorks Simulink) against physical system behaviors**, while verification ensures compliance with **functional and logical architecture specifications**. Uncertainty sources may arise from **data abstraction in digital shadows** (as referenced in [32]) or **model approximations** during system decomposition (e.g., RFLP, OOSEM methodologies). Quality assurance is implicitly supported by **tool-specific validation frameworks** (e.g., SysML’s formal semantics, ADL compliance checks), though explicit error detection/correction protocols are not detailed."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The document highlights the need for **interoperability between heterogeneous systems** in Digital Twin (DT) environments. **Data exchange protocols** and **integration patterns** are implied through the use of **architecture description languages (ADLs)** like **ACME, AADL, or SysML IBDs**, which standardize component interfaces and connections. The document does not specify exact protocols (e.g., OPC UA, MQTT, REST) but references **external tools** (e.g., MathWorks Simulink, simulation tools) and **general-purpose languages (C++, Java)**, suggesting **API-based or middleware-driven integration**. Dependencies on **external systems** (e.g., enterprise systems, other DTs) are managed via **MBSE methodologies** (e.g., OOSEM, SPES), which enforce **consistent modeling notations** across stakeholders. No explicit standards (e.g., ISO 23247) or integration patterns (e.g., event-driven, publish-subscribe) are mentioned, but the **component-connector paradigm** implies **plug-and-play interoperability** for modular DT systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE) standards**, leveraging **SysML** (ISO/IEC 19505) for system modeling and **Architecture Description Languages (ADLs)** such as **ACME**, **AADL**, and **MontiArc**, which may align with domain-specific standards (e.g., **ISO 10303 (STEP)** for product data interoperability). The **Digital Shadow Reference Model** (Kritzinger et al.) implies compliance with **manufacturing data aggregation standards**, though specific certifications or frameworks (e.g., **ISO 23247 for DTs**, **IEC 62443 for cybersecurity**) are not mentioned. **Interoperability** is addressed via integration of heterogeneous tools (e.g., **Simulink**, **C++/Java**) and modeling notations, suggesting adherence to **IEEE 1471 (Architecture Description)** or **OMG standards** for model exchange. No explicit mention of **compliance frameworks** (e.g., **ISO 9001**, **IATF 16949**) or **certification requirements** is provided."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system for the MABI MAX 100 serial robot incorporates **safety-critical system considerations** through the integration of a **safety cell** that restricts the operational range of the first vertical axis to **[-90°, 90°]**, ensuring compliance with predefined safety boundaries. **Threat mitigation strategies** are implicitly addressed via the **dual-encoder sensor arrangement** (motor encoder and secondary encoder behind the gearbox), which reduces **backlash** and **positional uncertainty** by cross-referencing encoder data to infer **elasticity and friction** in the drive train, thereby enhancing system reliability. **Fail-safe mechanisms** are not explicitly detailed, but the **Siemens SINUMERIK 840D sl CNC controller**—optimized for subtractive manufacturing—provides **closed-loop control** with **position, speed, and acceleration inputs/outputs**, enabling real-time monitoring of **target vs. actual values** (position, velocity, and motor current). The system lacks explicit mention of **cybersecurity protocols**, **access control mechanisms**, or **authentication systems**, though the **CNC controller’s closed-loop architecture** inherently supports **data integrity** for critical operational parameters (e.g., torque *τ_M*, gearbox torque *τ_G*, and output torque *τ_out*). **Risk assessment** is indirectly addressed through the **sensor redundancy** and **gear transmission design**, which mitigates mechanical failures. No details on **data protection regulations**, **consent management**, or **data anonymization** are provided."
]