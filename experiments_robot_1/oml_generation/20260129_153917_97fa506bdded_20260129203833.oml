// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) providing electrical current measurements"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor-mounted position encoder providing angular position of the motor shaft"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind the gearbox providing angular position of the gearbox output"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction – Data transmitted
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// C10: Data (measured and derived)
instance MeasuredCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current trace I_M"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance MeasuredMotorAngleData : DTDFVocab:Data [
    base:desc "Measured motor angular position from motor encoder"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance MeasuredGearboxAngleData : DTDFVocab:Data [
    base:desc "Measured gearbox output angular position from secondary encoder"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Derived torque calculated from current and motor parameters"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance DerivedAngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity computed from motor angle trace"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance DerivedAccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration computed from angular velocity"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEngine
]

// C11: Enablers (tooling and integration)
instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink executable models for motor, gearboxes and friction identification"
    DTDFVocab:enables RealTimeFrictionIdentification, ContinuousModelCalibration
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker for live streaming of sensor data to the digital shadow"
    DTDFVocab:enables DataStreamingService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) for model integration and interoperability"
    DTDFVocab:enables ModelIntegrationService
]

instance DashboardVisualizationTool : DTDFVocab:Enabler [
    base:desc "Dashboard for visualization of measured vs. simulated data"
    DTDFVocab:enables VisualizationDashboard
]

instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML for structural and functional modeling of the axis"
    DTDFVocab:enables StructuralModelManagement
]

// C6: Services
instance RealTimeFrictionIdentification : DTDFVocab:Service [
    base:desc "Real‑time friction identification (static, kinetic, viscous) for the gearbox"
    DTDFVocab:provides DerivedFrictionParametersInsight, AdjustMotionControlAction
]

instance ContinuousModelCalibration : DTDFVocab:Service [
    base:desc "Continuous model calibration to improve robot motion accuracy"
    DTDFVocab:provides CalibrationInsight
]

instance VisualizationDashboard : DTDFVocab:Service [
    base:desc "Visualization of measured vs. simulated data in an integrated dashboard"
    DTDFVocab:provides VisualizationInsight
]

instance DataStreamingService : DTDFVocab:Service [
    base:desc "Live streaming of sensor data via MQTT to the digital shadow"
    DTDFVocab:provides StreamingInsight
]

instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Integration of SysML and Simulink models through Asset Administration Shell"
    DTDFVocab:provides IntegrationInsight
]

instance StructuralModelManagement : DTDFVocab:Service [
    base:desc "Management of SysML structural and behavioral models"
    DTDFVocab:provides ModelingInsight
]

// C17: Insights
instance DerivedFrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters are fed back to the robot controller to adjust motion control algorithms, reducing positioning errors and improving machining accuracy."
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Continuous calibration of simulation models enhances the accuracy of motion control."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Dashboard visualizes measured vs. simulated data for operator monitoring."
]

instance StreamingInsight : DTDFVocab:Insight [
    base:desc "Live sensor streams enable up‑to‑date digital shadow state."
]

instance IntegrationInsight : DTDFVocab:Insight [
    base:desc "AAS integration aligns physical asset and virtual model semantics."
]

instance ModelingInsight : DTDFVocab:Insight [
    base:desc "SysML models capture structural and functional aspects of the first axis."
]

// C17: Actions
instance AdjustMotionControlAction : DTDFVocab:Action [
    base:desc "Adjust motion control algorithms in the robot controller based on derived friction parameters"
    DTDFVocab:IsAutomatic true
]

// C10: Engineering models
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML block diagram of the first axis (motor, gearboxes, drives)"
    DTDFVocab:inputTo SysMLModelingTool
]

instance SysMLBehavioralModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram describing signal flows and currents"
    DTDFVocab:inputTo SysMLModelingTool
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the permanent‑magnet synchronous motor"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkGearwheelGearboxModel : DTDFVocab:Model [
    base:desc "Simulink model of the gearwheel gearbox"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkCycloidalGearboxModel : DTDFVocab:Model [
    base:desc "Simulink model of the cycloidal gearbox"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance FrictionModelCoulombViscous : DTDFVocab:Model [
    base:desc "Friction model implementing Coulomb and viscous components"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance FrictionModelStribeck : DTDFVocab:Model [
    base:desc "Stribeck friction model for low‑speed behavior"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance FrictionModelDahl : DTDFVocab:Model [
    base:desc "Dahl friction model capturing pre‑slip dynamics"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance FrictionModelLuGre : DTDFVocab:Model [
    base:desc "LuGre friction model for comprehensive friction dynamics"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

// C10: Component representing the physical asset
instance MABIFirstAxis : DTDFVocab:Component [
    base:desc "First axis of the MABI MAX 100 industrial robot, comprising a permanent‑magnet synchronous motor, a gearwheel gearbox and a cycloidal gearbox, used for machining applications"
]

// C11: Digital shadow instance (multiplicity)
instance FrictionShadow : DTDFVocab:Component [
    base:desc "Single digital shadow instance instantiated for the first axis to host models, data and services"
]

// C2: Acting components (none in document, omitted)

// C5: Environment (optional)
instance RobotWorkspace : DTDFVocab:Environment [
    base:contains MABIFirstAxis
]

// C9: Twinning process & evolution (captured as a component for documentation)
instance PurposeDrivenMethodology : DTDFVocab:Component [
    base:desc "Purpose‑driven methodology: (1) problem identification (friction derivation), (2) asset and model analysis, (3) creation/selection of simulation and friction models, (4) data identification (sensor streams, derived traces); iterative refinement follows references [15] and [43]"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Not in Document (digital shadow is defined as a one‑way data flow with no autonomous actuation)."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time operation; data are captured and processed on‑line during robot motion, enabling live identification of friction parameters."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A concrete realization of the Digital Shadow Reference Model comprising Purpose (FrictionDerivation), Asset (MABI Axis), DataTraces/DataPoints, Sources (sensors, derived data), Processing components (Simulation M, GW, GB), and Models (engineering, simulation, data‑calculation) linked together to form the FrictionShadow digital shadow."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated stage – the digital shadow is created and used during runtime to monitor and improve the robot’s motion control; it also references engineering models defined during design."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Combination of white‑box analytical friction models and black‑box data‑driven models; continuous identification to capture wear, load, temperature effects; full traceability of each data point to its source and processing model; multi‑physics‑aware identification ensures model validity against measured data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow using the MQTT protocol; Asset Administration Shells are employed to link the physical asset with its models and data."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Uses the Asset Administration Shell (AAS) standard for asset representation and SysML as an engineering modeling language; reference to IEC standards is implicit but not detailed."
]