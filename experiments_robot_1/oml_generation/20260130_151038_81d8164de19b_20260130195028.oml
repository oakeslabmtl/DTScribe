// C3: Physical sensing components
instance Axis1JointSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring joint angle and torque of Axis 1 on MABI MAX 100 robot"
    DTDFVocab:producedData JointPositionTraceAxis1
]

instance Axis2JointSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring joint angle and torque of Axis 2 on MABI MAX 100 robot"
    DTDFVocab:producedData JointPositionTraceAxis2
]

// C4: Data transmitted from sensors
instance JointPositionTraceAxis1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Axis1JointSensor
]

instance JointPositionTraceAxis2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Axis2JointSensor
]

// C10: Data (derived)
instance JointPositionDataAxis1 : DTDFVocab:Data [
    base:desc "Pre‑processed time‑series of joint angle/torque for Axis 1"
    DTDFVocab:fromData JointPositionTraceAxis1
    DTDFVocab:inputTo DynamicsProcessingComponent, FrictionMLProcessingComponent
]

instance JointPositionDataAxis2 : DTDFVocab:Data [
    base:desc "Pre‑processed time‑series of joint angle/torque for Axis 2"
    DTDFVocab:fromData JointPositionTraceAxis2
    DTDFVocab:inputTo DynamicsProcessingComponent, FrictionMLProcessingComponent
]

// C10: Models
instance SimulinkDynamicsModel : DTDFVocab:Model [
    base:desc "White‑box multi‑physics simulation of robot kinematics and joint friction (MATLAB/Simulink)"
    DTDFVocab:inputTo DynamicsProcessingComponent
]

instance MLFrictionsModel : DTDFVocab:Model [
    base:desc "Black‑box neural‑network model trained to predict nonlinear joint friction"
    DTDFVocab:inputTo FrictionMLProcessingComponent
]

instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "UML class‑diagram based digital‑shadow reference model defining abstract data structures"
    DTDFVocab:inputTo MappingProcessingComponent
]

// C11: Enablers (processing components)
instance DynamicsProcessingComponent : DTDFVocab:Enabler [
    base:desc "Consumes joint position data and executes the Simulink dynamics simulation"
    DTDFVocab:enables VisualizationDashboardService, JointFrictionIdentificationService
]

instance FrictionMLProcessingComponent : DTDFVocab:Enabler [
    base:desc "Consumes joint position data and runs the ML friction model"
    DTDFVocab:enables JointFrictionIdentificationService, MotionAccuracyEnhancementService
]

instance MappingProcessingComponent : DTDFVocab:Enabler [
    base:desc "Maps concrete instances to the Digital Shadow Reference Model"
    DTDFVocab:enables DataManagementService
]

// C6: Services
instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Real‑time dashboard visualizing robot states and simulation results"
    DTDFVocab:provides InsightPerformanceVisualization
]

instance JointFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous multi‑physics aware identification of joint friction for monitoring and diagnostics"
    DTDFVocab:provides InsightFrictionAnomaly, ActionAdjustControlParameters
]

instance MotionAccuracyEnhancementService : DTDFVocab:Service [
    base:desc "Model‑based correction service that predicts and optimizes motion accuracy"
    DTDFVocab:provides InsightPredictedDeviation, ActionAdjustControlParameters
]

instance DataManagementService : DTDFVocab:Service [
    base:desc "Stores all model artefacts and generated data in the central repository (Thingsboard)"
    DTDFVocab:provides InsightDataAvailability
]

// C17: Insights
instance InsightPerformanceVisualization : DTDFVocab:Insight [
    base:desc "Operators can monitor real‑time performance metrics of the robot via the dashboard"
]

instance InsightFrictionAnomaly : DTDFVocab:Insight [
    base:desc "Detection of abnormal joint friction indicating possible wear or lubrication issues"
]

instance InsightPredictedDeviation : DTDFVocab:Insight [
    base:desc "Prediction of future motion deviation enabling preventive correction"
]

instance InsightDataAvailability : DTDFVocab:Insight [
    base:desc "Assurance that all generated data traces are persisted and retrievable from the repository"
]

// C17: Actions
instance ActionAdjustControlParameters : DTDFVocab:Action [
    base:desc "Automatic adjustment of controller parameters to compensate for identified friction or predicted deviation"
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin follows the Digital Shadow Reference Model (DSRM), where a Processing component consumes input DataTraces, executes engineering, simulation, or data‑calculation Models, and produces output DataTraces. The 'originates‑from' association links each DataTrace back to the generating Processing component, its consumed input traces, and the models involved, maintaining transitive traceability. This modular arrangement of Processing components and Models constitutes the system‑wide orchestration and coordination of the Digital Twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by continuous verification of both white‑box Simulink simulations and black‑box learning models against incoming sensor data. The approach emphasizes traceability of transformations (e.g., SysML to simulation code) and verification of model correctness as described in the literature. Uncertainty is addressed through dynamic adaptation: model parameters are automatically updated and neural networks are retrained as new data arrive, mitigating drift due to wear, temperature, or payload changes. Quality assurance includes transitive provenance tracking of data traces, enabling error detection and correction, and supports predictive maintenance by detecting anomalies in friction behaviour."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the physical sensors and the digital shadow relies on the MQTT protocol, a lightweight publish‑subscribe messaging standard. The source documents only specify the use of MQTT; additional network characteristics such as topology, bandwidth, latency, redundancy, or security mechanisms are not provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT leverages several established standards: SysML is used for systems modeling; UML class diagrams describe the Digital Shadow Reference Model; ADLs such as ACME, AADL and MontiArc provide component‑connector specifications; and the notion of a conformance relation follows the formal definition of reference models. By instantiating the reference model with concrete classes that map to these standards, the DT ensures interoperability and alignment with industry modeling practices."
]