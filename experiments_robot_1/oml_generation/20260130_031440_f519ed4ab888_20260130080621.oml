// C3: Physical sensing components
instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor-mounted encoder directly on the PMSM providing high-resolution position feedback for the first vertical axis of MABI MAX 100 industrial robot. Part of dual encoder system for gearbox compensation."
    DTDFVocab:producedData MotorMountedEncoderDataStream
]

instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearbox providing synchronized position feedback for the first vertical axis of MABI MAX 100 industrial robot. Part of dual encoder system for sub-micrometer resolution position tracking."
    DTDFVocab:producedData SecondaryEncoderDataStream
]

instance TimeSeriesSensorData : DTDFVocab:SensingComponent [
    base:desc "Embedded sensors collecting time-series operational data including temperature, current, and other state monitoring parameters for the MABI MAX 100 first axis system."
    DTDFVocab:producedData TimeSeriesOperationalData
]

// C4: Physical-to-virtual interaction
instance MotorMountedEncoderDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder
    base:desc "Real-time position data stream from motor-mounted encoder transmitted via MQTT protocol for digital twin ingestion."
]

instance SecondaryEncoderDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoder
    base:desc "Real-time position data stream from secondary encoder transmitted via MQTT protocol for digital twin ingestion with gearbox compensation."
]

instance TimeSeriesOperationalData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TimeSeriesSensorData
    base:desc "Time-series operational data including temperature, current, and other state parameters transmitted via MQTT protocol for digital twin analysis."
]

// C10: Models/Data
instance JointFrictionWhiteBoxModel : DTDFVocab:Model [
    base:desc "White-box model for multi-physics-aware identification of joint friction in the first vertical axis of MABI MAX 100 robot, incorporating mechanical and thermal physics."
    DTDFVocab:inputTo SysMLModelingToolchain, SimulinkSimulationEngine
]

instance JointFrictionBlackBoxModel : DTDFVocab:Model [
    base:desc "Black-box model for data-driven identification of joint friction patterns in the first vertical axis of MABI MAX 100 robot without explicit physical parameterization."
    DTDFVocab:inputTo SysMLModelingToolchain, SimulinkSimulationEngine
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces from physical system operations, including position, speed, acceleration, and environmental parameters."
    DTDFVocab:fromData MotorMountedEncoderDataStream, SecondaryEncoderDataStream, TimeSeriesOperationalData
    DTDFVocab:inputTo SysMLModelingToolchain, DataAggregationMiddleware
]

instance MultiPhysicsSimulationData : DTDFVocab:Data [
    base:desc "Simulated multi-physics data incorporating mechanical, thermal, and electrical interactions for the first vertical axis of MABI MAX 100 robot."
    DTDFVocab:fromData ContextualDataTraces
    DTDFVocab:inputTo SimulinkSimulationEngine, DashboardVisualization
]

// C11: Enablers
instance SysMLModelingToolchain : DTDFVocab:Enabler [
    base:desc "SysML-based MBSE toolchain implementing RFLP, OOSEM, and SPES methodologies for multi-layered system modeling across requirements, functional, logical, and technical architectures."
    DTDFVocab:enables StructuralModelingService, BehavioralModelingService
]

instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation engine for detailed behavioral modeling of multi-physics interactions including joint friction identification."
    DTDFVocab:enables SimulationAnalysisService
]

instance MQTTDataStreamingProtocol : DTDFVocab:Enabler [
    base:desc "MQTT publish-subscribe protocol for real-time, lightweight transmission of sensor data streams from physical system to digital twin."
    DTDFVocab:enables DataIngestionService
]

instance DataAggregationMiddleware : DTDFVocab:Enabler [
    base:desc "Middleware component for preprocessing, filtering, and aggregating heterogeneous sensor data streams before integration into digital twin models."
    DTDFVocab:enables DataPreprocessingService
]

instance DashboardVisualization : DTDFVocab:Enabler [
    base:desc "Dashboard visualization platform for real-time and post-processing display of multi-physics insights and operational parameters."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance StructuralModelingService : DTDFVocab:Service [
    base:desc "Service providing SysML-based structural modeling of the MABI MAX 100 first axis system including components, interfaces, and interconnections."
    DTDFVocab:provides SystemArchitectureInsight
]

instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Service providing SysML state machines and MontiArc automaton-based behavioral modeling of the first axis system dynamics."
    DTDFVocab:provides DynamicBehaviorInsight
]

instance SimulationAnalysisService : DTDFVocab:Service [
    base:desc "Service enabling simulation-based analysis of multi-physics interactions including joint friction identification through white-box and black-box models."
    DTDFVocab:provides FrictionIdentificationInsight, PredictiveBehaviorInsight
]

instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service handling real-time ingestion of MQTT-transmitted sensor data streams from physical system to digital twin."
    DTDFVocab:provides DataIngestionAction
]

instance DataPreprocessingService : DTDFVocab:Service [
    base:desc "Service performing preprocessing operations including filtering, normalization, and noise reduction on raw sensor data streams."
    DTDFVocab:provides PreprocessedDataInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service providing real-time and post-processing visualization of system parameters, insights, and operational metrics through interactive dashboards."
    DTDFVocab:provides VisualizedInsightsInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service enabling continuous multi-physics-aware monitoring of joint friction and operational parameters in the first vertical axis of MABI MAX 100 robot."
    DTDFVocab:provides OperationalMonitoringInsight
]

// C2: Acting Components
instance SINUMERIK840DslController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl industrial controller providing individual axis control for the PMSM in MABI MAX 100 first vertical axis with position, speed, and acceleration inputs. Supports OPC UA/Profinet integration and programmable safety functions."
    DTDFVocab:producedData ControllerCommandData
]

instance ControllerCommandData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SINUMERIK840DslController
    base:desc "Command data stream generated by SINUMERIK 840D sl controller for actuation of PMSM in first vertical axis, transmitted via CANopen/EtherCAT protocols."
]

// C17: Insights/Actions
instance SystemArchitectureInsight : DTDFVocab:Insight [
    base:desc "Structural architecture insights of the MABI MAX 100 first axis system including component relationships, interfaces, and mechanical linkages."
]

instance DynamicBehaviorInsight : DTDFVocab:Insight [
    base:desc "Behavioral insights of the first axis system dynamics including state transitions and operational sequences modeled via SysML state machines."
]

instance FrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Identified joint friction parameters and characteristics in the first vertical axis of MABI MAX 100 robot through multi-physics-aware white-box and black-box modeling."
]

instance PredictiveBehaviorInsight : DTDFVocab:Insight [
    base:desc "Predictive insights of system behavior under various operational conditions including friction effects and environmental influences."
]

instance OperationalMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time operational monitoring insights including joint friction status, position accuracy, and system health metrics for the first vertical axis."
]

instance VisualizedInsightsInsight : DTDFVocab:Insight [
    base:desc "Visualized representation of system parameters, friction identification results, and operational metrics through interactive dashboards."
]

instance DataIngestionAction : DTDFVocab:Action [
    base:desc "Automated ingestion of MQTT-transmitted sensor data streams into digital twin data processing pipeline."
    DTDFVocab:IsAutomatic true
]

instance PreprocessedDataInsight : DTDFVocab:Insight [
    base:desc "Preprocessed and normalized sensor data ready for integration into digital twin models with reduced noise and artifacts."
]

// C1: Environment
instance MABIMax100FirstAxisEnvironment : DTDFVocab:Environment [
    base:desc "Physical environment of the MABI MAX 100 industrial robot first vertical axis including mechanical components, sensors, and actuators."
    base:contains SINUMERIK840DslController, MotorMountedEncoder, SecondaryEncoder, TimeSeriesSensorData
]

// C5: Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:Component [
    base:desc "PMSM actuator in the first vertical axis of MABI MAX 100 robot providing precise position, speed, and acceleration control through SINUMERIK 840D sl controller."
]

instance DualEncoderPositionFeedbackSystem : DTDFVocab:Component [
    base:desc "Dual encoder system comprising motor-mounted and secondary encoders providing sub-micrometer resolution position feedback for the first vertical axis with gearbox compensation."
]

instance MultiPhysicsJointFrictionModel : DTDFVocab:Component [
    base:desc "Component integrating white-box and black-box models for multi-physics-aware joint friction identification in the first vertical axis system."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system validates model fidelity through **comparative analysis of simulation outputs** against real-world data traces, including **measured motor/gearbox outputs** and **simulated counterparts** (e.g., motor output, gearbox output). The digital shadow’s purpose—**understanding relations and detecting friction loss**—relies on **data trace aggregation** (measured vs. simulated) to quantify discrepancies. While explicit **uncertainty quantification** or **error correction mechanisms** are not detailed, the system implies **traceability-driven validation** via cross-referenced data sources. Quality assurance is inherently tied to **purpose-specific abstraction** of contextual traces, ensuring alignment between digital and physical states for operational insights."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for the Digital Shadow (DS) system is implicitly tied to the **MQTT protocol**, which is explicitly mentioned as the communication mechanism for streaming data from physical to digital components. Beyond this, the document does not provide details on **communication protocols** (e.g., OPC UA, AMQP, HTTP/REST), **network topology** (e.g., star, mesh, or hierarchical architectures), **bandwidth/latency requirements**, or **reliability/redundancy mechanisms** (e.g., failover strategies, QoS levels). Similarly, **security protocols** (e.g., TLS/SSL, authentication frameworks) are not addressed. The reference to MQTT suggests a lightweight, event-driven approach but lacks specifics on **network architecture** (e.g., edge-cloud integration) or **infrastructure standards** (e.g., 5G, industrial Ethernet)."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with external tools and methodologies for behavioral modeling and simulation, including **MathWorks Simulink** and other simulation tools (e.g., [29], [30]) for detailed behavioral analysis. Data streaming is facilitated via **MQTT**, a lightweight publish-subscribe protocol, enabling real-time data exchange between the digital and physical systems. However, the document does not specify formal interoperability standards (e.g., OPC UA, REST APIs) or enterprise system integration patterns (e.g., ERP/MES systems). The focus remains on tool-specific integration (e.g., Simulink, C++/Java code) rather than standardized protocols or system-wide orchestration."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **industry standards** such as **SysML (Systems Modeling Language)** for modeling and **Asset Administration Shells (AAS)** for interoperability and data exchange in manufacturing contexts. While the document does not specify certification frameworks or compliance requirements, it implies alignment with **MBSE best practices** and **ADL-based architecture standards** (e.g., ACME, AADL) for system description and integration."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system for the MABI MAX 100 serial robot incorporates **safety-critical system considerations** through a **safety cell** that restricts the operational working range of the first vertical axis to **[-90°, 90°]**, ensuring physical confinement within predefined boundaries. The system enforces a **maximum achievable speed** of **|q̇_max| = 75 [°/s]** to mitigate dynamic risks. **Sensor redundancy** is implemented via **two position encoders per drive**: a **motor encoder** mounted directly on the permanent magnet synchronous motor and a **secondary encoder** positioned behind the gearbox. This dual-encoder arrangement enables **backlash compensation** and **positional uncertainty reduction** by analyzing the differential signal between encoders, thereby inferring **elasticity and friction characteristics** of the drive train (gear transmission + cycloidal gear). The **Siemens SINUMERIK 840D sl CNC controller** provides **separate axis control** with configurable inputs (position, speed, acceleration) and outputs (target/actual position, derivatives, motor current), where the latter is converted to **applied torque (τ_M)** using known motor constants. No explicit cybersecurity protocols, access control mechanisms, or threat mitigation strategies are documented."
]