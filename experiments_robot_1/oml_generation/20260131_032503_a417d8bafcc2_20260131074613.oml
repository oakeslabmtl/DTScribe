// C3: Physical sensing components
instance PrimaryAxisMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted directly on the permanent magnet synchronous motor to measure input shaft angle with high precision, contributing to real-time monitoring and control."
    DTDFVocab:producedData PrimaryAxisMotorEncoderData
]

instance SecondaryAxisGearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearbox to measure output angle, designed to reduce backlash and positional uncertainty for high-precision measurements."
    DTDFVocab:producedData SecondaryAxisGearboxEncoderData
]

instance PrimaryAxisPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder for the primary drive axis, providing time-series sensor data for input current and output angle measurements."
    DTDFVocab:producedData PrimaryAxisPositionEncoderData
]

instance SecondaryAxisPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder for the secondary drive axis, complementing the motor encoder to ensure redundant high-precision angle measurements."
    DTDFVocab:producedData SecondaryAxisPositionEncoderData
]

// C4: Physical-to-virtual interaction
instance PrimaryAxisMotorEncoderData : DTDFVocab:DataTransmitted [
    base:desc "Time-series sensor data from the primary axis motor encoder, including input current and output angle measurements transmitted via MQTT protocol."
    DTDFVocab:producedFrom PrimaryAxisMotorEncoder
]

instance SecondaryAxisGearboxEncoderData : DTDFVocab:DataTransmitted [
    base:desc "Time-series sensor data from the secondary axis gearbox encoder, providing output angle measurements with reduced backlash and positional uncertainty."
    DTDFVocab:producedFrom SecondaryAxisGearboxEncoder
]

instance PrimaryAxisPositionEncoderData : DTDFVocab:DataTransmitted [
    base:desc "Time-series sensor data from the primary axis position encoder, including input current and output angle measurements for real-time monitoring."
    DTDFVocab:producedFrom PrimaryAxisPositionEncoder
]

instance SecondaryAxisPositionEncoderData : DTDFVocab:DataTransmitted [
    base:desc "Time-series sensor data from the secondary axis position encoder, ensuring redundant high-precision angle measurements for control applications."
    DTDFVocab:producedFrom SecondaryAxisPositionEncoder
]

// C10: Models/Data
instance MotorGearboxBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model of the motor-gearbox system captured using MontiArc Automaton, representing component interactions and dynamic behavior for control logic."
    DTDFVocab:inputTo MontiArcAutomatonEnabler, SimulinkCoSimulationEnabler
]

instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based functional architecture model describing system components, interfaces, and behavior across multiple abstraction layers (requirements, functions, logics, physics)."
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance TimeSeriesSensorData : DTDFVocab:Data [
    base:desc "Aggregated time-series sensor data from all encoders and current sensors, preprocessed for consistency and relevance in the Digital Shadow."
    DTDFVocab:fromData PrimaryAxisMotorEncoderData, SecondaryAxisGearboxEncoderData, PrimaryAxisPositionEncoderData, SecondaryAxisPositionEncoderData
    DTDFVocab:inputTo MQTTDataStreamingEnabler, AASDataIntegrationEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model implemented in C++/Java, integrating friction loss detection and real-time feedback mechanisms for dynamic adjustment of actuation ranges."
    DTDFVocab:inputTo CustomAlgorithmEnabler
]

// C11: Enablers
instance MQTTDataStreamingEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol implementation for lightweight, real-time sensor data streaming from physical robot to Digital Shadow, ensuring low-latency transmission."
    DTDFVocab:enables SensorDataStreamingService
]

instance AASDataIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) integration platform standardizing data exchange and service exposure across heterogeneous systems in the Digital Shadow."
    DTDFVocab:enables DataIntegrationService
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton tool for modeling component-connector interactions and automata-based behavior in the Digital Twin system."
    DTDFVocab:enables BehavioralModelingService
]

instance SimulinkCoSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink integration for dynamic system modeling and co-simulation of motor-gearbox interactions, enabling physics-based analysis."
    DTDFVocab:enables PhysicsSimulationService
]

instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 tooling for modeling functional/logical architecture and state machines, supporting multi-notation model management."
    DTDFVocab:enables SystemArchitectureService
]

instance CustomAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "C++/Java development environment for implementing custom algorithms (e.g., friction loss detection) and integrating with simulation models."
    DTDFVocab:enables ControlAlgorithmService
]

// C6: Services
instance SensorDataStreamingService : DTDFVocab:Service [
    base:desc "Service responsible for collecting and transmitting contextual data traces (current, angle, torque, velocity) from physical system to Digital Shadow via MQTT."
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Service managing aggregation, abstraction, and preprocessing of heterogeneous sensor data into a unified Digital Shadow representation."
    DTDFVocab:provides DataConsistencyInsight
]

instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Service enabling MontiArc Automaton-based behavioral modeling of component interactions and dynamic system behavior."
    DTDFVocab:provides ComponentInteractionInsight
]

instance PhysicsSimulationService : DTDFVocab:Service [
    base:desc "Service providing Simulink-based co-simulation of motor-gearbox interactions for physics-based analysis and validation."
    DTDFVocab:provides PhysicsValidationInsight
]

instance SystemArchitectureService : DTDFVocab:Service [
    base:desc "Service managing SysML-based system architecture across requirements, functional, logical, and product layers."
    DTDFVocab:provides ArchitectureTraceabilityInsight
]

instance ControlAlgorithmService : DTDFVocab:Service [
    base:desc "Service executing custom control algorithms (e.g., friction loss detection) and dynamic adjustment of actuation ranges based on real-time feedback."
    DTDFVocab:provides ControlOptimizationAction
]

// C17: Insights/Actions
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight providing real-time monitoring of physical system parameters (current, angle, torque, velocity) for operational awareness."
]

instance DataConsistencyInsight : DTDFVocab:Insight [
    base:desc "Insight ensuring data quality through validation, normalization, and consistency checks of aggregated sensor data."
]

instance ComponentInteractionInsight : DTDFVocab:Insight [
    base:desc "Insight detailing component interactions and dynamic behavior as modeled by MontiArc Automaton."
]

instance PhysicsValidationInsight : DTDFVocab:Insight [
    base:desc "Insight validating motor-gearbox interactions through Simulink-based physics simulations."
]

instance ArchitectureTraceabilityInsight : DTDFVocab:Insight [
    base:desc "Insight ensuring traceability across system architecture layers (requirements → functions → logics → physics) via SysML."
]

instance ControlOptimizationAction : DTDFVocab:Action [
    base:desc "Action dynamically adjusting actuation ranges and executing control commands based on real-time feedback and safety constraints."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Primary actuator driving the robot's primary axis, interfaced with Siemens SINUMERIK 840D sl controller for command execution."
]

instance SiemensSINUMERIK840DslController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl controller managing actuation commands, safety constraints, and remote control interfaces for the physical system."
]

instance SafetyCell : DTDFVocab:ActingComponent [
    base:desc "Safety cell enforcing operational limits and restricting maximum working range to ensure system integrity and prevent exceeding physical constraints."
]

// C1: Digital Shadow Services
instance DigitalShadowDataAggregationService : DTDFVocab:Service [
    base:desc "Service implementing automated one-way data flow from physical system to Digital Shadow, passively collecting contextual data traces (current, angle, torque, velocity)."
    DTDFVocab:provides PassiveDataCollectionInsight
]

instance PassiveDataCollectionInsight : DTDFVocab:Insight [
    base:desc "Insight confirming the Digital Shadow's role as a passive data collector without autonomous operation or bidirectional exchange."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system leverages **real-time, data-driven representations** of physical system behavior, ensuring synchronization between the digital and physical components through **live data acquisition during operation**. While the document does not specify explicit synchronization frequencies or latency requirements, the emphasis on real-time data implies low-latency, high-frequency updates to maintain fidelity between the digital and physical states. Temporal granularity is implicitly tied to the operational context, where dynamic system behavior (e.g., robot joint movements) must be reflected in the digital model with minimal delay. The integration of simulation tools (e.g., MathWorks Simulink) and general-purpose languages (C++, Java) further supports time-critical behavior modeling, though no quantitative thresholds (e.g., millisecond-level latency) are defined in the provided text."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin constellation** is implicitly defined by the **orchestration of modeling artifacts** across multiple tools and notations, as described in the MBSE framework. The system leverages **architecture patterns** such as **component & connector perspectives** (e.g., via ADLs like ACME, AADL, MontiArc, or SysML IBDs) to define **interfaces, interconnections, and composition** of digital twin components. **Resource management** is not explicitly detailed, but the integration of heterogeneous tools (e.g., MathWorks Simulink, simulation tools, or general-purpose languages like C++/Java) suggests **modular coordination** where behavior is described via state machines (SysML v1.7) or automata (MontiArc). **System-wide coordination** would rely on these ADLs and their associated methodologies (e.g., RFLP for hierarchical decomposition or OOSEM for iterative refinement), ensuring alignment between functional, logical, and physical layers. The document does not specify explicit orchestration protocols (e.g., middleware, event-driven architectures) but implies a **multi-tool, multi-perspective integration** framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system emphasizes **model fidelity** through **multi-layered validation and verification (V&V)** processes, though specific methods are not detailed in the document. Key considerations include:
  - **Uncertainty quantification**: Implicit in the *Digital Shadow Reference Model* [32], where **contextual data traces** are aggregated and abstracted, potentially introducing uncertainties due to one-way data flow and passive collection.
  - **Error detection/correction**: Requires **active software components** (not elaborated) to interpret and process incoming data, suggesting a reliance on external tools or algorithms for real-time or post-hoc validation.
  - **Quality assurance**: Enforced via **MBSE methodologies** (e.g., SysML, ADLs) that enforce traceability and consistency across models. However, explicit **uncertainty sources** (e.g., sensor noise, model simplification) or **quantitative metrics** (e.g., fidelity thresholds) are not provided.
  The document highlights the need for **heterogeneous stakeholder integration** [31], implying that validity is context-dependent and may require domain-specific V&V protocols (e.g., manufacturing-specific standards)."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system prioritizes **internal integration** of heterogeneous modeling artifacts and tools (e.g., SysML, Simulink, C++) via **ADLs** to unify disparate perspectives and stakeholders. Data ingestion is facilitated by **MQTT** for streaming sensor inputs, but the document does not specify **external interoperability standards** (e.g., ISO 10303, OPC UA) or dependencies on **enterprise systems** (e.g., PLM/MES). While the text acknowledges the need to integrate **heterogeneous stakeholders and perspectives**, it lacks explicit details on **plug-and-play integration with external Digital Twins** or **enterprise-wide system dependencies**. Thus, **horizontal integration with external systems, protocols, or standards** is **Not in Document**, though internal tool interoperability is a core design consideration."
]