// C3: Physical sensing components
instance ContextualDataCollector : DTDFVocab:SensingComponent [
    base:desc "Collects contextual data traces from the physical object for the digital shadow as defined in the physical-to-virtual interaction."
    DTDFVocab:producedData PhysicalToDigitalDataStream
]

// C4: Physical-to-virtual interaction                                           
instance PhysicalToDigitalDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContextualDataCollector
    base:desc "Automated one-way data flow (digital shadow) transmitting collected contextual data from the physical object to the digital twin."
]

// C10: Data
instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces used as input for digital twin models and services."
    DTDFVocab:fromData PhysicalToDigitalDataStream
    DTDFVocab:inputTo DataInterpretationEngine
]

// C11: Enablers (interpretation)
instance DataInterpretationEngine : DTDFVocab:Enabler [
    base:desc "Software component that interprets incoming physical‑to‑digital data streams for further processing."
    DTDFVocab:enables DigitalShadowService
]

// C6: Services (digital shadow)
instance DigitalShadowService : DTDFVocab:Service [
    base:desc "Provides insights derived from interpreted contextual data of the digital shadow."
    DTDFVocab:provides ContextualInsight
]

// C17: Insights
instance ContextualInsight : DTDFVocab:Insight [
    base:desc "Derived insight about the state or context of the physical object based on the digital shadow data."
]

// C10: Models/Data (structural model)
instance StructuralSysMLModel : DTDFVocab:Model [
    base:desc "Structural information captured in SysML block diagrams describing components, interfaces, interconnections, and composition."
    DTDFVocab:inputTo ModelIntegrationEngine
]

// C10: Models/Data (behavioral model)
instance BehavioralStateMachineModel : DTDFVocab:Model [
    base:desc "Behavioral aspects modeled with SysML state machines or MontiArc automata."
    DTDFVocab:inputTo ModelIntegrationEngine
]

// C10: Models/Data (simulation model)
instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "Analytical and dynamic behavior expressed through simulation models created in MathWorks Simulink."
    DTDFVocab:inputTo ModelIntegrationEngine
]

// C10: Models/Data (executable code fragment)
instance CppExecutableFragment : DTDFVocab:Model [
    base:desc "Executable C++ code fragments linked to models to provide runtime logic."
    DTDFVocab:inputTo ModelIntegrationEngine
]

// C11: Enablers (model integration)
instance ModelIntegrationEngine : DTDFVocab:Enabler [
    base:desc "Engine that integrates heterogeneous models and provides an execution environment for the digital twin."
    DTDFVocab:enables ModelAnalyticsService
]

// C6: Services (model analytics)
instance ModelAnalyticsService : DTDFVocab:Service [
    base:desc "Provides insights derived from the integrated structural, behavioral, and simulation models."
    DTDFVocab:provides ModelBasedInsight
]

// C17: Insights (model based)
instance ModelBasedInsight : DTDFVocab:Insight [
    base:desc "Insight derived from integrated structural, behavioral, and simulation models of the digital twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The document describes the Digital Twin development lifecycle as a sequence of MBSE abstraction levels: (1) Requirements model, (2) Functional architecture model, (3) Logical architecture model, and (4) Product/technical layer model. These levels are created using SysML and are refined progressively, with each level providing a representation that transitions to the next more detailed model."
]