// Acting Component
instance PermanentMagnetSynchMotorWithGearTrain : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor coupled to a gear train with a cycloidal gear stage, driven by a Siemens SINUMERIK 840D motor‑control system."
]

// Sensing Components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Incremental encoder mounted on the motor shaft, 0.1° resolution per pulse, sampled at 1 kHz and transmitted via MQTT."
    DTDFVocab:producedData MotorShaftEncoderDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Incremental encoder mounted behind the gearbox, 0.03° RMS accuracy, sampled at 1 kHz and transmitted via MQTT."
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance DriveCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor providing commutator current feedback to the controller, sampled at 1 kHz and transmitted via MQTT."
    DTDFVocab:producedData DriveCurrentDataTransmitted
]

instance DriveTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor monitoring motor and gearbox temperature, sampled at 1 kHz and transmitted via MQTT."
    DTDFVocab:producedData DriveTemperatureDataTransmitted
]

// Data Transmitted
instance MotorShaftEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance DriveCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DriveCurrentSensor
]

instance DriveTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DriveTemperatureSensor
]

// Data (internal representation)
instance MotorShaftAngleData : DTDFVocab:Data [
    base:desc "Encoded rotational angle of the motor shaft, derived from MotorShaftEncoderDataTransmitted."
    DTDFVocab:fromData MotorShaftEncoderDataTransmitted
    DTDFVocab:inputTo JsonParserEnabler
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Encoded rotational angle of the gearbox output, derived from GearboxEncoderDataTransmitted."
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo JsonParserEnabler
]

instance DriveCurrentReadingData : DTDFVocab:Data [
    base:desc "Measured commutator current of the drive, derived from DriveCurrentDataTransmitted."
    DTDFVocab:fromData DriveCurrentDataTransmitted
    DTDFVocab:inputTo JsonParserEnabler
]

instance DriveTemperatureReadingData : DTDFVocab:Data [
    base:desc "Measured temperature of the drive, derived from DriveTemperatureDataTransmitted."
    DTDFVocab:fromData DriveTemperatureDataTransmitted
    DTDFVocab:inputTo JsonParserEnabler
]

// Enablers
instance MqttReceiverEnabler : DTDFVocab:Enabler [
    base:desc "MQTT client that receives JSON payloads on the local network (≤1 Mbps) and forwards raw data to the JSON parser."
    DTDFVocab:enables JsonParserService
]

instance JsonParserEnabler : DTDFVocab:Enabler [
    base:desc "JSON parser processing the 256‑byte MQTT payloads into structured data objects for downstream models."
    DTDFVocab:enables SimulinkExecutionService, MontiArcAutomatonService
]

instance SimulinkExecutionEnabler : DTDFVocab:Enabler [
    base:desc "Simulink runtime executing the mathmodel of the mechanical system, using the angular angle and current data."
    DTDFVocab:enables SimulationInsightService
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton engine executing the state‑machine based control behavior derived from SysML."
    DTDFVocab:enables GuidanceInsightService
]

instance ModelRepositoryEnabler : DTDFVocab:Enabler [
    base:desc "Repository storing SysML, MontiArc, and Simulink model artifacts for traceability."
]

// Services
instance JsonParserService : DTDFVocab:Service [
    base:desc "Service handling JSON parsing of MQTT payloads."
    DTDFVocab:provides EncoderAccuracyInsight
]

instance SimulinkExecutionService : DTDFVocab:Service [
    base:desc "Simulink execution service providing simulation results."
    DTDFVocab:provides GearDrivetrainSimulationInsight
]

instance MontiArcAutomatonService : DTDFVocab:Service [
    base:desc "MontiArc Automaton service providing guidance insights."
    DTDFVocab:provides GuidanceInsightService
]

instance SimulationInsightService : DTDFVocab:Service [
    base:desc "Service providing simulation results for the mechanical system."
    DTDFVocab:provides GearDrivetrainSimulationInsight
]

instance GuidanceInsightService : DTDFVocab:Service [
    base:desc "Service providing state‑machine driven guidance insights."
    DTDFVocab:provides EncoderAccuracyInsight
]

// Models
instance SysMLProductArchitectureModel : DTDFVocab:Model [
    base:desc "SysML product‑level architecture defining requirements, functional, logical, and product layers."
    DTDFVocab:inputTo ModelRepositoryEnabler
]

instance MontiArcAutomatonBehaviorModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton behavior model specifying state‑machines for dynamic control."
    DTDFVocab:inputTo MontiArcAutomatonEnabler
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Simulink model integrating physics‑based dynamics, control logic, and data flow for simulation validation."
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

// Insights
instance GearDrivetrainSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight into gear train performance, validating cycloidal gear dynamics against measured encoder data."
]

instance EncoderAccuracyInsight : DTDFVocab:Insight [
    base:desc "Insight into encoder measurement accuracy, comparing motor shaft (0.1° RMS) and gearbox (0.03° RMS) resolutions."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin in this scenario functions as a passive digital shadow; therefore, there are no outbound control or command messages from the virtual domain to the physical robot. The system does not issue any control signals, authenticate or validate commands, or provide feedback to the actuator. Consequently, virtual‑to‑physical interaction is effectively non‑existent in this implementation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is quantitively assessed by comparing simulated joint trajectories against measured encoder data using a “solution‑scope” metric that defines the maximum allowed deviation. Verification is performed by injecting known disturbances into the physical plant and ensuring the Twin’s outputs stay within the predefined tolerance bounds. Key uncertainty sources—including backlash, encoder quantization, and current sensor noise—are quantified through error propagation analyses and validated against empirical residuals. A residual monitor flags bias exceeding 0.5 % of full scale. The Twin’s data management layer records timestamps for all events and synchronizes them across subsystems to guarantee chronological consistency. The overall quality assurance process follows a regression schedule, automatically re‑validating each model update against the measurement database and ensuring continued compliance with the defined fidelity criteria."
]