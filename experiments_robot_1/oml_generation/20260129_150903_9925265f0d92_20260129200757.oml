// C3: Physical sensing components (derived from digital‑shadow context)
instance ContextualDataTraceSensor : DTDFVocab:SensingComponent [
    base:desc "Collects contextual data traces defined in the digital‑shadow reference UML class diagram for specific purposes."
    DTDFVocab:producedData ContextualDataTraceTransmission
]

// C4: Physical-to-virtual interaction
instance ContextualDataTraceTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContextualDataTraceSensor
]

// C10: Data
instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces used for model integration and analysis."
    DTDFVocab:fromData ContextualDataTraceTransmission
    DTDFVocab:inputTo ModelRepositoryEnabler
]

// C10: Models
instance SysMLBlockDiagramModel : DTDFVocab:Model [
    base:desc "Model of functional and logical architecture defined using SysML internal block diagrams."
    DTDFVocab:inputTo SysMLToolEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "Behavioral model defined using SysML state machines (v1.7)."
    DTDFVocab:inputTo SysMLToolEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "Component‑connector architecture specified in ACME ADL."
    DTDFVocab:inputTo ADLToolEnabler
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "Component‑connector architecture specified in AADL ADL."
    DTDFVocab:inputTo ADLToolEnabler
]

instance MontiArcConnectorModel : DTDFVocab:Model [
    base:desc "Component‑connector structure specified using MontiArc ADL."
    DTDFVocab:inputTo MontiArcToolEnabler
]

instance MontiArcAutomatonBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral specification using MontiArc Automaton."
    DTDFVocab:inputTo MontiArcToolEnabler
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model executed in MathWorks Simulink for domain‑specific analysis."
    DTDFVocab:inputTo SimulinkEnabler
]

instance CppExecutableModel : DTDFVocab:Model [
    base:desc "Executable logic artifact implemented in C++ linked to model behavior."
    DTDFVocab:inputTo CppCompilerEnabler
]

instance JavaExecutableModel : DTDFVocab:Model [
    base:desc "Executable logic artifact implemented in Java linked to model behavior."
    DTDFVocab:inputTo JavaCompilerEnabler
]

// C11: Enablers
instance SysMLToolEnabler : DTDFVocab:Enabler [
    base:desc "Tool supporting SysML modeling, including internal block diagrams and state machines."
    DTDFVocab:enables ModelIntegrationService
]

instance ADLToolEnabler : DTDFVocab:Enabler [
    base:desc "Toolset handling ACME, AADL, and MontiArc architecture description languages."
    DTDFVocab:enables ModelIntegrationService
]

instance MontiArcToolEnabler : DTDFVocab:Enabler [
    base:desc "Specialized tool for MontiArc modeling and automaton behavior."
    DTDFVocab:enables ModelIntegrationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "Simulation environment for executing Simulink models."
    DTDFVocab:enables SimulationExecutionService
]

instance CppCompilerEnabler : DTDFVocab:Enabler [
    base:desc "C++ compiler enabling transformation of source code into executable twin components."
    DTDFVocab:enables CodeExecutionService
]

instance JavaCompilerEnabler : DTDFVocab:Enabler [
    base:desc "Java compiler enabling transformation of source code into executable twin components."
    DTDFVocab:enables CodeExecutionService
]

instance ModelRepositoryEnabler : DTDFVocab:Enabler [
    base:desc "MBSE repository managing model composition, inheritance, and interface bindings across abstraction layers."
    DTDFVocab:enables ModelIntegrationService, DataAggregationService
]

// C6: Services
instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Integrates heterogeneous models and data traces across requirements, functions, logics, and physics layers."
    DTDFVocab:provides ArchitectureTraceabilityInsight, BehavioralVerificationAction
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Executes simulation models to produce behavioral analysis results."
    DTDFVocab:provides SimulationResultInsight
]

instance CodeExecutionService : DTDFVocab:Service [
    base:desc "Runs compiled executable twin components representing active behavior."
    DTDFVocab:provides ExecutableDeploymentAction
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Aggregates contextual data traces for use by models and analytics."
    DTDFVocab:provides ArchitectureTraceabilityInsight
]

// C17: Insights/Actions
instance ArchitectureTraceabilityInsight : DTDFVocab:Insight [
    base:desc "Provides insight into traceability from physical asset data to analytical and behavioral representations."
]

instance BehavioralVerificationAction : DTDFVocab:Action [
    base:desc "Automated action to verify behavioral models against specifications."
    DTDFVocab:IsAutomatic true
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Delivers insight derived from simulation results for decision support."
]

instance ExecutableDeploymentAction : DTDFVocab:Action [
    base:desc "Deploys compiled executable twin components into the runtime environment."
    DTDFVocab:IsAutomatic false
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The document outlines that DT development follows Model‑Based Systems‑Engineering (MBSE) with modeling split into four abstraction levels—requirements, functional architecture, logical architecture, and product/technical layer. These levels serve as representation types at successive DT lifecycle phases, and transition between phases is achieved by refining models from high‑level requirements down to detailed product models. No explicit lifecycle governance approach is described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The document cites the use of standardized modeling languages—SysML (an OMG standard), ACME, AADL, MontiArc, and SysML internal block diagrams—as the foundation for describing the Digital Twin, indicating adherence to these modeling standards. No specific industry certifications, compliance frameworks, or interoperability standards are mentioned."
]