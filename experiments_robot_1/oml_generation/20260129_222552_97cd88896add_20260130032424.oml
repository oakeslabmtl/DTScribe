// E1: Enabler – SysML Toolchain
instance SysMLToolchain : DTDFVocab:Enabler [
    base:desc "SysML v1.7 toolchain enabling component–connector architecture with Information Block Diagrams and state‑machine models."
    DTDFVocab:enables SimulationService, ModelValidationService
]

// E2: Enabler – MontiArc Tool
instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc modeling tool providing ADL composition and automaton‑based state‑machine semantics."
    DTDFVocab:enables SimulationService, ModelValidationService
]

// E3: Enabler – Simulink Engine
instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink engine used for continuous‑time dynamics and integration of SysML/ADL models."
    DTDFVocab:enables SimulationService, ModelValidationService
]

// E4: Enabler – Code Generator
instance CodeGenerator : DTDFVocab:Enabler [
    base:desc "Code generator that produces C++/Java artifacts from Simulink or MontiArc models."
    DTDFVocab:enables CodeGenerationService
]

// E5: Enabler – Version Control Service
instance VCSService : DTDFVocab:Enabler [
    base:desc "Git‑based VCS for MBSE artifacts and generated source code, supporting branching, rollback, and versioning."
    DTDFVocab:enables CIService
]

// S1: Service – Simulation Service
instance SimulationService : DTDFVocab:Service [
    base:desc "Service that orchestrates simulation of cooperative models using MathWorks Simulink and MontiArc."
    DTDFVocab:provides SimulationValidationInsight
]

// S2: Service – Code Generation Service
instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Service that converts validated models into compilable C++ or Java artifacts for real‑time execution."
    DTDFVocab:provides CodeReuseAction
]

// S3: Service – Model Validation Service
instance ModelValidationService : DTDFVocab:Service [
    base:desc "Service that performs simulation‑driven validation of MBSE models using Simulink or MontiArc Auto‑maton tools."
    DTDFVocab:provides SimulationValidationInsight
]

// S4: Service – Continuous Integration Service
instance CIService : DTDFVocab:Service [
    base:desc "CI pipeline automating build, test and consistency checks for Simulink, MontiArc models and generated source code."
    DTDFVocab:provides RollbackAction
]

// M1: Model – SysML Functional Model
instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML functional architecture defined with Information Block Diagrams and state‑machine diagrams."
    DTDFVocab:inputTo SysMLToolchain
]

// M2: Model – SysML Logical Model
instance SysMLLogicalModel : DTDFVocab:Model [
    base:desc "SysML logical architecture capturing system behavior through state‑machine formalism."
    DTDFVocab:inputTo SysMLToolchain
]

// M3: Model – MontiArc Automaton Model
instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc ADL model incorporating finite state machine behavior via MontiArc Automaton extensions."
    DTDFVocab:inputTo MontiArcTool
]

// M4: Model – Simulink Dynamics Model
instance SimulinkMathematicalModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model representing continuous‑time dynamics derived from SysML logical specification."
    DTDFVocab:inputTo SimulinkEngine
]

// I1: Insight – Simulation Validation Insight
instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Insight that confirms the fidelity of simulation results against defined requirements and constraints."
]

// A1: Action – Code Reuse Action
instance CodeReuseAction : DTDFVocab:Action [
    base:desc "Automatic action that archives reusable C++/Java code artifacts generated from validated models."
    DTDFVocab:IsAutomatic true
]

// A2: Action – Rollback Action
instance RollbackAction : DTDFVocab:Action [
    base:desc "Automatic action that reverts the system to a previous stable DT version following VCS rollback strategies."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows a Model‑Based Systems‑Engineering (MBSE) disciplined pathway comprising four abstraction layers: (1) requirements abstraction, where stakeholder needs are captured in system–level requirement documents; (2) functional architecture, described with SysML use‑case and activity diagrams and refined in component‑connector diagrams such as ADL snippets from ACME or SysML IBDs; (3) logical architecture, developed with architectural description languages (ADLs) like MontiArc or AADL automata that capture behavioral aspects; and (4) product/technical layers, where concrete implementation models are specified using code generators or Simulink block diagrams. Transition management between layers is governed by RFLP (Requirements‑Functions‑Logics‑Physics) methodology, ensuring traceability of functional intent through to physical entities. Lifecycle governance is performed with MBSE tools that support model versioning, change‑impact analysis, and artifact linking across the four layers."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Standard compliance is achieved by adhering to open modeling standards: SysML v1.7 for functional and structural modeling, AADL for architecture description with real‑time properties, MontiArc for component‑connector behavioral modeling, and ACME for extensible architectural notation. These ADLs ensure interoperability with industry toolchains such as Enterprise Architect or Cameo, and provide mapping mechanisms to IEC 61131‑3 code templates for further implementation."
]