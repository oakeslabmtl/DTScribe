// C1: Environment
instance IndustrialRobotOperationEnvironment : DTDFVocab:Environment [
    base:contains MABI_MAX100Robot
]

// C2: Acting Components
instance MABI_MAX100Robot : DTDFVocab:Component [
    base:desc "MABI MAX 100 serial industrial robot with six revolute joints, permanent‑magnet synchronous motor driving gear and cycloidal gear train, used for subtraction‑manufacturing tasks."
]

// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures the input current of the permanent‑magnet synchronous motor at the first joint."
    DTDFVocab:producedData MQTTPayloadDataStream
]

instance OutputShaftAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Measures the output shaft angle of the first joint via a rotary encoder."
    DTDFVocab:producedData MQTTPayloadDataStream
]

// C4: Physical‑to‑virtual interaction
instance MQTTPayloadDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor, OutputShaftAngleSensor
]

// C10: Models/Data
instance InputCurrentData : DTDFVocab:Data [
    base:desc "Raw numeric value of input current received via MQTT."
    DTDFVocab:inputTo MQTTDataIngestionEnabler, MappingLayerEnabler
    DTDFVocab:fromData MQTTPayloadDataStream
]

instance OutputShaftAngleData : DTDFVocab:Data [
    base:desc "Raw numeric value of output shaft angle received via MQTT."
    DTDFVocab:inputTo MQTTDataIngestionEnabler, MappingLayerEnabler
    DTDFVocab:fromData MQTTPayloadDataStream
]

instance ACMEFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "Functional architecture expressed in ACME representing component‑connector graph."
    DTDFVocab:inputTo MappingLayerEnabler
]

instance MontiArcAutomatonBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model in MontiArc Automaton capturing discrete event logic."
    DTDFVocab:inputTo MappingLayerEnabler
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model instantiated in MathWorks Simulink for quantitative analysis."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

// C11: Enablers
instance MQTTDataIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Ingests MQTT payload stream into twin’s data layer."
    DTDFVocab:enables ModelDrivenMonitoringService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Executes Simulink model to produce simulated robotic states."
    DTDFVocab:enables ModelDrivenMonitoringService
]

instance MappingLayerEnabler : DTDFVocab:Enabler [
    base:desc "Maps physical sensor traces to corresponding model elements for state reconciliation."
    DTDFVocab:enables ModelDrivenMonitoringService
]

// C6: Services
instance ModelDrivenMonitoringService : DTDFVocab:Service [
    base:desc "Monitors twin by reconciling real‑world sensor data with model predictions."
    DTDFVocab:provides StatePredictionInsight
]

// C17: Insights/Actions
instance StatePredictionInsight : DTDFVocab:Insight [
    base:desc "Insight into the alignment between sensed shaft angle and simulated joint angle predictions."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system adopts a modular, concept‑driven architecture as outlined in the Digital Shadow Reference Model (DSRM). Core concepts—Asset, Model, and Processing—are represented as distinct UML classes linked through explicit composition relations. Asset encapsulates the physical device and its connectivity information; Model embodies the functional, logical, and data abstractions generated from SysML, MontiArc, or other ADLs; and Processing contains state‑machine or simulation elements that transform sensor streams into analytical outputs. Coordination among these concepts is achieved through hierarchical composition, where an Asset hosts one or more Models, each of which in turn orchestrates multiple Processing instances. The integration of these layers is facilitated by the Asset Administration Shell (AAS) that exposes both data and operation interfaces, thereby enabling resource management, versioning, and runtime deployment across distributed components."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows a Model‑Based Systems Engineering (MBSE) paradigm, progressing through the classic abstraction layers: (1) Requirements—formalized as textual or structured requirement artifacts; (2) Functional Architecture—captured with SysML use‑case or activity diagrams; (3) Logical Architecture—modeled with architecture description languages (ADLs) such as MontiArc Automaton, SysML interaction blocks, or AADL for logical component–connector views; (4) Product/Technical Layer—tangible artefacts including code (C++/Java) and simulation models (Simulink), which can be generated or validated against the logical model. Transitions between phases are managed through traceability links established in the MBSE toolchain and by applying multi‑level RFLP (Requirements, Functions, Logics, Physics) or SMArDT methodologies to maintain consistency. Governance of the lifecycle is typically achieved through MBSE discipline, versioned model repositories, and stakeholders’ review processes, although specific governance frameworks are not detailed in the source."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the physical sensors and the digital twin is performed using the MQTT messaging protocol. No additional details on network topology, bandwidth, security mechanisms, or redundancy are provided in the text. "
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The twin system communicates with external devices and systems through the Asset Administration Shell (AAS) and MQTT messaging. Sensors attached to the physical object produce time‑series data that are streamed via MQTT publish‑subscribe topics. The AAS interface exposes data attributes and operations through standard REST/ROA or OData endpoints, allowing external applications—such as supervisory control, maintenance decision‑support, or analytics—to query or invoke services on the twin without modifying the twin’s internal model. Integration is achieved by mapping AAS data elements to the twin’s model attributes and processing streams continuously, enabling a real‑time data‑driven representation."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach leverages established industry‑recognized modeling standards: SysML (for system requirement and architecture modeling), MontiArc (as an ADL for component‑and‑connector modeling with automaton extensions), and AADL (for system-level architecture). These languages serve as the underlying specification format, aligning the Digital Twin with prevalent systems engineering standards; explicit certification or interoperability compliance frameworks are not mentioned in the document."
]