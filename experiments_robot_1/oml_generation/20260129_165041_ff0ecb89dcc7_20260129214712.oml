instance ManufacturingSystem : DTDFVocab:Component [
    base:desc "Physical system operating in manufacturing domain as per digital shadow reference model"
]

instance MBSESysMLModel : DTDFVocab:Model [
    base:desc "SysML for structuring systems across abstraction levels (requirements, functional architecture, logical architecture, product/technical layer)"
    DTDFVocab:inputTo SysMLEnabler
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME for defining component interfaces, interconnections, and composition"
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL for defining component interfaces, interconnections, and composition"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcADLModel : DTDFVocab:Model [
    base:desc "MontiArc for defining component interfaces, interconnections, and composition"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams (IBDs) for defining component interfaces, interconnections, and composition"
    DTDFVocab:inputTo SysMLEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavioral modeling"
    DTDFVocab:inputTo SysMLEnabler
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink for simulation and behavioral modeling"
    DTDFVocab:inputTo SimulinkEnabler
]

instance CppCodeModel : DTDFVocab:Model [
    base:desc "C++ for detailed behavior description"
    DTDFVocab:inputTo CppEnabler
]

instance JavaCodeModel : DTDFVocab:Model [
    base:desc "Java for detailed behavior description"
    DTDFVocab:inputTo JavaEnabler
]

instance StakeholderPerspectivesDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom [ ]
]

instance StakeholderPerspectivesData : DTDFVocab:Data [
    base:desc "Heterogeneous stakeholder perspectives data"
    DTDFVocab:fromData StakeholderPerspectivesDataTransmitted
    DTDFVocab:inputTo UMLClassDiagramsEnabler
]

instance ContextualDataTracesTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom [ ]
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Contextual data traces from physical systems"
    DTDFVocab:fromData ContextualDataTracesTransmitted
    DTDFVocab:inputTo SimulinkEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering (MBSE) with SysML for system modeling"
    DTDFVocab:enables SystemModelingService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME architecture description language for component & connector perspectives"
    DTDFVocab:enables ACMEModelingService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL architecture description language for component & connector perspectives"
    DTDFVocab:enables AADLModelingService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc architecture description language for component & connector perspectives"
    DTDFVocab:enables MontiArcModelingService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation"
    DTDFVocab:enables SimulationService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior description"
    DTDFVocab:enables CppBehaviorService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior description"
    DTDFVocab:enables JavaBehaviorService
]

instance UMLClassDiagramsEnabler : DTDFVocab:Enabler [
    base:desc "UML class diagrams for constructing digital shadow reference model in manufacturing contexts"
    DTDFVocab:enables UMLModelingService
]

instance SystemModelingService : DTDFVocab:Service [
    base:desc "Service for system modeling using SysML"
    DTDFVocab:provides SystemModelingInsight
]

instance ACMEModelingService : DTDFVocab:Service [
    base:desc "Service for ACME architecture modeling"
    DTDFVocab:provides ACMEModelingInsight
]

instance AADLModelingService : DTDFVocab:Service [
    base:desc "Service for AADL architecture modeling"
    DTDFVocab:provides AADLModelingInsight
]

instance MontiArcModelingService : DTDFVocab:Service [
    base:desc "Service for MontiArc architecture modeling"
    DTDFVocab:provides MontiArcModelingInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for simulation using Simulink"
    DTDFVocab:provides SimulationInsight
]

instance CppBehaviorService : DTDFVocab:Service [
    base:desc "Service for C++ behavior description"
    DTDFVocab:provides CppBehaviorInsight
]

instance JavaBehaviorService : DTDFVocab:Service [
    base:desc "Service for Java behavior description"
    DTDFVocab:provides JavaBehaviorInsight
]

instance UMLModelingService : DTDFVocab:Service [
    base:desc "Service for UML class diagram modeling"
    DTDFVocab:provides UMLModelingInsight
]

instance SystemModelingInsight : DTDFVocab:Insight [
    base:desc "Insight from system modeling"
]

instance ACMEModelingInsight : DTDFVocab:Insight [
    base:desc "Insight from ACME architecture modeling"
]

instance AADLModelingInsight : DTDFVocab:Insight [
    base:desc "Insight from AADL architecture modeling"
]

instance MontiArcModelingInsight : DTDFVocab:Insight [
    base:desc "Insight from MontiArc architecture modeling"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from simulation results"
]

instance CppBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight from C++ behavior description"
]

instance JavaBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight from Java behavior description"
]

instance UMLModelingInsight : DTDFVocab:Insight [
    base:desc "Insight from UML class diagram modeling"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system employs industry-standard modeling languages and architecture description languages such as SysML, AADL, ACME, and MontiArc for representing system components, interfaces, and interconnections across multiple abstraction levels (requirements, functional, logical, and physical). These standards facilitate interoperability among heterogeneous modeling tools and integration of diverse stakeholder perspectives within the Model-Based Systems Engineering framework."
]