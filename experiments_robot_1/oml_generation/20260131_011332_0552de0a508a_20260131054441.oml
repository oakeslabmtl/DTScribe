// C3: Physical sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution encoder mounted directly on the permanent magnet synchronous motor providing angular position data for closed-loop control."
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gear transmission providing redundant angular position data for mechanical alignment accuracy."
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input current to the permanent magnet synchronous motor for dynamic behavior analysis."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical-to-virtual interaction
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
    base:desc "Real-time streaming of high-resolution angular position data from motor encoder via MQTT protocol."
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
    base:desc "Real-time streaming of angular position data from gearbox encoder via MQTT protocol for redundancy."
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
    base:desc "Real-time streaming of motor input current data via MQTT protocol for dynamic analysis."
]

// C10: Models/Data
instance JointAngleData : DTDFVocab:Data [
    base:desc "Aggregated joint angle data derived from motor and gearbox encoder data traces for kinematic analysis."
    DTDFVocab:fromData MotorEncoderDataTransmitted, GearboxEncoderDataTransmitted
    DTDFVocab:inputTo SysMLModelingEnabler, SimulinkSimulationEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Processed motor current data for dynamic behavior modeling and friction compensation analysis."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEnabler, CppDataProcessingEnabler
]

instance FrictionProfileData : DTDFVocab:Data [
    base:desc "Higher-level abstraction of gearbox friction metrics derived from joint angle and motor current data."
    DTDFVocab:fromData JointAngleData, MotorCurrentData
    DTDFVocab:inputTo SysMLModelingEnabler, SimulinkSimulationEnabler
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) defining component interfaces, interconnections, and composition for the MABI MAX 100 robot."
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based logical architecture model representing control logic and data flows between robot components."
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance StateMachineBehaviorModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model for behavioral modeling of robot control states and transitions."
    DTDFVocab:inputTo SysMLModelingEnabler, SimulinkSimulationEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model for formal behavioral specification of friction compensation logic."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for dynamic behavior simulation including control logic and friction compensation."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling framework for systems engineering modeling across requirements, functional, and logical architecture layers."
    DTDFVocab:enables FunctionalArchitectureService, LogicalArchitectureService, StateMachineService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation framework for dynamic behavior modeling and validation of control logic."
    DTDFVocab:enables DynamicBehaviorService, FrictionAnalysisService
]

instance CppDataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "C++ implementation for custom data processing scripts and interface adapters between Siemens controller and digital shadow."
    DTDFVocab:enables DataProcessingService
]

instance JavaDataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Java implementation for additional data processing and visualization components."
    DTDFVocab:enables DataProcessingService
]

// C6: Services
instance FunctionalArchitectureService : DTDFVocab:Service [
    base:desc "Service providing SysML-based functional architecture definition with component interfaces and interconnections."
    DTDFVocab:provides FunctionalArchitectureInsight
]

instance LogicalArchitectureService : DTDFVocab:Service [
    base:desc "Service providing SysML-based logical architecture representation of control data flows."
    DTDFVocab:provides LogicalArchitectureInsight
]

instance StateMachineService : DTDFVocab:Service [
    base:desc "Service enabling state machine-based behavioral modeling for robot control states."
    DTDFVocab:provides ControlStateInsight
]

instance DynamicBehaviorService : DTDFVocab:Service [
    base:desc "Service providing dynamic behavior simulation and validation through Simulink models."
    DTDFVocab:provides DynamicBehaviorInsight
]

instance FrictionAnalysisService : DTDFVocab:Service [
    base:desc "Service enabling friction profile identification and compensation through behavioral models."
    DTDFVocab:provides FrictionProfileInsight
]

instance DataProcessingService : DTDFVocab:Service [
    base:desc "Service for preprocessing, aggregation, and abstraction of raw sensor data into higher-level contextual traces."
    DTDFVocab:provides ProcessedDataInsight
]

instance ContextualDataAcquisitionService : DTDFVocab:Service [
    base:desc "Service automating collection of state data traces (joint angles, motor currents, gearbox friction) from Siemens controller."
    DTDFVocab:provides RealTimeDataInsight
]

// C17: Insights/Actions
instance FunctionalArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight into component interfaces, interconnections, and composition hierarchy of the MABI MAX 100 robot."
]

instance LogicalArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight into control data flows and logical architecture representation of the robot system."
]

instance ControlStateInsight : DTDFVocab:Insight [
    base:desc "Insight into robot control states and transitions modeled through state machines."
]

instance DynamicBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight into dynamic behavior simulation results including control logic validation and performance metrics."
]

instance FrictionProfileInsight : DTDFVocab:Insight [
    base:desc "Insight into gearbox friction profiles and compensation strategies derived from behavioral models."
]

instance ProcessedDataInsight : DTDFVocab:Insight [
    base:desc "Insight into aggregated and abstracted sensor data traces for higher-level analysis."
]

instance RealTimeDataInsight : DTDFVocab:Insight [
    base:desc "Insight into real-time state data traces collected from the physical robot system."
]

// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Primary actuator driving the robot's axis with permanent magnet synchronous motor technology."
]

instance GearTransmission : DTDFVocab:ActingComponent [
    base:desc "Mechanical gear transmission system adjusting mechanical power between motor and robot joints."
]

instance SiemensSINUMERIK840DslController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl controller managing separate axis control with configurable position, speed, and acceleration inputs."
]

// C17: Actions (Passive services only)
instance PassiveMonitoringAction : DTDFVocab:Action [
    base:desc "Passive monitoring of system behavior without active feedback loops."
    DTDFVocab:IsAutomatic false
]

instance DataAggregationAction : DTDFVocab:Action [
    base:desc "Automated aggregation and abstraction of raw sensor data into higher-level contextual traces."
    DTDFVocab:IsAutomatic true
]

// C10: Environment
instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:desc "Industrial manufacturing domain requiring high-precision closed-loop control and predictive maintenance."
    base:contains PermanentMagnetSynchronousMotor, GearTransmission, SiemensSINUMERIK840DslController
]

// C10: Components
instance RobotMechanicalStructure : DTDFVocab:Component [
    base:desc "Six-axis serial manipulator structure of the MABI MAX 100 robot."
    base:isContainedIn ManufacturingEnvironment
]

instance ControlSystem : DTDFVocab:Component [
    base:desc "Control system architecture including Siemens controller and behavioral models."
    base:isContainedIn ManufacturingEnvironment
]

instance DigitalShadowSystem : DTDFVocab:Component [
    base:desc "Digital Shadow implementation providing passive data collection and aggregation services."
    base:isContainedIn ManufacturingEnvironment
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system operates with a **real-time, data-driven temporal synchronization** between the physical and digital components, relying on **live measurements** and **automated one-way data flows** (as defined in the Digital Shadow Reference Model). While explicit synchronization frequencies (e.g., Hz, ms) or latency requirements are not specified, the system inherently supports **temporal granularity** aligned with the **behavioral modeling** of components (e.g., state machines in SysML v1.7 or MontiArc Automaton). Integration with simulation tools (e.g., MathWorks Simulink) further enables **time-scale-aware validation** of dynamic system behaviors, though no quantitative constraints (e.g., sub-millisecond latency) are documented. The absence of explicit time-scale definitions suggests reliance on **contextual operational requirements** (e.g., manufacturing process cycles) rather than rigid technical specifications."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin (DT) constellation in this context is implicitly defined through **Model-Based Systems Engineering (MBSE) methodologies** and **architecture description languages (ADLs)**. The orchestration and coordination of the DT system rely on **multi-layered modeling approaches** (e.g., RFLP, OOSEM, SPES, or SMArDT), which decompose systems into **requirements, functions, logics, and physics layers**. The **component & connector perspective** of ADLs (e.g., ACME, AADL, MontiArc, or SysML IBDs) enables **modular integration** of DT components, where **interfaces, interconnections, and composition** are explicitly modeled. Behavior is further refined using **state machines (SysML v1.7), automata (MontiArc Automaton), or simulation tools (e.g., MathWorks Simulink, other simulation methods [29]-[30])**, ensuring **tight coupling between digital and physical representations**. Resource management is not explicitly detailed, but the integration of **heterogeneous tools and stakeholders** suggests a **service-oriented or microservices-like architecture** for coordination, with potential dependencies on **general-purpose languages (C++, Java)** for implementation. No explicit orchestration patterns (e.g., event brokers, middleware) are mentioned, but the use of ADLs implies **standardized interfaces** for system-wide coordination."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle stages, as inferred from the provided context, align with **Model-Based Systems Engineering (MBSE)** methodologies and involve structured abstraction layers for system representation. The lifecycle includes:
  1. **Development Phase**: Utilizes **SysML** (Systems Modeling Language) for modeling across multiple abstraction levels, including **requirements**, **functional architecture**, **logical architecture**, and **product/technical layer**. The **RFLP (Requirements, Functions, Logics, Physics)**, **OOSEM**, **SPES**, or **SMArDT** methodologies may be employed to manage complexity.
  2. **Representation Types**: Models are described using **architecture description languages (ADLs)** such as **ACME**, **AADL**, **MontiArc**, or **SysML Internal Block Diagrams (IBDs)**, capturing **components**, **interfaces**, **interconnections**, and **composition**. Behavioral modeling is extended via **MontiArc Automaton** or **SysML state machines**, often integrated with **MathWorks Simulink** or other simulation tools (e.g., **C++/Java** implementations).
  3. **Transition Management**: The lifecycle transitions between abstraction layers are governed by **heterogeneous stakeholder integration** and **tool interoperability**, ensuring consistency across modeling notations (e.g., SysML, ADLs, simulation tools).
  4. **Lifecycle Governance**: While explicit governance frameworks (e.g., ISO standards) are not detailed, the **Digital Shadow Reference Model** (Fig. 1) implies a structured approach to **data aggregation**, **abstraction**, and **purpose-driven contextualization**, which may inform governance for Digital Twin evolution. The passive-to-active transition (from Digital Shadow to Digital Twin) suggests a **data-driven validation** phase for operational readiness."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **validation via deviation analysis between simulated and measured data**, ensuring alignment between digital and physical states. However, the provided document does not specify explicit **uncertainty quantification methods, error correction mechanisms, or quality assurance processes** beyond the one-way data flow characteristic of digital shadows. **Safety constraints** are not detailed, nor are **environmental noise or transmission latency** addressed as uncertainty sources. The system’s fidelity is implicitly tied to the **accuracy of aggregated contextual data traces** from the physical object, but no quantitative metrics or validation protocols (e.g., statistical tests, calibration procedures) are described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for the Digital Shadow system leverages **MQTT** as the primary communication protocol for streaming sensor data from physical objects to the digital representation. While the document does not specify the **network topology or architecture**, the use of MQTT implies a **lightweight, scalable, and event-driven** communication model suitable for industrial IoT environments. Bandwidth and latency requirements are not explicitly quantified, but the system must support **real-time or near-real-time data transmission** to maintain synchronization between physical and digital states. **Reliability and redundancy mechanisms** are not detailed, though the one-way data flow suggests minimal dependency on bidirectional communication. Security protocols for network communication are not addressed in the provided context."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with external systems primarily through **one-way data flows** from physical objects to their digital representations, as defined for Digital Shadows. The document specifies that **sensor data streaming** is a key input, with no explicit protocol (e.g., MQTT, OPC UA, HTTP) mentioned for this purpose. While the system may rely on **heterogeneous modeling tools** (e.g., Simulink, general-purpose languages like C++/Java) for processing, there is no evidence of **interoperability standards** (e.g., OPC UA, FIWARE) or **enterprise system dependencies** (e.g., ERP, MES). The integration pattern is **passive and unidirectional**, with no indication of **API-mediated connections, bidirectional data exchange, or federated Digital Twin architectures**. The document does not address **external system dependencies** beyond the implicit requirement for active components to process incoming data."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The provided documents reference the use of **Asset Administration Shells (AAS)** as a framework for digital twins in manufacturing, which inherently supports **safety-critical system considerations** through structured data modeling (e.g., via **SysML** or **RAMI4.0**). However, no explicit details on **cybersecurity protocols** (e.g., OAuth 2.0, JWT, TLS 1.3), **access control mechanisms**, or **threat mitigation strategies** are documented. The **safety cell** concept (physical safety constraint) is mentioned in the context of robotic systems (e.g., MABI robotic arms), but no cybersecurity or fail-safe mechanisms are specified. Data is streamed via **MQTT** (as referenced in [52]), but no **Quality of Service (QoS) levels** or authentication methods are described. Thus, the documents lack granular technical specifications for security and safety beyond high-level architectural references."
]