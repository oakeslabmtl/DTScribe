instance PMSMActuator : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor as the primary actuator, controlled via dedicated interfaces with defined torque and speed limits"
]

instance GearTransmission : DTDFVocab:ActingComponent [
    base:desc "Gear transmission coupled with cycloidal gear mechanism to convert rotational motion into precise linear or rotational movement"
]

instance CycloidalGearMechanism : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear mechanism for precise motion conversion, ensuring safe operation within mechanical constraints"
]

instance MABIMAX100FirstVerticalAxis : DTDFVocab:Component [
    base:desc "Physical system under study: MABI MAX 100 serial industrial robot's first vertical axis at the base. Operational domain is manufacturing, six-axis configuration, friction loss analysis for digital shadow implementation."
]

instance SysMLTool : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering (MBSE) utilizing SysML for systems modeling across abstraction levels (requirements, functional architecture, logical architecture, product/technical layer)"
]

instance MontiArcAutomatonTool : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for system behavior description"
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed behavioral simulation"
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML for structural modeling including component & connector perspectives through IBDs",
    inputTo SysMLTool
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines describing system behavior",
    inputTo SysMLTool
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for system behavior description",
    inputTo MontiArcAutomatonTool
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "Simulink for detailed behavioral simulation",
    inputTo SimulinkTool
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements, Functions, Logics, Physics) methodology for managing complexity"
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for managing complexity"
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for managing complexity"
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for managing complexity"
]

instance ACMEADL : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language defining components, interfaces, interconnections, and composition"
]

instance AADLADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language defining components, interfaces, interconnections, and composition"
]

instance MontiArcADL : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language defining components, interfaces, interconnections, and composition"
]

instance CPlusPlus : DTDFVocab:Enabler [
    base:desc "C++ general-purpose language for detailed behavioral modeling"
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java general-purpose language for detailed behavioral modeling"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system utilizes modeling languages such as SysML [17], AADL [24], ACME [23], and MontiArc [25,26] for architecture description, defining components, interfaces, interconnections, and composition, while addressing the integration of heterogeneous stakeholders [31]."
]