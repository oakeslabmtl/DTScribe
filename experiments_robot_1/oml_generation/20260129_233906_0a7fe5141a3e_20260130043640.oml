// Sensors
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the motor shaft of the MABI MAX 100 first rotary axis."
    DTDFVocab:producedData MotorEncoderDataTransmitted
]
instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the gearbox output of the first rotary axis."
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor at the motor driver of the first rotary axis."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// DataTransmitted
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]
instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// Data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Current value measured on the motor, emitted via MQTT."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, MqttEnabler
]
instance MotorTorqueData : DTDFVocab:Data [
    base:desc "Calculated motor torque derived from the measured current."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler
]
instance MotorVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity of the motor shaft computed from encoder counts."
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler
]
instance MotorAccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration computed from successive velocity samples."
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler
]

// Models
instance AxisStructuralModel : DTDFVocab:Model [
    base:desc "Engineering SysML component diagram of the first rotary axis."
    DTDFVocab:inputTo SysmlEnabler
]
instance MotorSimulationModel : DTDFVocab:Model [
    base:desc "Simulink model representing the motor dynamics."
    DTDFVocab:inputTo SimulinkEnabler
]
instance GearboxSimulationModel : DTDFVocab:Model [
    base:desc "Simulink model representing the double‑gear gearbox."
    DTDFVocab:inputTo SimulinkEnabler
]
instance WhiteBoxFrictionModel : DTDFVocab:Model [
    base:desc "Analytical friction model based on machine mechanics."
    DTDFVocab:inputTo SimulinkEnabler
]
instance BlackBoxFrictionModel : DTDFVocab:Model [
    base:desc "Data‑driven friction model identified from measured traces."
    DTDFVocab:inputTo SimulinkEnabler
]
instance TorqueDataCalculationModel : DTDFVocab:Model [
    base:desc "Model to calculate motor torque from current and encoder data."
    DTDFVocab:inputTo SimulinkEnabler
]
instance VelocityDataCalculationModel : DTDFVocab:Model [
    base:desc "Model to calculate motor velocity from encoder counts."
    DTDFVocab:inputTo SimulinkEnabler
]

// Enablers
instance SysmlEnabler : DTDFVocab:Enabler [
    base:desc "SysML tool used for structural modeling of the robot axis."
    DTDFVocab:enables StructuralModelInsightService
]
instance UmlEnabler : DTDFVocab:Enabler [
    base:desc "UML tool used for modeling data traces of the twin."
    DTDFVocab:enables DataTraceInsightService
]
instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink simulator for motor, gearbox, and friction models."
    DTDFVocab:enables SimulationService, IdentificationService, DerivationService
]
instance MqttEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker for streaming real‑time data from the robot."
    DTDFVocab:enables DataVisualizationService
]
instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for linking physical asset data to the twin."
    DTDFVocab:enables DerivationService
]
instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard visualization tooling for real‑time data display."
    DTDFVocab:enables DataVisualizationService
]
instance AADLMontiArcEnabler : DTDFVocab:Enabler [
    base:desc "AADL/MontiArc modeling languages for system‑level design."
    DTDFVocab:enables StructuralModelInsightService
]

// Services
instance StructuralModelInsightService : DTDFVocab:Service [
    base:desc "Service that uses SysML for generating structure insights."
    DTDFVocab:provides StructuralModelInsight
]
instance DataTraceInsightService : DTDFVocab:Service [
    base:desc "Service that models data traces using UML."
    DTDFVocab:provides DataTraceInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Real‑time simulation of motor and gearbox behaviour."
    DTDFVocab:provides SimulationResultInsight
]
instance IdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification and comparison of white‑box and black‑box friction models."
    DTDFVocab:provides FrictionModelComparisonInsight
]
instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time dashboarding of measured and simulated data."
    DTDFVocab:provides DataVisualizationInsight
]
instance DerivationService : DTDFVocab:Service [
    base:desc "Derives friction estimates to improve robot control."
    DTDFVocab:provides FrictionEstimateInsight, UpdateControlParameterAction
]

// Insights
instance StructuralModelInsight : DTDFVocab:Insight [
    base:desc "Provides insights from the SysML structural model."
]
instance DataTraceInsight : DTDFVocab:Insight [
    base:desc "Insights from UML data trace modeling."
]
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Result of motor and gearbox simulation."
]
instance FrictionModelComparisonInsight : DTDFVocab:Insight [
    base:desc "Comparison of white‑box and black‑box friction models."
]
instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of measured and simulated data."
]
instance FrictionEstimateInsight : DTDFVocab:Insight [
    base:desc "Provides friction estimates and identifies changes over time."
]
instance UpdateControlParameterAction : DTDFVocab:Action [
    base:desc "Update control parameters or maintenance schedules based on twin outputs."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Not described – the digital shadow does not send commands back to the PT in this work"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time operation during robot motion (data are streamed as fast as the robot’s sensor sampling, typically tens to hundreds of Hz). The twin’s services (simulation, visualization) are updated synchronously with data flow"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralised orchestration of: asset and engineering models, simulation and data‑calculation models, data traces, processing component that consumes and produces traces, and a user dashboard. All components are linked through the DSRM (Digital Shadow Reference Model) and an AAS"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Designed for the operated‐in‑service phase – the twin is built after manufacturing to monitor and model friction changes during actual use. No design or manufacturing stage twins are described"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "White‑box (analytical) friction models are combined with data‑driven (black‑box) models; continuous traceability ensures each data point can be linked to its source model or measurement. Verification is performed by comparing simulated outputs with real sensor data, while validation focuses on matching measured and modeled torque/velocity. Uncertainty is managed through ongoing model refinement, though explicit error analysis metrics are not provided"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time data exchange over MQTT between the robot’s PLC/CNC controller and the digital twin, with asset definition via Asset Administration Shells (AAS). Network protocols and architecture are not detailed beyond MQTT"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Not specified in the document – the digital twin is implemented as software with a dashboard, likely hosted locally or on a server; however, the exact deployment environment is not described"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not mentioned – no explicit integration with external DTs or enterprise information systems is described"
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not specified – ownership and privacy aspects of sensor data are not discussed in the document"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Standards and modeling languages used include SysML, UML, AAS (Asset Administration Shell), MQTT, and Simulink; also references to AADL, MontiArc, and other ADLs through literature citations"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Not addressed in the document – no discussion of cybersecurity, access control, or safety implications of remote operation or data integrity"
]