// C3: Physical sensing components (high‑resolution joint encoders)
instance Joint1Encoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution encoder on joint 1 of the MABI MAX 100 industrial robot",
    DTDFVocab:producedData JointEncoderDataTransmitted
]

instance Joint2Encoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution encoder on joint 2 of the MABI MAX 100 industrial robot",
    DTDFVocab:producedData JointEncoderDataTransmitted
]

instance Joint3Encoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution encoder on joint 3 of the MABI MAX 100 industrial robot",
    DTDFVocab:producedData JointEncoderDataTransmitted
]

// C4: Physical‑to‑virtual interaction (one‑way data flow)
instance JointEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Joint1Encoder, Joint2Encoder, Joint3Encoder
]

// C10: Data objects derived from transmitted encoder traces
instance JointStateData : DTDFVocab:Data [
    base:desc "Aggregated joint positions and velocities derived from encoder traces",
    DTDFVocab:fromData JointEncoderDataTransmitted,
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance FrictionEstimationData : DTDFVocab:Data [
    base:desc "Estimated joint friction parameters obtained from multi‑physics identification",
    DTDFVocab:fromData JointEncoderDataTransmitted,
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance MaintenanceAlertData : DTDFVocab:Data [
    base:desc "Predictive maintenance alerts generated from model‑based health predictions",
    DTDFVocab:fromData JointEncoderDataTransmitted,
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance DashboardVisualizationData : DTDFVocab:Data [
    base:desc "Formatted data prepared for visualisation on the operator dashboard",
    DTDFVocab:fromData JointEncoderDataTransmitted,
    DTDFVocab:inputTo ProcessingComponentEnabler
]

// C10: Computational models used by the processing component
instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "White‑box Simulink‑based dynamic simulation of robot kinematics and dynamics",
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance MachineLearningFrictionModel : DTDFVocab:Model [
    base:desc "Black‑box machine‑learning model capturing nonlinear joint friction effects",
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance MultiPhysicsIdentificationModel : DTDFVocab:Model [
    base:desc "Multi‑physics‑aware model for identification of joint friction",
    DTDFVocab:inputTo ProcessingComponentEnabler
]

// C11: Enablers (software tools & infrastructure)
instance ProcessingComponentEnabler : DTDFVocab:Enabler [
    base:desc "Software processing component that consumes sensor traces, executes Simulink and ML models, and produces refined shadow data implements the 'originates‑from' provenance traceability",
    DTDFVocab:enables JointStateMonitoringService, FrictionIdentificationService, CorrectiveActionService, PredictiveMaintenanceService, DashboardVisualizationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker that transports encoder traces from the Siemens SINUMERIK 840D sl controller to the processing component",
    DTDFVocab:enables JointStateMonitoringService, FrictionIdentificationService, CorrectiveActionService, PredictiveMaintenanceService, DashboardVisualizationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell exposing robot data in an OPC‑UA compatible format",
    DTDFVocab:enables JointStateMonitoringService, FrictionIdentificationService
]

// C6: Services offered by the Digital Twin
instance JointStateMonitoringService : DTDFVocab:Service [
    base:desc "Continuously monitors joint states of the robot",
    DTDFVocab:provides RealTimeJointStateInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Performs multi‑physics‑aware identification of joint friction",
    DTDFVocab:provides FrictionInsight
]

instance CorrectiveActionService : DTDFVocab:Service [
    base:desc "Computes corrective actions to improve motion accuracy",
    DTDFVocab:provides ComputeCorrectiveAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Supports predictive maintenance by analysing model‑based health indicators",
    DTDFVocab:provides MaintenanceAlertAction
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Visualises derived information in an operator dashboard",
    DTDFVocab:provides DashboardUpdateAction
]

// C17: Insights and Actions
instance RealTimeJointStateInsight : DTDFVocab:Insight [
    base:desc "Provides real‑time insight into joint anomalies for fault detection"
]

instance FrictionInsight : DTDFVocab:Insight [
    base:desc "Delivers insight into joint friction characteristics for optimisation"
]

instance ComputeCorrectiveAction : DTDFVocab:Action [
    base:desc "Computes and dispatches corrective actuator commands to improve motion accuracy",
    DTDFVocab:IsAutomatic true
]

instance MaintenanceAlertAction : DTDFVocab:Action [
    base:desc "Generates predictive maintenance alerts based on health‑prediction models",
    DTDFVocab:IsAutomatic true
]

instance DashboardUpdateAction : DTDFVocab:Action [
    base:desc "Updates the operator dashboard with latest joint performance metrics",
    DTDFVocab:IsAutomatic true
]

// C17: System components (context)
instance MabiMax100Robot : DTDFVocab:Component [
    base:desc "Serial industrial robot MABI MAX 100 equipped with permanent‑magnet synchronous motor, gearbox, and high‑resolution joint encoders"
]

instance PermanentMagnetSynchronousMotor : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor driving the first axis of the MABI MAX 100"
]

instance GearboxAssembly : DTDFVocab:Component [
    base:desc "Gearbox transmitting motor torque to robot joints"
]

instance SiemensSinumerik840DslController : DTDFVocab:Component [
    base:desc "Deterministic Siemens SINUMERIK 840D sl controller handling motion commands and sensor data acquisition"
]

// C17: Environment (digital‑shadow ecosystem)
instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains MabiMax100Robot, Joint1Encoder, Joint2Encoder, Joint3Encoder, ProcessingComponentEnabler, MQTTBrokerEnabler, AssetAdministrationShellEnabler
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The documents describe a multi‑level lifecycle for a Digital Twin that follows Model‑Based Systems Engineering (MBSE). Modeling is split into abstraction layers: (1) requirements, (2) functional architecture, (3) logical architecture, and (4) product/technical layer. Each layer is represented with appropriate engineering models (e.g., SysML requirement diagrams, functional block diagrams, logical component‑connector models) and transitions between layers are managed through traceability links defined in the reference model (originates‑from association). Governance is performed by conforming concrete realizations to the Digital Shadow Reference Model, ensuring that each stage’s artifacts satisfy the defined conformance relation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and validity are tied to the correctness of the underlying models and the transformations applied to data. The reference model emphasises fine‑grained traceability via the ‘originates‑from’ association, which supports verification of model transformations (e.g., from SysML specifications to simulation models). Reliability is ensured by tracing each data trace through its processing components and associated models, allowing detection of inconsistencies. The literature cited stresses the need for verification and traceability in model‑based development of complex systems, but no specific uncertainty quantification or error‑correction mechanisms are detailed in the provided documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The described Digital Twin utilizes standardized modeling specifications: SysML (systems modeling language), ACME (component‑based ADL), AADL (Architecture Analysis & Design Language), MontiArc (component‑connector ADL), and the SMArDT framework. Conformance to the Digital Shadow Reference Model is enforced through a formal conformance relation, ensuring that concrete models adhere to the reference class diagram specifications."
]