// Sensing Component (model repository)
instance ModelRepository : DTDFVocab:SensingComponent [
    base:desc "Repository storing MBSE models such as SysML, ACME, AADL, MontiArc, and simulation artifacts"
    DTDFVocab:producedData ModelMetadataTransmission
]

// Data Transmitted from the repository
instance ModelMetadataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ModelRepository
]

// Data representing model metadata
instance ModelMetadata : DTDFVocab:Data [
    base:desc "Metadata describing the stored MBSE models and their versioning information"
    DTDFVocab:fromData ModelMetadataTransmission
    DTDFVocab:inputTo SysMLModelingTool, ADLEditor, SimulinkEngine, CppCompiler, JavaCompiler
]

// Enablers (tooling stack)
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML modeling environment used to capture requirements, functional, logical and physical architectures"
    DTDFVocab:enables ModelValidationService
]

instance ADLEditor : DTDFVocab:Enabler [
    base:desc "Architecture Description Language editor supporting ACME, AADL and MontiArc specifications"
    DTDFVocab:enables ModelValidationService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation engine executing behavioral models and generating runtime data"
    DTDFVocab:enables SimulationExecutionService
]

instance CppCompiler : DTDFVocab:Enabler [
    base:desc "C++ compiler producing executable code from generated source artifacts"
    DTDFVocab:enables CodeGenerationService
]

instance JavaCompiler : DTDFVocab:Enabler [
    base:desc "Java compiler producing executable code from generated source artifacts"
    DTDFVocab:enables CodeGenerationService
]

// Services
instance ModelValidationService : DTDFVocab:Service [
    base:desc "Service performing syntactic and semantic validation of MBSE models"
    DTDFVocab:provides ModelConsistencyInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service that runs Simulink simulations and collects runtime results"
    DTDFVocab:provides RunSimulationAction
]

instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Service that generates and builds C++ or Java executable artifacts from model transformations"
    DTDFVocab:provides GenerateExecutableAction
]

// Insights / Actions
instance ModelConsistencyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that the MBSE models are internally consistent and satisfy defined constraints"
]

instance RunSimulationAction : DTDFVocab:Action [
    base:desc "Action to execute a Simulink simulation of the behavioral model"
    DTDFVocab:IsAutomatic true
]

instance GenerateExecutableAction : DTDFVocab:Action [
    base:desc "Action to generate compiled C++/Java executable code from validated models"
    DTDFVocab:IsAutomatic true
]

// Models
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram describing components, interfaces, and composition"
    DTDFVocab:inputTo SysMLModelingTool
]

instance SysMLBehavioralModel : DTDFVocab:Model [
    base:desc "SysML state‑machine diagram (v1.7) expressing component behavior"
    DTDFVocab:inputTo SysMLModelingTool
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME architecture description capturing component hierarchies and connectors"
    DTDFVocab:inputTo ADLEditor
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL model defining software‑hardware bindings and timing properties"
    DTDFVocab:inputTo ADLEditor
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "MontiArc component & connector model, optionally extended with automaton behavior"
    DTDFVocab:inputTo ADLEditor
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model representing continuous‑time behavioral dynamics"
    DTDFVocab:inputTo SimulinkEngine
]

instance CppExecutableArtifact : DTDFVocab:Model [
    base:desc "Generated C++ source code artifact derived from validated MBSE models"
    DTDFVocab:inputTo CppCompiler
]

instance JavaExecutableArtifact : DTDFVocab:Model [
    base:desc "Generated Java source code artifact derived from validated MBSE models"
    DTDFVocab:inputTo JavaCompiler
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The document outlines a multi‑level MBSE lifecycle for a Digital Twin: (1) requirements modeling, (2) functional architecture modeling, (3) logical architecture modeling, and (4) product/technical layer modeling. It also references the RFLP methodology that structures development into four sequential stages – Requirements, Functions, Logics, and Physics – with each stage producing a representation (e.g., SysML requirement diagrams, functional block diagrams, logical component‑connector models, and physics‑based simulation models). Transitions between stages are managed by linking models across abstraction layers within the MBSE toolchain, allowing traceability from requirements to physics‑level artefacts."
]