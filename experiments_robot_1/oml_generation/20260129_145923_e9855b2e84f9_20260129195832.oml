// C3: Physical sensing components (model capture components)
instance SysMLModelCaptureComponent : DTDFVocab:SensingComponent [
    base:desc "Captures structural models using SysML block‑definition and internal‑block diagrams"
    DTDFVocab:producedData SysMLModelDataTransmitted
]

instance ADLModelCaptureComponent : DTDFVocab:SensingComponent [
    base:desc "Captures component‑connector architectures expressed in ADLs such as ACME, AADL, and MontiArc"
    DTDFVocab:producedData ADLModelDataTransmitted
]

instance SimulinkModelCaptureComponent : DTDFVocab:SensingComponent [
    base:desc "Captures behavioral models from MathWorks Simulink simulation environments"
    DTDFVocab:producedData SimulinkModelDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmitted)
instance SysMLModelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLModelCaptureComponent
]

instance ADLModelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ADLModelCaptureComponent
]

instance SimulinkModelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkModelCaptureComponent
]

// C10: Data
instance SysMLModelData : DTDFVocab:Data [
    base:desc "Structured representation of SysML block‑definition and internal‑block diagram artifacts"
    DTDFVocab:fromData SysMLModelDataTransmitted
    DTDFVocab:inputTo MBSEIntegrationPlatform
]

instance ADLModelData : DTDFVocab:Data [
    base:desc "Component‑connector description encoded in ADL languages (ACME, AADL, MontiArc)"
    DTDFVocab:fromData ADLModelDataTransmitted
    DTDFVocab:inputTo MBSEIntegrationPlatform
]

instance SimulinkModelData : DTDFVocab:Data [
    base:desc "Executable simulation model consisting of Simulink blocks and parameters"
    DTDFVocab:fromData SimulinkModelDataTransmitted
    DTDFVocab:inputTo SimulationExecutionEngine
]

// C10: Models
instance StructuralModel : DTDFVocab:Model [
    base:desc "Geometric/structural model of the system captured via SysML diagrams and ADL specifications"
    DTDFVocab:inputTo MBSEIntegrationPlatform
]

instance BehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model expressed with SysML state‑machine diagrams, MontiArc Automaton, and Simulink blocks"
    DTDFVocab:inputTo MBSEIntegrationPlatform, SimulationExecutionEngine
]

instance AnalyticalModel : DTDFVocab:Model [
    base:desc "Physics‑based analytical model referenced in the logical architecture for performance evaluation"
    DTDFVocab:inputTo MBSEIntegrationPlatform
]

// C11: Enablers
instance MBSEIntegrationPlatform : DTDFVocab:Enabler [
    base:desc "MBSE integration platform that aggregates SysML, ADL, and analytical artifacts to maintain traceability"
    DTDFVocab:enables TraceabilityService
]

instance SimulationExecutionEngine : DTDFVocab:Enabler [
    base:desc "Engine that executes Simulink simulations and provides results to downstream services"
    DTDFVocab:enables SimulationService
]

// C6: Services
instance TraceabilityService : DTDFVocab:Service [
    base:desc "Provides traceability across MBSE abstraction layers linking requirements, functional, logical, and technical models"
    DTDFVocab:provides TraceabilityInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Executes simulations and delivers insights and automatic model update actions"
    DTDFVocab:provides SimulationResultInsight, ModelUpdateAction
]

// C17: Insights
instance TraceabilityInsight : DTDFVocab:Insight [
    base:desc "Insight about consistency and lineage of models throughout the digital twin evolution"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulation outcomes to support engineering decisions"
]

// C17: Actions
instance ModelUpdateAction : DTDFVocab:Action [
    base:desc "Automatically propagates new functional or physical information into existing models"
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin development follows a Model‑Based Systems Engineering (MBSE) approach in which the twin model is refined through the traditional systems‑engineering abstraction layers: (1) requirements model, (2) functional‑architecture model, (3) logical‑architecture model, and (4) product/technical (implementation) model. Transition between these layers is guided by MBSE methodologies such as RFLP (Requirements‑Functions‑Logics‑Physics), OOSEM, SPES, and SMArDT, which define how data, functional and physical specifications are propagated and governed throughout the DT lifecycle."
]