// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring the electrical input current of the system"
    DTDFVocab:producedData InputCurrentStream
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the output shaft angle of the system"
    DTDFVocab:producedData OutputAngleStream
]

// C4: Physical-to-virtual interaction
instance InputCurrentStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance OutputAngleStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

// C10: Models/Data
instance InputCurrentData : DTDFVocab:Data [
    base:desc "Aggregated input current time series data for simulation"
    DTDFVocab:fromData InputCurrentStream
    DTDFVocab:inputTo SimulinkRuntime
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Aggregated output angle time series data for simulation"
    DTDFVocab:fromData OutputAngleStream
    DTDFVocab:inputTo SimulinkRuntime
]

instance MontiArcBehaviorModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model representing system behavior"
    DTDFVocab:inputTo MontiArcCodeGenerator
]

// C11: Enablers
instance SimulinkRuntime : DTDFVocab:Enabler [
    base:desc "Runtime environment for executing Simulink models"
    DTDFVocab:enables SimulationService
]

instance MontiArcCodeGenerator : DTDFVocab:Enabler [
    base:desc "Code generator translating MontiArc models into executable code"
    DTDFVocab:enables CodeGenerationService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs model-based simulations in Simulink"
    DTDFVocab:provides SimulationResultInsight
]

instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Service that generates C++ or Java code from system models"
    DTDFVocab:provides CodeGenerationInsight, DeployGeneratedCodeAction
]

// C17: Insights/Actions
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight derived from running Simulink simulation capturing system behavior"
]

instance CodeGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight detailing the generated code artifacts and their mapping to system components"
]

instance DeployGeneratedCodeAction : DTDFVocab:Action [
    base:desc "Action to deploy generated C++/Java code into target environment"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization via an automated one‑way data flow; the digital twin ingests live sensor streams from the robot axis through MQTT, enabling a live data‑driven representation. No explicit update frequency or latency values are provided, but the system is designed for real‑time operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is quantified by ensuring that the simulated robot path deviates from the measured physical path by no more than 0.06 mm, reflecting the system’s high path repeatability. Validity is maintained by confirming that all discrepancies between the simulated and measured data stay within this tolerance, thereby confirming that the twin’s models adequately represent the physical system’s behavior."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin’s technical connection employs MQTT as the transport protocol for streams between the physical system and its digital representation. The source does not specify network topology, latency requirements, bandwidth, reliability mechanisms, or security protocols beyond the mention of MQTT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The document refers to SysML v1.7, UML, ACME, AADL, and MontiArc as formal modeling languages. It does not provide information on compliance to ISO standards, OPC UA, or other interoperability specifications."
]