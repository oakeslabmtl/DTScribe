// C3: Physical sensing component
instance AssetMqttSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measurements streamed from the physical asset via MQTT (Mosquitto server) as a passive continuous flow."
    DTDFVocab:producedData AssetMqttDataTransmitted
]

// C4: Physical‑to‑virtual interaction
instance AssetMqttDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AssetMqttSensor
]

// C10: Input data (trace)
instance AssetSensorData : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces derived from incoming MQTT messages, ready for processing."
    DTDFVocab:fromData AssetMqttDataTransmitted
    DTDFVocab:inputTo ProcessingComponent
]

// C11: Enabler (processing component)
instance ProcessingComponent : DTDFVocab:Enabler [
    base:desc "Processing component that consumes input data traces, applies simulation or calculation models (SysML, ADL, Simulink, ML) and emits output data constituting the digital shadow."
    DTDFVocab:enables DigitalShadowUpdateService
]

// C6: Service
instance DigitalShadowUpdateService : DTDFVocab:Service [
    base:desc "Service that updates the digital shadow with processed output data, enabling higher‑level abstractions and decision‑support analytics."
    DTDFVocab:provides DigitalShadowInsight
]

// C17: Insight
instance DigitalShadowInsight : DTDFVocab:Insight [
    base:desc "Higher‑level abstraction insight derived from the digital shadow, supporting decision‑making and confidence inference."
]

// C10: Models (heterogeneous portfolio)
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "Structural information captured with SysML block and internal block diagrams."
    DTDFVocab:inputTo ProcessingComponent
]

instance AcmeArchitectureModel : DTDFVocab:Model [
    base:desc "Architectural model expressed in the ACME ADL."
    DTDFVocab:inputTo ProcessingComponent
]

instance SimulinkPhysicsModel : DTDFVocab:Model [
    base:desc "Executable white‑box physics‑based simulation model implemented in MathWorks Simulink."
    DTDFVocab:inputTo ProcessingComponent
]

instance MachineLearningRegressorModel : DTDFVocab:Model [
    base:desc "Data‑driven black‑box regression model (machine learning) for predictive calculations."
    DTDFVocab:inputTo ProcessingComponent
]

instance MontiArcBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model specified using MontiArc Automaton for state‑machine logic."
    DTDFVocab:inputTo ProcessingComponent
]

instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "Reference model defining class diagram and conformance relations for digital‑shadow instantiation."
    DTDFVocab:inputTo ProcessingComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "According to the digital shadow reference model, the digital shadow (and thus the described Digital Twin implementation) functions as a passive entity that does not operate autonomously nor push data back to the physical system. Consequently, there is no virtual‑to‑physical control flow, no command messages, and no validation, authentication, or feedback mechanisms defined for sending instructions to the physical asset."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the MBSE development hierarchy described in Document 1: requirements modeling, functional‑architecture modeling, logical‑architecture modeling, and product/technical‑layer modeling. At each stage the representation is a model in a specific language (e.g., SysML requirement diagrams, SysML internal‑block diagrams, ADL component‑connector models such as ACME or AADL, and finally executable simulation models in Simulink or C++). Transitions between stages are managed by refining abstract models into more concrete ones and by maintaining traceability links defined in the reference model (see Document 2). Lifecycle governance is implied by the need to keep the concrete realization conformant to the reference model throughout development."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by combining analytical white‑box models (e.g., Simulink dynamic simulations) with data‑driven black‑box models (e.g., machine‑learning based friction representations) to capture both known physics and complex nonlinear effects. Validation relies on traceability links (originates‑from) that allow verification of model‑to‑model transformations, such as from SysML specifications to simulation models. Uncertainty sources include inaccuracies in input data traces and model parameter estimation; these are addressed through traceability‑based error detection and corrective updates. Quality assurance is emphasized through verification of transformation correctness and the maintenance of metadata that records model provenance and data lineage."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on an internal reference‑model standardisation mechanism: the Digital Shadow reference model defines domain concepts and their relationships, and a conformance relation explicitly identifies which concrete class diagrams (CDs) are valid realizations. Concrete realizations are produced by mapping concrete elements to reference concepts, ensuring semantic alignment across models. This internal conformance and the originates‑from traceability association serve as the primary standardisation and interoperability framework described in the documents. No external industry standards, certifications or interoperability specifications are mentioned."
]