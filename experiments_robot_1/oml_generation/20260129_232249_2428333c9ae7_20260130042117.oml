// C2: Acting Component
instance MABIMaxPassiveActingComponent : DTDFVocab:ActingComponent [
    base:desc "No physical actuators; the digital twin is a passive shadow that does not actuate the MABI MAX 100 robot."
]

// C3: Physical Sensing Components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) attached to the motor shaft to measure electrical current."
    DTDFVocab:producedData MotorCurrentMQTT
]
instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted on the motor shaft for high‑resolution position measurement."
    DTDFVocab:producedData MotorPositionMQTT
]
instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder on the gearbox output to capture joint position independent of the motor."
    DTDFVocab:producedData GearboxPositionMQTT
]
instance JointPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Joint position sensor providing the final output angle of the first vertical axis."
    DTDFVocab:producedData JointAngleMQTT
]

// C4: Physical‑to‑virtual interaction
instance MotorCurrentMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]
instance MotorPositionMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]
instance GearboxPositionMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]
instance JointAngleMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointPositionSensor
]

// Multi‑channel kinematic data derived from the above sensors
instance KinematicsMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionMQTT, GearboxPositionMQTT, JointAngleMQTT
]

// C10: Models/Data – Sensing data captured
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Current trace from the motor current sensor transmitted via MQTT."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData MotorCurrentMQTT
]
instance MotorPositionData : DTDFVocab:Data [
    base:desc "Position trace from the motor encoder transmitted via MQTT."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData MotorPositionMQTT
]
instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Position trace from the gearbox encoder transmitted via MQTT."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData GearboxPositionMQTT
]
instance JointAngleData : DTDFVocab:Data [
    base:desc "Joint angle trace from the joint position sensor transmitted via MQTT."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData JointAngleMQTT
]
instance KinematicsData : DTDFVocab:Data [
    base:desc "Derived kinematic quantities (torque, angular velocity, acceleration) calculated from sensor data and transmitted via MQTT."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData KinematicsMQTT
]

// Simulation output traces
instance MotorOutputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkSimulationTool
]
instance GearwheelOutputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkSimulationTool
]
instance SystemOutputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkSimulationTool
]

instance MotorOutputData : DTDFVocab:Data [
    base:desc "Simulated motor output data from the Simulink motor model."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData MotorOutputDataTransmitted
]
instance GearwheelOutputData : DTDFVocab:Data [
    base:desc "Simulated gearwheel output data from the Simulink gearbox model."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData GearwheelOutputDataTransmitted
]
instance SystemOutputData : DTDFVocab:Data [
    base:desc "Simulated system output data from the full axis Simulink model."
    DTDFVocab:inputTo MQTTBroker
    DTDFVocab:fromData SystemOutputDataTransmitted
]

// C11: Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML for engineering structural model of the MABI MAX 100 first vertical axis."
    DTDFVocab:enables StructuralSysMLModel
]
instance SimulinkSimulationTool : DTDFVocab:Enabler [
    base:desc "Simulink (MathWorks) for simulation of motor, gearbox, full axis, and friction models."
    DTDFVocab:enables MotorSimulinkModel, GearboxSimulinkModel, FullAxisSimulinkModel, FrictionIdentificationService, FrictionModelRefinementService, ControllerPerformanceMetricsService
]
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker for real‑time streaming of sensor data from the robot to the digital twin."
    DTDFVocab:enables RealTimeVisualizationService
]
instance AASAssetShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for standardized asset description of the MABI MAX 100 robot."
]
instance DashboardFramework : DTDFVocab:Enabler [
    base:desc "Dashboard framework for real‑time visualization and interaction with the digital twin."
    DTDFVocab:enables RealTimeVisualizationService, ControllerPerformanceMetricsService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization dashboard displaying live sensor and simulation data streams."
    DTDFVocab:provides RealTimeVisualizationInsight
]
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Joint friction identification service combining white‑box and black‑box techniques."
    DTDFVocab:provides FrictionLossDetectionInsight, FrictionLossQuantificationInsight
]
instance FrictionModelRefinementService : DTDFVocab:Service [
    base:desc "Continuous refinement of friction model parameters using extracted data."
    DTDFVocab:provides FrictionModelUpdateInsight
]
instance ControllerPerformanceMetricsService : DTDFVocab:Service [
    base:desc "Generation of performance metrics for controller improvement based on friction analysis."
    DTDFVocab:provides ControllerTuningRecommendationInsight, WearConditionInsight, ControllerAdjustmentAction
]

// C17: Insights
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight enabling real‑time tracking of system dynamics."
]
instance FrictionLossDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of friction loss in the bond between motor and gearbox."
]
instance FrictionLossQuantificationInsight : DTDFVocab:Insight [
    base:desc "Quantification of friction loss magnitude in the first vertical axis."
]
instance FrictionModelUpdateInsight : DTDFVocab:Insight [
    base:desc "Updates to friction model parameters based on identified loss."
]
instance ControllerTuningRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for controller tuning to mitigate friction impacts."
]
instance WearConditionInsight : DTDFVocab:Insight [
    base:desc "Insights into wear and operating conditions derived from friction analysis."
]

// C17: Actions
instance ControllerAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic controller adjustment based on identified friction model refinements."
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance StructuralSysMLModel : DTDFVocab:Model [
    base:desc "Engineering structural model of the MABI MAX 100 first axis created in SysML."
    DTDFVocab:inputTo SysMLModelingTool
]
instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of the motor dynamics for joint friction identification."
    DTDFVocab:inputTo SimulinkSimulationTool
]
instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of the gearbox dynamics for friction analysis."
    DTDFVocab:inputTo SimulinkSimulationTool
]
instance FullAxisSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink full‑axis model combining motor and gearbox for end‑to‑end simulation."
    DTDFVocab:inputTo SimulinkSimulationTool
]
instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Coulomb‑Viscous friction model used for white‑box friction identification."
    DTDFVocab:inputTo SimulinkSimulationTool
]
instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Stribeck friction model capturing stick‑slip behavior in the joint."
    DTDFVocab:inputTo SimulinkSimulationTool
]
instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Dahl friction model representing rate‑dependent friction for the joint."
    DTDFVocab:inputTo SimulinkSimulationTool
]
instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "LuGre friction model for detailed dynamic friction simulation."
    DTDFVocab:inputTo SimulinkSimulationTool
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "No data is transmitted from the digital shadow back to the robot; the digital shadow is passive."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time streaming aligned with the robot’s control cycle; data is processed immediately in the digital shadow for near‑instantaneous visualization and model adaptation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Asset (robot), Structural and behavioral models (SysML), Processing component (simulation & data calculation), Data traces (input and simulated), Dashboard UI; integrated through the reference model with Asset Administration Shell."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow covers the operated phase of the physical robot, providing real‑time monitoring; it is built upon original design models but focuses on runtime behavior."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of each data point to its source and processing model; comparison of measured versus simulated data; continuous refinement of white‑box/black‑box friction models; uncertainties from wear, load, and temperature are acknowledged."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Robot data is streamed to the digital shadow via MQTT over TCP/IP; the digital shadow processes the data in real time."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted on a computation server (not specified) that runs the simulation and dashboard; deployment details not provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Modeling follows SysML; physical asset described using Asset Administration Shell (AAS); simulation conducted with Simulink (ISO/IEC rules); other ADLs mentioned but not used."
]