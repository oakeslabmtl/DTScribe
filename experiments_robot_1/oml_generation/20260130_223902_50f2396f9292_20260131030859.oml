// Acting Component
instance MabiMax100RobotActing : DTDFVocab:ActingComponent [
    base:desc "MABI MAX 100 robotic arm with gearboxes and motors"
]

// Sensing Components
instance JointStateEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encodes joint states of the MABI MAX 100 robot"
    DTDFVocab:producedData JointStateDataTransmitted
]

instance FrictionSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors friction in MABI MAX 100 gearboxes"
    DTDFVocab:producedData FrictionDataTransmitted
]

// Data Transmitted
instance JointStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointStateEncoderSensor
]

instance FrictionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FrictionSensor
]

// Data
instance JointStateData : DTDFVocab:Data [
    base:desc "Real-time joint state data for MABI MAX 100"
    DTDFVocab:fromData JointStateDataTransmitted
    DTDFVocab:inputTo MonitoringEnabler
]

instance FrictionData : DTDFVocab:Data [
    base:desc "Real-time friction data from MABI MAX 100"
    DTDFVocab:fromData FrictionDataTransmitted
    DTDFVocab:inputTo MonitoringEnabler
]

instance WearData : DTDFVocab:Data [
    base:desc "Wear characteristics data inferred from friction monitoring"
    DTDFVocab:inputTo MonitoringEnabler
]

instance TrendData : DTDFVocab:Data [
    base:desc "Trend curves for friction and wear over time"
    DTDFVocab:inputTo MonitoringEnabler
]

// Models
instance RequirementsModel : DTDFVocab:Model [
    base:desc "Requirement specification for MABI MAX 100 robot digital twin"
    DTDFVocab:inputTo SimulationEnabler
]

instance FunctionalModel : DTDFVocab:Model [
    base:desc "Functional architecture using SysML v1.7"
    DTDFVocab:inputTo SimulationEnabler
]

instance LogicalModel : DTDFVocab:Model [
    base:desc "Logical architecture via ACME/AADL/MontiArc"
    DTDFVocab:inputTo SimulationEnabler
]

instance ProductTechnicalModel : DTDFVocab:Model [
    base:desc "Product/technical layer specifications"
    DTDFVocab:inputTo SimulationEnabler
]

instance BehaviorMontiArcModel : DTDFVocab:Model [
    base:desc "Behavioural model using MontiArc Automaton state machines"
    DTDFVocab:inputTo SimulationEnabler
]

instance BehaviorSysMLStateModel : DTDFVocab:Model [
    base:desc "Behavioural model using SysML state machines"
    DTDFVocab:inputTo SimulationEnabler
]

instance SimulationSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink simulation model for joint kinematics and friction"
    DTDFVocab:inputTo SimulationEnabler
]

// Enablers
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulink-based model transformation"
    DTDFVocab:enables SimulationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Data aggregation and analysis enabler for monitoring"
    DTDFVocab:enables MonitoringService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard rendering enabler for visualisation"
    DTDFVocab:enables VisualizationService
]

// Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates robot behaviour using joint state and friction data"
    DTDFVocab:provides SimulationInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitors joint states and friction in real‑time"
    DTDFVocab:provides FrictionTrendInsight, WearIdentificationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides visual dashboard for operators"
    DTDFVocab:provides DashboardVisualizationInsight
]

// Insights
instance FrictionTrendInsight : DTDFVocab:Insight [
    base:desc "Friction coefficient trends over time"
]

instance WearIdentificationInsight : DTDFVocab:Insight [
    base:desc "Identification of wear characteristics from friction data"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulated robot behaviour insights"
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Dashboard visualisation of monitoring data"
]

// Environment
instance SerialRobotWorkcell : DTDFVocab:Environment [
    base:contains MabiMax100RobotActing
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The paper notes that a Digital Twin can add active components capable of issuing controls back to the physical asset; however, specific command types, message formats, authentication mechanisms, or confirmation procedures are not described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The twin’s physical‑to‑digital connection uses MQTT as the sole communication protocol, operating over the existing plant Ethernet network.  No additional network topologies, bandwidth specifications or redundancy mechanisms are described in the provided documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The twin architecture incorporates the Asset Administration Shell (AAS) specification, which normalises digital representations of physical assets in line with industry standards for interoperability. SysML and UML are employed as formal means of modelling system structure and behaviour, providing a common language for stakeholders and ensuring compatibility with broader MBSE tooling ecosystems. These elements collectively align the twin with established standards for structural description, data exchange, and asset abstraction, facilitating integration within enterprise digitisation frameworks."
]