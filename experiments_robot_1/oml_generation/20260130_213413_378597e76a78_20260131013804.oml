// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor driving the six‑axis robot arm, interfaced by the Siemens SINUMERIK 840D SL controller."
]

instance CycloidalGearTrain : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear train providing torque amplification and speed reduction from the motor shaft to the machining end‑effector."
]

instance SiemensSinumerikController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D SL PLC controller that exposes position, speed and acceleration setpoints to the Digital Twin via a field‑bus (PROFIBUS/Profinet)."
]

// C3: Physical sensing components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution encoder mounted on the motor shaft, records motor current and shaft angle as sub‑microradian‑resolution time‑series data."
    DTDFVocab:producedData MotorCurrentTransmitted, MotorAngleTransmitted
]

instance GeartrainOutputEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution encoder attached to the gear‑train output, records output angle as a sub‑microradian‑resolution time‑series data."
    DTDFVocab:producedData MotorAngleTransmitted
]

instance MotorTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted on the motor housing, outputs temperature as a high‑frequency time‑series data."
    DTDFVocab:producedData TempSensorTransmitted
]

instance MotorVibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Vibration sensor mounted on the motor shaft, outputs vibration magnitude as a high‑frequency time‑series data."
    DTDFVocab:producedData VibrationSensorTransmitted
]

// C4: Physical‑to‑virtual interaction (Data Transmitted)
instance MotorCurrentTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance MotorAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder, GeartrainOutputEncoder
]

instance TempSensorTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorTemperatureSensor
]

instance VibrationSensorTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorVibrationSensor
]

// C10: Models/Data (inputTo)
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML structural model of the robot, detailing component geometry and interconnections, linked to abstracted trace data captured in the digital shadow."
    DTDFVocab:inputTo TraceAggregator
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model simulating the dynamic behavior of the motor and gear‑train, processing real‑time sensor time‑series data."
    DTDFVocab:inputTo SimulinkEngine
]

instance TraceAggregationModel : DTDFVocab:Model [
    base:desc "Digital shadow reference model aggregating and abstracting field‑bus and MQTT sensor traces for data layer integration."
    DTDFVocab:inputTo TraceAggregator
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Motor current time‑series data recorded from the motor shaft encoder, sampled at the motor’s native rate."
    DTDFVocab:fromData MotorCurrentTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkEngine, DataStore
]

instance MotorAngleData : DTDFVocab:Data [
    base:desc "Motor shaft and gear‑train output angle time‑series data from the encoders, sampled at the motor’s native rate."
    DTDFVocab:fromData MotorAngleTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkEngine, DataStore
]

instance MotorTemperatureData : DTDFVocab:Data [
    base:desc "Motor temperature time‑series data from the temperature sensor, sampled in real time."
    DTDFVocab:fromData TempSensorTransmitted
    DTDFVocab:inputTo MQTTBroker, DataStore
]

instance MotorVibrationData : DTDFVocab:Data [
    base:desc "Motor vibration magnitude time‑series data from the vibration sensor, sampled in real time."
    DTDFVocab:fromData VibrationSensorTransmitted
    DTDFVocab:inputTo MQTTBroker, DataStore
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker that receives one‑way data streams from the physical robot via the field‑bus and feeds them into the Digital Twin."
    DTDFVocab:enables DataIngestionService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink execution engine that runs the dynamic model and processes sensor data streams."
    DTDFVocab:enables MotorStateMonitoringService, PredictiveAnalyticsService
]

instance SysMLCompiler : DTDFVocab:Enabler [
    base:desc "SysML compiler that interprets the structural model for use in the Digital Twin."
    DTDFVocab:enables ModelInterpretationService
]

instance DataStore : DTDFVocab:Enabler [
    base:desc "InfluxDB data store that accumulates sensor and model outputs for historical analysis and visualization."
    DTDFVocab:enables DashboardsVisualizationService
]

instance TraceAggregator : DTDFVocab:Enabler [
    base:desc "Aggregation engine that consolidates field‑bus and MQTT traces into the digital shadow reference model."
    DTDFVocab:enables TraceAggregationService
]

// Auxiliary service definitions for reference resolution
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service that ingests MQTT sensor data streams into the Digital Twin."
]

instance ModelInterpretationService : DTDFVocab:Service [
    base:desc "Service that interprets SysML structural models within the Digital Twin."
]

instance TraceAggregationService : DTDFVocab:Service [
    base:desc "Service that aggregates and abstracts trace data for the Digital Twin."
]

// C6: Services
instance MotorStateMonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors motor state (speed, temperature, vibration) and sensor health in real time."
    DTDFVocab:provides MotorStateInsight, SensorHealthInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service that applies basic analytics to assess operational health and generate simple predictive insights."
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance DashboardsVisualizationService : DTDFVocab:Service [
    base:desc "Service that visualizes live data streams and historical trends through dashboards."
    DTDFVocab:provides LiveTrendInsight, HistoricalTrendInsight
]

// C17: Insights
instance MotorStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current motor speed, temperature, and vibration status during operation."
]

instance SensorHealthInsight : DTDFVocab:Insight [
    base:desc "Insight that reports health and status of all attached sensors (encoders, temperature, vibration)."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive insight indicating potential future maintenance actions based on trending sensor data."
]

instance LiveTrendInsight : DTDFVocab:Insight [
    base:desc "Live trend insight visualizing current values of key metrics in real time."
]

instance HistoricalTrendInsight : DTDFVocab:Insight [
    base:desc "Historical trend insight showing past evolution of motor and sensor metrics."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system delivers real‑time, data‑driven digital twin representations, actively synchronizing the state of each physical asset with the digital model as live data are streamed during operation. Sensor readings are captured as time‑series and transmitted continuously via MQTT, providing a near real‑time update loop. The processing component consumes these high‑frequency traces and generates updated outputs with minimal latency, ensuring that the twin remains tightly coupled to the current physical state."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows an architecture pattern derived from the Digital Shadow Reference Model. At its core lies a processing component that ingests raw sensor traces (via MQTT) and the Asset Administration Shell representation, performs computational operations, and emits derived analytics or control data. These elements are integrated using event‑driven messaging; the processing hub orchestrates data flow among acquisition, analytics, and visualization layers, manages edge resources, and ensures system‑wide coordination through publish/subscribe mechanisms."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is verified by comparing simulated motor current and output angle trajectories from the Simulink model against measured data. Sources of uncertainty include temperature variations, load changes and wear. Validation uses quantitative deviation thresholds between simulation and measurement, and any discrepancies are logged for model adjustment. Verification steps involve routine parameter checks, alignment of simulation outputs with real‑world data, and uncertainty quantification based on sensor accuracy and temperature‑dependent parameter variations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The communication between the physical system and the Digital Shadow occurs over MQTT. No additional network topology, bandwidth, latency, reliability or security details are specified."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External integration relies on publish‑subscribe messaging over MQTT and the standardized Asset Administration Shell. The physical asset sends telemetry to an MQTT broker; the digital twin subscribes and writes aggregated data to its AAS. No bidirectional control commands, RESTful interfaces, or explicit synchronization with other twins or enterprise systems are defined in the document."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The MABI MAX 100 industrial robot is equipped with a safety cell that enforces a defined safe operating envelope by limiting the maximum working range. All available sensor time‑series data are streamed via the MQTT protocol. The MQTT broker used in the system is implemented by Mosquitto, as referenced in the work on the Mosquitto server and client implementation (document 52). No explicit cybersecurity protocols, access‑control mechanisms, authentication schemes, threat‑mitigation strategies, risk‑assessment procedures, or fail‑safe technical details are documented in the provided materials; the references to the RAMI 4.0 and Asset Administration Shell frameworks present only high‑level security interfaces without specifying concrete implementation measures."
]