instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML model for requirements layer in MBSE"
    DTDFVocab:inputTo RFLPEnabler, SimulinkEnabler
]

instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model for functional architecture layer"
    DTDFVocab:inputTo OOSEMEnabler, SimulinkEnabler
]

instance SysMLLogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model for logical architecture layer"
    DTDFVocab:inputTo SPESEnabler, SimulinkEnabler
]

instance SysMLProductTechnicalLayerModel : DTDFVocab:Model [
    base:desc "SysML model for product/technical layer"
    DTDFVocab:inputTo SMArDTEnabler, SimulinkEnabler
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME model for component interfaces and composition"
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL model for component interfaces and composition"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc model for component interfaces and composition"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLIBDsModel : DTDFVocab:Model [
    base:desc "SysML IBDs for component interconnections"
    DTDFVocab:inputTo SysMLIBDEnabler
]

instance SysMLStateMachinesModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines for behavioral aspects"
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral aspects"
    DTDFVocab:inputTo MontiArcEnabler, JavaEnabler
]

instance RequirementsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLRequirementsModel
]

instance FunctionalArchitectureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLFunctionalArchitectureModel
]

instance LogicalArchitectureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLLogicalArchitectureModel
]

instance ProductTechnicalLayerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLProductTechnicalLayerModel
]

instance ACMEDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ACMEModel
]

instance AADLDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AADLModel
]

instance MontiArcDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MontiArcModel
]

instance SysMLIBDsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLIBDsModel
]

instance SysMLStateMachinesDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLStateMachinesModel
]

instance MontiArcAutomatonDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MontiArcAutomatonModel
]

instance RequirementsData : DTDFVocab:Data [
    base:desc "Requirements data from SysML model"
    DTDFVocab:fromData RequirementsDataTransmitted
    DTDFVocab:inputTo RFLPEnabler, SimulinkEnabler
]

instance FunctionalArchitectureData : DTDFVocab:Data [
    base:desc "Functional architecture data from SysML model"
    DTDFVocab:fromData FunctionalArchitectureDataTransmitted
    DTDFVocab:inputTo OOSEMEnabler, SimulinkEnabler
]

instance LogicalArchitectureData : DTDFVocab:Data [
    base:desc "Logical architecture data from SysML model"
    DTDFVocab:fromData LogicalArchitectureDataTransmitted
    DTDFVocab:inputTo SPESEnabler, SimulinkEnabler
]

instance ProductTechnicalLayerData : DTDFVocab:Data [
    base:desc "Product/technical layer data from SysML model"
    DTDFVocab:fromData ProductTechnicalLayerDataTransmitted
    DTDFVocab:inputTo SMArDTEnabler, SimulinkEnabler
]

instance ACMEData : DTDFVocab:Data [
    base:desc "ACME architecture data"
    DTDFVocab:fromData ACMEDataTransmitted
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLData : DTDFVocab:Data [
    base:desc "AADL architecture data"
    DTDFVocab:fromData AADLDataTransmitted
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcData : DTDFVocab:Data [
    base:desc "MontiArc architecture data"
    DTDFVocab:fromData MontiArcDataTransmitted
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLIBDsData : DTDFVocab:Data [
    base:desc "SysML IBDs interconnection data"
    DTDFVocab:fromData SysMLIBDsDataTransmitted
    DTDFVocab:inputTo SysMLIBDEnabler
]

instance SysMLStateMachinesData : DTDFVocab:Data [
    base:desc "SysML state machine behavioral data"
    DTDFVocab:fromData SysMLStateMachinesDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler
]

instance MontiArcAutomatonData : DTDFVocab:Data [
    base:desc "MontiArc Automaton behavioral data"
    DTDFVocab:fromData MontiArcAutomatonDataTransmitted
    DTDFVocab:inputTo MontiArcEnabler, JavaEnabler
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component interfaces and composition"
    DTDFVocab:enables ArchitectureDesignService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component interfaces and composition"
    DTDFVocab:enables ArchitectureDesignService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component interfaces and composition"
    DTDFVocab:enables ArchitectureDesignService
]

instance SysMLIBDEnabler : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component interconnections"
    DTDFVocab:enables ArchitectureDesignService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and dynamic analysis"
    DTDFVocab:enables SimulationService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed dynamic analysis"
    DTDFVocab:enables CodeExecutionService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed dynamic analysis"
    DTDFVocab:enables CodeExecutionService
]

instance RFLPEnabler : DTDFVocab:Enabler [
    base:desc "RFLP methodology (Requirements, Functions, Logics, Physics) for system modeling"
    DTDFVocab:enables RequirementsAnalysisService
]

instance OOSEMEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for system modeling"
    DTDFVocab:enables ArchitectureDesignService
]

instance SPESEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for system modeling"
    DTDFVocab:enables ArchitectureDesignService
]

instance SMArDTEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for system modeling"
    DTDFVocab:enables ArchitectureDesignService
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates system behavior using models"
    DTDFVocab:provides SimulationInsight
]

instance CodeExecutionService : DTDFVocab:Service [
    base:desc "Executes code for dynamic analysis"
    DTDFVocab:provides CodeExecutionInsight
]

instance RequirementsAnalysisService : DTDFVocab:Service [
    base:desc "Analyzes system requirements"
    DTDFVocab:provides RequirementsAnalysisInsight
]

instance ArchitectureDesignService : DTDFVocab:Service [
    base:desc "Designs system architecture using ADLs"
    DTDFVocab:provides ArchitectureDesignInsight
]

instance BehavioralAnalysisService : DTDFVocab:Service [
    base:desc "Analyzes behavioral aspects using state machines"
    DTDFVocab:provides BehavioralAnalysisInsight
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insights from simulation results"
]

instance CodeExecutionInsight : DTDFVocab:Insight [
    base:desc "Insights from code execution analysis"
]

instance RequirementsAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insights from requirements analysis"
]

instance ArchitectureDesignInsight : DTDFVocab:Insight [
    base:desc "Insights from architecture design"
]

instance BehavioralAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insights from behavioral analysis"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system employs SysML for modeling at various abstraction levels (requirements, functional architecture, logical architecture, product/technical layer), uses ACME, AADL, and MontiArc as architecture description languages (ADLs) for component & connector perspectives, and addresses interoperability through integration of heterogeneous stakeholders [31]."
]