// C3: Physical sensing components
instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring electrical input current (in Amperes) on axis 1 of the MABI MAX 100 serial robot."
    DTDFVocab:producedData CurrentDataTransmitted
]

instance JointAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Joint angle sensor measuring angular position (in degrees) of axis 1 of the MABI MAX 100 robot."
    DTDFVocab:producedData JointAngleDataTransmitted
]

// C4: Physical-to-virtual interaction
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
]

instance JointAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointAngleSensor
]

// C10: Models/Data
instance CurrentData : DTDFVocab:Data [
    base:desc "Current measurement data aggregated from MQTT stream."
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData CurrentDataTransmitted
]

instance JointAngleData : DTDFVocab:Data [
    base:desc "Joint angle data aggregated from MQTT stream."
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData JointAngleDataTransmitted
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker enabler ingesting robot telemetry and providing it to twin services."
    DTDFVocab:enables MonitoringDashboardService, FrictionIdentificationService, OptimizationService, PredictiveMaintenanceService, ControlInterfaceService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "Simulink-based simulation enabler for structural and behavioral models feeding control optimization."
    DTDFVocab:enables MonitoringDashboardService, FrictionIdentificationService, OptimizationService, PredictiveMaintenanceService, ControlInterfaceService
]

instance StructuralModel : DTDFVocab:Model [
    base:desc "SysML structural model of the full MABI MAX 100 robot, used for component architecture definition."
    DTDFVocab:inputTo SimulinkEnabler
]

instance BehavioralModel : DTDFVocab:Model [
    base:desc "SysML state machine model capturing dynamic behaviour of the robot's vertical axis."
    DTDFVocab:inputTo SimulinkEnabler
]

// C6: Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard service visualizing telemetry from robot sensors."
    DTDFVocab:provides TelemetryVisualizationInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Multi‑physics friction identification service estimating joint friction coefficients."
    DTDFVocab:provides JointFrictionEstimationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service automatically tuning control parameters for improved motion accuracy."
    DTDFVocab:provides ControlParameterOptimizationInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance service generating maintenance insights."
    DTDFVocab:provides MaintenancePredictionInsight
]

instance ControlInterfaceService : DTDFVocab:Service [
    base:desc "Direct control interface service sending control commands to machine tool controller."
    DTDFVocab:provides SendControlCommandAction
]

// C17: Insights / Actions
instance TelemetryVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight presenting sensor telemetry in the monitoring dashboard."
]

instance JointFrictionEstimationInsight : DTDFVocab:Insight [
    base:desc "Insight providing online friction coefficient estimates."
]

instance ControlParameterOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal control parameters."
]

instance MaintenancePredictionInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing maintenance predictions."
]

instance SendControlCommandAction : DTDFVocab:Action [
    base:desc "Action to transmit control commands to machine tool via MQTT."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital Twin lifecycle follows a staged MBSE approach. First, requirements are captured and mapped to system functions. Second, the functional architecture is defined with SysML Block Definition Diagrams, capturing components, flows, and interfaces. Third, a logical architecture is produced using ADLs such as MontiArc or AADL to detail component interactions and behavior specifications, including state‑machine elements or MontiArc Automata. Fourth, the product/technical layer is generated, often with code or Simulink models derived from the logical model. Transition between stages relies on traceability links automatically maintained by SysML model repositories, and governance is enforced through version control (e.g., GIT for SysML and ADL files) and model review cycles. This staged progression ensures that the Digital Twin evolves from abstract requirements to concrete executable models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The communication between the physical sensor layer and the digital shadow is implemented over MQTT, a lightweight publish/subscribe messaging protocol running on top of TCP/IP. The MQTT broker mediates the flow and provides a scalable, topic‑based distribution of sensor data. No specific network topology, bandwidth, latency, redundancy, or security mechanisms are detailed in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin modelling artefacts and reference models adhere to established standards for system description: SysML is used for functional and behavioural specifications, while logical architecture is expressed with ADLs such as AADL or MontiArc. The Digital Shadow reference framework is represented as a UML class diagram, providing a structured and standardised view of contextual data traces. No additional industry‑wide certification or interoperability standard references are present in the provided document."
]