// C3: Physical sensing components
instance CurrentSensorMotor : DTDFVocab:SensingComponent [
    base:desc "Current sensor mounted on the permanent‑magnet synchronous motor measuring electrical current."
    DTDFVocab:producedData CurrentSensorTelemetry
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted on the motor providing position, torque, and angular velocity information."
    DTDFVocab:producedData MotorEncoderTelemetry
]

instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder attached to the gearbox providing high‑resolution shaft position data."
    DTDFVocab:producedData SecondaryEncoderTelemetry
]

instance AxisPositionOutput : DTDFVocab:SensingComponent [
    base:desc "Axis position output from the first robot axis delivering absolute position and acceleration."
    DTDFVocab:producedData AxisPositionTelemetry
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance CurrentSensorTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensorMotor
]

instance MotorEncoderTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance SecondaryEncoderTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoder
]

instance AxisPositionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AxisPositionOutput
]

// C10: Models/Data (Data)
instance CurrentData : DTDFVocab:Data [
    base:desc "Real‑time current measurement stream received via MQTT."
    DTDFVocab:inputTo MQTTDataTransferEnabler
    DTDFVocab:fromData CurrentSensorTelemetry
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque data calculated from encoder and current measurements."
    DTDFVocab:inputTo MQTTDataTransferEnabler
    DTDFVocab:fromData MotorEncoderTelemetry
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity information obtained from the motor encoder."
    DTDFVocab:inputTo MQTTDataTransferEnabler
    DTDFVocab:fromData MotorEncoderTelemetry
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration derived from the axis position output."
    DTDFVocab:inputTo MQTTDataTransferEnabler
    DTDFVocab:fromData AxisPositionTelemetry
]

// C10: Models/Data (Models)
instance EngineeringSysMLModel : DTDFVocab:Model [
    base:desc "Engineering (structural) SysML model of the permanent‑magnet synchronous motor, gearbox, and cycloidal gearbox."
    DTDFVocab:inputTo MBSE_SysML_Enabler
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Data‑calculation model for Coulomb and viscous friction laws."
    DTDFVocab:inputTo MBSE_SysML_Enabler
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Data‑calculation model based on the Stribeck friction characteristics."
    DTDFVocab:inputTo MBSE_SysML_Enabler
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Data‑calculation model implementing the Dahl friction approach."
    DTDFVocab:inputTo MBSE_SysML_Enabler
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "Data‑calculation model using the LuGre friction formulation."
    DTDFVocab:inputTo MBSE_SysML_Enabler
]

instance IdealBehaviorSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model simulating the ideal friction‑free behavior of the first axis."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance FrictionAffectedSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model representing the axis behavior with friction effects."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance ContinuousFrictionIdentificationSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model used for continuous multi‑physics friction identification during runtime."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

// C11: Enablers (Enabler)
instance MBSE_SysML_Enabler : DTDFVocab:Enabler [
    base:desc "Enabler implementing Model‑Based Systems Engineering using SysML."
    DTDFVocab:enables FrictionIdentificationService, UpdateFrictionModelService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler managing Simulink simulation execution for ideal and friction‑affected models."
    DTDFVocab:enables SimulationService, FrictionIdentificationService
]

instance MQTTDataTransferEnabler : DTDFVocab:Enabler [
    base:desc "Enabler handling real‑time data transfer to/from the DT via MQTT."
    DTDFVocab:enables DataLinkingAASService, FrictionIdentificationService
]

instance AASSemanticLinkingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler linking DT data and models to the Asset Administration Shell for semantic interoperability."
    DTDFVocab:enables DataLinkingAASService
]

instance DashboardFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Enabler providing dashboard framework capabilities for real‑time visualization."
    DTDFVocab:enables VisualizationDashboardService
]

// C6: Services (Service)
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service for continuous multi‑physics friction identification and model updating."
    DTDFVocab:provides UpdatedFrictionParametersInsight, DeviationsVisualizationInsight, AdjustControllerParametersAction, PerformMaintenanceAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service executing ideal and friction‑affected Simulink simulations to compare expected versus measured behaviors."
    DTDFVocab:provides SimulationOutcomeInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Service delivering real‑time visualization of torque/velocity deviations and updated friction parameters on a dashboard."
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance DataLinkingAASService : DTDFVocab:Service [
    base:desc "Service managing the linking of simulation outputs and sensor data to the Asset Administration Shell."
    DTDFVocab:provides AASLinkageInsight
]

instance UpdateFrictionModelService : DTDFVocab:Service [
    base:desc "Service responsible for provisioning updated friction models back to the robot controller."
    DTDFVocab:provides UpdatedFrictionParametersInsight
]

// C17: Insights (Insight)
instance UpdatedFrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that the friction model parameters have been updated based on in‑situ identification."
]

instance DeviationsVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight visualizing deviations between expected and measured torque/velocity for controller assessment."
]

instance ControllerTuningRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending controller tuning adjustments derived from updated friction parameters."
]

instance MaintenanceActionRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting maintenance actions based on friction identification results."
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time visualization on the dashboard of friction‑related metrics."
]

instance AASLinkageInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful linking of DT data to the Asset Administration Shell."
]

instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing the outcomes of the ideal versus friction‑affected simulation comparisons."
]

// C17: Actions (Action)
instance AdjustControllerParametersAction : DTDFVocab:Action [
    base:desc "Action to adjust controller tuning parameters based on the updated friction model."
    DTDFVocab:IsAutomatic false
]

instance PerformMaintenanceAction : DTDFVocab:Action [
    base:desc "Action to perform maintenance on the first axis, recommended by the maintenance action insight."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time ingestion of sensor data and continuous model updating on the order of milliseconds to seconds, synchronized with the robot’s control loop; updates are applied immediately as new data arrives."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration of the asset model, simulation models, AAS, data streams, processing component, and visualization dashboard; all components are managed from a central backend that receives MQTT data and feeds the models."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the operated stage; it builds on manufacturer data and real‑time input to model the robot during runtime. Design and manufacturing stages are not represented in this digital shadow."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Use of white‑box and black‑box friction models with continuous identification; traceability of each data point back to source and model; validation by comparing simulated outputs with actual sensor data; uncertainty handled by updating models online."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data transmitted over MQTT between PT and DT; asset description and data traces linked via AAS; no other protocols or physical connections specified."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Not explicitly specified; the digital shadow and dashboard are assumed to be hosted on an application server or cloud service connected to the robot, with backend handling MQTT streams."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not detailed; the digital shadow only references the AAS and local data streams, with no integration to external DTs or enterprise systems mentioned."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with SysML for engineering modeling, Asset Administration Shell specification, and the use of MBSE best practices; other industry standards are not explicitly mentioned."
]