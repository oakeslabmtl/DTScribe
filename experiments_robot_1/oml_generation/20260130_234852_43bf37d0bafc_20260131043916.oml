// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor providing instantaneous current I_M for the first axis motor"
    DTDFVocab:producedData MotorCurrentMqtt
]

instance GearboxOutputEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary gearbox encoder measuring the joint angle at the final gearbox output of the first axis"
    DTDFVocab:producedData JointAngleMqtt
]

// C4: Physical-to-virtual interaction
instance MotorCurrentMqtt : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance JointAngleMqtt : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxOutputEncoder
]

// C10: Models/Data – Simulation traces
instance SimulatedMotorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkSimulationEnabler
]

instance SimulatedGearboxDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkSimulationEnabler
]

instance SimulatedOutputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkSimulationEnabler
]

// C10: Data – Sensor streams
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor current I_M from the first axis"
    DTDFVocab:inputTo DataProcessingEnabler
    DTDFVocab:fromData MotorCurrentMqtt
]

instance JointAngleData : DTDFVocab:Data [
    base:desc "Time‑series of joint angle measured at the gearbox output"
    DTDFVocab:inputTo DataProcessingEnabler
    DTDFVocab:fromData JointAngleMqtt
]

// C10: Data – Derived quantities
instance DerivedMotorTorqueData : DTDFVocab:Data [
    base:desc "Derived motor torque τ_M calculated from motor current using dynamic model"
    DTDFVocab:inputTo DataProcessingEnabler
    DTDFVocab:fromData MotorCurrentMqtt
]

instance DerivedAngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω of the first axis computed from joint angle time‑series"
    DTDFVocab:inputTo DataProcessingEnabler
    DTDFVocab:fromData JointAngleMqtt
]

instance DerivedAccelerationData : DTDFVocab:Data [
    base:desc "Derived acceleration α calculated from angular velocity time‑series"
    DTDFVocab:inputTo DataProcessingEnabler
    DTDFVocab:fromData DerivedAngularVelocityData
]

// C10: Data – Simulated traces
instance SimulatedMotorTraceData : DTDFVocab:Data [
    base:desc "Simulated motor trace r_M from MATLAB/Simulink motor model"
    DTDFVocab:inputTo SimulinkSimulationEnabler
    DTDFVocab:fromData SimulatedMotorDataTransmitted
]

instance SimulatedGearboxTraceData : DTDFVocab:Data [
    base:desc "Simulated gearbox trace r_G from MATLAB/Simulink gearbox model"
    DTDFVocab:inputTo SimulinkSimulationEnabler
    DTDFVocab:fromData SimulatedGearboxDataTransmitted
]

instance SimulatedOutputTraceData : DTDFVocab:Data [
    base:desc "Simulated system output trace r_out from MATLAB/Simulink models"
    DTDFVocab:inputTo SimulinkSimulationEnabler
    DTDFVocab:fromData SimulatedOutputDataTransmitted
]

// C10: Models
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML component‑connector structural model for motor, gearbox, and cycloidal gear of the first axis"
    DTDFVocab:inputTo DataProcessingEnabler
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable block for motor dynamics with Coulomb‑Viscous, Stribeck, Dahl, LuGre friction models"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable block for gearbox dynamics including various friction models"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Data calculation model for derived torque, angular velocity, and acceleration traces"
    DTDFVocab:inputTo DataProcessingEnabler
]

// C11: Enablers
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for data processing, model computation, and friction estimation"
    DTDFVocab:enables JointFrictionIdentificationService, BaselineModelDevelopmentService, RealTimeDashboardService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for executing MATLAB/Simulink simulation models of the motor and gearbox"
    DTDFVocab:enables SimulationTraceProvisionService
]

// C6: Services
instance JointFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service for real‑time joint‑friction identification and estimation of static, kinetic, and viscous friction"
    DTDFVocab:provides FrictionEstimationInsight
]

instance BaselineModelDevelopmentService : DTDFVocab:Service [
    base:desc "Service for baseline model development for future full digital twin"
    DTDFVocab:provides BaselineModelInsight
]

instance SimulationTraceProvisionService : DTDFVocab:Service [
    base:desc "Service providing simulated motor, gearbox, and system traces (r_M, r_G, r_out) for comparison with measured data"
    DTDFVocab:provides TraceComparisonInsight
]

instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Service presenting real‑time dashboard visualization of friction characteristics and system status"
    DTDFVocab:provides DashboardVisualizationInsight
]

// C17: Insights
instance FrictionEstimationInsight : DTDFVocab:Insight [
    base:desc "Quantified friction characteristics (static, kinetic, viscous) for the first axis, visualized in the dashboard"
]

instance BaselineModelInsight : DTDFVocab:Insight [
    base:desc "Baseline model information for future full digital twin evolution"
]

instance TraceComparisonInsight : DTDFVocab:Insight [
    base:desc "Comparison between measured and simulated traces of motor, gearbox, and output"
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of system dynamics and friction parameters to aid operators and maintenance planning"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time continuous streaming of live data from the physical system to the digital twin; no data flow from the DT to the PT (unidirectional)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation comprises a central processing unit that consumes MQTT streams, executes the Simulink simulation models (Simulation M, GW, GB), aggregates data traces (r_M, r_G, r_out) and memory; a data point repository tracking origin through the 'originate from' relationship; a dashboard component presenting the traces; all orchestrated under the Digital Shadow Reference Model (DSRM)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (ideal simulation model), Manufacturing (physical robot created with two gearboxes and a motor), and Operated (live data from the robot used in the DT); the DT covers all three phases in sequence."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of each data point to its source via 'originates from' relationship; comparative analysis of simulated vs measured traces to validate friction models; inclusion of both white‑box analytical and black‑box data‑driven models; continuous model refinement reduces uncertainty; however, explicit V&V procedures are not detailed in the document."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for transmitting live sensor data from the physical robot to the digital twin; the Asset Administration Shell interfaces are defined but no explicit network protocol is detailed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for structural modeling, AAS (Asset Administration Shell) for asset description, and adherence to the Digital Shadow Reference Model; implicit ISO/IEC standards associated with AAS are referenced but not explicitly cited."
]