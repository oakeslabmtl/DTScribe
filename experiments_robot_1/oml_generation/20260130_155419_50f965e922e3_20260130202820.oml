// C3: Physical sensing components
instance RobotPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Absolute encoder providing precise position feedback for each robot joint axis."
    DTDFVocab:producedData PositionDataTransmitted
]

instance RobotKinematicStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor-derived state vector capturing robot joint positions, velocities, and dynamic parameters."
    DTDFVocab:producedData StateVectorDataTransmitted
]

instance ContextualLogCollector : DTDFVocab:SensingComponent [
    base:desc "Component that aggregates high‑level contextual logs from the manufacturing cell."
    DTDFVocab:producedData ContextLogDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotPositionEncoder
]

instance StateVectorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotKinematicStateSensor
]

instance ContextLogDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContextualLogCollector
]

// C11: Data
instance PositionData : DTDFVocab:Data [
    base:desc "Aggregated position data from absolute encoders."
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo SimulinkRuntimeEnabler, MLInferenceEngine
]

instance StateVectorData : DTDFVocab:Data [
    base:desc "Robot state vectors used for physics simulation and friction learning."
    DTDFVocab:fromData StateVectorDataTransmitted
    DTDFVocab:inputTo SimulinkRuntimeEnabler, MLInferenceEngine
]

instance ContextLogData : DTDFVocab:Data [
    base:desc "High‑level contextual logs for purpose‑specific aggregation."
    DTDFVocab:fromData ContextLogDataTransmitted
    DTDFVocab:inputTo MLInferenceEngine
]

// C10: Models/Data
instance WhiteBoxSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink‑based dynamic simulation model capturing the physics of the MABI MAX 100 robot."
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

instance BlackBoxFrictionMLModel : DTDFVocab:Model [
    base:desc "Data‑driven machine‑learning model learning nonlinear friction effects from robot state data."
    DTDFVocab:inputTo MLInferenceEngine
]

// C11: Enablers
instance SimulinkRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink runtime environment executing white‑box dynamic simulations of robot mechanics."
    DTDFVocab:enables SimulationProcessingService
]

instance MLInferenceEngine : DTDFVocab:Enabler [
    base:desc "Machine‑learning inference engine executing black‑box models for friction and other nonlinear effects."
    DTDFVocab:enables MLProcessingService, InsightGenerationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating telemetry streaming between the physical robot and the digital twin."
    DTDFVocab:enables DataIngestionService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell providing semantic data exchange and versioning for twin artefacts."
    DTDFVocab:enables DataManagementService
]

// C6: Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Consumes MQTT telemetry streams and stores raw sensor data."
    DTDFVocab:provides RawTelemetryInsight
]

instance SimulationProcessingService : DTDFVocab:Service [
    base:desc "Runs the white‑box Simulink model on incoming data to generate simulated dynamics."
    DTDFVocab:provides SimulatedDynamicsInsight
]

instance MLProcessingService : DTDFVocab:Service [
    base:desc "Executes the black‑box ML model to estimate robot friction from state vectors."
    DTDFVocab:provides FrictionEstimationInsight
]

instance InsightGenerationService : DTDFVocab:Service [
    base:desc "Aggregates outputs from simulation and ML processing to derive higher‑level metrics and system state identification."
    DTDFVocab:provides NewMetricInsight, SystemStateIdentificationInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Displays derived insights on operator dashboards for decision support."
    DTDFVocab:provides InsightVisualizationAction
]

instance DataManagementService : DTDFVocab:Service [
    base:desc "Manages semantic data exchange and versioning for twin artifacts via Asset Administration Shell."
    DTDFVocab:provides DataManagementInsight
]

// C17: Insights
instance SimulatedDynamicsInsight : DTDFVocab:Insight [
    base:desc "Simulated robot dynamics derived from the white‑box Simulink model."
]

instance FrictionEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated robot friction values generated by the black‑box ML model."
]

instance NewMetricInsight : DTDFVocab:Insight [
    base:desc "New performance metrics produced by aggregating simulation and ML outputs."
]

instance SystemStateIdentificationInsight : DTDFVocab:Insight [
    base:desc "Identified system states (e.g., wear, overload) based on combined model outputs."
]

instance RawTelemetryInsight : DTDFVocab:Insight [
    base:desc "Raw telemetry data captured from the physical robot via MQTT."
]

instance DataManagementInsight : DTDFVocab:Insight [
    base:desc "Insight related to data management and versioning."
]

// C17: Actions
instance InsightVisualizationAction : DTDFVocab:Action [
    base:desc "Automatic visualization of insights on operator dashboards."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is defined as a passive entity that does not generate control commands or push data back to the physical system; therefore, no virtual‑to‑physical interaction is provided."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is organized around the Digital Shadow Reference Model, which is specified as a UML class diagram defining core concepts (e.g., assets, data traces, processing components, models) and their relationships. Concrete realizations are created by mapping these reference concepts to concrete elements, thereby incarnating the abstract model. Architecture and behavior are described using MBSE languages such as SysML and ADLs (e.g., ACME, AADL, MontiArc), which capture components, interfaces, and compositions. Processing components consume input data traces and produce output traces using simulation or data‑calculation models, preserving fine‑grained traceability through explicit associations. The overall orchestration thus relies on a layered integration of heterogeneous stakeholder perspectives, linking engineering, simulation, and data‑processing models within a unified, traceable structure."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle described in the documents consists of an MBSE‑driven development phase that creates system models at four abstraction levels – requirements, functional architecture, logical architecture and product/technical layer – using SysML and other ADLs. Concurrently a Digital‑Shadow Reference Model (UML class diagram) is instantiated. In a concretization step the abstract reference model is mapped to a concrete class diagram that materializes the data‑trace entities, processing components and their associations. The resulting concrete digital‑shadow model can be enriched with active components to become a full Digital Twin, thereby transitioning from a passive data aggregation artifact to an autonomous twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by combining deterministic Simulink simulations (providing clear interpretability) with statistical machine‑learning models (capturing nonlinearities). Validation and verification are performed through traceability of transformations from SysML to simulation or ML artefacts, ensuring correctness of model conversions. The approach emphasizes uncertainty quantification via probabilistic latent‑variable models and adaptive control schemes, and mandates verification of data correctness before integration. Quality assurance includes systematic verification of model‑based transformations and continuous monitoring of model performance against the aggregated contextual data traces."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Standardization is rooted in the use of established OMG specifications: SysML is employed as the primary MBSE modeling language, and the Digital‑Shadow Reference Model is expressed as a UML class diagram, providing a standardized notation for concepts and relationships. The ADLs (ACME, AADL, MontiArc) and the one‑way data‑flow definition of a digital shadow follow the semantics defined by their respective specifications, ensuring interoperability among tools and stakeholders."
]