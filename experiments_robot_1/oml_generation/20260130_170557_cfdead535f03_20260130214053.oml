instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor measuring input current for MABI MAX 100 robot"
    DTDFVocab:producedData MQTTDataTransmission
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor measuring output angle for MABI MAX 100 robot"
    DTDFVocab:producedData MQTTDataTransmission
]

instance MQTTDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor, OutputAngleSensor
    base:desc "Time-series data streamed via MQTT protocol from physical sensors to digital shadow"
]

instance CurrentData : DTDFVocab:Data [
    base:desc "Input current time-series data"
    DTDFVocab:fromData MQTTDataTransmission
    DTDFVocab:inputTo Simulink, CPlusPlus, Java
]

instance AngleData : DTDFVocab:Data [
    base:desc "Output angle time-series data"
    DTDFVocab:fromData MQTTDataTransmission
    DTDFVocab:inputTo Simulink, CPlusPlus, Java
]

instance SysMLModeling : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering (MBSE) using SysML for system modeling"
    DTDFVocab:enables RealTimeDataProcessingService
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP methodology for complexity management"
    DTDFVocab:enables RealTimeDataProcessingService
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for complexity management"
    DTDFVocab:enables RealTimeDataProcessingService
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for complexity management"
    DTDFVocab:enables RealTimeDataProcessingService
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for complexity management"
    DTDFVocab:enables RealTimeDataProcessingService
]

instance ACMEADL : DTDFVocab:Enabler [
    base:desc "ACME architecture description language for component & connector architecture"
    DTDFVocab:enables RealTimeDataProcessingService
]

instance AADLADL : DTDFVocab:Enabler [
    base:desc "AADL architecture description language for component & connector architecture"
    DTDFVocab:enables RealTimeDataProcessingService
]

instance MontiArcADL : DTDFVocab:Enabler [
    base:desc "MontiArc architecture description language for component & connector architecture"
    DTDFVocab:enables RealTimeDataProcessingService
]

instance SysMLIBDs : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component & connector architecture"
    DTDFVocab:enables RealTimeDataProcessingService
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavior modeling"
    DTDFVocab:enables RealTimeDataProcessingService
]

instance SysMLStateMachines : DTDFVocab:Enabler [
    base:desc "SysML state machines for behavior modeling"
    DTDFVocab:enables RealTimeDataProcessingService
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for analytical modeling"
    DTDFVocab:enables RealTimeDataProcessingService
]

instance CPlusPlus : DTDFVocab:Enabler [
    base:desc "C++ general-purpose programming language for code modeling"
    DTDFVocab:enables RealTimeDataProcessingService
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java general-purpose programming language for code modeling"
    DTDFVocab:enables RealTimeDataProcessingService
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "Structural modeling using SysML Internal Block Diagrams for component interfaces and interconnections"
    DTDFVocab:inputTo SysMLModeling, SysMLIBDs
]

instance MontiArcAutomatonBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral modeling using MontiArc Automaton"
    DTDFVocab:inputTo MontiArcAutomaton
]

instance SysMLStateMachinesBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral modeling using SysML state machines"
    DTDFVocab:inputTo SysMLStateMachines
]

instance SimulinkAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical modeling using MathWorks Simulink"
    DTDFVocab:inputTo Simulink
]

instance CPlusPlusCodeModel : DTDFVocab:Model [
    base:desc "General-purpose code modeling using C++"
    DTDFVocab:inputTo CPlusPlus
]

instance JavaCodeModel : DTDFVocab:Model [
    base:desc "General-purpose code modeling using Java"
    DTDFVocab:inputTo Java
]

instance RealTimeDataProcessingService : DTDFVocab:Service [
    base:desc "Active components for real-time data interpretation and processing enabling bidirectional communication with physical system"
    DTDFVocab:provides RealTimeDataInterpretation
]

instance RealTimeDataInterpretation : DTDFVocab:Insight [
    base:desc "Real-time data interpretation for system monitoring and control"
]

instance MABIMAX100Robot : DTDFVocab:Component [
    base:desc "Serial robot MABI MAX 100 with six axes, permanent magnet synchronous motors, gear transmission components, controlled by Siemens SINUMERIK 840D sl controller"
]

instance RobotEnvironment : DTDFVocab:Environment [
    base:contains MABIMAX100Robot
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital shadow operates with real-time data-driven representations, continuously updating the digital model from live data flows originating from the physical system via a one-way communication channel as defined in the Digital Shadow Reference Model."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Concrete Digital Shadow Model (Fig. 5) comprises Source components for raw data trace collection, Asset components representing the physical system, and Processing components that execute computational steps using simulation or data calculation models. Traceability is enforced via 'originates from' associations, which link output data traces to their generating processing components and consumed input traces, ensuring transitive traceability across the system."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between physical sensors and digital components is established via MQTT protocol using Mosquitto as the server implementation and Thingsboard for IoT data management."
]