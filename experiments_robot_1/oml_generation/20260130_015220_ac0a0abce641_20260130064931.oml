// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor positioned on the motor shaft of the first axis, measuring electrical current to infer torque."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the motor shaft of the first axis, providing motor angular position."
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the gearbox output of the first axis, providing gearbox angular position."
    DTDFVocab:producedData GearboxOutputAngleDataTransmitted
]

instance CNCPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor used by the CNC controller to provide reference positions for the first axis."
    DTDFVocab:producedData CNCPositionDataTransmitted
]

// C4: Physical-to-virtual interaction
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxOutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance CNCPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CNCPositionSensor
]

// C10: Models/Data – derived data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time-series data of motor current received via MQTT from MotorCurrentSensor."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance MotorAngleData : DTDFVocab:Data [
    base:desc "Time-series data of motor angular position received via MQTT from MotorEncoder."
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance GearboxOutputAngleData : DTDFVocab:Data [
    base:desc "Time-series data of gearbox output angular position received via MQTT from GearboxEncoder."
    DTDFVocab:fromData GearboxOutputAngleDataTransmitted
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance CNCPositionData : DTDFVocab:Data [
    base:desc "Reference position data from CNC controller received via MQTT from CNCPositionSensor."
    DTDFVocab:fromData CNCPositionDataTransmitted
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Simulated motor torque calculated by the Simulink motor model using current and angle data."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Simulated angular velocity computed from motor angle data in the Simulink system."
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Simulated angular acceleration derived from angular velocity data in the Simulink system."
    DTDFVocab:fromData AngularVelocityData
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

// C10: Models
instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of the motor incorporating Coulomb, viscous, Stribeck, Dahl, and LuGre friction submodels."
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of the gearbox capturing gear train dynamics and friction elements."
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance RobotSystemSimulinkModel : DTDFVocab:Model [
    base:desc "Integrated Simulink model of the first axis of the MABI MAX 100, combining motor, gearbox, and system dynamics."
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

// C11: Enablers
instance SimulinkExecutionEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink execution engine used for real-time simulation, model updating, and friction identification."
    DTDFVocab:enables RealTimeFrictionIdentificationService, FrictionModelUpdateService, SimulationComparisonService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating data streaming from robot sensors to the digital twin."
    DTDFVocab:enables DataAcquisitionService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell enabler providing semantic linkage between physical asset and its digital twin."
    DTDFVocab:enables AASLinkingService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard enabler providing a web-based visualization of motor torque, angular velocity, and friction components."
    DTDFVocab:enables VisualDashboardService
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service that performs online friction parameter identification and updates the friction model."
    DTDFVocab:provides FrictionParameterExtractionInsight, UpdateControlAlgorithmAction
]

instance FrictionModelUpdateService : DTDFVocab:Service [
    base:desc "Service that applies the updated friction parameters to the Simulink models for accurate simulation."
    DTDFVocab:provides FrictionParameterExtractionInsight
]

instance SimulationComparisonService : DTDFVocab:Service [
    base:desc "Service that compares measured torque, angular velocity, and acceleration data with simulated counterparts for validation."
    DTDFVocab:provides MotorGearboxWearDiagnosticInsight, ControlAccuracyImprovementInsight
]

instance VisualDashboardService : DTDFVocab:Service [
    base:desc "Dashboard service that visualizes motor torque, angular velocity, friction components, and diagnostic metrics."
    DTDFVocab:provides VisualizationInsight
]

instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Service that streams raw sensor data via MQTT into the digital twin."
    DTDFVocab:provides DataAcquisitionInsight
]

instance AASLinkingService : DTDFVocab:Service [
    base:desc "Service that maintains semantic linkage and traceability between the physical asset and its digital twin using the Asset Administration Shell."
    DTDFVocab:provides AASLinkageInsight
]

// C17: Insights/Actions
instance FrictionParameterExtractionInsight : DTDFVocab:Insight [
    base:desc "Insight detailing the identified friction parameters and their evolution over time."
]

instance MotorGearboxWearDiagnosticInsight : DTDFVocab:Insight [
    base:desc "Diagnostic insight evaluating wear conditions of the motor and gearbox based on friction data."
]

instance ControlAccuracyImprovementInsight : DTDFVocab:Insight [
    base:desc "Insight indicating how updated friction model and control algorithm improve robot motion accuracy."
]

instance MaintenanceDecisionInsight : DTDFVocab:Insight [
    base:desc "Insight providing data-driven maintenance decisions for motor and gearbox."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight capturing visualization data for dashboard display."
]

instance DataAcquisitionInsight : DTDFVocab:Insight [
    base:desc "Insight confirming receipt and integrity of sensor data streams."
]

instance AASLinkageInsight : DTDFVocab:Insight [
    base:desc "Insight documenting the semantic linkage established via the Asset Administration Shell."
]

// C17: Actions
instance UpdateControlAlgorithmAction : DTDFVocab:Action [
    base:desc "Automatically updates control algorithm parameters based on extracted friction insights."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time data streaming and processing at the sensor sampling rate (typically hundreds of Hz); twin updates and visualizations occur in near‑real‑time."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow orchestrates sensor inputs, simulation processing components (Simulation M, Simulation GW, Simulation GB), data‑calculation models, and a dashboard. The processing component consumes input data traces, applies simulation models, and outputs derived data traces that are linked back to their source through traceability."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Problem identification; asset and model analysis; creation/use of simulation models; data identification; deployment of the digital shadow; ongoing operational monitoring and online model refinement."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Separate engineering, data‑calculation, and simulation models ensure traceable derivation of data. Validation is achieved through comparison of measured versus simulated data for friction characteristics, mitigating degradation effects from wear, load, and temperature. Continuous identification maintains model fidelity over operational time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol over an IP network connects the robot sensors to the digital twin. The twin consumes current and position streams; metadata and references are managed via the Asset Administration Shell."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for modeling; Asset Administration Shell (AAS) for semantic data; simulation conducted in MathWorks Simulink, aligning with Model‑Based Systems Engineering standards."
]