// Sensing Components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor on motor to measure electrical current"
    DTDFVocab:producedData MotorCurrentDataTransmission
]
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder directly on the motor to measure shaft position"
    DTDFVocab:producedData MotorEncoderDataTransmission
]
instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Gearbox rear encoder to measure output shaft position"
    DTDFVocab:producedData GearboxEncoderDataTransmission
]
instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Output angle sensor on first axis of MABI MAX 100 robot"
    DTDFVocab:producedData OutputAngleDataTransmission
]

// Data Transmitted
instance MotorCurrentDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]
instance MotorEncoderDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]
instance GearboxEncoderDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]
instance OutputAngleDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

// Data
instance CurrentData : DTDFVocab:Data [
    base:desc "Electrical current measured by MotorCurrentSensor"
    DTDFVocab:inputTo SimulationEnvironmentEnabler
    DTDFVocab:fromData MotorCurrentDataTransmission
]
instance TorqueData : DTDFVocab:Data [
    base:desc "Torque calculated from motor current and motor model"
    DTDFVocab:inputTo SimulationEnvironmentEnabler
    DTDFVocab:fromData MotorCurrentDataTransmission
]
instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity derived from motor/gearbox output speed"
    DTDFVocab:inputTo SimulationEnvironmentEnabler
    DTDFVocab:fromData OutputAngleDataTransmission
]
instance AccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration calculated from angular velocity changes"
    DTDFVocab:inputTo SimulationEnvironmentEnabler
    DTDFVocab:fromData OutputAngleDataTransmission
]
instance MotorOutputData : DTDFVocab:Data [
    base:desc "Motor output torque and speed from Simulink simulation"
    DTDFVocab:inputTo SimulationEnvironmentEnabler
    DTDFVocab:fromData MotorCurrentDataTransmission
]
instance GearwheelOutputData : DTDFVocab:Data [
    base:desc "Gearwheel output torque and speed from Simulink simulation"
    DTDFVocab:inputTo SimulationEnvironmentEnabler
    DTDFVocab:fromData GearboxEncoderDataTransmission
]
instance SystemOutputData : DTDFVocab:Data [
    base:desc "Overall robot axis output torque and speed from Simulink simulation"
    DTDFVocab:inputTo SimulationEnvironmentEnabler
    DTDFVocab:fromData OutputAngleDataTransmission
]

// Enablers
instance MQTTDataStreamingEnabler : DTDFVocab:Enabler [
    base:desc "MQTT data streaming enabling real‑time data flow from sensors to services"
    DTDFVocab:enables RealTimeVisualizationService
]
instance SimulationEnvironmentEnabler : DTDFVocab:Enabler [
    base:desc "Simulation execution environment for state‑of‑the‑art robot models"
    DTDFVocab:enables JointFrictionIdentificationService, FrictionParameterUpdateService
]
instance SysMLModelingToolEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling tool for structural analysis of motor and gearbox"
    DTDFVocab:enables ModelingService
]
instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell enabling standardized asset description"
    DTDFVocab:enables AssetDescriptionService
]
instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard visualization platform for real‑time monitoring"
    DTDFVocab:enables RealTimeVisualizationService
]

// Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization dashboard of current, torque, angular velocity, and acceleration"
    DTDFVocab:provides RealTimeVisualizationInsight
]
instance JointFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of joint friction using white‑box and black‑box models"
    DTDFVocab:provides FrictionIdentificationInsight, RecommendMaintenanceAction
]
instance FrictionParameterUpdateService : DTDFVocab:Service [
    base:desc "Estimation and update of friction parameters to improve robot motion accuracy"
    DTDFVocab:provides FrictionParameterUpdateInsight, ControlAccuracyImprovementAction
]
instance ModelingService : DTDFVocab:Service [
    base:desc "Development of SysML structural models for motor and gearbox"
]
instance AssetDescriptionService : DTDFVocab:Service [
    base:desc "Standardized asset description via Asset Administration Shell"
]

// Insights
instance FrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Comparison of measured vs. simulated data to refine joint friction models"
]
instance FrictionParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Estimation and update of friction parameters to improve robot motion accuracy"
]
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time dashboard of current, torque, angular velocity, and acceleration"
]

// Actions
instance RecommendMaintenanceAction : DTDFVocab:Action [
    base:desc "Recommend maintenance or tool changes based on identified friction loss"
    DTDFVocab:IsAutomatic true
]
instance ControlAccuracyImprovementAction : DTDFVocab:Action [
    base:desc "Improve robot control accuracy through updated friction models"
    DTDFVocab:IsAutomatic true
]

// Models
instance EngineeringModelMotorGearbox : DTDFVocab:Model [
    base:desc "SysML structural model of motor and gearbox for MABI MAX 100 first axis"
    DTDFVocab:inputTo SysMLModelingToolEnabler
]
instance SimulinkModelMotorGearbox : DTDFVocab:Model [
    base:desc "Simulink simulation model of motor, gearbox, and system with friction"
    DTDFVocab:inputTo SimulationEnvironmentEnabler
]
instance CoulombViscousModel : DTDFVocab:Model [
    base:desc "Coulomb‑Viscous friction calculation model"
    DTDFVocab:inputTo SimulationEnvironmentEnabler
]
instance StribeckModel : DTDFVocab:Model [
    base:desc "Stribeck friction calculation model"
    DTDFVocab:inputTo SimulationEnvironmentEnabler
]
instance DahlModel : DTDFVocab:Model [
    base:desc "Dahl friction calculation model"
    DTDFVocab:inputTo SimulationEnvironmentEnabler
]
instance LuGreModel : DTDFVocab:Model [
    base:desc "LuGre friction calculation model"
    DTDFVocab:inputTo SimulationEnvironmentEnabler
]

// Component and Environment
instance RobotAxis1 : DTDFVocab:Component [
    base:desc "First axis of the MABI MAX 100 industrial robot"
]
instance RobotEnvironment : DTDFVocab:Environment [
    base:contains MotorCurrentSensor, MotorEncoder, GearboxEncoder, OutputAngleSensor
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time streaming; data points collected at each command/interruption (ticks of controller) with implicit high frequency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Concrete realization consisting of Asset (first axis), Processing component (Simulation), Models (engineering, simulation, data calculation), DataTrace objects (current, motor/gear wheel/system outputs), Source objects (system sensors, AAS), all orchestrated within the digital shadow."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational, i.e., DT represents the robot during its normal operation; comparison with ideal (designed) behavior for identification purposes."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of each data trace back to its source and processing component; comparison of reference and simulated data; continuous re‑identification of friction parameters; inclusion of both analytical and data‑driven models to capture uncertainties due to wear, load, temperature."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol used for one‑way data flow from PT to DT; asset described via Asset Administration Shells (AAS)."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML (an ISO/IEC standard for systems engineering) and Asset Administration Shells in line with Industrie‑4.0 specifications; simulation models expressed in MathWorks Simulink."
]