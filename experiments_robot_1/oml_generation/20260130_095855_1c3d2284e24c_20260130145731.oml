// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled temperature sensor capturing operational data with ±0.1% FS accuracy, deployed in grid-based spatial distribution with millisecond sampling frequency via 5G transmission using MQTT protocol."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "High-speed vibration sensor with 1mm resolution, sampling at millisecond intervals, transmitting via LoRaWAN protocol with event-triggered data collection for real-time monitoring."
    DTDFVocab:producedData VibrationDataTransmitted
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Industrial pressure sensor with ±0.05% FS accuracy, networked deployment with second-level sampling frequency, transmitting via Modbus TCP protocol for manufacturing system integration."
    DTDFVocab:producedData PressureDataTransmitted
]

instance LidarSensor : DTDFVocab:SensingComponent [
    base:desc "Optical LiDAR sensor capturing spatial data with millimeter-level resolution, deployed in mobile configurations with 10Hz transmission frequency via Ethernet for 3D environment mapping."
    DTDFVocab:producedData LidarDataTransmitted
]

instance ProximitySensor : DTDFVocab:SensingComponent [
    base:desc "Specialized industrial proximity sensor with binary output, integrated into manufacturing line with 100Hz sampling frequency, transmitting via PROFINET protocol for collision avoidance."
    DTDFVocab:producedData ProximityDataTransmitted
]

instance FlowMeter : DTDFVocab:SensingComponent [
    base:desc "Industrial flow meter with ±0.2% FS accuracy, deployed in pipeline systems with 1Hz transmission frequency via OPC UA protocol for process monitoring."
    DTDFVocab:producedData FlowDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance VibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

instance LidarDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LidarSensor
]

instance ProximityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProximitySensor
]

instance FlowDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FlowMeter
]

// C10: Models/Data
instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML-based requirements model capturing system functional needs using RFLP methodology (Requirements-Functions-Logics-Physics) for multi-layered abstraction."
    DTDFVocab:inputTo SysMLToolchainEnabler
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) representing functional architecture with component-connector relationships for system decomposition."
    DTDFVocab:inputTo SysMLToolchainEnabler
]

instance MontiArcStateMachineModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton-based state machine model capturing system behavioral dynamics with event-driven processing capabilities."
    DTDFVocab:inputTo MontiArcToolchainEnabler
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for detailed behavioral simulation with real-time data integration capabilities for dynamic system analysis."
    DTDFVocab:inputTo SimulinkToolchainEnabler
]

instance AADLStructuralModel : DTDFVocab:Model [
    base:desc "AADL component-connector model defining physical architecture with structural validation capabilities for system integration."
    DTDFVocab:inputTo AADLToolchainEnabler
]

instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated sensor data traces including time-series operational logs and environmental parameters with schema-on-read JSON-LD format for semantic enrichment."
    DTDFVocab:fromData TemperatureDataTransmitted, VibrationDataTransmitted, PressureDataTransmitted, LidarDataTransmitted, ProximityDataTransmitted, FlowDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler
]

instance RealTimeTelemetryData : DTDFVocab:Data [
    base:desc "Near-real-time sensor streams with NTP-synchronized timestamps processed through Kalman filtering for noise reduction before integration into digital twin."
    DTDFVocab:fromData TemperatureDataTransmitted, VibrationDataTransmitted
    DTDFVocab:inputTo RealTimeProcessingEnabler
]

// C11: Enablers
instance SysMLToolchainEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based MBSE toolchain enabling multi-perspective visualization through Internal Block Diagrams (IBDs) and state machines for stakeholder alignment."
    DTDFVocab:enables MonitoringService, VisualizationService, RequirementsValidationService
]

instance MontiArcToolchainEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton toolchain supporting behavioral simulation with event-driven processing and state machine validation for system dynamics."
    DTDFVocab:enables BehavioralSimulationService, DecisionSupportService
]

instance SimulinkToolchainEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink engine enabling dynamic system simulation with co-simulation capabilities via FMI interface for heterogeneous tool integration."
    DTDFVocab:enables DynamicAnalysisService, ClosedLoopOptimizationService
]

instance AADLToolchainEnabler : DTDFVocab:Enabler [
    base:desc "AADL-based architecture description language toolchain providing structural validation and component-connector modeling for physical architecture."
    DTDFVocab:enables StructuralAnalysisService, IntegrationValidationService
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "ETL pipeline using Apache NiFi for real-time data aggregation and abstraction with schema-on-write Avro serialization for heterogeneous data formats."
    DTDFVocab:enables MonitoringService
]

instance RealTimeProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Edge computing node with Python-based processing pipeline implementing Kalman filtering and outlier detection for real-time data preprocessing."
    DTDFVocab:enables DecisionSupportService
]

instance CodeImplementationEnabler : DTDFVocab:Enabler [
    base:desc "General-purpose C++/Java implementation enabling two-way interaction with physical system through active components for control feedback."
    DTDFVocab:enables ActiveInterpretationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Passive data aggregation service capturing contextual data traces from physical system for digital shadowing and real-time monitoring."
    DTDFVocab:provides ContextualInsight
]

instance BehavioralSimulationService : DTDFVocab:Service [
    base:desc "Behavioral simulation service integrating MontiArc state machines and Simulink models for predictive system behavior analysis."
    DTDFVocab:provides BehavioralPredictionInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Multi-perspective visualization service enabling SysML IBD and MontiArc Automaton inspection through unified modeling interfaces."
    DTDFVocab:provides VisualizationInsight
]

instance DynamicAnalysisService : DTDFVocab:Service [
    base:desc "Dynamic analysis service using Simulink for real-time system behavior modeling and performance benchmarking."
    DTDFVocab:provides PerformanceBenchmarkInsight
]

instance StructuralAnalysisService : DTDFVocab:Service [
    base:desc "Structural analysis service leveraging AADL for component-connector validation and physical architecture verification."
    DTDFVocab:provides StructuralValidationInsight
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Model-based reasoning service combining simulation data with real-time analytics for automated decision-making recommendations."
    DTDFVocab:provides DecisionRecommendationInsight
]

instance ActiveInterpretationService : DTDFVocab:Service [
    base:desc "Active interpretation service processing digital shadow data through state machines and rule engines for real-time system interpretation."
    DTDFVocab:provides InterpretationResultInsight
]

instance ClosedLoopOptimizationService : DTDFVocab:Service [
    base:desc "Closed-loop optimization service combining simulation and real-time data for system performance tuning and adaptive control."
    DTDFVocab:provides OptimizationResultInsight
]

instance RequirementsValidationService : DTDFVocab:Service [
    base:desc "Requirements validation service using SysML RFLP methodology to verify system compliance across abstraction layers."
    DTDFVocab:provides ComplianceVerificationInsight
]

instance IntegrationValidationService : DTDFVocab:Service [
    base:desc "Integration validation service validating component-connector relationships through AADL-based structural testing."
    DTDFVocab:provides IntegrationVerificationInsight
]

