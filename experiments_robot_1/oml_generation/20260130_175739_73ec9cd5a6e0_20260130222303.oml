instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input current for MABI MAX 100 robot's first vertical axis"
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring output angle for MABI MAX 100 robot's first vertical axis"
    DTDFVocab:producedData OutputAngleDataTransmitted
]

instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

instance InputCurrentData : DTDFVocab:Data [
    base:desc "Time series input current data streamed via MQTT protocol"
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo Simulink, Cpp, Java
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Time series output angle data streamed via MQTT protocol"
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo Simulink, Cpp, Java
]

instance FunctionalSysMLModel : DTDFVocab:Model [
    base:desc "SysML functional architecture model for MABI MAX 100 robot"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance LogicalSysMLModel : DTDFVocab:Model [
    base:desc "SysML logical architecture model for MABI MAX 100 robot"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance ProductTechnicalSysMLModel : DTDFVocab:Model [
    base:desc "SysML product/technical layer architecture model for MABI MAX 100 robot"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance ACMEComponentModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language model for component and connector perspectives"
    DTDFVocab:inputTo ACME
]

instance AADLComponentModel : DTDFVocab:Model [
    base:desc "AADL Architecture Description Language model for component and connector perspectives"
    DTDFVocab:inputTo AADL
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "MontiArc Architecture Description Language model for component and connector perspectives"
    DTDFVocab:inputTo MontiArcADL
]

instance SysMLIBDComponentModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram model for component and connector perspectives"
    DTDFVocab:inputTo SysMLIBD
]

instance MontiArcAutomatonBehaviorModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton behavioral model"
    DTDFVocab:inputTo MontiArcAutomaton
]

instance SysMLStateMachineBehaviorModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine behavioral model"
    DTDFVocab:inputTo SysMLStateMachine
]

instance SimulinkAnalyticalModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink analytical model"
    DTDFVocab:inputTo Simulink
]

instance CppAnalyticalModel : DTDFVocab:Model [
    base:desc "C++ analytical model for detailed functional implementation"
    DTDFVocab:inputTo Cpp
]

instance JavaAnalyticalModel : DTDFVocab:Model [
    base:desc "Java analytical model for detailed functional implementation"
    DTDFVocab:inputTo Java
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements, Functions, Logics, Physics) MBSE methodology for hierarchical system abstraction"
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "OOSEM MBSE methodology for hierarchical system abstraction"
]

instance SPES : DTDFVocab:Enabler [
    base:desc "SPES MBSE methodology for hierarchical system abstraction"
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "SMArDT MBSE methodology for hierarchical system abstraction"
]

instance ACME : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component and connector perspectives"
]

instance AADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component and connector perspectives"
]

instance MontiArcADL : DTDFVocab:Enabler [
    base:desc "MontiArc ADL for component and connector perspectives"
]

instance SysMLIBD : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component and connector perspectives"
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral modeling"
]

instance SysMLStateMachine : DTDFVocab:Enabler [
    base:desc "SysML v1.7 state machines for behavioral modeling"
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for analytical modeling and simulation"
]

instance Cpp : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed functional implementation"
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed functional implementation"
]

instance MABIMAX100RobotSystem : DTDFVocab:Environment [
    base:desc "MABI MAX 100 industrial robot's first vertical axis in machining operational domain"
    base:contains MotorComponent, GearboxComponent, EncoderComponent
]

instance MotorComponent : DTDFVocab:Component [
    base:desc "Motor component of MABI MAX 100 robot's first vertical axis"
]

instance GearboxComponent : DTDFVocab:Component [
    base:desc "Gearbox component of MABI MAX 100 robot's first vertical axis"
]

instance EncoderComponent : DTDFVocab:Component [
    base:desc "Encoder component of MABI MAX 100 robot's first vertical axis"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital shadow operates as a passive entity with no data push from virtual to physical components; it neither operates autonomously nor pushes data back to the physical system."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for streaming sensor data between physical and virtual components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Industry standards and methodologies include SysML for Model-Based Systems Engineering (MBSE), with architecture description languages (ADLs) such as ACME, AADL, MontiArc, and SysML IBDs for component and connector modeling. Methodologies like RFLP (Requirements, Functions, Logics, Physics), OOSEM, SPES, and SMArDT are applied to handle system complexity across abstraction levels including requirements, functional architecture, logical architecture, and product/technical layer."
]