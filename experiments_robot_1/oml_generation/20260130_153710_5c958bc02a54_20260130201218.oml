// C2: Acting Components
instance MabiMax100FirstAxisMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor of the first axis of the MABI MAX 100 industrial robot"
]

instance MabiMax100Gearbox : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear set gearbox coupled to the motor of the first axis"
]

instance SiemensSinumerikController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK controller issuing motion commands and enforcing safety constraints for the drive"
]

// C3: Physical sensing components
instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder delivering high‑resolution angular position"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder providing redundant high‑resolution angular position"
    DTDFVocab:producedData SecondaryEncoderDataTransmitted
]

// C4: Physical‑to‑virtual interaction
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder
]

instance SecondaryEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoder
]

// C10: Data (from sensors)
instance MotorEncoderAngularPositionData : DTDFVocab:Data [
    base:desc "Angular position data originating from the motor‑mounted encoder"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEngine, MLFramework
]

instance SecondaryEncoderAngularPositionData : DTDFVocab:Data [
    base:desc "Angular position data originating from the secondary encoder"
    DTDFVocab:fromData SecondaryEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEngine, MLFramework
]

// C10: Models
instance FrictionSimulinkModel : DTDFVocab:Model [
    base:desc "White‑box Simulink dynamic simulation of robot friction"
    DTDFVocab:inputTo SimulinkEngine
]

instance FrictionMLModel : DTDFVocab:Model [
    base:desc "Black‑box machine‑learning model trained on intrinsic robot state data to capture non‑linear friction effects"
    DTDFVocab:inputTo MLFramework
]

// C11: Enablers
instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation engine used for white‑box dynamic models"
    DTDFVocab:enables InsightService
]

instance MLFramework : DTDFVocab:Enabler [
    base:desc "Machine‑learning runtime (e.g., TensorFlow/PyTorch) executing the black‑box friction model"
    DTDFVocab:enables InsightService
]

instance CppRuntime : DTDFVocab:Enabler [
    base:desc "C++ runtime environment for generated executable artefacts"
    DTDFVocab:enables ControlActionService
]

instance JavaRuntime : DTDFVocab:Enabler [
    base:desc "Java runtime environment for generated executable artefacts"
    DTDFVocab:enables ControlActionService
]

instance MBSEPlatform : DTDFVocab:Enabler [
    base:desc "Model‑Based Systems Engineering platform (SysML, ACME, AADL, MontiArc) supporting traceability and model generation"
    DTDFVocab:enables InsightService
]

// C6: Services
instance InsightService : DTDFVocab:Service [
    base:desc "Service that aggregates model outputs and generates analytical insights for decision support"
    DTDFVocab:provides FrictionCompensationInsight
]

instance ControlActionService : DTDFVocab:Service [
    base:desc "Service that issues automatic control actions back to the physical system based on derived insights"
    DTDFVocab:provides PositionControlAction
]

// C17: Insights
instance FrictionCompensationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the estimated friction compensation needed for the first axis based on combined white‑box and black‑box model results"
]

// C17: Actions
instance PositionControlAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of drive commands to achieve precise positioning, using the estimated friction compensation"
    DTDFVocab:IsAutomatic true
]

// Optional: Environment containing the robot components
instance RobotFirstAxisEnvironment : DTDFVocab:Environment [
    base:contains MabiMax100FirstAxisMotor, MabiMax100Gearbox, SiemensSinumerikController, MotorMountedEncoder, SecondaryEncoder
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The text states that a Digital Twin can provide active components that interpret incoming data and push information back to the physical system, unlike a digital shadow which is passive. However, the documents do not specify command types, message formats, validation/authentication methods, feedback loops, conflict‑resolution strategies, or confirmation mechanisms for control actions from the twin to the physical asset."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is organized according to the Digital Shadow reference model, which introduces a Processing component that consumes input data traces, executes engineering, simulation or data‑calculation models, and produces output data traces that become part of the digital shadow. Concretization of the reference model is achieved by mapping its abstract class diagram to concrete classes and associations, thereby establishing a conformance relation between reference concepts and instantiated elements. This component‑based orchestration provides fine‑grained, transitive traceability through the ‘originates‑from’ association, enabling the system to track data provenance across processing steps. The architecture accommodates heterogeneous modeling languages (e.g., SysML, ADLs such as ACME, AADL) and toolchains (e.g., Simulink, C++) within the same framework."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The documents describe a model‑based systems‑engineering (MBSE) lifecycle that proceeds through four abstraction layers: (1) requirements engineering, (2) functional architecture, (3) logical architecture, and (4) product/technical (implementation) layer. At each stage the system is represented with appropriate modeling artefacts—requirements models, functional block diagrams, logical component‑connector diagrams, and finally concrete code or simulation models. Transition between stages is managed by traceability links (e.g., the “originates‑from” association) that bind data traces to the processing component, input traces, and the models that generated them, preserving a transitive provenance chain. Conformance relations are used to map concrete class‑diagram incarnations to the abstract Digital Shadow Reference Model, ensuring that each lifecycle phase yields a model that conforms to the reference semantics."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by maintaining traceability from high‑level SysML specifications to the concrete simulation and data‑driven models, allowing verification of transformation correctness. Validation relies on comparing Simulink simulation results with measured data from the dual encoders to detect deviations. Uncertainty arises from model abstraction, sensor noise, and transformation errors; these are managed by tracing model artifacts back to their source and applying verification steps during model conversion. Continuous identification and validation procedures are prescribed to uphold the reliability of the Digital Twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the physical asset and the digital shadow is based on the MQTT protocol (as indicated by the citation of the Mosquitto implementation). The documents do not provide information about network topology, bandwidth or latency requirements, redundancy mechanisms, or additional security protocols such as TLS or authentication schemes."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is built on open engineering standards: the reference model is expressed as a UML class diagram (OMG UML standard) and the system models are created with SysML (OMG SysML specification). Conformance to the reference model is enforced through a formal conformance relation that maps concrete model elements to the UML‑based reference concepts. The use of widely adopted ADLs (ACME, AADL, MontiArc) and simulation environments (Simulink) further aligns the Digital Twin with industry‑accepted modelling and interoperability standards."
]