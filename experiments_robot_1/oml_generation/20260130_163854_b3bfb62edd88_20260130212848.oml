// C17: Insights/Actions
instance RealTimeDataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight that provides operators with up‑to‑date visual representation of live sensor and simulated data"
]

instance DerivedFrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Insight delivering identified static, kinetic and viscous friction parameters for the gearbox"
]

instance UpdatedFrictionParametersAction : DTDFVocab:Action [
    base:desc "Action that automatically uploads the newly identified friction parameters to the robot controller",
    DTDFVocab:IsAutomatic true
]

// C6: Services
instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Service that visualizes measured and simulated data on a web dashboard",
    DTDFVocab:provides RealTimeDataVisualizationInsight
]

instance FrictionDerivationService : DTDFVocab:Service [
    base:desc "Service that processes live traces to identify static, kinetic and viscous friction parameters",
    DTDFVocab:provides DerivedFrictionParametersInsight
]

instance FrictionParameterUpdateService : DTDFVocab:Service [
    base:desc "Service that feeds updated friction parameters back to the robot controller to improve motion accuracy",
    DTDFVocab:provides UpdatedFrictionParametersAction
]

// C11: Enablers
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML modeling tool employed for structural model creation"
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment executing motor, gearwheel and gearbox simulation models",
    DTDFVocab:enables FrictionDerivationService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker used for live streaming of sensor DataTraces (I_M, r_M, r_G, r_out) from the robot to the digital twin",
    DTDFVocab:enables DashboardVisualizationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell providing integration and standardized access to the digital twin",
    DTDFVocab:enables FrictionParameterUpdateService
]

instance WebDashboardApp : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard application for visualizing measured and simulated data",
    DTDFVocab:enables DashboardVisualizationService
]

// C3: Physical sensing components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder of the first vertical axis, providing motor current I_M, motor angle, derived torque and angular velocity",
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the gearbox of the first vertical axis, providing gearbox angle and output angle",
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

// C10: Data (live sensor measurements)
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Live motor current I_M streamed via MQTT",
    DTDFVocab:fromData MotorEncoderDataTransmitted,
    DTDFVocab:inputTo MQTTBroker, SimulinkTool
]

instance MotorAngleData : DTDFVocab:Data [
    base:desc "Live motor angle r_M streamed via MQTT",
    DTDFVocab:fromData MotorEncoderDataTransmitted,
    DTDFVocab:inputTo MQTTBroker, SimulinkTool
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque (computed from current and motor parameters) streamed via MQTT",
    DTDFVocab:fromData MotorEncoderDataTransmitted,
    DTDFVocab:inputTo MQTTBroker, SimulinkTool
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity ω_M derived from motor encoder, streamed via MQTT",
    DTDFVocab:fromData MotorEncoderDataTransmitted,
    DTDFVocab:inputTo MQTTBroker, SimulinkTool
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Gearbox intermediate angle r_G streamed via MQTT",
    DTDFVocab:fromData GearboxEncoderDataTransmitted,
    DTDFVocab:inputTo MQTTBroker, SimulinkTool
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Output shaft angle r_out streamed via MQTT",
    DTDFVocab:fromData GearboxEncoderDataTransmitted,
    DTDFVocab:inputTo MQTTBroker, SimulinkTool
]

// C10: Models/Data
instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams describing the structure of the vertical axis (motor, gearwheel gearbox, cycloidal gearbox)",
    DTDFVocab:inputTo SysMLTool
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the permanent‑magnet synchronous motor behavior",
    DTDFVocab:inputTo SimulinkTool
]

instance SimulinkGearwheelModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the gearwheel gearbox dynamics",
    DTDFVocab:inputTo SimulinkTool
]

instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the cycloidal gearbox dynamics",
    DTDFVocab:inputTo SimulinkTool
]

instance FrictionCalculationModel : DTDFVocab:Model [
    base:desc "Data‑calculation model used to derive static, kinetic and viscous friction parameters for the gearbox",
    DTDFVocab:inputTo SimulinkTool
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital shadow operates in real‑time with live data; sensor streams are processed continuously as they arrive (sub‑second latency), enabling online identification of friction and immediate update of simulated outputs."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow comprising the purpose class FrictionDerivation, the asset class Mabi, multiple DataTrace classes (e.g., I_M, r_M, r_G, r_out, ˆr_M, ˆr_G, ˆr_out), Processing components (Simulation_M, Simulation_GW, Simulation_GB) that apply simulation models, and a dashboard consumer of the resulting data."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow is instantiated for the operated stage of the robot, using engineering models (SysML) of the designed asset and live operational data to refine friction models during runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of each DataTrace to its source and processing model; continuous validation by comparing simulated friction‑adjusted outputs with measured reference data; use of both analytical (white‑box) and data‑driven (black‑box) friction models to ensure model fidelity over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted to the digital shadow over MQTT; the Asset Administration Shell (AAS) is employed for structural model integration."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Uses the Asset Administration Shell (AAS) standard for model integration and SysML as a standardized modeling language; conforms to the Digital Shadow Reference Model (DSRM)."
]