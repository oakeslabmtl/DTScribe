instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
    DTDFVocab:dataType "Time-series temperature readings"
    DTDFVocab:transmissionFrequency "1-10Hz"
    DTDFVocab:protocol "MQTT/OPC UA"
]

instance VibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
    DTDFVocab:dataType "High-frequency vibration signals"
    DTDFVocab:transmissionFrequency "10-100Hz"
    DTDFVocab:protocol "MQTT/OPC UA"
    DTDFVocab:triggerCondition "Threshold breaches"
]

instance OperationalLogDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalLogSensor
    DTDFVocab:dataType "Discrete event logs and metadata"
    DTDFVocab:transmissionFrequency "Event-triggered"
    DTDFVocab:protocol "OPC UA/REST"
]

instance EnvironmentalParameterDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalParameterSensor
    DTDFVocab:dataType "Environmental parameters (humidity, pressure)"
    DTDFVocab:transmissionFrequency "1-10Hz"
    DTDFVocab:protocol "MQTT/OPC UA"
]

// C10: Models/Data
instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated, abstracted contextual data traces from physical system traces, serving as input for model-based simulations and analytics."
    DTDFVocab:fromData TemperatureDataTransmitted, VibrationDataTransmitted, OperationalLogDataTransmitted, EnvironmentalParameterDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler, ModelValidationEnabler
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram representing functional architecture with component-connector interfaces for system structure modeling."
    DTDFVocab:inputTo SysMLEnabler
]

instance SimulinkBehavioralModel : DTDFVocab:Model [
