// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Contextual temperature sensor providing real-time thermal data traces for system monitoring and predictive analytics, aggregated via digital shadow mechanisms."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency vibration sensor for equipment health monitoring, triggering data collection on threshold breaches for predictive maintenance."
    DTDFVocab:producedData VibrationDataTransmitted
]

instance OperationalLogSensor : DTDFVocab:SensingComponent [
    base:desc "System operational log sensor capturing discrete events and metadata from physical assets for behavioral analysis and traceability."
    DTDFVocab:producedData OperationalLogDataTransmitted
]

instance EnvironmentalParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring environmental parameters (e.g., humidity, pressure) for contextual data aggregation in system performance analysis."
    DTDFVocab:producedData EnvironmentalParameterDataTransmitted
]

