    DTDFVocab:inputTo MontiArcEnabler
]

instance AADLComponentModel : DTDFVocab:Model [
    base:desc "AADL model describing component interfaces, connectors, and composition with behavioral annotations for architecture analysis."
    DTDFVocab:inputTo AADLEnabler
]

