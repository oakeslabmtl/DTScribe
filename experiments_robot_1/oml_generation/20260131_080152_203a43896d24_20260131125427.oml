// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "A permanent magnet synchronous motor that converts electrical current (I_M) into mechanical torque (τ_M) for the MABI MAX 100 industrial robot's first axis"
]

instance StandardGearbox : DTDFVocab:ActingComponent [
    base:desc "Standard gearbox component in the gear transmission system that processes torque (τ_G) from the motor"
]

instance CycloidalGearbox : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gearbox following the standard gearbox that adjusts rotational dynamics and outputs final torque (τ_out) to the robot axis"
]

instance SiemensSinumerik840DCNCController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D CNC controller that processes position, speed, and acceleration commands to dynamically adjust torque/current for friction compensation"
]

// C3: Physical Sensing Components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder measuring angular position of the permanent magnet synchronous motor to reduce backlash/positional uncertainty"
]

instance SecondaryPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind the gearbox comparing readings with motor encoder to measure angular position and reduce positional uncertainty"
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring electrical input current (I_M) to infer torque via motor-specific constants"
]

instance MQTTSensorDataStream : DTDFVocab:SensingComponent [
    base:desc "MQTT protocol-based data acquisition system collecting sensor data streams for real-time monitoring of torque (τ_M, τ_G, τ_out), angular velocity (ω), and acceleration"
]

// C4: Data Transmission
instance EncoderPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder, SecondaryPositionEncoder
    base:desc "Angular position data streams from both encoders for positional uncertainty reduction"
]

instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
    base:desc "Electrical current (I_M) data stream for torque inference calculations"
]

instance MQTTSensorStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MQTTSensorDataStream
    base:desc "Real-time MQTT protocol data stream containing torque (τ_M, τ_G, τ_out), angular velocity (ω), and acceleration measurements"
]

// C10: Models/Data
instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "White-box friction model simulating Coulomb and viscous friction components for the permanent magnet synchronous motor"
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "White-box friction model implementing Stribeck friction behavior to account for velocity-dependent friction characteristics"
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "White-box friction model combining Coulomb, viscous, and hysteresis friction effects for detailed motion simulation"
]

instance BlackBoxDataDrivenFrictionModel : DTDFVocab:Model [
    base:desc "Black-box data-driven friction model trained on operational data to identify friction patterns and model wear effects"
]

instance StructuralSysMLBDD : DTDFVocab:Model [
    base:desc "SysML Block Definition Diagram describing the physical architecture of the MABI MAX 100 robot's first axis (motor, gearboxes, encoders)"
]

instance StructuralSysMLIBD : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram detailing energy flows (rotational torque/velocity, electrical current) through the robot's first axis components"
]

instance MeasuredTorqueData : DTDFVocab:Data [
    DTDFVocab:fromData MQTTSensorStream
    base:desc "Measured torque values (τ_M, τ_G, τ_out) derived from motor current and encoder data for physical state representation"
]

instance MeasuredAngularVelocityData : DTDFVocab:Data [
    DTDFVocab:fromData MQTTSensorStream
    base:desc "Real-time angular velocity (ω) measurements from encoders for motion state tracking"
]

instance SimulatedTorqueData : DTDFVocab:Data [
    DTDFVocab:fromData CoulombViscousFrictionModel, StribeckFrictionModel, LuGreFrictionModel
    base:desc "Simulated torque outputs from friction models compared against measured data for error analysis"
]

instance SimulatedAngularVelocityData : DTDFVocab:Data [
    DTDFVocab:fromData CoulombViscousFrictionModel, StribeckFrictionModel, LuGreFrictionModel
    base:desc "Simulated angular velocity outputs from friction models for virtual state representation"
]

instance DataTraceMetadata : DTDFVocab:Data [
    DTDFVocab:fromData MQTTSensorStream
    base:desc "Metadata traces including sensor origin and timestamps for traceability of operational data"
]

// C11: Enablers
instance MATLABSimulinkSimulation : DTDFVocab:Enabler [
    base:desc "MathWorks MATLAB Simulink platform enabling executable friction models (Coulomb-Viscous, Stribeck, LuGre) and system dynamics simulation"
]

instance MQTTProtocol : DTDFVocab:Enabler [
    base:desc "MQTT protocol for real-time sensor data streaming and digital shadow synchronization"
]

instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML modeling tools for creating Block Definition Diagrams (BDD) and Internal Block Diagrams (IBD) of the robot's physical architecture"
]

instance ModelBasedSystemsEngineering : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering framework integrating SysML and MATLAB Simulink for comprehensive digital twin development"
]

// C6: Services
instance FrictionAnalysisService : DTDFVocab:Service [
    base:desc "Real-time identification of joint friction (static, kinetic, viscous) using white-box (analytical) and black-box (data-driven) friction models"
    DTDFVocab:enables ModelRefinementService
    DTDFVocab:provides FrictionCharacterizationInsight
]

instance ModelRefinementService : DTDFVocab:Service [
    base:desc "Continuous updating of friction models via dynamic exchange of models (MathWorks MATLAB Simulink simulations) to account for wear, tooling changes, or operational conditions"
    DTDFVocab:enables MATLABSimulinkSimulation
    DTDFVocab:provides ModelParameterAdjustmentAction
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Unified dashboard integrating live data (sensor streams, model outputs) for semantic support and traceability"
    DTDFVocab:enables MQTTProtocol
    DTDFVocab:provides DeviationVisualizationInsight, MotionAccuracyAnalysisInsight
]

// C17: Insights/Actions
instance FrictionCharacterizationInsight : DTDFVocab:Insight [
    base:desc "Identification of static, kinetic, and viscous friction components to optimize control algorithms for improved motion accuracy"
]

instance MotionAccuracyAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analysis of motion accuracy deviations between measured and simulated data to diagnose wear, tooling changes, or environmental factors"
]

instance DeviationVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of deviations between measured and simulated data to diagnose wear, tooling changes, or environmental factors"
]

instance ModelParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Dynamic adjustment of friction model parameters via continuous model exchange to adapt to operational changes"
    DTDFVocab:IsAutomatic true
]

instance OperationalDiagnosticsAction : DTDFVocab:Action [
    base:desc "Automated diagnostics based on visualization of physical-virtual state deviations for predictive maintenance"
    DTDFVocab:IsAutomatic true
]

// C12: Environment
instance RobotFirstAxisEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotor, StandardGearbox, CycloidalGearbox
]

instance RobotControlSystemEnvironment : DTDFVocab:Environment [
    base:contains SiemensSinumerik840DCNCController, MATLABSimulinkSimulation
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin operates on a **real-time, live-data-driven time scale**, with data acquisition and processing occurring at **high frequency** (not explicitly quantified but implied to be near-real-time). The system is designed for **continuous, dynamic updates** during robot operation to maintain alignment between physical and virtual representations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellation focuses on the **first axis of the MABI MAX 100 robot**, integrating:
  - **Physical System**: Motor, gear transmission, and Siemens SINUMERIK controller.
  - **Digital Shadow**: A **passive, one-way data flow** entity that processes live measurements (via MQTT) and simulates friction effects for accuracy improvement.
  The Digital Shadow does **not** interact autonomously with the physical system (no virtual-to-physical feedback)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin spans the following lifecycle stages:
  1. **As Designed** – Defined via **SysML models** (Block Definition Diagram/Internal Block Diagram) describing the robot’s structural and behavioral components.
  2. **As Operated** – Enabled by **live data integration** (MQTT streams) and **continuous friction model refinement** during robot operation to account for wear, tooling changes, and environmental factors."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
  - **Model Validation**: Simulation models (e.g., Simulink) are validated against real-world operational data to calibrate friction parameters.
  - **Uncertainty Handling**: Traceability of data origins (sensor/processing model) allows for **root-cause analysis** of deviations between measured and simulated data.
  - **Verification/Validation**: Continuous comparison of **measured torque/velocity** with simulated outputs (e.g., ˆτ_M, ˆω) validates model accuracy in real-time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Technical connections are established via:
  - **MQTT Protocol**: Real-time sensor data streaming from the robot’s encoders and current sensors to the digital shadow.
  - **SysML Models**: Structural/behavioral models (BDD/IBD) define the physical system architecture for traceability.
  - **Simulation Integration**: MathWorks Simulink models communicate with the digital shadow to process friction data and generate derived outputs."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT leverages:
  - **SysML**: For structural/behavioral modeling of the physical system.
  - **MathWorks MATLAB Simulink**: For executable friction models and system simulations.
  - **MQTT Protocol**: For real-time data communication between physical sensors and digital shadow."
]