instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor position encoder for first axis of MABI MAX 100 industrial robot"
    DTDFVocab:producedData MotorEncoderPositionDataTransmitted, MotorEncoderVelocityDataTransmitted
]

instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder behind gearbox for first axis of MABI MAX 100 industrial robot"
    DTDFVocab:producedData SecondaryEncoderPositionDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor for first axis of MABI MAX 100 industrial robot"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance MotorEncoderVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance SecondaryEncoderPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current data from physical sensor"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler, DashboardVisualizationToolsEnabler
]

instance MotorEncoderPositionData : DTDFVocab:Data [
    base:desc "Measured motor position data from motor encoder"
    DTDFVocab:fromData MotorEncoderPositionDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler, DashboardVisualizationToolsEnabler
]

instance MotorEncoderVelocityData : DTDFVocab:Data [
    base:desc "Measured motor velocity data from motor encoder"
    DTDFVocab:fromData MotorEncoderVelocityDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler, DashboardVisualizationToolsEnabler
]

instance SecondaryEncoderPositionData : DTDFVocab:Data [
    base:desc "Measured gearbox output position data from secondary encoder"
    DTDFVocab:fromData SecondaryEncoderPositionDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler, DashboardVisualizationToolsEnabler
]

instance SysMLBDD : DTDFVocab:Model [
    base:desc "SysML Block Definition Diagram model for first axis of MABI MAX 100 industrial robot"
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLIBD : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram model for first axis of MABI MAX 100 industrial robot"
    DTDFVocab:inputTo SysMLEnabler
]

instance SimulinkMotor : DTDFVocab:Model [
    base:desc "Simulink simulation model for motor component of first axis"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance SimulinkGearwheel : DTDFVocab:Model [
    base:desc "Simulink simulation model for gearwheel component of first axis"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance SimulinkGearbox : DTDFVocab:Model [
    base:desc "Simulink simulation model for gearbox component of first axis"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Coulomb-Viscous white-box friction model for first axis"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Stribeck white-box friction model for first axis"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Dahl white-box friction model for first axis"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "LuGre white-box friction model for first axis"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance SysMLBDDVirtualSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for SysML BDD model output"
    DTDFVocab:producedData SysMLBDDDataTransmitted
]

instance SysMLIBDVirtualSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for SysML IBD model output"
    DTDFVocab:producedData SysMLIBDDataTransmitted
]

instance SimulinkMotorVirtualSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for Simulink motor model output"
    DTDFVocab:producedData SimulinkMotorDataTransmitted
]

instance SimulinkGearwheelVirtualSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for Simulink gearwheel model output"
    DTDFVocab:producedData SimulinkGearwheelDataTransmitted
]

instance SimulinkGearboxVirtualSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for Simulink gearbox model output"
    DTDFVocab:producedData SimulinkGearboxDataTransmitted
]

instance CoulombViscousFrictionVirtualSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for Coulomb-Viscous friction model output"
    DTDFVocab:producedData CoulombViscousFrictionDataTransmitted
]

instance StribeckFrictionVirtualSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for Stribeck friction model output"
    DTDFVocab:producedData StribeckFrictionDataTransmitted
]

instance DahlFrictionVirtualSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for Dahl friction model output"
    DTDFVocab:producedData DahlFrictionDataTransmitted
