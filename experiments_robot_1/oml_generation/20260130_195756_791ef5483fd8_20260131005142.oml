    DTDFVocab:producedData LuGreFrictionDataTransmitted
]

instance SysMLBDDDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLBDDVirtualSensor
]

instance SysMLIBDDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLIBDVirtualSensor
]

instance SimulinkMotorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkMotorVirtualSensor
]

instance SimulinkGearwheelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkGearwheelVirtualSensor
]

instance SimulinkGearboxDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkGearboxVirtualSensor
]

instance CoulombViscousFrictionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CoulombViscousFrictionVirtualSensor
]

instance StribeckFrictionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StribeckFrictionVirtualSensor
]

instance DahlFrictionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DahlFrictionVirtualSensor
]

instance LuGreFrictionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LuGreFrictionVirtualSensor
]

