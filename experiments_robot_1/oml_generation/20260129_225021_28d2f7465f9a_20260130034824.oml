// ----------------- Enablers -----------------

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "Simulink numerical simulation engine."
    DTDFVocab:enables SimulinkSimulationService
]

instance CPlusPlusGenEngine : DTDFVocab:Enabler [
    base:desc "Model‑to‑code transformation backend targeting C++."
    DTDFVocab:enables CPPCodeGenerationService
]

instance JavaGenEngine : DTDFVocab:Enabler [
    base:desc "Model‑to‑code transformation backend targeting Java."
    DTDFVocab:enables JavaCodeGenerationService
]

instance RelationalDBEnabler : DTDFVocab:Enabler [
    base:desc "Relational database for managing real‑time telemetry, historical data and model artifacts."
    DTDFVocab:enables DataPersistenceService
]

instance NoSQLDBEnabler : DTDFVocab:Enabler [
    base:desc "NoSQL database for analytics and real‑time telemetry."
    DTDFVocab:enables DataPersistenceService
]

// ----------------- Services -----------------

instance SimulinkSimulationService : DTDFVocab:Service [
    base:desc "Service that executes the Simulink model producing simulation outputs."
    DTDFVocab:provides SimulationInsight
]

instance CPPCodeGenerationService : DTDFVocab:Service [
    base:desc "Service that generates C++ implementation modules from SysML/ACME/AADL models."
    DTDFVocab:provides CodeGenerationInsight
]

instance JavaCodeGenerationService : DTDFVocab:Service [
    base:desc "Service that generates Java implementation modules from SysML/ACME/AADL models."
    DTDFVocab:provides CodeGenerationInsight
]

instance DataPersistenceService : DTDFVocab:Service [
    base:desc "Service that persists telemetry, simulation outputs, and model artifacts into databases."
    DTDFVocab:provides PersistenceInsight
]

// ----------------- Insights -----------------

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from Simulink simulation results."
]

instance CodeGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful code generation for runtime implementation."
]

instance PersistenceInsight : DTDFVocab:Insight [
    base:desc "Insight confirming persistence of data for analytics and traceability."
]

// ----------------- Models -----------------

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML v1.7 structural decomposition model defining functional, logical, and product layers."
    DTDFVocab:inputTo SimulinkEngine
]

instance ACMEComponentModel : DTDFVocab:Model [
    base:desc "ACME component-level description linking functional, logical, product layers."
    DTDFVocab:inputTo CPlusPlusGenEngine, JavaGenEngine
]

instance AADLComponentModel : DTDFVocab:Model [
    base:desc "AADL model for precise interface pinning and component composition."
    DTDFVocab:inputTo CPlusPlusGenEngine, JavaGenEngine
]

instance MontiArcBehaviorModel : DTDFVocab:Model [
    base:desc "MontiArc automaton model for behavioral specification."
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkSimModel : DTDFVocab:Model [
    base:desc "Simulink model used for numerical simulation of system dynamics."
    DTDFVocab:inputTo SimulinkEngine
]

// ----------------- Data -----------------

instance SimulinkSimulationData : DTDFVocab:Data [
    base:desc "Simulation outputs from Simulink model."
    DTDFVocab:inputTo RelationalDBEnabler
    DTDFVocab:fromData SimulinkOutputDataTransmitted
]

instance RuntimeCppModuleData : DTDFVocab:Data [
    base:desc "Runtime C++ implementation module generated from SysML/ACME/AADL models."
    DTDFVocab:inputTo RelationalDBEnabler
]

instance RuntimeJavaModuleData : DTDFVocab:Data [
    base:desc "Runtime Java implementation module generated from SysML/ACME/AADL models."
    DTDFVocab:inputTo RelationalDBEnabler
]

instance ModelArtifactsData : DTDFVocab:Data [
    base:desc "Artifacts of SysML and MontiArc models for traceability."
    DTDFVocab:inputTo RelationalDBEnabler
]

// ----------------- Sensing & Data Transmission -----------------

instance SimulinkDataSource : DTDFVocab:SensingComponent [
    base:desc "Simulink engine acting as data source for simulation outputs."
    DTDFVocab:producedData SimulinkOutputDataTransmitted
]

instance SimulinkOutputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkDataSource
]