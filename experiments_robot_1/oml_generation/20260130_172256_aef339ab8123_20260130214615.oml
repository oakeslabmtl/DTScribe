instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Senses input current for the actuation system"
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Senses output angle for the actuation system"
    DTDFVocab:producedData OutputAngleDataTransmitted
]

instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

instance InputCurrentData : DTDFVocab:Data [
    base:desc "Time-series input current data"
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo MQTTProtocol, SimulinkTool
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Time-series output angle data"
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo MQTTProtocol, SimulinkTool
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML for structural modeling using IBDs"
    DTDFVocab:inputTo SysMLIBDsADL
]

instance MontiArcBehavioralModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcADL
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines for behavioral modeling"
    DTDFVocab:inputTo SysMLIBDsADL
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink for analytical simulations"
    DTDFVocab:inputTo SimulinkTool
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "MBSE methodology for Requirements, Functions, Logics, Physics abstraction levels"
    DTDFVocab:enables DataSynchronizationService
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "Object-Oriented Systems Engineering Methodology for system abstraction"
    DTDFVocab:enables DataSynchronizationService
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for multi-level abstraction"
    DTDFVocab:enables DataSynchronizationService
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for system complexity management"
    DTDFVocab:enables DataSynchronizationService
]

instance ACMEADL : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component & connector structures"
    DTDFVocab:enables DataSynchronizationService
]

instance AADLADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component & connector structures"
    DTDFVocab:enables DataSynchronizationService
]

instance MontiArcADL : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for behavior modeling"
    DTDFVocab:enables DataSynchronizationService
]

instance SysMLIBDsADL : DTDFVocab:Enabler [
    base:desc "SysML IBDs for component & connector-based descriptions"
    DTDFVocab:enables DataSynchronizationService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation"
    DTDFVocab:enables DataSynchronizationService
]

instance CppLanguage : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior description"
    DTDFVocab:enables DataSynchronizationService
]

instance JavaLanguage : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior description"
    DTDFVocab:enables DataSynchronizationService
]

instance MQTTProtocol : DTDFVocab:Enabler [
    base:desc "MQTT protocol for real-time data transmission"
    DTDFVocab:enables DataSynchronizationService
]

instance DataSynchronizationService : DTDFVocab:Service [
    base:desc "Service for real-time state synchronization via MQTT"
    DTDFVocab:provides StateSynchronizationAction
]

instance StateSynchronizationAction : DTDFVocab:Action [
    base:desc "Synchronizes virtual model state with physical system in real-time"
    DTDFVocab:IsAutomatic true
]

instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving the first axis"
]

instance GearTransmission : DTDFVocab:ActingComponent [
    base:desc "Gear transmission mechanism for the actuation system"
]

instance CycloidalGearMechanism : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear mechanism for precise motion control"
]

instance SiemensSINUMERIK840Dsl : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl control system processing position, speed, and acceleration commands"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "No virtual-to-physical interaction occurs, as the digital shadow functions as a passive entity that neither operates autonomously nor pushes data back to the physical system."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital shadow operates with real-time, data-driven representations utilizing live sensor data streams for continuous identification of physical system states, ensuring one-way data flow synchronization between physical and digital components without bidirectional communication."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Shadow Reference Model defines a UML class diagram structure with components including Asset (representing physical entities), Processing (handling data transformation via calculation or simulation models), and Model (engineering or simulation models). The system coordinates these components through traceability links where data traces originate from processing steps, enabling fine-grained traceability across the shadow's architecture."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained through the integration of analytical and data-driven models with live physical data to enhance accuracy. Validation involves comparing reference values against simulated outputs and quantifying deviations between measured and simulated data. Traceability of data to its origin and computational methods is enforced, with systematic error detection and correction mechanisms embedded in the verification process to ensure reliability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for sensor data streaming from physical to digital components, with data visualization in a dashboard. No details on network topology, bandwidth, latency, reliability, redundancy, or security protocols are provided."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved via Asset Administration Shells (AAS) for standardized interoperability and MQTT protocol for streaming sensor data from external controllers, ensuring seamless data exchange between the digital shadow and cyber-physical system components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with industry standards including SysML for systems engineering modeling, AADL for architecture description, ACME for component-based modeling, and MontiArc for architecture modeling, facilitating interoperability across heterogeneous stakeholders and tools as part of MBSE practices."
]