// C3: Physical sensing components
instance PhysicalAssetStateSensor : DTDFVocab:SensingComponent [
    base:desc "Automated one‑way sensor streaming the current state of the physical asset for the digital shadow."
    DTDFVocab:producedData PhysicalToVirtualDataStream
]

// C4: Physical-to-virtual interaction
instance PhysicalToVirtualDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalAssetStateSensor
]

// C10: Data
instance DigitalShadowData : DTDFVocab:Data [
    base:desc "Continuous stream of sensor or contextual data representing the physical object's state in the digital twin."
    DTDFVocab:fromData PhysicalToVirtualDataStream
    DTDFVocab:inputTo SimulationEnabler
]

// C10: Models/Data
instance StructuralModelACME : DTDFVocab:Model [
    base:desc "Structural architecture model expressed in ACME ADL capturing components, interfaces, and connectors of the twin."
    DTDFVocab:inputTo ModelingEnabler
]

instance StructuralModelAADL : DTDFVocab:Model [
    base:desc "Structural architecture model expressed in AADL ADL describing component‑connector structures."
    DTDFVocab:inputTo ModelingEnabler
]

instance BehavioralModelSysMLStateMachine : DTDFVocab:Model [
    base:desc "Behavioral model defined as a SysML v1.7 state‑machine specification for the twin's dynamic behavior."
    DTDFVocab:inputTo SimulationEnabler
]

instance BehavioralModelMontiArcAutomaton : DTDFVocab:Model [
    base:desc "Behavioral model expressed in MontiArc Automaton capturing state transitions."
    DTDFVocab:inputTo SimulationEnabler
]

instance SimulationModelSimulink : DTDFVocab:Model [
    base:desc "Executable simulation model implemented in MathWorks Simulink, refined from behavioral specifications."
    DTDFVocab:inputTo SimulationEnabler
]

// C11: Enablers
instance ModelingEnabler : DTDFVocab:Enabler [
    base:desc "Toolchain that integrates heterogeneous ADL structural models (ACME, AADL, MontiArc, SysML IBD) into a unified representation."
    DTDFVocab:enables ModelingService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation environment (e.g., MathWorks Simulink, C++/Java runtime) that executes behavioral models and provides iterative evolution of the twin."
    DTDFVocab:enables SimulationService
]

// C6: Services
instance ModelingService : DTDFVocab:Service [
    base:desc "Service that composes and validates structural models for the digital twin."
    DTDFVocab:provides ModelConsistencyInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs the twin's behavioral simulation and supplies runtime state information."
    DTDFVocab:provides TwinRuntimeInsight
]

// C17: Insights
instance ModelConsistencyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that the integrated structural models are consistent across ADL descriptions."
]

instance TwinRuntimeInsight : DTDFVocab:Insight [
    base:desc "Insight delivering the current runtime state of the digital twin derived from simulation execution."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The document outlines that MBSE modeling is organized into successive abstraction layers that correspond to lifecycle phases: (1) requirements layer, (2) functional architecture layer, (3) logical architecture layer, and (4) product/technical layer. Each layer provides a distinct representation of the system, and progression from one layer to the next is managed through SysML models and associated MBSE tooling, enabling controlled transitions and governance of the overall development lifecycle."
]