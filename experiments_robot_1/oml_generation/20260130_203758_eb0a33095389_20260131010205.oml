// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor (PMSM) rated for |qmax| = 75 °/s and a firm electrical torque limit of 50 Nm."
]

instance GearTrainTransmission : DTDFVocab:ActingComponent [
    base:desc "Combined gear‑transmission: standard gear stage plus auxiliary cycloidal gear train, 1:15 gear ratio, mechanical range ±90°."
]

// C3: Physical sensing components
instance PrimaryMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Primary Hall‑effect encoder mounted on motor rotor, 10,000 counts/rotation resolution."
    DTDFVocab:producedData PrimaryEncoderPayload
]

instance SecondaryGearEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary optical incremental encoder positioned behind gear train, 5,000 counts/rotation resolution."
    DTDFVocab:producedData SecondaryEncoderPayload
]

instance ShuntCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Shunt current sensor, 0‑150 A range, 0.01 % accuracy, sampled at 10 kHz."
    DTDFVocab:producedData CurrentSensorPayload
]

// C4: Physical-to-virtual interaction
instance PrimaryEncoderPayload : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PrimaryMotorEncoder
]

instance SecondaryEncoderPayload : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryGearEncoder
]

instance CurrentSensorPayload : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ShuntCurrentSensor
]

// C10: Models/Data
instance MotorPositionData : DTDFVocab:Data [
    base:desc "Normalized motor position data derived from primary encoder."
    DTDFVocab:fromData PrimaryEncoderPayload
    DTDFVocab:inputTo DataNormalizerEnabler
]

instance GearBacklashData : DTDFVocab:Data [
    base:desc "Normalized gear backlash data derived from secondary encoder."
    DTDFVocab:fromData SecondaryEncoderPayload
    DTDFVocab:inputTo DataNormalizerEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Normalized motor current data derived from shunt current sensor."
    DTDFVocab:fromData CurrentSensorPayload
    DTDFVocab:inputTo DataNormalizerEnabler
]

instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML functional architecture capturing requirements and high‑level functions."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME component‑connector architecture documenting logical structure."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc automaton model describing computational behaviour."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance SimulinkDynamicsModel : DTDFVocab:Model [
    base:desc "Simulink model for physics‑based simulation of motor dynamics."
    DTDFVocab:inputTo SimulationEngineEnabler
]

// C11: Enablers
instance DataNormalizerEnabler : DTDFVocab:Enabler [
    base:desc "Normalizes raw sensor streams into dispositioned JSON payloads for storage."
    DTDFVocab:enables InfluxDBStorageService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine integrating Simulink and MontiArc models."
    DTDFVocab:enables SimulationExecutionService
]

instance PLCInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "PLC interface over EtherCAT and CAN‑bus OPC UA gateway providing closed‑loop control."
    DTDFVocab:enables ActuationCommandService
]

// C6: Services
instance InfluxDBStorageService : DTDFVocab:Service [
    base:desc "Writes normalized data to InfluxDB 2.0 time‑series database."
    DTDFVocab:provides PositionTimeSeriesInsight,
                         GearbacklashAnalysisInsight,
                         CurrentTrendInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Executes combined simulation models to predict motor behaviour."
    DTDFVocab:provides SimulatedMotorSpeedInsight
]

instance ActuationCommandService : DTDFVocab:Service [
    base:desc "Sends position setpoints to motion controller via EtherCAT network."
    DTDFVocab:provides MotorSetpointAction
]

// C17: Insights and Actions
instance PositionTimeSeriesInsight : DTDFVocab:Insight [
    base:desc "Time‑series insight of motor position allowing trend analysis."
]

instance GearbacklashAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analysis of gear backlash derived from dual‑encoder data."
]

instance CurrentTrendInsight : DTDFVocab:Insight [
    base:desc "Insight into motor current trend for fault detection."
]

instance SimulatedMotorSpeedInsight : DTDFVocab:Insight [
    base:desc "Simulated motor speed insight produced by the simulation engine."
]

instance MotorSetpointAction : DTDFVocab:Action [
    base:desc "Command action to adjust motor position via PLC."
    DTDFVocab:IsAutomatic true
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is validated through a continuous comparison between reference values measured on the physical test rig and the simulated outputs of the analog plant model. The following process is followed:\n\n1. **Reference acquisition**: Encoder positions and current sensor readings are saved as ground‑truth traces over a predefined test sequence (20 s ramp, 3 °/s, 30 % duty‑cycle).\n2. **Simulation**: The same set‑point sequence is injected into the Simulink animated model, producing simulated joint positions and currents.\n3. **Comparison**: Root‑mean‑square error (RMSE) and maximum‑deviation metrics are computed in real time. A tolerance band of ±0.2 % of full‑scale for position and ±1 % for current is acceptable; deviations beyond this band trigger a fault flag.\n4. **Uncertainty quantification**: Encoder quantisation error (51.2 µrad), machine back‑EMF noise (±0.5 V rms), and thermal drift (0.5 °C / °m/s²) are modelled as Gaussian perturbations in the simulation and propagated through a Monte‑Carlo study to obtain confidence intervals.\n5. **Error detection and correction**: Once a divergence is detected, the FT compares the deviation against the model’s identified sensitivity matrix; in case of consistent bias, the model parameters (stiffness, damping) are automatically re‑optimised via a least‑squares routine.\n6. **Quality assurance**: All simulation traces, comparison reports, and identified model parameter updates are version‑controlled in GitLab and subject to a peer review workflow. The DT’s verification report is generated as a PDF on daily basis and stored in the project repository."
]