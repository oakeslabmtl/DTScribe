// C2: Acting Components
instance BaseJointMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor driving the robot’s first rotary joint, supplied by Siemens SINUMERIK 840D controller via controllable motor‑current input I_M"
]

// C3: Physical sensing components
instance MotorPositionEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor position encoder on the first rotary joint"
    DTDFVocab:producedData MotorPositionDataTransmitted
]
instance GearwheelPositionEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Gearwheel position encoder on the first rotary joint"
    DTDFVocab:producedData GearwheelPositionDataTransmitted
]
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor supply current I_M"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical-to-virtual interaction
instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoderSensor
]
instance GearwheelPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearwheelPositionEncoderSensor
]
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C5: Data traces (core data)
instance MotorPositionData : DTDFVocab:Data [
    base:desc "Measured motor position from MQTT stream, time‑stamped"
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo FrictionIdentificationProcessingEnabler
]
instance GearwheelPositionData : DTDFVocab:Data [
    base:desc "Measured gearwheel position from MQTT stream, time‑stamped"
    DTDFVocab:fromData GearwheelPositionDataTransmitted
    DTDFVocab:inputTo FrictionIdentificationProcessingEnabler
]
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current I_M from MQTT stream, time‑stamped"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo FrictionIdentificationProcessingEnabler
]
instance JointAngleData : DTDFVocab:Data [
    base:desc "Derived joint angle, computed from motor and gearwheel encoder data"
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo FrictionIdentificationProcessingEnabler
]
instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity Ω of the first joint, computed from encoder data"
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo FrictionIdentificationProcessingEnabler
]
instance JointTorqueData : DTDFVocab:Data [
    base:desc "Derived joint torque τ, estimated from current and encoder data"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo FrictionIdentificationProcessingEnabler
]

// C10: Models/Data
instance MotorStructuralModel : DTDFVocab:Model [
    base:desc "Structural SysML model of the permanent‑magnet synchronous motor on the base joint"
    DTDFVocab:inputTo AASMetadataEnabler
]
instance GearwheelStructuralModel : DTDFVocab:Model [
    base:desc "Structural SysML model of the gearwheel gearbox on the base joint"
    DTDFVocab:inputTo AASMetadataEnabler
]
instance CycloidalGearboxStructuralModel : DTDFVocab:Model [
    base:desc "Structural SysML model of the cycloidal gearbox following the gearwheel"
    DTDFVocab:inputTo AASMetadataEnabler
]
instance EncoderModel : DTDFVocab:Model [
    base:desc "Encoder model for motor and gearwheel position sensing"
    DTDFVocab:inputTo AASMetadataEnabler
]
instance MotorDynamicSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the motor dynamics"
    DTDFVocab:inputTo FrictionIdentificationProcessingEnabler
]
instance GearboxDynamicSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the gearwheel and cycloidal gearbox"
    DTDFVocab:inputTo FrictionIdentificationProcessingEnabler
]
instance FrictionModelCoulombViscous : DTDFVocab:Model [
    base:desc "White‑box Coulomb‑Viscous friction model for joint friction identification"
    DTDFVocab:inputTo FrictionIdentificationProcessingEnabler
]
instance FrictionModelStribeck : DTDFVocab:Model [
    base:desc "White‑box Stribeck friction model for joint friction identification"
    DTDFVocab:inputTo FrictionIdentificationProcessingEnabler
]
instance FrictionModelDahl : DTDFVocab:Model [
    base:desc "White‑box Dahl friction model for joint friction identification"
    DTDFVocab:inputTo FrictionIdentificationProcessingEnabler
]
instance FrictionModelLuGre : DTDFVocab:Model [
    base:desc "White‑box LuGre friction model for joint friction identification"
    DTDFVocab:inputTo FrictionIdentificationProcessingEnabler
]
instance ReferenceMotorOutputModel : DTDFVocab:Model [
    base:desc "Reference model of motor output r_M for comparison with measured data"
    DTDFVocab:inputTo FrictionIdentificationProcessingEnabler
]
instance ReferenceGearwheelOutputModel : DTDFVocab:Model [
    base:desc "Reference model of gearwheel output r_G for comparison with measured data"
    DTDFVocab:inputTo FrictionIdentificationProcessingEnabler
]
instance ReferenceSystemOutputModel : DTDFVocab:Model [
    base:desc "Reference model of system output r_out for comparison with measured data"
    DTDFVocab:inputTo FrictionIdentificationProcessingEnabler
]

// C11: Enablers
instance FrictionIdentificationProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that executes Simulink models and identifies joint friction parameters using real‑time sensor streams"
    DTDFVocab:enables FrictionIdentificationService, RealTimeVisualizationService, AutomatedAggregationService, FeedbackForModelUpdateService
]
instance AASMetadataEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell enabler that stores asset metadata and model references"
    DTDFVocab:enables FrictionIdentificationService
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service for continuous, multi‑physics identification of joint friction using white‑box and black‑box models"
    DTDFVocab:provides FrictionParameterUpdateInsight, FrictionTrendInsight
]
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time dashboard service that visualizes joint friction trends and simulation results"
    DTDFVocab:provides FrictionTrendInsight
]
instance AutomatedAggregationService : DTDFVocab:Service [
    base:desc "Service that aggregates and abstracts contextual data for higher‑level analysis"
]
instance FeedbackForModelUpdateService : DTDFVocab:Service [
    base:desc "Service that sends feedback for updating simulation models and controller parameters"
    DTDFVocab:provides AdjustControllerGainsAction, MaintenanceNotificationAction
]

// C17: Insights/Actions
instance FrictionParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight indicating updated friction parameters for the joint"
]
instance FrictionTrendInsight : DTDFVocab:Insight [
    base:desc "Insight visualizing dynamic changes in joint friction over time"
]
instance AdjustControllerGainsAction : DTDFVocab:Action [
    base:desc "Automated recommendation to adjust controller gains based on updated friction parameters"
    DTDFVocab:IsAutomatic true
]
instance MaintenanceNotificationAction : DTDFVocab:Action [
    base:desc "Automatic notification to maintenance personnel for potential wear or defects in the joint"
    DTDFVocab:IsAutomatic true
]

// C18: Environment
instance IndustrialRobotEnvironment : DTDFVocab:Environment [
    base:contains BaseJoint, SafetyCell, RobotMotor, Gearwheel, CycloidalGearbox
]

// C19: Components
instance BaseJoint : DTDFVocab:Component [
    base:desc "First rotary joint of the MABI MAX 100 linear robot, encompassing motor, gearwheel and cycloidal gearbox"
]
instance SafetyCell : DTDFVocab:Component [
    base:desc "Safety cell that limits joint position to ±90° to prevent hazardous motion"
]
instance RobotMotor : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor driving the base joint"
]
instance Gearwheel : DTDFVocab:Component [
    base:desc "Gearwheel gearbox with gear ratios for the first rotary joint"
]
instance CycloidalGearbox : DTDFVocab:Component [
    base:desc "Cycloidal gearbox providing precise motion after the gearwheel"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time operation: sensor data is streamed continuously via MQTT; processing and model evaluation occur on the fly with no defined discrete time step, enabling near‑instantaneous friction estimation and visualization."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized processing pipeline: sensor data ingestion via MQTT, ingestion into the AAS, simulation modules (Simulink) consuming the data, and a visualization dashboard. The pipeline is embodied as the Digital Shadow Reference Model instantiated for the first axis; the primary components are Source (sensor input), Model (SysML and Simulink), Processing (data calculation), and DataTrace/DataPoint."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow covers the operated stage of the PT; the engineering workflow utilizes the design (ideal white‑box models), manufacturing (parameter extraction, AAS), and operation (runtime identification) phases of the robot. The DT specifically models the first axis during active machining processes."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Verification through traceability between sensor data, derived signals, and simulation outputs; validation via comparison of reference and simulated torque/velocity signals; continuous identification accounts for wear, load, and temperature changes; uncertainty handled by dual white‑box and black‑box modeling; data calculation models provide deterministic provenance."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "One‑way MQTT streams from PT to DT; Asset Administration Shell interface (likely REST/OPC‑UA) between digital shadow and asset metadata; no bi‑directional control signals reported in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for engineering models, Asset Administration Shell (standardized by IEC 62832), and MQTT as a standardized messaging protocol."
]