// ====================================================
// C3: Physical sensing components
// ====================================================

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) measuring electrical current of the permanent‑magnet synchronous motor"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder providing rotor position measurements"
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind the gearbox providing gearbox shaft position"
    DTDFVocab:producedData GearboxPositionDataTransmitted
]

// ====================================================
// C4: Physical-to-virtual interaction (DataTransmitted)
// ====================================================

instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

instance DerivedKinematicsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorEncoderSensor, GearboxEncoderSensor
]

// ====================================================
// C10: Data
// ====================================================

instance LiveCurrentData : DTDFVocab:Data [
    base:desc "Live stream of motor current values"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo MqttBrokerEnabler, SimulinkEngineEnabler
]

instance LiveMotorPositionData : DTDFVocab:Data [
    base:desc "Live motor encoder position trace"
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo MqttBrokerEnabler, SimulinkEngineEnabler
]

instance LiveGearboxPositionData : DTDFVocab:Data [
    base:desc "Live gearbox encoder position trace"
    DTDFVocab:fromData GearboxPositionDataTransmitted
    DTDFVocab:inputTo MqttBrokerEnabler, SimulinkEngineEnabler
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Torque values derived from current and position sensors"
    DTDFVocab:fromData DerivedKinematicsDataTransmitted
    DTDFVocab:inputTo SimulinkEngineEnabler, AssetAdministrationShellEnabler
]

instance DerivedVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity derived from position traces"
    DTDFVocab:fromData DerivedKinematicsDataTransmitted
    DTDFVocab:inputTo SimulinkEngineEnabler, AssetAdministrationShellEnabler
]

instance DerivedAccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration derived from velocity data"
    DTDFVocab:fromData DerivedKinematicsDataTransmitted
    DTDFVocab:inputTo SimulinkEngineEnabler, AssetAdministrationShellEnabler
]

// ====================================================
// C11: Enablers (tooling and integration)
// ====================================================

instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker for one‑way automated data flow from robot to digital shadow"
    DTDFVocab:enables ServiceMqttStreaming
]

instance SimulinkEngineEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink execution engine for friction model simulation and parameter identification"
    DTDFVocab:enables ServiceFrictionIdentification, ServiceModelComparison, ServiceParameterGeneration
]

instance SysmlModelingToolEnabler : DTDFVocab:Enabler [
    base:desc "SysML tool for structural component‑connector modeling of the robot axis"
    DTDFVocab:enables ServiceModelDocumentation
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for integrating engineering models and runtime data"
    DTDFVocab:enables ServiceModelIntegration
]

instance VisualizationDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Custom dashboard for real‑time visualization of sensor and simulation results"
    DTDFVocab:enables ServiceRealTimeVisualization
]

// ====================================================
// C6: Services (DT services)
// ====================================================

instance ServiceRealTimeVisualization : DTDFVocab:Service [
    base:desc "Real‑time visualization dashboard showing live sensor traces and simulated results"
    DTDFVocab:provides InsightLiveSystemStatus
]

instance ServiceFrictionIdentification : DTDFVocab:Service [
    base:desc "Continuous friction identification (static, kinetic, viscous) using live data"
    DTDFVocab:provides InsightFrictionParameterDerivation
]

instance ServiceModelComparison : DTDFVocab:Service [
    base:desc "Comparison of simulated vs measured data to validate friction models"
    DTDFVocab:provides InsightSimulatedMeasuredComparison
]

instance ServiceParameterGeneration : DTDFVocab:Service [
    base:desc "Generation of updated friction model parameters for improved robot motion control"
    DTDFVocab:provides InsightUpdatedControlSetpoints, ActionFeedBackParameters
]

instance ServiceModelDocumentation : DTDFVocab:Service [
    base:desc "Documentation of SysML component‑connector model of the first rotational axis"
    DTDFVocab:provides InsightModelDocumentation
]

instance ServiceModelIntegration : DTDFVocab:Service [
    base:desc "Integration of engineering models and runtime data via Asset Administration Shell"
    DTDFVocab:provides InsightModelIntegration
]

instance ServiceMqttStreaming : DTDFVocab:Service [
    base:desc "Streaming of live sensor data over MQTT to the digital twin"
    DTDFVocab:provides InsightLiveSystemStatus
]

// ====================================================
// C17: Insights & Actions
// ====================================================

instance InsightFrictionParameterDerivation : DTDFVocab:Insight [
    base:desc "Derivation of friction parameters for the gearbox"
]

instance InsightUpdatedControlSetpoints : DTDFVocab:Insight [
    base:desc "Updated control set‑points based on identified friction parameters"
]

instance InsightImprovedMotionAccuracy : DTDFVocab:Insight [
    base:desc "Improved motion accuracy of the robot achieved by refined friction models"
]

instance InsightLiveSystemStatus : DTDFVocab:Insight [
    base:desc "Live system status visualized in the dashboard"
]

instance InsightSimulatedMeasuredComparison : DTDFVocab:Insight [
    base:desc "Comparison of simulated versus measured data to assess model fidelity"
]

instance InsightModelDocumentation : DTDFVocab:Insight [
    base:desc "Systematic SysML documentation of the rotational axis components"
]

instance InsightModelIntegration : DTDFVocab:Insight [
    base:desc "Integration of models and data within the Asset Administration Shell"
]

instance ActionFeedBackParameters : DTDFVocab:Action [
    base:desc "Feed back updated friction model parameters into the robot controller for better trajectory planning"
    DTDFVocab:IsAutomatic true
]

// ====================================================
// C10: Models (engineering and simulation models)
// ====================================================

instance SysMLAxisModel : DTDFVocab:Model [
    base:desc "SysML component‑connector model of the first rotational axis (motor, gear‑wheel gearbox, cycloidal gearbox) of the MABI MAX 100 robot"
    DTDFVocab:inputTo SysmlModelingToolEnabler
]

instance SimulinkFrictionlessModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction‑less simulation model of the axis"
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance SimulinkCoulombViscousModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model implementing Coulomb‑Viscous friction for the gearbox"
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance SimulinkStribeckModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model implementing Stribeck friction characteristics"
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance SimulinkDahlModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model implementing Dahl friction dynamics"
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance SimulinkLuGreModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model implementing LuGre friction dynamics"
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (continuous) operation; data are streamed and processed during robot runtime to update friction models on‑the‑fly."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow composed of a Purpose entity, the first‑axis Asset, multiple DataTraces (measured and simulated), Processing components that execute simulation models, and metadata linking all elements according to the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the operated stage of the physical system; the digital shadow is created and used during runtime to monitor and improve performance."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Combination of white‑box (analytical) and black‑box (data‑driven) friction models with traceability of each data point to its source; validation performed by comparing simulated outputs with measured sensor data; dynamic exchange of models ensures up‑to‑date fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are published to an MQTT broker and consumed by the digital shadow processing components; Asset Administration Shells provide semantic linking of models and data."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) as a standardised information model for linking engineering models and data; reference to SysML and IEC‑related modeling standards."
]