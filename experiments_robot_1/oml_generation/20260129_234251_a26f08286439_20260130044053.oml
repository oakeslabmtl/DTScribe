// Sensing Components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Dual angular position encoder located at the motor shaft of the first axis"
    DTDFVocab:producedData MotorAngleTransmission
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Dual angular position encoder after the gearwheel gearbox of the first axis"
    DTDFVocab:producedData GearboxAngleTransmission
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring actuator input current on the first axis"
    DTDFVocab:producedData CurrentTransmission
]

// Data Transmitted
instance MotorAngleTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxAngleTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

instance CurrentTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// Data
instance JointAngleData : DTDFVocab:Data [
    base:desc "Measured joint angle derived from the motor shaft encoder"
    DTDFVocab:fromData MotorAngleTransmission
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Joint angular velocity calculated from encoder data on the first axis"
    DTDFVocab:fromData MotorAngleTransmission
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance TorqueEstimateData : DTDFVocab:Data [
    base:desc "Estimated joint torque derived from the encoder data on the first axis"
    DTDFVocab:fromData MotorAngleTransmission
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current supplied to the actuator on the first axis"
    DTDFVocab:fromData CurrentTransmission
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

// Models
instance MotorSimulationModel : DTDFVocab:Model [
    base:desc "Matlab/Simulink executable simulation model of the permanent‑magnet synchronous motor with embedded friction sub‑models"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance GearwheelSimulationModel : DTDFVocab:Model [
    base:desc "Matlab/Simulink executable simulation model of the gearwheel gearbox with embedded friction sub‑models"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance CycloidalGearboxSimulationModel : DTDFVocab:Model [
    base:desc "Matlab/Simulink executable simulation model of the cycloidal gearbox with embedded friction sub‑models"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance SysMLComponentConnectorModel : DTDFVocab:Model [
    base:desc "SysML component‑and‑connector diagram of the first axis, including motor, gearwheel, cycloidal gearbox, dual encoders, and current sensor"
    DTDFVocab:inputTo SysMLToolEnabler
]

// Enablers
instance SysMLToolEnabler : DTDFVocab:Enabler [
    base:desc "SysML tooling for structural modeling of the first axis"
    DTDFVocab:enables StructuralModelingService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink executable simulation for real‑time model execution"
    DTDFVocab:enables ExecutableSimulationService
]

instance MQTTStreamingEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol for real‑time data streaming from the robot to the digital twin"
    DTDFVocab:enables RealTimeDataStreamingService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for semantic asset representation"
    DTDFVocab:enables SemanticAssetRepresentationService
]

instance DashboardUIEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard UI for visualization of measured vs simulated joint torque and velocity"
    DTDFVocab:enables DashboardUIService
]

instance TwinningProcessEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the iterative twin refinement process"
    DTDFVocab:enables TwinningService
]

// Services
instance StructuralModelingService : DTDFVocab:Service [
    base:desc "Service providing structural SysML modeling insight of the first axis"
    DTDFVocab:provides StructuralModelingInsight
]

instance ExecutableSimulationService : DTDFVocab:Service [
    base:desc "Service executing MATLAB/Simulink simulation of motor and gearboxes"
    DTDFVocab:provides ExecutableSimulationInsight
]

instance RealTimeDataStreamingService : DTDFVocab:Service [
    base:desc "Service providing MQTT data streaming from robot sensors to digital twin"
    DTDFVocab:provides MQTTDataStreamingInsight
]

instance SemanticAssetRepresentationService : DTDFVocab:Service [
    base:desc "Service providing semantic asset information via Asset Administration Shell"
    DTDFVocab:provides AssetSemanticInsight
]

instance DashboardUIService : DTDFVocab:Service [
    base:desc "Service providing real‑time visualization on dashboard UI"
    DTDFVocab:provides ComparisonMeasuredVsSimulatedInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring real‑time discrepancies between measured and simulated joint torque and velocity"
    DTDFVocab:provides ComparisonMeasuredVsSimulatedInsight, HeatAndWearIndicatorInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Service visualizing the comparison of measured and simulated joint states"
    DTDFVocab:provides ComparisonMeasuredVsSimulatedInsight
]

instance FrictionModelIdentificationService : DTDFVocab:Service [
    base:desc "Service performing automatic friction model identification and continuous refinement"
    DTDFVocab:provides UpdatedFrictionCoefficientsInsight, MaintenanceRecommendationAction
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Service aggregating data traces for historical analysis"
    DTDFVocab:provides DataAggregationInsight
]

instance FrictionParameterProvisionService : DTDFVocab:Service [
    base:desc "Service providing refined friction parameters for control‑loop improvement"
    DTDFVocab:provides ControlParameterTuningRecommendationAction
]

instance TwinningService : DTDFVocab:Service [
    base:desc "Service tracking iterative refinement of the digital twin model"
    DTDFVocab:provides TwinningProcessProgressInsight
]

// Insights
instance UpdatedFrictionCoefficientsInsight : DTDFVocab:Insight [
    base:desc "Updated friction coefficients derived from automatic friction model identification"
]

instance HeatAndWearIndicatorInsight : DTDFVocab:Insight [
    base:desc "Heat and wear indicators computed from torque and velocity deviations"
]

instance ComparisonMeasuredVsSimulatedInsight : DTDFVocab:Insight [
    base:desc "Real‑time comparison of measured joint torque and angular velocity with simulated values"
]

instance TwinningProcessProgressInsight : DTDFVocab:Insight [
    base:desc "Iteration progress in the twin refinement process integrating new data and model updates"
]

instance MQTTDataStreamingInsight : DTDFVocab:Insight [
    base:desc "Real‑time data streaming status via MQTT from robot sensors to twin"
]

instance AssetSemanticInsight : DTDFVocab:Insight [
    base:desc "Semantic asset information provided by Asset Administration Shell representation"
]

instance StructuralModelingInsight : DTDFVocab:Insight [
    base:desc "Structural SysML model of the first axis components and connectors"
]

instance ExecutableSimulationInsight : DTDFVocab:Insight [
    base:desc "Execution results of MATLAB/Simulink simulation for motor and gearbox behavior"
]

instance DataAggregationInsight : DTDFVocab:Insight [
    base:desc "Aggregated data streams for historical analysis and trend detection"
]

// Actions
instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Recommendation for maintenance scheduling based on friction coefficient trends"
    DTDFVocab:IsAutomatic false
]

instance ControlParameterTuningRecommendationAction : DTDFVocab:Action [
    base:desc "Recommendation for updating control loop parameters using refined friction model"
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time data acquisition during robot operation; the digital twin updates simulation outputs and friction models on a continuous basis, keeping pace with the robot’s controller loop."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin comprises the physical asset (first axis), an AAS that exposes sensor streams, a processing component that runs simulation and data aggregation, and a dashboard that presents visual analytics; all components are linked through MQTT and the AAS."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the design (ideal simulation models), manufacturing (the physical first axis hardware), and operation (live sensor data) stages, enabling continuous monitoring and model updating throughout the asset’s life."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by continuous comparison of simulated and measured torque/velocity traces; friction models are adapted online to account for wear, temperature, and load changes, maintaining validity; traceability of data origins and computational steps provides verifiability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The twin receives data through MQTT topics published by the robot’s sensor suite; the AAS serves as semantic API; simulation outputs are communicated internally via the processing component, no explicit external protocols beyond MQTT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Standards referenced include SysML for system modeling, Asset Administration Shell (AAS) for semantic asset definition, and MQTT for publish/subscribe communication."
]