// C3: Physical sensing components (simulated sensor)
instance SimulinkSimulationComponent : DTDFVocab:SensingComponent [
    base:desc "Simulation component that generates data from MathWorks Simulink for behavioral verification."
    DTDFVocab:producedData SimulinkDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmitted)
instance SimulinkDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Data transmitted from SimulinkSimulationComponent representing simulation outputs."
    DTDFVocab:producedFrom SimulinkSimulationComponent
]

// C10: Data
instance SimulatedBehaviorData : DTDFVocab:Data [
    base:desc "Aggregated simulation data used for model integration and analysis."
    DTDFVocab:fromData SimulinkDataTransmitted
    DTDFVocab:inputTo SimulinkTool
]

// C11: Enablers (tooling)
instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink tool for executing model simulations."
    DTDFVocab:enables SimulationExecutionService
]

instance SysMLMBSETool : DTDFVocab:Enabler [
    base:desc "SysML modeling environment used for creating structural and behavioral models."
    DTDFVocab:enables ModelIntegrationService
]

instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc tool for defining component‑connector architectures and automaton behavior."
    DTDFVocab:enables ModelIntegrationService
]

instance CppCodeGenerator : DTDFVocab:Enabler [
    base:desc "Automatic code generator that produces C++ source code from model specifications."
    DTDFVocab:enables CodeGenerationService
]

instance JavaCodeGenerator : DTDFVocab:Enabler [
    base:desc "Automatic code generator that produces Java source code from model specifications."
    DTDFVocab:enables CodeGenerationService
]

instance DigitalShadowReferenceModel : DTDFVocab:Enabler [
    base:desc "UML class diagram representing the Digital Shadow reference model for contextual data aggregation."
    DTDFVocab:enables DataAggregationService
]

instance ModelIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that integrates heterogeneous models from various ADLs and SysML."
    DTDFVocab:enables ModelIntegrationService
]

// C6: Services
instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service that runs simulation scenarios using Simulink."
    DTDFVocab:provides SimulationInsight
]

instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Service that integrates structural and behavioral models across different notations."
    DTDFVocab:provides DesignInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Service that aggregates contextual data traces according to the Digital Shadow reference model."
    DTDFVocab:provides DataAggregationInsight
]

instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Service that generates executable code in C++ or Java from model specifications."
    DTDFVocab:provides CodeGenerationAction
]

// C17: Insights
instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulation results to support design decisions."
]

instance DesignInsight : DTDFVocab:Insight [
    base:desc "Insight about system architecture obtained from integrated models."
]

instance DataAggregationInsight : DTDFVocab:Insight [
    base:desc "Aggregated data insight supporting cross‑domain analysis."
]

// C17: Actions
instance CodeGenerationAction : DTDFVocab:Action [
    base:desc "Action to generate source code artifacts automatically."
    DTDFVocab:IsAutomatic true
]

// C10: Models (structural, component‑connector, behavioral)
instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML requirements model capturing system requirements for the digital twin."
    DTDFVocab:inputTo ModelIntegrationEnabler
]

instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML functional architecture model expressing high‑level system functions."
    DTDFVocab:inputTo ModelIntegrationEnabler
]

instance SysMLLogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML logical architecture model detailing logical components and interfaces."
    DTDFVocab:inputTo ModelIntegrationEnabler
]

instance SysMLProductTechnicalModel : DTDFVocab:Model [
    base:desc "SysML product/technical layer model describing physical realization details."
    DTDFVocab:inputTo ModelIntegrationEnabler
]

instance ACMEComponentConnectorModel : DTDFVocab:Model [
    base:desc "Component‑connector model defined in the ACME architecture description language."
    DTDFVocab:inputTo ModelIntegrationEnabler
]

instance AADLComponentConnectorModel : DTDFVocab:Model [
    base:desc "Component‑connector model defined in the AADL architecture description language."
    DTDFVocab:inputTo ModelIntegrationEnabler
]

instance MontiArcComponentConnectorModel : DTDFVocab:Model [
    base:desc "Component‑connector model defined in the MontiArc architecture description language."
    DTDFVocab:inputTo ModelIntegrationEnabler
]

instance SysMLIBDComponentConnectorModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram model representing component connections."
    DTDFVocab:inputTo ModelIntegrationEnabler
]

instance SysMLStateMachineBehaviorModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state‑machine model capturing behavioral logic."
    DTDFVocab:inputTo ModelIntegrationEnabler
]

instance MontiArcAutomatonBehaviorModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model expressing component behavior as automata."
    DTDFVocab:inputTo ModelIntegrationEnabler
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated using a Model‑Based Systems‑Engineering (MBSE) approach that leverages architecture description languages (e.g., ACME, AADL, MontiArc, SysML internal block diagrams) to model components, their interfaces, interconnections, and composition. The overall architecture can be organised across the typical MBSE abstraction layers—requirements, functional architecture, logical architecture, and product/technical layer—and may follow methodologies such as RFLP, OOSEM, SPES, or SMArDT. Behavioural aspects can be added with state machines, Simulink models, or custom code (C++/Java), and the integration of heterogeneous models and heterogeneous stakeholder perspectives is explicitly supported."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle is expressed through the MBSE abstraction hierarchy used during development: (1) requirements modeling, (2) functional architecture definition, (3) logical architecture modeling, and (4) product/technical layer realization. Each stage is represented by corresponding models (e.g., SysML requirement diagrams, functional block diagrams, logical component‑connector diagrams, and detailed design artifacts). Transitions between stages are managed by successive refinement of models, but the document does not detail governance mechanisms."
]