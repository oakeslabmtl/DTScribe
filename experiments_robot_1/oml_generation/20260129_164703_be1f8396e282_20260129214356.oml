instance PhysicalSystemStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors capturing physical system states for automated one-way data flow"
    DTDFVocab:producedData PhysicalSystemStateDataTransmitted
]

instance PhysicalSystemStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemStateSensor
]

instance PhysicalSystemStateData : DTDFVocab:Data [
    base:desc "Raw data from physical system states via automated one-way flow"
    DTDFVocab:fromData PhysicalSystemStateDataTransmitted
    DTDFVocab:inputTo SysMLEnabler, RFLPEnabler, OOSEMEnabler, SPESEnabler, SMArDTEnabler, ACMEADLEnabler, AADLADLEnabler, MontiArcADLEnabler, MontiArcAutomatonEnabler, SysMLStateMachinesEnabler, SimulinkEnabler, CppEnabler, JavaEnabler
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML structural modeling with Internal Block Diagrams for component interfaces and geometric representation"
    DTDFVocab:inputTo SysMLEnabler
]

instance MontiArcBehavioralModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcAutomatonEnabler
]

instance SysMLStateMachinesModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines for behavioral modeling"
    DTDFVocab:inputTo SysMLStateMachinesEnabler
]

