// C2: Acting Components
instance MotorPMSM : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor driving the first axis of the MABI MAX 100 robot"
]

instance GearboxAxis1 : DTDFVocab:ActingComponent [
    base:desc "Gearbox coupled to the motor of axis 1, transmitting torque to the joint"
]

instance SinumerikController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840d sl controller exposing remote control interfaces for supervisory commands and trajectory updates"
]

// C3: Physical sensing components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted encoder directly on the motor shaft, providing high‑resolution position data"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxOutputEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located after the gearbox, providing post‑gearbox position data"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance JointTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Joint‑level torque sensor measuring torque on each axis"
    DTDFVocab:producedData TorqueSensorDataTransmitted
]

instance JointTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Joint‑level temperature sensor measuring temperature on each axis"
    DTDFVocab:producedData TemperatureSensorDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxOutputEncoder
]

instance TorqueSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointTorqueSensor
]

instance TemperatureSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointTemperatureSensor
]

// C5: Data instances
instance MotorAngleData : DTDFVocab:Data [
    base:desc "Filtered and unit‑converted motor shaft angle"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo FrictionIdentificationEnabler, MotionPlanningEnabler
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Filtered and unit‑converted post‑gearbox angle"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo FrictionIdentificationEnabler, MotionPlanningEnabler
]

instance JointTorqueData : DTDFVocab:Data [
    base:desc "Trusted joint torque measurement after range check"
    DTDFVocab:fromData TorqueSensorDataTransmitted
    DTDFVocab:inputTo HealthMonitoringEnabler, PredictiveMaintenanceEnabler
]

instance JointTemperatureData : DTDFVocab:Data [
    base:desc "Trusted joint temperature measurement after range check"
    DTDFVocab:fromData TemperatureSensorDataTransmitted
    DTDFVocab:inputTo HealthMonitoringEnabler, PredictiveMaintenanceEnabler
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram representing the kinematic chain of the six‑axis robot"
    DTDFVocab:inputTo MotionPlanningEnabler
]

instance FrictionIdentificationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model identifying joint friction using angle, torque and temperature data"
    DTDFVocab:inputTo FrictionIdentificationEnabler
]

instance HealthMonitoringModel : DTDFVocab:Model [
    base:desc "SysML state‑machine model assessing real‑time health based on torque and temperature trends"
    DTDFVocab:inputTo HealthMonitoringEnabler
]

instance PredictiveMaintenanceModel : DTDFVocab:Model [
    base:desc "Simulink predictive model generating maintenance alerts from health degradation patterns"
    DTDFVocab:inputTo PredictiveMaintenanceEnabler
]

instance MotionPlanningModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model optimizing motion plans using updated friction estimates"
    DTDFVocab:inputTo MotionPlanningEnabler
]

// C11: Enablers
instance FrictionIdentificationEnabler : DTDFVocab:Enabler [
    base:desc "Processing engine that runs the friction identification model on incoming angle, torque and temperature data"
    DTDFVocab:enables ContinuousFrictionIdentificationService
]

instance HealthMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Engine that evaluates the health monitoring model using torque and temperature data"
    DTDFVocab:enables RealTimeHealthMonitoringService
]

instance PredictiveMaintenanceEnabler : DTDFVocab:Enabler [
    base:desc "Engine that executes the predictive maintenance model to create alerts"
    DTDFVocab:enables PredictiveMaintenanceAlertService
]

instance MotionPlanningEnabler : DTDFVocab:Enabler [
    base:desc "Engine that runs the motion planning model, incorporating friction estimates"
    DTDFVocab:enables MotionPlanningOptimizationService, InteractiveWebDashboardService
]

// C6: Services
instance ContinuousFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Provides continuous multi‑physics‑aware identification of joint friction"
    DTDFVocab:provides FrictionEstimateInsight, UpdateFrictionModelAction
]

instance RealTimeHealthMonitoringService : DTDFVocab:Service [
    base:desc "Delivers real‑time health monitoring of joints based on torque and temperature trends"
    DTDFVocab:provides TemperatureTrendInsight, KinematicStateInsight
]

instance PredictiveMaintenanceAlertService : DTDFVocab:Service [
    base:desc "Generates predictive maintenance alerts when degradation thresholds are exceeded"
    DTDFVocab:provides MaintenanceAlertInsight, TriggerMaintenanceOrderAction
]

instance MotionPlanningOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes motion plans by feeding back updated friction models"
    DTDFVocab:provides AdjustMotionPlanAction
]

instance InteractiveWebDashboardService : DTDFVocab:Service [
    base:desc "Interactive web dashboard visualizing friction estimates, temperature trends and kinematic states"
    DTDFVocab:provides FrictionEstimateInsight, TemperatureTrendInsight, KinematicStateInsight
]

// C17: Insights/Actions
instance FrictionEstimateInsight : DTDFVocab:Insight [
    base:desc "Estimated joint friction values derived from the friction identification model"
]

instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Trend analysis of joint temperature over time for health assessment"
]

instance KinematicStateInsight : DTDFVocab:Insight [
    base:desc "Current kinematic state (positions, velocities) of the six‑axis robot"
]

instance MaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating predicted need for maintenance based on degradation forecasts"
]

instance UpdateFrictionModelAction : DTDFVocab:Action [
    base:desc "Automatically updates the friction model parameters in the motion planning pipeline"
    DTDFVocab:IsAutomatic true
]

instance AdjustMotionPlanAction : DTDFVocab:Action [
    base:desc "Automatically adjusts the upcoming motion plan to account for new friction estimates"
    DTDFVocab:IsAutomatic true
]

instance TriggerMaintenanceOrderAction : DTDFVocab:Action [
    base:desc "Triggers a maintenance order in the enterprise system"
    DTDFVocab:IsAutomatic false
]

// Environment containing the robot’s core components
instance RobotEnvironment : DTDFVocab:Environment [
    base:contains MotorPMSM, GearboxAxis1, SinumerikController, MotorShaftEncoder, GearboxOutputEncoder, JointTorqueSensor, JointTemperatureSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Doc 1 states that a Digital Twin can provide the active components required to push data back to the physical system, unlike a digital shadow which is passive. However, the provided documents do not describe concrete command types, message formats, authentication, validation, or confirmation mechanisms used for control flows from the digital twin to the physical asset."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is built upon the Digital Shadow Reference Model, which is presented as a UML class diagram defining key concepts such as DataTrace, ProcessingComponent, and Metadata together with their associations. A concrete Digital Twin is obtained by a conformance mapping that incarnates the reference classes into specific elements (e.g., concrete processing components and model artifacts). The ProcessingComponent encapsulates the computational logic (engineering, simulation, or data‑calculation models) and orchestrates data flow: it consumes input DataTraces, applies the associated models, and produces output DataTraces. Traceability is maintained via the ‘originates‑from’ association, allowing a transitive link from any output trace back to its generating component, input traces, and models. This class‑based composition constitutes the overall orchestration pattern, integrating heterogeneous MBSE artifacts (SysML, ADLs) with processing components to achieve systematic coordination and resource management within the Digital Twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle follows the MBSE abstraction hierarchy: (1) requirements stage, (2) functional architecture stage, (3) logical architecture stage, and (4) product/technical (physical) stage. At each stage the DT is represented by model artifacts appropriate to the abstraction: SysML requirement diagrams, SysML internal block diagrams for functional and logical architecture, and concrete engineering models (e.g., Simulink, C++ code) for the product layer. Transitions between stages are managed by traceability links defined in the Digital Shadow reference model (the “originates‑from” association) which record which processing component produced each data trace, thus enabling controlled migration of model artefacts. Governance is achieved through the conformance relation of concrete realizations to the reference class diagram, ensuring that every instantiated model adheres to the defined domain concepts."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through a traceability chain that links high‑level SysML specifications to lower‑level simulation models (e.g., Simulink) and to generated code. The reliability of the digital shadow depends on the correctness of the underlying physics‑based (white‑box) models and data‑driven (black‑box) models, as well as on the transformations applied to the data. The approach emphasizes verification of model transformations (e.g., from SysML to simulation models) and traceability of data provenance to ensure uncertainties are identified and managed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the physical system and the Digital Twin is realized through MQTT, a lightweight publish‑subscribe protocol that runs over TCP/IP. Sensors act as MQTT clients publishing measurement topics to an MQTT broker; the Twin acts as a subscriber client. This client‑server topology supports low‑latency, real‑time data delivery suitable for industrial sensor update rates. The network requirements are driven by the sampling frequencies of the physical sensors (typically tens of hertz), but specific bandwidth or latency figures are not detailed in the document. Reliability is achieved via MQTT's QoS levels, while security aspects (e.g., TLS) are not explicitly described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT follows a reference‑model‑based standardization approach. A reference class diagram defines domain concepts and relationships, and a formal conformance relation (expressed as a mapping between concrete elements and reference concepts) guarantees that any concrete DT model conforms to the reference model. This provides an interoperability framework comparable to industry standards for model interchange, and the use of SysML and widely‑adopted ADLs (ACME, AADL, MontiArc) aligns the DT with established engineering standards."
]