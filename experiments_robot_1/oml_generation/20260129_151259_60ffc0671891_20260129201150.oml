// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures motor phase current I_M from the SINUMERIK‑controlled MABI MAX 100 first vertical axis"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder attached to the permanent‑magnet synchronous motor of the first axis"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the cycloidal gearbox of the first axis"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

instance SimulinkOutputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkEngine
]

// C10: Data objects
instance MotorCurrentMeasuredData : DTDFVocab:Data [
    base:desc "Time‑stamped measured motor current I_M values streamed via MQTT"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance MotorEncoderMeasuredData : DTDFVocab:Data [
    base:desc "Time‑stamped measured motor angle r_M from the motor encoder"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance GearboxEncoderMeasuredData : DTDFVocab:Data [
    base:desc "Time‑stamped measured output angle r_out from the gearbox encoder"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance SimulatedTorqueData : DTDFVocab:Data [
    base:desc "Simulated torque τ generated by the combined motor and gearbox Simulink models"
    DTDFVocab:fromData SimulinkOutputDataTransmitted
    DTDFVocab:inputTo DashboardApp
]

instance SimulatedAngularVelocityData : DTDFVocab:Data [
    base:desc "Simulated angular velocity ω produced by the Simulink simulation of the first axis"
    DTDFVocab:fromData SimulinkOutputDataTransmitted
    DTDFVocab:inputTo DashboardApp
]

// C11: Enablers
instance MqttBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker transports live sensor streams (current, encoder positions) from the SINUMERIK 840D controller to the digital shadow"
    DTDFVocab:enables RealTimeVisualizationService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink runtime executes the motor and gearbox models for real‑time simulation and friction identification"
    DTDFVocab:enables FrictionIdentificationService
]

instance AasIntegration : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) integrates the SysML block definition with the digital shadow and enables parameter updates"
    DTDFVocab:enables MotionControlParameterUpdateService
]

instance DashboardApp : DTDFVocab:Enabler [
    base:desc "Unified dashboard visualizes measured and simulated data in real time and allows operator interaction"
    DTDFVocab:enables RealTimeVisualizationService
]

instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML is used for structural modeling of the first vertical axis (motor, gear transmission, cycloidal gearbox)"
]

// C10: Models
instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Executable Simulink model of the permanent‑magnet synchronous motor of the first axis"
    DTDFVocab:inputTo SimulinkEngine
]

instance GearboxSimulinkModelCoulombViscous : DTDFVocab:Model [
    base:desc "Simulink model of the cycloidal gearbox including Coulomb‑Viscous friction"
    DTDFVocab:inputTo SimulinkEngine
]

// C2: Acting Components (physical system)
instance FirstAxisComponent : DTDFVocab:Component [
    base:desc "First vertical axis of the MABI MAX 100 industrial robot, comprising a permanent‑magnet synchronous motor, gear transmission and a cycloidal gearbox, controlled by Siemens SINUMERIK 840D"
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Identifies static, kinetic and viscous friction parameters by comparing simulated and measured torque and angular velocity"
    DTDFVocab:provides InsightFrictionParameters, InsightDeviationQuantification
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of measured and simulated axis data in a unified dashboard"
    DTDFVocab:provides InsightFrictionParameters
]

instance MotionControlParameterUpdateService : DTDFVocab:Service [
    base:desc "Updates the SINUMERIK 840D motion‑control parameters using newly identified friction parameters to improve positioning accuracy"
    DTDFVocab:provides ActionUpdateController
]

// C17: Insights
instance InsightFrictionParameters : DTDFVocab:Insight [
    base:desc "Derived static, kinetic and viscous friction parameters for the first axis"
]

instance InsightDeviationQuantification : DTDFVocab:Insight [
    base:desc "Quantifies deviations between simulated and measured torque and angular velocity"
]

// C17: Actions
instance ActionUpdateController : DTDFVocab:Action [
    base:desc "Updates the robot’s motion‑control parameters in the SINUMERIK 840D controller based on identified friction values"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates continuously in real‑time; data are captured and processed on‑line during robot operation, allowing on‑the‑fly identification of friction parameters."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A concrete digital shadow instantiated from the Digital Shadow Reference Model, comprising the asset (first axis), purpose (FrictionDerivation), sources (sensor channels), processing components (Simulation_M, Simulation_GW, Simulation_GB), models (engineering, simulation, data‑calculation), and data traces linked through the originates‑from association to provide a coherent virtual representation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability is ensured by linking every data point to its source and the processing model that generated it; both white‑box analytical and black‑box data‑driven friction models are continuously identified during operation to maintain model fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow via MQTT messages; the digital shadow consumes these streams and may interface with the Asset Administration Shell for metadata."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation utilizes the Asset Administration Shell (AAS), an Industrie 4.0 standard for digital twins, and follows SysML modelling conventions."
]