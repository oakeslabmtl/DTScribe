// C3: Physical Sensing Components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution position encoder mounted directly on the permanent magnet synchronous motor for closed-loop control, providing spatial measurements for kinematic state monitoring."
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder positioned behind the gearbox, providing redundant high-resolution spatial measurements for closed-loop control and digital twin synchronization."
    DTDFVocab:producedData SecondaryEncoderDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
    base:desc "Time-series sensor data from motor encoder providing real-time kinematic states for digital shadow aggregation."
]

instance SecondaryEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoder
    base:desc "Time-series sensor data from secondary encoder providing redundant kinematic measurements for digital shadow synchronization."
]

// C10: Models/Data
instance KinematicStateModel : DTDFVocab:Model [
    base:desc "Structural model of robot kinematics defined using SysML Internal Block Diagrams, capturing joint configurations and spatial relationships."
    DTDFVocab:inputTo SysMLEnabler, SimulinkEnabler
]

instance DigitalShadowData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces from physical robot (MABI MAX 100) representing structured digital object states for downstream analysis."
    DTDFVocab:fromData MotorEncoderDataTransmitted, SecondaryEncoderDataTransmitted
    DTDFVocab:inputTo SysMLEnabler, SimulinkEnabler
]

instance RobotDynamicsModel : DTDFVocab:Model [
    base:desc "Behavioral model of robot dynamics implemented in MathWorks Simulink, integrating kinematic and physical laws for simulation-based analysis."
    DTDFVocab:inputTo SimulinkEnabler
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML (Systems Modeling Language) v1.7 used for multi-layered system modeling including requirements, functional architecture, logical architecture, and technical layers via Internal Block Diagrams and state machines."
    DTDFVocab:enables DataAcquisitionService, AggregationService, VisualizationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed behavioral modeling of robot kinematics and dynamics, enabling simulation-based analysis and integration with SysML models."
    DTDFVocab:enables BehavioralModelingService
]

instance SINUMERIKControllerEnabler : DTDFVocab:Enabler [
    base:desc "Siemens SINUMERIK controller acting as primary interface for acquiring real-time data (encoder feedback, motor states) from physical robot."
    DTDFVocab:enables DataAcquisitionService
]

// C6: Services
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Automated one-way ingestion of contextual data traces (kinematic states, encoder readings) from physical robot via Siemens SINUMERIK controller."
    DTDFVocab:provides KinematicStateInsight
]

instance AggregationService : DTDFVocab:Service [
    base:desc "Processing of raw sensor data into structured digital object representations (aggregated sensor states, kinematic models) for downstream analysis."
    DTDFVocab:provides DigitalShadowDataInsight
]

instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Integration with MathWorks Simulink for simulation-based behavioral modeling of robot's dynamics, enabling passive analysis of functional and logical architectures."
    DTDFVocab:provides RobotDynamicsInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Generation of dashboard-based visualizations for real-time state monitoring of robot kinematics and operational states."
    DTDFVocab:provides OperationalStateInsight
]

// C17: Insights/Actions
instance KinematicStateInsight : DTDFVocab:Insight [
    base:desc "Real-time identification of robot joint configurations and spatial relationships derived from encoder data for motion analysis."
]

instance DigitalShadowDataInsight : DTDFVocab:Insight [
    base:desc "Aggregated contextual data traces enabling multi-physics-aware analytics for operational diagnostics and planning."
]

instance RobotDynamicsInsight : DTDFVocab:Insight [
    base:desc "Simulation-based analysis of robot dynamics revealing joint friction characteristics and motion accuracy improvements."
]

instance OperationalStateInsight : DTDFVocab:Insight [
    base:desc "Visualized real-time monitoring of robot operational states for manufacturing engineers and maintenance personnel."
]

// C2: Acting Components (Not in Document - Excluded)

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system leverages a **real-time data synchronization** mechanism between the physical system and its digital representation, as implied by the distinction between passive digital shadows (one-way data flow) and active Digital Twin components. While explicit synchronization frequencies or latency requirements are not specified, the system relies on **live data aggregation** (e.g., contextual traces) to maintain temporal alignment. The temporal granularity is determined by the **streaming capabilities of the underlying infrastructure**, such as MQTT-based data exchange, which supports low-latency, event-driven updates. The document does not provide quantitative metrics (e.g., Hz, ms) but emphasizes the necessity of **automated, continuous data flow** for real-time operational alignment between physical and digital domains."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin (DT) constellation** in the document is implicitly framed through **Model-Based Systems Engineering (MBSE)** methodologies, which emphasize **orchestration via multi-layered abstraction** (requirements → functions → logics → physics). Key architectural patterns include:
  - **Component & Connector Perspectives**: Defined via **ADLs (ACME, AADL, MontiArc, SysML IBDs)**, where **components** represent DT modules (e.g., simulation, data processing) and **connectors** manage interoperability.
  - **Behavioral Integration**: Achieved through **state machines (SysML v1.7), MontiArc Automaton, or external tools** (e.g., MathWorks Simulink, C++/Java code) for dynamic coordination.
  - **Resource Management**: Implicit in **heterogeneous tool integration**, where MBSE copes with **diverse modeling notations** (e.g., SysML for architecture, Simulink for physics-based behavior) and **stakeholder perspectives**.
  The document does not specify **explicit orchestration frameworks** (e.g., microservices, event-driven architectures) or **real-time coordination protocols**, but the **digital shadow reference model** (Fig. 1) suggests a **passive-to-active data flow** where DTs act as **active interpreters** of aggregated data traces. No mention of **federated DTs** or **distributed ledger technologies** is provided."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **validation and verification (V&V) methods** to ensure model fidelity, though specific techniques are not detailed in the provided document. The **digital shadow reference model** implies that data traces are collected and abstracted for specific purposes, suggesting a need for **uncertainty quantification** in data aggregation and abstraction processes. While explicit error detection/correction mechanisms or quality assurance processes are not described, the integration of **heterogeneous models and tools** (e.g., SysML, ADLs, simulation tools) necessitates **cross-validation** to maintain consistency. The **one-way data flow** in digital shadows (as opposed to active DTs) may introduce **latency or fidelity gaps**, requiring active components (e.g., in DTs) to interpret and process data for accuracy. No specific **sampling frequencies, precision specifications, or calibration protocols** are provided."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for the Digital Shadow system is implicitly supported by **MQTT**, a lightweight publish-subscribe protocol optimized for streaming sensor data. While the document does not explicitly detail the **network topology, bandwidth requirements, or redundancy mechanisms**, the use of MQTT suggests a **client-server or broker-based architecture** with low-latency, high-frequency communication. No explicit mention of **security protocols (e.g., TLS, OAuth)** or **reliability mechanisms (e.g., QoS levels, failover)** is provided. The infrastructure is designed to handle **one-way data flows** from physical to digital components, aligning with the passive nature of the Digital Shadow."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with **external systems** via **heterogeneous toolchains**, including **SysML** (for modeling), **MathWorks Simulink** (for simulation), and **general-purpose programming languages (C++, Java)** for implementation. Data exchange occurs through **MQTT**, a lightweight publish-subscribe protocol enabling **real-time streaming** of contextual traces from physical objects (e.g., Siemens SINUMERIK controllers) to the digital shadow. The system’s interoperability relies on **standardized modeling languages (SysML, ADLs)** and **simulation tools**, but explicit **interoperability standards** (e.g., OPC UA, FIWARE) or **enterprise integration patterns** (e.g., APIs, ESBs) are not detailed. Dependencies on external systems are implied by the **one-way data flow** from physical assets (e.g., controllers) to the digital twin, with no mention of **bidirectional synchronization** or **federated Digital Twin ecosystems**."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE)** standards, particularly leveraging **SysML** (Systems Modeling Language) for system architecture and behavior modeling. For **architecture description**, it complies with **ADLs** such as **ACME**, **AADL**, **MontiArc**, and **SysML IBDs**, which standardize component-connector perspectives. Behavioral modeling aligns with **SysML v1.7 state machines** and **MontiArc Automaton** for formalized state transitions. Interoperability is ensured through integration with **simulation tools** (e.g., **MathWorks Simulink**) and general-purpose languages (**C++**, **Java**), adhering to industry practices for heterogeneous toolchains. While no explicit **certification frameworks** or **compliance standards** (e.g., ISO, IEC) are mentioned, the use of **MBSE methodologies** (e.g., RFLP, OOSEM) implies alignment with **systems engineering best practices** and **interoperability standards** for digital system representations. The **Digital Shadow Reference Model** (Fig. 1) further suggests adherence to **UML-based modeling conventions** for contextual data aggregation and abstraction."
]