// C3: Physical sensing components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Rotary encoder mounted on the motor shaft providing angular position"
    DTDFVocab:producedData MotorShaftPositionData
]

instance GearboxOutputEncoder : DTDFVocab:SensingComponent [
    base:desc "Rotary encoder mounted on the gearbox output providing angular position"
    DTDFVocab:producedData GearboxOutputPositionData
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor on the motor providing motor current IM"
    DTDFVocab:producedData MotorCurrentData
]

// C4: Physical-to-virtual interaction
instance MotorShaftPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxOutputPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxOutputEncoder
]

instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Models/Data
instance MotorAngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity trace from motor shaft position data"
    DTDFVocab:fromData MotorShaftPositionData
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance MotorTorqueData : DTDFVocab:Data [
    base:desc "Derived torque trace from motor current data via friction model"
    DTDFVocab:fromData MotorCurrentData
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance MotorPositionCorrectionData : DTDFVocab:Data [
    base:desc "Derived positional correction trace from gearbox output position data"
    DTDFVocab:fromData GearboxOutputPositionData
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

// C11: Enablers
instance MQTTSensorIngestEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker ingest enabler for real-time sensor streams"
    DTDFVocab:enables FrictionModelIdentificationService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink enabler for executing simulation, comparison, and loss estimation"
    DTDFVocab:enables MultiPhysicsSimulationService, ModelComparisonService, FrictionLossEstimationService
]

instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Desktop dashboard enabler for live data visualization via MQTT"
    DTDFVocab:enables LiveVisualizationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell enabler mapping each physical component to semantic metadata"
    DTDFVocab:enables AssetMetadataService
]

// C6: Services
instance FrictionModelIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time friction model identification using white‑box and black‑box techniques"
    DTDFVocab:provides FrictionEstimates, UpdateMotionController, ScheduleMaintenance
]

instance MultiPhysicsSimulationService : DTDFVocab:Service [
    base:desc "Continuous multi‑physics simulation of motor, gears, and cycloidal gearbox dynamics"
    DTDFVocab:provides SimulationComparison
]

instance FrictionLossEstimationService : DTDFVocab:Service [
    base:desc "Quantitative friction loss estimation using derived torque and velocity data"
    DTDFVocab:provides FrictionLossQuantification, CalibrateJointDynamics
]

instance ModelComparisonService : DTDFVocab:Service [
    base:desc "Automated model comparison between simulation and measured data traces"
    DTDFVocab:provides SimulationComparison
]

instance LiveVisualizationService : DTDFVocab:Service [
    base:desc "Live visualization of measured versus simulated data in a unified dashboard"
    DTDFVocab:provides LiveDashboard
]

instance AssetMetadataService : DTDFVocab:Service [
    base:desc "Semantic asset representation service leveraging Asset Administration Shells"
    DTDFVocab:provides AssetMetadata
]

// C17: Insights/Actions
instance FrictionEstimates : DTDFVocab:Insight [
    base:desc "Insight on current estimated friction parameters of the drive system"
]

instance FrictionLossQuantification : DTDFVocab:Insight [
    base:desc "Insight quantifying total friction loss within the motor‑gearbox assembly"
]

instance SimulationComparison : DTDFVocab:Insight [
    base:desc "Insight comparing simulation traces to sensor data for model validation"
]

instance LiveDashboard : DTDFVocab:Insight [
    base:desc "Insight enabling real‑time visualization of current, torque, and velocity data"
]

instance AssetMetadata : DTDFVocab:Insight [
    base:desc "Insight providing semantic metadata for each physical component in the twin"
]

instance UpdateMotionController : DTDFVocab:Action [
    base:desc "Automatically updates the robot’s motion controller with new friction parameters"
    DTDFVocab:IsAutomatic true
]

instance CalibrateJointDynamics : DTDFVocab:Action [
    base:desc "Calibrates joint dynamics based on updated friction estimates"
    DTDFVocab:IsAutomatic false
]

instance ScheduleMaintenance : DTDFVocab:Action [
    base:desc "Schedules maintenance when significant friction changes are detected"
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation: sensor data are streamed continuously at the native sampling rate of the robot’s sensors; the digital shadow processes and updates simulation outputs in sync with these incoming data points."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow comprises: asset definition (MABI robot), engineering models, simulation models, data‑calculation models, a processing component that subscribes to MQTT streams, and a dashboard exposing the aggregated data traces and computed friction estimates; all components are orchestrated under the Digital Shadow Reference Model (DSRM) with clear provenance links."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design/engineering model creation → simulation/implementation of friction models → live operation and continuous identification; the twin evolves from an ideal (design) model through simulation to an operational model updated by real‑time data."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability is ensured by linking each data trace back to its source (sensor or processing component) and to the models that generate or consume it; validation is performed by comparing simulated outputs against measured data; uncertainties in friction parameters are quantified through continuous identification; white‑box and black‑box models are cross‑checked for consistency; simulation fidelity is increased by incorporating real‑time sensor data into the models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "One‑way data flow over MQTT topics from the robot’s sensors to the digital shadow; no bidirectional control commands. The Asset Administration Shell provides semantic context for the data but is not used for actuation."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for modeling, ADLs (ACME, AADL, MontiArc) for architecture, MQTT for messaging, and Asset Administration Shells for semantic data exchange – all following industry‑wide MBSE, IoT, and digital twin standards."
]