instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor for actuation in the first axis of MABI MAX 100 industrial robot"
]

instance GearTransmission : DTDFVocab:ActingComponent [
    base:desc "Gear transmission component in the first axis of MABI MAX 100 industrial robot"
]

instance CycloidalGear : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear mechanism in the first axis of MABI MAX 100 industrial robot"
]

instance SiemensSINUMERIK840DslCNCController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl CNC controller for actuation in the first axis of MABI MAX 100 industrial robot"
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder measuring angular position and velocity for the first axis of MABI MAX 100 robot"
    DTDFVocab:producedData MotorEncoderPositionVelocityData
]

instance SecondaryEncoderBehindGearbox : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind gearbox measuring angular position for the first axis of MABI MAX 100 robot"
    DTDFVocab:producedData SecondaryEncoderPositionData
]

instance CurrentSensorsInputCurrentIM : DTDFVocab:SensingComponent [
    base:desc "Current sensors measuring input current (I_M) for the first axis of MABI MAX 100 robot"
    DTDFVocab:producedData CurrentSensorsInputCurrentIMData
]

instance MotorEncoderPositionVelocityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
    base:desc "Time series data of angular position and velocity from motor encoder streamed via MQTT protocol"
]

instance SecondaryEncoderPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoderBehindGearbox
    base:desc "Time series data of angular position from secondary encoder behind gearbox streamed via MQTT protocol"
]

instance CurrentSensorsInputCurrentIMData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensorsInputCurrentIM
    base:desc "Time series data of input current (I_M) measured by current sensors streamed via MQTT protocol"
]

instance MeasuredCurrentData : DTDFVocab:Data [
    base:desc "Measured current (I_M) data from current sensors"
    DTDFVocab:fromData CurrentSensorsInputCurrentIMData
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance MeasuredPositionData : DTDFVocab:Data [
    base:desc "Measured angular position data from motor encoder"
    DTDFVocab:fromData MotorEncoderPositionVelocityData
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance MeasuredVelocityData : DTDFVocab:Data [
    base:desc "Measured angular velocity data from motor encoder"
    DTDFVocab:fromData MotorEncoderPositionVelocityData
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance MeasuredSecondaryPositionData : DTDFVocab:Data [
    base:desc "Measured angular position data from secondary encoder behind gearbox"
    DTDFVocab:fromData SecondaryEncoderPositionData
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance MeasuredTorqueData : DTDFVocab:Data [
    base:desc "Measured torque data derived from current and motor parameters"
    DTDFVocab:fromData MeasuredCurrentData
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance SimulatedCurrentData : DTDFVocab:Data [
    base:desc "Simulated current data from MATLAB Simulink models"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance SimulatedTorqueData : DTDFVocab:Data [
    base:desc "Simulated torque data from MATLAB Simulink models"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance SimulatedAngularVelocityData : DTDFVocab:Data [
    base:desc "Simulated angular velocity data from MATLAB Simulink models"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance BlockDefinitionModel : DTDFVocab:Model [
    base:desc "SysML Block Definition Model for the first axis of MABI MAX 100 robot"
    DTDFVocab:inputTo AssetAdministrationShellsEnabler
]

instance InternalBlockDiagramModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram for the first axis of MABI MAX 100 robot"
    DTDFVocab:inputTo AssetAdministrationShellsEnabler
]

instance CoulombViscousModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink Coulomb-Viscous friction model"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance StribeckModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink Stribeck friction model"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance DahlModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink Dahl friction model"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance LuGreModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink LuGre friction model"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance AssetAdministrationShell : DTDFVocab:Model [
    base:desc "Asset Administration Shell for metadata of the first axis of MABI MAX 100 robot"
    DTDFVocab:inputTo DashboardEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML tool for creating Block Definition and Internal Block Diagram models"
    DTDFVocab:enables MetadataService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink for simulating friction models (Coulomb-Viscous, Stribeck, Dahl, LuGre)"
    DTDFVocab:enables FrictionIdentificationService
]

instance AssetAdministrationShellsEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shells for metadata management"
    DTDFVocab:enables MetadataService
]

instance DataStreamingInsight : DTDFVocab:Insight [
    base:desc "Real-time data stream for sensor readings"
]

instance DataStreamingService : DTDFVocab:Service [
    base:desc "Service for streaming sensor data via MQTT protocol"
    DTDFVocab:provides DataStreamingInsight
]

instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol for streaming sensor data from physical to virtual"
    DTDFVocab:enables DataStreamingService
]

instance MotionControlInsight : DTDFVocab:Insight [
    base:desc "Insights for motion control parameters"
]

instance MotionControlService : DTDFVocab:Service [
    base:desc "Service for controlling the motion of the robot axis"
    DTDFVocab:provides MotionControlInsight
]

instance SiemensSINUMERIK840DslControllerEnabler : DTDFVocab:Enabler [
    base:desc "Siemens SINUMERIK 840D sl CNC controller for actuation"
    DTDFVocab:enables MotionControlService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard for visualization of robot status and friction insights"
    DTDFVocab:enables VisualizationService
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of joint friction using white-box and black-box models"
    DTDFVocab:provides FrictionInsight
]

instance MotionAccuracyImprovementService : DTDFVocab:Service [
    base:desc "Service for improving motion accuracy through friction identification insights"
    DTDFVocab:provides MotionAccuracyImprovementAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Integrated visualization of robot status and friction insights in dashboard"
    DTDFVocab:provides VisualizationInsight
]

instance MetadataService : DTDFVocab:Service [
    base:desc "Metadata management using Asset Administration Shells"
    DTDFVocab:provides MetadataInsight
]

instance FrictionInsight : DTDFVocab:Insight [
    base:desc "Friction identification insights for improving robot control parameters"
]

instance MotionAccuracyImprovementAction : DTDFVocab:Action [
    base:desc "Adjusting robot control parameters based on friction insights to improve motion accuracy"
    DTDFVocab:IsAutomatic true
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of robot performance metrics in dashboard"
]

instance MetadataInsight : DTDFVocab:Insight [
    base:desc "Metadata information for the digital twin components"
]

instance FirstAxisMABIMAX100Robot : DTDFVocab:Component [
    base:desc "First axis of the MABI MAX 100 industrial robot"
]

instance DigitalShadowReferenceModel : DTDFVocab:Environment [
    base:desc "Purpose-driven methodology for problem identification, asset analysis, use/create models, data identification concrete realization of Digital Shadow Reference Model for the first axis of MABI MAX 100 robot"
    base:contains FirstAxisMABIMAX100Robot, PermanentMagnetSynchronousMotor, GearTransmission, CycloidalGear, SiemensSINUMERIK840DslCNCController, MotorEncoder, SecondaryEncoderBehindGearbox, CurrentSensorsInputCurrentIM
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital shadow is a passive entity with one-way data flow from physical to virtual; no data pushed back to physical system (per Kritzinger et al. [32])"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time data streaming via MQTT, but specific time intervals not specified in document"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration of physical robot components, sensors, MQTT data streaming, processing components (Simulink models), and dashboard visualization; digital shadow as a passive entity integrating structural and behavioral models with live data"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "As operated phase; continuous monitoring during robot operation"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Comparison of simulated vs measured data to identify friction deviations; no specific V&V mechanisms mentioned beyond model comparison"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol for streaming sensor data from physical robot to digital shadow"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Asset Administration Shell (AAS) and SysML standards for modeling"
]