// C3: Physical sensing component
instance PhysicalAssetTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Automated one‑way telemetry sensor that captures contextual data traces from the physical asset and forwards them to the digital twin without returning data."
    DTDFVocab:producedData AggregatedContextualData
]

// C4: Physical‑to‑virtual interaction – data transmitted
instance AggregatedContextualData : DTDFVocab:DataTransmitted [
    base:desc "Aggregated and abstracted contextual data collected from the physical asset, transferred passively to the digital representation."
    DTDFVocab:producedFrom PhysicalAssetTelemetrySensor
]

// C10: Data used by the twin
instance DigitalTwinInputData : DTDFVocab:Data [
    base:desc "Input data for the digital twin, derived from the aggregated contextual data stream."
    DTDFVocab:fromData AggregatedContextualData
    DTDFVocab:inputTo ModelIntegrationEngine
]

// C10: Models – structural & architectural
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram defining structural blocks, ports and connectors of the system under study."
    DTDFVocab:inputTo ModelIntegrationEngine
]

instance ACMEComponentModel : DTDFVocab:Model [
    base:desc "ACME architecture description language model capturing component composition and interfaces."
    DTDFVocab:inputTo ModelIntegrationEngine
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL model describing software‑hardware bindings and execution platforms."
    DTDFVocab:inputTo ModelIntegrationEngine
]

instance MontiArcConnectorModel : DTDFVocab:Model [
    base:desc "MontiArc model specifying component connectors and data flow topology."
    DTDFVocab:inputTo ModelIntegrationEngine
]

// C10: Models – behavioral & simulation
instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink simulation model used for validation of behavioral specifications."
    DTDFVocab:inputTo ModelIntegrationEngine
]

instance CppCodeGenerationModel : DTDFVocab:Model [
    base:desc "C++ code generation artifact derived from MBSE models for executable twin components."
    DTDFVocab:inputTo ModelIntegrationEngine
]

// C11: Enabler
instance ModelIntegrationEngine : DTDFVocab:Enabler [
    base:desc "Toolchain that integrates MBSE artifacts (SysML, ACME, AADL, MontiArc) and simulation models (Simulink) to drive the digital twin."
    DTDFVocab:enables SimulationAndAnalysisService
]

// C6: Service
instance SimulationAndAnalysisService : DTDFVocab:Service [
    base:desc "Service that orchestrates simulation execution, validation and analysis based on integrated models."
    DTDFVocab:provides SimulationOutcomeInsight, AutomatedCodeGenerationAction
]

// C17: Insight
instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulation results that informs system performance and compliance."
]

// C17: Action
instance AutomatedCodeGenerationAction : DTDFVocab:Action [
    base:desc "Automatic generation of C++ or Java code from validated models for deployment in the digital twin."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The document mentions that a Digital Twin can provide active components capable of interacting with the physical asset, but it does not describe concrete command types, message formats, validation, authentication, or execution confirmation mechanisms."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin development follows the MBSE‑driven, multi‑level abstraction lifecycle: (1) Requirements level, capturing stakeholder needs; (2) Functional architecture level, defining functions and interfaces; (3) Logical architecture level, specifying component‑connector structures using ADLs such as ACME, AADL, MontiArc or SysML internal block diagrams; (4) Product/Technical layer, where concrete implementations (e.g., Simulink models, C++/Java code) are realized. Transitions between stages are managed by systematic refinement of models and traceability links, enabling governance of the twin from abstract specifications to executable artifacts."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach aligns with established modeling standards: SysML (an OMG standard) is used for requirements, functional and logical architectures; ADLs such as ACME, AADL and MontiArc are employed for component‑connector specifications; behavioral modeling follows SysML state‑machine semantics and MontiArc Automaton. The digital‑shadow reference model is expressed as a UML class diagram, adhering to UML standards. No other industry‑specific certification or interoperability standards are mentioned."
]