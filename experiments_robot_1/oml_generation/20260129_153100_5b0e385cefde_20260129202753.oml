// C3: Physical sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor of the first axis of the MABI MAX 100 robot, providing motor shaft angle."
    , DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder located behind the gearbox of the first axis, providing output shaft angle."
    , DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring the motor input current I_M for the first axis."
    , DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical-to-virtual interaction (raw sensor data)
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Raw measurement data
instance MotorAngleData : DTDFVocab:Data [
    base:desc "Raw motor angle data points streamed via MQTT."
    , DTDFVocab:fromData MotorEncoderDataTransmitted
    , DTDFVocab:inputTo MqttBroker
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Raw output angle data points from the gearbox encoder."
    , DTDFVocab:fromData GearboxEncoderDataTransmitted
    , DTDFVocab:inputTo MqttBroker
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Raw motor current measurements I_M."
    , DTDFVocab:fromData MotorCurrentDataTransmitted
    , DTDFVocab:inputTo MqttBroker
]

// C10: Calculation models for derived data
instance TorqueCalculationModel : DTDFVocab:Model [
    base:desc "Simulink model that derives torque from motor current and angle."
    , DTDFVocab:inputTo SimulinkEngine
]

instance VelocityCalculationModel : DTDFVocab:Model [
    base:desc "Simulink model that computes angular velocity from successive angle measurements."
    , DTDFVocab:inputTo SimulinkEngine
]

instance AccelerationCalculationModel : DTDFVocab:Model [
    base:desc "Simulink model that computes angular acceleration from velocity data."
    , DTDFVocab:inputTo SimulinkEngine
]

// C4: Derived data transmitted
instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueCalculationModel
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocityCalculationModel
]

instance AngularAccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AccelerationCalculationModel
]

// C10: Derived measurement data
instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque data points (Nm) after calculation."
    , DTDFVocab:fromData TorqueDataTransmitted
    , DTDFVocab:inputTo MqttBroker
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity data (rad/s)."
    , DTDFVocab:fromData AngularVelocityDataTransmitted
    , DTDFVocab:inputTo MqttBroker
]

instance AngularAccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration data (rad/s²)."
    , DTDFVocab:fromData AngularAccelerationDataTransmitted
    , DTDFVocab:inputTo MqttBroker
]

// C10: Simulation friction models
instance SimulinkFrictionlessModel : DTDFVocab:Model [
    base:desc "Simulink model representing frictionless behavior of the first robot axis."
    , DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkCoulombViscousModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Coulomb and viscous friction for the axis."
    , DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkStribeckModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Stribeck friction characteristic."
    , DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkDahlModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Dahl friction model."
    , DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkLuGreModel : DTDFVocab:Model [
    base:desc "Simulink model implementing LuGre friction model."
    , DTDFVocab:inputTo SimulinkEngine
]

// C10: Engineering (SysML) models
instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "SysML block definition diagram describing the structural hierarchy of the first axis, including motor, gearboxes, and sensors."
    , DTDFVocab:inputTo SysMLTool
]

instance SysMLBehaviorModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram modeling the dynamic behavior and ports of the first axis."
    , DTDFVocab:inputTo SysMLTool
]

// C4: Simulated data transmitted
instance SimulatedTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkCoulombViscousModel, SimulinkStribeckModel, SimulinkDahlModel, SimulinkLuGreModel
]

instance SimulatedAngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkCoulombViscousModel, SimulinkStribeckModel, SimulinkDahlModel, SimulinkLuGreModel
]

// C10: Simulated measurement data
instance SimulatedTorqueData : DTDFVocab:Data [
    base:desc "Simulated torque trace generated from friction models."
    , DTDFVocab:fromData SimulatedTorqueDataTransmitted
    , DTDFVocab:inputTo MqttBroker
]

instance SimulatedAngularVelocityData : DTDFVocab:Data [
    base:desc "Simulated angular velocity trace generated from friction models."
    , DTDFVocab:fromData SimulatedAngularVelocityDataTransmitted
    , DTDFVocab:inputTo MqttBroker
]

// C11: Enablers
instance MqttBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker streaming live sensor and derived data to the digital shadow."
    , DTDFVocab:enables RealTimeDashboardVisualization, FrictionIdentificationService, ModelParameterUpdateService, SimulationComparisonService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for friction identification and simulation."
    , DTDFVocab:enables FrictionIdentificationService, SimulationComparisonService
]

instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML modeling tool used to maintain structural and behavioral engineering models."
    , DTDFVocab:enables ModelParameterUpdateService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell providing contextual metadata linking data points to the physical asset."
    , DTDFVocab:enables RealTimeDashboardVisualization, ModelParameterUpdateService
]

// C6: Services
instance RealTimeDashboardVisualization : DTDFVocab:Service [
    base:desc "Real‑time dashboard visualization of sensor data, derived data, and friction trends."
    , DTDFVocab:provides FrictionTrendInsight, ModelDeviationInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous multi‑physics‑aware identification of static, kinetic, and viscous friction parameters."
    , DTDFVocab:provides FrictionParameterInsight, UpdateControllerAction
]

instance ModelParameterUpdateService : DTDFVocab:Service [
    base:desc "Generation of updated friction model parameters for model‑based robot motion control."
    , DTDFVocab:provides ParameterUpdateInsight, UpdateControllerAction
]

instance SimulationComparisonService : DTDFVocab:Service [
    base:desc "Comparison of simulated vs measured torque and velocity data traces."
    , DTDFVocab:provides SimulationComparisonInsight, VisualizeComparisonAction
]

// C17: Insights
instance FrictionTrendInsight : DTDFVocab:Insight [
    base:desc "Operators gain insight into friction trends over time from the dashboard."
]

instance ModelDeviationInsight : DTDFVocab:Insight [
    base:desc "Operators see model deviation insights when simulated data diverges from measurements."
]

instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Identified static, kinetic, and viscous friction parameters are presented as insights."
]

instance ParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight that updated friction parameters have been applied to the robot controller."
]

instance SimulationComparisonInsight : DTDFVocab:Insight [
    base:desc "Insight into differences between simulated and measured torque/velocity traces."
]

// C17: Actions
instance UpdateControllerAction : DTDFVocab:Action [
    base:desc "Update the robot controller with newly identified friction parameters to improve motion accuracy."
    , DTDFVocab:IsAutomatic true
]

instance VisualizeComparisonAction : DTDFVocab:Action [
    base:desc "Display side‑by‑side plots of simulated and measured data traces on the dashboard."
    , DTDFVocab:IsAutomatic false
]

// Environment and component
instance FirstAxisComponent : DTDFVocab:Component [
    base:desc "The first axis of the MABI MAX 100 industrial robot, comprising a permanent‑magnet synchronous motor, gearwheel gearbox and cycloidal gearbox."
]

instance RobotEnvironment : DTDFVocab:Environment [
    base:contains FirstAxisComponent
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time data acquisition and processing during robot operation (live‑data linking)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow composed of Purpose (FrictionDerivation), Asset (MABI robot first axis), Processing components (Simulation_M, Simulation_GW, Simulation_GB) that consume input data traces and produce simulated output traces, linked via the Digital Shadow Reference Model (DataTrace, DataPoint, Source, Model)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational (runtime) stage – the digital shadow is created and used while the robot is running to identify friction and improve control."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each DataPoint to its source and processing component; comparison of simulated friction‑free and friction‑included models with measured data to assess model accuracy; multi‑physics‑aware identification ensures physical relevance of friction parameters."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data from the robot is transmitted to the digital shadow using MQTT messaging protocol; Asset Administration Shells provide standardized interfaces for metadata exchange."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Uses the Asset Administration Shell (AAS) standard for industrial asset representation and SysML as a modeling standard; follows the Digital Shadow Reference Model (DSRM) definition."
]