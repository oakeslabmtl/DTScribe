// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor generating torque for the first axis."
]

instance GearwheelGearbox : DTDFVocab:ActingComponent [
    base:desc "Gearwheel gearbox that transmits torque to the cycloidal gearbox."
]

instance CycloidalGearbox : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gearbox providing final reduction for the first axis."
]

// C3: Physical sensing components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor shaft, providing motor angle."
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder located behind the gearbox, measuring output shaft angle."
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor phase current I_M."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Time‑series of motor encoder angles transmitted via MQTT."
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Time‑series of gearbox encoder angles transmitted via MQTT."
    DTDFVocab:producedFrom GearboxPositionEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Time‑series of motor current I_M transmitted via MQTT."
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C5: Data
instance MotorEncoderData : DTDFVocab:Data [
    base:desc "Raw motor encoder angle data."
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance GearboxEncoderData : DTDFVocab:Data [
    base:desc "Raw gearbox encoder angle data."
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Raw motor current measurement."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Calculated motor torque derived from current and motor parameters."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity computed from encoder position differences."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance AngularAccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration computed from velocity data."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

// C10: Models/Data
instance TorqueCalculationModel : DTDFVocab:Model [
    base:desc "Model converting motor current and motor parameters into torque."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance VelocityDerivationModel : DTDFVocab:Model [
    base:desc "Model deriving angular velocity from encoder position data."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance AccelerationDerivationModel : DTDFVocab:Model [
    base:desc "Model deriving angular acceleration from velocity data."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance FrictionIdentificationModel : DTDFVocab:Model [
    base:desc "Model identifying static, kinetic, and viscous friction parameters from torque and velocity data."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance FrictionFreeSimulationModel : DTDFVocab:Model [
    base:desc "Simulink friction‑free simulation model of the first axis."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Coulomb‑viscous friction."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Stribeck friction characteristics."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Dahl friction dynamics."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "Simulink model implementing LuGre friction formulation."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SysMLFirstAxisModel : DTDFVocab:Model [
    base:desc "SysML engineering model of the first axis encompassing mechanical topology."
    DTDFVocab:inputTo SysMLModelingEnabler
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML tool used for structural modeling of the first axis."
    DTDFVocab:enables DashboardVisualizationService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for executable simulation of friction and motion models."
    DTDFVocab:enables ContinuousFrictionIdentificationService, FrictionParameterGenerationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating live transmission of sensor data as time‑series."
    DTDFVocab:enables DashboardVisualizationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell integrating models and data for standardized interaction."
    DTDFVocab:enables DashboardVisualizationService, ContinuousFrictionIdentificationService, FrictionParameterGenerationService
]

instance WebDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard visualizing measured and simulated data."
    DTDFVocab:enables DashboardVisualizationService
]

// C6: Services
instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Visualization of measured and simulated data on a web dashboard."
    DTDFVocab:provides MeasuredSimulatedDataVisualizationInsight
]

instance ContinuousFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of static, kinetic and viscous friction from live data."
    DTDFVocab:provides FrictionIdentificationInsight
]

instance FrictionParameterGenerationService : DTDFVocab:Service [
    base:desc "Generation of friction model parameters to improve model‑based robot control."
    DTDFVocab:provides FrictionParameterFeedbackInsight, AdjustMotionControlAction
]

// C17: Insights/Actions
instance MeasuredSimulatedDataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight into the correlation between measured sensor data and simulated model outputs."
]

instance FrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Insight about identified friction characteristics (static, kinetic, viscous)."
]

instance FrictionParameterFeedbackInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters are fed back to the robot controller to adjust motion control."
]

instance AdjustMotionControlAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of model‑based motion control using updated friction parameters."
    DTDFVocab:IsAutomatic true
]

// C14: Environment
instance FirstAxisEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotor, GearwheelGearbox, CycloidalGearbox, MotorPositionEncoder, GearboxPositionEncoder, MotorCurrentSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow is a one‑way passive representation and does not send commands back to the robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time/online during robot operation, enabling continuous friction model updates."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A digital shadow composed of Purpose (FrictionDerivation), Asset (Mabi first axis), Sources (sensor channels), Processing components (SimulationM, SimulationGW, SimulationGB), Models (engineering, simulation, data‑calculation), and DataTraces (I_M, r_M, r_G, r_out, and their simulated counterparts)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of each data point to its source and processing model, comparison of simulated friction‑augmented outputs with measured reference data to validate model accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data transmitted via MQTT; integration with Asset Administration Shells for standardized data exchange."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) as a standard representation for the asset and its data; SysML and IEC‑based modeling conventions."
]