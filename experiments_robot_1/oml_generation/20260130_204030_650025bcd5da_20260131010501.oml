// Sensing Component
instance RobotJointPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the joint positions of the six permanent‑magnet synchronous motors on the MABI MAX 100 serial robot."
    DTDFVocab:producedData JointPositionDataTransmitted
]

// Data Transmitted
instance JointPositionDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Transmits joint position data from RobotJointPositionSensor to the digital twin."
    DTDFVocab:producedFrom RobotJointPositionSensor
]

// Data
instance RobotJointPositionData : DTDFVocab:Data [
    base:desc "Joint position data used as input to models and simulation tools."
    DTDFVocab:fromData JointPositionDataTransmitted
    DTDFVocab:inputTo SimulinkTool
]

// Enablers
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML used for modeling structural and functional architectures."
    DTDFVocab:enables JointPositionMonitoringService
]

instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc with automaton extensions for behavior modeling."
    DTDFVocab:enables JointPositionMonitoringService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed behavioral simulation."
    DTDFVocab:enables JointPositionMonitoringService
]

instance CppTool : DTDFVocab:Enabler [
    base:desc "C++ used for code generation."
    DTDFVocab:enables JointPositionMonitoringService
]

instance JavaTool : DTDFVocab:Enabler [
    base:desc "Java used for implementation."
    DTDFVocab:enables JointPositionMonitoringService
]

instance ACMEADLTool : DTDFVocab:Enabler [
    base:desc "ACME ADL for architecture description."
    DTDFVocab:enables JointPositionMonitoringService
]

instance AADLADLTool : DTDFVocab:Enabler [
    base:desc "AADL ADL for system description."
    DTDFVocab:enables JointPositionMonitoringService
]

// Models
instance StructuralModel : DTDFVocab:Model [
    base:desc "Structural architecture modeled using SysML and MontiArc."
    DTDFVocab:inputTo SysMLTool, MontiArcTool
]

instance FunctionalModel : DTDFVocab:Model [
    base:desc "Functional architecture modeled using SysML and MontiArc."
    DTDFVocab:inputTo SysMLTool, MontiArcTool
]

instance BehaviorModel : DTDFVocab:Model [
    base:desc "Behavior modeled using MontiArc Automaton."
    DTDFVocab:inputTo MontiArcTool
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Behavior simulated using Simulink."
    DTDFVocab:inputTo SimulinkTool
]

// Service
instance JointPositionMonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors joint position accuracy by comparing model predictions with sensor data."
    DTDFVocab:provides PositionAccuracyInsight
]

// Insight
instance PositionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Insight into the robot's positioning accuracy, providing deviation metrics."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin, following the reference model, functions as a passive observer and does not generate outbound control commands. Consequently, command types, control message formats, validation, authentication, feedback mechanisms, conflict resolution, and execution confirmation are undefined within this system. Any control action must be addressed by an external layer not part of the twin."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin operates on a real‑time basis, ingesting sensor streams as timestamped time‑series data at the native sampling rates of the physical sensors (on the order of milliseconds). The system processes this data synchronously, with no explicit push‑back to the physical system, thereby avoiding two‑way latency constraints. The temporal granularity is determined by the underlying sensor resolution, and no explicit synchronization frequency or latency thresholds are stipulated in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated through the Digital Shadow Reference Model, comprising four primary component types: Asset Administration Shell (AAS) for semantic representation of the physical asset, Source for input data collection, Processing for real‑time data handling and analytics, and Model for the virtual representation and simulation. These components are integrated via middleware that enables data exchange and functional coordination within the twin architecture."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved using the AAS interoperability standard, enabling semantic alignment with enterprise asset data repositories, and MQTT as the low‑latency publish/subscribe protocol for streaming sensor time‑series. The twin adopts an adapter pattern to map raw sensor data into AAS entities, thereby facilitating horizontal coupling with other Digital Twins and enterprise applications."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The digital twin for the MABI robot “MAX‑100‑2‑25‑P” relies on the robot’s built‑in safety cell to constrain the maximum reachable volume, thereby preventing collisions with personnel or equipment. Statically bounded safety is complemented by runtime checks on joint limits. Digital twin data are streamed from the physical robot to the twin via MQTT, as documented in the robot’s integration guidelines and in the referenced MQTT server implementation (Mosquitto). No explicit encryption, authentication, or access‑control mechanisms are specified in the provided documents. Likewise, no formal risk‑assessment methodology, threat‑mitigation strategy, or fail‑safe system design is described beyond the hardware safety cell and the basic data‑streaming channel.'"
]