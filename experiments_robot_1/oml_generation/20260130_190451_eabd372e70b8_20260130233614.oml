prefix DTDFVocab: http://www.example.org/DTDFVocab
prefix base: http://example.org/base/ 

instance FrictionLossInsight : DTDFVocab:Insight [
    base:desc "Analysis of friction loss relationships to enhance robot motion accuracy"
]

instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Real-time data and performance metrics visualization for user interaction and informed decision-making"
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous multi-physics-aware identification of joint friction to enhance motion accuracy",
    DTDFVocab:provides FrictionLossInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Integrated visualization within unified dashboard for real-time monitoring and analysis",
    DTDFVocab:provides DashboardInsight
]

instance RFLPEnabler : DTDFVocab:Enabler [
    base:desc "RFLP methodology for multi-level abstraction (Requirements, Functions, Logics, Physics)",
    DTDFVocab:enables FrictionIdentificationService
]

instance OOSEMEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for multi-level abstraction",
    DTDFVocab:enables FrictionIdentificationService
]

instance SPESEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for multi-level abstraction",
    DTDFVocab:enables FrictionIdentificationService
]

instance SMArDTEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for multi-level abstraction",
    DTDFVocab:enables FrictionIdentificationService
]

instance SysMLIBDEnabler : DTDFVocab:Enabler [
    base:desc "SysML IBDs for component and connector perspectives",
    DTDFVocab:enables FrictionIdentificationService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME architecture description language for component and connector perspectives",
    DTDFVocab:enables FrictionIdentificationService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL architecture description language for component and connector perspectives",
    DTDFVocab:enables FrictionIdentificationService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc architecture description language for component and connector perspectives",
    DTDFVocab:enables FrictionIdentificationService
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavior modeling",
    DTDFVocab:enables FrictionIdentificationService
]

instance SysMLStateMachineEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 state machines for behavior modeling",
    DTDFVocab:enables FrictionIdentificationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and analysis",
    DTDFVocab:enables FrictionIdentificationService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ general-purpose programming for simulation and analysis",
    DTDFVocab:enables FrictionIdentificationService, DashboardVisualizationService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java general-purpose programming for simulation and analysis",
    DTDFVocab:enables FrictionIdentificationService, DashboardVisualizationService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard interface for visualization and monitoring",
    DTDFVocab:enables DashboardVisualizationService
]

instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input current for MABI MAX 100 robot axis 1",
    DTDFVocab:producedData MABIMAX100Axis1DataStream
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring output angle for MABI MAX 100 robot axis 1",
    DTDFVocab:producedData MABIMAX100Axis1DataStream
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring torque for MABI MAX 100 robot axis 1",
    DTDFVocab:producedData MABIMAX100Axis1DataStream
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring angular velocity for MABI MAX 100 robot axis 1",
    DTDFVocab:producedData MABIMAX100Axis1DataStream
]

instance AccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring acceleration for MABI MAX 100 robot axis 1",
    DTDFVocab:producedData MABIMAX100Axis1DataStream
]

instance MABIMAX100Axis1DataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor, OutputAngleSensor, TorqueSensor, AngularVelocitySensor, AccelerationSensor
]

instance MABIMAX100Axis1SensorData : DTDFVocab:Data [
    base:desc "Real-time sensor data from MABI MAX 100 robot axis 1 transmitted via MQTT",
    DTDFVocab:fromData MABIMAX100Axis1DataStream,
    DTDFVocab:inputTo MontiArcAutomatonEnabler, SimulinkEnabler, CppEnabler, JavaEnabler
]

instance RFLPModel : DTDFVocab:Model [
    base:desc "RFLP methodology model for requirements, functions, logics, physics layers",
    DTDFVocab:inputTo RFLPEnabler
]

instance OOSEMModel : DTDFVocab:Model [
    base:desc "OOSEM methodology model for object-oriented system engineering",
    DTDFVocab:inputTo OOSEMEnabler
]

instance SPESModel : DTDFVocab:Model [
    base:desc "SPES methodology model for system engineering processes",
    DTDFVocab:inputTo SPESEnabler
]

instance SMArDTModel : DTDFVocab:Model [
    base:desc "SMArDT methodology model for system architecture modeling",
    DTDFVocab:inputTo SMArDTEnabler
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML IBD model for component and connector perspectives",
    DTDFVocab:inputTo SysMLIBDEnabler
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME architecture description language model",
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL architecture description language model",
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description language model",
    DTDFVocab:inputTo MontiArcEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model for behavior description",
    DTDFVocab:inputTo MontiArcAutomatonEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model for behavior",
    DTDFVocab:inputTo SysMLStateMachineEnabler
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for simulation",
    DTDFVocab:inputTo SimulinkEnabler
]

instance CppModel : DTDFVocab:Model [
    base:desc "C++ general-purpose programming model",
    DTDFVocab:inputTo CppEnabler
]

instance JavaModel : DTDFVocab:Model [
    base:desc "Java general-purpose programming model",
    DTDFVocab:inputTo JavaEnabler
]

instance RobotAxis1 : DTDFVocab:Component [
    base:desc "First vertical robot axis at the base of MABI MAX 100 serial robot"
]

instance MABIMAX100System : DTDFVocab:Environment [
    base:desc "MABI MAX 100 serial robot system",
    base:contains RobotAxis1
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT communication protocol is used for sensor data streaming; network topology, bandwidth, latency requirements, reliability mechanisms, and security protocols are not detailed in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with Industry standards including Asset Administration Shells (AAS) for asset information modeling, SysML for model-based systems engineering, and MQTT protocol for lightweight data streaming, ensuring interoperability and standardized communication across digital twin components."
]