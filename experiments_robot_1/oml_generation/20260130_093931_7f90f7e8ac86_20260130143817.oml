// C3: Physical Sensing Components
instance TelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Automated sensor collecting contextual data traces from physical objects as defined in the Digital Shadow Reference Model, transmitting real-time or near-real-time measurement data including telemetry, environmental metrics, and operational logs."
]

instance OperationalLogSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing system operational logs and event-based data for contextual abstraction and purpose-driven analysis within the Digital Twin system."
]

instance EnvironmentalParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring environmental parameters (e.g., temperature, pressure) with high-frequency sampling for real-time monitoring and system state tracking."
]

// C4: Physical-to-Virtual Interaction
instance RawSensorDataTraces : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TelemetrySensor, OperationalLogSensor, EnvironmentalParameterSensor
    base:desc "Contextual data traces aggregated from physical sensors including raw telemetry, operational logs, and environmental parameters transmitted via standardized protocols like MQTT, OPC UA, or RESTful APIs."
]

instance SensorTelemetryStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalParameterSensor
    base:desc "High-frequency data stream (milliseconds to seconds) of environmental parameters and critical system metrics transmitted for real-time monitoring and analysis."
]

// C10: Models/Data
instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) representing the functional architecture of the system, capturing components, connectors, and interfaces for behavioral and structural modeling."
    DTDFVocab:inputTo SysMLModelingEnabler, MontiArcCompositionEnabler
]

instance AADLComponentConnectorModel : DTDFVocab:Model [
    base:desc "AADL-based component-connector model specifying system components, interfaces, and composition for critical systems engineering with formalized architecture descriptions."
    DTDFVocab:inputTo AADLModelingEnabler
]

instance StateMachineBehaviorModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model capturing dynamic system behavior through automata-based simulations for behavioral validation and predictive analytics."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance DigitalShadowDataAggregation : DTDFVocab:Data [
    base:desc "Structured aggregation of raw sensor data traces into purpose-driven digital shadow representations for monitoring, analytics, and decision support."
    DTDFVocab:fromData RawSensorDataTraces
    DTDFVocab:inputTo DataProcessingEnabler, VisualizationEnabler
]

instance RealTimeTelemetryData : DTDFVocab:Data [
    base:desc "Low-latency processed data stream derived from high-frequency sensor telemetry, enabling real-time system state tracking and contextual data processing."
    DTDFVocab:fromData SensorTelemetryStream
    DTDFVocab:inputTo ControlAlgorithmEnabler, OptimizationEnabler
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based modeling platform (e.g., Cameo Systems Modeler) enabling structural and behavioral modeling across requirements, functional, logical, and physical layers."
    DTDFVocab:enables SysMLMonitoringService, SysMLOptimizationService
]

instance AADLModelingEnabler : DTDFVocab:Enabler [
    base:desc "AADL-compatible modeling framework for component-based architecture specification, supporting formal validation and cross-tool consistency checks."
    DTDFVocab:enables ArchitectureValidationService
]

instance MontiArcCompositionEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc-based toolchain for component-based modeling with automata support, enabling compositional analysis and behavioral simulation."
    DTDFVocab:enables BehavioralSimulationService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink platform for dynamic system simulation, enabling real-time analytics, scenario testing, and closed-loop control integration."
    DTDFVocab:enables RealTimeAnalyticsService, ScenarioSimulationService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Real-time data processing framework aggregating and abstracting sensor data traces into meaningful KPIs, anomalies, and contextual insights."
    DTDFVocab:enables ContextualDataProcessingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Interactive visualization platform (e.g., Tableau, Power BI) providing multi-perspective dashboards for stakeholders across requirements, functional, and physical layers."
    DTDFVocab:enables MultiPerspectiveDashboardService
]

instance ControlAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Embedded control algorithm framework integrating simulation-driven logic for closed-loop automation and real-time system adjustments."
    DTDFVocab:enables ClosedLoopAutomationService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Performance optimization engine analyzing logical/functional architectures to tune system configurations via simulation-driven analysis."
    DTDFVocab:enables PerformanceTuningService
]

// C6: Services
instance SysMLMonitoringService : DTDFVocab:Service [
    base:desc "Real-time state tracking service correlating physical and digital states via SysML-based models and simulation tools for system monitoring."
    DTDFVocab:provides DigitalStateTrackingInsight, ContextualDataAbstractionInsight
]

instance SysMLOptimizationService : DTDFVocab:Service [
    base:desc "Performance tuning service analyzing functional/logical architectures to optimize resource allocation and workflow efficiency."
    DTDFVocab:provides ConfigurationOptimizationInsight, EfficiencyAnalysisInsight
]

instance BehavioralSimulationService : DTDFVocab:Service [
    base:desc "Behavioral modeling service using automata-based simulations to forecast system behavior and test hypothetical conditions."
    DTDFVocab:provides PrognosticAnalyticsInsight, ScenarioSimulationInsight
]

instance RealTimeAnalyticsService : DTDFVocab:Service [
    base:desc "Real-time analytics service processing telemetry streams to generate actionable insights for decision-making."
    DTDFVocab:provides AnomalyDetectionInsight, KPIGenerationInsight
]

instance ContextualDataProcessingService : DTDFVocab:Service [
    base:desc "Contextual data processing service aggregating raw sensor traces into structured representations for purpose-driven analysis."
    DTDFVocab:provides DataAbstractionInsight
]

instance MultiPerspectiveDashboardService : DTDFVocab:Service [
    base:desc "Interactive visualization service providing hierarchical dashboards for diverse stakeholder perspectives across modeling layers."
    DTDFVocab:provides StakeholderVisualizationInsight, LayeredAbstractionInsight
]

instance ClosedLoopAutomationService : DTDFVocab:Service [
    base:desc "Closed-loop control service translating digital insights into actionable commands for physical system adjustments."
    DTDFVocab:provides SystemAdjustmentAction
]

instance ScenarioSimulationService : DTDFVocab:Service [
    base:desc "What-if analysis service enabling scenario testing via simulation tools to evaluate hypothetical conditions."
    DTDFVocab:provides ScenarioTestingInsight, RiskAssessmentInsight
]

