// C3: Physical sensing components
instance PositionEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Position encoder sensor capturing shaft position data from the physical asset."
    DTDFVocab:producedData PositionTelemetryMQTT
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring electrical current flowing to the motor."
    DTDFVocab:producedData CurrentTelemetryMQTT
]

// C4: Physical-to-virtual interaction
instance PositionTelemetryMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionEncoderSensor
]

instance CurrentTelemetryMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Models/Data
instance PositionTelemetryData : DTDFVocab:Data [
    base:desc "Time‑series numeric data stream of shaft position aggregated from position encoder."
    DTDFVocab:fromData PositionTelemetryMQTT
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

instance CurrentTelemetryData : DTDFVocab:Data [
    base:desc "Time‑series numeric data stream of motor current aggregated from motor current sensor."
    DTDFVocab:fromData CurrentTelemetryMQTT
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

instance FrictionSimulinkModel : DTDFVocab:Model [
    base:desc "White‑box MATLAB Simulink friction model computing shaft first‑axis friction in real‑time."
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

// C11: Enablers
instance SimulinkExecutionEnvironment : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink execution environment that runs the friction model and processes sensor telemetry."
    DTDFVocab:enables FrictionAnalysisService
]

// C6: Services
instance FrictionAnalysisService : DTDFVocab:Service [
    base:desc "Service that analyzes virtual friction output and streams results to the dashboard."
    DTDFVocab:provides RealTimeFrictionInsight
]

// C17: Insights/Actions
instance RealTimeFrictionInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight of shaft first‑axis friction behavior derived from the Simulink model."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical communication layer relies on MQTT to stream time‑series sensor data from the physical system to the digital representation. No additional topology, bandwidth, or security details are specified in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin model adheres to Model‑Based Systems Engineering practices, employing SysML v1.7 for requirements, functional and logical architecture depiction and state‑machine modelling. It integrates with architecture description languages such as MontiArc and ACME, and executes simulations via MATLAB‑Simulink. The twin’s design conforms to the Digital Shadow reference model’s UML class diagram, ensuring alignment with established manufacturing modelling conventions."
]