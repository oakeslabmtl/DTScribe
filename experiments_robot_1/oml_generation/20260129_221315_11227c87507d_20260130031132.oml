// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in turbine blade, capturing temperature at 1kHz."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Pressure sensor mounted on turbine casing, sampling at 500Hz."
    DTDFVocab:producedData PressureDataTransmitted
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Vibration accelerometer placed on rotor housing, measuring at 10kHz."
    DTDFVocab:producedData VibrationDataTransmitted
]

// C4: Data transmitted from sensing components
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Temperature data transmitted over OPC-UA protocol."
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Pressure data transmitted over OPC-UA protocol."
    DTDFVocab:producedFrom PressureSensor
]

instance VibrationDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Vibration data transmitted over OPC-UA protocol."
    DTDFVocab:producedFrom VibrationSensor
]

// C10: Data captured from transmitted streams
instance TemperatureData : DTDFVocab:Data [
    base:desc "Raw temperature readings from live telemetry feed."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo InfluxDBTimeSeriesStore
]

instance PressureData : DTDFVocab:Data [
    base:desc "Raw pressure readings from live telemetry feed."
    DTDFVocab:fromData PressureDataTransmitted
    DTDFVocab:inputTo InfluxDBTimeSeriesStore
]

instance VibrationData : DTDFVocab:Data [
    base:desc "Raw vibration measurements from live telemetry feed."
    DTDFVocab:fromData VibrationDataTransmitted
    DTDFVocab:inputTo InfluxDBTimeSeriesStore
]

// C11: Enablers for data aggregation
instance InfluxDBTimeSeriesStore : DTDFVocab:Enabler [
    base:desc "InfluxDB time-series database aggregating sensor streams."
    DTDFVocab:enables TemperatureAnalyticsService, PressureAnalyticsService, VibrationAnalyticsService
]

// C6: Services performing analytics
instance TemperatureAnalyticsService : DTDFVocab:Service [
    base:desc "Aggregates temperature series and detects anomalies."
    DTDFVocab:provides TemperatureAnomalyDetectionInsight
]

instance PressureAnalyticsService : DTDFVocab:Service [
    base:desc "Aggregates pressure series and detects anomalies."
    DTDFVocab:provides PressureAnomalyDetectionInsight
]

instance VibrationAnalyticsService : DTDFVocab:Service [
    base:desc "Aggregates vibration series and detects anomalies."
    DTDFVocab:provides VibrationAnomalyDetectionInsight
]

// C17: Insights derived from analytics
instance TemperatureAnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight identifying temperature spikes exceeding threshold."
]

instance PressureAnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight identifying pressure transients beyond acceptable limits."
]

instance VibrationAnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight identifying abnormal vibration signatures."
]

// C10: Models and their supporting enablers
instance GeometricCADModel : DTDFVocab:Model [
    base:desc "Geometric representation of turbine structures exported to STEP and imported into SysML Block diagrams."
    DTDFVocab:inputTo CADModelEnabler
]

instance StateMachineBehaviorModel : DTDFVocab:Model [
    base:desc "SysML state machine sequence describing turbine operational modes."
    DTDFVocab:inputTo BehaviorModelEnabler
]

instance SimulinkTransferFunctionModel : DTDFVocab:Model [
    base:desc "Analytical model using Simulink transfer-function blocks and MATLAB scripts."
    DTDFVocab:inputTo AnalyticalModelEnabler
]

// C11: Enablers for model execution
instance CADModelEnabler : DTDFVocab:Enabler [
    base:desc "Enables conversion of CAD geometry to SysML block diagram."
    DTDFVocab:enables CADComputationService
]

instance BehaviorModelEnabler : DTDFVocab:Enabler [
    base:desc "Orchestrates MontiArc automaton simulation."
    DTDFVocab:enables BehaviorSimulationService
]

instance AnalyticalModelEnabler : DTDFVocab:Enabler [
    base:desc "Executes Simulink model within MATLAB environment."
    DTDFVocab:enables AnalyticalExecutionService
]

// C6: Services for model validation
instance CADComputationService : DTDFVocab:Service [
    base:desc "Computes spatial relationships and mass properties from CAD geometry."
    DTDFVocab:provides GeometricModelInsight
]

instance BehaviorSimulationService : DTDFVocab:Service [
    base:desc "Runs behavior simulation to validate control logic via MontiArc automaton."
    DTDFVocab:provides BehaviorInsight
]

instance AnalyticalExecutionService : DTDFVocab:Service [
    base:desc "Performs numerical analysis producing frequency response from Simulink transfer-function."
    DTDFVocab:provides AnalyticalInsight
]

// C17: Insights from model execution
instance GeometricModelInsight : DTDFVocab:Insight [
    base:desc "Insight on mass centroids and volumetric calculations of turbine components."
]

instance BehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight on state transitions, control strategy effectiveness, and safety limits."
]

instance AnalyticalInsight : DTDFVocab:Insight [
    base:desc "Insight on system stability, dynamic response, and resonance frequencies."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "In the described MBSE approach, a Digital Twin is engineered through successive modeling layers: a Requirements layer capturing system constraints, a Functional Architecture layer defining capabilities, a Logical Architecture layer specifying interactions, and a Product/Technical layer detailing implementation artifacts. SysML is employed to construct block definitions and interfaces, while architecture description languages such as ACME, AADL, and MontiArc are used for component‑connector modeling. Transition between stages is coordinated by model integration tools and MBSE methodologies (e.g., SMArDT, SPES), with lifecycle governance maintained through version control of the models and continuous validation via simulation tools such as MathWorks Simulink."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system utilizes SysML v1.7 as a standardized modeling language, and employs architecture description languages such as ACME, AADL, and MontiArc, all of which are widely adopted modeling standards within systems engineering. No explicit certification or compliance framework is mentioned within the provided documents."
]