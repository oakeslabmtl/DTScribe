// ------------------------------------------------
// C3: Physical sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Absolute position encoder mounted on the motor shaft of the first axis, providing position and derived angular velocity."
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Absolute position encoder mounted behind the gearbox of the first axis, supplying gearbox output position and derived angular velocity."
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring the motor input current I_M of the first axis."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// ------------------------------------------------
// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance DerivedTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder, MotorCurrentSensor
]

instance DerivedVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder, GearboxEncoder
]

// ------------------------------------------------
// C10: Data (DataTraces) created from transmitted streams
instance PositionDataTrace : DTDFVocab:Data [
    base:desc "Time‑series of measured position values from MotorEncoder."
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo DataProcessingEngine
]

instance VelocityDataTrace : DTDFVocab:Data [
    base:desc "Time‑series of measured angular velocity derived from MotorEncoder and GearboxEncoder."
    DTDFVocab:fromData DerivedVelocityDataTransmitted
    DTDFVocab:inputTo DataProcessingEngine
]

instance CurrentDataTrace : DTDFVocab:Data [
    base:desc "Time‑series of measured motor current I_M."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo DataProcessingEngine
]

instance TorqueDataTrace : DTDFVocab:Data [
    base:desc "Time‑series of torque computed from current and position data (derived on the digital twin)."
    DTDFVocab:fromData DerivedTorqueDataTransmitted
    DTDFVocab:inputTo DataProcessingEngine
]

// ------------------------------------------------
// C10: Models
instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "SysML block‑definition and internal‑block diagrams describing the structural hierarchy of the first vertical axis."
    DTDFVocab:inputTo SysMLModelingTool
]

instance SimulinkFrictionlessModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the first axis without friction."
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkCoulombViscousModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Coulomb‑viscous friction for the first axis."
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkStribeckModel : DTDFVocab:Model [
    base:desc "Simulink model implementing the Stribeck friction characteristic."
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkDahlModel : DTDFVocab:Model [
    base:desc "Simulink model implementing the Dahl friction model."
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance SimulinkLuGreModel : DTDFVocab:Model [
    base:desc "Simulink model implementing the LuGre friction model."
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance DataCalculationTorqueModel : DTDFVocab:Model [
    base:desc "Data‑calculation model that derives torque from measured current and position data."
    DTDFVocab:inputTo DataProcessingEngine
]

instance DataCalculationVelocityModel : DTDFVocab:Model [
    base:desc "Data‑calculation model that derives angular velocity from position encoder data."
    DTDFVocab:inputTo DataProcessingEngine
]

// ------------------------------------------------
// C11: Enablers (tools & platforms)
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker used for streaming live sensor data (current, angle, derived torque, angular velocity) from the robot to the digital shadow."
    DTDFVocab:enables RealTimeMonitoringService, FrictionIdentificationService, FrictionParameterFeedbackService
]

instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for running friction models."
    DTDFVocab:enables FrictionIdentificationService
]

instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML modeling tool used to maintain the structural system model of the first axis."
    DTDFVocab:enables RealTimeMonitoringService
]

instance DataProcessingEngine : DTDFVocab:Enabler [
    base:desc "Data processing engine (MATLAB scripts) that consumes DataTraces and supplies parameters to services."
    DTDFVocab:enables FrictionIdentificationService, FrictionParameterFeedbackService
]

instance VisualizationDashboard : DTDFVocab:Enabler [
    base:desc "Integrated visualization dashboard for real‑time monitoring and interaction with the digital twin."
    DTDFVocab:enables RealTimeMonitoringService
]

// ------------------------------------------------
// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Integrated visualization dashboard for real‑time monitoring of the first axis."
    DTDFVocab:provides MotionStatusInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Friction identification using combined white‑box and black‑box Simulink models to extract static, kinetic and viscous parameters."
    DTDFVocab:provides FrictionParameterExtractionInsight
]

instance FrictionParameterFeedbackService : DTDFVocab:Service [
    base:desc "Feedback of derived friction parameters to the robot controller to improve motion control accuracy."
    DTDFVocab:provides ControllerParameterUpdateAction
]

// ------------------------------------------------
// C17: Insights / Actions
instance MotionStatusInsight : DTDFVocab:Insight [
    base:desc "Current position, velocity and torque status of the first axis as visualized on the dashboard."
]

instance FrictionParameterExtractionInsight : DTDFVocab:Insight [
    base:desc "Extraction of static, kinetic and viscous friction parameters from simulation and measurement data."
]

instance ControllerParameterUpdateAction : DTDFVocab:Action [
    base:desc "Automatic update of robot controller parameters with newly identified friction values."
    DTDFVocab:IsAutomatic true
]

// ------------------------------------------------
// C9: Environment & Components (system under study)
instance FirstAxisEnvironment : DTDFVocab:Environment [
    base:contains FirstAxisMotor, FirstAxisGearbox, FirstAxisCycloidalGearbox
]

instance FirstAxisMotor : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor of the first vertical axis."
]

instance FirstAxisGearbox : DTDFVocab:Component [
    base:desc "Gear transmission preceding the cycloidal gearbox."
]

instance FirstAxisCycloidalGearbox : DTDFVocab:Component [
    base:desc "Cycloidal gearbox driving the robot's first vertical axis."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time data acquisition and processing during robot operation, enabling online identification of friction models."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow consisting of a Purpose (FrictionDerivation), Asset (MABI robot first axis), Sources (sensor channels), Processing components (simulation models), Models (engineering, simulation, data‑calculation), and DataTraces (measured and simulated values) instantiated according to the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated stage – the digital shadow is created and updated while the robot is in service to support runtime friction identification and control refinement."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each DataTrace to its generating Processing component and source, comparison of simulated friction‑free data with measured data to validate friction models, and continuous re‑identification to capture wear, temperature, and load variations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the physical robot to the digital shadow using the MQTT protocol over the plant network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) as an industry standard for asset representation, and SysML as a standardized modeling language; data exchange via MQTT follows common IoT messaging standards."
]