prefix base: http://www.ontohub.org/oml/base#
prefix DTDFVocab: http://www.example.org/dtdf#
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor for physical system data traces",
    DTDFVocab:producedData TemperatureDataTrace
]
instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Pressure sensor for physical system data traces",
    DTDFVocab:producedData PressureDataTrace
]
instance TemperatureDataTrace : DTDFVocab:DataTransmitted [
    base:desc "Raw temperature data traces from physical system",
    DTDFVocab:producedFrom TemperatureSensor
]
instance PressureDataTrace : DTDFVocab:DataTransmitted [
    base:desc "Raw pressure data traces from physical system",
    DTDFVocab:producedFrom PressureSensor
]
instance AggregatedContextualData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces from physical systems integrating heterogeneous tools and stakeholder perspectives",
    DTDFVocab:fromData TemperatureDataTrace, PressureDataTrace
    DTDFVocab:inputTo SysMLTool, SimulinkTool, CPlusPlusTool, JavaTool
]
instance RequirementsModel : DTDFVocab:Model [
    base:desc "SysML model for requirements specification",
    DTDFVocab:inputTo SysMLTool
]
instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model for functional architecture",
    DTDFVocab:inputTo SysMLTool
]
instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model for logical architecture",
    DTDFVocab:inputTo SysMLTool
]
instance ProductTechnicalLayerModel : DTDFVocab:Model [
    base:desc "SysML model for product/technical layer",
    DTDFVocab:inputTo SysMLTool
]
instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram for component-connectors and interfaces",
    DTDFVocab:inputTo SysMLTool
]
instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language for component-connectors and interfaces",
    DTDFVocab:inputTo ACMETool
]
instance AADLModel : DTDFVocab:Model [
    base:desc "AADL Architecture Description Language for component-connectors and interfaces",
    DTDFVocab:inputTo AADLTool
]
instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc for component-connectors and interfaces",
    DTDFVocab:inputTo MontiArcTool
]
instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling",
    DTDFVocab:inputTo MontiArcTool
]
instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machine for behavioral modeling",
    DTDFVocab:inputTo SysMLTool
]
instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink for analytical simulations",
    DTDFVocab:inputTo SimulinkTool
]
instance CPlusPlusModel : DTDFVocab:Model [
    base:desc "C++ code for detailed behavior modeling and implementation",
    DTDFVocab:inputTo CPlusPlusTool
]
instance JavaModel : DTDFVocab:Model [
    base:desc "Java code for detailed behavior modeling and implementation",
    DTDFVocab:inputTo JavaTool
]
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering (MBSE) tool using SysML for systems modeling across abstraction levels",
    DTDFVocab:enables SystemModelingService
]
instance ACMETool : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language tool for component & connector-based architecture descriptions",
    DTDFVocab:enables ArchitectureDescriptionService
]
instance AADLTool : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language tool for component & connector-based architecture descriptions",
    DTDFVocab:enables ArchitectureDescriptionService
]
instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc for component-connectors and interfaces and behavioral modeling",
    DTDFVocab:enables ArchitectureDescriptionService
]
instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for analytical simulations and detailed behavior modeling",
    DTDFVocab:enables SimulationService
]
instance CPlusPlusTool : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior modeling and implementation",
    DTDFVocab:enables ImplementationService
]
instance JavaTool : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior modeling and implementation",
    DTDFVocab:enables ImplementationService
]
instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP methodology for complexity management in systems engineering",
    DTDFVocab:enables ComplexityManagementService
]
instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for complexity management in systems engineering",
    DTDFVocab:enables ComplexityManagementService
]
instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for complexity management in systems engineering",
    DTDFVocab:enables ComplexityManagementService
]
instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for complexity management in systems engineering",
    DTDFVocab:enables ComplexityManagementService
]
instance SystemModelingService : DTDFVocab:Service [
    base:desc "Service for system modeling using SysML",
    DTDFVocab:provides RequirementsInsight
]
instance ArchitectureDescriptionService : DTDFVocab:Service [
    base:desc "Service for architecture description using ADLs",
    DTDFVocab:provides ArchitectureInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Service for analytical simulations",
    DTDFVocab:provides SimulationInsight
]
instance ImplementationService : DTDFVocab:Service [
    base:desc "Service for implementation using programming languages",
    DTDFVocab:provides ImplementationInsight
]
instance ComplexityManagementService : DTDFVocab:Service [
    base:desc "Service for complexity management using methodologies",
    DTDFVocab:provides ComplexityInsight
]
instance RequirementsInsight : DTDFVocab:Insight [
    base:desc "Insight for requirements specification and validation"
]
instance ArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight for architecture description and analysis"
]
instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight for simulation results and analysis"
]
instance ImplementationInsight : DTDFVocab:Insight [
    base:desc "Insight for implementation correctness and performance"
]
instance ComplexityInsight : DTDFVocab:Insight [
    base:desc "Insight for system complexity management"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with industry standards such as SysML [17], AADL [24], ACME [23], and MontiArc [25], [26], where SysML IBDs describe component interfaces and connections, and methodologies like RFLP, OOSEM, SPES, and SMArDT handle complexity across abstraction levels (requirements, functional, logical, product/technical) to ensure interoperability among heterogeneous stakeholders [31]."
]