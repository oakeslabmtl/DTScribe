// C3: Physical sensing components // Return code: 1 | Stderr:
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution rotary encoder mounted on motor shaft of the first rotary axis"
    DTDFVocab:producedData MotorEncoderData
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution rotary encoder mounted after the gearbox in the first rotary axis"
    DTDFVocab:producedData GearboxEncoderData
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor input current I_M for the first rotary axis"
    DTDFVocab:producedData MotorCurrentData
]

instance AxisAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Output angle sensor capturing the output angle of the first rotary axis"
    DTDFVocab:producedData AxisAngleData
]

// C4: Physical-to-virtual interaction
instance MotorEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance AxisAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AxisAngleSensor
]

// C10: Models/Data
instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque τ using dynamics equations from motor current I_M"
    DTDFVocab:inputTo ProcessComponentEnabler, AASEnabler
    DTDFVocab:fromData MotorCurrentData
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω computed from the output angle sensor"
    DTDFVocab:inputTo ProcessComponentEnabler, AASEnabler
    DTDFVocab:fromData AxisAngleData
]

instance SysMLMotorStructureModel : DTDFVocab:Model [
    base:desc "SysML BDD/IBD structural model of the permanent‑magnet synchronous motor in the first axis"
    DTDFVocab:inputTo SysMLArchitectureEnabler
]

instance SysMLGearboxStructureModel : DTDFVocab:Model [
    base:desc "SysML BDD/IBD model of the gearwheel and cycloidal gearbox pair in first axis"
    DTDFVocab:inputTo SysMLArchitectureEnabler
] // Fixed reference to SysMLArchitectureEnabler

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "Simulink executable model of motor dynamics for continuous friction estimation"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "Simulink model of gearbox dynamics for friction identification"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SimulinkSystemModel : DTDFVocab:Model [
    base:desc "Integrated Simulink model of motor, gearbox, and encoder outputs for the first axis"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance DataCalculationDynamicsModel : DTDFVocab:Model [
    base:desc "Data calculation model deriving torque and angular velocity from sensor data"
    DTDFVocab:inputTo ProcessComponentEnabler
]

// C11: Enablers
instance SysMLArchitectureEnabler : DTDFVocab:Enabler [
    base:desc "SysML engineering model enabler for system architecture of the first rotary axis"
    DTDFVocab:enables ModelIntegrationService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulink executable simulation enabler for friction estimation and model integration"
    DTDFVocab:enables FrictionIdentificationService, ModelIntegrationService
]

instance MQTTStreamingEnabler : DTDFVocab:Enabler [
    base:desc "MQTT real‑time data streaming enabler for sensor time‑series"
    DTDFVocab:enables FrictionIdentificationService
]

instance DashboardUIEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard UI enabler for real‑time visualization of friction insights"
    DTDFVocab:enables DashboardVisualizationService
]

instance ProcessComponentEnabler : DTDFVocab:Enabler [
    base:desc "Process component enabler for data transformation, traceability, and friction identification"
    DTDFVocab:enables FrictionIdentificationService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell enabler for digital representation and interoperability"
    DTDFVocab:enables DashboardVisualizationService, FrictionIdentificationService, ModelIntegrationService, DiagnosticInsightsService
]

// C6: Services
instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time dashboard service visualizing friction parameters, trends, and maintenance decisions"
    DTDFVocab:provides FrictionParametersInsight, FrictionLossTrendInsight, MaintenanceDecisionInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Friction identification service performing continuous estimation of static, kinetic, viscous, Stribeck, Dahl, and LuGre models"
    DTDFVocab:provides FrictionParametersInsight, FrictionLossTrendInsight, UpdateRobotControlAlgorithmAction
]

instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Model integration service combining engineering, data calculation, and simulation models for a cohesive digital twin"
]

instance DiagnosticInsightsService : DTDFVocab:Service [
    base:desc "Diagnostic insights service providing maintenance and tool change recommendations"
    DTDFVocab:provides MaintenanceDecisionInsight
]

// C17: Insights/Actions
instance FrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Derived static, kinetic, and viscous friction parameters used to update robot control algorithm"
]

instance FrictionLossTrendInsight : DTDFVocab:Insight [
    base:desc "Friction loss trend information informing maintenance and tool change decisions"
]

instance MaintenanceDecisionInsight : DTDFVocab:Insight [
    base:desc "Maintenance and tool change recommendations based on friction loss analysis"
]

instance UpdateRobotControlAlgorithmAction : DTDFVocab:Action [
    base:desc "Automated update of robot control algorithm based on newly identified friction parameters"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time data acquisition and processing; synchronization between live sensor data and simulation outputs at the sensor sample rate (not explicitly specified but implied to be real‑time)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated pipeline: PT sensor data ➜ MQTT data feed ➜ processing component (consumes sensor traces, executes simulation and data‑calculation models) ➜ generates output data traces and aggregates per the Digital Shadow Reference Model ➜ unified dashboard visualisation; all components linked via AAS interfaces."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital shadow represents the robot in the operated phase; the twin is updated continuously during robot operation and reflects as-operating conditions rather than ideal design or manufactured state."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of each data point to its source trace, processing component and model; use of executable simulation models ensures reproducibility; continuous identification of friction models enables validation against live measurements; no explicit error statistics reported."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol over TCP/IP for real‑time sensor streaming; Asset Administration Shells provide REST‑based interfaces for accessing engineering models and data traces."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML (v1.7/IBD), Asset Administration Shell Specification (ISO 19440), and standard engineering model definitions; UML class diagrams for Digital Shadow Reference Model."
]