// C3: Physical sensing component
instance PhysicalAssetContextCollector : DTDFVocab:SensingComponent [
    base:desc "Collects contextual data traces from the physical asset to build the digital shadow as described in the physical‑to‑virtual interaction characteristic."
    DTDFVocab:producedData DigitalShadowTrace
]

// C4: Data transmitted (physical‑to‑virtual)
instance DigitalShadowTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalAssetContextCollector
]

// C10: Data
instance AggregatedContextualData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data trace that serves as input to both white‑box simulation models and black‑box data‑driven models."
    DTDFVocab:fromData DigitalShadowTrace
    DTDFVocab:inputTo TwinProcessingComponent
]

// C10: Models
instance SysMLArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model capturing structural and architectural information of the digital twin constellation."
    DTDFVocab:inputTo TwinProcessingComponent
]

instance ACMEComponentModel : DTDFVocab:Model [
    base:desc "ACME ADL component‑connector description used to represent the system architecture."
    DTDFVocab:inputTo TwinProcessingComponent
]

instance AADLComponentModel : DTDFVocab:Model [
    base:desc "AADL model describing components, interfaces and timing constraints."
    DTDFVocab:inputTo TwinProcessingComponent
]

instance MontiArcArchitectureModel : DTDFVocab:Model [
    base:desc "MontiArc ADL model defining component and connector composition."
    DTDFVocab:inputTo TwinProcessingComponent
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "White‑box physics‑based dynamic simulation model implemented in MATLAB‑Simulink."
    DTDFVocab:inputTo TwinProcessingComponent
]

instance MachineLearningFrictionModel : DTDFVocab:Model [
    base:desc "Black‑box machine‑learning model for nonlinear friction effects."
    DTDFVocab:inputTo TwinProcessingComponent
]

instance ProbabilisticLatentVariableModel : DTDFVocab:Model [
    base:desc "Probabilistic latent‑variable model used for data‑driven inference within the twin."
    DTDFVocab:inputTo TwinProcessingComponent
]

// C11: Enabler (Processing component)
instance TwinProcessingComponent : DTDFVocab:Enabler [
    base:desc "Processing component that consumes input data traces and applies data‑calculation or simulation models to generate output traces (knowledge base) as defined in the insights and decision‑making characteristic."
    DTDFVocab:enables AbstractionComputationService, PredictionService
]

// C6: Services
instance AbstractionComputationService : DTDFVocab:Service [
    base:desc "Computes higher‑level abstractions from raw contextual data using the set of MBSE models."
    DTDFVocab:provides HigherLevelAbstractionInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Provides simulation‑based predictions of future system states."
    DTDFVocab:provides SimulationBasedPredictionInsight
]

// C17: Insights
instance HigherLevelAbstractionInsight : DTDFVocab:Insight [
    base:desc "Insight delivering higher‑level abstraction of the physical asset derived from aggregated contextual data."
]

instance SimulationBasedPredictionInsight : DTDFVocab:Insight [
    base:desc "Insight delivering prediction of future behavior based on simulation models such as Simulink."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The documents describe a model‑based systems‑engineering (MBSE) lifecycle that proceeds through hierarchical abstraction levels: (1) requirements, (2) functional architecture, (3) logical architecture, and (4) product/technical layer. At each level the system is represented by different model types – SysML requirement and block diagrams for the requirements stage, SysML internal block diagrams (IBDs) or architecture description languages (e.g., ACME, AADL, MontiArc) for functional and logical architectures, and concrete engineering or simulation models (e.g., Simulink, C++/Java code) for the product layer. Transition between stages is managed by a conformance relation defined in the Digital Shadow Reference Model: a concrete realization (concretization) maps reference concepts to concrete classes and associations, preserving traceability via the “originates‑from” association. Governance is implied by the reference‑model approach, which mandates that every concrete model must conform to the reference model’s structure and semantics."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is tied to the correctness of the underlying architectural and behavioral models as well as the transformations that map high‑level MBSE artifacts (e.g., SysML) to executable simulation models (e.g., Simulink). The documents emphasize traceability of model elements and verification of model transformations to ensure that the digital shadow reflects the intended physical behavior. No explicit uncertainty quantification, error‑detection mechanisms, or quality‑assurance procedures are described beyond the general requirement for correct transformations and traceability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange between the physical and virtual components is performed using MQTT (Message Queuing Telemetry Transport) over standard network infrastructure; further details on topology, bandwidth, latency, redundancy, or security mechanisms are not specified in the documents."
]