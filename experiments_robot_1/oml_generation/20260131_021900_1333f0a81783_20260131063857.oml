// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving the first axis of the robot, controlled via Siemens SINUMERIK 840D sl controller."
]

instance GearboxComponent : DTDFVocab:ActingComponent [
    base:desc "Gearbox translating motor motion into mechanical output for the robot's first axis, integrated with the motor and controller."
]

instance SafetyCell : DTDFVocab:ActingComponent [
    base:desc "Safety cell enforcing maximum working range constraints for the robot's first axis operation."
]

instance SiemensSINUMERIK840DslController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl controller managing closed-loop feedback for the first axis, integrating position encoders and current sensors for precise motion control."
]

// C3: Physical Sensing Components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted directly on the permanent magnet synchronous motor, measuring shaft position at high sampling frequency."
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance OutputShaftPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearbox, measuring output shaft position for redundant measurement."
    DTDFVocab:producedData OutputShaftPositionDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor monitoring input current to the permanent magnet synchronous motor."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Angle sensor tracking output angle of the gearbox shaft."
    DTDFVocab:producedData OutputAngleDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance OutputShaftPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputShaftPositionEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

// C10: Models/Data
instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based functional architecture model describing requirements, functions, and logical architecture for the robot's first axis."
    DTDFVocab:inputTo SysMLToolEnabler, MontiArcToolEnabler
]

instance SysMLLogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams (IBDs) defining component-connector architecture for the robot's first axis."
    DTDFVocab:inputTo SysMLToolEnabler, MontiArcToolEnabler
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "MontiArc component model defining interfaces, interconnections, and composition for the robot's first axis."
    DTDFVocab:inputTo MontiArcToolEnabler
]

instance SimulinkControlModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model implementing dynamic system simulation and control logic for the robot's first axis."
    DTDFVocab:inputTo SimulinkToolEnabler
]

instance RobotAxisStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machine (v1.7) capturing behavioral dynamics of the robot's first axis."
    DTDFVocab:inputTo SysMLToolEnabler
]

instance AggregatedSensorData : DTDFVocab:Data [
    base:desc "Time-series aggregation of all sensor inputs (position, current, angle) from the robot's first axis at high sampling frequency."
    DTDFVocab:fromData MotorPositionDataTransmitted, OutputShaftPositionDataTransmitted, MotorCurrentDataTransmitted, OutputAngleDataTransmitted
    DTDFVocab:inputTo DigitalShadowPipelineEnabler, MQTTProtocolEnabler
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Processed contextual data traces from the physical robot axis, filtered and reduced for downstream analysis."
    DTDFVocab:fromData AggregatedSensorData
    DTDFVocab:inputTo DataLakeEnabler, RealTimeDatabaseEnabler
]

// C11: Enablers
instance SysMLToolEnabler : DTDFVocab:Enabler [
    base:desc "SysML (v1.7) tool enabling multi-layered system description across requirements, functional, and logical architecture layers."
    DTDFVocab:enables DigitalShadowMonitoringService
]

instance MontiArcToolEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc tool supporting component composition and behavioral modeling via MontiArc Automaton for state-driven systems."
    DTDFVocab:enables DigitalShadowMonitoringService
]

instance SimulinkToolEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink enabling dynamic system simulation and control logic implementation for the robot's first axis."
    DTDFVocab:enables DigitalShadowMonitoringService
]

instance DigitalShadowPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Digital Shadow pipeline implementing one-way data acquisition, aggregation, and abstraction from physical objects."
    DTDFVocab:enables DigitalShadowMonitoringService
]

instance MQTTProtocolEnabler : DTDFVocab:Enabler [
    base:desc "MQTT lightweight publish-subscribe protocol for streaming sensor data from physical axis to digital representation."
    DTDFVocab:enables DigitalShadowMonitoringService
]

instance DataLakeEnabler : DTDFVocab:Enabler [
    base:desc "Contextual data lake storing Digital Shadow traces and simulation outputs for historical analysis."
    DTDFVocab:enables DigitalShadowMonitoringService
]

instance RealTimeDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Real-time database supporting low-latency access to operational data for monitoring services."
    DTDFVocab:enables DigitalShadowMonitoringService
]

// C6: Services
instance DigitalShadowMonitoringService : DTDFVocab:Service [
    base:desc "Passive monitoring service collecting contextual data traces from the physical robot axis via one-way data flows."
    DTDFVocab:provides RobotAxisMonitoringInsight
]

// C17: Insights/Actions
instance RobotAxisMonitoringInsight : DTDFVocab:Insight [
    base:desc "Aggregated contextual data traces enabling real-time monitoring of the robot's first axis operational parameters (position, current, angle)."
]

instance RobotControlAccuracyImprovementAction : DTDFVocab:Action [
    base:desc "Application of derived insights to improve robot control accuracy through adjusted actuation parameters."
    DTDFVocab:IsAutomatic false
]

// C1: Environment
instance RobotFirstAxisEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotor, GearboxComponent, SafetyCell, SiemensSINUMERIK840DslController,
                 MotorPositionEncoder, OutputShaftPositionEncoder, MotorCurrentSensor, OutputAngleSensor
]

// C1: Components
instance RobotFirstAxisComponent : DTDFVocab:Component [
    base:desc "Physical first axis of the robot system, including motor, gearbox, safety cell, and controller components."
    base:isContainedIn RobotFirstAxisEnvironment
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system, as described in the context of the Digital Shadow Reference Model, operates with a **real-time, data-driven synchronization** between the physical and digital representations. The system captures **time series of all sensors** in the physical object (e.g., a robot axis) and streams this data via **MQTT**, implying low-latency requirements for real-time processing. The digital shadow aggregates and abstracts these data traces **with respect to a specific time interval**, ensuring temporal alignment between the physical and digital states. While explicit synchronization frequencies or latency thresholds are not specified, the use of streaming protocols (e.g., MQTT) and the emphasis on real-time data flow suggest **sub-second to millisecond-level granularity** for critical operational monitoring and control tasks. The system does not explicitly define hard latency constraints but relies on the underlying infrastructure to support near-real-time synchronization for dynamic adjustments or predictive analytics."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system’s orchestration and coordination are not explicitly detailed in the provided documents. However, the context implies an architecture that integrates heterogeneous modeling tools and methodologies (e.g., MBSE with SysML, ADLs like ACME/AADL, or simulation tools like Simulink) to describe system structure and behavior. The system may employ component-based architectures (e.g., component & connector perspectives in ADLs) to manage integration, interconnections, and composition of digital and physical entities. Coordination mechanisms could involve state machines (e.g., SysML v1.7 or MontiArc Automaton) or hybrid modeling approaches combining formal methods with simulation. Resource management may rely on tool-specific frameworks (e.g., MathWorks tools for real-time simulation) or middleware layers to handle data flow and processing. The document does not specify orchestration patterns (e.g., microservices, service-oriented architectures) or system-wide coordination protocols (e.g., OPC UA, MQTT) but suggests a need for integrating diverse stakeholders and perspectives through unified modeling frameworks."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin system's lifecycle stages are structured around a **purpose-driven methodology** with four sequential steps, as referenced in the Digital Shadow Reference Model (DSRM) and further refined for this use case. The lifecycle begins with **Problem Identification**, where the specific objective (e.g., understanding friction loss relations in robotic systems) is defined. This is followed by **Asset Analysis**, where the physical system (e.g., robotic components) is modeled using **Model-Based Systems Engineering (MBSE)** methodologies, including **SysML** for requirements, functional architecture, logical architecture, and product/technical layers. The **Digital Shadow Reference Model (DSRM)** is employed to define the **one-way data flow** from the physical object to its digital representation, capturing contextual data traces and their aggregation/abstraction. The third stage involves **Model Integration**, where heterogeneous models (e.g., SysML IBDs for component-connector architectures, MontiArc Automaton or SysML state machines for behavior, and simulation tools like MathWorks Simulink) are combined to create a unified digital representation. The final stage, **Application Deployment**, leverages the Digital Twin’s **active components** (e.g., simulation models, C++/Java code) to process data and derive insights. Transition management between phases is governed by **methodological consistency** (e.g., adherence to the 4-step process) and **tool interoperability** (e.g., integration of SysML, Simulink, and general-purpose programming languages). Lifecycle governance is implicit in the structured use of MBSE abstraction layers and the DSRM’s UML-based class diagram framework, ensuring traceability and alignment with the system’s purpose."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **fidelity considerations** by comparing **simulated data** against **measured data** to quantify deviations, ensuring alignment between digital and physical system states. While the document does not explicitly detail **validation and verification (V&V) methods** or **uncertainty quantification**, the **digital shadow reference model** emphasizes **automated one-way data flow** from physical to digital objects, implying a reliance on **data-driven validation** (e.g., consistency checks between aggregated sensor traces and model predictions). No explicit **error correction mechanisms** or **quality assurance processes** are described, though the system’s fidelity depends on the **accuracy of data aggregation and abstraction** from contextual traces."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for this Digital Shadow system relies on **MQTT** as the primary communication protocol for streaming data from physical objects to the digital representation. The document does not specify additional protocols (e.g., OPC UA, AMQP), network topology (e.g., star, mesh), or detailed bandwidth/latency requirements. However, the use of MQTT implies support for **low-latency, event-driven communication** suitable for IoT environments. No explicit mention is made of **reliability mechanisms** (e.g., redundancy, failover), **security protocols** (e.g., TLS, authentication), or **network architecture** (e.g., cloud-edge integration). The system’s passive nature (as a Digital Shadow) further suggests that **bidirectional or real-time control flows** are not part of its technical connection scope."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates horizontally via **MQTT-based streaming protocols** for real-time data exchange between physical assets (e.g., sensors) and their digital counterparts. The reference model (Fig. 1) emphasizes **automated one-way data flow** from physical objects to digital shadows, with no bidirectional or active feedback mechanisms described. While the document does not explicitly mention **interoperability standards (e.g., OPC UA, RAMI 4.0)** or enterprise systems (e.g., ERP, MES), the use of **Asset Administration Shells (AAS)** is implied as a foundational concept for structuring digital shadow data traces. Integration patterns are constrained to **contextual data aggregation** (e.g., sensor time-series) and **abstraction layers** for specific purposes, with no explicit dependencies on external Digital Twins or enterprise-wide systems."
]