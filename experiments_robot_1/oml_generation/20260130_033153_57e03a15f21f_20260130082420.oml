// C3: Physical sensing components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted directly on the permanent magnet synchronous motor (PMSM) for precise motion feedback."
    DTDFVocab:producedData MotorPositionDataStream
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder positioned behind the cycloidal gearbox for secondary position feedback in the gear transmission system."
    DTDFVocab:producedData GearboxPositionDataStream
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor currents for real-time friction identification in the PMSM-gearbox system."
    DTDFVocab:producedData MotorCurrentDataStream
]

instance GearboxTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring gearbox torque for multi-physics-aware friction modeling in the cycloidal gear transmission."
    DTDFVocab:producedData GearboxTorqueDataStream
]

// C4: Physical-to-virtual interaction
instance MotorPositionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxPositionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

instance MotorCurrentDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance GearboxTorqueDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxTorqueSensor
]

// C10: Models/Data
instance EncoderTimeSeriesData : DTDFVocab:Data [
    base:desc "Time-series position data from both motor and gearbox encoders streamed via MQTT for real-time friction analysis."
    DTDFVocab:fromData MotorPositionDataStream, GearboxPositionDataStream
    DTDFVocab:inputTo MQTTStreamingEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Real-time motor current measurements used for identifying friction characteristics in the PMSM system."
    DTDFVocab:fromData MotorCurrentDataStream
    DTDFVocab:inputTo MQTTStreamingEnabler
]

instance GearboxTorqueData : DTDFVocab:Data [
    base:desc "Torque measurements from the cycloidal gearbox system aggregated for multi-physics friction modeling."
    DTDFVocab:fromData GearboxTorqueDataStream
    DTDFVocab:inputTo MQTTStreamingEnabler
]

instance MultiPhysicsFrictionModel : DTDFVocab:Model [
    base:desc "Physics-based model for continuous joint friction identification in the cycloidal gear and motor-gearbox system."
    DTDFVocab:inputTo SimulinkIntegrationEnabler
]

instance RobotAxisGeometricModel : DTDFVocab:Model [
    base:desc "CAD-based geometric representation of the MABI MAX 100 first vertical axis including motor, gearbox, and encoder positions."
    DTDFVocab:inputTo SysMLModelingEnabler
]

// C11: Enablers
instance MQTTStreamingEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol implementation for streaming sensor data (encoder readings, motor currents, gearbox torque) from physical robot axis to digital shadow."
    DTDFVocab:enables DataAcquisitionService, FrictionModelingService
]

instance SimulinkIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink integration for multi-physics simulation and behavioral modeling of the friction identification system."
    DTDFVocab:enables FrictionModelingService
]

instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based systems engineering modeling for structural and behavioral description of the robot axis components and their interconnections."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Automated collection and aggregation of contextual data traces (motor currents, encoder signals, gearbox torque) via MQTT streaming."
    DTDFVocab:provides FrictionIdentificationInsight
]

instance FrictionModelingService : DTDFVocab:Service [
    base:desc "Continuous identification of joint friction in the cycloidal gear and motor-gearbox system using aggregated sensor data."
    DTDFVocab:provides FrictionAnalysisInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Presentation of friction identification results in a dashboard for monitoring and analysis of the robot axis performance."
    DTDFVocab:provides FrictionDashboardInsight
]

// C17: Insights/Actions
instance FrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Real-time identification of friction characteristics in the PMSM-gearbox system based on aggregated sensor data."
]

instance FrictionAnalysisInsight : DTDFVocab:Insight [
    base:desc "Multi-physics-aware analysis of joint friction behavior in the cycloidal gear transmission system."
]

instance FrictionDashboardInsight : DTDFVocab:Insight [
    base:desc "Visual representation of friction identification results for operational monitoring and performance assessment."
]

// C2: Acting Components (Physical Acting Components not specified - excluded)
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "PMSM driving the first vertical axis of MABI MAX 100 robot, coupled with cycloidal gear transmission for torque amplification."
]

instance CycloidalGearTransmission : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear system providing torque amplification between the PMSM motor and robot axis output."
]

// C10: Additional Models (MBSE Methodologies)
instance RequirementsModel : DTDFVocab:Model [
    base:desc "SysML-based requirements model defining functional and non-functional requirements for the digital twin system."
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML functional architecture model describing system functions and their interactions in the robot axis."
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML logical architecture model defining component interfaces and interconnections for the digital twin."
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance StateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machine model representing behavioral dynamics of the robot axis components."
    DTDFVocab:inputTo SimulinkIntegrationEnabler
]

// C11: Additional Enablers (MBSE Methodologies)
instance RFLPMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "Requirements, Functions, Logics, Physics (RFLP) methodology for managing complexity in multi-physics systems."
    DTDFVocab:enables DataAcquisitionService, FrictionModelingService
]

instance OOSEMMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "Object-Oriented Systems Engineering Method (OOSEM) for structuring system descriptions across abstraction layers."
    DTDFVocab:enables VisualizationService
]

// C6: Additional Services (MBSE Methodologies)
instance SystemIntegrationService : DTDFVocab:Service [
    base:desc "Integration of heterogeneous models and data components across requirements, functional, logical, and product layers."
    DTDFVocab:provides SystemConsistencyInsight
]

// C17: Additional Insights
instance SystemConsistencyInsight : DTDFVocab:Insight [
    base:desc "Verification of consistency between physical system behavior and digital twin representation across all abstraction layers."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system, as described in the context of **Digital Shadow Reference Model** [32], operates under a **one-way, automated data flow** from the physical object to its digital representation, implying a **passive synchronization mechanism** without real-time bidirectional updates. While the document does not specify explicit synchronization frequencies, latency requirements, or temporal granularity, it establishes a foundational requirement for **live data aggregation** (e.g., contextual data traces) to maintain alignment between the physical and digital domains. The absence of active feedback loops suggests that temporal dynamics are constrained by the **external system’s data generation rate** rather than a predefined time scale. For behavior modeling, tools like **MathWorks Simulink** or **state machines in SysML v1.7** may be employed to simulate or analyze time-dependent processes, but no quantitative metrics (e.g., Hz, ms latency) are provided in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system’s orchestration and coordination are not explicitly detailed in the provided document. However, the **Model-Based Systems Engineering (MBSE) framework** (e.g., SysML, MontiArc, or Simulink) implies a **multi-layered architecture** (requirements, functional, logical, and technical layers) with **heterogeneous tool integration** to manage complexity. The **Digital Shadow Reference Model** (Fig. 1) defines foundational concepts but does not specify **architecture patterns** (e.g., microservices, service-oriented) or **system-wide coordination mechanisms**. The document references **active components** (e.g., in Digital Twins) for interpreting data, but no **resource management** or **orchestration protocols** (e.g., Kubernetes, event-driven) are mentioned. Integration of **component-based models** (e.g., MontiArc Automaton, state machines) suggests behavioral coordination, yet no concrete **orchestration framework** (e.g., choreography, workflow engines) is described."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system validates model fidelity by **comparing simulated data with measured data** to derive friction characteristics, ensuring alignment between digital and physical system behavior. The **Digital Shadow Reference Model** emphasizes **traceability of data generation**, including aggregation and abstraction processes, which may influence model accuracy. However, explicit details on **uncertainty quantification, error detection/correction mechanisms, or formal validation/verification (V&V) methods** are not specified in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with external systems via **MQTT** for streaming data from physical objects (e.g., robot axes) to the digital shadow. The data exchange follows a **one-way, automated flow** from the physical state to the digital representation, as defined in the Digital Shadow Reference Model. While the document does not specify additional protocols (e.g., OPC UA, HTTP, or REST APIs), it implies interoperability with **Asset Administration Shells (AAS)** for contextual data aggregation and abstraction. No explicit mention of integration patterns (e.g., microservices, event-driven architectures) or dependencies on other Digital Twins or enterprise systems is provided."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system for the MABI MAX 100 serial robot incorporates **safety-critical system considerations** through the integration of a **safety cell** that restricts the maximum working range of the first vertical axis to **[-90°, 90°]**, ensuring operational boundaries are enforced. **Fail-safe mechanisms** are implicitly addressed via the **Siemens SINUMERIK 840D sl CNC controller**, which governs axis control with **position, speed, or acceleration inputs** and enforces **target/actual value validation** for position and its derivatives. **Threat mitigation strategies** are partially implied by the **dual-encoder sensor arrangement** (motor encoder + secondary encoder behind the gearbox), which reduces **backlash and positional uncertainty** by cross-referencing encoder data to infer **elasticity and friction** in the drive train. However, explicit **cybersecurity protocols**, **access control mechanisms**, or **authentication systems** are not detailed in the provided documents. **Risk assessment approaches** are not explicitly described beyond the physical safety constraints of the safety cell."
]