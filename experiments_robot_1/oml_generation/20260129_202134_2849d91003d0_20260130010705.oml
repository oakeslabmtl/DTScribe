prefix DTDFVocab = "http://www.example.org/dtdfvocab"
prefix base = "http://www.example.org/base"

instance MABIMAX100Robot : DTDFVocab:SystemUnderStudy [
    base:desc "MABI MAX 100 industrial robot with six axes, focusing on first axis for precise motion control and dynamics analysis",
    DTDFVocab:hasEnvironment ManufacturingEnvironment
]

instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:desc "Manufacturing environment for MABI MAX 100 industrial robot operations"
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Current operational status of robot axes"
]

instance JointFrictionInsight : DTDFVocab:Insight [
    base:desc "Friction levels in robot joints for maintenance analysis"
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive insights for maintenance scheduling"
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of robot operational data and simulation results"
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of operational parameters for industrial robot",
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance JointFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous multi-physics-aware identification of joint friction in industrial robots",
    DTDFVocab:provides JointFrictionInsight
]

instance DynamicSimulationService : DTDFVocab:Service [
    base:desc "Dynamic simulation for predictive maintenance of industrial robots",
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Interactive visualization dashboard interface for manufacturing engineers and maintenance teams",
    DTDFVocab:provides DashboardVisualizationInsight
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for multi-level abstraction modeling",
    DTDFVocab:enables RealTimeMonitoringService, JointFrictionIdentificationService, DynamicSimulationService, VisualizationDashboardService
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for multi-level abstraction modeling",
    DTDFVocab:enables RealTimeMonitoringService, JointFrictionIdentificationService, DynamicSimulationService, VisualizationDashboardService
]

instance SPES : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for multi-level abstraction modeling",
    DTDFVocab:enables RealTimeMonitoringService, JointFrictionIdentificationService, DynamicSimulationService, VisualizationDashboardService
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for multi-level abstraction modeling",
    DTDFVocab:enables RealTimeMonitoringService, JointFrictionIdentificationService, DynamicSimulationService, VisualizationDashboardService
]

instance ACME : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for system component and interface definition",
    DTDFVocab:enables RealTimeMonitoringService, JointFrictionIdentificationService
]

instance AADL : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for system component and interface definition",
    DTDFVocab:enables RealTimeMonitoringService, JointFrictionIdentificationService
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for system component and interface definition",
    DTDFVocab:enables RealTimeMonitoringService, JointFrictionIdentificationService
]

instance SysMLIBDs : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component interconnections",
    DTDFVocab:enables RealTimeMonitoringService, JointFrictionIdentificationService
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "Behavior modeling using MontiArc Automaton for state machines",
    DTDFVocab:enables JointFrictionIdentificationService
]

instance SysMLStateMachine : DTDFVocab:Enabler [
    base:desc "SysML state machines for behavioral modeling",
    DTDFVocab:enables JointFrictionIdentificationService
]

instance MathWorksSimulink : DTDFVocab:Enabler [
    base:desc "Detailed simulation tool for dynamic modeling",
    DTDFVocab:enables DynamicSimulationService, JointFrictionIdentificationService
]

instance CPlusPlus : DTDFVocab:Enabler [
    base:desc "General-purpose programming language for detailed behavioral implementation",
    DTDFVocab:enables DynamicSimulationService, VisualizationDashboardService
]

instance Java : DTDFVocab:Enabler [
    base:desc "General-purpose programming language for dashboard implementation",
    DTDFVocab:enables VisualizationDashboardService
]

instance JointFrictionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring joint friction in industrial robot axes",
    DTDFVocab:producedData JointFrictionDataTransmitted
]

instance JointFrictionDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "One-way automated data flow from physical assets to digital shadow via Asset Administration Shells (AAS)",
    DTDFVocab:producedFrom JointFrictionSensor
]

instance JointFrictionData : DTDFVocab:Data [
    base:desc "Contextual data traces aggregated and abstracted for continuous multi-physics-aware identification of joint friction",
    DTDFVocab:fromData JointFrictionDataTransmitted,
    DTDFVocab:inputTo MontiArcAutomaton, MathWorksSimulink, SysMLIBDs, Java
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to industry standards including SysML [17] for model-based systems engineering, AADL [24] for architecture description, ACME [23] for component-based modeling, MontiArc [25], [26] for architectural descriptions, and SysML IBDs [17], [27] for interface and behavior modeling. These standards ensure structured representation of system components, interfaces, and behaviors across abstraction levels, facilitating interoperability among heterogeneous modeling tools and stakeholders."
]