instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:desc "Manufacturing environment for MABI MAX 100 robot operation"
    base:contains BaseVerticalAxis, RotationalJoints, EndEffector
]

instance BaseVerticalAxis : DTDFVocab:Component [
    base:desc "Vertical axis component of MABI MAX 100 robot base"
]

instance RotationalJoints : DTDFVocab:Component [
    base:desc "Rotational joints in MABI MAX 100 robot arm"
]

instance EndEffector : DTDFVocab:Component [
    base:desc "End-effector component of MABI MAX 100 robot"
]

instance MABIMAX100Sensor : DTDFVocab:SensingComponent [
    base:desc "Sensing component of MABI MAX 100 robot"
    DTDFVocab:producedData MABIMAX100SensorData
]

instance MABIMAX100SensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MABIMAX100Sensor
    base:desc "Time series sensor data transmitted via MQTT protocol"
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Real-time sensor data from MABI MAX 100 robot"
    DTDFVocab:fromData MABIMAX100SensorData
    DTDFVocab:inputTo MQTTEnabler
]

instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol implementation for data transmission"
    DTDFVocab:enables DataTransmissionService
]

instance DataTransmissionService : DTDFVocab:Service [
    base:desc "Service for transmitting sensor data via MQTT"
    DTDFVocab:provides DataTransmissionInsight
]

instance DataTransmissionInsight : DTDFVocab:Insight [
    base:desc "Insight related to data transmission status"
]

instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML model for requirements layer"
    DTDFVocab:inputTo SysMLIBDEnabler
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML model for functional layer"
    DTDFVocab:inputTo SysMLIBDEnabler
]

instance SysMLLogicalModel : DTDFVocab:Model [
    base:desc "SysML model for logical layer"
    DTDFVocab:inputTo SysMLIBDEnabler
]

instance SysMLProductModel : DTDFVocab:Model [
    base:desc "SysML model for product/technical layer"
    DTDFVocab:inputTo SysMLIBDEnabler
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language model for component & connector"
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL Architecture Description Language model for component & connector"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc Architecture Description Language model for component & connector"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML IBD model for component & connector"
    DTDFVocab:inputTo SysMLIBDEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton behavioral model"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine behavioral model"
    DTDFVocab:inputTo SysMLIBDEnabler
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink simulation model"
    DTDFVocab:inputTo SimulinkEnabler
]

instance CPPCodeModel : DTDFVocab:Model [
    base:desc "C++ general-purpose code model"
    DTDFVocab:inputTo CppEnabler
]

instance JavaCodeModel : DTDFVocab:Model [
    base:desc "Java general-purpose code model"
    DTDFVocab:inputTo JavaEnabler
]

