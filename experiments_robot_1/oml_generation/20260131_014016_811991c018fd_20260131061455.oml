]

instance MotorShaftPositionData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted time-series data from motor shaft encoder for analytical purposes"
    DTDFVocab:fromData MotorShaftPositionDataStream
    DTDFVocab:inputTo DataProcessingEnabler
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted time-series data from gearbox encoder for analytical purposes"
    DTDFVocab:fromData GearboxPositionDataStream
