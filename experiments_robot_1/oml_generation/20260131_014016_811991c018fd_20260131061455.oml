// C3: Physical sensing components
instance MotorShaftPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted directly on the motor shaft providing time-series positional feedback via dual arrangement"
    DTDFVocab:producedData MotorShaftPositionDataStream
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearbox providing time-series positional feedback via dual arrangement"
    DTDFVocab:producedData GearboxPositionDataStream
]

// C4: Physical-to-virtual interaction
instance MotorShaftPositionDataStream : DTDFVocab:DataTransmitted [
    base:desc "Time-series sensor data stream containing torque, angular velocity, and current measurements transmitted via MQTT protocol"
    DTDFVocab:producedFrom MotorShaftPositionEncoder
]

instance GearboxPositionDataStream : DTDFVocab:DataTransmitted [
    base:desc "Time-series sensor data stream containing positional feedback from gearbox encoder transmitted via MQTT protocol"
    DTDFVocab:producedFrom GearboxPositionEncoder
]

