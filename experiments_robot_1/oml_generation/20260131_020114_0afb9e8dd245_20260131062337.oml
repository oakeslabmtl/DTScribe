// C3: Physical Sensing Components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder located at the motor shaft of MABI MAX 100 robot axis, providing high-precision motion feedback for joint dynamics analysis."
    DTDFVocab:producedData MotorShaftEncoderDataTransmitted
]

instance GearboxOutputEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder located at the gearbox output of MABI MAX 100 robot axis, enabling spatial distribution for real-time motion validation and calibration."
    DTDFVocab:producedData GearboxOutputEncoderDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance MotorShaftEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
    base:desc "Automated one-way transmission of motor shaft position data via MQTT protocol, optimized for low-latency IoT streaming."
]

instance GearboxOutputEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxOutputEncoder
    base:desc "Automated one-way transmission of gearbox output position data via MQTT protocol, supporting high-throughput sensor time series."
]

// C10: Models/Data
instance RobotAxisPositionModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) representing the functional architecture of MABI MAX 100 robot axis components (motors, gearboxes, encoders) and their interconnections."
    DTDFVocab:inputTo SysMLModelingEnabler, MontiArcAutomatonEnabler
]

instance JointFrictionBehavioralModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model capturing joint friction dynamics and state transitions for MABI MAX 100 robot axis, integrated with Simulink for behavioral simulation."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance EncoderTimeSeriesData : DTDFVocab:Data [
    base:desc "Aggregated and preprocessed time series data from motor shaft and gearbox output encoders, structured for friction identification analysis."
    DTDFVocab:fromData MotorShaftEncoderDataTransmitted, GearboxOutputEncoderDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler
]

instance OperationalLogData : DTDFVocab:Data [
    base:desc "Contextual operational logs from MABI MAX 100 robot axis, including motor currents, dynamic loads, and safety limit violations for validation purposes."
    DTDFVocab:inputTo DataIntegrationEnabler, SysMLModelingEnabler
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 implementation enabling multi-layered system description (requirements, functional/logical architectures) via Internal Block Diagrams (IBDs) and state machines."
    DTDFVocab:enables RobotAxisPositionService
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton framework for formalized behavioral modeling of robot axis components, supporting interoperability with SysML and simulation tools."
    DTDFVocab:enables JointFrictionBehavioralService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for dynamic system simulation, control system design, and signal processing of joint friction models."
    DTDFVocab:enables FrictionAnalysisService
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "Abstraction layer processing raw encoder time series into structured traces for analytical purposes, including filtering and normalization."
    DTDFVocab:enables FrictionAnalysisService
]

instance MQTTCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "MQTT publish-subscribe protocol implementation for low-latency, high-throughput data transmission from physical sensors to digital shadow."
    DTDFVocab:enables DataAcquisitionService
]

instance DataIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Cross-tool integration framework aligning heterogeneous data sources (SysML models, simulation outputs, operational logs) for consistent analysis."
    DTDFVocab:enables SystemValidationService
]

// C6: Services
instance RobotAxisPositionService : DTDFVocab:Service [
    base:desc "SysML-based service providing structural representation of MABI MAX 100 robot axis components (motors, gearboxes, encoders) and their interconnections."
    DTDFVocab:provides RobotAxisComponentInsight
]

instance JointFrictionBehavioralService : DTDFVocab:Service [
    base:desc "MontiArc Automaton service modeling joint friction dynamics and state transitions for MABI MAX 100 robot axis components."
    DTDFVocab:provides FrictionStateInsight
]

instance FrictionAnalysisService : DTDFVocab:Service [
    base:desc "Multi-physics-aware service identifying joint friction characteristics using aggregated encoder data and simulation models."
    DTDFVocab:provides FrictionIdentificationInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Dashboard-based service visualizing contextual data traces for real-time monitoring of robot axis operational state."
    DTDFVocab:provides OperationalStateInsight
]

instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Automated service collecting sensor time series (encoder readings, motor currents) from physical robot axis via MQTT protocol."
    DTDFVocab:provides SensorDataTraceInsight
]

instance SystemValidationService : DTDFVocab:Service [
    base:desc "Service validating alignment between physical robot axis behavior and digital twin models using operational logs and simulation outputs."
    DTDFVocab:provides ModelValidationInsight
]

// C17: Insights/Actions
instance RobotAxisComponentInsight : DTDFVocab:Insight [
    base:desc "Structural insight into MABI MAX 100 robot axis components (motors, gearboxes, encoders) and their functional interconnections as modeled in SysML IBDs."
]

instance FrictionStateInsight : DTDFVocab:Insight [
    base:desc "Behavioral insight into joint friction states and transitions for MABI MAX 100 robot axis, derived from MontiArc Automaton models."
]

instance FrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Identified joint friction characteristics and their impact on robot axis motion precision, enabling quantitative analysis of deviations."
]

instance CompensationRecommendationAction : DTDFVocab:Action [
    base:desc "Automated recommendation for friction compensation strategies based on identified friction models and operational constraints."
    DTDFVocab:IsAutomatic true
]

instance OperationalStateInsight : DTDFVocab:Insight [
    base:desc "Real-time operational state of MABI MAX 100 robot axis, including position, velocity, and dynamic load parameters visualized in dashboards."
]

instance SensorDataTraceInsight : DTDFVocab:Insight [
    base:desc "Aggregated time series data from motor shaft and gearbox output encoders, processed for friction analysis and calibration purposes."
]

instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results comparing physical robot axis behavior with digital twin models, identifying discrepancies for calibration."
]

// C1: System Under Study
instance MabiMax100RobotAxis : DTDFVocab:Component [
    base:desc "Physical twin of MABI MAX 100 industrial robot axis system, operating in high-precision machining domain with critical joint dynamics and friction characteristics."
]

instance MachiningDomainEnvironment : DTDFVocab:Environment [
    base:desc "High-precision manufacturing environment where MABI MAX 100 robot axis operates, with strict requirements for motion control and product quality."
    base:contains MabiMax100RobotAxis
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system validates model fidelity through **comparison of simulated data versus measured data**, ensuring alignment between digital representations and physical system behavior. **Uncertainty sources** arise from deviations between modeled and real-world data, necessitating **quality assurance processes** to maintain consistency. The system integrates **heterogeneous stakeholder perspectives** to address validation challenges, though explicit **verification and validation (V&V) methodologies** or **uncertainty quantification techniques** are not detailed in the provided context. **Conformance relations** between digital and physical states are implied but not explicitly defined."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for the Digital Shadow system leverages **MQTT** as the primary communication protocol for streaming sensor time series data from physical objects to their digital representations. While the document does not specify **network topology** (e.g., star, mesh, or hierarchical) or **bandwidth/latency requirements**, the use of MQTT implies support for **low-latency, event-driven communication** suitable for IoT deployments. No details are provided on **reliability/redundancy mechanisms** (e.g., failover protocols, QoS levels) or **security protocols** (e.g., TLS, authentication/authorization frameworks). The absence of explicit **network architecture** (e.g., cloud-edge hybrid, on-premise) or **topology** (e.g., centralized vs. distributed) prevents further technical specification."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **interoperability standards** such as **Asset Administration Shells (AAS)**, a framework for standardized data exchange in industrial contexts. **SysML** is explicitly adopted as a **modeling language standard** within **Model-Based Systems Engineering (MBSE)**. While the document does not specify **certification requirements** or **compliance frameworks** (e.g., ISO, IEC), the use of **AAS** and **SysML** implies alignment with **industry-specific interoperability standards** (e.g., RAMI 4.0 for Industry 4.0). No explicit mention of **domain-agnostic standards** (e.g., OMG, OASIS) or **validation protocols** is provided."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The provided documents reference **MQTT** (Message Queuing Telemetry Transport) as a protocol for streaming data within the Digital Twin system, specifically in the context of **Digital Shadows** (as described in [42]). However, no explicit details on cybersecurity protocols (e.g., encryption, authentication, or access control mechanisms) are provided. The documents also mention **safety cells** in manufacturing environments (e.g., [43]), which imply physical safety measures but do not elaborate on cybersecurity frameworks like IEC 62443 or ISO/IEC 27001. No trace of **Role-Based Access Control (RBAC)**, **TLS/SSL encryption**, or **fail-safe mechanisms** is documented. The only relevant technical mention is the use of **MQTT** for data streaming, which lacks security-specific configurations."
]