// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Primary actuation element interfaced with a gear transmission system including a cycloidal gear to translate rotational motion with high torque density, controlled via Siemens SINUMERIK 840D sl CNC controller processing position, speed, and acceleration inputs."
]

instance CycloidalGearTransmission : DTDFVocab:ActingComponent [
    base:desc "Mechanical transmission system integrated with the PermanentMagnetSynchronousMotor to reduce speed while increasing torque output, enabling precise kinematic adjustments for the MABI MAX 100 robot axis."
]

instance Sinumerik840DslController : DTDFVocab:ActingComponent [
    base:desc "Industrial CNC controller supporting PROFIBUS and EtherCAT protocols for real-time feedback loops, enabling precise regulation of motor behavior through drive-specific identifiers and motion control framework."
]

// C3: Physical Sensing Components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution position encoder directly mounted on the PermanentMagnetSynchronousMotor providing real-time rotational position feedback."
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution position encoder positioned behind the CycloidalGearTransmission providing real-time positional feedback of the output shaft."
    DTDFVocab:producedData GearboxPositionDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

// C10: Models/Data
instance SysMLInternalBlockDiagramModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram representing the functional architecture of the MABI MAX 100 robot axis including components (PermanentMagnetSynchronousMotor, CycloidalGearTransmission) and their interfaces."
    DTDFVocab:inputTo MQTTDataBroker
]

instance MontiArcBehavioralModel : DTDFVocab:Model [
    base:desc "MontiArc automata model describing the behavioral states of the robot axis operational modes within the logical architecture."
    DTDFVocab:inputTo SimulinkFrictionAnalysis
]

instance SimulinkFrictionModel : DTDFVocab:Model [
    base:desc "Executable MATLAB Simulink model for real-time friction identification and analysis in the motor-gearbox assembly, correlating physical sensor data with digital representations."
    DTDFVocab:inputTo SimulinkFrictionAnalysis
]

instance PositionSpeedAccelerationData : DTDFVocab:Data [
    base:desc "Aggregated time-series data representing position, speed, and acceleration metrics transmitted from the physical system via MQTT."
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:fromData GearboxPositionDataTransmitted
    DTDFVocab:inputTo SimulinkFrictionAnalysis
]

instance FrictionTraceData : DTDFVocab:Data [
    base:desc "Processed data traces identifying friction dynamics in the motor-gearbox assembly, derived from position and speed data through simulation models."
    DTDFVocab:fromData SimulinkFrictionDataTransmitted
    DTDFVocab:inputTo VisualizationDashboard
]

// C11: Enablers
instance MQTTDataBroker : DTDFVocab:Enabler [
    base:desc "Message Queuing Telemetry Transport protocol implementation enabling real-time streaming of sensor data (MotorPositionDataTransmitted, GearboxPositionDataTransmitted) from physical components to the Digital Twin."
    DTDFVocab:enables FrictionAnalysisService
    DTDFVocab:enables VisualizationService
]

instance SimulinkFrictionAnalysis : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink environment hosting executable friction analysis models that process PositionSpeedAccelerationData to generate FrictionTraceData."
    DTDFVocab:enables FrictionAnalysisService
]

instance VisualizationDashboard : DTDFVocab:Enabler [
    base:desc "Unified dashboard aggregating and visualizing FrictionTraceData and operational metrics for stakeholder monitoring of system health and performance trends."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance FrictionAnalysisService : DTDFVocab:Service [
    base:desc "Real-time modeling service for friction identification in the motor-gearbox assembly using executable simulation models to correlate physical sensor data with digital representations."
    DTDFVocab:provides FrictionInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service providing integrated visualization of aggregated data traces (friction metrics, operational metrics) in a unified dashboard format."
    DTDFVocab:provides OperationalHealthInsight
]

// C17: Insights/Actions
instance FrictionInsight : DTDFVocab:Insight [
    base:desc "Contextual data insight derived from friction trace analysis enabling identification of mechanical degradation or operational inefficiencies in the gear-motor assembly."
]

instance OperationalHealthInsight : DTDFVocab:Insight [
    base:desc "Aggregated performance metrics visualization providing stakeholders with system health monitoring capabilities for the MABI MAX 100 robot axis."
]

// C1: Environment
instance RobotAxisEnvironment : DTDFVocab:Environment [
    base:desc "Physical environment containing the MABI MAX 100 first axis components including the PermanentMagnetSynchronousMotor, CycloidalGearTransmission, and associated sensing infrastructure."
    base:contains PermanentMagnetSynchronousMotor
    base:contains CycloidalGearTransmission
    base:contains MotorPositionEncoder
    base:contains GearboxPositionEncoder
]

// C5: Components
instance MechatronicDriveSystem : DTDFVocab:Component [
    base:desc "Core mechatronic subsystem combining the PermanentMagnetSynchronousMotor with CycloidalGearTransmission under control of the Sinumerik840DslController for precise motion regulation in manufacturing automation."
]

// Additional Data Transmitted for Model Inputs
instance SimulinkFrictionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkFrictionAnalysis
]

instance SimulinkInputData : DTDFVocab:Data [
    base:desc "Processed input data prepared by SimulinkFrictionAnalysis for friction modeling, derived from PositionSpeedAccelerationData."
    DTDFVocab:fromData PositionSpeedAccelerationData
    DTDFVocab:inputTo SimulinkFrictionAnalysis
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system's orchestration and coordination are framed within a Model-Based Systems Engineering (MBSE) paradigm, leveraging architecture patterns derived from ADLs (e.g., ACME, AADL, MontiArc) and integration with simulation tools (e.g., Simulink, MathWorks). The overall constellation is structured around component-based architectures where systems are decomposed into interconnected modules with defined interfaces and behaviors. Resource management is implicitly handled through the tool-specific environments (e.g., Simulink's block diagrams or MontiArc's automaton-based models), which enforce modularity and encapsulation. System-wide coordination is achieved through the aggregation of models across tools, with no explicit mention of middleware (e.g., Kubernetes, microservices) or orchestration frameworks (e.g., Docker Swarm). The documents suggest that coordination relies on the shared semantics of MBSE notations (e.g., SysML or MontiArc) and the synchronization of simulation clocks across tools, though no centralized orchestrator or dynamic reconfiguration mechanisms are detailed."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The lifecycle of a Digital Twin (DT) system is structured through **Model-Based Systems Engineering (MBSE)** methodologies, encompassing multiple abstraction layers: **requirements, functional architecture, logical architecture, and product/technical layers**. Transition management between these stages is facilitated by **architecture description languages (ADLs)** such as **ACME, AADL, MontiArc, or SysML Internal Block Diagrams (IBDs)**, which define components, interfaces, connectors, and composition rules. For behavior modeling, **SysML state machines (v1.7) or MontiArc Automaton** are integrated with simulation tools like **MathWorks Simulink** or general-purpose languages (e.g., C++, Java) to ensure cohesive representation across phases. Lifecycle governance involves **heterogeneous stakeholder integration** (as per [31]) and **abstraction refinement** to align physical and digital representations, with **RFLP (Requirements-Functions-Logics-Physics), OOSEM, SPES, or SMArDT** frameworks guiding structured evolution. No explicit lifecycle governance frameworks (e.g., ISO/IEC standards) are mentioned in the document."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
The Digital Twin system adheres to **model fidelity requirements** through **multi-layered MBSE methodologies**, ensuring consistency across **requirements, functional, logical, and physical layers**. Validation and verification (V&V) are implicitly addressed via **automated one-way data flows** (as per Kritzinger et al. [32]), where **digital shadows aggregate and abstract data** for specific purposes, reducing reliance on bidirectional validation protocols.

Uncertainty quantification is not explicitly detailed in the provided documents, but **model fidelity** is implicitly maintained through **structured MBSE frameworks** (e.g., SysML, ADLs) and **simulation tool integration** (e.g., Simulink). The **passive nature of digital shadows** (one-way data flow) inherently limits **error detection and correction mechanisms** to **software-based interpretation** of incoming data, as noted in [33]–[34].

Quality assurance processes are inferred from **heterogeneous stakeholder integration** ([31]) and **interoperable modeling tools**, ensuring alignment between **digital and physical representations**. However, **specific validation methodologies, uncertainty sources, or error correction mechanisms** (e.g., state-machine-based detection) are not documented.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection for this Digital Twin system is primarily defined by **MQTT-based communication** for streaming data from physical systems to the digital representation, as referenced in the digital shadow model. The document does not specify network topology, bandwidth requirements, or redundancy mechanisms beyond the implied need for **live-data linking** via MQTT. No explicit mention of protocols like OPC UA, REST, or security protocols (e.g., TLS) is provided. The system’s reliance on **MBSE tools** (e.g., SysML, Simulink) for modeling suggests integration with simulation environments, but no details on network architecture (e.g., edge/cloud, latency) are given."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The deployment infrastructure for this Digital Twin system is not explicitly detailed in the provided documents. However, the system is described in the context of a **Siemens SINUMERIK 840D sl controller** and **MATLAB Simulink** for modeling, implying an **on-premise or embedded deployment** for industrial applications. No cloud/edge hosting, scalability mechanisms, or computational/storage requirements (e.g., hardware specifications, containerization) are mentioned. The system’s deployment is implicitly tied to **manufacturing-specific tools** and a **dashboard interface**, but general architectural details (e.g., Kubernetes, AWS/Azure) are absent."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "The provided documents do not explicitly detail data ownership policies, privacy protection measures, or compliance frameworks (e.g., GDPR, CCPA). However, the **Asset Administration Shell (AAS)** framework (as referenced in [50]) emphasizes **traceability** of data through structured metadata, ensuring that data remains fully traceable to its origin and method of computation. The **SysML/UML-based modeling** (mentioned in [43]) supports versioning and lineage tracking of digital twin models, which indirectly implies governance through model-driven engineering practices. No explicit mention of consent management, data anonymization techniques, or formal data-sharing agreements (e.g., contractual or legal) is present in the documents. The **MABI robotic system** ([44]) does not provide details on proprietary data handling or third-party access controls. Thus, while traceability is implied, **no concrete data governance mechanisms or privacy safeguards are documented**."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "
Not in Document
"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The documents outline **safety-critical considerations** for digital twins in manufacturing and automation. The **MABI robotic arm (Max-100)** ([44]) operates within a **safety cell** that restricts the maximum working range to **1000 mm** (X/Y/Z axes) and incorporates **emergency stop mechanisms** for fail-safe operations. **MQTT protocol** ([52]) is referenced as a communication standard for streaming sensor data, enabling real-time monitoring but lacks explicit mention of **TLS encryption** or **authentication layers**. The **Asset Administration Shell (AAS)** ([50]) supports **model-based validation** of digital twin components, ensuring compliance with functional requirements, though no **cybersecurity protocols** (e.g., OAuth, role-based access control) are detailed. **RAMI 4.0** ([49]) and **SysML/UML-based conformance relations** ([43]) imply **structured risk assessment** through model-driven engineering, but no **ISO 13849-1** or **IEC 62443** compliance frameworks are explicitly cited. **Fail-safe mechanisms** are implied for robotic systems ([44]) but not quantified for broader digital twin architectures. **No semantic security models** (e.g., RDF/OWL-based access control) or **threat mitigation strategies** (e.g., intrusion detection) are documented."
]