// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Physical actuation mechanism driven by a permanent magnet synchronous motor, interfaced with a gear transmission system to modulate torque and speed. Operates within safety protocols for operational integrity."
]

instance CycloidalGearTransmission : DTDFVocab:ActingComponent [
    base:desc "Gear transmission system (specifically cycloidal gear) used to modulate torque and speed of the permanent magnet synchronous motor. Enables precision control over motion dynamics."
]

// C3: Physical Sensing Components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution position encoder mounted directly on the permanent magnet synchronous motor to provide rotational state feedback for closed-loop control."
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution position encoder positioned behind the gearbox to provide synchronized rotational state measurement for system monitoring."
    DTDFVocab:producedData GearboxPositionDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

// C10: Models/Data
instance RobotKinematicModel : DTDFVocab:Model [
    base:desc "SysML-based model representing the robot's kinematic architecture, including mechanical/electrical subsystem composition and interconnections."
    DTDFVocab:inputTo SysMLModelingEnabler, SimulinkSimulationEnabler
]

instance RobotDynamicModel : DTDFVocab:Model [
    base:desc "Executable simulation model for dynamic behavior (e.g., friction modeling in the first axis) using MathWorks Simulink/MATLAB."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance OperationalLogData : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces from physical robot operations, including sensor readings and environmental parameters for manufacturing use cases."
    DTDFVocab:fromData MotorPositionDataTransmitted, GearboxPositionDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler
]

instance FrictionIdentificationData : DTDFVocab:Data [
    base:desc "Processed data traces focused on friction identification in the robot's mechanical components, derived from sensor and operational data."
    DTDFVocab:fromData MotorPositionDataTransmitted, GearboxPositionDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based modeling tool for component & connector architecture (logical architecture) of the MABI MAX 100 robot, including interfaces and composition."
    DTDFVocab:enables RobotArchitectureService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink/MATLAB environment for executable simulation models of dynamic behavior (e.g., friction modeling)."
    DTDFVocab:enables DynamicBehaviorService
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "MQTT-based protocol for automated one-way ingestion of sensor/actuator data from physical robot to digital representation."
    DTDFVocab:enables DataCollectionService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Software components for interpreting and processing aggregated data traces (e.g., friction identification) from the Digital Shadow."
    DTDFVocab:enables DataAnalysisService
]

// C6: Services
instance RobotArchitectureService : DTDFVocab:Service [
    base:desc "Service providing structural and behavioral descriptions of the robot's logical architecture using SysML component & connector models."
    DTDFVocab:provides RobotArchitectureInsight
]

instance DynamicBehaviorService : DTDFVocab:Service [
    base:desc "Service enabling data-driven validation of dynamic behavior (e.g., friction modeling) through Simulink simulations."
    DTDFVocab:provides DynamicBehaviorInsight
]

instance DataCollectionService : DTDFVocab:Service [
    base:desc "Service managing automated one-way data flow from physical robot sensors to digital shadow via MQTT protocol."
    DTDFVocab:provides DataCollectionInsight
]

instance DataAnalysisService : DTDFVocab:Service [
    base:desc "Service processing aggregated data traces for specific purposes (e.g., friction identification) in manufacturing contexts."
    DTDFVocab:provides FrictionIdentificationInsight
]

// C17: Insights/Actions
instance RobotArchitectureInsight : DTDFVocab:Insight [
    base:desc "Structural and behavioral understanding of the robot's logical architecture, including mechanical/electrical subsystem composition."
]

instance DynamicBehaviorInsight : DTDFVocab:Insight [
    base:desc "Validated dynamic behavior of the robot's physical components (e.g., friction characteristics) through simulation."
]

instance DataCollectionInsight : DTDFVocab:Insight [
    base:desc "Real-time contextual data traces (e.g., operational logs, sensor readings) aggregated for manufacturing use cases."
]

instance FrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Identified friction characteristics in the robot's mechanical components for predictive maintenance and process optimization."
]

// C1: Environment
instance MabiMax100RobotEnvironment : DTDFVocab:Environment [
    base:desc "Manufacturing environment hosting the MABI MAX 100 serial industrial robot with kinematic and dynamic control requirements."
    base:contains PermanentMagnetSynchronousMotor, CycloidalGearTransmission,
                MotorPositionEncoder, GearboxPositionEncoder
]

// C10: Additional Models (Methodologies)
instance RFLPMethodologyModel : DTDFVocab:Model [
    base:desc "Multi-abstraction layer modeling framework (Requirements, Functions, Logics, Physics) for decomposing the robot's complexity."
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance UMLClassDiagramModel : DTDFVocab:Model [
    base:desc "UML Class Diagrams defining concepts for data aggregation, abstraction, and traceability in manufacturing contexts (Digital Shadow Reference Model)."
    DTDFVocab:inputTo DataAggregationEnabler
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system, as described in the context of Digital Shadows, operates under a **real-time, data-driven synchronization paradigm**, where the digital representation is continuously updated via an **automated one-way data flow** from the physical system. While explicit synchronization frequencies or latency requirements are not quantified, the system inherently relies on **temporal granularity** aligned with the physical system's operational dynamics (e.g., sensor data streams). The distinction between Digital Shadows (passive, one-way) and Digital Twins (active, bidirectional) implies that the latter must support **low-latency processing** to enable real-time decision-making or feedback mechanisms, though no specific time scales (e.g., millisecond-level updates) are provided in the document. The use of **MQTT for sensor data streaming** (implied by Section IV) suggests a lightweight, event-driven protocol optimized for real-time data exchange, further reinforcing the need for **temporal alignment** between physical and digital components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system’s **orchestration and coordination** are grounded in **Model-Based Systems Engineering (MBSE)** methodologies, leveraging **architecture description languages (ADLs)** such as ACME, AADL, MontiArc, or SysML Internal Block Diagrams (IBDs) to define **component & connector-based architectures**. The system integrates **heterogeneous modeling notations** (e.g., SysML for structure/behavior, Simulink for simulation, or C++/Java for code implementation) and **tools**, requiring **resource management** to handle cross-tool dependencies. **System-wide coordination** is achieved through **compositional hierarchies** (e.g., RFLP methodology) and **behavioral descriptions** (e.g., MontiArc Automaton or SysML state machines), ensuring alignment between functional, logical, and physical layers. The **architecture pattern** is **modular and multi-perspective**, with explicit interfaces and interconnections managed via ADLs, while **active components** (e.g., simulation engines or code modules) process data autonomously, as opposed to passive digital shadows."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle encompasses distinct phases aligned with Model-Based Systems Engineering (MBSE) methodologies, including **development** (where SysML, RFLP, OOSEM, SPES, or SMArDT methodologies are applied) and **operation** (where the Digital Twin functions as an active system). During the **development phase**, the lifecycle progresses through structured abstraction layers: **requirements**, **functional architecture**, **logical architecture**, and **product/technical layer**, utilizing architecture description languages (ADLs) such as ACME, AADL, MontiArc, or SysML Internal Block Diagrams (IBDs) to define components, interfaces, and interconnections. Behavioral modeling is integrated via tools like MontiArc Automaton or SysML state machines, often supplemented by simulation environments (e.g., MathWorks Simulink) or general-purpose programming languages (e.g., C++, Java). Transition management between phases involves **heterogeneous stakeholder integration** and **model harmonization** across diverse notations and tools, ensuring consistency in system representation. Lifecycle governance is implicitly tied to MBSE practices, emphasizing **traceability** and **validation** through iterative modeling and simulation refinements. The Digital Shadow Reference Model (Fig. 1) further contextualizes this by framing the Digital Twin as an evolution from a **passive data aggregation system** (digital shadow) to an **active, autonomous entity** capable of bidirectional data flow and real-time processing."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **fidelity requirements** aligned with MBSE principles, where model accuracy and validity are ensured through **validation and verification (V&V) methods** tied to the system’s abstraction layers. Uncertainty sources are implicitly addressed via **data abstraction and aggregation** from digital shadows (as per [32]), though explicit quantification mechanisms (e.g., statistical error modeling, probabilistic validation) are not detailed in the provided context. Error detection and correction rely on **active DT components** interpreting incoming data flows, but specific protocols (e.g., real-time correction algorithms, anomaly detection frameworks) are not specified. Quality assurance processes leverage **modeling toolchains** (e.g., SysML, Simulink) and **ADLs** to enforce consistency across components, interfaces, and behaviors. The system’s fidelity is constrained by the **passive nature of digital shadows**, which lack autonomous feedback loops, necessitating external software systems to process and validate data. No explicit mention of **sampling-based validation, Monte Carlo simulations, or formal verification** (e.g., model checking) is provided."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for the Digital Shadow (DS) includes **MQTT** as the primary communication protocol for streaming sensor data from physical objects to the digital representation. The document does not specify **network topology/architecture**, **bandwidth/latency requirements**, or **reliability/redundancy mechanisms**, but the use of MQTT implies a **lightweight, event-driven** approach suitable for industrial IoT scenarios. No explicit details on **security protocols** (e.g., TLS, authentication) or **data routing mechanisms** are provided. The DS operates as a **passive entity**, relying on external systems for data interpretation and processing."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Industry 4.0 standards**, particularly through the implementation of **Asset Administration Shells (AAS)**, a key specification for interoperability in smart manufacturing. Data exchange and real-time communication are standardized via **MQTT (Message Queuing Telemetry Transport)**, a lightweight protocol for IoT and industrial telemetry. While the document does not explicitly mention broader certification frameworks (e.g., ISO/IEC, IEC 62443), the use of **AAS** and **MQTT** aligns with **Industry 4.0 Reference Architecture Model (RAMI 4.0)** and **IIoT interoperability standards**. Compliance is implicitly ensured through **model-based systems engineering (MBSE)** practices, which enforce structured, traceable system representations compatible with standardized architectures."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system incorporates **physical safety measures** through a **safety cell** restricting the robot's working range to **[-90°, 90°]** (as referenced in [44], MABI robotic arm specifications). However, the provided documents do not explicitly detail **cybersecurity protocols** (e.g., encryption for MQTT communication, despite MQTT being mentioned in [52] as a protocol for streaming data). The **Asset Administration Shell (AAS) framework** is referenced ([47], [50]) as a structural component for Digital Twin implementation, but the documents do not substantiate claims of inherent **secure data encapsulation** or **access control mechanisms**. **Risk assessment** and **fail-safe mechanisms** are not explicitly described, though **Model-Driven Engineering (MDE)** traceability ([43]) is used to track data point changes, which indirectly supports **safety-critical system considerations** by enabling root-cause analysis of deviations. No explicit **authentication systems** or **threat mitigation strategies** are documented."
]