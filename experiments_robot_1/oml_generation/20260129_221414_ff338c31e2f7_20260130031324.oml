// C3: Physical sensing component
instance PhysicalStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that captures the state of the physical object and sends it automatically as a one‑way flow to the digital twin."
    DTDFVocab:producedData PhysicalStateDataTransmitted
]

// C4: Physical-to-virtual interaction
instance PhysicalStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalStateSensor
]

// C10: Models/Data
instance PhysicalStateData : DTDFVocab:Data [
    base:desc "Digital representation of the physical object's state derived from the transmitted data."
    DTDFVocab:fromData PhysicalStateDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

// C11: Enablers
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that processes the physical state data within the digital twin."
    DTDFVocab:enables DataProcessingService
]

// C6: Services
instance DataProcessingService : DTDFVocab:Service [
    base:desc "Service that updates the digital twin state using the processed physical state data."
    DTDFVocab:provides StateUpdateInsight
]

// C17: Insights/Actions
instance StateUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that the digital twin state has been updated to reflect the current physical object status."
]