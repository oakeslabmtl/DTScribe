// Sensing Component for modeling data aggregation
instance ModelingDataCollector : DTDFVocab:SensingComponent [
    base:desc "Collects heterogeneous modeling artifacts (SysML, ACME, AADL, MontiArc, Simulink) generated during MBSE activities"
    DTDFVocab:producedData ModelingDataTransmitted
]

// Data transmitted from modeling collector
instance ModelingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ModelingDataCollector
]

// Integrated model data derived from transmitted artifacts
instance IntegratedModelData : DTDFVocab:Data [
    base:desc "Aggregated model data spanning requirements, functional, logical, and technical layers"
    DTDFVocab:fromData ModelingDataTransmitted
    DTDFVocab:inputTo MBSEFramework
]

// MBSE framework enabler
instance MBSEFramework : DTDFVocab:Enabler [
    base:desc "Model‑Based Systems‑Engineering toolchain supporting SysML, ACME, AADL, MontiArc, and internal block diagrams"
    DTDFVocab:enables ModelExecutionService
]

// Service that executes integrated models
instance ModelExecutionService : DTDFVocab:Service [
    base:desc "Executes integrated MBSE models and provides insights for system designers"
    DTDFVocab:provides RequirementTraceabilityInsight, AutomaticCodeGeneration
]

// Insight about requirements traceability
instance RequirementTraceabilityInsight : DTDFVocab:Insight [
    base:desc "Shows automatic traceability from requirements to implemented components across model layers"
]

// Action to generate executable code
instance AutomaticCodeGeneration : DTDFVocab:Action [
    base:desc "Generates C++/Java source code from validated models"
    DTDFVocab:IsAutomatic true
]

// Individual model artifacts
instance SysMLModel : DTDFVocab:Model [
    base:desc "SysML model capturing requirements, functional, logical, and technical architectures"
    DTDFVocab:inputTo MBSEFramework
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME architecture description model defining components, connectors, and interfaces"
    DTDFVocab:inputTo MBSEFramework
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL model describing software‑hardware binding and timing properties"
    DTDFVocab:inputTo MBSEFramework
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc component‑and‑connector model for structural composition"
    DTDFVocab:inputTo MBSEFramework
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink simulation model for dynamic behavior"
    DTDFVocab:inputTo SimulationEnvironment
]

instance StateMachineModel : DTDFVocab:Model [
    base:desc "State‑machine model (e.g., MontiArc Automaton) describing component behavior"
    DTDFVocab:inputTo MBSEFramework, SimulationEnvironment
]

// Second chain for simulation

instance SimulationDataCollector : DTDFVocab:SensingComponent [
    base:desc "Acquires simulation results and runtime data from external tools such as Simulink"
    DTDFVocab:producedData SimulationDataTransmitted
]

instance SimulationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationDataCollector
]

instance SimulationModelData : DTDFVocab:Data [
    base:desc "Processed simulation data ready for analysis and decision support"
    DTDFVocab:fromData SimulationDataTransmitted
    DTDFVocab:inputTo SimulationEnvironment
]

instance SimulationEnvironment : DTDFVocab:Enabler [
    base:desc "Simulation environment integrating Simulink, MontiArc Automaton, and custom C++/Java runtimes"
    DTDFVocab:enables SimulationService
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs simulations and provides performance insights"
    DTDFVocab:provides SimulationResultInsight, ExecuteSimulation
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Provides quantitative results such as response times, stability margins, and resource utilization"
]

instance ExecuteSimulation : DTDFVocab:Action [
    base:desc "Triggers automatic execution of the integrated simulation scenario"
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The document states that a Digital Twin follows a Model‑Based Systems‑Engineering (MBSE) lifecycle that is divided into four abstraction levels: (1) requirements modelling, (2) functional architecture, (3) logical architecture, and (4) product/technical layer (physical implementation). The RFLP methodology (Requirements, Functions, Logics, Physics) is cited as a concrete mapping of these stages. At the requirements stage SysML requirement diagrams are used; the functional stage employs SysML block definition and internal block diagrams; the logical stage uses architecture description languages (e.g., ACME, AADL, MontiArc) to capture component‑connector structures; and the product/technical layer is realised with physics‑based simulation models (e.g., Simulink) or executable code in C++/Java. Progression between stages is managed through model‑to‑model refinement and model‑to‑code generation, with MBSE governance ensuring traceability and controlled transitions across the RFLP stages."
]