instance PhysicalSystem : DTDFVocab:Component [
    base:desc "Physical system providing data for aggregation"
]

instance DataTransmittedContextual : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystem
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Contextual data traces aggregated from physical systems and integrated across requirements, functional, logical, and product/technical abstraction levels using tools such as C++ and Java"
    DTDFVocab:inputTo CppEnabler, JavaEnabler
    DTDFVocab:fromData DataTransmittedContextual
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for Model-Based Systems Engineering (MBSE) across abstraction levels (requirements, functional architecture, logical architecture, product/technical layer)"
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP methodology for complexity management"
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for complexity management"
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for complexity management"
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for complexity management"
]

instance ACMEADL : DTDFVocab:Enabler [
    base:desc "ACME architecture description language for component & connector modeling"
]

instance AADLADL : DTDFVocab:Enabler [
    base:desc "AADL architecture description language for component & connector modeling"
]

instance MontiArcADL : DTDFVocab:Enabler [
    base:desc "MontiArc architecture description language for component & connector modeling"
]

instance SysMLIBDsADL : DTDFVocab:Enabler [
    base:desc "SysML IBDs for component & connector modeling"
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavior modeling"
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for analytical simulation"
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for data integration"
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for data integration"
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML for structural component and connector modeling"
    DTDFVocab:inputTo SysMLEnabler
]

instance MontiArcBehavioralModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcAutomatonEnabler
]

instance SysMLStateMachinesModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavioral modeling"
    DTDFVocab:inputTo SysMLEnabler
]

instance SimulinkAnalyticalModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink for analytical simulation"
    DTDFVocab:inputTo SimulinkEnabler
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data governance is enforced through the Asset Administration Shell (AAS) security submodel utilizing Role-Based Access Control (RBAC) for authorization. Privacy protection measures include Transport Layer Security (TLS) encryption for data in transit, implemented in MQTT brokers such as Mosquitto and IoT platforms like Thingsboard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security protocols include authentication via OAuth, X.509 certificates, and JWT tokens; authorization through Role-Based Access Control (RBAC); and encryption of data in transit using TLS. These measures are implemented in the Asset Administration Shell (AAS) security submodel, Mosquitto MQTT broker, and Thingsboard IoT platform. Safety considerations such as fail-safe mechanisms and risk assessment are not detailed in the provided documents."
]