// C3: Physical sensing components (inferred from manufacturing context)
instance ManufacturingAssetSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensing component for manufacturing assets (e.g., machinery, equipment) collecting operational parameters in manufacturing environments."
    DTDFVocab:producedData ManufacturingAssetDataTransmitted
]

// C4: Physical-to-virtual interaction
instance ManufacturingAssetDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Contextual data traces collected from manufacturing assets via one-way physical-to-virtual flow, aggregated for monitoring purposes."
    DTDFVocab:producedFrom ManufacturingAssetSensor
]

// C10: Models/Data
instance ManufacturingAssetGeometricModel : DTDFVocab:Model [
    base:desc "Structural representation of manufacturing assets using SysML Internal Block Diagrams (IBDs) or AADL for component composition."
    DTDFVocab:inputTo SysMLEnabler, AADLEnabler
]

instance ManufacturingAssetBehavioralModel : DTDFVocab:Model [
    base:desc "Dynamic behavior modeling of manufacturing assets using SysML state machines (v1.7) or MontiArc Automaton for state-based processing."
    DTDFVocab:inputTo SysMLEnabler, MontiArcAutomatonEnabler
]

instance ManufacturingAssetAnalyticalModel : DTDFVocab:Model [
    base:desc "Physics/logic abstraction models derived from simulation tools (e.g., MathWorks Simulink) or general-purpose languages (C++/Java)."
    DTDFVocab:inputTo SimulinkEnabler, CppJavaEnabler
]

instance ManufacturingAssetOperationalData : DTDFVocab:Data [
    base:desc "Real-time or near-real-time operational parameters (e.g., sensor readings, state variables) from manufacturing assets."
    DTDFVocab:fromData ManufacturingAssetDataTransmitted
    DTDFVocab:inputTo SysMLEnabler, MontiArcAutomatonEnabler, SimulinkEnabler
]

instance ManufacturingAssetContextualData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces from manufacturing assets for specific analytical purposes."
    DTDFVocab:fromData ManufacturingAssetDataTransmitted
    DTDFVocab:inputTo DigitalShadowEnabler
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering framework using SysML for multi-level abstraction (requirements, functional, logical, product/technical layers)."
    DTDFVocab:enables MonitoringService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Language (ADL) for defining manufacturing asset components, interfaces, and interconnections."
    DTDFVocab:enables MonitoringService
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "Behavioral modeling tool using MontiArc Automaton for state machine-based system behavior in manufacturing assets."
    DTDFVocab:enables MonitoringService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "Simulation tool for detailed dynamic behavior modeling of manufacturing assets using MathWorks Simulink."
    DTDFVocab:enables MonitoringService
]

instance CppJavaEnabler : DTDFVocab:Enabler [
    base:desc "General-purpose programming languages (C++/Java) for implementing system logic or integrating with other tools in manufacturing DTs."
    DTDFVocab:enables MonitoringService
]

instance DigitalShadowEnabler : DTDFVocab:Enabler [
    base:desc "Digital Shadow Reference Model implementation for passive data aggregation and abstraction from manufacturing assets."
    DTDFVocab:enables MonitoringService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Passive data collection service from physical manufacturing objects, aggregating and abstracting contextual data traces for analytics."
    DTDFVocab:provides ManufacturingAssetMonitoringInsight
]

// C17: Insights/Actions
instance ManufacturingAssetMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight derived from aggregated operational and contextual data traces of manufacturing assets for monitoring purposes."
]

// C2: Acting Components (inferred from MBSE methodologies)
instance ManufacturingAssetControlComponent : DTDFVocab:ActingComponent [
    base:desc "Active component for interpreting and processing data flows between physical manufacturing assets and their digital representations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin (DT) system’s orchestration and coordination are implicitly tied to **Model-Based Systems Engineering (MBSE)** methodologies, which rely on **architecture description languages (ADLs)** like ACME, AADL, MontiArc, or SysML Internal Block Diagrams (IBDs) to define **component integration** and **interconnections**. These ADLs describe systems from a **component & connector perspective**, including interfaces, compositions, and (in some cases) behavior via **state machines (SysML v1.7) or MontiArc Automaton**. For **resource management**, the document suggests integration with **simulation tools (e.g., MathWorks Simulink)** or **general-purpose languages (C++, Java)** to model behavior, implying a **hybrid architecture** combining formal modeling with executable code. **System-wide coordination** is not explicitly detailed, but the need to integrate **heterogeneous stakeholders and perspectives** (via MBSE) suggests a **modular, service-oriented orchestration** where components may operate autonomously or be centrally managed depending on the methodology (e.g., RFLP, OOSEM)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **fidelity requirements** aligned with MBSE methodologies, where model validation and verification (V&V) are critical. While the document does not specify exact fidelity metrics, it implies reliance on **formal modeling languages** (e.g., SysML, ADLs) and **simulation tools** (e.g., Simulink [28]) for behavioral/analytical validation. Uncertainty sources may arise from **data abstraction in Digital Shadows** [32] (e.g., aggregated sensor traces) and **model-tool heterogeneity** [31]. Error detection/correction mechanisms are not explicitly detailed, but the system’s **active components** (e.g., DT-specific interpreters [35–37]) suggest dynamic adjustment capabilities. Quality assurance processes are inferred to involve **multi-tool integration** (e.g., SysML + Simulink) and **stakeholder-specific validation** [31], though no specific protocols (e.g., ISO 15926, VDI 2652) are referenced."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The document highlights **horizontal integration** through the use of **MBSE methodologies and tools** to bridge heterogeneous systems. Key aspects include:
  1. **Data Exchange Protocols**: Implicit reliance on **standardized modeling languages** (e.g., SysML, ADLs) and **simulation tools** (e.g., MathWorks Simulink) to ensure interoperability between digital and physical layers.
  2. **Interoperability Standards**: ADLs like **AADL, ACME, or MontiArc** provide frameworks for **component-based integration**, while SysML IBDs enable **logical and physical system alignment**.
  3. **Dependencies on External Systems**: The document emphasizes the need to integrate **multiple tools** (e.g., simulation environments, code in C++/Java) and **stakeholder perspectives**, suggesting **APIs or middleware** (not explicitly named) may be required for seamless data flow.
  4. **Integration Patterns**: The **Digital Shadow Reference Model** (Fig. 1) implies a **one-way data flow** from physical to digital, but DTs extend this by enabling **bidirectional or active processing** via integrated tools. For **enterprise systems**, the document does not specify protocols (e.g., OPC UA, MQTT) but implies **standardized modeling** as a foundational enabler for cross-system compatibility."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system for the MABI MAX 100 serial robot incorporates **safety-critical system considerations** through the implementation of a **physical safety cell** that restricts the operational range of the first vertical axis to **[-90°, 90°]**, ensuring compliance with predefined safety boundaries. **Threat mitigation strategies** are indirectly addressed via the **dual encoder system** (motor encoder and secondary encoder behind the gearbox), which reduces **backlash and positional uncertainty** by cross-referencing encoder data to infer **elasticity and friction** in the drive train, thereby enhancing system reliability. **Fail-safe mechanisms** are implied through the **Siemens SINUMERIK 840D sl CNC controller**, which provides **closed-loop control** with **position, speed, and acceleration inputs** and **target/actual value outputs**, ensuring real-time monitoring and correction of deviations. **Access control mechanisms** are not explicitly detailed, but the **CNC controller’s closed-loop architecture** inherently enforces **authentication and authorization** via its proprietary industrial communication protocols (e.g., PROFINET, Ethernet/IP). **Risk assessment** is partially addressed through the **gear transmission and cycloidal gear design**, which mitigates torque-related failures by distributing mechanical stress across components. **Cybersecurity protocols** are not explicitly mentioned, but the use of a **dedicated industrial CNC controller** suggests adherence to **OT (Operational Technology) security standards**, such as **IEC 62443**, for critical manufacturing systems."
]