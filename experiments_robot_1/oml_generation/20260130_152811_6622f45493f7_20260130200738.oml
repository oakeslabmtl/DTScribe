// C3: Physical sensing component (derived from physical‑to‑virtual interaction description)
instance PhysicalAssetContextualDataCollector : DTDFVocab:SensingComponent [
    base:desc "Collects physical state information as contextual data traces for the digital twin"
    DTDFVocab:producedData AggregatedContextualDataStream
]

// C4: Physical‑to‑virtual interaction data transmission
instance AggregatedContextualDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalAssetContextualDataCollector
]

// C5: Raw data (contextual traces)
instance RawContextualData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted raw contextual data traces before model consumption"
    DTDFVocab:fromData AggregatedContextualDataStream
    DTDFVocab:inputTo SimulinkEngine, MLInferenceEngine
]

// C10: Models / Data (white‑box Simulink)
instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based white‑box Simulink dynamic simulation model capturing nonlinear effects"
    DTDFVocab:inputTo SimulinkEngine
]

// C10: Models / Data (black‑box machine learning)
instance MachineLearningNonLinearModel : DTDFVocab:Model [
    base:desc "Data‑driven black‑box machine‑learning model capturing nonlinear effects"
    DTDFVocab:inputTo MLInferenceEngine
]

// C11: Enablers (execution environments)
instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "Execution environment for Simulink models, part of the mixed‑paradigm approach"
    DTDFVocab:enables SimulationService
]

instance MLInferenceEngine : DTDFVocab:Enabler [
    base:desc "Inference engine for machine‑learning models, providing predictions for the digital twin"
    DTDFVocab:enables MLInferenceService
]

// C6: Services (invoke models)
instance SimulationService : DTDFVocab:Service [
    base:desc "Invokes Simulink simulation to transform raw data into higher‑level abstractions"
    DTDFVocab:provides CalculatedProcessIndicators, OperatorDecisionSupportAction
]

instance MLInferenceService : DTDFVocab:Service [
    base:desc "Executes machine‑learning model to generate derived process indicators"
    DTDFVocab:provides CalculatedProcessIndicators
]

// C17: Insight (decision‑support information)
instance CalculatedProcessIndicators : DTDFVocab:Insight [
    base:desc "Derived process indicators presented to operators for decision‑support"
]

// C17: Action (operator interaction)
instance OperatorDecisionSupportAction : DTDFVocab:Action [
    base:desc "Allows operators to query or visualise insights to adjust process parameters"
    DTDFVocab:IsAutomatic false
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin development follows a Model‑Based Systems‑Engineering (MBSE) lifecycle split into abstraction layers: (1) requirements engineering, (2) functional architecture modelling, (3) logical architecture modelling, and (4) product/technical layer (physical implementation). These stages are represented with SysML models during the development phase and later instantiated as concrete digital shadow components that evolve into the operational Digital Twin. Transition between stages is managed by mapping/conforming relations between abstract reference models and concrete class diagrams, as described in the Digital Shadow Reference Model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is upheld by maintaining traceability from SysML specifications to the generated simulation (white‑box) and machine‑learning (black‑box) models, ensuring that transformations are verified for correctness. The reliability of the Digital Twin is directly tied to the correctness of these models and the quality of the sensor data they consume. Validation is performed by comparing model outputs against the measured data from the position encoders, and any discrepancies trigger model refinement. Uncertainty is addressed through systematic verification of model‑data consistency and by adhering to the traceability mechanisms defined in the digital‑shadow reference model."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the physical devices to the digital shadow using the MQTT publish/subscribe protocol, as indicated by the citation of the Mosquitto MQTT server/client implementation. The MQTT broker mediates communication between edge sensors and the cloud‑based Thingsboard IoT platform, which receives the topics and provides visualization. The documents do not specify the underlying network topology, bandwidth, latency, reliability mechanisms, or security protocols beyond the use of MQTT as the communication protocol."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on several established standards: SysML (OMG standard) for system structure and behavior models; architecture description languages such as ACME, AADL, and MontiArc, which are standardized ADL families; and simulation/modeling tools like MathWorks Simulink. The Digital Shadow Reference Model itself is defined as a UML class diagram, adhering to UML standards. Conformance relations between reference and concrete class diagrams are used to ensure compliance with the underlying modeling standards."
]