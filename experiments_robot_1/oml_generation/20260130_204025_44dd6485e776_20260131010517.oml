// Sensing Components
instance DrivePositionEncoder1 : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on drive unit 1 measuring inclination and wheel rotation."
    DTDFVocab:producedData DrivePositionData1
]

instance DrivePositionEncoder2 : DTDFVocab:SensingComponent [
    base:desc "Second position encoder mounted on drive unit 1 providing redundancy in incline measurement."
    DTDFVocab:producedData DrivePositionData2
]

instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted directly on the motor shaft to capture shaft rotation and torque."
    DTDFVocab:producedData MotorShaftPositionData
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearbox to monitor gear tooth position."
    DTDFVocab:producedData GearboxPositionData
]

// Data Transmitted
instance DrivePositionData1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DrivePositionEncoder1
    base:desc "JSON payload transmitted over MQTT containing timestamped position data from DrivePositionEncoder1."
]

instance DrivePositionData2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DrivePositionEncoder2
    base:desc "JSON payload transmitted over MQTT containing timestamped position data from DrivePositionEncoder2."
]

instance MotorShaftPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
    base:desc "JSON payload transmitted over MQTT containing timestamped shaft rotation data from MotorShaftEncoder."
]

instance GearboxPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
    base:desc "JSON payload transmitted over MQTT containing timestamped gearbox position data from GearboxPositionEncoder."
]

// Processed Data
instance AggregatedDriveMeasurement : DTDFVocab:Data [
    base:desc "Aggregated, filtered and synthesised drive measurement data derived from all four position encoders."
    DTDFVocab:fromData DrivePositionData1, DrivePositionData2, MotorShaftPositionData, GearboxPositionData
    DTDFVocab:inputTo DataProcessingStack
]

// Data Processing Enabler
instance DataProcessingStack : DTDFVocab:Enabler [
    base:desc "Data processing stack that aggregates, filters and synthesises raw sensor traces into higher‑level contextual data."
    DTDFVocab:enables AnalysisService, PredictionService, ControlService
]

// Services
instance AnalysisService : DTDFVocab:Service [
    base:desc "Analysis service that consumes aggregated drive measurements to derive position insights."
    DTDFVocab:provides DrivePositionInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Prediction service that forecasts future torque demand based on aggregated drive data."
    DTDFVocab:provides TorquePredictionInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Control service that generates actuation commands using predictions and real‑time measurements."
    DTDFVocab:provides ControlCommandAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service that runs closed‑loop grey‑box studies in Simulink for validation."
    DTDFVocab:provides SimulationInsight
]

// Insights and Actions
instance DrivePositionInsight : DTDFVocab:Insight [
    base:desc "Insight derived from aggregated drive position data indicating current inclination status."
]

instance TorquePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive insight forecasting torque requirement for the upcoming control cycle."
]

instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Automatic action producing control commands for drive actuators based on predictions."
    DTDFVocab:IsAutomatic true
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight generated from closed‑loop Simulink simulations validating system behavior."
]

// Model Processing Enabler
instance ModelProcessingStack : DTDFVocab:Enabler [
    base:desc "Enabler that consumes system architecture and behavior models for simulation and code generation."
    DTDFVocab:enables SimulationService
]

// Models/Artifacts
instance SysMLRequirementsDiagram : DTDFVocab:Model [
    base:desc "SysML v1.7 Requirements diagram representing system needs and constraints."
    DTDFVocab:inputTo ModelProcessingStack
]

instance SysMLFunctionalArchitectureDiagram : DTDFVocab:Model [
    base:desc "SysML v1.7 Functional Architecture diagram detailing system functions."
    DTDFVocab:inputTo ModelProcessingStack
]

instance SysMLLogicalArchitectureDiagram : DTDFVocab:Model [
    base:desc "SysML v1.7 Logical Architecture diagram depicting component interfaces."
    DTDFVocab:inputTo ModelProcessingStack
]

instance ACMEComponentConnectorModel : DTDFVocab:Model [
    base:desc "ACME component‑connector model describing component composition and connections."
    DTDFVocab:inputTo ModelProcessingStack
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL architecture model providing execution and resource constraints."
    DTDFVocab:inputTo ModelProcessingStack
]

instance MontiArcSubsystemModel : DTDFVocab:Model [
    base:desc "MontiArc subsystem model capturing system component hierarchy."
    DTDFVocab:inputTo ModelProcessingStack
]

instance MontiArcAutomataBehaviorModel : DTDFVocab:Model [
    base:desc "MontiArc automata model expressing behavior of system components."
    DTDFVocab:inputTo ModelProcessingStack
]

instance SysMLStateMachineBehaviorModel : DTDFVocab:Model [
    base:desc "SysML state machine model representing behavior transitions."
    DTDFVocab:inputTo ModelProcessingStack
]

instance SimulinkClosedLoopSimulationModel : DTDFVocab:Model [
    base:desc "Simulink model for closed‑loop grey‑box simulation of the digital twin."
    DTDFVocab:inputTo ModelProcessingStack
]

instance CodeGenTemplateCPlusPlus : DTDFVocab:Model [
    base:desc "C++ code generation template for model‑based components."
    DTDFVocab:inputTo ModelProcessingStack
]

instance CodeGenTemplateJava : DTDFVocab:Model [
    base:desc "Java code generation template for model‑based components."
    DTDFVocab:inputTo ModelProcessingStack
]

// Digital Shadow Reference Model
instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "Digital Shadow Reference Model providing the data backbone for raw sensor measurements, data traces, aggregation, filtering, and context synthesis."
    DTDFVocab:inputTo ModelProcessingStack
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Development phases follow a hierarchical abstraction sequence: requirements, functional architecture, logical architecture, and product/technical layers, with transitions managed by MBSE practices (e.g., SysML, ADLs, state machines)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity concerns focus on reducing backlash and positional uncertainty in the mechanical drive, thereby improving the robot control’s accuracy. Validation is performed by comparing simulated data against measured data streams; deviations are identified as a measure of model validity. Failure to achieve acceptable alignment between simulation and observation triggers corrective model adjustments, and continuous monitoring ensures that model fidelity remains within defined tolerances."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adopts a set of modeling standards to ensure consistency and interoperability. It uses SysML and UML, both defined by the Object Management Group (OMG), for structural and behavioral modeling. Component‑connector interactions are modeled with Architecture Description Languages (ADLs) such as ACME, AADL, and MontiArc, the latter providing an automaton extension for state‑based behavior. Behavioral sequencing is further supported by SysML v1.7 state machine diagrams and MontiArc Automaton formulations. For simulation and validation, MathWorks Simulink is integrated to execute the models. No explicit mention of industry certification programs, compliance frameworks, or additional interoperability standards is provided in the document."
]