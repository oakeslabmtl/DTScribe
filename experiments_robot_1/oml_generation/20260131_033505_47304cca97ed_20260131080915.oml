// C3: Physical Sensing Components
instance JointPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-precision position encoder measuring output angle for each axis of the MABI MAX 100 serial robot, providing real-time joint position data."
    DTDFVocab:producedData JointPositionDataTransmitted
]

instance JointCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring input current for each axis's permanent magnet synchronous motor, enabling torque estimation and motor health monitoring."
    DTDFVocab:producedData JointCurrentDataTransmitted
]

instance SafetyCellSensor : DTDFVocab:SensingComponent [
    base:desc "Safety cell sensor enforcing operational constraints by monitoring the robot's working range and triggering safety interventions when boundaries are exceeded."
    DTDFVocab:producedData SafetyConstraintDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance JointPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointPositionEncoder
]

instance JointCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointCurrentSensor
]

instance SafetyConstraintDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SafetyCellSensor
]

// C10: Models/Data
instance RobotKinematicModel : DTDFVocab:Model [
    base:desc "Physics-based model representing the 6-axis kinematic structure of the MABI MAX 100 robot, including forward/inverse kinematics calculations and joint limits."
    DTDFVocab:inputTo SysMLModelingTool, MathWorksSimulink
]

instance RobotDynamicModel : DTDFVocab:Model [
    base:desc "Dynamic behavior model capturing mass properties, inertia, and force/torque relationships for each axis, enabling simulation of motion profiles and load effects."
    DTDFVocab:inputTo MathWorksSimulink, MontiArcAutomaton
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model of the robot's control architecture, including state machines for operational modes (e.g., idle, motion, emergency stop) as defined in SysML v1.7 or MontiArc Automaton."
    DTDFVocab:inputTo MontiArcAutomaton, MathWorksSimulink
]

instance RobotCADModel : DTDFVocab:Model [
    base:desc "Geometric CAD representation of the MABI MAX 100 robot, including assembly structures, collision meshes, and spatial relationships between components."
    DTDFVocab:inputTo SysMLModelingTool
]

instance JointPositionData : DTDFVocab:Data [
    base:desc "Real-time joint position data collected from encoders, aggregated into operational cycles for kinematic analysis and trajectory verification."
    DTDFVocab:fromData JointPositionDataTransmitted
    DTDFVocab:inputTo MathWorksSimulink, AssetAdministrationShell
]

instance JointCurrentData : DTDFVocab:Data [
    base:desc "Current measurements from motor drives, processed to derive torque estimates and energy consumption patterns for predictive maintenance."
    DTDFVocab:fromData JointCurrentDataTransmitted
    DTDFVocab:inputTo MathWorksSimulink, AssetAdministrationShell
]

instance SafetyConstraintData : DTDFVocab:Data [
    base:desc "Operational constraint data including joint angle limits, velocity profiles, and payload restrictions enforced by the safety cell."
    DTDFVocab:fromData SafetyConstraintDataTransmitted
    DTDFVocab:inputTo AssetAdministrationShell, MontiArcAutomaton
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Aggregated and preprocessed data traces representing higher-level operational patterns (e.g., motion cycles, energy consumption) for anomaly detection and performance optimization."
    DTDFVocab:fromData JointPositionData, JointCurrentData, SafetyConstraintData
    DTDFVocab:inputTo AssetAdministrationShell, VisualizationDashboard
]

// C11: Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML-based toolchain for multi-layered system description, including Internal Block Diagrams (IBDs) for component-connector modeling and state machines for behavioral specification (SysML v1.7)."
    DTDFVocab:enables RobotModelIntegrationService, ContextualAbstractionService
]

instance MathWorksSimulink : DTDFVocab:Enabler [
    base:desc "Simulation environment for behavioral modeling and co-simulation of control logic, kinematics, and dynamic responses with real-time data streams."
    DTDFVocab:enables DynamicBehaviorSimulationService, DataIngestionService
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "Architecture Description Language (ADL) tool for component-connector modeling of control architectures, including state machines for operational behavior."
    DTDFVocab:enables ControlLogicSimulationService, SafetyConstraintValidationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Standardized framework for semantic interoperability, enabling structured data exchange between physical robot and digital shadow via MQTT and other protocols."
    DTDFVocab:enables DataIngestionService, ContextualAbstractionService
]

instance MQTTProtocol : DTDFVocab:Enabler [
    base:desc "Lightweight publish-subscribe protocol for real-time, low-latency transmission of sensor data from robot to digital shadow's data ingestion layer."
    DTDFVocab:enables DataIngestionService
]

instance CPlusPlusMiddleware : DTDFVocab:Enabler [
    base:desc "Custom middleware implemented in C++ for bridging simulation tools (Simulink) with AAS/MQTT pipelines, handling data format conversions and protocol translations."
    DTDFVocab:enables DataIngestionService, DynamicBehaviorSimulationService
]

instance VisualizationDashboard : DTDFVocab:Enabler [
    base:desc "SysML/UML-compatible dashboard for real-time and historical visualization of data traces, supporting monitoring and diagnostics for stakeholders."
    DTDFVocab:enables MonitoringService, DiagnosticService
]

// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving each axis of the MABI MAX 100 robot, controlled via Siemens SINUMERIK 840D sl controller with position, speed, and acceleration inputs."
]

instance SiemensSINUMERIK840DController : DTDFVocab:ActingComponent [
    base:desc "Real-time controller accepting position, speed, and acceleration commands for axis actuation, enforcing safety constraints via integrated safety cell."
]

// C6: Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Automated one-way ingestion of state data (joint positions, velocities, sensor readings) from physical robot via MQTT and Asset Administration Shells."
    DTDFVocab:provides RealTimeDataIngestionInsight
]

instance ContextualAbstractionService : DTDFVocab:Service [
    base:desc "Aggregation and preprocessing of raw sensor data into higher-level contextual traces (e.g., operational cycles, energy consumption patterns)."
    DTDFVocab:provides ContextualDataTracesInsight
]

instance DynamicBehaviorSimulationService : DTDFVocab:Service [
    base:desc "Simulation of robot's dynamic behavior using physics-based models in MathWorks Simulink, synchronized with real-time data streams."
    DTDFVocab:provides DynamicBehaviorInsight
]

instance ControlLogicSimulationService : DTDFVocab:Service [
    base:desc "Behavioral modeling and simulation of control logic using MontiArc Automaton or SysML state machines, validating operational modes and transitions."
    DTDFVocab:provides ControlLogicValidationInsight
]

instance SafetyConstraintValidationService : DTDFVocab:Service [
    base:desc "Validation of safety constraints (joint limits, velocity profiles) against real-time operational data to ensure compliance with working range."
    DTDFVocab:provides SafetyComplianceInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of operational data traces via dashboards, enabling continuous monitoring of robot performance and state."
    DTDFVocab:provides OperationalMonitoringInsight
]

instance DiagnosticService : DTDFVocab:Service [
    base:desc "Analysis of contextual data traces for anomaly detection and fault signature identification in robot operations."
    DTDFVocab:provides FaultDetectionInsight
]

instance RobotModelIntegrationService : DTDFVocab:Service [
    base:desc "Integration of heterogeneous models (kinematic, dynamic, control) across SysML, Simulink, and MontiArc, ensuring traceability and consistency."
    DTDFVocab:provides ModelIntegrationInsight
]

// C17: Insights/Actions
instance RealTimeDataIngestionInsight : DTDFVocab:Insight [
    base:desc "Confirmation of successful real-time data acquisition from all physical sensing components without loss or corruption."
]

instance ContextualDataTracesInsight : DTDFVocab:Insight [
    base:desc "Generated higher-level operational patterns (e.g., motion cycles, energy consumption) for downstream analysis and optimization."
]

instance DynamicBehaviorInsight : DTDFVocab:Insight [
    base:desc "Simulated dynamic responses of the robot under various load conditions, validated against real-time sensor data."
]

instance ControlLogicValidationInsight : DTDFVocab:Insight [
    base:desc "Verification of control logic behavior across operational modes, including state transitions and emergency stop responses."
]

instance SafetyComplianceInsight : DTDFVocab:Insight [
    base:desc "Assessment of real-time operational compliance with predefined safety constraints (e.g., joint limits, velocity thresholds)."
]

instance OperationalMonitoringInsight : DTDFVocab:Insight [
    base:desc "Continuous visualization of robot state and performance metrics for real-time operational oversight by maintenance teams."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identified anomalies or fault signatures in operational data traces, categorized by severity and potential root cause."
]

instance ModelIntegrationInsight : DTDFVocab:Insight [
    base:desc "Confirmed consistency and traceability across heterogeneous models (kinematic, dynamic, control) within the digital twin constellation."
]

// C1: Environment
instance ManufacturingAutomationEnvironment : DTDFVocab:Environment [
    base:desc "Industrial automation context where the MABI MAX 100 serial robot operates, requiring high-precision motion control and real-time synchronization."
    base:contains PermanentMagnetSynchronousMotor, SiemensSINUMERIK840DController, JointPositionEncoder, JointCurrentSensor, SafetyCellSensor
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system, as described in the context of a **Digital Shadow Reference Model**, operates under a **one-way, automated data flow** from the physical object to its digital representation, implying a **real-time or near-real-time synchronization** between the physical and digital components. While explicit synchronization frequencies or latency requirements are not specified, the model emphasizes **live measurements** and **contextual data traces** aggregation, suggesting a need for **low-latency data acquisition** to maintain fidelity between the physical and digital states. The system relies on **active components** (e.g., software modules or simulation tools like MathWorks Simulink) to process incoming data, which may introduce temporal constraints depending on the complexity of the data abstraction and analysis workflows. The **temporal granularity** is implicitly tied to the **purpose-driven aggregation** of data traces, where finer granularity may be required for dynamic systems (e.g., manufacturing processes) to ensure accurate decision-making or predictive capabilities."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system’s orchestration and coordination are grounded in **Model-Based Systems Engineering (MBSE)** methodologies, leveraging **architecture description languages (ADLs)** such as **ACME, AADL, MontiArc, or SysML Internal Block Diagrams (IBDs)** to define the system’s **component & connector perspective**. These ADLs describe the **composition, interfaces, and interconnections** of system components, while extensions like **MontiArc Automaton or SysML state machines** enable behavioral modeling. The system integrates **heterogeneous modeling tools** (e.g., SysML for structural/logical architecture, MathWorks Simulink for detailed behavioral simulation, or general-purpose languages like C++/Java for implementation), necessitating **cross-tool coordination** to maintain consistency across abstraction layers. The **Digital Shadow Reference Model** further emphasizes the role of **active components** (e.g., software modules) to interpret and process incoming data, implying a **centralized or hybrid orchestration** where data flows from physical objects to digital representations are managed via predefined workflows. However, explicit patterns like **service-oriented or event-driven architectures** are not detailed in the provided context."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through **comparative validation** between simulated and measured data, leveraging integrated simulation tools (e.g., Simulink) and MBSE methodologies. **Uncertainty sources** are acknowledged, particularly **positional uncertainty**, though explicit quantification methods are not detailed. Validation processes rely on **traceability** between physical and digital representations, while **error detection** is inferred from data integration workflows. No explicit **quality assurance protocols** (e.g., ISO standards, formal verification) or **correction mechanisms** (e.g., adaptive calibration) are described in the provided documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system must integrate with **external systems and tools** to handle **heterogeneous modeling notations and tools**, as highlighted by the need to 'cope with models in different modeling notations and different tools' (e.g., SysML for architecture, Simulink for simulation, or C++/Java for implementation). While the document does not specify **enterprise system integration** (e.g., ERP/MES) or **standardized protocols** (e.g., OPC UA, MQTT), the **data exchange** between physical objects and their digital shadows implies dependencies on **real-time data acquisition protocols** (e.g., IoT protocols) and **interoperability mechanisms** to bridge disparate tools. The system’s scope is primarily focused on **internal modeling tool integration** (e.g., linking SysML models to simulation tools), but broader **horizontal integration** with external Digital Twins or enterprise systems is not explicitly addressed in the provided context."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE)** standards, particularly leveraging **SysML (Systems Modeling Language)** for system modeling across abstraction layers. For architecture description, it aligns with **ADL (Architecture Description Language) standards**, including **ACME**, **AADL (Architecture Analysis & Design Language)**, and **SysML IBDs (Internal Block Diagrams)**. Behavioral modeling may incorporate **SysML state machines** or **MontiArc Automaton** standards. Interoperability is facilitated through integration with **simulation tools** (e.g., **MathWorks Simulink**) and **general-purpose programming languages** (e.g., **C++**, **Java**), though no explicit interoperability standards (e.g., OPC UA, FIWARE, or ISO/IEC standards) are mentioned. The context does not specify **certification requirements** or **compliance frameworks**, nor does it detail **industry-specific standards** (e.g., ISO 23223 for Digital Twins or IEC 62424 for manufacturing)."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The provided documents do not explicitly address comprehensive cybersecurity protocols, access control mechanisms, or authentication systems for Digital Twin systems. However, **Document [44]** (MABI robotic arm) references a **physical safety cell** as a safety measure to restrict the robot's operational range, ensuring human safety during operation. No evidence of fail-safe mechanisms, risk assessment methodologies, or compliance frameworks (e.g., ISO 26262, IEC 61508) is provided in the context of Digital Twins or automation systems. The documents also do not mention threat mitigation strategies, data encryption, or regulatory compliance (e.g., GDPR, NIST) for Digital Twin data governance."
]