// C3: Physical sensing components
instance OperationalStateSensor : DTDFVocab:SensingComponent [
    base:desc "Collects operational metrics and equipment status from physical manufacturing assets for real-time monitoring and contextual data traces."
    DTDFVocab:producedData OperationalStateDataTransmitted
]

instance ProductionLogSensor : DTDFVocab:SensingComponent [
    base:desc "Aggregates production logs and operational performance data from manufacturing equipment for historical analysis and system optimization."
    DTDFVocab:producedData ProductionLogDataTransmitted
]

instance ContextualDataTraceSensor : DTDFVocab:SensingComponent [
    base:desc "Collects heterogeneous contextual data traces from physical objects including sensor readings, operational states, and environmental factors for digital twin integration."
    DTDFVocab:producedData ContextualDataTraceTransmitted
]

// C4: Physical-to-virtual interaction
instance OperationalStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalStateSensor
    base:desc "Automated one-way transmission of real-time operational states and equipment status from physical assets to digital representation."
]

instance ProductionLogDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProductionLogSensor
    base:desc "Event-triggered transmission of production logs and operational metrics from manufacturing systems for digital twin analysis."
]

instance ContextualDataTraceTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContextualDataTraceSensor
    base:desc "Aggregated contextual data traces collected from physical objects via automated flows, including sensor readings and operational states."
]

// C10: Models/Data
instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based functional architecture model capturing system requirements, functions, and logical architecture layers using RFLP methodology."
    DTDFVocab:inputTo SysMLToolchainEnabler, MBSEMethodologyEnabler
]

instance MontiArcComponentConnectorModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description model defining components, interfaces, and interconnections with behavioral extensions via MontiArc Automaton."
    DTDFVocab:inputTo MontiArcToolchainEnabler, ADLIntegrationEnabler
]

instance SimulinkPhysicsBasedModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for physics-based simulations and control system validation, integrated with digital twin behavioral modeling."
    DTDFVocab:inputTo SimulinkToolchainEnabler, SimulationIntegrationEnabler
]

instance StateMachineBehavioralModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model for behavioral modeling of system components, enabling dynamic simulation and validation."
    DTDFVocab:inputTo SysMLToolchainEnabler, BehavioralModelingEnabler
]

instance OperationalStateData : DTDFVocab:Data [
    base:desc "Real-time operational state data collected from physical assets, including equipment status and sensor readings for monitoring services."
    DTDFVocab:fromData OperationalStateDataTransmitted
    DTDFVocab:inputTo MonitoringServiceEnabler, PredictionServiceEnabler
]

instance ProductionLogData : DTDFVocab:Data [
    base:desc "Historical production logs and operational metrics aggregated from manufacturing systems for optimization and failure prediction."
    DTDFVocab:fromData ProductionLogDataTransmitted
    DTDFVocab:inputTo OptimizationServiceEnabler, VisualizationServiceEnabler
]

instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces from physical objects, processed and normalized for digital twin analysis across multiple abstraction layers."
    DTDFVocab:fromData ContextualDataTraceTransmitted
    DTDFVocab:inputTo SimulationIntegrationEnabler, ControlAutomationEnabler
]

// C11: Enablers
instance SysMLToolchainEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based toolchain enabling requirements management, functional/logical architecture modeling, and state machine behavioral modeling."
    DTDFVocab:enables MonitoringService, PredictionService, VisualizationService
]

instance MontiArcToolchainEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc architecture description language toolchain for component-connector modeling with behavioral extensions via MontiArc Automaton."
    DTDFVocab:enables ControlAutomationService, OptimizationService
]

instance SimulinkToolchainEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation engine for physics-based and control system modeling, integrated with digital twin behavioral validation."
    DTDFVocab:enables PredictionService, ControlAutomationService
]

instance MBSEMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodologies (RFLP, OOSEM, SPES, SMArDT) for managing multi-abstraction modeling and stakeholder alignment."
    DTDFVocab:enables MonitoringService, OptimizationService, VisualizationService
]

instance ADLIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Language integration platform (ACME, AADL, MontiArc) for component-connector modeling and interoperability."
    DTDFVocab:enables ControlAutomationService, SimulationIntegrationService
]

instance SimulationIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation integration platform enabling co-simulation between SysML, ADLs, and MathWorks Simulink for digital twin validation."
    DTDFVocab:enables PredictionService, OptimizationService
]

instance BehavioralModelingEnabler : DTDFVocab:Enabler [
    base:desc "Behavioral modeling enabler using SysML state machines and MontiArc Automaton for dynamic system validation and control logic."
    DTDFVocab:enables ControlAutomationService, PredictionService
]

instance MonitoringServiceEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring service enabler aggregating and abstracting contextual data traces for real-time and historical analysis."
    DTDFVocab:enables MonitoringService
]

instance ControlAutomationEnabler : DTDFVocab:Enabler [
    base:desc "Control automation enabler implementing active components for bidirectional data processing and autonomous system adjustments."
    DTDFVocab:enables ControlAutomationService
]

instance PredictionServiceEnabler : DTDFVocab:Enabler [
    base:desc "Prediction service enabler leveraging simulation models for failure prediction, performance optimization, and system behavior forecasting."
    DTDFVocab:enables PredictionService
]

instance OptimizationServiceEnabler : DTDFVocab:Enabler [
    base:desc "Optimization service enabler using simulation-driven methodologies to refine system architectures and operational parameters."
    DTDFVocab:enables OptimizationService
]

instance VisualizationServiceEnabler : DTDFVocab:Enabler [
    base:desc "Visualization service enabler integrating multi-notation models into unified dashboards for heterogeneous stakeholder alignment."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Aggregates and abstracts contextual data traces from physical systems for real-time and historical analysis across multiple abstraction layers."
    DTDFVocab:provides RealTimeMonitoringInsight, HistoricalAnalysisInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Leverages modeling tools (Simulink, ADLs) to simulate system behavior, predict failures, and optimize performance using state machines and physics-based models."
    DTDFVocab:provides FailurePredictionInsight, PerformanceOptimizationInsight
]

instance ControlAutomationService : DTDFVocab:Service [
    base:desc "Implements active components to interpret data and push decisions back to the physical system, enabling autonomous adjustments via C++/Java control logic."
    DTDFVocab:provides AutonomousAdjustmentAction, ClosedLoopControlInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Integrates multi-notation models (SysML diagrams, simulation outputs) into unified dashboards for stakeholders, supporting heterogeneous perspective alignment."
    DTDFVocab:provides UnifiedDashboardInsight, StakeholderAlignmentInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Uses simulation-driven methodologies (RFLP, OOSEM) to refine system architectures or operational parameters based on digital twin insights."
    DTDFVocab:provides ArchitectureRefinementInsight, ParameterOptimizationInsight
]

instance SimulationIntegrationService : DTDFVocab:Service [
    base:desc "Enables co-simulation between SysML, ADLs, and simulation tools for digital twin validation and cross-tool interoperability."
    DTDFVocab:provides CrossToolValidationInsight, SimulationConsistencyInsight
]

// C17: Insights/Actions
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time operational state monitoring providing immediate feedback on equipment status and sensor readings for proactive maintenance."
]

instance HistoricalAnalysisInsight : DTDFVocab:Insight [
    base:desc "Historical production log analysis enabling trend identification and long-term performance optimization."
]

instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive failure analysis using physics-based simulations and state machine models to anticipate system malfunctions."
]

instance PerformanceOptimizationInsight : DTDFVocab:Insight [
    base:desc "Performance optimization recommendations derived from simulation-driven analysis of operational parameters."
]

instance AutonomousAdjustmentAction : DTDFVocab:Action [
    base:desc "Autonomous system adjustments implemented via control logic to maintain optimal operational states."
    DTDFVocab:IsAutomatic true
]

instance ClosedLoopControlInsight : DTDFVocab:Insight [
    base:desc "Closed-loop control system insights enabling bidirectional interaction between digital twin and physical system for autonomous management."
]

instance UnifiedDashboardInsight : DTDFVocab:Insight [
    base:desc "Unified visualization dashboard integrating SysML diagrams, simulation outputs, and operational data for cross-domain stakeholders."
]

instance StakeholderAlignmentInsight : DTDFVocab:Insight [
    base:desc "Multi-perspective stakeholder alignment through integrated visualization of heterogeneous modeling notations and data sources."
]

instance ArchitectureRefinementInsight : DTDFVocab:Insight [
    base:desc "System architecture refinement recommendations based on simulation-driven validation and optimization methodologies."
]

instance ParameterOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized operational parameters derived from digital twin insights and simulation analysis."
]

instance CrossToolValidationInsight : DTDFVocab:Insight [
    base:desc "Cross-tool validation results ensuring consistency between SysML, ADLs, and simulation models in the digital twin ecosystem."
]

instance SimulationConsistencyInsight : DTDFVocab:Insight [
    base:desc "Simulation consistency metrics validating the alignment between digital twin models and physical system behavior."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system’s orchestration and coordination are grounded in Model-Based Systems Engineering (MBSE) methodologies, where architecture description languages (ADLs) like MontiArc or SysML IBDs define component integration, interconnections, and composition. The system-wide coordination leverages behavioral models (e.g., state machines in SysML v1.7 or MontiArc Automaton) to describe dynamic interactions. Resource management is implied through the use of simulation tools (e.g., MathWorks Simulink) or general-purpose languages (C++, Java) for detailed behavior modeling. The architecture patterns may include centralized control (e.g., a single master digital twin managing subordinate instances) or decentralized federated models, where multiple twins collaborate via standardized interfaces. The document highlights the need to integrate diverse modeling notations and tools, suggesting a constellation of tightly coupled or loosely coupled components depending on the use case."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **validation and verification (V&V) methods** to ensure model fidelity, though specific techniques are not detailed in the provided document. Uncertainty sources and quantification are implied through the **one-way data flow from physical objects to digital representations** (as per the Digital Shadow Reference Model), where passive data collection may introduce **latency, abstraction errors, or missing contextual traces**. Error detection and correction mechanisms are not explicitly described, but the system relies on **active software components** (e.g., in DTs) to interpret and process incoming data, suggesting post-processing validation. Quality assurance processes are inferred from the **MBSE framework**, which mandates structured modeling across abstraction layers (e.g., requirements to technical implementation) and integration of **heterogeneous tools** (e.g., SysML, Simulink) to cross-validate models. The absence of explicit error correction protocols implies reliance on **modeling tool-specific checks** (e.g., SysML consistency rules) or external simulation-based validation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **hosting and deployment infrastructure** for a Digital Twin (DT) system is not explicitly detailed in the provided document. However, the broader context of **Model-Based Systems Engineering (MBSE)** and **Digital Shadow Reference Models** implies that deployment may occur across **heterogeneous platforms** (e.g., cloud, edge, or on-premise) to accommodate diverse stakeholder needs and system complexity. Computational and storage requirements are likely **highly dependent on the application**, with potential use of **scalable architectures** (e.g., microservices, containerization via Docker/Kubernetes) to handle dynamic workloads. Deployment models may include **hybrid cloud-edge solutions** for latency-sensitive applications or **monolithic deployments** for simpler use cases. **Availability and reliability assurance** would typically rely on **redundancy mechanisms** (e.g., failover systems, replication) and **fault-tolerant designs**, though specific implementations are not provided in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration in the Digital Twin system is enabled through interoperability mechanisms defined by architecture description languages (ADLs) such as ACME, AADL, or SysML, which standardize component interfaces and data exchange protocols. Integration with external systems (e.g., enterprise systems, other Digital Twins, or IoT platforms) relies on these ADLs to ensure compatibility across heterogeneous tools and stakeholders. The document does not specify exact protocols (e.g., OPC UA, MQTT) but implies adherence to interoperability standards to facilitate data exchange. Dependencies on external systems are managed via the logical architecture layer, where interfaces and connectors are explicitly modeled. Integration patterns may include service-oriented architectures (SOA) or event-driven communication, though the document does not detail these further. The emphasis on MBSE methodologies ensures that external integrations are traceable and aligned with system requirements."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE) standards**, particularly leveraging **SysML** (Systems Modeling Language) for system modeling across abstraction layers. For **architecture description**, it complies with **ADLs (Architecture Description Languages)** such as **ACME**, **AADL**, and **MontiArc**, which standardize component-based system representation. Behavioral modeling aligns with **SysML v1.7 state machines** or **MontiArc Automaton** for formalized system behavior. Interoperability is facilitated through integration with **simulation tools** (e.g., **MathWorks Simulink**) and **general-purpose programming languages** (e.g., **C++**, **Java**), ensuring compatibility with broader engineering workflows. While the document does not specify **certification requirements** or **compliance frameworks**, the use of standardized modeling languages implies adherence to **ISO/IEC 15288 (Systems Engineering)** and **IEEE 1471 (Architecture Description)** principles. **Interoperability standards** are implicitly supported via toolchain integration (e.g., SysML with simulation tools), though no explicit protocols (e.g., OPC UA, FIWARE) are mentioned."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system for the MABI MAX 100 serial robot incorporates **safety-critical system considerations** through the integration of a **safety cell** that restricts the maximum working range of the first vertical axis to **[-90°, 90°]**, ensuring operational boundaries are enforced. **Cybersecurity and access control** are implicitly addressed via the **Siemens SINUMERIK 840D sl CNC controller**, which manages **authentication and authorization** for control inputs (e.g., position, speed, acceleration) and outputs (e.g., target/actual values, motor current). The system employs **redundant sensor validation** via **two position encoders per drive** (motor encoder and secondary encoder post-gearbox), enabling **backlash mitigation** and **positional uncertainty reduction** by cross-referencing encoder discrepancies to infer drive train elasticity and friction. **Fail-safe mechanisms** are implied through the **gear transmission and cycloidal gear design**, which ensure torque integrity (τ_G → τ_out) and mechanical stability. **Risk assessment** is partially addressed by the **75°/s maximum speed limit** and the **0.06 mm path repeatability/0.1 mm positional accuracy** specifications, which define operational tolerances for safety-critical machining tasks. No explicit mention of **data anonymization, consent management, or compliance frameworks** (e.g., GDPR) is provided in the document."
]