// Sensing component collecting contextual data traces from physical objects
instance PhysicalObjectContextSensor : DTDFVocab:SensingComponent [
    base:desc "Collects contextual data traces from physical objects through an automated one-way data flow"
    DTDFVocab:producedData DataTransmittedContext
]

// Data transmitted downstream from the sensor
instance DataTransmittedContext : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalObjectContextSensor
]

// Contextual data aggregated per the Digital Shadow reference model
instance ContextualData : DTDFVocab:Data [
    base:desc "Contextual data traces collected from physical objects and aggregated according to the Digital Shadow reference model"
    DTDFVocab:fromData DataTransmittedContext
    DTDFVocab:inputTo MontiArcEnabler
    DTDFVocab:inputTo CodeGenerationEnabler
]

// Enabler that leverages MontiArc Automaton for behavioral modeling
instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that utilizes MontiArc Automaton within the Digital Twin to model system behavior"
    DTDFVocab:enables MontiArcExecutionService
]

// Service that executes MontiArc automata derived from the system’s functional architecture
instance MontiArcExecutionService : DTDFVocab:Service [
    base:desc "Service that executes MontiArc automata based on the SysML v1.7 state machine definitions"
    DTDFVocab:provides StateMachineExecutionInsight
]

// Insight into the state machine execution of the Digital Twin
instance StateMachineExecutionInsight : DTDFVocab:Insight [
    base:desc "Insight into the state machine execution per SysML v1.7 specifications"
]

// Enabler for code generation pipelines producing executable code in C++/Java
instance CodeGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that manages code generation pipelines for executable execution in C++ or Java"
    DTDFVocab:enables CodeGenerationService
]

// Service responsible for generating executable code from models
instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Service that generates executable code from the Digital Twin models"
    DTDFVocab:provides CodeGenerationAction
]

// Action that automatically generates executable code
instance CodeGenerationAction : DTDFVocab:Action [
    base:desc "Generates executable code for the Digital Twin"
    DTDFVocab:IsAutomatic true
]

// Model describing system components, interfaces, and composition via SysML IBDs and ADL links
instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML v1.7 model describing system components, interfaces, interconnections, and composition with IBDs and ADL composition links"
    DTDFVocab:inputTo MontiArcEnabler
    DTDFVocab:inputTo CodeGenerationEnabler
]