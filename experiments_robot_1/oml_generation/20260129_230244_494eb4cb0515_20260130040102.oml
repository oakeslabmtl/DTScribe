// C2: Acting Components
instance ElectricalDriveActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical drive of the permanent‑magnet synchronous motor via the torque‑producing current input (I_M) that delivers rotational effort to the gearbox; the DT can actuate the PT by commanding this current."
]

// C3: Physical sensing components
instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted directly on the permanent‑magnet synchronous motor for measuring angular position r_M."
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder mounted on the gearbox for measuring angular position r_G and derived output position r_out."
    DTDFVocab:producedData GearboxPositionDataTransmitted
    DTDFVocab:producedData OutputPositionDataTransmitted
]

instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring the torque‑producing motor current I_M."
    DTDFVocab:producedData CurrentDataTransmitted
]

// C4: Physical–to–virtual data transmitted via MQTT
instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

instance OutputPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
]

// C10: Data (Measured)
instance MeasuredMotorPositionData : DTDFVocab:Data [
    base:desc "Measurable motor position trace r_M time‑stamped and received via MQTT."
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo MQTTEnabler
]

instance MeasuredGearboxPositionData : DTDFVocab:Data [
    base:desc "Measurable gearbox position trace r_G time‑stamped and received via MQTT."
    DTDFVocab:fromData GearboxPositionDataTransmitted
    DTDFVocab:inputTo MQTTEnabler
]

instance MeasuredOutputPositionData : DTDFVocab:Data [
    base:desc "Measurable output position trace r_out time‑stamped and received via MQTT."
    DTDFVocab:fromData OutputPositionDataTransmitted
    DTDFVocab:inputTo MQTTEnabler
]

instance MeasuredCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current trace I_M time‑stamped and received via MQTT."
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo MQTTEnabler
]

// C10: Derived Data (Computed by Processing component)
instance MeasuredTorqueData : DTDFVocab:Data [
    base:desc "Computed motor torque derived from the measured current I_M."
    DTDFVocab:fromData MeasuredCurrentData
    DTDFVocab:inputTo MQTTEnabler
]

instance MeasuredAngularVelocityData : DTDFVocab:Data [
    base:desc "Computed angular velocity derived from position traces r_M and r_G."
    DTDFVocab:fromData MeasuredMotorPositionData
    DTDFVocab:inputTo MQTTEnabler
]

instance MeasuredAccelerationData : DTDFVocab:Data [
    base:desc "Computed angular acceleration derived from successive angular velocity measurements."
    DTDFVocab:fromData MeasuredAngularVelocityData
    DTDFVocab:inputTo MQTTEnabler
]

// C10: Models (Simulation and Structural)
instance MotorSimulationModel : DTDFVocab:Model [
    base:desc "Simulink block model of the permanent‑magnet synchronous motor for executable simulation."
    DTDFVocab:inputTo SimulinkEnabler
]

instance GearboxSimulationModel : DTDFVocab:Model [
    base:desc "Simulink block model of the gear transmission for executable simulation."
    DTDFVocab:inputTo SimulinkEnabler
]

instance CycloidalGearSimulationModel : DTDFVocab:Model [
    base:desc "Simulink block model of the cycloidal gear for executable simulation."
    DTDFVocab:inputTo SimulinkEnabler
]

// C10: Structural Engineering Model
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML structural diagram representing the motor, gearbox, and cycloidal gear for MBSE."
    DTDFVocab:inputTo SysMLEnabler
]

// C10: Data linking through AAS
instance DataLinkStatusData : DTDFVocab:Data [
    base:desc "Status of data linking through the Asset Administration Shell (AAS)."
    DTDFVocab:fromData MeasuredCurrentData
    DTDFVocab:inputTo AASEnabler
]

// C11: Enablers (Tooling and Runtime Support)
instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker for real‑time streaming of sensor data from the PT to the DT."
    DTDFVocab:enables FrictionModelIdentificationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "Simulink environment for executable simulation models."
    DTDFVocab:enables ModelRefinementService
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML tooling for MBSE structural modeling."
    DTDFVocab:enables DataLinkingService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for model linking and metadata management."
    DTDFVocab:enables DataLinkingService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard visualization libraries for real‑time monitoring."
    DTDFVocab:enables VisualizationMonitoringService
]

instance DigitalShadowEnabler : DTDFVocab:Enabler [
    base:desc "Digital Shadow Reference Model organizer for structuring data and metadata."
    DTDFVocab:enables DataLinkingService
]

// C6: Services
instance FrictionModelIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of white‑box and black‑box joint friction models."
    DTDFVocab:provides FrictionParameterUpdateInsight
]

instance ModelRefinementService : DTDFVocab:Service [
    base:desc "Continuous model refinement using simulation results."
    DTDFVocab:provides ControllerGainSuggestionInsight
]

instance VisualizationMonitoringService : DTDFVocab:Service [
    base:desc "Visualization and monitoring of DT data via an integrated dashboard."
    DTDFVocab:provides WearDetectionAlertInsight
]

instance DataLinkingService : DTDFVocab:Service [
    base:desc "Data linking through the Asset Administration Shell (AAS)."
    DTDFVocab:provides DataLinkStatusInsight
]

instance MaintenanceSchedulingService : DTDFVocab:Service [
    base:desc "Service for proposing maintenance scheduling actions based on controller gains and wear‑detection alerts."
    DTDFVocab:provides MaintenanceSchedulingAction
]

// C17: Insights and Actions
instance FrictionParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Updated friction parameters for joints based on real‑time sensor data."
]

instance WearDetectionAlertInsight : DTDFVocab:Insight [
    base:desc "Wear‑detection alerts derived from sensor traces."
]

instance ControllerGainSuggestionInsight : DTDFVocab:Insight [
    base:desc "Suggested controller gains for maintenance scheduling based on model refinement."
]

instance DataLinkStatusInsight : DTDFVocab:Insight [
    base:desc "Status indication of data linkage via the Asset Administration Shell."
]

instance MaintenanceSchedulingAction : DTDFVocab:Action [
    base:desc "Suggested maintenance scheduling action based on controller gains and wear‑detection alerts."
    DTDFVocab:IsAutomatic true
]

// C14: Components (system internal parts)
instance MotorComponent : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor forming the first axis of the MABI MAX 100 industrial robot."
]

instance GearboxComponent : DTDFVocab:Component [
    base:desc "Gear transmission (gearbox) transferring motor torque to the cycloidal gear."
]

instance CycloidalGearComponent : DTDFVocab:Component [
    base:desc "Cycloidal gear completing the power transmission chain of the first axis."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT outputs updated friction model parameters and torque compensation signals for the motor controller, which are written back to the PT’s controller (e.g., modified torque setpoints) to improve motion accuracy."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time with the same sampling frequency as the sensor data streams (milliseconds to sub‑millisecond latency) to enable continuous friction identification and immediate feedback."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated DT comprising a central Processing component, simulation models, engineering and data‑calculation models, data traces, and an Asset Administration Shell connected via MQTT; displayed through a unified dashboard for monitoring and control."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans all lifecycle phases: designed (ideal frictionless simulation), manufactured (parameter extraction from physical asset models), and operated (live, continuous identification and adaptive control during robot operation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity achieved by comparing simulated torque/angular velocity to measured values; continuous parameter estimation for white‑box and black‑box models; traceability of data traces to their generating models; model complexity trade‑off discussed (white‑box vs black‑box)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT broker for transmitting sensor data and model outputs; AAS interfaces provide semantic linkage; data streams annotated with metadata for provenance; all communications conform to ISO 19458 (AAS) and IEEE‐1451.3 (wireless sensor nodes where used)."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Utilizes ISO 19458 for Asset Administration Shells, SysML v1.7 for MBSE, and MQTT (RFC 7546) for data transport; follows best practices for model‐based engineering."
]