// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Heterogeneous IoT/embedded sensor capturing real-time operational parameters for contextual data aggregation in the digital shadow reference model"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded sensor measuring mechanical vibration patterns for component health monitoring and degradation analysis"
    DTDFVocab:producedData VibrationDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Distributed sensor network capturing environmental parameters (temperature, humidity, pressure) for system performance context"
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

instance OperationalLogSensor : DTDFVocab:SensingComponent [
    base:desc "System log collector aggregating operational traces and event logs for behavioral analysis"
    DTDFVocab:producedData OperationalLogDataTransmitted
]

// C4: Physical-to-Virtual Data Transmission
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance VibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance OperationalLogDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalLogSensor
]

// C10: Models/Data
instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated and abstracted sensor data traces representing system state for purpose-specific analysis as defined in Digital Shadow reference model"
    DTDFVocab:fromData TemperatureDataTransmitted, VibrationDataTransmitted, EnvironmentalDataTransmitted, OperationalLogDataTransmitted
    DTDFVocab:inputTo DataAggregationMiddleware
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based functional decomposition of system into functional blocks using RFLP methodology (Requirements, Functions, Logics, Physics)"
    DTDFVocab:inputTo SysMLModelingTool
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "AADL/MontiArc component-connector system model representing components, connectors, and interfaces with defined behavioral specifications"
    DTDFVocab:inputTo ArchitectureAnalysisTool
]

instance BehavioralSimulationModel : DTDFVocab:Model [
    base:desc "Simulink-based dynamic system simulation model implementing control logic and signal processing for behavioral analysis"
    DTDFVocab:inputTo SimulationEngine
]

instance DegradationModel : DTDFVocab:Model [
    base:desc "SysML/AADL-based component degradation model correlating physical data with predicted wear-and-tear patterns"
    DTDFVocab:inputTo HealthMonitoringTool
]

instance TimeSeriesForecastModel : DTDFVocab:Model [
    base:desc "LSTM/ARIMA-based time-series forecasting model integrated with digital twin simulations for prognostic analytics"
    DTDFVocab:inputTo AnalyticsEngine
]

// C11: Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML toolchain supporting Internal Block Diagrams, state machines, and parametric diagrams for functional/logical architecture modeling"
    DTDFVocab:enables FunctionalArchitectureService, LogicalArchitectureService
]

instance ArchitectureAnalysisTool : DTDFVocab:Enabler [
    base:desc "AADL/MontiArc toolset for component-based architecture analysis with automata-based behavioral specification"
    DTDFVocab:enables ArchitectureValidationService, ComponentInteractionService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for dynamic system simulation with integration capabilities for SysML/AADL models"
    DTDFVocab:enables BehavioralSimulationService, ControlStrategyService
]

instance DataAggregationMiddleware : DTDFVocab:Enabler [
    base:desc "Middleware layer processing raw sensor data through aggregation and abstraction pipelines for contextual data trace creation"
    DTDFVocab:enables MonitoringService, AnomalyDetectionService, HealthMonitoringService
]

instance AnalyticsEngine : DTDFVocab:Enabler [
    base:desc "General-purpose analytics platform integrating time-series models, pattern recognition algorithms, and predictive analytics"
    DTDFVocab:enables PrognosticAnalyticsService, ScenarioSimulationService
]

instance HealthMonitoringTool : DTDFVocab:Enabler [
    base:desc "Specialized toolset for component health evaluation correlating physical data with degradation models"
    DTDFVocab:enables HealthMonitoringService
]

instance ControlStrategyEngine : DTDFVocab:Enabler [
    base:desc "Embedded control logic implementation in C++/Java for real-time feedback control strategies"
    DTDFVocab:enables ClosedLoopControlService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time state tracking service aggregating sensor data and operational traces through bidirectional data flows"
    DTDFVocab:provides SystemStateInsight, OperationalTraceInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Pattern recognition service identifying deviations from expected behavior using simulation-integrated algorithms"
    DTDFVocab:provides AnomalyAlertAction, DeviationInsight
]

instance HealthMonitoringService : DTDFVocab:Service [
    base:desc "Component degradation evaluation service correlating physical data with digital degradation models"
    DTDFVocab:provides ComponentHealthInsight, WearAndTearAlertAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Parameter tuning service adjusting system configurations using optimization algorithms linked to logical architecture models"
    DTDFVocab:provides OptimalConfigurationInsight, ResourceAllocationAction
]

instance PrognosticAnalyticsService : DTDFVocab:Service [
    base:desc "Future state forecasting service combining time-series models with digital twin simulations for predictive analytics"
    DTDFVocab:provides FailureForecastInsight, PerformanceTrendAction
]

instance ScenarioSimulationService : DTDFVocab:Service [
    base:desc "What-if analysis service enabling parameter perturbation and outcome simulation using logical/physical models"
    DTDFVocab:provides ScenarioOutcomeInsight, DecisionSupportAction
]

instance ClosedLoopControlService : DTDFVocab:Service [
    base:desc "Feedback control implementation service using real-time data to adjust actuators and system parameters"
    DTDFVocab:provides ControlAdjustmentAction, SystemStabilityInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Multi-abstraction visualization service rendering hierarchical models through interactive dashboards"
    DTDFVocab:provides VisualizedInsight, CustomizableViewAction
]

instance FunctionalArchitectureService : DTDFVocab:Service [
    base:desc "SysML-based functional architecture service supporting design validation and stakeholder perspectives"
    DTDFVocab:provides DesignValidationInsight
]

instance LogicalArchitectureService : DTDFVocab:Service [
    base:desc "Component-connector architecture service enabling decentralized system modeling and validation"
    DTDFVocab:provides ArchitectureConsistencyInsight
]

// C17: Insights/Actions
instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Aggregated real-time system state representation derived from sensor data and operational traces"
]

instance OperationalTraceInsight : DTDFVocab:Insight [
    base:desc "Historical operational pattern analysis enabling trend identification and root cause analysis"
]

instance AnomalyAlertAction : DTDFVocab:Action [
    base:desc "Automated alert generation for detected deviations from expected system behavior"
    DTDFVocab:IsAutomatic true
]

instance DeviationInsight : DTDFVocab:Insight [
    base:desc "Pattern-based analysis of system behavior deviations with confidence metrics"
]

instance ComponentHealthInsight : DTDFVocab:Insight [
    base:desc "Predicted component health status correlating physical measurements with degradation models"
]

instance WearAndTearAlertAction : DTDFVocab:Action [
    base:desc "Proactive maintenance trigger based on predicted component degradation"
    DTDFVocab:IsAutomatic true
]

instance OptimalConfigurationInsight : DTDFVocab:Insight [
    base:desc "System configuration parameters optimized through multi-objective algorithms"
]

instance ResourceAllocationAction : DTDFVocab:Action [
    base:desc "Automated resource distribution based on optimization framework recommendations"
    DTDFVocab:IsAutomatic true
]

instance FailureForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted failure modes and timing based on time-series forecasting models"
]

instance PerformanceTrendAction : DTDFVocab:Action [
    base:desc "Performance optimization recommendations based on trend analysis"
    DTDFVocab:IsAutomatic false
]

instance ScenarioOutcomeInsight : DTDFVocab:Insight [
    base:desc "Simulated outcomes of parameter perturbations enabling what-if analysis"
]

instance DecisionSupportAction : DTDFVocab:Action [
    base:desc "Strategic planning recommendations based on scenario simulations"
    DTDFVocab:IsAutomatic false
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Real-time actuator adjustments based on feedback control strategies"
    DTDFVocab:IsAutomatic true
]

instance SystemStabilityInsight : DTDFVocab:Insight [
    base:desc "Current system stability assessment based on control performance metrics"
]

instance VisualizedInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D/2D representation of hierarchical system models"
]

instance CustomizableViewAction : DTDFVocab:Action [
    base:desc "Role-specific data visualization customization for different stakeholder perspectives"
    DTDFVocab:IsAutomatic false
]

instance DesignValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results for functional architecture models against requirements"
]

instance ArchitectureConsistencyInsight : DTDFVocab:Insight [
    base:desc "Consistency verification between logical architecture components and connectors"
]

