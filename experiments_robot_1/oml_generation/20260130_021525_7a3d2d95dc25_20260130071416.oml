instance OperationalStateSensor : DTDFVocab:SensingComponent [
    base:desc "Collects contextual data traces from the physical system including operational states and environmental parameters for digital twin integration."
    DTDFVocab:producedData OperationalStateDataTransmitted
]

instance SensorDataCollector : DTDFVocab:SensingComponent [
    base:desc "Aggregates heterogeneous sensor readings (e.g., IoT sensors, PLCs, SCADA systems) via standardized communication protocols (OPC UA, MQTT, HTTP/REST)."
    DTDFVocab:producedData SensorDataTransmitted
]

instance OperationalStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalStateSensor
    base:desc "Transmits operational state data traces from physical system to digital twin with data validation, normalization, and filtering for quality assurance."
]

instance SensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SensorDataCollector
    base:desc "Transmits raw sensor data (e.g., temperature, pressure, environmental parameters) from heterogeneous sources to digital twin infrastructure."
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "Defines component-based functional architecture using SysML Internal Block Diagrams (IBDs) or Architecture Description Languages (ADLs) like ACME/AADL."
    DTDFVocab:inputTo SysMLToolchain, MontiArcToolchain
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Describes component interfaces, interconnections, and composition hierarchies using ADLs (e.g., MontiArc, AADL) or SysML IBDs."
    DTDFVocab:inputTo MontiArcToolchain, SysMLToolchain
]

instance BehavioralStateMachineModel : DTDFVocab:Model [
    base:desc "Captures system behavior using SysML v1.7 state machines or MontiArc Automaton for dynamic analysis and validation."
    DTDFVocab:inputTo SimulinkIntegration, MontiArcToolchain
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Physics-based simulation model implemented in MathWorks Simulink or other simulation engines for dynamic system behavior prediction."
    DTDFVocab:inputTo SimulinkIntegration
]

instance ContextualDataStore : DTDFVocab:Data [
    base:desc "Aggregated and preprocessed contextual data traces (sensor readings, operational logs) stored for real-time and historical analysis."
    DTDFVocab:fromData OperationalStateDataTransmitted, SensorDataTransmitted
    DTDFVocab:inputTo DataProcessingPipeline, TimeSeriesDatabase
]

instance HeterogeneousDataFeed : DTDFVocab:Data [
    base:desc "Raw and processed data from diverse sources (IoT, PLCs, SCADA) integrated into the digital twin's data management layer."
    DTDFVocab:fromData SensorDataTransmitted
    DTDFVocab:inputTo DataProcessingPipeline
]

instance SysMLToolchain : DTDFVocab:Enabler [
    base:desc "SysML-based modeling environment supporting multi-layered abstraction (requirements, functional/logical architectures) and state machine behavior modeling."
    DTDFVocab:enables DataAcquisitionService, MonitoringDiagnosticsService, VisualizationService
]

instance MontiArcToolchain : DTDFVocab:Enabler [
    base:desc "MontiArc framework for component-based architecture definition and MontiArc Automaton for behavioral modeling with cross-tool interoperability."
    DTDFVocab:enables DataAcquisitionService, SimulationPredictionService, ControlOptimizationService
]

instance SimulinkIntegration : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink integration for dynamic simulation, control system modeling, and physics-based validation of digital twin components."
    DTDFVocab:enables SimulationPredictionService, ControlOptimizationService
]

instance DataProcessingPipeline : DTDFVocab:Enabler [
    base:desc "ETL pipeline for data validation, normalization, filtering, and transformation of raw sensor data into actionable insights."
    DTDFVocab:enables MonitoringDiagnosticsService, VisualizationService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time-series database (e.g., InfluxDB, TimescaleDB) for storing and querying contextual data traces with temporal granularity."
    DTDFVocab:enables MonitoringDiagnosticsService
]

instance ModelIntegrationFramework : DTDFVocab:Enabler [
    base:desc "Cross-tool interoperability framework (e.g., FMI, DDS, OPC UA) enabling seamless integration between SysML, ADLs, and simulation tools."
    DTDFVocab:enables CrossDomainIntegrationService
]

instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Actively collects, aggregates, and abstracts contextual data traces from the physical system with bidirectional data flow capabilities."
    DTDFVocab:provides DataAcquisitionInsight
]

instance MonitoringDiagnosticsService : DTDFVocab:Service [
    base:desc "Enables real-time or near-real-time monitoring of system components and interconnections using ADL-defined interfaces and behavioral models."
    DTDFVocab:provides AnomalyDetectionInsight, SystemHealthInsight
]

instance SimulationPredictionService : DTDFVocab:Service [
    base:desc "Integrates simulation tools to predict system behavior, validate designs, and optimize operational parameters under varying conditions."
    DTDFVocab:provides BehaviorPredictionInsight, DesignValidationInsight
]

instance ControlOptimizationService : DTDFVocab:Service [
    base:desc "Provides active components to interpret data and adjust physical system parameters via automated control loops or optimization algorithms."
    DTDFVocab:provides ParameterAdjustmentAction, OptimizationRecommendationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Offers multi-perspective visualization of system models (functional/logical architectures, simulation results) for stakeholder-specific decision-making."
    DTDFVocab:provides VisualizedModelInsight, DecisionSupportInsight
]

instance CrossDomainIntegrationService : DTDFVocab:Service [
    base:desc "Facilitates heterogeneous tool integration combining ADLs for architecture, simulation tools for dynamics, and code for custom logic."
    DTDFVocab:provides UnifiedModelInsight
]

instance DataAcquisitionInsight : DTDFVocab:Insight [
    base:desc "Real-time contextual data aggregation enabling bidirectional interaction between physical and virtual systems."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Identified deviations or anomalies in system components using behavioral models and ADL-defined interfaces."
]

instance SystemHealthInsight : DTDFVocab:Insight [
    base:desc "Comprehensive health status of system components and interconnections derived from monitoring data."
]

instance BehaviorPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted system behavior under varying conditions generated through simulation integration."
]

instance DesignValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results of system designs through simulation-driven approaches and formal verification techniques."
]

instance ParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated adjustment of physical system parameters based on real-time data interpretation."
    DTDFVocab:IsAutomatic true
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimized operational parameters and recommendations derived from control optimization algorithms."
]

instance VisualizedModelInsight : DTDFVocab:Insight [
    base:desc "Multi-perspective visual representations of system models for stakeholder-specific analysis."
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Actionable insights for strategic decision-making based on integrated system data and models."
]

instance UnifiedModelInsight : DTDFVocab:Insight [
    base:desc "Consolidated view of heterogeneous models across different tools and notations for cross-domain analysis."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin (DT) constellation** is implicitly defined through the **Model-Based Systems Engineering (MBSE)** framework, which employs **multi-layered abstraction** (requirements, functional, logical, and product/technical layers) and **architecture description languages (ADLs)** like ACME, AADL, or MontiArc to orchestrate system-wide coordination. The document highlights the use of **component & connector perspectives** (e.g., interfaces, interconnections, and composition) to manage **resource management** and **system integration**. Behavioral descriptions are supported via **state machines (SysML v1.7)** or **MontiArc Automaton**, enabling **dynamic coordination** between components. The integration of **simulation tools (e.g., MathWorks Simulink)** and **general-purpose languages (C++, Java)** further suggests a **hybrid orchestration** approach, combining **model-driven and code-driven execution**. However, no explicit architecture patterns (e.g., microservices, service-oriented) or system-wide coordination protocols (e.g., event-driven, publish-subscribe) are detailed."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **fidelity and validity considerations** through structured **validation and verification (V&V) methods** embedded in MBSE workflows. **Model fidelity** is ensured by aligning computational models (e.g., behavioral/analytical models in SysML or Simulink) with **physical system requirements**, while **uncertainty sources** (e.g., sensor noise, model approximations) are quantified via **statistical analysis or simulation-based error propagation** (e.g., using tools like Simulink or domain-specific simulators [29], [30]). **Error detection and correction mechanisms** may involve **automated anomaly detection** in data streams (e.g., from digital shadows) or **model calibration loops** where physical feedback refines digital representations. **Quality assurance processes** include **traceability matrices** (linking requirements to models) and **cross-validation** between heterogeneous tools (e.g., SysML for architecture, Simulink for dynamics). The system’s **digital shadow reference model** (Fig. 1) implicitly supports validity by aggregating **contextual data traces** for abstraction, though explicit V&V methodologies are not detailed in the provided context."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for a Digital Twin (DT) system is not explicitly detailed in the provided documents. However, the broader context of **Model-Based Systems Engineering (MBSE)** and **Digital Shadow Reference Model** implies reliance on **heterogeneous communication protocols** (e.g., OPC UA for industrial automation, MQTT for IoT, or HTTP/REST for cloud services) to facilitate data exchange between physical and digital layers. The **network topology** may adopt a **hybrid architecture** (e.g., edge computing for low-latency local processing and cloud for centralized analytics), with **bandwidth and latency requirements** varying by use case (e.g., real-time control demanding sub-100ms latency). **Reliability and redundancy mechanisms** (e.g., failover protocols, data replication) are critical to ensure uninterrupted operation, while **security protocols** (e.g., TLS/SSL, role-based access control) must safeguard data integrity and confidentiality during transmission. The infrastructure must support **interoperability** across tools (e.g., SysML, Simulink, or general-purpose languages like C++/Java) used in DT development [17], [28], [31]."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **hosting and deployment infrastructure** for a Digital Twin (DT) system is not explicitly specified in the provided documents. However, the **Model-Based Systems Engineering (MBSE)** framework suggests a **multi-layered deployment model**, potentially leveraging **cloud, edge, or on-premise platforms** depending on computational and storage demands. **Scalability mechanisms** (e.g., containerization via Docker, orchestration via Kubernetes) may be employed to handle dynamic workloads, while **availability/reliability assurance** could involve redundancy, load balancing, and high-availability clustering. The deployment must integrate with **heterogeneous tools** (e.g., SysML for architecture modeling, Simulink for simulation, or C++/Java for custom logic), requiring **interoperability standards** (e.g., OMG’s SysML, FIWARE for IoT) to unify disparate components. The choice of platform (e.g., AWS IoT Greengrass for edge, Azure Digital Twins for cloud) would depend on the DT’s **real-time processing needs, data volume, and stakeholder accessibility** [17], [28], [31]."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The document emphasizes **horizontal integration** through the **interoperability challenges** inherent in MBSE, where **heterogeneous modeling notations** (e.g., SysML, ADLs) and **tools** (Simulink, C++, Java) must coexist. **Data exchange protocols** are not explicitly named, but the reliance on **ADLs (e.g., AADL, MontiArc)** and **SysML IBDs** implies adherence to **standardized interface definitions** (e.g., ports, connectors) for **inter-system communication**. The document also references **digital shadow integration** (via one-way data flow), suggesting dependencies on **external physical systems** and **enterprise data aggregation** mechanisms. No specific interoperability standards (e.g., OPC UA, MQTT) or integration patterns (e.g., API gateways, ESBs) are mentioned, but the **passive data collection** model of digital shadows implies a need for **external active components** (e.g., middleware) to process and distribute data across DTs or enterprise systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE)** standards, particularly leveraging **SysML** (Systems Modeling Language) for system description and **Architecture Description Languages (ADLs)** such as **ACME**, **AADL**, **MontiArc**, and **SysML IBDs** for component-based modeling. Interoperability is facilitated through integration with simulation tools like **MathWorks Simulink** and general-purpose programming languages (**C++**, **Java**), ensuring compliance with broader software engineering standards. While the document does not specify exact **certification frameworks** or **industry standards** (e.g., ISO, IEC, or domain-specific norms like **IEC 62443** for cybersecurity or **ISO 22400** for manufacturing), the use of **MBSE** and **ADLs** implies alignment with **systems engineering best practices** (e.g., **INCOSE** standards). **Interoperability standards** are indirectly supported by the modular and tool-agnostic nature of MBSE, enabling data exchange across heterogeneous systems. The **Digital Shadow Reference Model** (Fig. 1) further suggests adherence to **UML-based modeling standards** for class diagrams and data aggregation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system for the MABI MAX 100 serial robot incorporates **safety-critical system considerations** through the integration of a **safety cell** that restricts the maximum working range of the first vertical axis to **[-90°, 90°]**, ensuring operational boundaries are enforced. **Fail-safe mechanisms** are implicitly addressed via the **dual encoder system** (motor encoder and secondary encoder behind the gearbox), which mitigates backlash and positional uncertainty by cross-referencing encoder data to infer elasticity and friction in the drive train. The **Siemens SINUMERIK 840D sl CNC controller** provides **cybersecurity and safety protocols** by enabling controlled access to axis inputs (position, speed, acceleration) and outputs (target/actual position, derivatives, motor current), though explicit details on authentication, threat mitigation, or compliance with regulations (e.g., ISO 26262, IEC 62443) are not specified. **Risk assessment** is indirectly supported by the system’s ability to derive torque (τ_M, τ_G, τ_out) from motor current (I_M) using known motor constants, enabling predictive maintenance and fault detection. No explicit mention of **data anonymization**, **consent management**, or **data sharing agreements** is provided."
]