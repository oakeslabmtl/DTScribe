// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Senses motor current for Axis 1 using Hall-effect current sensor with 0.1 A resolution"
    DTDFVocab:producedData MotorCurrentDataTransmission
]
instance MotorTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Measures motor block temperature for Axis 1 with 0.5 °C accuracy via thermistor"
    DTDFVocab:producedData MotorTemperatureDataTransmission
]
instance MotorTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Captures motor output torque for Axis 1 using a strain-gauge torque transducer (±0.1 Nm)"
    DTDFVocab:producedData MotorTorqueDataTransmission
]
instance EncoderPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Provides incremental encoder position for Axis 1 with 0.01° resolution"
    DTDFVocab:producedData EncoderPositionDataTransmission
]

// C4: Physical‑to‑virtual interaction
instance MotorCurrentDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]
instance MotorTemperatureDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorTemperatureSensor
]
instance MotorTorqueDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorTorqueSensor
]
instance EncoderPositionDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderPositionSensor
]

// C10: Models/Data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Motor current time‑series data trace, published via MQTT topic 'robot/axis1/current'"
    DTDFVocab:fromData MotorCurrentDataTransmission
    DTDFVocab:inputTo MonitoringEnabler, FrictionEnabler, DiagnosticsEnabler, MaintenanceEnabler, DashboardEnabler, SimulationEnabler
]
instance MotorTemperatureData : DTDFVocab:Data [
    base:desc "Motor temperature time‑series data trace, published via MQTT topic 'robot/axis1/temperature'"
    DTDFVocab:fromData MotorTemperatureDataTransmission
    DTDFVocab:inputTo MonitoringEnabler, FrictionEnabler, DiagnosticsEnabler, MaintenanceEnabler, DashboardEnabler, SimulationEnabler
]
instance MotorTorqueData : DTDFVocab:Data [
    base:desc "Motor torque time‑series data trace, published via MQTT topic 'robot/axis1/torque'"
    DTDFVocab:fromData MotorTorqueDataTransmission
    DTDFVocab:inputTo MonitoringEnabler, FrictionEnabler, DiagnosticsEnabler, MaintenanceEnabler, DashboardEnabler, SimulationEnabler
]
instance EncoderPositionData : DTDFVocab:Data [
    base:desc "Encoder position time‑series data trace, published via MQTT topic 'robot/axis1/encoder'"
    DTDFVocab:fromData EncoderPositionDataTransmission
    DTDFVocab:inputTo MonitoringEnabler, TrajectoryEnabler, DiagnosticsEnabler, MaintenanceEnabler, DashboardEnabler, SimulationEnabler
]

instance CADStructuralModel : DTDFVocab:Model [
    base:desc "CAD geometry of the MABI MAX 100 robot arm, used for visualisation and kinematic calculations"
    DTDFVocab:inputTo SimulationEnabler
]
instance KinematicModel : DTDFVocab:Model [
    base:desc "Forward and inverse kinematic model derived from CAD, parameterised in SysML"
    DTDFVocab:inputTo SimulationEnabler
]
instance MotorGearTrainSimModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the permanent‑magnet synchronous motor and cycloidal geartrain dynamics"
    DTDFVocab:inputTo SimulationEnabler
]
instance FrictionIdentificationModel : DTDFVocab:Model [
    base:desc "Hybrid white‑box/black‑box multi‑physics model for real‑time joint friction estimation"
    DTDFVocab:inputTo SimulationEnabler
]
instance TrajectoryOptimizationModel : DTDFVocab:Model [
    base:desc "Optimization solver for motion trajectory planning based on live sensor data"
    DTDFVocab:inputTo SimulationEnabler
]
instance PredictiveMaintenanceAnalyticsModel : DTDFVocab:Model [
    base:desc "Predictive maintenance analytics model to anticipate wear‑related failures"
    DTDFVocab:inputTo SimulationEnabler
]
instance SimulationValidationModel : DTDFVocab:Model [
    base:desc "Model validation ensemble for comparing simulated data traces with measured sensor traces"
    DTDFVocab:inputTo SimulationEnabler
]

// C11: Enablers
instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Processes sensor data streams for real‑time monitoring and trend analysis"
    DTDFVocab:enables RealTimeMonitoringService
]
instance FrictionEnabler : DTDFVocab:Enabler [
    base:desc "Feeds sensor data into the friction identification model for hybrid estimation"
    DTDFVocab:enables FrictionIdentificationService
]
instance TrajectoryEnabler : DTDFVocab:Enabler [
    base:desc "Provides sensor data to the trajectory optimisation solver for online trajectory planning"
    DTDFVocab:enables TrajectoryOptimizationService
]
instance DiagnosticsEnabler : DTDFVocab:Enabler [
    base:desc "Supplies data to control‑level diagnostics and actuator health monitoring"
    DTDFVocab:enables ControlDiagnosticsService
]
instance MaintenanceEnabler : DTDFVocab:Enabler [
    base:desc "Delivers activity data to predictive maintenance analytics for anomaly detection"
    DTDFVocab:enables PredictiveMaintenanceService
]
instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Connects Simulink‑generated visualizations and MQTT data to the web‑based dashboard"
    DTDFVocab:enables DashboardVisualizationService
]
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Ingests data and model artefacts for MATLAB/Simulink simulation validation"
    DTDFVocab:enables SimulationValidationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Monitors motor parameters in real‑time, generating live dashboards"
    DTDFVocab:provides MotorCurrentTrendInsight, MotorTemperatureTrendInsight, MotorTorqueTrendInsight, EncoderPositionAccuracyInsight
]
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Identifies joint friction levels using hybrid white‑box/black‑box estimation techniques"
    DTDFVocab:provides FrictionLevelInsight, UpdateFrictionModelAction
]
instance TrajectoryOptimizationService : DTDFVocab:Service [
    base:desc "Optimises motion trajectories on‑line based on live sensor streams"
    DTDFVocab:provides MotionTrajectoryOptimalityInsight, MotionAccuracyInsight
]
instance ControlDiagnosticsService : DTDFVocab:Service [
    base:desc "Provides control‑level diagnostics and actionable maintenance recommendations"
    DTDFVocab:provides DiagnosticReportInsight, AdjustControlGainsAction
]
instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Analyzes wear‑related data to predict failure and schedule maintenance"
    DTDFVocab:provides WearPredictionInsight, ScheduleMaintenanceAction
]
instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Visualises real‑time sensor streams, model parameters and optimisation outputs in a web dashboard"
    DTDFVocab:provides MotorCurrentTrendInsight, MotorTemperatureTrendInsight, MotorTorqueTrendInsight, EncoderPositionAccuracyInsight,
                 FrictionLevelInsight, MotionTrajectoryOptimalityInsight, MotionAccuracyInsight, WearPredictionInsight
]
instance SimulationValidationService : DTDFVocab:Service [
    base:desc "Validates Simulink simulation traces against measured data to ensure model fidelity"
    DTDFVocab:provides ModelValidationInsight
]

// C17: Insights
instance MotorCurrentTrendInsight : DTDFVocab:Insight [
    base:desc "Time‑based trend of motor current indicating potential over‑loading"
]
instance MotorTemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Time‑based temperature trend of the motor block indicating thermal drift"
]
instance MotorTorqueTrendInsight : DTDFVocab:Insight [
    base:desc "Time‑based torque trend highlighting step changes in load"
]
instance EncoderPositionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Accuracy assessment of encoder position relative to desired trajectory"
]
instance FrictionLevelInsight : DTDFVocab:Insight [
    base:desc "Real‑time estimation of joint friction level derived from hybrid model"
]
instance MotionTrajectoryOptimalityInsight : DTDFVocab:Insight [
    base:desc "Assessment of trajectory optimality based on live kinematic and dynamic data"
]
instance MotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Overall motion accuracy computed from position and torque error metrics"
]
instance WearPredictionInsight : DTDFVocab:Insight [
    base:desc "Prediction of wear‑related failures based on historic sensor data trends"
]
instance DiagnosticReportInsight : DTDFVocab:Insight [
    base:desc "Report of control‑level faults and recommended corrective actions"
]
instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Comparison of simulated data traces with measured sensor traces for model validation"
]

// C17: Actions
instance AdjustControlGainsAction : DTDFVocab:Action [
    base:desc "Operator action to adjust PID control gains for a specific joint"
    DTDFVocab:IsAutomatic false
]
instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Operator action to schedule maintenance based on wear prediction insight"
    DTDFVocab:IsAutomatic false
]
instance UpdateFrictionModelAction : DTDFVocab:Action [
    base:desc "Automatic update of friction compensation parameters via REST API"
    DTDFVocab:IsAutomatic true
]

// C14: Components
instance RobotMABI_MAX100 : DTDFVocab:Component [
    base:desc "Industrial robot MABI MAX 100 with six motion axes, permanent‑magnet synchronous motors and cycloidal geartrain"
]

// C15: Environment
instance IndustrialAutomationEnvironment : DTDFVocab:Environment [
    base:contains RobotMABI_MAX100, MonitoringEnabler, FrictionEnabler, TrajectoryEnabler, DiagnosticsEnabler, MaintenanceEnabler, DashboardEnabler, SimulationEnabler
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital Twin development follows a Model‑Based Systems Engineering (MBSE) lifecycle organized into four abstraction layers: requirements specification, functional architecture, logical architecture, and product/technical layer. At each level SysML-based models (e.g., component‑connector diagrams, state machines) capture the system’s structure and behavior. Transition between phases is governed by MBSE artefacts: a SysML IBD (integrated block diagram) at the functional level is mapped to a logical model defined in an architecture description language such as AADL or MontiArc, and further mapped to a product/technical model implemented in Simulink or generated C++/Java code. Lifecycle governance is facilitated by maintaining synchronized MBSE artefacts across levels and by adopting process frameworks such as RFLP or SMArDT."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The physical‑to‑digital interaction occurs over an MQTT broker. The documents do not specify the broker location, network topology, QoS level, or security mechanisms such as TLS or authentication."
]