// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "PMSM actuator for precise motion control in the MABI MAX 100 six-axis serial robot, integrated with Siemens SINUMERIK 840D sl CNC system for trajectory execution."
]

instance GearboxPrimary : DTDFVocab:ActingComponent [
    base:desc "Primary gearbox component in the FirstAxis of the MABI MAX 100 robot, transmitting torque from the motor to the secondary encoder and load."
]

instance GearboxSecondary : DTDFVocab:ActingComponent [
    base:desc "Secondary gearbox component positioned behind the primary gearbox in the FirstAxis, providing additional torque transmission and positional feedback."
]

// C3: Physical Sensing Components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted directly on the PMSM motor shaft, providing high-resolution positional feedback for closed-loop control."
    DTDFVocab:producedData MotorPositionDataStream
]

instance SecondaryPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearbox in the FirstAxis, providing redundant high-resolution positional feedback for control and monitoring."
    DTDFVocab:producedData SecondaryPositionDataStream
]

// C4: Physical-to-Virtual Interaction
instance MotorPositionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
    base:desc "Real-time time-series positional data stream from the motor encoder via MQTT protocol, representing high-resolution angular position measurements."
]

instance SecondaryPositionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryPositionEncoder
    base:desc "Real-time time-series positional data stream from the secondary encoder via MQTT protocol, representing high-resolution angular position measurements after gearbox transmission."
]

// C10: Models/Data
instance GeometricModel : DTDFVocab:Model [
    base:desc "CAD-based geometric model of the MABI MAX 100 six-axis serial robot, including kinematic constraints and component spatial relationships."
    DTDFVocab:inputTo SysMLModelingFramework
]

instance BehavioralStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model representing the operational states and transitions of the robot's FirstAxis, including joint friction characterization."
    DTDFVocab:inputTo SysMLModelingFramework
]

instance PhysicsBasedSimulationModel : DTDFVocab:Model [
    base:desc "Physics-based simulation model implemented in MathWorks Simulink, capturing dynamic load variations and friction-induced inaccuracies in the robot's motion."
    DTDFVocab:inputTo SimulationIntegrationEnabler
]

instance TimeSeriesSensorData : DTDFVocab:Data [
    base:desc "Aggregated time-series sensor data from both motor and secondary encoders, preprocessed for joint friction analysis and visualization."
    DTDFVocab:fromData MotorPositionDataStream, SecondaryPositionDataStream
    DTDFVocab:inputTo DataProcessingPipeline
]

instance HistoricalOperationalData : DTDFVocab:Data [
    base:desc "Historical operational data repository containing past sensor measurements, maintenance logs, and performance metrics for the MABI MAX 100 robot."
    DTDFVocab:inputTo DataStorageEnabler
]

// C11: Enablers
instance SysMLModelingFramework : DTDFVocab:Enabler [
    base:desc "SysML-based MBSE framework for modeling system structure (Internal Block Diagrams) and behavior (state machines) across requirements, functional, and logical architectures."
    DTDFVocab:enables DataCollectionService, JointFrictionAnalysisService, VisualizationService
]

instance SimulationIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Integration layer for MathWorks Simulink physics-based simulations, enabling dynamic behavior analysis and validation of the robot's motion."
    DTDFVocab:enables JointFrictionAnalysisService
]

instance DataProcessingPipeline : DTDFVocab:Enabler [
    base:desc "C++/Java-based data processing pipeline for real-time aggregation, filtering, and normalization of time-series sensor data from MQTT streams."
    DTDFVocab:enables DataCollectionService, JointFrictionAnalysisService
]

instance MQTTDataStreamingProtocol : DTDFVocab:Enabler [
    base:desc "MQTT protocol implementation for one-way real-time data streaming from physical sensors to the Digital Shadow, ensuring low-latency transmission of positional measurements."
    DTDFVocab:enables DataCollectionService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Standardized Asset Administration Shell (AAS) for structuring and exposing Digital Shadow data in an interoperable format, compliant with industrial manufacturing contexts."
    DTDFVocab:enables DataCollectionService, VisualizationService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Data storage solution for historical operational data, supporting version control and evolution management for iterative model refinements."
    DTDFVocab:enables JointFrictionAnalysisService
]

// C6: Services
instance DataCollectionService : DTDFVocab:Service [
    base:desc "Automated one-way data collection and aggregation service gathering contextual data traces from physical sensors (motor/secondary encoders) for specific diagnostic purposes."
    DTDFVocab:provides SensorDataAggregationInsight
]

instance JointFrictionAnalysisService : DTDFVocab:Service [
    base:desc "Analytical service for detecting and characterizing joint friction in mechanical systems (e.g., industrial robots) by processing incoming time-series sensor data traces."
    DTDFVocab:provides FrictionCharacterizationInsight, FrictionAnomalyDetectionInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service presenting aggregated and processed data in structured formats (e.g., UML class diagrams, SysML models) for stakeholder interpretation of system states or anomalies."
    DTDFVocab:provides SystemStateVisualizationInsight
]

// C17: Insights/Actions
instance SensorDataAggregationInsight : DTDFVocab:Insight [
    base:desc "Insight providing real-time aggregated sensor data traces from motor and secondary encoders, enabling passive monitoring of the robot's FirstAxis."
]

instance FrictionCharacterizationInsight : DTDFVocab:Insight [
    base:desc "Detailed characterization of joint friction (static, kinetic, viscous) in the robot's gearbox system, derived from positional data analysis."
]

instance FrictionAnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Automated detection of friction-induced anomalies in the robot's motion, triggering alerts for maintenance personnel."
]

instance SystemStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Structured visualization of the robot's system state, including kinematic constraints, dynamic loads, and friction effects, presented via SysML/UML diagrams."
]

// C1: Environment
instance MachiningOperationalEnvironment : DTDFVocab:Environment [
    base:desc "Physical operational environment for the MABI MAX 100 six-axis serial robot in a machining domain, characterized by high-precision kinematic constraints and dynamic load variations."
    base:contains PermanentMagnetSynchronousMotor, GearboxPrimary, GearboxSecondary,
                   MotorPositionEncoder, SecondaryPositionEncoder
]

// C5: Components
instance FirstAxis : DTDFVocab:Component [
    base:desc "FirstAxis component of the MABI MAX 100 robot, composed of a motor, two gearboxes, and associated sensors for precise motion control and monitoring."
    base:isContainedIn MachiningOperationalEnvironment
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system leverages **Model-Based Systems Engineering (MBSE)** methodologies, utilizing **SysML** for architecture modeling (e.g., Internal Block Diagrams [IBDs]) and **MathWorks Simulink** for behavioral simulation. The system integrates **component & connector perspectives** (e.g., via SysML or ADLs like AADL/ACME) to define interfaces, interconnections, and composition. However, the provided context does not specify orchestration patterns (e.g., centralized/decentralized) or system-wide coordination mechanisms beyond the use of **MQTT** for sensor data streaming and **Simulink** for real-time model execution. No explicit resource management or cross-component coordination protocols are detailed."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system emphasizes **validation through deviation comparison** between simulated and measured data to ensure model fidelity. **Traceability** is a critical quality assurance mechanism, linking digital representations to physical system states. However, the document does not specify explicit **quantitative uncertainty quantification methods**, **error correction mechanisms**, or **formal verification protocols**. Validation relies on **consistency checks** derived from MBSE methodologies (e.g., SysML, ADLs) and **model-driven simulation** to align digital and physical behaviors, though no detailed safety constraints or addressing mechanisms for actuators are provided."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical connection** for this Digital Twin system is implicitly tied to the **one-way data flow** from physical to digital, as defined in the Digital Shadow Reference Model [32]. The document does not specify **communication protocols** (e.g., MQTT, HTTP, OPC UA), **network topology** (e.g., star, mesh), or **bandwidth/latency requirements**. While the system relies on **streaming sensor data**, no details are provided on **reliability mechanisms** (e.g., retries, acknowledgments) or **security protocols** (e.g., TLS, encryption). The absence of **two-way interaction** (e.g., control commands) further limits the scope of technical connection details to **passive data ingestion** without active network management or redundancy features."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with external physical systems via **MQTT** for streaming time-series sensor data from the robot axis. No explicit interoperability standards (e.g., OPC UA, REST APIs) or integration patterns with other Digital Twins or enterprise systems are described. The focus is on **vertical integration** between the physical robot, sensor data, and the digital model (Simulink/SysML), without addressing broader horizontal dependencies or external system dependencies."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE) standards**, particularly leveraging **SysML** (Systems Modeling Language) for modeling across abstraction layers. **Architecture Description Languages (ADLs)** such as **ACME**, **AADL**, **MontiArc**, and **SysML IBDs** provide standardized frameworks for component-based system descriptions, including interfaces, interconnections, and composition. Behavioral modeling standards are supported via **SysML state machines** (v1.7+) and **MontiArc Automaton**. For simulation and behavioral validation, tools like **MathWorks Simulink** and other simulation methodologies ([29], [30]) align with industry practices for dynamic system analysis. **Interoperability standards** are implied through the integration of heterogeneous tools and modeling notations, though no specific interoperability protocols (e.g., OPC UA, FIWARE) are mentioned. **Certification requirements** or compliance frameworks are not explicitly detailed in the document."
]