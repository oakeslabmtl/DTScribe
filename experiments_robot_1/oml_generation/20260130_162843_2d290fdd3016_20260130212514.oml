// ------------------------------------------------------------ // Return code: 1 | Stderr:
// C3: Physical sensing components
// ------------------------------------------------------------

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor shaft of the vertical axis"
    DTDFVocab:producedData MotorEncoderPositionStream
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder located behind the gearbox of the vertical axis"
    DTDFVocab:producedData GearboxEncoderPositionStream
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring the motor phase current I_M"
    DTDFVocab:producedData MotorCurrentStream
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor providing the output angle of the vertical axis"
    DTDFVocab:producedData OutputAngleStream
]

// ------------------------------------------------------------
// C4: Physical-to-virtual interaction (DataTransmitted)
// ------------------------------------------------------------

instance MotorEncoderPositionStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderPositionStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance OutputAngleStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

instance TorqueDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, OutputAngleSensor
]

instance AngularVelocityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder, GearboxEncoder
]

instance SimulatedTorqueStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSimulinkModel
]

instance SimulatedAngularVelocityStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxSimulinkModel
]

// ------------------------------------------------------------
// C10: Data (raw and derived)
// ------------------------------------------------------------

instance MotorEncoderPositionData : DTDFVocab:Data [
    base:desc "Raw position data from the motor encoder"
    DTDFVocab:fromData MotorEncoderPositionStream
    DTDFVocab:inputTo MQTTEnabler
]

instance GearboxEncoderPositionData : DTDFVocab:Data [
    base:desc "Raw position data from the gearbox encoder"
    DTDFVocab:fromData GearboxEncoderPositionStream
    DTDFVocab:inputTo MQTTEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current I_M"
    DTDFVocab:fromData MotorCurrentStream
    DTDFVocab:inputTo MQTTEnabler
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Measured output angle of the axis"
    DTDFVocab:fromData OutputAngleStream
    DTDFVocab:inputTo MQTTEnabler
]

instance MeasuredTorqueData : DTDFVocab:Data [
    base:desc "Torque τ calculated from motor current and output angle"
    DTDFVocab:fromData TorqueDataStream
    DTDFVocab:inputTo MQTTEnabler, DashboardEnabler
]

instance MeasuredAngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity ω derived from encoder positions"
    DTDFVocab:fromData AngularVelocityDataStream
    DTDFVocab:inputTo MQTTEnabler, DashboardEnabler
]

instance SimulatedTorqueData : DTDFVocab:Data [
    base:desc "Torque τ generated by MATLAB/Simulink simulation models"
    DTDFVocab:fromData SimulatedTorqueStream
    DTDFVocab:inputTo DashboardEnabler
]

instance SimulatedAngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity ω produced by MATLAB/Simulink simulation models"
    DTDFVocab:fromData SimulatedAngularVelocityStream
    DTDFVocab:inputTo DashboardEnabler
]

// ------------------------------------------------------------
// C10: Models (Engineering & Simulation)
// ------------------------------------------------------------

instance AxisSysMLModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagram of the vertical axis"
    DTDFVocab:inputTo SysMLEnabler
]

instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the motor including electrical dynamics"
    DTDFVocab:inputTo SimulinkEnabler
]

instance GearwheelSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the gearwheel component"
    DTDFVocab:inputTo SimulinkEnabler
]

instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the gear‑box (including cycloidal gearbox)"
    DTDFVocab:inputTo SimulinkEnabler
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Friction model combining Coulomb and viscous terms"
    DTDFVocab:inputTo SimulinkEnabler
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Stribeck friction model capturing velocity‑dependent transition"
    DTDFVocab:inputTo SimulinkEnabler
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Dahl friction model describing pre‑sliding displacement"
    DTDFVocab:inputTo SimulinkEnabler
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "LuGre friction model for dynamic friction phenomena"
    DTDFVocab:inputTo SimulinkEnabler
]

// ------------------------------------------------------------
// C11: Enablers (Tooling & Integration)
// ------------------------------------------------------------

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML tooling used for structural modeling of the robot axis"
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for simulation and model parameter updates"
    DTDFVocab:enables ModelParameterUpdateService
]

instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker for live streaming of sensor data to the digital twin"
    DTDFVocab:enables FrictionIdentificationService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for model integration and parameter exchange"
    DTDFVocab:enables ModelParameterUpdateService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Custom dashboard visualizing measured vs. simulated data and controller feedback"
    DTDFVocab:enables DashboardVisualizationService, MotionAccuracyImprovementService
]

// ------------------------------------------------------------
// C6: Services
// ------------------------------------------------------------

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Visualization of measured versus simulated torque and angular velocity"
    DTDFVocab:provides VisualizationInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of static, kinetic and viscous friction parameters"
    DTDFVocab:provides FrictionParameterInsight
]

instance ModelParameterUpdateService : DTDFVocab:Service [
    base:desc "Automatic update of friction model parameters in the simulation models"
    DTDFVocab:provides UpdateFrictionParametersAction
]

instance MotionAccuracyImprovementService : DTDFVocab:Service [
    base:desc "Feedback loop improving robot motion accuracy based on updated models"
    DTDFVocab:provides AdjustControllerSetpointsAction
]

// ------------------------------------------------------------
// C17: Insights / Actions
// ------------------------------------------------------------

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Comparison of measured and simulated data highlights model fidelity"
]

instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Identified static, kinetic and viscous friction parameters are available"
]

instance UpdateFrictionParametersAction : DTDFVocab:Action [
    base:desc "Feed derived friction parameters back into MATLAB/Simulink models"
    DTDFVocab:IsAutomatic true
]

instance AdjustControllerSetpointsAction : DTDFVocab:Action [
    base:desc "Modify robot controller setpoints to improve motion accuracy"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time acquisition and processing during robot operation; data are updated as new measurements arrive (streaming via MQTT)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow comprising a Purpose (FrictionDerivation), Asset (MABI robot first axis), Sources (sensor channels), Processing components (SimulationM, SimulationGW, SimulationGB), Models (engineering and simulation), and DataTraces storing measured and simulated values."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operative/runtime stage – the digital shadow is created and used while the robot is operating to identify friction and refine control."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of each DataTrace to its originating sensor and processing model; comparison of simulated (frictionless) vs. measured data to validate friction models; continuous re‑identification to account for wear and tool changes."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol for streaming sensor measurements from the physical robot to the digital shadow."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of Asset Administration Shells (AAS) as an Industry 4.0 standard for model integration; SysML as a modeling standard."
]