{
    SwingAngleData, WindSpeedData, MotorPositionData, SystemHealthData, TrajectoryExecutionLog, EventBasedAlerts
}

DTDFVocab:Data {
    SwingAngleData [
        base:desc "Real-time measurement of crane hoist swinging angle"
    ],
    WindSpeedData [
        base:desc "Environmental wind speed measurements affecting crane dynamics"
    ],
    MotorPositionData [
        base:desc "Position feedback from crane motors for trajectory tracking"
    ],
    SystemHealthData [
        base:desc "System status monitoring including motor currents and sensor health"
    ],
    TrajectoryExecutionLog [
        base:desc "Recorded crane movement trajectories with timestamps and positions"
    ],
    EventBasedAlerts [
        base:desc "Operational alerts for anomalies or milestones in crane operation"
    ]
}

DTDFVocab:SensingComponent {
    SwingAngleEncoder [
        base:desc "Sensor measuring the swinging motion of the crane hoist"
        DTDFVocab:producedData SwingAngleData
    ],
    Anemometer [
        base:desc "Wind speed measurement sensor for environmental data"
        DTDFVocab:producedData WindSpeedData
    ],
    MotorPositionEncoder [
        base:desc "Motor position feedback sensor for trajectory tracking"
        DTDFVocab:producedData MotorPositionData
    ],
    ArduinoCurrentSensor [
        base:desc "System health monitoring sensor measuring motor currents"
        DTDFVocab:producedData SystemHealthData
    ],
    ArduinoController [
        base:desc "Microcontroller handling sensor data collection and event triggering"
        DTDFVocab:producedData TrajectoryExecutionLog, EventBasedAlerts
    ]
}

DTDFVocab:DataTransmitted {
    SwingAngleData [
        DTDFVocab:producedFrom SwingAngleEncoder
    ],
    WindSpeedData [
        DTDFVocab:producedFrom Anemometer
    ],
    MotorPositionData [
        DTDFVocab:producedFrom MotorPositionEncoder
    ],
    SystemHealthData [
        DTDFVocab:producedFrom ArduinoCurrentSensor
    ],
    TrajectoryExecutionLog [
        DTDFVocab:producedFrom ArduinoController
    ],
    EventBasedAlerts [
        DTDFVocab:producedFrom ArduinoController
    ]
}

DTDFVocab:Model {
    CraneCADModel [
        base:desc "3D CAD representation of the crane structure for visualization"
        DTDFVocab:inputTo CraneVisualizationEnabler
    ],
    CraneKinematicModel [
        base:desc "Mathematical model for crane trajectory generation and simulation"
        DTDFVocab:inputTo TrajectoryGenerationEnabler, SimulationEnabler
    ],
    ArcadiaMBSEModel [
        base:desc "MBSE model for educational purposes using Capella framework"
        DTDFVocab:inputTo TeachingExtensionEnabler
    ],
    SimulationModel [
        base:desc "Digital simulation of crane dynamics for offline validation"
        DTDFVocab:inputTo SimulationEnabler
    ]
}

DTDFVocab:Data {
    TimescaleDBDatabase [
        base:desc "Time-series database storing all sensor data and validation metrics"
    ]
}

DTDFVocab:Enabler {
    MQTTBroker [
        base:desc "Lightweight publish-subscribe messaging broker for data transmission"
        DTDFVocab:enables DataLoggingService, DataVisualizationService, OptimalTrajectoryService, ContinuousValidationService
    ],
    TimescaleDBEnabler [
        base:desc "Database access layer for TimescaleDB integration"
        DTDFVocab:enables DataLoggingService, ContinuousValidationService
    ],
    GrafanaDashboard [
        base:desc "Visualization platform for real-time and historical data presentation"
        DTDFVocab:enables DataVisualizationService
    ],
    TrajectoryGenerationEnabler [
        base:desc "Component enabling optimal trajectory calculation"
        DTDFVocab:enables OptimalTrajectoryService
    ],
    SimulationEnabler [
        base:desc "Component enabling crane simulation functionality"
        DTDFVocab:enables SimulationService
    ],
    DockerContainerization [
        base:desc "Containerization platform for service deployment"
        DTDFVocab:enables DataLoggingService, DataVisualizationService, OptimalTrajectoryService, ContinuousValidationService, SimulationService
    ],
    GantryLibPython [
        base:desc "Python library for crane control and trajectory optimization"
        DTDFVocab:enables OptimalTrajectoryService, ContinuousValidationService
    ],
    CraneVisualizationEnabler [
        base:desc "Enabler for crane visualization services"
        DTDFVocab:enables DataVisualizationService
    ]
}

DTDFVocab:Service {
    DataLoggingService [
        base:desc "Continuous recording of crane state data in TimescaleDB"
        DTDFVocab:provides CraneStateInsight, DataStorageAction
    ],
    DataVisualizationService [
        base:desc "Real-time and historical visualization of crane operations"
        DTDFVocab:provides PerformanceVisualizationInsight, OperatorAlertAction
    ],
    OptimalTrajectoryService [
        base:desc "Service generating optimal crane trajectories with minimal swinging"
        DTDFVocab:provides TrajectoryOptimizationInsight, PathPlanningAction
    ],
    ContinuousValidationService [
        base:desc "Compares real trajectories with simulations and alerts on deviations"
        DTDFVocab:provides ValidationResultsInsight, FaultDetectionAction
    ],
    SimulationService [
        base:desc "Replicates crane behavior for offline testing and validation"
        DTDFVocab:provides SimulationResultsInsight, OfflineTestingAction
    ],
    TeachingExtensionService [
        base:desc "Educational extensions for MBSE and system understanding"
        DTDFVocab:provides EducationalInsight, ConceptDemonstrationAction
    ]
}

DTDFVocab:Insight {
    CraneStateInsight [
        base:desc "Real-time monitoring of crane operational state"
    ],
    PerformanceVisualizationInsight [
        base:desc "Visual representation of crane performance metrics"
    ],
    TrajectoryOptimizationInsight [
        base:desc "Analysis of optimal trajectory generation results"
    ],
    ValidationResultsInsight [
        base:desc "Comparison results between real and simulated trajectories"
    ],
    SimulationResultsInsight [
        base:desc "Results from crane behavior simulations"
    ],
    EducationalInsight [
        base:desc "Educational insights from MBSE models and demonstrations"
    ]
}

DTDFVocab:Action {
    DataStorageAction [
        base:desc "Automated data storage operations"
        DTDFVocab:IsAutomatic true
    ],
    OperatorAlertAction [
        base:desc "Alerts for operational anomalies or important events"
        DTDFVocab:IsAutomatic true
    ],
    PathPlanningAction [
        base:desc "Automated trajectory planning and optimization"
        DTDFVocab:IsAutomatic true
    ],
    FaultDetectionAction [
        base:desc "Automated detection of system faults and anomalies"
        DTDFVocab:IsAutomatic true
    ],
    OfflineTestingAction [
        base:desc "Automated simulation testing procedures"
        DTDFVocab:IsAutomatic true
    ],
    ConceptDemonstrationAction [
        base:desc "Educational demonstration of system concepts"
        DTDFVocab:IsAutomatic false
    ]
}

DTDFVocab:Environment {
    LabEnvironment [
        base:desc "Controlled laboratory environment for crane testing"
        base:contains CraneStructure, Motors, Sensors, ArduinoController
    ]
}

DTDFVocab:Component {
    CraneStructure [
        base:desc "Physical gantry crane structure including beams and joints"
        base:isContainedIn LabEnvironment
    ],
    Motors [
        base:desc "Stepper motors for horizontal and vertical movement"
        base:isContainedIn LabEnvironment
    ],
    Sensors [
        base:desc "Collection of physical sensors measuring crane parameters"
        base:isContainedIn LabEnvironment
    ]
}

DTDFVocab:SystemUnderStudy {
    CraneSystem [
        base:desc "Lab-scale gantry crane system for container handling simulation"
        DTDFVocab:hasEnvironment LabEnvironment
    ]
}