// Sensing components
instance LinearAxis1PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Motor position sensor for linear axis 1, providing shaft position data."
    DTDFVocab:producedData LinearAxis1PositionTransmitted
]

instance LinearAxis1VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Motor velocity sensor for linear axis 1, providing shaft velocity data."
    DTDFVocab:producedData LinearAxis1VelocityTransmitted
]

instance LinearAxis2PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Motor position sensor for linear axis 2, providing shaft position data."
    DTDFVocab:producedData LinearAxis2PositionTransmitted
]

instance LinearAxis2VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Motor velocity sensor for linear axis 2, providing shaft velocity data."
    DTDFVocab:producedData LinearAxis2VelocityTransmitted
]

instance RotaryJointPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Motor position sensor for the rotary joint, providing shaft position data."
    DTDFVocab:producedData RotaryJointPositionTransmitted
]

instance RotaryJointVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Motor velocity sensor for the rotary joint, providing shaft velocity data."
    DTDFVocab:producedData RotaryJointVelocityTransmitted
]

// Data transmitted from sensors
instance LinearAxis1PositionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LinearAxis1PositionSensor
]

instance LinearAxis1VelocityTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LinearAxis1VelocitySensor
]

instance LinearAxis2PositionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LinearAxis2PositionSensor
]

instance LinearAxis2VelocityTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LinearAxis2VelocitySensor
]

instance RotaryJointPositionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RotaryJointPositionSensor
]

instance RotaryJointVelocityTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RotaryJointVelocitySensor
]

// Data stored in reference database
instance LinearAxis1PositionData : DTDFVocab:Data [
    base:desc "Time‑series data for linear axis 1 shaft position."
    DTDFVocab:inputTo TimescaleDB, KinematicEngine
    DTDFVocab:fromData LinearAxis1PositionTransmitted
]

instance LinearAxis1VelocityData : DTDFVocab:Data [
    base:desc "Time‑series data for linear axis 1 shaft velocity."
    DTDFVocab:inputTo TimescaleDB, KinematicEngine
    DTDFVocab:fromData LinearAxis1VelocityTransmitted
]

instance LinearAxis2PositionData : DTDFVocab:Data [
    base:desc "Time‑series data for linear axis 2 shaft position."
    DTDFVocab:inputTo TimescaleDB, KinematicEngine
    DTDFVocab:fromData LinearAxis2PositionTransmitted
]

instance LinearAxis2VelocityData : DTDFVocab:Data [
    base:desc "Time‑series data for linear axis 2 shaft velocity."
    DTDFVocab:inputTo TimescaleDB, KinematicEngine
    DTDFVocab:fromData LinearAxis2VelocityTransmitted
]

instance RotaryJointPositionData : DTDFVocab:Data [
    base:desc "Time‑series data for rotary joint shaft position."
    DTDFVocab:inputTo TimescaleDB, KinematicEngine
    DTDFVocab:fromData RotaryJointPositionTransmitted
]

instance RotaryJointVelocityData : DTDFVocab:Data [
    base:desc "Time‑series data for rotary joint shaft velocity."
    DTDFVocab:inputTo TimescaleDB, KinematicEngine
    DTDFVocab:fromData RotaryJointVelocityTransmitted
]

// Enablers
instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database storing all sensor streams and logging data."
    DTDFVocab:enables PositionMonitoringService, DataLoggingService
]

instance KinematicEngine : DTDFVocab:Enabler [
    base:desc "Kinematic modeling engine performing forward and inverse kinematics for the crane."
    DTDFVocab:enables ControlLoopService
]

instance DataVisualizationEngine : DTDFVocab:Enabler [
    base:desc "Web‑based visualization engine rendering CAD geometry and motion trajectories."
    DTDFVocab:enables VisualizationService
]

instance ValidationAlgorithm : DTDFVocab:Enabler [
    base:desc "Algorithm performing live validation comparing measurements against the kinematic model."
    DTDFVocab:enables ValidationService
]

// Services
instance PositionMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of shaft positions and velocities."
    DTDFVocab:provides ShaftPositionInsight, ShaftVelocityInsight
]

instance ControlLoopService : DTDFVocab:Service [
    base:desc "Closed‑loop optimal‑control module computing actuator commands based on the kinematic model."
    DTDFVocab:provides ControlCommand
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Historical data logging service recording all sensor streams."
    DTDFVocab:provides DataHistoricalLogInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Data visualization interface rendering CAD geometry and motion trajectories."
    DTDFVocab:provides TrajectoryVisualizationInsight
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Continuous validation routine comparing live measurements against the kinematic model to detect deviations."
    DTDFVocab:provides DeviationDetectionInsight
]

// Insights
instance ShaftPositionInsight : DTDFVocab:Insight [
    base:desc "Real‑time shaft position information for the crane's axes."
]

instance ShaftVelocityInsight : DTDFVocab:Insight [
    base:desc "Real‑time shaft velocity information for the crane's axes."
]

instance DataHistoricalLogInsight : DTDFVocab:Insight [
    base:desc "Time‑series log of all sensor streams."
]

instance TrajectoryVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of the crane's motion trajectory in CAD."
]

instance DeviationDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of deviations between measured positions and kinematic model predictions."
]

// Actions
instance ControlCommand : DTDFVocab:Action [
    base:desc "Actuator command computed by the closed‑loop controller."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital twin services generate control plans: the Trajectory Generator Service computes optimal movement trajectories, and the Simulation Service validates them. The resulting trajectory commands are offered to the Control Application, which then uses the Physical Crane Interface to send commands to the physical crane. Command formats are unspecified but are likely serialized in a Python‑friendly structure (e.g., JSON or binary). The document does not report on validation, authentication, conflict‑resolution, or confirmation mechanisms after command execution."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "GreenhouseDT orchestrates its digital twin through containerised services running on virtual machines, with sensor data ingested and persisted in an InfluxDB time‑series database; inter‑component communication is handled by an Apache ActiveMQ message broker using a publish‑subscribe model that supports synchronous state updates and real‑time control loops within the self‑adaptive twin.  The Air Quality Management exemplar employs a Raspberry‑Pi sensor suite whose telemetry is transmitted via MQTT to Microsoft Azure IoT services, after which an AutomationML‑based digital twin model is visualised and simulated through Azure‑hosted components.  Both exemplars adopt lightweight containerisation or virtualization strategies, allowing isolated deployment, straightforward scaling, and consistent coordination between physical and virtual subsystems."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All intra‑system communication between digital twin services is mediated by an MQTT broker, providing publish‑subscribe messaging for event signaling. The Physical Crane Interface communicates directly with the crane controllers via an unspecified protocol (possibly serial or Ethernet). The network topology is essentially a star, with all services connecting to the MQTT broker and the database. Bandwidth, latency, and QoS requirements are not stated, and no security protocols (TLS, authentication, etc.) are detailed in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system appears to be deployed on on‑premises infrastructure (local server or edge device) running the Python applications, MQTT broker, TimescaleDB database, and Grafana dashboard. No cloud deployment, scalability mechanisms, or availability/reliability guarantees are explicitly described in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "GreenhouseDT integrates with external systems through its Apache ActiveMQ broker, exposing JMS interfaces, and with InfluxDB’s HTTP and Line Protocol APIs for time‑series data ingestion and retrieval; these interfaces enable data exchange with third‑party logging, monitoring or analytics tools.  The Air Quality Management exemplar leverages Microsoft Azure’s cloud stack, where sensor telemetry is sent via secure MQTT to Azure IoT Hub, then processed by Azure stream analytics feeding the AutomationML model stored in Azure Blob Storage; downstream enterprise applications can retrieve the twin data via Azure’s REST APIs.  This combination of open‑source broker, time‑series database, and commercial cloud platform provides horizontal connectivity to data sources, analytics services and potential enterprise ERP or MES systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin model conforms to the AutomationML industry standard. The exemplar uses open‑source technologies such as InfluxDB and ActiveMQ; no adherence to commercial twin framework or additional certification requirements is described."
]