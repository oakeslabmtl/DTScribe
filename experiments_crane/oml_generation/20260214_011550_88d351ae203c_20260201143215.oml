// Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "swing‑angle encoder mounted on the hoist measuring swing angle"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "anemometer for wind speed measurement at the crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartStepperEncoder : DTDFVocab:SensingComponent [
    base:desc "stepper motor encoder embedded in the cart TMC4671 controller"
    DTDFVocab:producedData CartEncoderDataTransmitted
]

instance HoistStepperEncoder : DTDFVocab:SensingComponent [
    base:desc "stepper motor encoder embedded in the hoist TMC4671 controller"
    DTDFVocab:producedData HoistEncoderDataTransmitted
]

// Data Transmitted Instances
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance CartEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartStepperEncoder
]

instance HoistEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistStepperEncoder
]

// Data Instances (stored by TimescaleDB)
instance SwingAngleData : DTDFVocab:Data [
    base:desc "measured swing angle in degrees"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "wind speed measured in meters per second"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance CartEncoderData : DTDFVocab:Data [
    base:desc "cart stepper motor encoder count and velocity"
    DTDFVocab:fromData CartEncoderDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HoistEncoderData : DTDFVocab:Data [
    base:desc "hoist stepper motor encoder count and velocity"
    DTDFVocab:fromData HoistEncoderDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database for persistent real‑time time‑series sensor logs"
    DTDFVocab:enables LoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana instance rendering dashboards using TimescaleDB data"
    DTDFVocab:enables VisualizationService
]

instance TrajectoryModelEnabler : DTDFVocab:Enabler [
    base:desc "provides 3D kinematic model from Fusion360 used by trajectory generator"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationModelEnabler : DTDFVocab:Enabler [
    base:desc "provides CAD geometry to simulation service"
    DTDFVocab:enables SimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "middleware enabling ContinuousValidationService using real‑time sensor data"
    DTDFVocab:enables ContinuousValidationService
]

// Models and Data used by Enablers
instance CADModelFusion360 : DTDFVocab:Model [
    base:desc "CAD geometry of the crane produced in Autodesk Fusion360"
    DTDFVocab:inputTo SimulationModelEnabler
]

instance KinematicModel3D : DTDFVocab:Model [
    base:desc "3D kinematic model used by TrajectoryGenerator to produce optimal swing‑free paths"
    DTDFVocab:inputTo TrajectoryModelEnabler
]

instance SimulationTracesData : DTDFVocab:Data [
    base:desc "simulation traces and confidence bounds of crane behavior"
    DTDFVocab:inputTo SimulationModelEnabler
]

// Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "cart stepper motor controlled via TMC4671Eval board"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "hoist stepper motor controlled via TMC4671Eval board"
]

instance ElectromagnetAtHoist : DTDFVocab:ActingComponent [
    base:desc "electromagnet at the hoist for picking up containers"
]

// Services
instance LoggingService : DTDFVocab:Service [
    base:desc "continuous state capture into TimescaleDB"
    DTDFVocab:provides LoggingInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboards for real‑time and simulated trajectory overlays"
    DTDFVocab:provides DashboardInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "physics‑based kinematic model producing optimal swing‑free paths"
    DTDFVocab:provides GenerateTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "forward simulation of crane and controller using CAD model"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "real‑time comparison of measured vs simulated trajectories, distance metric calculation"
    DTDFVocab:provides DeviationInsight
    DTDFVocab:provides SendAlertAction
]

// Insights
instance LoggingInsight : DTDFVocab:Insight [
    base:desc "captures continuous state logs into TimescaleDB with real‑time granularity"
]

instance DashboardInsight : DTDFVocab:Insight [
    base:desc "visualizes real‑time state and simulation traces in Grafana"
]

instance TrajectoryInsight : DTDFVocab:Insight [
    base:desc "provides optimal swing‑free trajectory plan generated by the trajectory generator"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "simulation traces and confidence bounds of crane behavior"
]

instance DeviationInsight : DTDFVocab:Insight [
    base:desc "distance metric between real and simulated trajectories, alert on threshold breach"
]

// Actions
instance GenerateTrajectoryAction : DTDFVocab:Action [
    base:desc "generates an optimal trajectory for the crane to reduce swing"
    DTDFVocab:IsAutomatic true
]

instance SendAlertAction : DTDFVocab:Action [
    base:desc "notifies operator of deviation beyond threshold"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application publishes command topics to MQTT (e.g., target position, trajectory profiles). The Physical Crane Interface receives these topics, translates them into motor controller commands (stepper driver configuration, electromagnet activation) and sends them over USB/serial to the TMC4671 controllers. The Trajectory Generator Service emits optimal motion plans, the Continuous Validation Service issues alerts via MQTT when thresholds are breached, which are displayed on the HMI."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in real‑time: the Logging Service samples every control loop cycle (~10–20 ms), the Trajectory Generator updates on command, the Continuous Validation runs continuously with each telemetry point, effectively providing continuous monitoring and immediate feedback."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system ingests physical sensor data via the Physical Crane Interface into the Logging Application, stores it in the Database, and makes it available to MQTT topics. The Trajectory Generator Service publishes motion plans; the Simulation Service generates simulated trajectories for comparison. The Continuous Validation Service consumes both measured and simulated data, computes distance metrics against a threshold, and publishes alerts to the HMI. All services communicate through the Eclipse Mosquitto broker, orchestrated by Docker Compose on a single host."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Designed (CAD and kinematic models in Fusion360); Manufactured (physical crane assembled with TMC4671 drivers, Arduino, sensors); Operated (runtime logging, simulation, validation). The digital twin evolves through continuous validation research, fault detection extensions, and teaching‑based feature extensions (e.g., harbor simulation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The kinematic model is validated against real‑time measurements via the Continuous Validation Service: measured swing angles and positions are compared against simulated ones, a distance metric is calculated, and a threshold determines validity. The database stores raw data for post‑hoc verification; Grafana allows visual inspection of deviations. No formal model verification is described, but continuous validation provides runtime fidelity checks."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between physical and virtual layers uses MQTT over TCP/IP within the Docker network. The Physical Crane Interface talks to motor controllers over USB/serial. The dashboard and services access the database over PostgreSQL protocol. All containers are bound to a private Docker bridge network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components (Python services, TimescaleDB, Mosquitto broker, Grafana) are containerized and deployed on a single personal computer using Docker Compose. The repository is hosted on GitHub, with installation instructions and documentation in MkDocs. No cloud hosting is used."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Explicitly follows an ad‑hoc approach; does not employ a dedicated digital twin framework or industry standard, relying instead on open‑source tools (Python, Docker, TimescaleDB, Mosquitto, Grafana); no formal standardization is reported."
]