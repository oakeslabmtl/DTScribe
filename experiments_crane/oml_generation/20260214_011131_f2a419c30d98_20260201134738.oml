// Acting components
instance CraneFrame : DTDFVocab:ActingComponent [
    base:desc "Frame of the lab-scale gantry crane"
]

instance MotorActuatorA : DTDFVocab:ActingComponent [
    base:desc "Linear actuator (motor) responsible for vertical lift on one side of the gantry"
]

instance MotorActuatorB : DTDFVocab:ActingComponent [
    base:desc "Linear actuator (motor) responsible for vertical lift on the opposite side of the gantry"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet used to lift payload"
]

instance ControlElectronicUnit : DTDFVocab:ActingComponent [
    base:desc "Control electronics unit managing actuator commands"
]

// Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encodes swing angle of the gantry crane shaft"
    DTDFVocab:producedData MQTTMessage_SwingAngle
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Measures wind speed around the crane"
    DTDFVocab:producedData MQTTMessage_WindSpeed
]

instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Measures linear position of the crane carriage"
    DTDFVocab:producedData MQTTMessage_Position
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Measures linear velocity of the crane carriage"
    DTDFVocab:producedData MQTTMessage_Velocity
]

instance LoadSensor : DTDFVocab:SensingComponent [
    base:desc "Measures payload load on the crane"
    DTDFVocab:producedData MQTTMessage_Load
]

instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures electrical current draw of the crane actuators"
    DTDFVocab:producedData MQTTMessage_Current
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Measures temperature of the crane components"
    DTDFVocab:producedData MQTTMessage_Temperature
]

// Data transmitted (MQTT messages)
instance MQTTMessage_SwingAngle : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance MQTTMessage_WindSpeed : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MQTTMessage_Position : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

instance MQTTMessage_Velocity : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySensor
]

instance MQTTMessage_Load : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadSensor
]

instance MQTTMessage_Current : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
]

instance MQTTMessage_Temperature : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// Data stored in database
instance DbSwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series record of swing angle stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDB_Instance
    DTDFVocab:fromData MQTTMessage_SwingAngle
]

instance DbWindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series record of wind speed stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDB_Instance
    DTDFVocab:fromData MQTTMessage_WindSpeed
]

instance DbPositionData : DTDFVocab:Data [
    base:desc "Time‑series record of linear position stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDB_Instance
    DTDFVocab:fromData MQTTMessage_Position
]

instance DbVelocityData : DTDFVocab:Data [
    base:desc "Time‑series record of linear velocity stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDB_Instance
    DTDFVocab:fromData MQTTMessage_Velocity
]

instance DbLoadData : DTDFVocab:Data [
    base:desc "Time‑series record of payload load stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDB_Instance
    DTDFVocab:fromData MQTTMessage_Load
]

instance DbCurrentData : DTDFVocab:Data [
    base:desc "Time‑series record of electrical current stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDB_Instance
    DTDFVocab:fromData MQTTMessage_Current
]

instance DbTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series record of temperature stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDB_Instance
    DTDFVocab:fromData MQTTMessage_Temperature
]

// Enablers
instance PythonAdapter_CRANE : DTDFVocab:Enabler [
    base:desc "Python adapter reads telemetry from the physical crane controller and writes into TimescaleDB"
    DTDFVocab:enables DataLoggingService
]

instance Mosquitto_MQTT_Broker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker mediating data flows between the physical controller and the digital twin"
    DTDFVocab:enables DataLoggingService, VisualizationDashboardService, OptimalControlAlgorithmService
]

instance TimescaleDB_Instance : DTDFVocab:Enabler [
    base:desc "TimescaleDB serving high‑throughput time‑series database for crane telemetry"
    DTDFVocab:enables DataLoggingService, VisualizationDashboardService, ContinuousValidationService
]

instance Grafana_Dashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboards visualising live and archived crane states"
    DTDFVocab:enables VisualizationDashboardService
]

instance DockerContainer_GantryLib : DTDFVocab:Enabler [
    base:desc "Docker container hosting the Python application implementing the kinematic model and service logic"
    DTDFVocab:enables OptimalControlAlgorithmService, ContinuousValidationService
]

// Services
instance OptimalControlAlgorithmService : DTDFVocab:Service [
    base:desc "Computes motion trajectories for the crane based on user‑defined payload constraints"
    DTDFVocab:provides ControlAction, TrajectoryInsight
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Real‑time historical data logging of sensor streams for post‑hoc analysis"
    DTDFVocab:provides HistoricalDataInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Interactive data visualization dashboards exposing live and archived crane states"
    DTDFVocab:provides LiveTelemetryInsight, AlertInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation routines compare physical measurements with the kinematic model to detect drift or faults"
    DTDFVocab:provides ValidationInsight, FaultDetectionAction
]

// Insights and Actions
instance ControlAction : DTDFVocab:Action [
    base:desc "Adjusts crane actuators to follow computed motion trajectory"
    DTDFVocab:IsAutomatic true
]

instance TrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight into optimal trajectory based on payload constraints"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Archived sensor data for post-hoc analysis"
]

instance LiveTelemetryInsight : DTDFVocab:Insight [
    base:desc "Real-time crane state displayed on Grafana dashboard"
]

instance AlertInsight : DTDFVocab:Insight [
    base:desc "Alert when sensor thresholds are exceeded"
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Comparison of physical measurements to model predictions to detect drift or faults"
]

instance FaultDetectionAction : DTDFVocab:Action [
    base:desc "Triggers fault diagnostics when sensor anomalies detected"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin’s Control Application operates as a Python process that consumes trajectories generated by the Trajectory Generator Service. A trajectory is a sequence of positional waypoints computed by a kinematic model that is intended to drive the crane without residual swing. The Control Application forwards these waypoints to the Physical Crane Interface, which translates them into low‑level motor/actuator commands sent to the crane controllers. The interface exposes no details on message format or authentication in the documents; it simply relays the high‑level commands to the physical hardware. Feedback from the physical system is captured by the Physical Crane Interface and recorded by the Logging Application for post‑hoc validation by the Continuous Validation Service."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated following a microservice architecture depicted by the C4 Context and Container diagrams. The Physical Crane component streams real‑time sensor telemetry (acoustic, torque, motor currents, end‑effector position) to a central MQTT broker. The Control Application consumes these topics, invokes a Trajectory Generator service (implemented in Python/ROS) to compute optimal motion plans, and publishes plan packets to a dedicated MQTT topic consumed by the Crane control unit. A Simulation Service runs inside a Docker container; it subscribes to planned trajectories, forwards them to a physics‑based simulator (Gazebo, PyBullet), and returns simulated telemetry. All services – control, trajectory generation, simulation – are containerized, deployed on VMs (Ubuntu 20.04), and communicate via secure TLS‑enabled MQTT with QoS 1. Coordination is achieved by the broker; the Control Application acts as a central orchestrator, scheduling tasks and aggregating telemetry for ingestion into InfluxDB and visualization dashboards. The architecture follows a layered client‑server pattern with the Control Application as the orchestrator and the Crane actuator as the subordinate client."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "GreenhouseDT follows a lifecycle that starts with a C4‑model based architectural design where the greenhouse layout and sensor network are diagrammed. The implementation phase bundles the system into Docker containers that include an InfluxDB time‑series database, an ActiveMQ message broker, and a virtual‑machine image that provides pre‑recorded data for the greenhouse. Deployment is achieved via the pre‑configured VM image, enabling rapid installation on a host machine. During operation the twin collects real‑time sensor data through MQTT, writes to InfluxDB, and synchronises adaptations with the physical greenhouse. Evolution of the twin is governed by an ad‑hoc version‑control strategy recorded in the GitHub repository; changes are tracked by Git commits and the repository’s README document outlines the iterative development process."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication is performed via an MQTT broker that acts as the messaging backbone for the Trajectory Generator Service, Simulation Service, and Continuous Validation Service, using MQTT's publish/subscribe semantics over TCP/IP (default port 1883). Data persistence and analytics are carried out with TimescaleDB, accessed over the standard PostgreSQL wire protocol. The system therefore relies on standard TCP/IP networking for both MQTT and database traffic; no specific network topology, bandwidth, latency, reliability, redundancy or security protocols beyond the MQTT and PostgreSQL defaults are mentioned."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Both the physical and digital twin stacks are deployed on a single personal computer (edge device). The Python applications (crane interface, control, logging, trajectory generation, simulation, validation, dashboard) and supporting services (TimescaleDB, Eclipse Mosquitto MQTT broker) run in Docker containers orchestrated by a docker‑compose file. The deployment is a single‑node edge configuration; no horizontal scaling or high‑availability features are described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adheres to a set of open standards: sensor data are transmitted using MQTT over an ActiveMQ broker, time‑series data are stored in InfluxDB (built on PostgreSQL), the Air‑Quality twin is described using AutomationML, and architecture diagrams are created with the C4 model notation. Deployment is platform‑agnostic through Docker containers. All source code is distributed under the MIT license as indicated by the LICENSE file in the GitHub repository."
]