// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder that measures hoist swing on the crane",
    producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer that measures wind speed affecting crane motion",
    producedData WindSpeedDataTransmitted
]

instance ArduinoMotorStateReader : DTDFVocab:SensingComponent [
    base:desc "Arduino firmware reads motor state information (current, position) from cart and hoist stepper motors",
    producedData MotorStateDataTransmitted
]

// C2: Acting components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cartesian stepper motor that drives the crane carriage along the gantry"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor that raises and lowers the electromagnet payload"
]

instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval controller for the cart stepper motor"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval controller for the hoist stepper motor"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist used to pick up small pucks (containers)"
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    producedFrom Anemometer
]

instance MotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    producedFrom ArduinoMotorStateReader
]

// C5: Data entities
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements (degrees) streamed from the encoder",
    fromData SwingAngleDataTransmitted,
    provides DataLoggingInsight, SystemPerformanceInsight, OptimalTrajectoryInsight, SimulationOutcomeInsight, ValidationAlertInsight
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of wind speed readings (m/s) streamed from the anemometer",
    fromData WindSpeedDataTransmitted,
    provides DataLoggingInsight, SystemPerformanceInsight, OptimalTrajectoryInsight, SimulationOutcomeInsight, ValidationAlertInsight
]

instance MotorStateData : DTDFVocab:Data [
    base:desc "Time‑series of motor state variables (position, current) for cart and hoist motors",
    fromData MotorStateDataTransmitted,
    provides DataLoggingInsight, SystemPerformanceInsight, OptimalTrajectoryInsight, SimulationOutcomeInsight, ValidationAlertInsight
]

// C10: Models/Data
instance GantryCraneCADModel : DTDFVocab:Model [
    base:desc "Fusion360 CAD model of the lab‑scale gantry crane (frame, motors, electromagnet, shield)"
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator and Simulation services to compute feasible motions"
]

// C11: Enablers
instance PhysicalCraneInterface : DTDFVocab:Enabler [
    base:desc "Python program (gantrylib) that reads sensors and commands actuators via the Arduino",
    enables DataLoggingService, RealTimeVisualizationService, TrajectoryGenerationService, SimulationService, ContinuousValidationService
]

instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Python logging app that streams sensor measurements over MQTT and writes them to TimescaleDB",
    enables DataLoggingService
]

instance MosquittoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker that transports sensor data to all DT services",
    enables DataLoggingService, RealTimeVisualizationService, TrajectoryGenerationService, SimulationService, ContinuousValidationService
]

instance TimescaleDBInstance : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database storing logged measurements for analysis and replay",
    enables DataLoggingService, RealTimeVisualizationService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboard visualising performance indicators from live sensor data",
    enables RealTimeVisualizationService
]

instance TrajectoryGeneratorEngine : DTDFVocab:Enabler [
    base:desc "Engine that computes optimal motion plans using the kinematic model",
    enables TrajectoryGenerationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Physics‑based simulation service that emulates crane dynamics and controller behaviour",
    enables SimulationService
]

instance ValidationEngine : DTDFVocab:Enabler [
    base:desc "Continuous validation engine that compares executed trajectories with simulated results",
    enables ContinuousValidationService
]

instance DockerComposeOrchestrator : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestration of all containerised DT components",
    enables DataLoggingService, RealTimeVisualizationService, TrajectoryGenerationService, SimulationService, ContinuousValidationService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that ingests sensor streams from MQTT and persists them in TimescaleDB",
    provides DataLoggingInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Service that renders live dashboards in Grafana using the latest sensor data",
    provides SystemPerformanceInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service that generates optimal motion trajectories for the crane using the kinematic model",
    provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs physics‑based simulations of planned trajectories and controller actions",
    provides SimulationOutcomeInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously validates executed motions against simulated ones and raises alerts",
    provides ValidationAlertInsight, ParameterAdjustmentAction
]

// C17: Insights / Actions
instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor measurements have been successfully stored in the time‑series database"
]

instance SystemPerformanceInsight : DTDFVocab:Insight [
    base:desc "Key performance indicators (e.g., swing angle, wind speed, motor currents) visualised for operator monitoring"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal motion plan (position, velocity profiles) computed for the next crane task"
]

instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Predicted crane behaviour from the physics simulation (trajectory adherence, energy consumption)"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when discrepancy between executed and simulated trajectories exceeds defined thresholds"
]

instance ParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Operator‑initiated action to adjust controller gains or trajectory parameters in response to validation alerts",
    IsAutomatic false
]

// C1: Environment (optional grouping)
instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains SwingAngleEncoder, Anemometer, ArduinoMotorStateReader,
                 CartStepperMotor, HoistStepperMotor, CartMotorController, HoistMotorController, Electromagnet,
                 PhysicalCraneInterface, LoggingApplication, MosquittoBroker, TimescaleDBInstance,
                 GrafanaDashboard, TrajectoryGeneratorEngine, SimulationEngine, ValidationEngine,
                 DockerComposeOrchestrator,
                 GantryCraneCADModel, KinematicModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital twin services (e.g., the Trajectory Generator Service) send motion commands to the Physical Crane Interface, which forwards them to the Control Application and ultimately to the motor controllers over the same Python‑based communication channel, enabling the DT to command cart and hoist motions and activate the electromagnet."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall constellation consists of the physical crane with its controllers and Arduino, a Python‑based interface layer, a set of Docker‑containerised services (DB, MQTT broker, dashboard, trajectory generator, simulator, continuous validation), and a human‑machine interface front‑end. Communication flows via MQTT and SQL, forming a tightly coupled cyber‑physical system."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated trajectories, computes distance metrics, and checks them against predefined thresholds; violations trigger operator notifications via the dashboard, providing runtime fidelity assessment of the digital twin models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑component communication relies on MQTT (Eclipse Mosquitto) for signaling and command exchange, and SQL (PostgreSQL) connections for data persistence in TimescaleDB. The Physical Crane Interface uses a Python program to communicate with Arduino and motor controllers over serial/USB links."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital twin services (database, MQTT broker, dashboard) are Docker‑containerised and deployed on a personal computer using a provided docker‑compose file. The Python modules and applications run directly on the host OS and are installed via pip."
]