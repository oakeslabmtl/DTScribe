// ---------------------------------------------------
// C3: Physical sensing components
// ---------------------------------------------------
instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Python‑based Physical Crane Interface reads position values from the crane controllers"
    DTDFVocab:producedData PositionDataTransmitted
]

instance CraneLoadSensor : DTDFVocab:SensingComponent [
    base:desc "Python‑based Physical Crane Interface reads load values from the crane controllers"
    DTDFVocab:producedData LoadDataTransmitted
]

// ---------------------------------------------------
// C4: Physical-to-virtual interaction (data transmitted)
// ---------------------------------------------------
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor
]

instance LoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneLoadSensor
]

// ---------------------------------------------------
// C10: Data entities
// ---------------------------------------------------
instance PositionTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of crane position values stored in TimescaleDB"
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MosquittoMQTTBrokerEnabler
]

instance LoadTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of crane load values stored in TimescaleDB"
    DTDFVocab:fromData LoadDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MosquittoMQTTBrokerEnabler
]

// ---------------------------------------------------
// C10: Models
// ---------------------------------------------------
instance CraneCADKinematicModel : DTDFVocab:Model [
    base:desc "CAD and kinematic model of the laboratory gantry crane created with Autodesk Fusion360"
    DTDFVocab:inputTo OptimalControlEngineEnabler
]

instance SimulatedTrajectoryModel : DTDFVocab:Model [
    base:desc "Predictive model that generates simulated crane trajectories for validation"
    DTDFVocab:inputTo ContinuousValidationEngineEnabler
]

// ---------------------------------------------------
// C11: Enablers (software / infrastructure)
// ---------------------------------------------------
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database used for historical data logging"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance MosquittoMQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for real‑time data exchange between components"
    DTDFVocab:enables DataVisualizationService, ContinuousValidationService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard container that visualises real‑time and recorded crane states"
    DTDFVocab:enables DataVisualizationService
]

instance PythonPhysicalCraneInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Python script that forwards sensor values to logging and validation components"
    DTDFVocab:enables HistoricalDataLoggingService, ContinuousValidationService
]

instance OptimalControlEngineEnabler : DTDFVocab:Enabler [
    base:desc "Control engine that consumes the CAD‑kinematic model to compute reference trajectories"
    DTDFVocab:enables OptimalControlService
]

instance ContinuousValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Validation engine that compares live executed trajectories with simulated trajectories"
    DTDFVocab:enables ContinuousValidationService
]

// ---------------------------------------------------
// C6: Services
// ---------------------------------------------------
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service that computes optimal reference trajectories and control commands for the crane"
    DTDFVocab:provides OptimalTrajectoryInsight, AdjustControlCommandAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that records sensor and operational data into TimescaleDB for offline analysis"
    DTDFVocab:provides HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service that renders real‑time and recorded crane states via Grafana dashboards"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously validates live sensor data against the predictive trajectory model"
    DTDFVocab:provides ValidationAlertAction
]

// ---------------------------------------------------
// C17: Insights / Actions
// ---------------------------------------------------
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight presenting the computed optimal trajectory for the gantry crane"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight summarising historical crane operation data stored in TimescaleDB"
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight delivering live visualisation of crane position and load on the Grafana dashboard"
]

instance ValidationAlertAction : DTDFVocab:Action [
    base:desc "Automatic alert generated when deviation between executed and simulated trajectories exceeds thresholds"
    DTDFVocab:IsAutomatic true
]

instance AdjustControlCommandAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of control commands based on optimal trajectory computation"
    DTDFVocab:IsAutomatic true
]

// ---------------------------------------------------
// Physical components (environment)
// ---------------------------------------------------
instance GantryStructure : DTDFVocab:Component [
    base:desc "Small‑scale mechanical gantry structure forming the main support of the laboratory crane"
]

instance CraneCarriage : DTDFVocab:Component [
    base:desc "Moving carriage that slides along the gantry supporting the hoist"
]

instance HoistMechanism : DTDFVocab:Component [
    base:desc "Mechanism that raises and lowers loads attached to the crane"
]

instance ArduinoController : DTDFVocab:Component [
    base:desc "Arduino‑based controller interfacing with crane motors and sensors, executing Python logic"
]

instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains GantryStructure, CraneCarriage, HoistMechanism, ArduinoController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control of the crane is performed by a Python Control Application that uses the Physical Crane Interface to send commands to the crane’s controllers. The Trajectory Generator Service produces optimal movement trajectories (kinematic model) that are delivered to the crane via this interface. No specific command formats, validation, authentication, or execution‑confirmation mechanisms are described in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The exemplar adopts an ad‑hoc, container‑based orchestration that follows the C4 modelling approach. A set of Docker containers implement the core services: a Python logging application that continuously records the physical system’s state, an MQTT broker (or ActiveMQ in the greenhouse case) that provides publish/subscribe signalling between services, a time‑series database (InfluxDB) for persisting sensor data, and the digital‑twin logic itself (implemented as a Python module). Deployment is driven by a docker‑compose file that specifies container images, network links, and resource limits, allowing the whole constellation to be started, stopped and scaled with a single command. Coordination among the components is realised through MQTT topics: the physical system publishes sensor readings, the twin consumes them to update its model, and control commands are sent back on dedicated topics. The architecture is deliberately non‑framework‑centric, relying on widely used open‑source tools (Docker, MQTT, InfluxDB, ActiveMQ) to manage resources, handle inter‑service communication and maintain system‑wide coherence."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin relies on an MQTT broker that provides publish/subscribe signaling between the Trajectory Generator Service, Simulation Service, Continuous Validation Service, and other components. The broker is the only explicitly mentioned network protocol; the document does not describe network topology, bandwidth, latency, redundancy, or security measures for the MQTT connection."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software components (Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface, Database, Dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service, and MQTT Broker) are executed on a single personal computer. The Database, MQTT Broker, and Grafana Dashboard are packaged as Docker containers, and the system can be started with a Docker‑Compose configuration. No explicit CPU, memory, or storage requirements are given, and the document does not mention cloud or edge hosting, scalability beyond container replication, or formal availability guarantees."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The gantry crane digital twin uses the C4 Model to visualize and describe its architecture, applying a software‑architectural notation to the cyber‑physical system."
]