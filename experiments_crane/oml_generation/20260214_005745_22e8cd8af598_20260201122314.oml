// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring pendulum swing of the gantry crane."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting crane stability."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartStepperMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder for the cart stepper motor providing position feedback."
    DTDFVocab:producedData CartMotorEncoderDataTransmitted
]

instance HoistStepperMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder for the hoist stepper motor providing position feedback."
    DTDFVocab:producedData HoistMotorEncoderDataTransmitted
]

instance ArduinoAggregator : DTDFVocab:SensingComponent [
    base:desc "Arduino controller aggregating all sensor data for MQTT transmission."
    DTDFVocab:producedData ArduinoAggregatedDataTransmitted
]

// C4: Physical‑to‑virtual interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CartMotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartStepperMotorEncoder
]

instance HoistMotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistStepperMotorEncoder
]

instance ArduinoAggregatedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoAggregator
]

// C4 continued: Data flow into Time‑series database
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "TimescaleDB time‑series of swing angle measurements."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "TimescaleDB time‑series of wind speed measurements."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance CartMotorPositionTimeSeries : DTDFVocab:Data [
    base:desc "TimescaleDB time‑series of cart motor position feedback."
    DTDFVocab:fromData CartMotorEncoderDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance HoistMotorPositionTimeSeries : DTDFVocab:Data [
    base:desc "TimescaleDB time‑series of hoist motor position feedback."
    DTDFVocab:fromData HoistMotorEncoderDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance ArduinoAggregatedTimeSeries : DTDFVocab:Data [
    base:desc "TimescaleDB time‑series of aggregated sensor data from Arduino."
    DTDFVocab:fromData ArduinoAggregatedDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

// C10: Models/Data
instance CADModelCrane : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane created in Autodesk Fusion 360."
]

instance KinematicModelCrane : DTDFVocab:Model [
    base:desc "Kinematic model for trajectory planning of the gantry crane."
    DTDFVocab:inputTo PythonGantryLib
]

instance PhysicsSimulationModelCrane : DTDFVocab:Model [
    base:desc "Physics‑based simulation model used by the Simulation Service."
    DTDFVocab:inputTo PythonGantryLib
]

// C11: Enablers
instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database storing all operational telemetry."
    DTDFVocab:enables DataLoggingService, FaultDetectionService, ContinuousValidationService
]

instance MosquittoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for real‑time telemetry streaming."
    DTDFVocab:enables DataLoggingService
]

instance PythonGantryLib : DTDFVocab:Enabler [
    base:desc "Python gantrylib module providing kinematic computations."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService
]

instance Grafana : DTDFVocab:Enabler [
    base:desc "Grafana dashboard visualization platform."
    DTDFVocab:enables GrafanaDashboardService
]

instance DockerCompose : DTDFVocab:Enabler [
    base:desc "Docker compose orchestrator managing all Digital Twin container stack."
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Real‑time data logging service that streams sensor telemetry to TimescaleDB via MQTT."
    DTDFVocab:provides DataLogInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Service providing real‑time visualization of telemetry via Grafana."
    DTDFVocab:provides VisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service generating optimal crane trajectories using the kinematic model."
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service simulating crane dynamics and controllers using the physics‑based model."
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service comparing executed trajectories to simulation results and issuing alerts."
    DTDFVocab:provides ValidationAlertInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service performing time‑series classification for fault detection."
    DTDFVocab:provides FaultDetectionInsight, MaintenancePlanningAction
]

// C17: Insights/Actions
instance DataLogInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful real‑time logging of telemetry data."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating availability of real‑time dashboard visualization."
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight providing optimal trajectory paths for the gantry crane."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing simulation outcomes for the crane system."
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when trajectory deviations exceed predefined thresholds."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating detected fault conditions in the crane system."
]

instance TrajectoryAdjustmentAction : DTDFVocab:Action [
    base:desc "Action to adjust trajectory based on validation feedback."
    DTDFVocab:IsAutomatic false
]

instance MaintenancePlanningAction : DTDFVocab:Action [
    base:desc "Action to plan maintenance following fault detection."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application and Trajectory Generator Service compute and publish trajectory commands (position, velocity profiles) and electromagnet on/off signals to the Physical Crane Interface over MQTT, which then drives the cart and hoist motors through the Arduino and motor drivers."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous data logging and validation occur at the sensor sampling frequency (10–50 Hz). Trajectory generation and simulation are triggered on demand and run on the order of seconds. The entire twin operates in real time, synchronising with the physical crane via MQTT with sub‑second latency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin’s architecture follows a C4 container diagram. Docker‑compose brings up the TimescaleDB, Mosquitto broker, and Grafana. Services (logging, trajectory generator, simulation, continuous validation) publish/subscribe over MQTT. The operator GUI communicates via MQTT; the control and logging applications interact directly with the physical interface over Python."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design: CAD models (Autodesk Fusion 360) and kinematic model. Manufacturing: Build the crane per BOM and firmware on Arduino. Operation: Deploy twin, collect operational data, run continuous validation, and iteratively evolve services such as fault detection."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The kinematic and simulation models are validated against live measurements through the Continuous Validation Service which computes Euclidean distance metrics between simulated and real trajectories and flags deviations beyond a user‑defined threshold, ensuring model fidelity during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical sensors and actuators are interfaced through an Arduino MCU connected to the PC via serial; the Python Physical Crane Interface translates high‑level commands into UART messages. Within the twin, services exchange data via MQTT over TCP/IP; the TimescaleDB instance is accessed via PostgreSQL over TCP/IP port 5432."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin containers run locally on the operator’s personal computer under Docker; the Python gantrylib package is installed via pip. The GitHub repository hosts the source, Docker‑compose file, and documentation (MkDocs). No cloud hosting is used."
]