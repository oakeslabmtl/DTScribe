// C3: Physical sensing components – Encoder sensors for joint angle measurement
instance EncoderSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Encoder sensors attached to rotary joints of the laboratory gantry crane for precise joint angle measurement."
    DTDFVocab:producedData EncoderDataTransmitted
]

// C4: Physical-to-virtual interaction – Encoder data transmission
instance EncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderSensingComponent
]

// C10: Models/Data – Encoder data
instance EncoderData : DTDFVocab:Data [
    base:desc "Time‑stamped encoder positional data for the crane joints."
    DTDFVocab:fromData EncoderDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, InfluxDBEnabler
]

// C3: Load cell sensor for payload weight measurement
instance LoadCellSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Load cell sensor installed on the gantry crane to measure payload weight."
    DTDFVocab:producedData LoadCellDataTransmitted
]

// C4: Load cell data transmission
instance LoadCellDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadCellSensingComponent
]

// C10: Load cell data
instance LoadCellData : DTDFVocab:Data [
    base:desc "Time‑stamped load cell data indicating payload weight."
    DTDFVocab:fromData LoadCellDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, InfluxDBEnabler
]

// C3: Raspberry Pi based air‑quality sensor array
instance RaspberryPiAirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry Pi based sensor array measuring temperature, humidity, and pollutant concentrations."
    DTDFVocab:producedData AirQualityDataTransmitted
]

// C4: Air‑quality data transmission
instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RaspberryPiAirQualitySensor
]

// C10: Air‑quality data
instance AirQualityData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature, humidity, and pollutant concentration data."
    DTDFVocab:fromData AirQualityDataTransmitted
    DTDFVocab:inputTo AzureIoTHubEnabler
]

// C11: Enabler for TimescaleDB storage
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that writes sensor data to TimescaleDB via PostgreSQL operations."
    DTDFVocab:enables HistoricalDataLoggingService, RealTimeMonitoringService
]

// C11: Enabler for InfluxDB ingestion
instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that streams sensor data to InfluxDB for simulation ingest."
    DTDFVocab:enables SimulationService, RealTimeMonitoringService
]

// C11: Enabler for Azure IoT Hub
instance AzureIoTHubEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that streams sensor data via MQTT over ActiveMQ to Azure IoT Hub."
    DTDFVocab:enables AzureStreamAnalyticsService
]

// C6: Historical data logging service
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that archives time‑stamped sensor measurements in TimescaleDB for trend and fault analysis."
    DTDFVocab:provides AutomaticLoggingAction
]

// C6: Real‑time monitoring service
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring service that consumes joint position and payload weight data for visualization."
    DTDFVocab:provides RealTimeJointPositionInsight, PayloadWeightInsight
]

// C6: Simulation service generating predictive trajectories
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation component that consumes InfluxDB outputs to generate predictive state trajectories."
    DTDFVocab:provides PredictedJointPositionInsight
]

// C6: Azure Stream Analytics service for air‑quality prediction
instance AzureStreamAnalyticsService : DTDFVocab:Service [
    base:desc "Azure Stream Analytics processing service that outputs processed data to Azure Digital Twins."
    DTDFVocab:provides PredictedAirQualityInsight, RecommendedVentilationAction
]

// C17: Insight – Real‑time joint position
instance RealTimeJointPositionInsight : DTDFVocab:Insight [
    base:desc "Insight that displays current joint angles of the crane in Grafana dashboard."
]

// C17: Insight – Payload weight
instance PayloadWeightInsight : DTDFVocab:Insight [
    base:desc "Insight showing real‑time payload weight for monitoring."
]

// C17: Insight – Predicted joint position for simulation
instance PredictedJointPositionInsight : DTDFVocab:Insight [
    base:desc "Predicted future joint trajectories used for optimal control."
]

// C17: Insight – Predicted indoor air quality
instance PredictedAirQualityInsight : DTDFVocab:Insight [
    base:desc "Predicted indoor air quality under varying occupancy and ventilation scenarios."
]

// C17: Action – Automatic logging
instance AutomaticLoggingAction : DTDFVocab:Action [
    base:desc "Logs data events automatically when threshold values are exceeded."
    DTDFVocab:IsAutomatic true
]

// C17: Action – Recommended ventilation
instance RecommendedVentilationAction : DTDFVocab:Action [
    base:desc "Recommends ventilation interventions when pollutant thresholds are exceeded."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Control Application are dispatched through the Python‑based Physical Crane Interface to the crane controllers. Commands are sent as direct function calls over the interface; specific message formats, authentication, or validation steps are not described in the document. The system relies on the underlying Physical Crane Interface to handle low‑level communication protocols, while the Logging Application provides feedback by recording the resulting state for monitoring. No explicit conflict resolution logic or command execution confirmation protocol is detailed."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "GreenhouseDT employs a three-tiered architecture comprising the physical greenhouse equipped with sensors, a virtual machine-based digital twin environment, and a backend services layer. Communication between the greenhouse and the twin is mediated by an ActiveMQ message broker that handles asynchronous messaging for sensor telemetry and twin commands. Telemetry data are stored in an InfluxDB time‑series database, providing persistent, time‑ordered storage for monitoring and analysis. The digital twin logic, including its adaptation algorithms, is encapsulated within software components deployed in virtual machines, ensuring reproducibility and ease of installation via pre‑configured VM images."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Digital twin services communicate over an MQTT broker implementing the MQTT protocol, serving as the pub/sub middleware between components such as Trajectory Generator, Simulation, Validation, and Dashboard. The Physical Crane Interface connects to the crane controllers via a Python library; the specific underlying protocol (e.g., serial, Ethernet/IP) is not specified. Network topology is implicitly a local network with all services running as containers on the same host; no explicit bandwidth, latency, redundancy, or security measures are documented."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system comprises multiple Python‑based containers (Physical Crane Interface, Control Application, Logging Application, Human Machine Interface, Trajectory Generator, Simulation, Validation, Dashboard) but the deployment environment—whether on‑premises edge hardware, cloud, or hybrid—is not specified in the document. Computational, storage, scalability, and availability requirements are likewise not described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The exemplar utilizes Azure-based tools for its digital twin pipeline, indicating integration with Microsoft Azure services. Internally, data flow is orchestrated through an ActiveMQ broker and an InfluxDB database, while external interfaces are exposed via standard protocols such as HTTPS for RESTful access and MQTT for device communication, as suggested by the use of Raspberry‑Pi sensor nodes and Azure tools. The system’s code is hosted on GitHub, enabling source‑level integration and version control interoperability."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplar implements an AutomationML‑based digital twin model, leveraging the AutomationML specification to encode plant and component hierarchy, process data, and enable interoperability with other PLM and manufacturing systems. It also adheres to common IoT communication standards: sensor data is published over MQTT via ActiveMQ, and data ingestion into Azure utilizes the Azure IoT Hub interface, which supports industry‑standard protocols such as AMQP and HTTPS. No explicit certifications or regulatory compliance frameworks are reported."
]