// Sensing Components -------------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing, interfaced via an Arduino that streams sensor values to the Logging Application."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the crane, interfaced via an Arduino that streams sensor values to the Logging Application."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartMotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder on the cart motor for position measurement, interfaced via an Arduino that streams data to the Logging Application."
    DTDFVocab:producedData CartMotorPositionDataTransmitted
]

instance HoistMotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder on the hoist motor for position measurement, interfaced via an Arduino that streams data to the Logging Application."
    DTDFVocab:producedData HoistMotorPositionDataTransmitted
]

// Acting Components --------------------------------------------------------
instance CartMotorDriverActuator : DTDFVocab:ActingComponent [
    base:desc "Step‑per cart motor driven by a TMC4671‑Eval controller, actuated through the Physical Crane Interface."
]

instance HoistMotorDriverActuator : DTDFVocab:ActingComponent [
    base:desc "Step‑per hoist motor driven by a TMC4671‑Eval controller, actuated through the Physical Crane Interface."
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet for picking up containers, actuated through the Physical Crane Interface."
]

// Data Transmitted ----------------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CartMotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorPositionEncoder
]

instance HoistMotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorPositionEncoder
]

// Data (TimescaleDB logs) --------------------------------------------------
instance SwingAngleSensorLog : DTDFVocab:Data [
    base:desc "TimescaleDB log of swing‑angle sensor data from the physical crane."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo DatabaseEnabler
]

instance WindSpeedSensorLog : DTDFVocab:Data [
    base:desc "TimescaleDB log of wind‑speed sensor data from the physical crane."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo DatabaseEnabler
]

instance CartMotorPositionSensorLog : DTDFVocab:Data [
    base:desc "TimescaleDB log of cart motor position data from the physical crane."
    DTDFVocab:fromData CartMotorPositionDataTransmitted
    DTDFVocab:inputTo DatabaseEnabler
]

instance HoistMotorPositionSensorLog : DTDFVocab:Data [
    base:desc "TimescaleDB log of hoist motor position data from the physical crane."
    DTDFVocab:fromData HoistMotorPositionDataTransmitted
    DTDFVocab:inputTo DatabaseEnabler
]

// Models --------------------------------------------------------------------
instance KinematicModel : DTDFVocab:Model [
    base:desc "Cinematic kinematic model used by the trajectory generator and simulator."
    DTDFVocab:inputTo TrajectoryGenEnabler
]

instance CraneSimModel : DTDFVocab:Model [
    base:desc "Real‑time simulation model of the crane and its controllers."
    DTDFVocab:inputTo SimulationEnabler
]

instance CADCraneComponentsModel : DTDFVocab:Model [
    base:desc "CAD models of crane components."
]

// Enablers -------------------------------------------------------------
instance DatabaseEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database enabler for storing sensor logs and metrics."
    DTDFVocab:enables DataLoggingService, HistoricalDataAnalysisService, ContinuousValidationService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard enabler for time‑series visualization."
    DTDFVocab:enables TimeSeriesVisualizationService
]

instance TrajectoryGenEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the trajectory generator service using the kinematic model."
    DTDFVocab:enables OptimalTrajectoryGenerationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the real‑time simulation service of the crane."
    DTDFVocab:enables RealTimeSimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the continuous validation service comparing measured and simulated trajectories."
    DTDFVocab:enables ContinuousValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker enabler for streaming sensor and motor data."
    DTDFVocab:enables RealTimeSimulationService, DataLoggingService
]

// Services ---------------------------------------------------------------
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that logs raw sensor data into TimescaleDB via the DatabaseEnabler."
    DTDFVocab:provides DataLoggedInsight
]

instance TimeSeriesVisualizationService : DTDFVocab:Service [
    base:desc "Service that visualizes time‑series data in Grafana via the DashboardEnabler."
    DTDFVocab:provides SimulationVisualizationInsight
]

instance OptimalTrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service that generates optimal trajectories using the KinematicModel via the TrajectoryGenEnabler."
    DTDFVocab:provides OptimalPathCalculationAction
]

instance RealTimeSimulationService : DTDFVocab:Service [
    base:desc "Service that runs real‑time simulation of the crane and its controllers via the SimulationEnabler."
    DTDFVocab:provides SimulationVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously validates measured versus simulated trajectories via the ContinuousValidationEnabler."
    DTDFVocab:provides TrajectoryDeviationAlertInsight
]

instance HistoricalDataAnalysisService : DTDFVocab:Service [
    base:desc "Service that performs historical data analysis of crane logs via the DatabaseEnabler."
    DTDFVocab:provides HistoricalLogAnalysisAction
]

// Insights & Actions -------------------------------------------------------
instance DataLoggedInsight : DTDFVocab:Insight [
    base:desc "Insight confirming that sensor data has been successfully logged."
]

instance SimulationVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time simulation visualizations in Grafana."
]

instance TrajectoryDeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating deviations between measured and simulated crane trajectories."
]

instance OptimalPathCalculationAction : DTDFVocab:Action [
    base:desc "Action calculating optimal path for the crane to minimize swing and energy consumption."
    DTDFVocab:IsAutomatic true
]

instance HistoricalLogAnalysisAction : DTDFVocab:Action [
    base:desc "Action enabling operators to analyze historical logs for tuning parameters."
    DTDFVocab:IsAutomatic false
]

// Environment -------------------------------------------------------------
instance LabScaleGantryCraneEnv : DTDFVocab:Environment [
    base:contains CartMotorDriverActuator, HoistMotorDriverActuator, ElectromagnetActuator,
              SwingAngleEncoder, Anemometer, CartMotorPositionEncoder, HoistMotorPositionEncoder
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Trajectory Generator Service and Control Application are transmitted via MQTT to the Physical Crane Interface to drive the cart and hoist motors and the electromagnet; Validation alerts are also forwarded to the Human‑Machine Interface for operator action."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time continuous operation with sensor data logged at millisecond granularity, trajectory generation and validation executed per motion cycle, and near real‑time dashboard updates."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Services are orchestrated via Docker networking: sensor data and control messages travel over MQTT topics; simulation, trajectory generation and validation services subscribe to relevant topics; results are persisted in TimescaleDB and visualised by Grafana, while operator control is provided through a Python HMI."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design: CAD models in Autodesk Fusion360 and Capella Arcadia models capture the crane geometry and kinematics. Development: Python implementation of the kinematic model, simulation, and digit twin services. Operation: Continuous logging, real‑time control, simulation, and validation during crane use."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service computes a distance metric between measured and simulated trajectories, compares against a predefined threshold, and triggers alerts; the simulation uses a validated kinematic model to ensure swing‑motion residuals are minimized."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical–to–virtual: Python Physical Crane Interface streams sensor data over TCP to the Logging Application, which writes to TimescaleDB via PostgreSQL’s native protocol. Virtual–to–physical: Control commands are published on MQTT topics (broker Mosquitto) and consumed by the Control Application, which then commands the Physical Crane Interface. All services are networked within Docker Compose, using default ports (PostgreSQL 5432, MQTT 1883)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Containerised deployment via Docker and docker‑compose on a local workstation, with services exposed on local ports; repository hosted on GitHub for version control and reproducibility."
]