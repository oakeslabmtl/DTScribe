// C3: Physical sensing components
instance CraneControllerSensor : DTDFVocab:SensingComponent [
    base:desc "Python program Physical Crane Interface reads sensor data from crane controllers"
    DTDFVocab:producedData CraneSensorDataTransmitted
]

// C4: Physical-to-virtual interaction – Data transmitted
instance CraneSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneControllerSensor
]

// C11: Data
instance CraneSensorData : DTDFVocab:Data [
    base:desc "Live sensor streams of position, velocity, and load from the gantry crane"
    DTDFVocab:fromData CraneSensorDataTransmitted
    DTDFVocab:inputTo LoggingEnabler, ValidationEnabler, VisualizationEnabler
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the lab‑scale gantry crane used for validation and simulation"
    DTDFVocab:inputTo ValidationEnabler, TrajectoryGenerationEnabler
]

instance PhysicsBasedTrajectoryModel : DTDFVocab:Model [
    base:desc "Physics‑based model that generates optimal motion plans and confidence intervals"
    DTDFVocab:inputTo TrajectoryGenerationEnabler
]

// C11: Enablers
instance LoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB based component that records sensor and actuator data over time"
    DTDFVocab:enables HistoricalLoggingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard component that renders real‑time and archived crane states"
    DTDFVocab:enables DataVisualizationService
]

instance OptimalControlEnabler : DTDFVocab:Enabler [
    base:desc "Component that computes and dispatches improved motion commands to the crane"
    DTDFVocab:enables OptimalControlService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation component that compares live sensor data against the kinematic model"
    DTDFVocab:enables ContinuousValidationService
]

instance TrajectoryGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs physics‑based trajectory generation using the kinematic model"
    DTDFVocab:enables TrajectoryGenerationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal control service computes and dispatches improved motion commands to the crane"
    DTDFVocab:provides ImprovedMotionCommandAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Historical data logging service records sensor and actuator data over time"
    DTDFVocab:provides HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Data visualization service renders real‑time and archived crane states via a web dashboard"
    DTDFVocab:provides RealTimeStateInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service detects deviations between live data and the kinematic model"
    DTDFVocab:provides DeviationDetectionInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Trajectory generator service runs physics‑based simulations to compute optimal motion plans and confidence bounds"
    DTDFVocab:provides TrajectoryRecommendationInsight, ConfidenceBoundInsight
]

// C17: Insights / Actions
instance ImprovedMotionCommandAction : DTDFVocab:Action [
    base:desc "Dispatch improved motion command to the crane based on optimal control output"
    DTDFVocab:IsAutomatic true
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Aggregated historical sensor and actuator data for analysis"
]

instance RealTimeStateInsight : DTDFVocab:Insight [
    base:desc "Live visualization of crane sensor streams, positions, and status"
]

instance DeviationDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of deviations between live sensor data and kinematic model predictions"
]

instance TrajectoryRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommended optimal trajectory for the gantry crane derived from simulation"
]

instance ConfidenceBoundInsight : DTDFVocab:Insight [
    base:desc "Statistical confidence bounds associated with the generated trajectory"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the Trajectory Generator Service (optimal movement trajectories without residual swing) and are passed to the Control Application, a Python program that uses the same Physical Crane Interface to issue actuation commands to the crane controllers. The command messages contain trajectory waypoints (positions, velocities) and are sent over the same interface used for state acquisition. The documents do not describe explicit validation, authentication, or acknowledgment mechanisms, but operators are notified via the Dashboard if the Continuous Validation Service detects deviations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The exemplar adopts an ad‑hoc, container‑based orchestration that is modelled with the C4 architecture notation. Physical components (e.g., greenhouse sensors) are represented as separate containers that exchange data through an ActiveMQ message broker. All runtime services—including data ingestion, model execution, and adaptation logic—run inside virtual‑machine images that contain pre‑recorded data and can be instantiated quickly. State and time‑series measurements are persisted in an InfluxDB database. Coordination among the components relies on asynchronous messaging rather than a commercial digital‑twin framework, and the overall system is packaged using containerization/virtualization to simplify deployment and reproducibility."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital‑twin services (Trajectory Generator Service, Simulation Service, Continuous Validation Service, etc.) communicate via an MQTT broker using the MQTT publish/subscribe protocol, which provides the signaling backbone between the services. The Physical Crane Interface and Control Application are Python programs that connect to the crane controllers, but the document does not specify lower‑level network protocols, topology, bandwidth, latency, redundancy, or security mechanisms."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is modelled as six logical containers (Database, Dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service, MQTT Broker) according to the C4 model. These containers run on the same physical host (the document clarifies that they are not Docker containers) and consist of a TimescaleDB database for storage, a Grafana dashboard for visualization, and Python applications for the services. No specific cloud, edge, or virtualization platform is mentioned; deployment relies on local execution of these components."
]