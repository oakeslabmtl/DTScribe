// --------------------------------------------------
// C3: Physical sensing components
// --------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder that measures the swing angle of the gantry crane trolley."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Wind speed sensor used to capture ambient air velocity affecting crane dynamics."
    DTDFVocab:producedData AnemometerDataTransmitted
]

instance MotorController : DTDFVocab:SensingComponent [
    base:desc "Motor controller electronics that expose motor current, voltage and speed set‑points."
    DTDFVocab:producedData MotorControllerDataTransmitted
]

// --------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// --------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MotorControllerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorController
]

// --------------------------------------------------
// C10: Data (raw sensor readings)
// --------------------------------------------------
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped raw swing‑angle measurements acquired from the encoder."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEnabler, OptimalControlEngineEnabler
]

instance AnemometerData : DTDFVocab:Data [
    base:desc "Time‑stamped wind speed values measured by the anemometer."
    DTDFVocab:fromData AnemometerDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEnabler
]

instance MotorControllerData : DTDFVocab:Data [
    base:desc "Time‑stamped motor current, voltage and speed set‑points from the motor controller."
    DTDFVocab:fromData MotorControllerDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEnabler, OptimalControlEngineEnabler
]

// --------------------------------------------------
// C10: Models / Data (CAD & Kinematic)
// --------------------------------------------------
instance GantryCraneCADModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the laboratory‑scale gantry crane structure."
    DTDFVocab:inputTo GrafanaDashboardEnabler, TimescaleDBEnabler
]

instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Behavioural kinematic model that predicts crane motion based on control inputs."
    DTDFVocab:inputTo OptimalControlEngineEnabler, ContinuousValidationEnabler, TrajectoryGeneratorEnabler
]

// --------------------------------------------------
// C11: Enablers (software / infrastructure)
// --------------------------------------------------
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database container used for historical data logging."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Engine that continuously validates real‑time measurements against the kinematic model."
    DTDFVocab:enables ContinuousValidationService
]

instance OptimalControlEngineEnabler : DTDFVocab:Enabler [
    base:desc "Engine that computes optimal motion commands using the kinematic model."
    DTDFVocab:enables OptimalControlService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Service that generates feasible trajectories from the kinematic model."
    DTDFVocab:enables OptimalControlService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana container that visualises crane state, trajectories and logged data."
    DTDFVocab:enables InteractiveVisualizationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for inter‑service signalling."
    // No direct service attached here; it underpins other services.
]

// --------------------------------------------------
// C6: Services
// --------------------------------------------------
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal‑control service that computes motion commands for the crane."
    DTDFVocab:provides MotionCommandAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Historical data‑logging service that stores sensor and actuator traces in TimescaleDB."
    DTDFVocab:provides HistoricalDataInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualisation service that displays crane state and trajectory via Grafana."
    DTDFVocab:provides VisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service that compares realtime measurements with the kinematic model to detect deviations."
    DTDFVocab:provides DeviationDetectionInsight
]

// --------------------------------------------------
// C17: Insights / Actions
// --------------------------------------------------
instance MotionCommandAction : DTDFVocab:Action [
    base:desc "Automatic motion command issued to the crane actuators."
    DTDFVocab:IsAutomatic true
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight derived from stored historical sensor and actuator data for analysis and model refinement."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Live visual insight of crane position, swing angle and trajectory."
]

instance DeviationDetectionInsight : DTDFVocab:Insight [
    base:desc "Alert indicating a deviation between measured state and kinematic model prediction."
]

// --------------------------------------------------
// C2: Acting Components (physical side)
// --------------------------------------------------
instance PhysicalCrane : DTDFVocab:ActingComponent [
    base:desc "Laboratory‑scale gantry crane consisting of a gantry, motorised trolley and interchangeable pucks."
]

instance PhysicalCraneInterface : DTDFVocab:ActingComponent [
    base:desc "Python program that connects to crane controllers and streams raw measurements to the logging application."
]

instance ControlApplication : DTDFVocab:ActingComponent [
    base:desc "Application that receives optimal motion commands and forwards them to the crane motor controllers."
]

instance LoggingApplication : DTDFVocab:ActingComponent [
    base:desc "Application that writes time‑stamped state records into TimescaleDB."
]

instance HumanMachineInterface : DTDFVocab:ActingComponent [
    base:desc "Operator GUI for manual control and monitoring of the crane."
]

// --------------------------------------------------
// C13: Components (logical containers)
// --------------------------------------------------
instance TimescaleDBContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the TimescaleDB instance."
]

instance GrafanaContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the Grafana dashboard."
]

instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Container running the trajectory generator service."
]

instance SimulationContainer : DTDFVocab:Component [
    base:desc "Container that runs the crane simulation service."
]

instance ContinuousValidationContainer : DTDFVocab:Component [
    base:desc "Container that runs the continuous validation service."
]

instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Container that runs the Eclipse Mosquitto MQTT broker."
]

// --------------------------------------------------
// C9: Environment
// --------------------------------------------------
instance GantryCraneLabEnvironment : DTDFVocab:Environment [
    base:contains PhysicalCrane, PhysicalCraneInterface, ControlApplication, LoggingApplication, HumanMachineInterface,
                TimescaleDBContainer, GrafanaContainer, TrajectoryGeneratorContainer, SimulationContainer,
                ContinuousValidationContainer, MQTTBrokerContainer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (implemented in Python) generates motion commands—such as optimal trajectories produced by the Trajectory Generator Service—and sends them to the Physical Crane Interface, which forwards the commands to the crane’s motor controllers. Execution feedback is captured by the Logging Application and stored in the database. Service coordination and command notifications are mediated via the MQTT broker, but the command messages themselves travel over the Python interface to the physical controllers."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows an ad‑hoc, container‑based architecture described with the C4 model. Physical and digital components run as separate Python applications or services packaged as containers. The Logging Application continuously writes crane state data to a TimescaleDB database; the Grafana dashboard visualizes this data. The Trajectory Generator Service creates optimal movement trajectories based on a kinematics model, which are consumed by the Simulation Service and the Control Application to drive the physical crane. The Continuous Validation Service continuously compares measured trajectories with simulated ones, calculates distance metrics, and triggers alerts through the dashboard when thresholds are exceeded. All services exchange messages via an MQTT broker using publish/subscribe semantics, providing the system‑wide coordination mechanism without employing a commercial digital‑twin framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through continuous validation approaches, including fault‑detection methods based on time‑series classification and reuse of model validation techniques. The kinematic model’s predictions are continuously compared with logged operational data to detect and correct deviations, and validation outcomes are fed back to update the models, maintaining their accuracy over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital‑twin components (TimescaleDB, Grafana dashboard, MQTT broker) are containerised with Docker and orchestrated via Docker‑Compose on a single host PC, communicating over the host’s Docker network using TCP/IP. The MQTT broker provides publish/subscribe messaging for inter‑service signalling, while TimescaleDB uses the PostgreSQL protocol for database access. No explicit bandwidth, latency, redundancy, or security mechanisms (e.g., TLS) are described in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software runs on‑premise on a personal computer. Docker containers host the database, MQTT broker and dashboard, launched together with Docker‑Compose. The Python services are distributed as a pip‑installable package named gantrylib. Deployment relies on open‑source tools (TimescaleDB, Grafana, Eclipse Mosquitto) and does not involve cloud or edge platforms. The documents do not detail scalability mechanisms, storage sizing, or high‑availability provisions."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The twin model is expressed in AutomationML, complying with the AutomationML standard for model‑driven engineering and ensuring interoperability with other tools that support this specification. No additional industry standards or certification frameworks are referenced in the documents."
]