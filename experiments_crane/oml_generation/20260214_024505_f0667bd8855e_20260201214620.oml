]

instance DataFlowExecutionToValidation : DTDFVocab:DataFlow [
    DTDFVocab:from TrajectoryExecutionData
    DTDFVocab:to ContinuousValidationEnabler
]

instance DataFlowSimulationToValidation : DTDFVocab:DataFlow [
    DTDFVocab:from SimulationTrajectoryData
    DTDFVocab:to ContinuousValidationEnabler
]

instance DataFlowValidationService : DTDFVocab:DataFlow [
    DTDFVocab:from ContinuousValidationEnabler
    DTDFVocab:to ContinuousValidationService
]

instance DataFlowInterfaceToService : DTDFVocab:DataFlow [
    DTDFVocab:from PhysicalCraneInterface
    DTDFVocab:to DataAcquisitionService
]

instance DataFlowMQTTToLogging : DTDFVocab:DataFlow [
    DTDFVocab:from MQTTBrokerEnabler
    DTDFVocab:to LoggingService
]

instance DataFlowDBToVisualization : DTDFVocab:DataFlow [
    DTDFVocab:from TimescaleDBEnabler
    DTDFVocab:to DataVisualizationService
]

instance DataFlowVisualization : DTDFVocab:DataFlow [
    DTDFVocab:from CraneVisualizationEnabler
    DTDFVocab:to DataVisualizationService
]

