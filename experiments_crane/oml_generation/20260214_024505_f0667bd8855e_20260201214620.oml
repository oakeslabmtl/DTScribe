// C2: Acting Components
instance CartMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor responsible for horizontal movement along the gantry rail, controlled via the PhysicalCraneInterface and TrajectoryGeneratorService"
]

instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor responsible for vertical movement (lifting/lowering) of the crane's hoist mechanism, integrated with the ContinuousValidationService for trajectory validation"
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnetic actuator for gripping/releasing puck containers, synchronized with trajectory execution through the OptimalControlService"
]

// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution angular sensor mounted on the crane's arm measuring swinging motion for real-time trajectory validation"
    DTDFVocab:producedData SwingAngleData
]

instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor providing real-time kinematic feedback for cart and hoist movements, integrated with the ContinuousValidationService"
    DTDFVocab:producedData CranePositionData
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Velocity sensor measuring instantaneous speed of crane components for dynamic trajectory validation"
    DTDFVocab:producedData CraneVelocityData
]

instance CraneAccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Acceleration sensor capturing dynamic motion characteristics for residual swinging analysis"
    DTDFVocab:producedData CraneAccelerationData
]

instance PuckContainerStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring puck container status (gripped/ungripped) for trajectory execution validation"
    DTDFVocab:producedData PuckContainerStatusData
]

instance CraneEnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring environmental wind speed for contextual crane operation analysis"
    DTDFVocab:producedData EnvironmentalData
]

// C4: Physical-to-Virtual Data Transmission
instance SwingAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance CranePositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor
]

instance CraneVelocityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocitySensor
]

instance CraneAccelerationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneAccelerationSensor
]

instance PuckContainerStatusData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PuckContainerStatusSensor
]

instance EnvironmentalData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneEnvironmentalSensor
]

instance TrajectoryExecutionMetrics : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor, CraneVelocitySensor, CraneAccelerationSensor
]

// C10: Models/Data
instance GantryCraneCADModel : DTDFVocab:Model [
    base:desc "3D CAD representation of the gantry crane structure created in Autodesk Fusion 360 for structural visualization"
    DTDFVocab:inputTo CraneVisualizationEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Python-implemented kinematic model simulating crane movements for trajectory planning and validation"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler, ContinuousValidationEnabler
]

instance RealTimeCraneStateData : DTDFVocab:Data [
    base:desc "Continuous time-series data representing real-time crane state including positions, velocities, and container status"
    DTDFVocab:fromData CranePositionData, CraneVelocityData, PuckContainerStatusData
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEnabler
]

instance TrajectoryExecutionData : DTDFVocab:Data [
    base:desc "Historical data capturing executed trajectories with metrics like endpoint deviations and residual swinging motion"
    DTDFVocab:fromData TrajectoryExecutionMetrics
    DTDFVocab:inputTo TimescaleDBEnabler, ContinuousValidationEnabler
]

instance SimulationTrajectoryData : DTDFVocab:Data [
    base:desc "Predicted trajectory data generated by the kinematic model for comparison with real-world execution"
    DTDFVocab:fromData CraneKinematicModel
    DTDFVocab:inputTo ContinuousValidationEnabler
]

// C11: Enablers
instance PhysicalCraneInterface : DTDFVocab:Enabler [
    base:desc "Python-based interface facilitating direct communication between physical crane controllers and digital twin components"
    DTDFVocab:enables DataAcquisitionService, OptimalControlService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker enabling asynchronous, event-driven communication between PhysicalCraneInterface and LoggingApplication"
    DTDFVocab:enables DataAcquisitionService, LoggingService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time-series database storing high-resolution crane state data for historical analysis and validation"
    DTDFVocab:enables LoggingService, ContinuousValidationService, DataVisualizationService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana-based visualization platform providing real-time monitoring of crane performance metrics"
    DTDFVocab:enables DataVisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python-based trajectory planning engine utilizing the kinematic model to generate optimal motion paths"
    DTDFVocab:enables OptimalControlService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Service comparing executed trajectories with simulated predictions using distance metrics and threshold validation"
    DTDFVocab:enables ContinuousValidationService
]

instance CraneVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D visualization component rendering the CAD model with real-time sensor data overlay"
    DTDFVocab:enables DataVisualizationService
]

// C6: Services
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Continuous data collection service capturing real-time sensor data from the physical crane via the PhysicalCraneInterface"
    DTDFVocab:provides RealTimeCraneStateInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Trajectory generation and optimization service creating motion plans for crane operations using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Runtime validation service comparing simulated trajectories with actual execution to detect anomalies and validate system behavior"
    DTDFVocab:provides SystemValidationInsight, FaultDetectionAction
]

instance LoggingService : DTDFVocab:Service [
    base:desc "Historical data logging service storing crane state data in TimescaleDB for post-analysis and validation"
    DTDFVocab:provides HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Real-time dashboard service providing visual representation of crane performance metrics through Grafana"
    DTDFVocab:provides CranePerformanceInsight
]

// C17: Insights/Actions
instance RealTimeCraneStateInsight : DTDFVocab:Insight [
    base:desc "Continuous insight into current crane state including positions, velocities, and container status for operational monitoring"
]

instance OptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Automated generation and execution of optimized crane trajectories based on kinematic simulations"
    DTDFVocab:IsAutomatic true
]

instance SystemValidationInsight : DTDFVocab:Insight [
    base:desc "Validation metrics comparing simulated and executed trajectories with performance thresholds"
]

instance FaultDetectionAction : DTDFVocab:Action [
    base:desc "Automated detection of system anomalies based on trajectory deviations and sensor data anomalies"
    DTDFVocab:IsAutomatic true
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Historical analysis of crane operations including trajectory execution patterns and performance trends"
]

instance CranePerformanceInsight : DTDFVocab:Insight [
    base:desc "Visual representation of crane performance metrics through interactive dashboards"
]

// C1: Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Controlled laboratory environment housing the physical gantry crane system and its associated digital twin infrastructure"
    base:contains GantryCraneStructure, CraneController, PhysicalCraneInterface, MQTTBrokerEnabler
]

// C5: Physical Components
instance GantryCraneStructure : DTDFVocab:Component [
    base:desc "Mechanical assembly comprising movable beams and structural elements enabling material handling operations"
    base:isContainedIn LabScaleGantryCraneEnvironment
]

instance CraneController : DTDFVocab:Component [
    base:desc "Embedded controller interfacing with sensors and actuators for real-time crane operation and closed-loop control"
    base:isContainedIn LabScaleGantryCraneEnvironment
]

// Relationships
instance DataFlowSwingAngle : DTDFVocab:DataFlow [
    DTDFVocab:from SwingAngleEncoder
    DTDFVocab:to SwingAngleData
]

instance DataFlowPosition : DTDFVocab:DataFlow [
    DTDFVocab:from CranePositionSensor
    DTDFVocab:to CranePositionData
]

instance DataFlowVelocity : DTDFVocab:DataFlow [
    DTDFVocab:from CraneVelocitySensor
    DTDFVocab:to CraneVelocityData
]

instance DataFlowAcceleration : DTDFVocab:DataFlow [
    DTDFVocab:from CraneAccelerationSensor
    DTDFVocab:to CraneAccelerationData
]

instance DataFlowContainerStatus : DTDFVocab:DataFlow [
    DTDFVocab:from PuckContainerStatusSensor
    DTDFVocab:to PuckContainerStatusData
]

instance DataFlowEnvironmental : DTDFVocab:DataFlow [
    DTDFVocab:from CraneEnvironmentalSensor
    DTDFVocab:to EnvironmentalData
]

instance DataFlowMetrics : DTDFVocab:DataFlow [
    DTDFVocab:from CranePositionSensor
    DTDFVocab:from CraneVelocitySensor
    DTDFVocab:from CraneAccelerationSensor
    DTDFVocab:to TrajectoryExecutionMetrics
]

instance DataFlowSimulation : DTDFVocab:DataFlow [
    DTDFVocab:from CraneKinematicModel
    DTDFVocab:to SimulationTrajectoryData
]

instance DataFlowStateToDB : DTDFVocab:DataFlow [
    DTDFVocab:from RealTimeCraneStateData
