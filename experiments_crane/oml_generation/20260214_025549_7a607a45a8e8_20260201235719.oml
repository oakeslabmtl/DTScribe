// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor controlling the horizontal (cart) movement of the gantry crane, interfaced with Trinamic TMC4671-Eval controller"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor controlling the vertical (hoist) movement of the gantry crane, interfaced with Trinamic TMC4671-Eval controller"
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnetic device at the end effector for picking up and releasing small pucks (representing containers)"
]

// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swinging motion of the hoist during container pickup/drop operations"
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Wind speed sensor measuring environmental conditions affecting crane operations"
]

instance CartPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder tracking the horizontal position of the cart component"
]

instance HoistPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder tracking the vertical position of the hoist component"
]

// C4: Physical-to-Virtual Data Transmission
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CartPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartPositionEncoder
]

instance HoistPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistPositionEncoder
]

instance CraneEventDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoController
]

// C6: Services
instance OptimalTrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service using kinematic models to generate smooth, efficient crane movements while minimizing residual swinging"
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service storing crane operational data in TimescaleDB for analysis and trend tracking"
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service providing real-time monitoring of crane states, trajectories, and alerts through Grafana dashboards"
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Service comparing simulated and actual trajectories to detect anomalies or faults in crane operations"
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service simulating crane behavior for testing control strategies or predicting outcomes without physical risk"
]

instance EducationalService : DTDFVocab:Service [
    base:desc "Service demonstrating digital twin concepts and system evolution using Capella models for educational purposes"
]

// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Mathematical model of the crane's movement for trajectory generation and swing dynamics analysis, implemented in Python"
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Digital replica of the crane and controllers for testing and validation of control strategies, implemented using Python simulation"
]

instance CraneValidationModel : DTDFVocab:Model [
    base:desc "Model comparing simulated trajectories with actual trajectories to detect anomalies or faults"
]

instance TimescaleDBHistoricalData : DTDFVocab:Data [
    base:desc "Time-series database storing crane operational data including trajectories, sensor readings, and operational events"
    DTDFVocab:fromData SwingAngleDataTransmitted, WindSpeedDataTransmitted, CartPositionDataTransmitted, HoistPositionDataTransmitted, CraneEventDataTransmitted
]

instance CapellaHarborSystemModel : DTDFVocab:Model [
    base:desc "System engineering model of the harbor system created in Capella for educational purposes, demonstrating crane integration"
]

instance Fusion360CADModel : DTDFVocab:Model [
    base:desc "3D CAD representation of the crane created in Fusion360 used as the geometric foundation for the digital twin"
]

// C11: Enablers
instance ArduinoController : DTDFVocab:Enabler [
    base:desc "Arduino-based system collecting sensor data and interfacing with motor controllers and electromagnet, using MQTT for communication"
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker facilitating real-time communication between physical sensors and digital twin components"
]

instance PythonGantryLib : DTDFVocab:Enabler [
    base:desc "Python module (gantrylib) orchestrating all digital twin services and coordinating between components"
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB time-series database storing historical operational data for analysis and trend tracking"
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana-based visualization platform providing real-time monitoring of crane states, trajectories, and alerts"
]

// C17: Insights/Actions
instance OperationalOptimizationInsight : DTDFVocab:Insight [
    base:desc "Identification of optimal trajectories and reduction of residual swinging motion through trajectory optimization"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Alerting operators via dashboard when deviations exceed thresholds (e.g., unexpected swinging or motor errors)"
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Analysis of historical data to predict potential failures (e.g., motor wear) before they occur"
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Continuous visualization of crane states, trajectories, and operational parameters through Grafana dashboards"
]

instance HistoricalDataAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analysis of time-series data to identify operational patterns and trends in crane performance"
]

instance EducationalDemonstrationInsight : DTDFVocab:Insight [
    base:desc "Demonstration of digital twin concepts, system evolution, and cyber-physical system engineering to students"
]

instance EducationalContentInsight : DTDFVocab:Insight [
    base:desc "Providing Capella models and documentation for teaching digital twin and system engineering principles"
]

instance TrajectoryExecutionAction : DTDFVocab:Action [
    base:desc "Execution of optimized trajectories on the physical crane system"
    DTDFVocab:IsAutomatic true
]

instance FaultAlertAction : DTDFVocab:Action [
    base:desc "Automatic generation of alerts when faults are detected in crane operations"
    DTDFVocab:IsAutomatic true
]

// C12: Environment
instance CraneEnvironment : DTDFVocab:Environment [
    base:contains CartStepperMotor, HoistStepperMotor, CraneElectromagnet, SwingAngleEncoder, Anemometer, CartPositionEncoder, HoistPositionEncoder, ArduinoController
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains CraneKinematicModel, CraneSimulationModel, CraneValidationModel, TimescaleDBHistoricalData, CapellaHarborSystemModel, Fusion360CADModel, MQTTBroker, PythonGantryLib, TimescaleDB, GrafanaDashboard
]

instance CraneSystem : DTDFVocab:Environment [
    base:desc "System environment containing both physical and digital twin environments"
    base:contains CraneEnvironment, DigitalTwinEnvironment
]

// Relationships
instance CraneEnvironment : DTDFVocab:Environment [
    DTDFVocab:hasEnvironment CraneSystem
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    DTDFVocab:hasEnvironment CraneSystem
]

// Service-Enabler relationships
instance PythonGantryLib : DTDFVocab:Enabler [
    DTDFVocab:enables OptimalTrajectoryGenerationService, SimulationService, ValidationService, DataLoggingService, VisualizationService
]

instance TimescaleDB : DTDFVocab:Enabler [
    DTDFVocab:enables DataLoggingService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    DTDFVocab:enables VisualizationService
]

instance MQTTBroker : DTDFVocab:Enabler [
    DTDFVocab:enables DataLoggingService, SimulationService
]

instance ArduinoController : DTDFVocab:Enabler [
    DTDFVocab:enables DataLoggingService
]

// Service-Insight relationships
instance OptimalTrajectoryGenerationService : DTDFVocab:Service [
    DTDFVocab:provides OperationalOptimizationInsight
]

instance DataLoggingService : DTDFVocab:Service [
    DTDFVocab:provides HistoricalDataAnalysisInsight
]

instance VisualizationService : DTDFVocab:Service [
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance ValidationService : DTDFVocab:Service [
    DTDFVocab:provides FaultDetectionInsight
]

instance SimulationService : DTDFVocab:Service [
    DTDFVocab:provides EducationalDemonstrationInsight
]

instance EducationalService : DTDFVocab:Service [
    DTDFVocab:provides EducationalContentInsight
]

// Model-Enabler relationships
instance CraneKinematicModel : DTDFVocab:Model [
    DTDFVocab:inputTo PythonGantryLib
]

instance CraneSimulationModel : DTDFVocab:Model [
    DTDFVocab:inputTo PythonGantryLib
]

instance CraneValidationModel : DTDFVocab:Model [
    DTDFVocab:inputTo PythonGantryLib
]

instance CapellaHarborSystemModel : DTDFVocab:Model [
    DTDFVocab:inputTo EducationalService
]

instance Fusion360CADModel : DTDFVocab:Model [
    DTDFVocab:inputTo VisualizationService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin influences the physical system through:
  - **Trajectory Generation Service**: Generates optimal movement trajectories for the crane (e.g., minimizing residual swinging motion) and sends control commands to the crane via the **Control Application**.
  - **Simulation Service**: Simulates crane behavior and controller performance, which can be used to refine control strategies or predict outcomes before physical execution.
  - **Continuous Validation Service**: Compares simulated trajectories with actual measurements and alerts operators if deviations exceed acceptable thresholds (e.g., via the dashboard)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation consists of:
  - **Physical System**: Crane hardware, Arduino, and controllers.
  - **Digital Twin Components**:
    - **Database** (TimescaleDB) for storing data.
    - **Dashboard** (Grafana) for visualization.
    - **Trajectory Generator Service** (kinematic model-based).
    - **Simulation Service** (digital replica of the crane).
    - **Continuous Validation Service** (compares simulated vs. actual trajectories).
    - **MQTT Broker** (Eclipse Mosquitto) for inter-service communication.
  - **Orchestration**: Python module (`gantrylib`) integrates all services and interfaces with the physical system via Docker containers (for database, dashboard, broker)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin covers the **as-operated** phase of the crane's lifecycle, focusing on real-time monitoring, control, and validation during operation. It does not explicitly model the 'as-designed' or 'as-manufactured' phases, though CAD models and kinematic simulations are used for planning and validation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
  - **Continuous Validation**: Compares simulated trajectories with actual measurements using distance metrics and thresholds.
  - **Uncertainty Handling**: Simulation confidence bounds (upper/lower bounds) are derived for trajectory predictions.
  - **Verification**: Testing of digital twin services (e.g., trajectory generation, fault detection) against physical crane data.
  - **Validation**: Use of existing model validation techniques (e.g., [4], [5]) to ensure accuracy of kinematic and simulation models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection between the physical and digital twin uses:
  - **Network Protocol**: MQTT (Eclipse Mosquitto broker) for real-time data exchange between services and the physical system.
  - **Data Flow**: Sensor data (Arduino) → MQTT → Digital Twin Services → Control Commands → Physical Crane.
  - **Synchronization**: High-frequency data streams (e.g., motor positions) for real-time control and validation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is hosted and deployed on:
  - **Physical Crane**: Runs on a personal computer with all software (Python, Docker containers) installed locally.
  - **Docker Containers**: Containerized components (database, dashboard, MQTT broker) managed via `docker-compose`.
  - **Cloud/Remote**: Not explicitly used; the setup is designed for local deployment on a single machine for simplicity."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Limited horizontal integration is mentioned, but the exemplar primarily focuses on the crane and its digital twin. Extensions for teaching include:
  - Integration with a **harbor system** (e.g., container identification, ship buoyancy models) for broader logistics use cases.
  - **Capella models** for system engineering education (e.g., modeling the harbor and ship digital twins)."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership is not explicitly addressed in the document. The exemplar is published under an **MIT license**, suggesting open access to the code and data. Privacy considerations are not detailed, but the use of open-source tools (e.g., TimescaleDB, Grafana) implies standard data handling practices."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplar does not adhere to specific digital twin standards but uses:
  - **Open-Source Technologies**: TimescaleDB, Grafana, Eclipse Mosquitto, Docker.
  - **Ad-Hoc Approach**: No dedicated digital twin framework (e.g., Eclipse Ditto, BaSyx) is used, though these could be integrated in future work.
  - **Modeling Standards**: CAD models (Fusion360), Arcadia/Capella for system engineering (used in teaching)."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety considerations include:
  - **Localized Deployment**: All components run on a personal computer, reducing exposure to cyber threats.
  - **Continuous Validation**: Real-time monitoring mitigates operational risks (e.g., crane malfunctions) by alerting operators to deviations.
  - **No Remote Operation**: The system is designed for lab-scale use with human oversight; remote execution of unsafe operations is not supported.
  - **Lack of Formal Safety Standards**: No mention of ISO 13849, functional safety, or cybersecurity protocols (e.g., TLS, authentication). Safety relies on manual operator intervention via the Human Machine Interface."
]