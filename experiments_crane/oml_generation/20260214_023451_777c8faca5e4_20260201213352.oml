]

instance PositionEncoderZ : DTDFVocab:SensingComponent [
    base:desc "High-frequency sensor measuring Z-axis position coordinates of the gantry crane carriage, transmitted via proprietary hardware communication protocols."
    DTDFVocab:producedData PositionCoordinateDataZ
]

