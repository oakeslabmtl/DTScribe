instance PositionCoordinateDataX : DTDFVocab:DataTransmitted [
    base:desc "Real-time X-axis position coordinates transmitted at 10-100Hz via proprietary hardware protocols."
    DTDFVocab:producedFrom PositionEncoderX
]

instance PositionCoordinateDataY : DTDFVocab:DataTransmitted [
    base:desc "Real-time Y-axis position coordinates transmitted at 10-100Hz via proprietary hardware protocols."
    DTDFVocab:producedFrom PositionEncoderY
]

instance PositionCoordinateDataZ : DTDFVocab:DataTransmitted [
    base:desc "Real-time Z-axis position coordinates transmitted at 10-100Hz via proprietary hardware protocols."
    DTDFVocab:producedFrom PositionEncoderZ
]

instance VelocityData : DTDFVocab:DataTransmitted [
    base:desc "Real-time velocity measurements (linear and angular) transmitted at 10-100Hz for dynamic motion analysis."
    DTDFVocab:producedFrom VelocitySensor
]

instance AccelerationData : DTDFVocab:DataTransmitted [
    base:desc "Real-time acceleration measurements transmitted at 10-100Hz for dynamic load handling validation."
    DTDFVocab:producedFrom AccelerationSensor
]

instance LoadWeightData : DTDFVocab:DataTransmitted [
    base:desc "High-precision load weight measurements transmitted at 10-100Hz for dynamic load handling validation."
    DTDFVocab:producedFrom LoadCellSensor
]

