]

// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Parametric CAD-based kinematic model of the gantry crane structure, joints, and actuators using FreeCAD/SolidWorks for geometric foundation."
    DTDFVocab:inputTo PythonSimulationEngine, ROSControlMiddleware
]

instance LoadDynamicModel : DTDFVocab:Model [
    base:desc "Multibody physics simulation model for crane load dynamics using NumPy/SciPy for forward/inverse kinematics."
    DTDFVocab:inputTo PythonSimulationEngine, ROSControlMiddleware
]

instance PhysicalCraneData : DTDFVocab:Data [
    base:desc "Structured time-series data repository containing all sensor measurements from the physical crane system."
    DTDFVocab:fromData PositionCoordinateDataX, PositionCoordinateDataY, PositionCoordinateDataZ, VelocityData, AccelerationData, LoadWeightData, TrajectoryExecutionStatusData, EnvironmentalSensorData
    DTDFVocab:inputTo TimescaleDBLogger, ContinuousValidationService
]

instance DigitalTwinStateData : DTDFVocab:Data [
    base:desc "Real-time state data representing the digital twin's simulation state synchronized with physical measurements."
    DTDFVocab:fromData SimulatedTrajectoryData
    DTDFVocab:inputTo ROSControlMiddleware, VisualizationPlatform
]

instance SimulatedTrajectoryData : DTDFVocab:Data [
    base:desc "Predicted trajectory data generated by the digital twin's kinematic and dynamic models."
    DTDFVocab:fromData CraneKinematicModel, LoadDynamicModel
    DTDFVocab:inputTo ROSControlMiddleware, ContinuousValidationService
]

// C11: Enablers
instance PythonSimulationEngine : DTDFVocab:Enabler [
    base:desc "Python-based simulation environment using NumPy/SciPy for kinematic and dynamic simulations of crane movement and load dynamics."
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

instance ROSControlMiddleware : DTDFVocab:Enabler [
    base:desc "Robot Operating System middleware for real-time control prototyping and low-latency communication between physical crane and digital twin."
    DTDFVocab:enables OptimalControlService, DataVisualizationService
]

instance TimescaleDBLogger : DTDFVocab:Enabler [
    base:desc "TimescaleDB-based time-series database for high-frequency logging of physical and simulated crane data with minimal preprocessing."
    DTDFVocab:enables HistoricalDataLoggingService, ContinuousValidationService
]

instance PythonCraneInterface : DTDFVocab:Enabler [
    base:desc "Python-based containerized interface bridging physical crane hardware with digital twin components via proprietary communication protocols."
    DTDFVocab:enables PhysicalToVirtualDataIngestion
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT message broker facilitating asynchronous inter-service communication between physical data ingestion and digital twin components."
    DTDFVocab:enables ServiceCommunication
]

instance VisualizationPlatform : DTDFVocab:Enabler [
    base:desc "3D visualization platform using Unity/Unreal Engine or custom Python GUIs for real-time telemetry and comparative visualization."
    DTDFVocab:enables DataVisualizationService
]

instance FaultDetectionEngine : DTDFVocab:Enabler [
    base:desc "Python-based machine learning engine using scikit-learn/TensorFlow for residual analysis and anomaly detection in crane operations."
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Real-time model-predictive control service optimizing crane trajectory, load handling, and energy efficiency using digital twin predictions."
    DTDFVocab:provides TrajectoryOptimizationInsight, ControlCommandAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Data acquisition and archival service logging time-series data for longitudinal validation of digital twin accuracy."
    DTDFVocab:provides CraneOperationHistoryInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization service rendering 3D kinematic simulations and real-time telemetry comparisons."
    DTDFVocab:provides CraneVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Real-time validation framework comparing physical measurements with simulated trajectories using residual analysis and machine learning."
    DTDFVocab:provides SystemHealthInsight, FaultDetectionInsight
]

instance PhysicalToVirtualDataIngestion : DTDFVocab:Service [
    base:desc "Python service continuously ingesting and preprocessing physical crane data streams before logging to TimescaleDB."
    DTDFVocab:provides DataPreprocessingInsight
]

instance DigitalToPhysicalCommandExecution : DTDFVocab:Service [
    base:desc "Service executing optimized control commands from the digital twin to the physical crane actuators."
    DTDFVocab:provides ControlCommandAction
]

instance ServiceCommunication : DTDFVocab:Service [
    base:desc "MQTT-based service facilitating asynchronous communication between all digital twin components."
    DTDFVocab:provides SystemSynchronizationInsight
]

// C17: Insights/Actions
instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized crane trajectory recommendations generated by model-predictive control algorithms for improved operational efficiency."
]

instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Automated control commands executed on physical crane actuators based on digital twin predictions."
    DTDFVocab:IsAutomatic true
]

instance CraneOperationHistoryInsight : DTDFVocab:Insight [
    base:desc "Historical analysis of crane operations including kinematic states, sensor readings, and control commands for performance validation."
]

instance CraneVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D visualization comparing digital twin predictions with physical system measurements for debugging and validation."
]

instance SystemHealthInsight : DTDFVocab:Insight [
    base:desc "Real-time system health metrics including model fidelity, sensor reliability, and operational status."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection results identifying potential faults in crane components based on residual analysis."
]

instance DataPreprocessingInsight : DTDFVocab:Insight [
    base:desc "Preprocessing status and quality metrics for physical data streams before digital twin integration."
]

instance SystemSynchronizationInsight : DTDFVocab:Insight [
    base:desc "Status of real-time synchronization between physical system and digital twin components."
]

