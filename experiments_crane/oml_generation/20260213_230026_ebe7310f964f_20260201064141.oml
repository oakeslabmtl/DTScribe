// C3: Physical sensing components
instance SwingAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Swing Angle Encoder measured by Arduino and forwarded to Physical Crane Interface"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measured by Arduino and forwarded to Physical Crane Interface"
    DTDFVocab:producedData AnemometerDataTransmitted
]

// C4: Physical-to-virtual interaction – Data transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensor
]

instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// C10: Data artifacts
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Swing angle measurement values of the crane"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo MqttBrokerEnabler, TimescaleDBEnabler
]

instance AirFlowData : DTDFVocab:Data [
    base:desc "Airflow speed readings from the anemometer"
    DTDFVocab:fromData AnemometerDataTransmitted
    DTDFVocab:inputTo MqttBrokerEnabler, TimescaleDBEnabler
]

// C11: Enablers
instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service signalling"
    DTDFVocab:enables HistoricalLoggingService, ContinuousValidationService, RealTimeVisualizationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database for historical data storage"
    DTDFVocab:enables HistoricalLoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for real‑time visualization of crane state"
    DTDFVocab:enables RealTimeVisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Trajectory Generator service creating optimal motion plans"
    DTDFVocab:enables OptimalControlService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation service executing the kinematic model"
    DTDFVocab:enables SimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous Validation service comparing logged data with simulated trajectories"
    DTDFVocab:enables ContinuousValidationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Fault‑detection module supporting research studies"
    DTDFVocab:enables FaultDetectionService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal control of crane motion based on the kinematic model"
    DTDFVocab:provides OptimalControlInsight
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Historical logging of sensor and actuator states"
    DTDFVocab:provides HistoricalDataInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of crane position and performance"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation of the physical system against the digital model"
    DTDFVocab:provides ValidationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of crane behavior using the kinematic model"
    DTDFVocab:provides SimulationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault‑detection support used in research studies"
    DTDFVocab:provides FaultDetectionInsight
]

// C17: Insights
instance OptimalControlInsight : DTDFVocab:Insight [
    base:desc "Provides optimized motion trajectories for the gantry crane"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Enables analysis of historical sensor and actuator data"
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Delivers live visual representation of crane state"
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Reports discrepancies between physical measurements and simulated trajectories"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Shows simulated crane motion for what‑if analysis"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identifies anomalies or faults in crane operation"
]

// C10: Models
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "CAD geometric model of the gantry crane used for visualization"
    DTDFVocab:inputTo GrafanaEnabler, SimulationEnabler
]

instance KinematicBehaviorModel : DTDFVocab:Model [
    base:desc "Kinematic model representing crane motion used for control and validation"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler, SimulationEnabler, ContinuousValidationEnabler
]

// C2: Acting Component
instance GantryCraneMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Motorised trolley and hoist actuator that moves the crane along the gantry"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal movement trajectories using a kinematic model of the crane. These trajectories are passed to the Control Application, a Python application that uses the Physical Crane Interface to send command set‑points to the motor controllers (cart and hoist) of the physical crane. The Control Application therefore drives the crane according to the digital twin’s plan, and receives feedback through the same interface to confirm execution. The documents do not specify command formats, authentication, or conflict‑resolution mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a service‑oriented constellation orchestrated through an MQTT broker that provides pub/sub signaling among the Trajectory Generator, Simulation, and Continuous Validation services. Runtime data are persisted in a TimescaleDB instance and visualized via a Grafana dashboard. The logical components are described using the C4 model, and the twin can operate independently of the physical crane, enabling a decoupled yet tightly coordinated architecture."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The exemplar is employed to demonstrate continuous validation methods, fault detection techniques, and the DarTwin notation for system evolution, indicating that model fidelity is maintained through ongoing validation, though specific validation procedures or uncertainty quantification methods are not detailed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital‑twin components run on a single personal computer and are orchestrated with Docker Compose. The Database (TimescaleDB), MQTT Broker (Eclipse Mosquitto) and Dashboard (Grafana) are containerised and communicate over the host’s TCP/IP network. Signalling between services uses MQTT publish/subscribe; Grafana accesses the database via HTTP/SQL; and the Python applications interact with the MQTT broker and the database over standard TCP ports. The documents do not provide explicit bandwidth, latency, reliability, redundancy, or security protocol details."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin is deployed on‑premise on a personal computer. The Python modules are installed via pip (gantrylib). Docker containers host the TimescaleDB database, the MQTT broker, and the Grafana dashboard, and are started with a single docker‑compose command that also performs first‑time initialization of the database and dashboard. Computational and storage requirements are modest and suitable for a single workstation; scalability is limited to what Docker Compose can provide, and no cloud, edge, or distributed deployment models are mentioned. Availability is handled by Docker’s container management and automatic initialization scripts."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external components is achieved via the MQTT protocol for inter‑service messaging, SQL/TimescaleDB for data storage, and Grafana for visualization. No enterprise‑level standards (e.g., AutomationML) or external digital twins are referenced; the twin relies on these open‑source tools for data exchange and interoperability."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar models its digital twin using AutomationML, thereby adhering to the AutomationML standard for engineering data exchange. No other industry standards or certification frameworks are explicitly referenced in the documents."
]