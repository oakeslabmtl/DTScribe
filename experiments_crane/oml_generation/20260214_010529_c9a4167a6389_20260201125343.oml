// Sensing components
instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder on the gantry crane providing precise Cartesian position data within a confined workspace."
    DTDFVocab:producedData PositionDataT
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Velocity sensor capturing the crane’s instantaneous velocity."
    DTDFVocab:producedData VelocityDataT
]

instance ActuatorCommandSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing the controller’s actuator commands."
    DTDFVocab:producedData ActuatorCommandDataT
]

// Simulated prediction sensor
instance PredictedTrajectorySensor : DTDFVocab:SensingComponent [
    base:desc "Simulation sensor providing predicted trajectory from the kinematic motion model."
    DTDFVocab:producedData PredictedTrajectoryDataT
]

// Data transmitted from sensors
instance PositionDataT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

instance VelocityDataT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySensor
]

instance ActuatorCommandDataT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ActuatorCommandSensor
]

instance PredictedTrajectoryDataT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PredictedTrajectorySensor
]

// Actual data streams
instance ActualPositionData : DTDFVocab:Data [
    base:desc "Actual Cartesian position measurement of the crane."
    DTDFVocab:fromData PositionDataT
    DTDFVocab:inputTo DockerContainerEnabler
]

instance ActualVelocityData : DTDFVocab:Data [
    base:desc "Actual velocity measurement of the crane."
    DTDFVocab:fromData VelocityDataT
    DTDFVocab:inputTo DockerContainerEnabler
]

instance ActualActuatorCommandData : DTDFVocab:Data [
    base:desc "Actual actuator command data issued to the crane."
    DTDFVocab:fromData ActuatorCommandDataT
    DTDFVocab:inputTo DockerContainerEnabler
]

// Predicted data stream
instance PredictedTrajectoryData : DTDFVocab:Data [
    base:desc "Predicted trajectory of the crane from the kinematic model."
    DTDFVocab:fromData PredictedTrajectoryDataT
    DTDFVocab:inputTo DockerContainerEnabler
]

// Model
instance KinematicMotionModel : DTDFVocab:Model [
    base:desc "CAD-based kinematic motion model reproducing the crane geometry for trajectory predictions."
    DTDFVocab:inputTo DockerContainerEnabler
]

// Enabler
instance DockerContainerEnabler : DTDFVocab:Enabler [
    base:desc "Docker container orchestrating twin services via lightweight Python middleware."
    DTDFVocab:enables OptimalMotionPlanningService, HistoricalDataLoggingService, DataVisualizationService, ContinuousValidationService
]

// Services
instance OptimalMotionPlanningService : DTDFVocab:Service [
    base:desc "Service that generates collision‑free paths for the gantry crane."
    DTDFVocab:provides CollisionFreePathInsight, ExecutePathAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service logging state traces (position, velocity, actuator commands) for post‑mortem analysis."
    DTDFVocab:provides HistoricalDataInsight, StoreHistoricalDataAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service providing an interactive dashboard displaying live telemetry and logged data."
    DTDFVocab:provides DashboardDisplayInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously compares real‑time sensor measurements against model predictions."
    DTDFVocab:provides DeviationReportInsight, PathCorrectionAction, AlertOperatorAction
]

// Insights
instance CollisionFreePathInsight : DTDFVocab:Insight [
    base:desc "Insight providing collision‑free trajectory recommendations for the gantry crane."
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the availability of logged state traces for analysis."
]

instance DashboardDisplayInsight : DTDFVocab:Insight [
    base:desc "Insight representing live telemetry visualization in the dashboard."
]

instance DeviationReportInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing real‑time deviation between actual and predicted trajectories within tolerance bands."
]

// Actions
instance ExecutePathAction : DTDFVocab:Action [
    base:desc "Action that sends the computed trajectory to the crane controller for execution."
    DTDFVocab:IsAutomatic true
]

instance StoreHistoricalDataAction : DTDFVocab:Action [
    base:desc "Action that records the state traces in TimescaleDB."
    DTDFVocab:IsAutomatic true
]

instance PathCorrectionAction : DTDFVocab:Action [
    base:desc "Action that recommends corrections to path planning based on deviations."
    DTDFVocab:IsAutomatic true
]

instance AlertOperatorAction : DTDFVocab:Action [
    base:desc "Action that alerts operators when deviations exceed tolerances."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application orchestrates the crane by sending control commands through the Python‑based Crane Interface to the Physical Crane’s controller hardware. Commands (e.g., move to target coordinates) are issued from the Control Application logic and forwarded to the crane. The document does not detail command formats, validation, authentication, or feedback mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin is organized into six Docker containers (or virtual machine images) as specified by the container diagram. These components include: a Python logging service that captures physical sensor streams and pushes them to a database; an MQTT broker that routes messages between services; a validation service that continuously compares sensor data to the simulated state; a visualization service that renders runtime status; a simulation engine that provides predicted dynamics; and a database service that persists historical state. The system follows an ad‑hoc coordination pattern, with each container exposing well‑defined APIs over MQTT and REST, orchestrated by container tooling (Docker) to enable isolated deployment and scaling. The C4 context diagram positions the twin as a single logical entity interacting solely with the physical gantry via the shared messaging middleware."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital twin services (Trajectory Generator, Simulation, Continuous Validation) communicate via an MQTT broker that provides publish/subscribe signaling between services. The broker enables inter‑service messaging. Specific network topology, bandwidth, latency, redundancy or security protocols are not described in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system components are deployed as containers, following the C4 container model. The document indicates that the TimescaleDB database, MQTT broker, and application services are co‑located with the physical crane system, implying on‑premise or edge hosting. No explicit cloud, scalability, availability, or deployment models are detailed."
]