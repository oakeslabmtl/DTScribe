// C2: Acting Components
instance XAxisDriveMotor : DTDFVocab:ActingComponent [
    base:desc "DC drive motor translating the carriage along the X‑axis, range ≈1.2 m, max speed 0.2 m s⁻¹"
]

instance HoistDriveMotor : DTDFVocab:ActingComponent [
    base:desc "DC drive motor for vertical motion of the hoist, max speed 0.2 m s⁻¹"
]

instance ElectromagnetEndEffector : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end‑effector used to pick up pucks"
]

instance MotorController : DTDFVocab:ActingComponent [
    base:desc "Motor controller accessed remotely via MQTT messages forwarded by ActiveMQ"
]

// C3: Physical sensing components
instance XAxisEncoder : DTDFVocab:SensingComponent [
    base:desc "Rotary encoder mounted on X‑axis motor shaft, resolution 0.01 rad, publishes at 10 Hz via ActiveMQ"
    DTDFVocab:producedData XAxisEncoderDataTransmitted
]

instance YAxisEncoder : DTDFVocab:SensingComponent [
    base:desc "Rotary encoder mounted on hoist motor shaft, resolution 0.01 rad, publishes at 10 Hz via ActiveMQ"
    DTDFVocab:producedData YAxisEncoderDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient airflow to assess disturbance forces, samples at 1 Hz"
    DTDFVocab:producedData AnemometerDataTransmitted
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance XAxisEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom XAxisEncoder
]

instance YAxisEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom YAxisEncoder
]

instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// C10: Data
instance XAxisEncoderData : DTDFVocab:Data [
    base:desc "Position and velocity data from X‑axis encoder"
    DTDFVocab:fromData XAxisEncoderDataTransmitted
    DTDFVocab:inputTo SimulationEngine, LoggingEngine
]

instance YAxisEncoderData : DTDFVocab:Data [
    base:desc "Position and velocity data from hoist encoder"
    DTDFVocab:fromData YAxisEncoderDataTransmitted
    DTDFVocab:inputTo SimulationEngine, LoggingEngine
]

instance AnemometerData : DTDFVocab:Data [
    base:desc "Ambient airflow measurement used for disturbance estimation"
    DTDFVocab:fromData AnemometerDataTransmitted
    DTDFVocab:inputTo SimulationEngine
]

// C10: Models
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the gantry crane created in Autodesk Fusion360"
    DTDFVocab:inputTo VisualizationEngine
]

instance KinematicBehaviorModel : DTDFVocab:Model [
    base:desc "Python kinematic model predicting carriage and hoist motion"
    DTDFVocab:inputTo SimulationEngine, ControlEngine
]

instance DynamicLoadModel : DTDFVocab:Model [
    base:desc "Analytical model of container handling dynamics"
    DTDFVocab:inputTo SimulationEngine
]

// C11: Enablers
instance MQTTBrokerActiveMQ : DTDFVocab:Enabler [
    base:desc "ActiveMQ MQTT broker forwarding sensor messages and receiving control commands"
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

instance TimescaleDBStorage : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database storing logged sensor and actuator data"
    DTDFVocab:enables HistoricalLoggingService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana visualisation platform rendering real‑time and historical crane states"
    DTDFVocab:enables DataVisualizationService
]

instance DockerContainerPlatform : DTDFVocab:Enabler [
    base:desc "Docker container runtime packaging all twin components for reproducible deployment"
    DTDFVocab:enables OptimalControlService, HistoricalLoggingService, DataVisualizationService, ContinuousValidationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Python simulation service consuming kinematic and dynamic models and sensor data to update the digital twin"
    DTDFVocab:enables ContinuousValidationService, DataVisualizationService, OptimalControlService
]

instance ControlEngine : DTDFVocab:Enabler [
    base:desc "Python module implementing trajectory optimisation and control command generation"
    DTDFVocab:enables OptimalControlService
]

instance LoggingEngine : DTDFVocab:Enabler [
    base:desc "Python logging application writing sensor measurements into TimescaleDB"
    DTDFVocab:enables HistoricalLoggingService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Component that binds CAD model with real‑time simulation output for Grafana visualisation"
    DTDFVocab:enables DataVisualizationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes and issues optimal control commands to improve crane motion efficiency"
    DTDFVocab:provides OptimalTrajectoryInsight, ControlRecommendationAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Continuously records sensor and actuator data into TimescaleDB for later analysis"
    DTDFVocab:provides HistoricalTrendInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Provides graphical display of real‑time and archived crane states via Grafana"
    DTDFVocab:provides RealTimeStateInsight, HistoricalVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Automated comparison of measured behaviour against kinematic model, generating alerts on deviation"
    DTDFVocab:provides ValidationAlertInsight, DeviationRecommendationAction
]

// C17: Insights / Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal motion trajectory computed for reduced travel time and energy consumption"
]

instance ControlRecommendationAction : DTDFVocab:Action [
    base:desc "Recommended control command sent to motor controller"
    DTDFVocab:IsAutomatic true
]

instance HistoricalTrendInsight : DTDFVocab:Insight [
    base:desc "Statistical trend analysis of historical position, speed and load data"
]

instance RealTimeStateInsight : DTDFVocab:Insight [
    base:desc "Current crane position, load status and performance metrics visualised on dashboard"
]

instance HistoricalVisualizationInsight : DTDFVocab:Insight [
    base:desc "Historical plots of crane trajectories and load dynamics"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating that measured behaviour deviates from model beyond predefined threshold"
]

instance DeviationRecommendationAction : DTDFVocab:Action [
    base:desc "Operator recommendation to adjust speed or load to bring behaviour within model bounds"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory Generator Service computes optimal movement trajectories (position set‑points and velocity profiles) using a kinematics model. These trajectories are transmitted via the MQTT broker to the Control Application, which translates them into control commands sent through the Physical Crane Interface to the crane’s controllers. The Control Application and the Physical Crane Interface are both Python components, and command execution is confirmed indirectly by the Logging Application updating the crane’s state in the database, which can then be validated by the Continuous Validation Service. Specific command formats, authentication, or conflict‑resolution mechanisms are not described in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The gantry‑crane exemplar synchronises the physical crane with its digital counterpart in a continuous, real‑time fashion. Sensor measurements are published instantly over MQTT (Eclipse Mosquitto) and consumed by Docker‑hosted Python services that immediately write the values to a TimescaleDB database. The Logging Application records the crane’s state as each measurement arrives, and the Continuous Validation Service evaluates the digital model against the incoming data without any defined batch window. No explicit synchronization frequency, latency bound, or time‑step granularity is specified in the documentation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation is built around a TimescaleDB database for historic state storage, an Eclipse Mosquitto MQTT broker for publish/subscribe communication, and a set of Docker‑containerised Python services (Logging, Visualization, Validation) that orchestrate data flow. The components are orchestrated on a personal computer host, with the MQTT broker mediating sensor data ingestion and the services accessing the TimescaleDB for state persistence and analysis."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by a validation service that periodically compares the real‑time encoder measurements with the kinematic model predictions; deviations beyond 2 % trigger an error‑correction routine. The analytical model is calibrated using recorded data from the InfluxDB store, and uncertainty is quantified by propagating sensor tolerance (±0.5 %) through the simulation. Continuous integration tests verify model‑data consistency before each VM image release, providing quality assurance for both models and data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital‑twin services communicate through an MQTT broker that acts as a central signaling hub. All containers (Trajectory Generator Service, Simulation Service, Continuous Validation Service, Dashboard, etc.) publish and subscribe to MQTT topics over TCP/IP. No further details on bandwidth, latency, topology, redundancy or security protocols are provided in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire system is deployed on‑premise on a personal computer directly connected to the physical crane. Docker containers are used for the TimescaleDB database, the MQTT broker, and the Grafana dashboard, while the remaining Python applications (Physical Crane Interface, Control Application, Logging Application, HMI) run as processes on the host OS. No explicit CPU, memory, or storage specifications are given; however, containerization implies easy scalability by adding more resources to the host machine. Availability depends on the continuous operation of the PC; no cloud or edge‑distributed deployment, redundancy, or high‑availability features are described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is limited to standard MQTT messaging for sensor data exchange and Docker for container deployment. No enterprise‑level middleware, cloud platforms, or industry‑specific standards (e.g., AutomationML) are employed; the twin interacts only with the local PC and the MQTT broker."
]