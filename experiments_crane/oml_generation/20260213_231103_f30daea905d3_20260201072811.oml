// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring the angular deviation of the crane’s load, wired to the Arduino.",
    DTDFVocab:producedData = SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer recording ambient wind speed, wired to the Arduino.",
    DTDFVocab:producedData = WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmission)
instance SwingAngleDataTransmitted : DTDFVocab:ProducedData [
    DTDFVocab:producedFrom = SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:ProducedData [
    DTDFVocab:producedFrom = Anemometer
]

// C5: Data produced from sensors
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Raw swing‑angle measurement values transmitted from the encoder.",
    DTDFVocab:fromData = SwingAngleDataTransmitted,
    DTDFVocab:inputTo = TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Raw wind‑speed measurement values transmitted from the anemometer.",
    DTDFVocab:fromData = WindSpeedDataTransmitted,
    DTDFVocab:inputTo = TimescaleDBEnabler
]

// C11: Enablers (tools/platforms)
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance receiving logged sensor data via the Python Logging Application over TCP.",
    DTDFVocab:enables = HistoricalDataLoggingService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that consumes CAD and kinematic models to provide control, validation, and visualization.",
    DTDFVocab:enables = OptimalControlService, DataVisualizationService, ContinuousValidationService
]

// C10: Models/Data
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "CAD geometric model of the laboratory‑scale gantry crane.",
    DTDFVocab:inputTo = SimulationEngineEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic behavioral model of the crane used for simulation and control.",
    DTDFVocab:inputTo = SimulationEngineEnabler
]

// C6: Services
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that stores continuous sensor and actuator states into TimescaleDB for later analysis.",
    DTDFVocab:provides = InsightHistoricalDataAvailable
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service that computes optimal motion commands from the kinematic model and transmits them to the crane controller.",
    DTDFVocab:provides = ActionExecuteMotionCommand
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service that renders the crane’s kinematic state and puck positions for operators.",
    DTDFVocab:provides = InsightVisualizationReady
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously compares real‑time measurements with the CAD/kinematic model to detect deviations.",
    DTDFVocab:provides = InsightDeviationDetected, ActionTriggerAlert
]

// C17: Insights / Actions
instance InsightHistoricalDataAvailable : DTDFVocab:Insight [
    base:desc "Indicates that sensor data have been successfully persisted in TimescaleDB."
]

instance ActionExecuteMotionCommand : DTDFVocab:Action [
    base:desc "Sends computed motion command to the Arduino‑mediated motor controllers.",
    DTDFVocab:IsAutomatic = true
]

instance InsightVisualizationReady : DTDFVocab:Insight [
    base:desc "Visual representation of the crane state is ready for display."
]

instance InsightDeviationDetected : DTDFVocab:Insight [
    base:desc "Detection of deviation between measured state and model predictions."
]

instance ActionTriggerAlert : DTDFVocab:Action [
    base:desc "Triggers an alert to operators when a deviation is detected.",
    DTDFVocab:IsAutomatic = false
]

// C2: Acting components
instance MotorXAxis : DTDFVocab:ActingComponent [
    base:desc "Motor driving the trolley motion along the X‑axis, controlled via its motor controller."
]

instance MotorYAxis : DTDFVocab:ActingComponent [
    base:desc "Motor driving the hoist motion along the Y‑axis."
]

instance MotorControllerX : DTDFVocab:ActingComponent [
    base:desc "Motor controller for the X‑axis motor, receives commands from the digital twin."
]

instance MotorControllerY : DTDFVocab:ActingComponent [
    base:desc "Motor controller for the Y‑axis motor."
]

instance ElectromagnetGripper : DTDFVocab:ActingComponent [
    base:desc "Electromagnet attached to the hoist end providing gripping capability for pucks."
]

instance PowerSupplyUnit : DTDFVocab:ActingComponent [
    base:desc "Shared power‑supply unit powering all actuators."
]

instance ArduinoBoard : DTDFVocab:ActingComponent [
    base:desc "Arduino board mediating communication between motor controllers, sensors and the digital twin."
]

// C8: System under study
instance GantryCraneSystem : DTDFVocab:Component [
    base:desc "Laboratory‑scale gantry crane comprising rectangular overhead frame, X‑axis trolley, Y‑axis hoist, gripper, and embedded controller."
]

// C9: Environment
instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains = GantryCraneSystem, TimescaleDBEnabler, SimulationEngineEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, a Python program, sends control commands to the Physical Crane Interface, which in turn drives the actuators of the Physical Crane. Trajectory commands generated by the Trajectory Generator Service are delivered to the Control Application for execution. The document does not detail the command message format, validation, authentication, or acknowledgment mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The exemplar adopts an ad‑hoc architecture based on containerization and virtualization. Physical components such as Raspberry‑Pi devices (Air Quality Management) or virtual machines (GreenhouseDT) host sensors and expose data to the digital twin through an ActiveMQ message broker. Time‑series and state information are stored in an InfluxDB database. The software stack is organized into multiple Docker containers, as illustrated by the C4 container diagram, and the overall system architecture is visualized with C4 context and container diagrams. No commercial digital‑twin framework is employed; service coordination relies on the message broker and standard network protocols."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A continuous validation service is provided that compares real‑time crane states with predictions from the kinematic model, allowing detection of model drift. The documents do not specify quantitative fidelity targets, uncertainty quantification methods, or detailed verification procedures."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin relies on an MQTT broker that provides signaling between the Trajectory Generator Service, Simulation Service, Continuous Validation Service and other components. The containers (Python applications, TimescaleDB, Grafana) are connected via this broker using the MQTT protocol. No further details on network topology, bandwidth, latency, redundancy or security are provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system is intended to run on a single personal computer onto which the physical crane is plugged. All software components—including the Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface, and the digital‑twin services—execute on this host. Core digital‑twin services (TimescaleDB database, MQTT broker, Grafana dashboard) are containerized with Docker for easy deployment and isolation. No cloud, edge, or separate on‑premise servers are used; scalability and availability depend on the resources and stability of the host PC, and no explicit redundancy or high‑availability mechanisms are described."
]