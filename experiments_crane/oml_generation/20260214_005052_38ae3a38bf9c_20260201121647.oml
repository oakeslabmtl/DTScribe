// Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart, controlled via Trinamic TMC4671 driver board"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist, controlled via Trinamic TMC4671 driver board"
]

instance ArduinoController : DTDFVocab:ActingComponent [
    base:desc "Atmega-based Arduino controlling the motors and electromagnet, reading sensor data"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet for cargo pickup, powered by the Arduino controller"
]

// Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing-angle optical encoder mounted on the hoist"
    DTDFVocab:producedData SwingAnglePacket
]

instance WindAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedPacket
]

instance MotorEncoderFeedback : DTDFVocab:SensingComponent [
    base:desc "Motor encoder feedback providing steps per revolution"
    DTDFVocab:producedData MotorEncoderPacket
]

instance VoltageSensor : DTDFVocab:SensingComponent [
    base:desc "Voltage sensor monitoring system voltage"
    DTDFVocab:producedData VoltagePacket
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor monitoring ambient temperature"
    DTDFVocab:producedData TemperaturePacket
]

// Data Transmitted
instance SwingAnglePacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindAnemometer
]

instance MotorEncoderPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderFeedback
]

instance VoltagePacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VoltageSensor
]

instance TemperaturePacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time-series data of swing angle collected from the optical encoder"
    DTDFVocab:fromData SwingAnglePacket
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time-series data of wind speed collected from the anemometer"
    DTDFVocab:fromData WindSpeedPacket
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance MotorEncoderData : DTDFVocab:Data [
    base:desc "Time-series data of motor encoder feedback (steps per revolution)"
    DTDFVocab:fromData MotorEncoderPacket
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance VoltageData : DTDFVocab:Data [
    base:desc "Time-series data of system voltage"
    DTDFVocab:fromData VoltagePacket
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Time-series data of ambient temperature"
    DTDFVocab:fromData TemperaturePacket
    DTDFVocab:inputTo TimescaleDBEnabler
]

// Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB container storing time-series data, accessed by services for analysis and visualization"
    DTDFVocab:enables DataLoggingService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService, RealTimeVisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for kinematic trajectory generation logic"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for crane dynamics simulation"
    DTDFVocab:enables SimulationService
]

// Models
instance Fusion360CADModel : DTDFVocab:Model [
    base:desc "CAD geometry of the crane in Fusion 360 used for reference and documentation"
]

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Kinematic model used to generate swing‑minimizing trajectories for the crane"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance CraneDynamicsSimulationModel : DTDFVocab:Model [
    base:desc "Dynamics simulation model of the crane used by the simulation service"
    DTDFVocab:inputTo SimulationEnabler
]

// Insights
instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Insight into data logging performance and reliability"
]

instance TrajectoryPlanInsight : DTDFVocab:Insight [
    base:desc "Automatic trajectory plan indicating swing‑minimizing path based on current wind and load conditions"
]

instance ValidationThresholdExceededInsight : DTDFVocab:Insight [
    base:desc "Alert triggered when the difference between planned and logged trajectories exceeds the validation threshold"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation output showing expected crane dynamics for the current trajectory plan"
]

instance UpdateDashboardInsight : DTDFVocab:Insight [
    base:desc "Dashboard update containing the latest sensor and simulation data points"
]

// Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs sensor data into TimescaleDB for long‑term storage and historical analysis"
    DTDFVocab:provides DataLoggingInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates kinematic trajectories that minimize swing based on current wind conditions"
    DTDFVocab:provides TrajectoryPlanInsight, GenerateTrajectoryPlanAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs dynamics simulation of the crane with current parameters to generate expected trajectories"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares logged trajectories against simulated ones for continuous validation"
    DTDFVocab:provides ValidationThresholdExceededInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Visualizes real‑time data on Grafana dashboards for operators"
    DTDFVocab:provides UpdateDashboardAction
]

instance OperatorControlService : DTDFVocab:Service [
    base:desc "Offers operator HMI to send control commands to the Arduino which actuates motors"
    DTDFVocab:provides ControlCommandAction
]

// Actions
instance GenerateTrajectoryPlanAction : DTDFVocab:Action [
    base:desc "Automatically generate a new trajectory plan that minimizes swing amplitude"
    DTDFVocab:IsAutomatic true
]

instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Send control commands to the Arduino controller to actuate motors"
    DTDFVocab:IsAutomatic false
]

instance UpdateDashboardAction : DTDFVocab:Action [
    base:desc "Push updated visualization metrics to Grafana dashboards"
    DTDFVocab:IsAutomatic true
]

// Physical Components Containers (Docker Compose)
instance TimescaleDBContainer : DTDFVocab:Component [
    base:desc "Docker container running TimescaleDB"
]

instance GrafanaContainer : DTDFVocab:Component [
    base:desc "Docker container running Grafana dashboard for visualization"
]

instance MosquittoMQTTContainer : DTDFVocab:Component [
    base:desc "Docker container running Mosquitto MQTT broker for data routing"
]

instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Docker container running the trajectory generation service"
]

instance SimulationContainer : DTDFVocab:Component [
    base:desc "Docker container running the crane dynamics simulation service"
]

instance ContinuousValidationContainer : DTDFVocab:Component [
    base:desc "Docker container running the continuous validation service"
]

instance PhysicalCraneInterfaceContainer : DTDFVocab:Component [
    base:desc "Docker container running the physical crane interface service"
]

instance ArduinoContainer : DTDFVocab:Component [
    base:desc "Docker container providing the Arduino firmware and driver interface"
]

// Environment
instance LabScaleCraneEnvironment : DTDFVocab:Environment [
    base:contains TimescaleDBContainer, GrafanaContainer, MosquittoMQTTContainer, TrajectoryGeneratorContainer, SimulationContainer, ContinuousValidationContainer, PhysicalCraneInterfaceContainer, ArduinoContainer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service produces optimal motion trajectories which are sent as command messages via MQTT to the Physical Crane Interface; the Control Application forwards these commands to the Arduino that actuates the motors. The Continuous Validation Service publishes alerts to the HMI Dashboard when deviation thresholds are exceeded."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in near real‑time; the Logging Application samples the crane state at each motor update cycle, the Trajectory Generator updates trajectory points continuously, and the Continuous Validation Service evaluates each executed trajectory immediately after completion, synchronizing via the MQTT broker."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A containerized microservice architecture powered by Docker Compose: the physical subsystem is interfaced through a Python module; inter‑service communication occurs over an MQTT broker; logs are stored in TimescaleDB and visualized with Grafana; all services are deployed on a single personal computer."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the design phase (z‑CAD model in Fusion 360), the manufacturing phase (physical crane built and assembled), and the operational phase (runtime state logging, live validation, and operator interaction)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service computes Euclidean distance between measured and simulated trajectories; a threshold is configured to trigger alerts if residual swing is non‑zero. The kinematic model is verified against real‑world data from the Logging Application, and fault detection is enhanced using time‑series classification techniques."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical hardware connects to the Python interface via serial/USB to the Arduino; inter‑service messaging uses MQTT over TCP; the TimescaleDB and Grafana containers expose PG and HTTP ports on the Docker network; data transfer rates are limited by the motor control loop and logging frequency."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin components are containerized and deployed using Docker Compose on a single workstation; the Python modules run as local processes or as Docker containers, while TimescaleDB, Mosquitto, and Grafana run as separate containers; the repository and documentation are hosted on GitHub and GitHub Pages."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "No explicit integration with external enterprise systems or other digital twins is described; the exemplar is self‑contained and the repository is publicly available on GitHub."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Employs open‑source industry standards – Docker, MQTT (Eclipse Mosquitto), TimescaleDB/SQL, Grafana, C4 model notation, Capella, and Autodesk Fusion 360; no formal twin reference model or ISO standard is referenced."
]