// Sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring pendulum motion of the hoist"
    DTDFVocab:producedData SwingAngleTelemetry
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting the crane"
    DTDFVocab:producedData WindSpeedTelemetry
]

instance CartMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Embedded encoder feedback from the cart stepper motor via the Arduino"
    DTDFVocab:producedData CartMotorPositionTelemetry
]

instance HoistMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Embedded encoder feedback from the hoist stepper motor via the Arduino"
    DTDFVocab:producedData HoistMotorPositionTelemetry
]

instance ElectromagnetStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting the on/off status of the electromagnet"
    DTDFVocab:producedData ElectromagnetStatusTelemetry
]

// Data transmitted from sensors
instance SwingAngleTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CartMotorPositionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoder
]

instance HoistMotorPositionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoder
]

instance ElectromagnetStatusTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ElectromagnetStatusSensor
]

// Telemetry data stored in TimescaleDB
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Recorded swing‑angle values in the TimescaleDB time‑series database"
    DTDFVocab:fromData SwingAngleTelemetry
    DTDFVocab:inputTo PostgreSQLDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Recorded wind‑speed values in the TimescaleDB database"
    DTDFVocab:fromData WindSpeedTelemetry
    DTDFVocab:inputTo PostgreSQLDBEnabler
]

instance CartMotorPositionData : DTDFVocab:Data [
    base:desc "Recorded cart motor position values in the TimescaleDB database"
    DTDFVocab:fromData CartMotorPositionTelemetry
    DTDFVocab:inputTo PostgreSQLDBEnabler
]

instance HoistMotorPositionData : DTDFVocab:Data [
    base:desc "Recorded hoist motor position values in the TimescaleDB database"
    DTDFVocab:fromData HoistMotorPositionTelemetry
    DTDFVocab:inputTo PostgreSQLDBEnabler
]

instance ElectromagnetStatusData : DTDFVocab:Data [
    base:desc "Recorded electromagnet status in the TimescaleDB database"
    DTDFVocab:fromData ElectromagnetStatusTelemetry
    DTDFVocab:inputTo PostgreSQLDBEnabler
]

// Acting components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor controlled by a TMC4671 Eval controller via the Arduino"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor controlled by a TMC4671 Eval controller via the Arduino"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist end used to pick up containers"
]

instance ArduinoController : DTDFVocab:ActingComponent [
    base:desc "Arduino board interfacing sensors and stepper motor drivers for the Crane"
]

// Enablers (technology layers that enable services)
instance PostgreSQLDBEnabler : DTDFVocab:Enabler [
    base:desc "PostgreSQL (TimescaleDB) database that ingests telemetry via PostgreSQL driver"
    DTDFVocab:enables RealTimeDataLoggingService, CraneSimulationService, ContinuousValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Mosquitto MQTT broker that publishes telemetry to subscribed services"
    DTDFVocab:enables ContinuousValidationService, ThresholdNotificationService, TrajectoryCommandProvisionService, GrafanaDashboardService
]

instance GantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib library that provides kinematic and control routines"
    DTDFVocab:enables TrajectoryGenerationService, CraneSimulationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Environment that provides the analytical simulation model for the crane"
    DTDFVocab:enables CraneSimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Component that supplies continuous validation distance metrics to the validation service"
    DTDFVocab:enables ContinuousValidationService
]

// Models
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane captured in Autodesk Fusion360"
    DTDFVocab:inputTo GantryLibEnabler
]

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Kinematic model used for zero‑swing trajectory generation"
    DTDFVocab:inputTo GantryLibEnabler
]

instance AnalyticalSimulationModel : DTDFVocab:Model [
    base:desc "Analytical simulation model of crane dynamics and controller behavior"
    DTDFVocab:inputTo SimulationEnabler
]

instance ContinuousValidationMetricsModel : DTDFVocab:Model [
    base:desc "Continuous‑validation distance metrics comparing telemetry to simulation"
    DTDFVocab:inputTo ValidationEnabler
]

// Services
instance RealTimeDataLoggingService : DTDFVocab:Service [
    base:desc "Python logging application that writes telemetry into TimescaleDB over PostgreSQL"
    DTDFVocab:provides TelemetryDataLoggedInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard system for visualizing time‑series telemetry via MQTT"
    DTDFVocab:provides VisualizationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Optimal trajectory generation service using the gantrylib library for zero‑swing paths"
    DTDFVocab:provides TrajectoryOptimizationInsight
]

instance CraneSimulationService : DTDFVocab:Service [
    base:desc "Simulation service that models crane dynamics and controller behavior"
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous‑validation service that compares logged telemetry to simulation"
    DTDFVocab:provides ContinuousValidationAlertsInsight, ThresholdBreachCorrectiveAction
]

instance ThresholdNotificationService : DTDFVocab:Service [
    base:desc "Service that publishes threshold‑breach alerts to operators"
    DTDFVocab:provides ThresholdAlertInsight
]

instance TrajectoryCommandProvisionService : DTDFVocab:Service [
    base:desc "Service that provides trajectory command instructions to the control application"
    DTDFVocab:provides TrajectoryCommandAction
]

// Insights
instance TelemetryDataLoggedInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful ingestion of telemetry data into TimescaleDB"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight showing real‑time visualisation of time‑series telemetry in Grafana dashboards"
]

instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight that identifies optimal zero‑swing trajectory paths for load transport"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight summarising simulated crane dynamics and controller behaviour"
]

instance ContinuousValidationAlertsInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that continuous‑validation distance metrics have exceeded acceptable limits"
]

instance ThresholdAlertInsight : DTDFVocab:Insight [
    base:desc "Insight alerting operators that a sensor threshold has been breached"
]

// Actions
instance ThresholdBreachCorrectiveAction : DTDFVocab:Action [
    base:desc "Action suggesting corrective measures in response to a threshold breach"
    DTDFVocab:IsAutomatic false
]

instance TrajectoryCommandAction : DTDFVocab:Action [
    base:desc "Automatic action that sends a trajectory command to the control application"
    DTDFVocab:IsAutomatic true
]

// Environment and components
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains CartStepperMotor, HoistStepperMotor, Electromagnet, ArduinoController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The trajectory generator service computes optimal cart and hoist trajectories (zero‑swing) and sends desired motor positions/velocities to the control application, which forwards them to the physical interface for dispatch to the TMC4671‑Eval controllers; continuous‑validation outputs deviation alerts to the dashboard but does not command the PT."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All twin services operate in real‑time during crane operation; the logging and validation services are described as continuous, but the explicit sampling or polling rates are not specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical side: Crane, Physical Crane Interface, Control Application, Logging Application, Human Machine Interface; Digital side: Database, MQTT broker, Trajectory Generator Service, Simulation Service, Continuous Validation Service, Grafana Dashboard; communication via MQTT topics and SQL database; Docker Compose deploys all containers on a single PC."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (CAD models in Autodesk Fusion360), Manufacturing (physical crane assembled per BOM), and Operation (runtime twin services: logging, simulation, validation, trajectory generation); the continuous‑validation service covers the operated phase and the twin evolves with research updates."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Trajectory generator guarantees zero residual swinging by analytically solving for optimal motion; continuous‑validation computes distance metrics between measured and simulated trajectories and flags deviations beyond a predefined threshold; simulation model validated against logged telemetry; all models updated during research to improve accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data from the physical controllers are read by the Python interface over serial/USB; subsequent services communicate via an Eclipse Mosquitto MQTT broker; the database (TimescaleDB) is accessed over TCP/IP; the Control Application publishes motor commands, while the Trajectory Generator and Validation services publish/subscribe on MQTT topics."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted locally on a personal computer (Linux/Windows) running Docker; all core services (Database, MQTT broker, Grafana) containerized, orchestration via Docker Compose; Web UI served by Grafana; gantrylib installed via pip; no external cloud deployment."
]