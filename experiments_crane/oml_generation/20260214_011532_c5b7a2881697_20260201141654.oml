// Sensors
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution rotary encoder mounted on hoist shaft 10 kHz sampling, 0.1° resolution"
    DTDFVocab:producedData SwingAngleEncoderTx
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient wind speed sensor on upper gantry, 0–50 m/s range, 2 Hz update rate"
    DTDFVocab:producedData AnemometerTx
]

// Data transmitted
instance SwingAngleEncoderTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// Persisted data
instance EncoderMeasurementData : DTDFVocab:Data [
    base:desc "Encoder angle and velocity data persisted in TimescaleDB at 10 Hz"
    DTDFVocab:fromData SwingAngleEncoderTx
    DTDFVocab:inputTo LoggingApplicationEnabler
]

instance AnemometerMeasurementData : DTDFVocab:Data [
    base:desc "Wind speed data persisted in TimescaleDB at 10 Hz"
    DTDFVocab:fromData AnemometerTx
    DTDFVocab:inputTo LoggingApplicationEnabler
]

// Acting components
instance HorizontalCartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Step‑per motor driving cart along gantry rail A4988 controller, ±180° step limits, safety limit switches"
]

instance VerticalHoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Step‑per motor driving vertical hoist A4988 controller, ±90° step limits, safety limit switches"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "24 V DC electromagnet on hoist, toggled by interface for pick‑and‑place"
]

// Enablers
instance LoggingApplicationEnabler : DTDFVocab:Enabler [
    base:desc "Python application writing real‑time telemetry to TimescaleDB and signaling via MQTT"
    DTDFVocab:enables HistoricalLoggingService, ContinuousValidationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink engine performing forward kinematics and trajectory predictions"
    DTDFVocab:enables MotionPlanningService, ContinuousValidationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database storing all telemetry"
    DTDFVocab:enables HistoricalLoggingService, ContinuousValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto broker handling inter‑service signalling"
]

// Services
instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Service logging historical crane state for post‑hoc analysis"
    DTDFVocab:provides InsightHistoricalLogging
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service comparing real‑time telemetry against simulated trajectories"
    DTDFVocab:provides InsightTrajectoryValidation
]

instance MotionPlanningService : DTDFVocab:Service [
    base:desc "Service generating optimal motion plans using kinematic model"
    DTDFVocab:provides ActionPlanGeneration
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Service providing real‑time telemetry dashboards via Grafana"
    DTDFVocab:provides InsightVisualizationDashboard
]

instance DiagnosticMonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring physical controller health and diagnostics"
    DTDFVocab:provides InsightControllerDiagnostics
]

// Insights and Actions
instance InsightHistoricalLogging : DTDFVocab:Insight [
    base:desc "Insight on historical trajectory and state logging for analysis"
]

instance InsightTrajectoryValidation : DTDFVocab:Insight [
    base:desc "Insight comparing logged telemetry with model predictions for validation"
]

instance ActionPlanGeneration : DTDFVocab:Action [
    base:desc "Action to generate optimal trajectory plans for the gantry crane"
    DTDFVocab:IsAutomatic true
]

instance InsightVisualizationDashboard : DTDFVocab:Insight [
    base:desc "Insight providing real‑time visual dashboards of crane telemetry"
]

instance InsightControllerDiagnostics : DTDFVocab:Insight [
    base:desc "Insight monitoring encoder currents, motor limits, and safety switch status"
]

// Environment
instance LabGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains HorizontalCartStepperMotor, VerticalHoistStepperMotor, Electromagnet, SwingAngleEncoder, AnemometerSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Control Application (using trajectory data from the Trajectory Generator Service) are sent to the Physical Crane via the Physical Crane Interface, which forwards the instructions to the crane’s hardware controllers. The documents provide no detail on validation, authentication, feedback, conflict resolution, or command execution confirmation mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin system follows a C4 container architectural model and is deployed in six Docker containers to separate concerns and simplify orchestration. The containers are: (1) an MQTT broker that serves as the central signaling medium for inter-service communication; (2) a twin core container housing the simulation engine and state model that represents the physical gantry crane; (3) a data store container (e.g., InfluxDB) that persists time‑series sensor and telemetry data; (4) a gateway service container responsible for ingesting sensor data from the physical crane’s onboard Raspberry‑Pi; (5) a web dashboard container that visualizes the twin’s state and analytics for operators; and (6) a monitoring/alerts container that performs anomaly detection and generates notifications. The containers communicate through MQTT topics and shared database access, creating a decoupled yet coordinated runtime environment that facilitates maintenance, scaling, and clear separation of duties within the twin system."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A Continuous Validation Service continuously compares the measured execution of trajectories against the simulated trajectories produced by the dynamic model. Discrepancies beyond configured tolerances are flagged for further inspection, ensuring that the Digital Twin maintains fidelity to real‑world behaviour."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All inter‑component communication occurs over a local area network. Core services (Control Application, Logging Application, Trajectory Generator Service, Simulation Service, Continuous Validation Service) exchange messages via a lightweight MQTT broker; each service subscribes to the appropriate topics and publishes its status or telemetry. The Physical Crane Interface communicates with the crane controller hardware via a native TCP socket. No explicit bandwidth or latency metrics are specified in the document, and the document does not describe redundancy or security mechanisms beyond the MQTT broker’s presence."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin components are intended for on‑premise deployment on the host machine that directly controls the gantry crane. The Python containers run as local processes, utilizing a single TimescaleDB instance for persistent time‑series data. No cloud or edge deployment options are described, and the deployment model is a monolithic, single‑host architecture with no explicit scaling provisions beyond the modular container design outlined in the container diagram."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplars cite an AutomationML based digital twin model and the use of Microsoft Azure cloud services, indicating alignment with industry standards for digital twin representation and cloud deployment. No explicit certification, compliance frameworks or interoperability standards are mentioned."
]