// C2: Acting Components
instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the crane hoist, controlled by the TMC4671‑Eval controller"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval motor controller receiving commands from the Python Physical Crane Interface"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring hoist swing angle attached to the crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed near the crane"
    DTDFVocab:producedData AnemometerDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series swing angle measurements"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo PythonPhysicalCraneInterface, TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series wind speed measurements"
    DTDFVocab:fromData AnemometerDataTransmitted
    DTDFVocab:inputTo PythonPhysicalCraneInterface, TimescaleDBEnabler
]

// C11: Enablers
instance PythonPhysicalCraneInterface : DTDFVocab:Enabler [
    base:desc "Python program that connects to crane controllers, forwards sensor data and receives commands"
    DTDFVocab:enables ContinuousValidationService, SimulationService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database storing logged crane state"
    DTDFVocab:enables LoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker mediating signalling among services"
    DTDFVocab:enables DashboardService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestrates all containerised services"
    DTDFVocab:enables LoggingService, DashboardService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService, ControlApplicationService, HMIService
]

instance KinematicModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that supplies the kinematic model to trajectory generation and simulation"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler exposing the behavioral simulation model to the Simulation Service"
    DTDFVocab:enables SimulationService
]

// C6: Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Persistently stores sensor and state data into TimescaleDB"
    DTDFVocab:provides DataLoggingInsight
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualising real‑time data and simulation confidence bounds"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates swing‑free optimal movement trajectories using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Emulates crane and controller behaviour for a given trajectory"
    DTDFVocab:provides PredictiveSimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares measured trajectories with simulated ones and raises alerts"
    DTDFVocab:provides ValidationAlertAction
]

instance ControlApplicationService : DTDFVocab:Service [
    base:desc "Python control application issuing movement, homing and zero‑ing commands"
    DTDFVocab:provides ExecutionControlInsight
]

instance HMIService : DTDFVocab:Service [
    base:desc "Human‑Machine Interface allowing operator interaction with the crane"
    DTDFVocab:provides OperatorFeedbackInsight
]

// C17: Insights
instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Ensures complete storage of crane state for later analysis"
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides operators with live visualization of measurements and simulated confidence bands"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Computes swing‑free optimal movement trajectories"
]

instance PredictiveSimulationInsight : DTDFVocab:Insight [
    base:desc "Predicts outcome of a trajectory before execution"
]

instance ExecutionControlInsight : DTDFVocab:Insight [
    base:desc "Enables start, home, zero and logging configuration through the control application"
]

instance OperatorFeedbackInsight : DTDFVocab:Insight [
    base:desc "Provides immediate feedback to operator via the HMI"
]

// C18: Actions
instance ValidationAlertAction : DTDFVocab:Action [
    base:desc "Action triggered by Continuous Validation Service to alert operator when trajectory deviation exceeds threshold"
    DTDFVocab:IsAutomatic false
]

// C10: Models/Data
instance CADModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the lab‑scale gantry crane"
    DTDFVocab:inputTo DockerComposeEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Analytical kinematic model used for trajectory generation and simulation"
    DTDFVocab:inputTo KinematicModelEnabler
]

instance BehavioralSimulationModel : DTDFVocab:Model [
    base:desc "Behavioral simulation model implemented in the Simulation Service"
    DTDFVocab:inputTo SimulationEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, a Python service, consumes optimal trajectories generated by the Trajectory Generator Service and issues movement commands to the Physical Crane Interface, which translates them into controller‑level commands for the cart and hoist motors. These commands are sent to the motor controllers (TMC4671‑Eval) that drive the stepper motors. After execution, the crane’s state (e.g., position, swing angle) is measured again by the sensors and fed back through the same logging pipeline. The documents do not detail the exact command format, validation or authentication mechanisms, or acknowledgment messages, but indicate that command flow is through the Python interface and that feedback is captured by the Logging Application."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The lab‑scale gantry crane digital twin is orchestrated using an ad‑hoc, container‑based architecture described with the C4 model. Six digital‑twin containers are deployed via a single Docker‑Compose command: a TimescaleDB database stores all logged measurements; a Grafana dashboard visualises the data; a Trajectory Generator Service computes optimal crane trajectories using a kinematics model; a Simulation Service provides a physics‑based simulation of the crane and its controllers; a Continuous Validation Service continuously compares executed trajectory measurements with simulated results, calculating distance metrics and triggering alerts when thresholds are exceeded; an MQTT broker supplies lightweight signalling between the services. Each service runs in its own Docker container, enabling isolation, reproducibility and simple resource management. Services communicate primarily through MQTT messages for event signalling and via the shared TimescaleDB for state persistence, while Grafana reads the database for visualisation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The gantry‑crane twin follows a four‑stage lifecycle that is described across the documents: (1) Modeling – CAD models and a kinematic model of the crane are created (Document 4); (2) Implementation – the models are wrapped in Dockerised Python services (Trajectory Generator, Simulation, Continuous Validation, MQTT broker, database and dashboard) as shown in the container diagram and docker‑compose startup (Document 6, Fig 7); (3) Deployment & Operation – a single `docker‑compose` command launches all containers, the Logging Application stores state in a TimescaleDB database and the Grafana dashboard visualises data while the HMI allows the operator to control the crane (Document 6); (4) Evolution & Governance – research extensions such as continuous‑validation methods, fault‑detection techniques and the DarTwin notation are applied to evolve the twin, and the complete artefacts are released on GitHub under an open‑source licence, providing version‑controlled governance (Document 4)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by the Trajectory Generator Service which produces optimal trajectories with no residual swing, and by the Simulation Service that emulates the crane’s dynamics. Validation is performed continuously by the Continuous Validation Service, which compares logged sensor measurements of executed trajectories against simulated trajectories, calculates distance metrics, and checks them against a predefined acceptance threshold. If the threshold is exceeded, operators are notified via the Grafana dashboard. This validation loop constitutes the primary quality‑assurance mechanism for the digital twin; explicit uncertainty quantification or error‑correction procedures are not described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital‑twin services run on a personal computer. The TimescaleDB database, Grafana dashboard, and MQTT broker (Eclipse Mosquitto) are packaged as Docker containers orchestrated by a Docker‑Compose file, creating a local Docker bridge network. Inter‑service communication uses the MQTT protocol for signalling, while data access to the database occurs via standard PostgreSQL SQL queries. No explicit bandwidth, latency, or security (e.g., TLS) requirements are mentioned; reliability is provided by Docker container isolation and the MQTT broker’s messaging capabilities."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The exemplar is deployed on‑premise on a single personal computer (edge deployment). Docker containers host the database (TimescaleDB), MQTT broker, and Grafana dashboard, while the remaining Python services run directly on the host after installing the gantrylib module via pip. Storage is provided by the TimescaleDB instance; compute requirements are modest, requiring only a PC capable of running Python and Docker. Scalability is achieved by Docker‑Compose, allowing additional containers to be added if needed. Availability is managed through Docker’s start‑up scripts, but no high‑availability or cloud‑based hosting is described."
]