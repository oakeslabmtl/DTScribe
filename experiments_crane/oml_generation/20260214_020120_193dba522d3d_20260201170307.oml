// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor responsible for horizontal movement of the lab-scale gantry crane's cart, executing predefined trajectories for container transport."
]

instance HoistElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist for container manipulation, enabling precise positioning and release of containers during crane operations."
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures the swinging motion of the hoist during container transport, providing dynamic behavior data for trajectory validation."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Measures wind speed in the lab environment, providing contextual data for operational conditions affecting crane movements."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalCraneInterface
]

// C10: Models/Data
instance CADModel : DTDFVocab:Model [
    base:desc "Geometric representation of the lab-scale gantry crane's physical components, used for visualization and simulation purposes."
    DTDFVocab:inputTo PythonSimulationEngine
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Mathematical model describing the crane's motion dynamics and mechanical behavior for accurate trajectory simulation."
    DTDFVocab:inputTo PythonSimulationEngine
]

instance TimeseriesOperationalData : DTDFVocab:Data [
    base:desc "Time-series data storing crane operational metrics such as position, speed, load, and trajectory execution metrics."
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance PredictedTrajectoryData : DTDFVocab:Data [
    base:desc "Simulated trajectory data generated by the digital twin's kinematic model for comparison with physical measurements."
]

// C11: Enablers
instance PythonSimulationEngine : DTDFVocab:Enabler [
    base:desc "Open-source Python-based simulation engine executing kinematic and behavioral models for real-time trajectory prediction."
    DTDFVocab:enables TrajectoryGeneratorService, ContinuousValidationService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "PostgreSQL extension optimized for time-series data storage, handling historical operational data and real-time logging."
    DTDFVocab:enables HistoricalDataLoggingService, DataVisualizationService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Message broker enabling asynchronous communication between physical and digital twin components via publish-subscribe pattern."
]

instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Python-based service continuously recording crane state data into TimescaleDB for historical analysis and validation."
    DTDFVocab:enables HistoricalDataLoggingService
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes and optimizes movement trajectories for crane pucks, ensuring efficient and collision-free operations."
    DTDFVocab:provides OptimizedTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Validates digital twin accuracy by comparing predicted trajectories with physical measurements, detecting deviations via distance metrics."
    DTDFVocab:provides ValidationAlertAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Collects and stores operational data from the physical crane for retrospective analysis and trend identification."
    DTDFVocab:provides HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Provides real-time and historical data visualization for monitoring crane state, kinematic models, and operational trajectories."
    DTDFVocab:provides VisualizationDashboardInsight
]

instance PhysicalCraneInterface : DTDFVocab:Service [
    base:desc "Python program interfacing with crane controllers to collect real-time operational data and transmit it to the logging application."
    DTDFVocab:provides CraneStateDataTransmitted
]

// C17: Insights/Actions
instance OptimizedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Real-time or near-real-time optimized crane movement paths improving efficiency, precision, and energy consumption."
]

instance ValidationAlertAction : DTDFVocab:Action [
    base:desc "Automatically detects and notifies operators of discrepancies between digital twin predictions and physical system behavior."
    DTDFVocab:IsAutomatic true
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Long-term storage of crane operational metrics enabling retrospective analysis and trend identification for system evolution."
]

instance VisualizationDashboardInsight : DTDFVocab:Insight [
    base:desc "Real-time graphical interfaces showing crane state, kinematic models, and operational trajectories for monitoring and analysis."
]

// C1: Components
instance PhysicalCrane : DTDFVocab:Component [
    base:desc "Lab-scale gantry crane system designed for research and educational purposes, featuring stepper motor actuation and electromagnet manipulation."
]

instance CraneController : DTDFVocab:Component [
    base:desc "Embedded or software-based controller managing crane movements and operations, interfacing with actuators and sensors."
]

instance DashboardContainer : DTDFVocab:Component [
    base:desc "Runtime visualization component providing real-time monitoring of crane state, trajectories, and system health."
]

instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Service container handling path planning and trajectory optimization for crane puck movements."
]

instance DatabaseContainer : DTDFVocab:Component [
    base:desc "Container storing state information and operational data in TimescaleDB for historical analysis and validation."
]

instance DigitalTwinContainer : DTDFVocab:Component [
    base:desc "Central container integrating CAD and kinematic models with simulation services for digital twin operations."
]

// C13: Environment
instance LabScaleEnvironment : DTDFVocab:Environment [
    base:desc "Controlled indoor research environment for the lab-scale gantry crane system."
    base:contains PhysicalCrane, CraneController, DashboardContainer, TrajectoryGeneratorContainer, DatabaseContainer, DigitalTwinContainer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the **Trajectory Generator Service**, which leverages a kinematics model to produce optimal movement trajectories for the crane, ensuring minimal residual swinging motion at trajectory endpoints. These commands are relayed through the **Control Application** (a Python service) to the **Physical Crane Interface**, which translates them into executable instructions for the crane’s controllers. The **Human Machine Interface (HMI)** allows operators to configure and override crane operations dynamically. The **Continuous Validation Service** indirectly validates control outcomes by comparing physical trajectory execution against simulated predictions, triggering alerts via the **Dashboard** if discrepancies exceed thresholds. No explicit details on command formats (e.g., message schemas), validation/authentication mechanisms (e.g., access control), or feedback systems (e.g., closed-loop adjustments) are provided. Command execution confirmation is implied through the validation service’s comparison process."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellation for the lab-scale gantry crane follows an **ad-hoc, containerized architecture** without reliance on a commercial digital twin framework. The system is orchestrated using the **C4 Model**, which defines five **physical containers** (e.g., crane hardware, sensors) and six **digital twin containers** (e.g., Database, Dashboard, Trajectory Generator). Component integration is achieved through **modular containerization**, likely leveraging lightweight virtualization or container platforms (e.g., Docker, Kubernetes) for deployment. Resource management is implicit in the containerized design, with each container handling distinct responsibilities (e.g., real-time control vs. visualization). System-wide coordination is implied to be **container-centric**, with dependencies between containers (e.g., Trajectory Generator → Physical Crane) ensuring synchronized operation. The absence of a commercial framework suggests custom integration logic, potentially using **message-passing or shared databases** (e.g., InfluxDB-like systems) for state synchronization."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system employs an **MQTT Broker** for lightweight, publish-subscribe messaging between services, ensuring decoupled communication. Data storage relies on **TimescaleDB**, a PostgreSQL extension optimized for time-series workloads, housing all system-generated data. The **Dashboard** (Grafana) visualizes this data, while the **Trajectory Generator Service** and **Simulation Service** interact via the MQTT Broker to exchange trajectory data. The **Database**, **MQTT Broker**, and **Dashboard** are containerized using **Docker**, with a provided `docker compose` file for orchestration. No explicit details on network topology (e.g., LAN/WAN), bandwidth/latency requirements, or security protocols (e.g., encryption) are documented. The system’s architecture suggests a localized deployment (e.g., on-premise) but does not specify redundancy or failover mechanisms."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin system is deployed on a **personal computer**, with the physical crane interfacing directly via software running on the same machine. The **Database**, **MQTT Broker**, and **Dashboard** are containerized using **Docker**, while the remaining services (e.g., **Trajectory Generator**, **Simulation Service**) operate as standalone Python applications. A `docker compose` file is provided for managing containerized components. The system does not explicitly specify cloud/edge deployment options, computational/storage requirements (e.g., CPU/RAM), or scalability mechanisms. Availability/reliability assurances are implied by continuous logging and validation but not quantified. The deployment model prioritizes simplicity, with no mention of high-availability configurations or distributed architectures."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with external systems via **MQTT-based publish-subscribe communication** for real-time signaling between physical and digital components. The **Physical Crane Interface** (implemented in Python) serves as a critical integration layer, translating low-level sensor/actuator data into higher-level digital twin representations. While no explicit enterprise interoperability standards (e.g., OPC UA, REST APIs) are mentioned, the use of **MQTT** ensures lightweight, scalable data exchange. Dependencies on external systems are minimal, with the primary focus on internal coordination via the MQTT Broker. The system does not explicitly detail integration patterns with other Digital Twins or enterprise systems beyond its own containerized architecture."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar adheres to:
  - **AutomationML** for digital twin representation, enabling **interoperability** with industrial automation tools.
  - **Microsoft Azure tools** for pipeline implementation, suggesting alignment with cloud-native standards (e.g., Azure IoT, Event Grid).
  GreenhouseDT uses **InfluxDB** (time-series database) and **ActiveMQ** (message broker), which are de facto standards for IoT/data streaming but lack formal certification. The gantry crane exemplar’s architecture is documented via **C4 Model**, a software architecture standard, though no domain-specific standards (e.g., ISO 23227 for digital twins) are mentioned. **No certification requirements** or compliance frameworks (e.g., GDPR, IEC 62443) are referenced."
]