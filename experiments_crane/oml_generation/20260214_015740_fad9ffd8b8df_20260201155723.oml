// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures the swinging motion of the hoist in the lab-scale gantry crane to ensure precise trajectory tracking. Part of the physical system's real-time sensor feedback for synchronization with the Digital Twin."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Gauges wind speed in the lab environment, providing environmental context for trajectory validation and fault detection in the gantry crane system."
    DTDFVocab:producedData AnemometerDataTransmitted
]

instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Implied sensor for tracking positional data of crane components (e.g., hoist, carriage) to enable real-time trajectory validation against simulated models."
    DTDFVocab:producedData PositionDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder, PositionSensor
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "Behavioral model of the gantry crane's deterministic kinematics, used by the Trajectory Generator Service to compute precise control inputs for optimal movement trajectories."
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance TrajectorySimulationData : DTDFVocab:Data [
    base:desc "Simulated trajectories generated by the Simulation Service, representing expected crane movements based on kinematic models and control inputs."
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo SimulationEnabler
]

instance RealTimeTrajectoryData : DTDFVocab:Data [
    base:desc "Real-time measurements of executed trajectories (positional data, kinematic parameters) captured by the Logging Application from the physical crane."
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo ValidationEnabler
]

instance OperationalData : DTDFVocab:Data [
    base:desc "Time-series operational data including sensor readings, control inputs, and environmental conditions stored in TimescaleDB for post-hoc analysis."
    DTDFVocab:fromData SwingAngleDataTransmitted, AnemometerDataTransmitted, PositionDataTransmitted
    DTDFVocab:inputTo DatabaseEnabler
]

// C11: Enablers
instance LoggingApplicationEnabler : DTDFVocab:Enabler [
    base:desc "Python-based service continuously capturing and transmitting the crane's state to TimescaleDB. Implicitly handles data preprocessing before storage."
    DTDFVocab:enables TrajectoryValidationService, FaultDetectionService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Generates simulated trajectories based on kinematic models for comparison with real-time physical data."
    DTDFVocab:enables TrajectoryValidationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python module (`gantrylib`) implementing optimal trajectory generation for the crane's hoist, ensuring no residual swinging motion post-operation."
    DTDFVocab:enables OptimalControlService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous Validation Service comparing real-time measurements with simulated trajectories, calculating distance metrics and triggering alerts for deviations."
    DTDFVocab:enables TrajectoryValidationService, FaultDetectionService
]

instance DatabaseEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database optimized for time-series data, serving as the single source of truth for all digital twin services with sub-millisecond precision."
    DTDFVocab:enables DataVisualizationService, HistoricalDataLoggingService
]

instance CommunicationEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto (MQTT broker) facilitating low-latency, bidirectional data exchange between physical crane, controller, and digital twin services."
    DTDFVocab:enables LoggingApplicationEnabler
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard rendering real-time and historical data traces for crane motion, sensor feedback, and system performance metrics."
    DTDFVocab:enables DataVisualizationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Generates optimal movement trajectories for the crane's hoist using kinematic models to ensure precise control inputs and no residual swinging motion."
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance TrajectoryValidationService : DTDFVocab:Service [
    base:desc "Compares physical system behavior (real-time measurements) with digital twin predictions (simulated trajectories) to detect discrepancies and validate synchronization."
    DTDFVocab:provides TrajectoryAccuracyInsight, SystemSynchronizationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Analyzes sensor data (e.g., Swing Angle Encoder) to identify abnormalities such as unexpected swinging or controller failures, triggering alerts or corrective actions."
    DTDFVocab:provides FaultAlertAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Visualizes real-time and historical operational data from TimescaleDB, presenting traces of crane motion, sensor feedback, and system performance metrics."
    DTDFVocab:provides SystemHealthInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Stores time-series operational data in TimescaleDB for post-hoc analysis, trend identification, and long-term system evolution documentation."
    DTDFVocab:provides HistoricalTrendInsight
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Precisely computed movement trajectories for the crane's hoist, optimized to eliminate residual swinging and ensure deterministic kinematics."
]

instance TrajectoryAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantitative comparison between executed and simulated trajectories, including distance metrics and deviation thresholds for validation."
]

instance SystemSynchronizationInsight : DTDFVocab:Insight [
    base:desc "Real-time synchronization status between physical crane state and digital twin predictions, ensuring bidirectional data flow integrity."
]

instance FaultAlertAction : DTDFVocab:Action [
    base:desc "Automated alert triggered when sensor data deviates from expected behavior, indicating potential faults in the physical system or controller."
    DTDFVocab:IsAutomatic true
]

instance SystemHealthInsight : DTDFVocab:Insight [
    base:desc "Comprehensive overview of crane system performance, including motion traces, sensor feedback, and operational metrics for operators and researchers."
]

instance HistoricalTrendInsight : DTDFVocab:Insight [
    base:desc "Longitudinal analysis of crane operational data to identify trends, anomalies, and system evolution patterns over time."
]

// C2: Acting Components
instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Motor responsible for controlled vertical movement of the crane's hoist, interfacing with the Arduino-based control unit for precise actuation."
]

instance CarriageMotor : DTDFVocab:ActingComponent [
    base:desc "Motor enabling horizontal movement of the crane's carriage, paired with controllers for synchronized operation with the hoist."
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnetic actuator at the hoist's end enabling container (puck) pickup and release operations, managed by the Arduino control unit."
]

instance ArduinoControlUnit : DTDFVocab:ActingComponent [
    base:desc "Arduino-based control unit managing all actuators (motors, electromagnet) and interfacing with sensors to regulate motion and lifting operations via closed-loop control."
]

// C1: Physical System Components
instance GantryCranePhysicalSystem : DTDFVocab:Component [
    base:desc "Lab-scale gantry crane designed as a cyber-physical system for research and educational purposes, comprising physical components and controllers."
]

instance CraneController : DTDFVocab:Component [
    base:desc "Controller interfacing with the physical crane to execute commands and process sensor feedback, enabling bidirectional communication with the digital twin."
]

instance LabEnvironment : DTDFVocab:Environment [
    base:desc "Controlled lab environment enabling reproducible experiments for digital twin validation, fault detection, and trajectory optimization."
    base:contains GantryCranePhysicalSystem, CraneController, SwingAngleEncoder, Anemometer, PositionSensor,
                 HoistMotor, CarriageMotor, ElectromagnetActuator, ArduinoControlUnit
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The **Control Application** executes commands generated by the **Trajectory Generator Service**, which produces optimal movement trajectories for the crane using a kinematics model. These trajectories are designed to eliminate residual swinging motion at the end of execution. The Control Application transmits these commands to the **Physical Crane Interface**, which relays them to the crane’s controllers. The **Continuous Validation Service** provides a feedback loop by comparing the executed trajectories (measured in real-time) with simulated trajectories, calculating distance metrics to detect deviations. If the threshold for acceptable deviation is breached, operators are alerted via the **Dashboard**. While the document does not specify control message formats, validation mechanisms, or conflict resolution strategies, the system implies a unidirectional command flow from the Trajectory Generator to the Control Application, with feedback-driven validation ensuring physical-digital alignment. Command execution confirmation is inferred through the validation service’s comparison process."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The provided documents do not specify explicit synchronization frequencies, latency requirements, or real-time constraints for any of the Digital Twin systems. GreenhouseDT relies on **prerecorded data** in virtual machine images, implying **no real-time synchronization** between the physical greenhouse and its digital twin. The Air Quality Management exemplar focuses on **runtime visualization, simulation, and prediction**, but no temporal granularity or synchronization frequency is detailed. The Gantry Crane system lacks explicit mention of time scales, though its **Logging Application** suggests continuous state monitoring, which may imply **low-latency data collection** for validation purposes. No high-frequency or real-time synchronization is confirmed for any exemplar."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin systems in the documents adopt a **lightweight, ad-hoc orchestration pattern** without relying on commercial digital twin frameworks. **GreenhouseDT** uses a **service-oriented architecture** with **InfluxDB (time-series storage)**, **ActiveMQ (message broker for event-driven communication)**, and **virtual machines** for isolation, enabling **behavioral adaptation** of both the physical greenhouse and its twin. The **Air Quality Management** exemplar employs an **AutomationML-based digital twin** integrated with **Microsoft Azure tools**, suggesting a **pipeline-driven orchestration** for runtime visualization, simulation, and prediction. The **gantry crane system** leverages the **C4 Model** for architectural clarity, though no specific orchestration mechanisms (e.g., microservices, event buses) are detailed. **Resource management** is implied via **containerization/virtualization** (e.g., virtual machines, Raspberry Pi for edge processing), but **no centralized coordination layer** (e.g., Kubernetes, service mesh) is mentioned. The exemplars collectively emphasize **domain-specific, modular integration** over standardized digital twin constellations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The **GreenhouseDT** and **Air Quality Management** exemplars adopt **ad-hoc approaches** without commercial frameworks, prioritizing flexibility over standardized validation. The **gantry crane** system features a **Continuous Validation Service** that compares **executed trajectories** (physical system) with **simulated trajectories** (digital twin) in real-time, though no quantitative metrics (e.g., error thresholds, RMSE) or uncertainty quantification methods are specified. No formal verification processes (e.g., model checking, calibration protocols) or quality assurance frameworks (e.g., ISO/IEC 15909) are documented. The **Air Quality Management** exemplar’s **runtime visualization, simulation, and prediction** applications imply iterative validation but lack technical rigor."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **MQTT Broker** serves as the primary communication protocol for signaling between services within the Digital Twin system, enabling lightweight, publish-subscribe-based messaging. The **TimescaleDB** database, built on PostgreSQL, handles time-series data storage and retrieval, supporting efficient querying of crane state logs and validation metrics. The system architecture is centralized, with all containers (Database, MQTT Broker, Dashboard, Trajectory Generator, Simulation, and Continuous Validation Services) deployed on a single host (a personal computer). While the document does not specify network topology (e.g., LAN/WAN), bandwidth requirements, latency thresholds, or redundancy mechanisms, the use of MQTT implies low-latency, event-driven communication suitable for real-time control and monitoring. Security protocols are not explicitly detailed, but the containerized deployment suggests isolation between services."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin system is deployed **on-premise** on a personal computer, with the **Physical Crane** interfacing directly via hardware connections. The **Database (TimescaleDB)**, **MQTT Broker**, and **Dashboard (Grafana)** are containerized using Docker for ease of deployment and management. The remaining services (Trajectory Generator, Simulation, and Continuous Validation) are implemented as standalone Python applications running on the same host. The document does not specify computational or storage requirements, scalability mechanisms (e.g., partitioning, sharding), or availability/reliability assurances (e.g., backups, failover). Deployment is limited to a single-node setup, with no explicit mention of distributed or cloud-based hosting."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin systems demonstrate **limited horizontal integration** with external systems, relying on **ad-hoc or domain-specific protocols**. **GreenhouseDT** integrates with **InfluxDB (time-series database)** and **ActiveMQ (message broker)**, but no interoperability standards (e.g., OPC UA, MQTT) or enterprise system dependencies are specified. The **Air Quality Management** exemplar uses **AutomationML** for digital twin modeling and **Microsoft Azure tools** for pipeline execution, indicating potential for **cloud-based integration** but no explicit APIs or data exchange protocols with external systems. The **gantry crane system** lacks documented integration details, though its **cyber-physical nature** suggests potential for **industrial communication protocols** (e.g., PROFINET, EtherCAT). **No evidence** of integration with other Digital Twins or enterprise resource planning (ERP) systems is provided. The exemplars prioritize **self-contained, research-oriented setups** over scalable enterprise interoperability."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **no explicit industry standards** (e.g., ISO/IEEE 42010, OMG Digital Twin standards) or certification frameworks. Interoperability is achieved through **CAD models in Autodesk Fusion360** and **Arcadia models in Capella**, with no reference to AutomationML or other standardized exchange formats. Version control and dissemination are managed via **GitHub**, and the architecture is documented using the **C4 Model**, a non-standardized but widely adopted visualization framework for software systems."
]