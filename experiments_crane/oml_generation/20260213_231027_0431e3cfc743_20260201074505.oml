// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing Angle Encoder measuring the pendulum swing of the hoisted payload"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder on the cart measuring linear displacement"
    DTDFVocab:producedData CartPositionDataTransmitted
]

// C4: Physical-to-virtual interaction – data transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CartPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartPositionEncoder
]

// C10: Data produced from sensors
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Timestamped swing angle measurements with basic filtering performed by the Arduino"
    DTDFVocab:fromData SwingAngleDataTransmitted
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Timestamped wind speed measurements with basic filtering performed by the Arduino"
    DTDFVocab:fromData WindSpeedDataTransmitted
]

instance CartPositionData : DTDFVocab:Data [
    base:desc "Timestamped cart linear displacement measurements with basic filtering performed by the Arduino"
    DTDFVocab:fromData CartPositionDataTransmitted
]

// C11: Enablers (middleware & software)
instance PhysicalCraneInterface : DTDFVocab:Enabler [
    base:desc "Python program that connects directly to the crane controllers and exposes the real‑time state of the crane"
    DTDFVocab:enables DataVisualizationService, ContinuousValidationService, OptimalControlService
]

instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Python logging application that continuously reads state information from PhysicalCraneInterface and writes it into TimescaleDB"
    DTDFVocab:enables HistoricalLoggingService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance persisting sensor readings, command histories and trajectory logs"
    DTDFVocab:enables HistoricalLoggingService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for real‑time pub/sub between physical data streams and twin services"
    DTDFVocab:enables DataVisualizationService, ContinuousValidationService, OptimalControlService
]

// C2: Acting components (physical actuators)
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Motor‑driven actuation mechanisms that move the trolley and control the hoist"
]

instance CraneController : DTDFVocab:ActingComponent [
    base:desc "Electronic controller that receives set‑points from the twin’s optimal‑control service and drives the MotorActuator"
]

// C10: Models / Data
instance GantryCADModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the laboratory‑scale gantry crane created in Autodesk Fusion360"
]

instance GantryKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic (behavioral) model representing the crane’s motion used for optimal control and validation"
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal‑control service that computes and dispatches set‑points to the crane controller"
    DTDFVocab:provides DispatchSetPointsAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Historical data logging service that records sensor readings and command histories in TimescaleDB"
    DTDFVocab:provides HistoricalDataAccessInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Data‑visualization service that renders the crane’s state and trajectories in Grafana dashboards"
    DTDFVocab:provides LiveStateVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service that compares live sensor data against the kinematic model to detect deviations"
    DTDFVocab:provides DeviationDetectionInsight
]

// C17: Insights / Actions
instance DispatchSetPointsAction : DTDFVocab:Action [
    base:desc "Automatic dispatch of optimal set‑points to the crane controller"
    DTDFVocab:IsAutomatic true
]

instance HistoricalDataAccessInsight : DTDFVocab:Insight [
    base:desc "Access to historical sensor and command data for post‑run analysis and model refinement"
]

instance LiveStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of crane position, swing angle and environmental conditions"
]

instance DeviationDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of deviations between live sensor streams and the kinematic model, enabling corrective actions"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control of the crane is performed by the Control Application, a Python program that issues motion commands through the same Physical Crane Interface used for sensing. Commands (e.g., target position, speed set‑points) are generated by higher‑level services such as the Trajectory Generator and are transmitted to the crane controllers via the interface. The Human‑Machine Interface allows an operator to issue or modify commands, and the crane’s response is observable through the logging feedback loop. The document does not detail the command message format, authentication, or confirmation mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The gantry‑crane digital twin adopts an ad‑hoc, component‑based architecture without a commercial DT framework. Sensor measurements from the physical crane are published to an open‑source Eclipse Mosquitto MQTT broker. Twin services subscribe to the MQTT topics, ingest the data, and store time‑stamped observations in a TimescaleDB instance. Analytical and control components (e.g., kinematic model, prediction algorithm) run on the same personal‑computer host, retrieve data from TimescaleDB, compute updated states, and publish actuation commands back to the physical controller via MQTT. Coordination is achieved through loose coupling of components via MQTT topics and a centralized time‑series database, providing resource‑light orchestration suitable for the lab‑scale setup."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained through a continuous validation service that compares real‑time data from the crane with the CAD and kinematic models, supporting fault‑detection methods and ensuring model accuracy. Validation is performed by logging operational data, visualizing discrepancies, and applying verification techniques described in prior research on continuous validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin relies on an MQTT broker that provides publish/subscribe signaling between containers such as the Trajectory Generator Service, Simulation Service, Continuous Validation Service, and other components. The architecture assumes a client‑server MQTT topology; no further bandwidth, latency, redundancy, or security specifications are given."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire system is intended to run on a single personal computer that the physical crane is plugged into. The software components (Database, MQTT Broker, Dashboard, and the various service containers) are packaged as Docker containers, enabling container‑based deployment on the host PC. This constitutes an on‑premise/edge deployment; computational resources are limited to a typical workstation, and storage is provided by the TimescaleDB container. The architecture supports scaling by adding more containers or moving containers to other hosts, but no specific cloud platform is mentioned. Availability is achieved by running all components locally; redundancy or high‑availability mechanisms are not described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration between the twin and the physical crane relies on the MQTT protocol mediated by Eclipse Mosquitto, enabling real‑time, publish/subscribe data exchange. Persisted data are stored in TimescaleDB, which can be accessed through standard PostgreSQL interfaces, allowing external analysis tools to query historic sensor data. The integration scope is limited to these internal protocols and databases; no external enterprise systems, cloud services, or interoperability standards such as AutomationML are employed."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The lab‑scale gantry crane digital twin incorporates a Continuous Validation Service that continuously compares sensor measurements of executed crane trajectories with simulated trajectories, computes distance metrics, and, when a metric exceeds a predefined acceptable threshold, generates an alert via the Grafana dashboard to inform the operator. This runtime validation mechanism provides safety‑critical monitoring and enables prompt corrective actions to prevent unsafe crane behavior."
]