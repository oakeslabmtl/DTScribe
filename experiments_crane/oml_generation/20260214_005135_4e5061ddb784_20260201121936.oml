// ---------- Sensing Components ----------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder reads the crane's swing angle during operation"
    DTDFVocab:producedData SwingAngleTopic
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measures wind speed affecting crane dynamics"
    DTDFVocab:producedData WindSpeedTopic
]

instance CartMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder on the cart wheel provides translational position and velocity"
    DTDFVocab:producedData CartTelemetryTopic
]

instance HoistMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder on the hoist provides vertical position and velocity"
    DTDFVocab:producedData HoistTelemetryTopic
]

// ---------- Data Transmitted (MQTT topics) ----------
instance SwingAngleTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CartTelemetryTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoder
]

instance HoistTelemetryTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoder
]

// ---------- Data Objects ----------
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Measured swing angle data stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleTopic
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Measured wind speed data stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedTopic
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance CartTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry of cart position and velocity stored in TimescaleDB"
    DTDFVocab:fromData CartTelemetryTopic
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HoistTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry of hoist position and velocity stored in TimescaleDB"
    DTDFVocab:fromData HoistTelemetryTopic
    DTDFVocab:inputTo TimescaleDBEnabler
]

// ---------- Acting Component ----------
instance PhysicalCraneInterface : DTDFVocab:ActingComponent [
    base:desc "Interface that translates control setpoints into TMC4671 stepper driver signals for cart and hoist motors"
]

// ---------- Models ----------
instance KinematicModel : DTDFVocab:Model [
    base:desc "Python implementation of gantry crane kinematic model used for trajectory generation"
    DTDFVocab:inputTo KinematicEngineEnabler
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulation model replicating motor controller dynamics for real‑time simulation"
    DTDFVocab:inputTo SimulationEngineEnabler
]

// ---------- Enablers ----------
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB service that stores telemetry and provides data for validation"
    DTDFVocab:enables LoggingService, ContinuousValidationService
]

instance KinematicEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime that executes the kinematic model for trajectory generation"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Runtime environment that executes the motor‑controller dynamics simulation"
    DTDFVocab:enables RealTimeSimulationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker enabling inter‑service communication"
    DTDFVocab:enables LoggingService, ContinuousValidationService, TrajectoryGeneratorService, ControlApplicationService
]

// ---------- Services ----------
instance LoggingService : DTDFVocab:Service [
    base:desc "Data logging service storing telemetry into TimescaleDB"
    DTDFVocab:provides DataStorageInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous model‑based validation computing deviations and triggering alerts"
    DTDFVocab:provides ThresholdAlertInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboard service visualizing live trajectories and confidence bounds"
    DTDFVocab:provides LiveTrajectoryInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Optimal trajectory generation service using the kinematic model"
    DTDFVocab:provides TrajectoryCommandInsight
]

instance RealTimeSimulationService : DTDFVocab:Service [
    base:desc "Real‑time simulation service replicating motor controller dynamics"
]

instance ControlApplicationService : DTDFVocab:Service [
    base:desc "Control application that sends velocity and position setpoints to the PhysicalCraneInterface"
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Eclipse Mosquitto MQTT broker enabling inter‑service communication"
]

// ---------- Insights ----------
instance LiveTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Dashboard displays live trajectories and confidence bounds"
]

instance DataStorageInsight : DTDFVocab:Insight [
    base:desc "Telemetry is stored in TimescaleDB and available for analysis"
]

instance ThresholdAlertInsight : DTDFVocab:Insight [
    base:desc "Threshold alerts are generated when deviation metrics exceed predefined limits"
]

instance TrajectoryCommandInsight : DTDFVocab:Insight [
    base:desc "Setpoints are transmitted to the PhysicalCraneInterface for actuation"
]

// ---------- Actions ----------
instance ThresholdAlertAction : DTDFVocab:Action [
    base:desc "Operator is notified when deviation thresholds are breached"
    DTDFVocab:IsAutomatic true
]

instance DataAnalyticsAction : DTDFVocab:Action [
    base:desc "Researchers analyze historical logs for optimisation and fault detection"
    DTDFVocab:IsAutomatic false
]

// ---------- Components (Containers) ----------
instance DatabaseContainer : DTDFVocab:Component [
    base:desc "Container running TimescaleDB for telemetry storage"
]

instance DashboardContainer : DTDFVocab:Component [
    base:desc "Container running Grafana for data visualization"
]

instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Container running the trajectory generation service"
]

instance SimulationContainer : DTDFVocab:Component [
    base:desc "Container running the real‑time simulation service"
]

instance ContinuousValidationContainer : DTDFVocab:Component [
    base:desc "Container running the continuous validation service"
]

instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Container running the Eclipse Mosquitto MQTT broker"
]

instance PhysicalCraneContainer : DTDFVocab:Component [
    base:desc "Container representing the physical gantry crane structure"
]

instance PhysicalCraneInterfaceContainer : DTDFVocab:Component [
    base:desc "Container hosting the PhysicalCraneInterface for motor actuation"
]

instance ControlAppContainer : DTDFVocab:Component [
    base:desc "Container running the Control Application that sends setpoints"
]

instance LoggingAppContainer : DTDFVocab:Component [
    base:desc "Container running the Logging Application that publishes telemetry via MQTT"
]

instance HMIContainer : DTDFVocab:Component [
    base:desc "Container hosting the Human‑Machine Interface for operator interaction"
]

// ---------- Environment ----------
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains DatabaseContainer, DashboardContainer, TrajectoryGeneratorContainer,
            SimulationContainer, ContinuousValidationContainer, MQTTBrokerContainer,
            PhysicalCraneContainer, PhysicalCraneInterfaceContainer, ControlAppContainer,
            LoggingAppContainer, HMIContainer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory Generator and Control Application publish velocity and position setpoints to the Physical Crane Interface via MQTT; the interface drives the TMC4671 stepper drivers to move the cart and hoist."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Logging occurs at real‑time sample rates (e.g., every 10 ms to 100 ms implied), trajectory generation and validation execute continuously during operation, while simulation and classification run in near real‑time; no explicit discrete time step is specified."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated via Docker Compose; containers cluster on a single PC; inter‑container communication on private network; external interfaces: operator’s HMI and research tools connect via HTTP/HTTPS to dashboard, MQTT to services, and PostgreSQL to databases."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The system covers design (CAD and kinematic model), manufacturing (assembly per BOM), and operation (actual crane with digital twin services). Development iterations include continuous validation and future extensions for education and fault‑detection."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service compares measured trajectory moments with simulated counterparts using Euclidean distance metrics; thresholds determined experimentally; classification models would augment detecting faults; validation occurs in real‑time, enabling reliability assessment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication via Mosquitto MQTT broker (TCP port 1883) between services and physical interface; database accessed via PostgreSQL TCP; all services run over Docker bridge network; HMI communicates via HTTP to dashboard."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted locally on a personal computer; Docker Compose deploys Database, MQTT Broker, Grafana containers; Python applications run natively (gantrylib module) or via containers; all code is open source and available on GitHub repository."
]