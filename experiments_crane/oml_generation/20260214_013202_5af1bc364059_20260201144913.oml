// Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Lab‑scale gantry crane inspired by harbor cranes in Antwerp and implemented as a cyber‑physical system."
    base:contains LabScaleGantryCraneEnvironment_ComponentList
]

// Acting Components (C2)
instance CartStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Step‑per cart motor powered by a Trinamic TMC4671 eval motor driver and controlled via a Python interface."
]
instance HoistStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Step‑per hoist motor powered by a Trinamic TMC4671 eval motor driver and controlled via a Python interface."
]
instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist to snatch small pucks."
]
instance PhysicalCraneInterfaceActuator : DTDFVocab:ActingComponent [
    base:desc "Central interface that polls an Arduino for sensor data, feeds encoder feedback from the motor controllers, and issues control commands to the stepper motors and electromagnet."
]

// Sensing Components (C3)
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder measuring the pendulum motion of the hoist."
    DTDFVocab:producedData SwingAngleDataTransmitted
]
instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer for measuring ambient wind speed."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// Data Transmitted (C4)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// Data (C10)
instance TimeSeriesSensorLogData : DTDFVocab:Data [
    base:desc "Time‑series sensor logs stored in TimescaleDB."
    DTDFVocab:fromData SwingAngleDataTransmitted, WindSpeedDataTransmitted
    DTDFVocab:inputTo MosquittoMQTTBroker, TimescaleDB
]
instance SimulationConfidenceBoundData : DTDFVocab:Data [
    base:desc "Simulation output providing confidence bounds."
    DTDFVocab:fromData SimulationOutputDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]
instance ServiceConfigFileData : DTDFVocab:Data [
    base:desc "Service configuration files in JSON format."
    DTDFVocab:inputTo PythonInterface
]

// Models (C10)
instance Fusion360CADModel : DTDFVocab:Model [
    base:desc "CAD model created in Autodesk Fusion360."
    DTDFVocab:inputTo PythonInterface
]
instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the trajectory generator and simulation services."
    DTDFVocab:inputTo PythonInterface
]

// Enablers (C11)
instance PythonInterface : DTDFVocab:Enabler [
    base:desc "Python interface used to communicate with motor drivers and to load models/configurations."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService,
                ContinuousValidationService, LoggingService
]
instance MosquittoMQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service signalling."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService,
                ContinuousValidationService, LoggingService
]
instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB for real‑time data logging and simulation output storage."
    DTDFVocab:enables LoggingService
]
instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for metrics and visualization."
    DTDFVocab:enables DashboardApplication
]

// Services (C6)
instance TrajectoryGeneratorService : DTDFVocab:DTComponent [
    base:desc "Optimal trajectory generation ensuring zero‑residual swing."
    DTDFVocab:provides OptimalTrajectoryInsight
]
instance SimulationService : DTDFVocab:DTComponent [
    base:desc "Simulation of crane dynamics with confidence bounds."
    DTDFVocab:provides SimulationConfidenceBoundInsight
]
instance ContinuousValidationService : DTDFVocab:DTComponent [
    base:desc "Continuous validation comparing measured vs simulated trajectories and alerting on threshold breaches."
    DTDFVocab:provides SwingDeviationInsight
]
instance LoggingService : DTDFVocab:DTComponent [
    base:desc "Real‑time data logging to TimescaleDB."
    DTDFVocab:provides LogDataAction
]
instance DashboardApplication : DTDFVocab:Service [
    base:desc "Grafana dashboard for visualization."
]

// Insights / Actions (C17)
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory suggestions to avoid unwanted swinging."
]
instance SimulationConfidenceBoundInsight : DTDFVocab:Insight [
    base:desc "Confidence bounds from simulation outputs."
]
instance SwingDeviationInsight : DTDFVocab:Insight [
    base:desc "Detection of excess swinging or waveform deviations."
]
instance LogDataAction : DTDFVocab:Action [
    base:desc "Continuous logging of sensor data to TimescaleDB."
    DTDFVocab:IsAutomatic true
]
instance ControlAction : DTDFVocab:Action [
    base:desc "Operator commands to move pucks between two locations."
    DTDFVocab:IsAutomatic false
]

// Additional Data Transmitted (Simulation Output)
instance SimulationOutputDataTransmitted : DTDFVocab:DataTransmitted [
]

// Component List (C3)
instance LabScaleGantryCraneEnvironment_ComponentList : DTDFVocab:Component [
    base:desc "Primary system components deployed in a centralized Docker‑compose architecture."
    base:contains ControlApplication, LoggingApplication, DashboardApplication, TimescaleDB,
                 MosquittoMQTTBroker, TrajectoryGeneratorService, SimulationService,
                 ContinuousValidationService, PhysicalCraneInterfaceActuator,
                 CartStepperMotorActuator, HoistStepperMotorActuator, ElectromagnetActuator,
                 SwingAngleEncoder, Anemometer, PythonInterface
]

// Newly added components referenced in Component List
instance ControlApplication : DTDFVocab:Component [
    base:desc "Control application for operator commands."
]
instance LoggingApplication : DTDFVocab:Component [
    base:desc "Logging application for data collection."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application receives trajectory commands generated by the Trajectory Generator Service and forwards motor setpoints to the Physical Crane Interface, which then issues corresponding control signals to the stepper motors and electromagnet through the Arduino.
"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All twin services operate continuously; logging and validation run in real time with every control loop iteration (data sampled at the same rate as the crane’s motor controller, typically sub‑second). Trajectory generation is triggered on-demand but its output is consumed immediately by the control loop. The system’s architecture therefore supports continuous, near‑real‑time synchronization between physical and virtual worlds."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated web of services: Physical Crane Interface bridging hardware and services; Data Logging; Trajectory Generation; Simulation; Continuous Validation; Dashboard; MQTT broker; TimescaleDB; all coordinated through Docker compose and the gantrylib Python library."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design – CAD models in Fusion360 and a kinematic model; Manufacturing – assembly guided by the BOM; Operation – runtime data logging, continuous validation, and control. The twin’s software evolves through iterative research releases and teaching extensions.
"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous validation compares measured sensor data against simulated trajectories, computing a distance metric and checking against a predefined threshold; threshold breaches trigger operator alerts; simulation model substantiated by manufacturing kinematic data; no formal formal model‑checking reported."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical control uses serial/USB communication between the Python Physical Crane Interface and the Arduino board. Service coordination occurs over MQTT topics; data persistence accesses TimescaleDB via SQL queries. All communications stay within the local machine’s network.
"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin services are containerised with Docker and orchestrated by docker‑compose on a single personal computer; TimescaleDB, MQTT broker, Grafana each run in separate containers; gantrylib installed via pip; no cloud deployment."
]