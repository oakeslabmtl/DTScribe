instance SwingAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the hoist capturing swing angle of the gantry crane."
    DTDFVocab:producedData SwingAngleDataTransmitted
]
instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting crane dynamics."
    DTDFVocab:producedData WindSpeedDataTransmitted
]
instance MotorCurrentVoltageSensor : DTDFVocab:SensingComponent [
    base:desc "Feedback sensor on the TMC4671 drivers providing motor current and voltage."
    DTDFVocab:producedData MotorCurrentVoltageDataTransmitted
]
instance ContainerPresenceSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor triggered by the electromagnet logic when a plastic puck is attached."
    DTDFVocab:producedData ContainerPresenceDataTransmitted
]
instance PositionEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder capturing cart position on the 2‑D grid."
    DTDFVocab:producedData PositionDataTransmitted
]

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensor
]
instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]
instance MotorCurrentVoltageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentVoltageSensor
]
instance ContainerPresenceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContainerPresenceSensor
]
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionEncoderSensor
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing angle measurements of the crane."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo LoggingApplicationEnabler
]
instance WindSpeedData : DTDFVocab:Data [
    base:desc "Wind speed data captured by the anemometer."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo LoggingApplicationEnabler
]
instance MotorCurrentVoltageData : DTDFVocab:Data [
    base:desc "Motor current and voltage feedback from TMC4671 drivers."
    DTDFVocab:fromData MotorCurrentVoltageDataTransmitted
    DTDFVocab:inputTo LoggingApplicationEnabler
]
instance ContainerPresenceData : DTDFVocab:Data [
    base:desc "Presence status of plastic pucks sensed by electromagnet."
    DTDFVocab:fromData ContainerPresenceDataTransmitted
    DTDFVocab:inputTo LoggingApplicationEnabler
]
instance PositionData : DTDFVocab:Data [
    base:desc "Cartesian coordinates of the crane cart on the 2‑D grid."
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo LoggingApplicationEnabler
]
instance TrajectoryPointData : DTDFVocab:Data [
    base:desc "Generated trajectory points from the kinematic model."
    DTDFVocab:inputTo LoggingApplicationEnabler
]
instance SimulatedTrajectoryPointData : DTDFVocab:Data [
    base:desc "Physics‑based simulated trajectory points for validation."
    DTDFVocab:inputTo LoggingApplicationEnabler
]
instance ValidationMetricData : DTDFVocab:Data [
    base:desc "Euclidean distance metric comparing live and simulated trajectories."
    DTDFVocab:inputTo ContinuousValidationEnabler
]

instance CADModel : DTDFVocab:Model [
    base:desc "Fusion360 CAD model of the gantry crane, including nodes and links."
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]
instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Python implementation of the kinetic model for swing‑free trajectory generation."
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]
instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation module reproducing motor and controller dynamics."
    DTDFVocab:inputTo SimulationServiceEnabler
]
instance ValidationModel : DTDFVocab:Model [
    base:desc "Validator that computes Euclidean distance between live and simulated trajectories."
    DTDFVocab:inputTo ContinuousValidationEnabler
]

instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor on the cart axis driven via TMC4671 Eval driver."
]
instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor on the hoist axis driven via TMC4671 Eval driver."
]
instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet end‑effector used to lift and release plastic pucks."
]

instance LoggingApplicationEnabler : DTDFVocab:Enabler [
    base:desc "Python logging service that writes telemetry to TimescaleDB and publishes over MQTT."
    DTDFVocab:enables DataLoggingService
]
instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python service that consumes sensor telemetry and produces swing‑free trajectories."
    DTDFVocab:enables TrajectoryGenerationService
]
instance SimulationServiceEnabler : DTDFVocab:Enabler [
    base:desc "Python service running the physics‑based simulation of the crane."
    DTDFVocab:enables SimulationService
]
instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Python service that compares live and simulated trajectories and flags deviations."
    DTDFVocab:enables ValidationService
]
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto broker orchestrating service-to-service messaging."
    DTDFVocab:enables MQTTService
]
instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana instance visualising telemetry and validation metrics."
    DTDFVocab:enables DashboardService
]
instance HumanMachineInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Python front‑end enabling manual crane control and configuration."
    DTDFVocab:enables HMIService
]
instance PhysicalInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Arduino‑based Python program that reads sensors and drives actuators."
    DTDFVocab:enables PhysicalInterfaceService
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that persists telemetry in TimescaleDB and sends MQTT updates."
    DTDFVocab:provides TelemetryLoggingInsight
]
instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service that generates kinematic swing‑free trajectories."
    DTDFVocab:provides TrajectoryComputationInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Service running physics‑based crane dynamics simulation."
    DTDFVocab:provides SimulationInsight
]
instance ValidationService : DTDFVocab:Service [
    base:desc "Service comparing live and simulated trajectories and notifying on deviations."
    DTDFVocab:provides ValidationThresholdBreachedAction, ValidationInsight
]
instance MQTTService : DTDFVocab:Service [
    base:desc "Service managing MQTT message routing between twin services."
    DTDFVocab:provides MQTTConnectivityInsight
]
instance DashboardService : DTDFVocab:Service [
    base:desc "Service supplying data to Grafana for real‑time dashboards."
    DTDFVocab:provides DashboardVisualizationInsight
]
instance HMIService : DTDFVocab:Service [
    base:desc "Service allowing operators to manually control crane and adjust configuration."
    DTDFVocab:provides ManualControlAction
]
instance PhysicalInterfaceService : DTDFVocab:Service [
    base:desc "Service that interfaces with Arduino hardware for sensor reading and actuator control."
    DTDFVocab:provides PhysicalInterfaceInsight
]

instance TelemetryLoggingInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that telemetry is being logged to TimescaleDB."
]
instance TrajectoryComputationInsight : DTDFVocab:Insight [
    base:desc "Insight confirming generation of swing‑free trajectory points."
]
instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight that physics‑based simulation has produced trajectory outputs."
]
instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Insight summarising validation metrics between live and simulated data."
]
instance ValidationThresholdBreachedAction : DTDFVocab:Action [
    base:desc "Action that notifies operators when validation distance exceeds configurable threshold."
    DTDFVocab:IsAutomatic true
]
instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight showing real‑time visualisation of actual vs simulated trajectories in Grafana."
]
instance ManualControlAction : DTDFVocab:Action [
    base:desc "Action allowing manual override of crane position via the HMI front‑end."
    DTDFVocab:IsAutomatic false
]
instance MQTTConnectivityInsight : DTDFVocab:Insight [
    base:desc "Insight confirming MQTT broker connectivity for service messaging."
]
instance PhysicalInterfaceInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful sensor acquisition and actuator command delivery."
]

instance LabScaleGantryEnvironment : DTDFVocab:Environment [
    base:contains DatabaseContainer, MQTTBrokerContainer, GrafanaDashboardContainer, TrajectoryGeneratorContainer, SimulationServiceContainer, ValidationServiceContainer, PhysicalInterfaceContainer, ControlApplicationContainer, LoggingApplicationContainer, HumanMachineInterfaceContainer
]
instance DatabaseContainer : DTDFVocab:Component [
    base:desc "Docker container running TimescaleDB for high‑volume telemetry storage."
]
instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Docker container running Eclipse Mosquitto broker for local messaging."
]
instance GrafanaDashboardContainer : DTDFVocab:Component [
    base:desc "Grafana Docker container visualising crane telemetry and validation metrics."
]
instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the Python Trajectory Generation service."
]
instance SimulationServiceContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the physics‑based simulation Python service."
]
instance ValidationServiceContainer : DTDFVocab:Component [
    base:desc "Docker container for the Continuous Validation Python service."
]
instance PhysicalInterfaceContainer : DTDFVocab:Component [
    base:desc "Container exposing the Arduino firmware interface via serial communication."
]
instance ControlApplicationContainer : DTDFVocab:Component [
    base:desc "Docker container running the Python control loop for actuation."
]
instance LoggingApplicationContainer : DTDFVocab:Component [
    base:desc "Container running the Tensor logging application writing to TimescaleDB."
]
instance HumanMachineInterfaceContainer : DTDFVocab:Component [
    base:desc "Container running the Python HMI front‑end accessible via web browser."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service emits optimal position trajectories via MQTT, which are received by the Control Application that forwards the output to the Physical Interface. The Control Application sends motor set‑points back to the Arduino controlling the TMC4671 drivers. Continuous Validation may trigger operator alerts through the Grafana dashboard, but control actions are limited to the generated trajectories."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Services operate continuously during crane operation; data logging and validation happen in real‑time, but no explicit sampling intervals or time‑scales are specified in the document"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin constellation follows a C4‑modelled architecture: the physical system interface (Python module) connects to the Arduino hardware; the Control Application issues trajectory set‑points; the Logging Application streams telemetry into TimescaleDB; the Trajectory, Simulation, and Validation Services operate as separate containers communicating through the MQTT broker; the Grafana Dashboard outputs live visualisations and alerts; all containers are orchestrated by a Docker‑Compose file that defines networking and volume mounts. The Digital Twin services run on a local PC, with the physical hardware interface directly attached to the machine’s serial/USB port."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin is developed through four main phases: (1) design – CAD models in Autodesk Fusion360 and kinematic models; (2) manufacturing – assembly of the physical crane per the BOM; (3) deployment – installation of the twin services on a local PC containerised via Docker; (4) operation – real‑time control, continuous validation and research experiments such as fault classification and twin evolution annotations through DarTwin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin’s fidelity relies on a closed‑loop validation loop that compares live capture against a deterministic simulation. Distance metrics (e.g., mean squared error in position and swing angle) are calculated per sample. If a metric exceeds a user‑defined threshold the Continuous Validation Service flags a warning that is shown in the Grafana dashboard. This approach provides a quantitative low‑fidelity validation while ensuring the continuous data stream remains coherent with the physical behaviour. Fault classification experiments use time‑series models trained on historical telemetry to detect deviations from nominal behaviour, further increasing validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical Crane Interface connects to the Arduino via USB/serial, reads sensor data, writes to TimescaleDB over PostgreSQL protocol, and publishes control commands; MQTT broker (Eclipse Mosquitto) handles inter‑service messaging on a local network"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin is hosted locally on a development machine running a Linux/Windows PC. A single Docker‑Compose YAML file brings up the TimescaleDB, Mosquitto broker, Grafana dashboard, and all twin service containers with one command. The physical interface and control application run as native Python processes on the host; the Arduino firmware is flashed via the Arduino IDE. This local deployment enables instant experimentation and real‑time interaction without external infrastructure."
]