// C3: Physical sensing components
instance BeamSwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder mounted on the gantry beam, measuring the angular deviation of the beam"
]

instance CraneTipAnemometer : DTDFVocab:SensingComponent [
    base:desc "Miniature anemometer integrated at the crane tip, monitoring airflow for environmental conditioning"
]

instance ArduinoMicrocontroller : DTDFVocab:SensingComponent [
    base:desc "Arduino microcontroller collecting sensor data (encoder and anemometer) and forwarding it to the digital twin pipeline"
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance BeamSwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BeamSwingAngleEncoder
]

instance CraneTipAnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneTipAnemometer
]

instance ArduinoDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoMicrocontroller
]

// C10: Models/Data
instance Fusion360CADModel : DTDFVocab:Model [
    base:desc "Highly detailed CAD representation of the gantry crane authored in Autodesk Fusion 360 and exported as a STEP file for simulation use"
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Geometric kinematic model used by the Trajectory Generator Service to synthesize feasible motion plans"
]

instance PhysicsBasedSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model emulating crane dynamics for validation and prediction"
]

instance SwingAngleTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data for the swing angle, persisted in TimescaleDB"
    DTDFVocab:fromData BeamSwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance AnemometerTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data for the crane tip anemometer, persisted in TimescaleDB"
    DTDFVocab:fromData CraneTipAnemometerDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance ArduinoTelemetryData : DTDFVocab:Data [
    base:desc "Aggregated telemetry data collected by the Arduino microcontroller, persisted in TimescaleDB"
    DTDFVocab:fromData ArduinoDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance TrajectoryPlanData : DTDFVocab:Data [
    base:desc "Trajectory plan generated by the Trajectory Generator Service and stored for execution by the Physical Crane Interface"
    DTDFVocab:inputTo CasADiMPCEnabler
]

instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Simulation results from the physics‑based simulation service, streamed back to the twin for comparison"
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HistoricalData : DTDFVocab:Data [
    base:desc "Historical data log maintained for trend analysis, accumulated in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
]

// DTDFVocab:Enabler instances
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database for persisting high‑frequency sensor logs and simulation outputs"
    DTDFVocab:enables MonitoringService, ValidationService, HistoricalLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker handling publish/subscribe traffic between physical controller and cloud services"
    DTDFVocab:enables CommunicationService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard visualising telemetry streams by querying data stored in TimescaleDB"
    DTDFVocab:enables VisualizationService
]

instance CasADiMPCEnabler : DTDFVocab:Enabler [
    base:desc "CasADi MPC routine implemented in Python for optimal trajectory generation"
    DTDFVocab:enables OptimalControlService
]

instance PythonControlEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime executing control logic and kinematic model calculations"
    DTDFVocab:enables MonitoringService, ValidationService
]

// DTDFVocab:Service instances
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of the crane's operational data"
    DTDFVocab:provides LiveDataInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal control suggestions to improve motion efficiency using MPC"
    DTDFVocab:provides OptimizeTrajectoryAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Historical data logging for trend analysis"
    DTDFVocab:provides HistoricalDataInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Data visualization interface for user interaction"
    DTDFVocab:provides VisualizationInsight
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Continuous validation comparing live measurements against the kinematic model to detect deviations"
    DTDFVocab:provides DeviationDetectionInsight
]

instance CommunicationService : DTDFVocab:Service [
    base:desc "Handles communication between the Physical Crane Interface and cloud services via MQTT"
]

// Insights
instance LiveDataInsight : DTDFVocab:Insight [
    base:desc "Insight into live telemetry data streams of the gantry crane"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight into historical data trends within the crane system"
]

instance DeviationDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting deviations between live sensor data and the kinematic model"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from visualised telemetry aggregates"
]

// Actions
instance OptimizeTrajectoryAction : DTDFVocab:Action [
    base:desc "Action to generate an optimized motion plan using model predictive control"
    DTDFVocab:IsAutomatic true
]

// C9: Acting Components
instance LeftGantryTrackStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Step‑per motor driving the left gantry track"
]

instance RightGantryTrackStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Step‑per motor driving the right gantry track"
]

instance PhysicalCraneInterface : DTDFVocab:ActingComponent [
    base:desc "Python program translating high‑level motion commands into step commands sent to the step‑per motors; exposes a remote control API"
]

// C11: Environment and Components
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains BeamSwingAngleEncoder, CraneTipAnemometer, ArduinoMicrocontroller,
               LeftGantryTrackStepperMotor, RightGantryTrackStepperMotor, PhysicalCraneInterface
]

instance GantryStructure : DTDFVocab:Component [
    base:desc "Mechanical gantry structure of the lab‑scale crane"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the Control Application, which utilizes the Physical Crane Interface to send instructions to the crane hardware. Commands are issued via Python function calls to the interface, which then transmits the control signals to the crane controllers. The documentation does not detail the exact command format, authentication, validation, feedback, conflict resolution, or execution confirmation mechanisms employed."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates continuously: a sensor‑reading service streams raw data from the Raspberry‑Pi mounted on the gantry crane, which is immediately published to an MQTT broker. A state‑comparison service in the twin consumes these messages in real time, continuously comparing current measurements against the digital model. All measurement streams are ingested into a TimescaleDB time‑series database for subsequent analysis. No explicit periodic sampling interval or latency limits are defined in the documentation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is orchestrated by Docker Compose, which deploys six Docker containers: (1) the physical crane control container, (2) the sensor data collector, (3) the MQTT broker for intra‑system messaging, (4) the Twin core service that performs continuous state comparison, (5) the analytics/logic service, and (6) the TimescaleDB time‑series database used as the persistent log of all sensor data and twin states. All components interact via MQTT topics; the Twin core publishes updates back to the physical control container, and both the sensor collector and Twin core write to and read from TimescaleDB. No physical crane simulator is employed; all operations involve the actual boot‑up hardware."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A Continuous Validation Service operates concurrently with physical operations, continuously comparing real‑time sensor measurements against simulated trajectory predictions. The service computes Euclidean distance metrics between measured and simulated positions and flags deviations exceeding an adjustable threshold (e.g., 10 mm). Fault detection routines monitor anomalous motor currents and wind gusts. Validation includes unit testing of the kinematic model, integration testing of the Simulation Service, and periodic integrity checks of the TimescaleDB records. Quality assurance is achieved through automated regression testing of the twin pipeline and manual verification during system commissioning."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin’s internal services communicate via a local MQTT broker, which facilitates signaling between the Trajectory Generator Service, Simulation Service, Continuous Validation Service, and other components. PostgreSQL (TimescaleDB) serves as the time‑series database backend, accessed using the standard PostgreSQL protocol. Grafana connects to the database over HTTP to render dashboards. The document does not specify additional network protocols, topologies, bandwidth or latency requirements, or explicit reliability or security mechanisms beyond the presence of MQTT broker communication."
]