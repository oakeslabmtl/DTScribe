// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder measuring hoist oscillation"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting crane dynamics"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the cart motor to detect horizontal motion"
    DTDFVocab:producedData CartMotorPositionDataTransmitted
]

instance HoistMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the hoist motor to capture vertical motion"
    DTDFVocab:producedData HoistMotorPositionDataTransmitted
]

instance HoistMotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor for the hoist motor to monitor load and electrical consumption"
    DTDFVocab:producedData HoistMotorCurrentDataTransmitted
]

// C4: Physical-to-virtual interaction – Data transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance CartMotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoder
]

instance HoistMotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoder
]

instance HoistMotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorCurrentSensor
]

// C10: Models/Data – Kinematic model used by trajectory generator and simulation
instance KinematicModel : DTDFVocab:Model [
    base:desc "Mathematical kinematic model of the gantry crane, used for trajectory planning and simulation"
]

// C10: Data instances for sensor logs
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Persisted swing angle measurements"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler, TrajectoryGeneratorEnabler, ContinuousValidationEnabler, FaultDetectionEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Persisted wind speed readings"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler, TrajectoryGeneratorEnabler, ContinuousValidationEnabler, FaultDetectionEnabler
]

instance CartMotorPositionData : DTDFVocab:Data [
    base:desc "Persisted cart motor position readings"
    DTDFVocab:fromData CartMotorPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler, TrajectoryGeneratorEnabler, ContinuousValidationEnabler, FaultDetectionEnabler
]

instance HoistMotorPositionData : DTDFVocab:Data [
    base:desc "Persisted hoist motor position readings"
    DTDFVocab:fromData HoistMotorPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler, TrajectoryGeneratorEnabler, ContinuousValidationEnabler, FaultDetectionEnabler
]

instance HoistMotorCurrentData : DTDFVocab:Data [
    base:desc "Persisted hoist motor current measurements"
    DTDFVocab:fromData HoistMotorCurrentDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler, TrajectoryGeneratorEnabler, ContinuousValidationEnabler, FaultDetectionEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database enabling real‑time data logging"
    DTDFVocab:enables LoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker enabling publish/subscribe messaging"
    DTDFVocab:enables MQTTPublisherService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Component enabling optimal trajectory generation using the kinematic model"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Component enabling continuous validation comparing measured versus simulated trajectories"
    DTDFVocab:enables ContinuousValidationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Component enabling fault detection via time‑series classification"
    DTDFVocab:enables FaultDetectionService
]

// C6: Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Real‑time data logging service storing sensor observations in TimescaleDB"
    DTDFVocab:provides LoggingInsight
]

instance MQTTPublisherService : DTDFVocab:Service [
    base:desc "Service publishing sensor data, trajectory commands, and validation metrics over MQTT"
    DTDFVocab:provides QoSMqttInsights
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Optimises trajectories for the gantry crane to minimise swing while satisfying constraints"
    DTDFVocab:provides MinimalSwingInsight, TrajectoryOptimisationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates measured trajectories against simulation, computing error statistics"
    DTDFVocab:provides DeviationAlertInsight, ControlPolicyRefinementInsight, MaintenanceScheduleInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects and localises anomalies in motors or sensors using time‑series classification"
    DTDFVocab:provides FaultLocalizationInsight
]

// C17: Insights
instance LoggingInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data has been logged to TimescaleDB"
]

instance QoSMqttInsights : DTDFVocab:Insight [
    base:desc "Quality of service metrics for MQTT publishing"
]

instance MinimalSwingInsight : DTDFVocab:Insight [
    base:desc "Generated trajectory yields minimal swing of the hoist load"
]

instance TrajectoryOptimisationInsight : DTDFVocab:Insight [
    base:desc "Trajectory planning optimised for speed, smoothness, and safety"
]

instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Continuous validation flags deviations exceeding threshold, indicating possible control issues"
]

instance ControlPolicyRefinementInsight : DTDFVocab:Insight [
    base:desc "Insights used to refine control policies and maintenance schedules"
]

instance MaintenanceScheduleInsight : DTDFVocab:Insight [
    base:desc "Recommendation for maintenance based on cumulative error statistics"
]

instance FaultLocalizationInsight : DTDFVocab:Insight [
    base:desc "Identifies anomalies in specific motors or sensors based on fault detection"
]

// C17: Actions
instance OperatorAdjustmentAction : DTDFVocab:Action [
    base:desc "Operator manually adjusts control parameters in response to deviation alerts"
    DTDFVocab:IsAutomatic false
]

instance FaultTroubleshootAction : DTDFVocab:Action [
    base:desc "Automated troubleshooting steps triggered by fault localisation insights"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance CartMotor : DTDFVocab:ActingComponent [
    base:desc "Cart motor providing horizontal displacement under control of Arduino motor-controller"
]

instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist motor lifting and lowering the load via Trinamic TMC4671 Eval driver"
]

instance TrinamicEvalDriver : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671 Eval driver providing step/enable control signals to the motors"
]

instance ArduinoMotorControllerBoard : DTDFVocab:ActingComponent [
    base:desc "Arduino board running firmware that converts high-level commands into driver signals"
]

// C3 (continued): Physical Interface
instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Interface layer between physical crane and digital twin, forwarding sensor data and actuator commands"
]

// C3: Physical Crane
instance PhysicalCrane : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane replica of harbor cranes in Antwerp, moving containers between two points"
]

// C3: Control Application
instance ControlApplication : DTDFVocab:Component [
    base:desc "Software application orchestrating trajectory generation, simulation, validation, and fault detection"
]

// C3: Logging Application
instance LoggingApplication : DTDFVocab:Component [
    base:desc "Local application that streams sensor outputs over MQTT to TimescaleDB and twin services"
]

// C3: HMI
instance HMI : DTDFVocab:Component [
    base:desc "Human‑machine interface providing dashboards and command controls via Grafana and web UI"
]

// C10: Environment
instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains PhysicalCrane, PhysicalCraneInterface, ControlApplication, LoggingApplication, HMI
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The trajectory generator publishes target angles and motor step commands to the control application via MQTT; the control application translates these into driver signals for the motors. The continuous‑validation service can push alerts to the HMI dashboard. All commands flow through the Mosquitto broker."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Control and validation run in real‑time at sub‑second intervals (~10–100 Hz for telemetry, <1 s for trajectory updates); simulation runs asynchronously on the same host, producing confidence bounds within milliseconds of trajectory generation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated by a docker‑compose file that starts the MQTT broker, TimescaleDB, and Grafana containers. The physical‑crane interface, control application, logging application, and HMI run as Python processes on the host PC and communicate via MQTT topics. Services exchange messages through the broker; all telemetry is persisted to the database; dashboards ingest and display live data."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design phase: CAD models and kinematic model created; Manufacturing phase: physical crane constructed from BOM; Operation phase: crane runs real‑time; Twin provides continuous validation and fault detection throughout operation; Research and teaching use cases drive evolution across the full lifecycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service computes residual distances between recorded sensor trajectories and simulated trajectories; a threshold defines acceptable quality. Simulations are validated against real platform data; CAD and kinematic models are verified against the constructed crane. Validation metrics and fault‑detection performance are reported in related publications."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication uses MQTT over TCP/IP on localhost; the physical sensors and actuators connect via Arduino over serial USB; control commands are published to MQTT topics consumed by driver modules; telemetry is written to TimescaleDB via PostgreSQL queries."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin services run in Docker containers on a single personal computer using Docker‑compose. The stack includes TimescaleDB, Mosquitto, Grafana, and Python applications; deployment is achieved by running 'docker‑compose up --build'."
]