// C2: Acting Components
instance GantryCraneMotorController : DTDFVocab:ActingComponent [
    base:desc "Embedded controller managing two motors for horizontal and vertical movement of the lab-scale gantry crane, including trajectory execution and safety constraints."
]

instance GantryCraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnetic actuator for puck manipulation in the lab-scale gantry crane system, controlled via Arduino microcontroller."
]

instance ArduinoMicrocontroller : DTDFVocab:ActingComponent [
    base:desc "Centralized microcontroller coordinating actuation logic for the gantry crane's motors and electromagnet, implementing predefined travel paths."
]

instance GreenhouseEnvironmentController : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi-based controller for automated environmental management in the GreenhouseDT, though specific actuation details are unspecified."
]

// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring puck orientation and swing angle in the lab-scale gantry crane system."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor for monitoring wind conditions in the gantry crane system."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

instance RaspberryPiAirQualitySensorSet : DTDFVocab:SensingComponent [
    base:desc "Set of sensors on Raspberry Pi for indoor air quality monitoring in the Air Quality Management exemplar."
    DTDFVocab:producedData AirQualityDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RaspberryPiAirQualitySensorSet
]

instance CraneOperationalStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GantryCraneMotorController
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "Python-based kinematic solver computing joint trajectories and constraints for the lab-scale gantry crane based on physical parameters."
    DTDFVocab:inputTo PythonKinematicEngine
]

instance TimeseriesOperationalData : DTDFVocab:Data [
    base:desc "Historical operational data stored in TimescaleDB, including sensor logs, trajectories, and crane operational states with high temporal resolution."
    DTDFVocab:fromData SwingAngleDataTransmitted, EnvironmentalDataTransmitted
    DTDFVocab:inputTo GrafanaDashboard
]

instance PrerecordedGreenhouseData : DTDFVocab:Data [
    base:desc "Prerecorded data within virtual machine images serving as initial conditions for behavioral models in the GreenhouseDT."
    DTDFVocab:inputTo InfluxDB
]

instance AirQualityModel : DTDFVocab:Model [
    base:desc "AutomationML-based model representing indoor air quality dynamics for the Air Quality Management exemplar."
    DTDFVocab:inputTo AzureSimulationEngine
]

// C11: Enablers
instance PythonKinematicEngine : DTDFVocab:Enabler [
    base:desc "Custom Python-based kinematic solver for computing joint trajectories and constraints in the gantry crane system."
    DTDFVocab:enables ContinuousValidationService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "Time-series database storing high-resolution operational data for the gantry crane and GreenhouseDT systems."
    DTDFVocab:enables MonitoringService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Data visualization tool integrated with TimescaleDB for creating interactive dashboards of real-time and historical crane operations."
    DTDFVocab:enables VisualizationService
]

instance DockerContainerization : DTDFVocab:Enabler [
    base:desc "Containerization framework ensuring portability and consistent deployment of digital twin services across environments."
    DTDFVocab:enables DeploymentService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Message broker facilitating real-time data transmission between the Physical Crane Interface and digital twin services."
    DTDFVocab:enables DataIngestionService
]

instance InfluxDB : DTDFVocab:Enabler [
    base:desc "Time-series database for the GreenhouseDT storing high-resolution temporal data for behavioral adaptation."
    DTDFVocab:enables GreenhouseBehavioralService
]

instance AzureSimulationEngine : DTDFVocab:Enabler [
    base:desc "Microsoft Azure tools implementing simulation, prediction, and runtime visualization for the Air Quality Management digital twin."
    DTDFVocab:enables AirQualityPredictionService
]

instance GitHubRepository : DTDFVocab:Enabler [
    base:desc "Publicly available repository hosting source code, CAD models, and documentation for the entire digital twin system."
    DTDFVocab:enables VersionControlService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time data acquisition service tracking the physical crane's operational status, including position, speed, load, and energy consumption."
    DTDFVocab:provides CraneOperationalInsight, HistoricalPerformanceInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing crane control parameters for efficiency, safety, or energy consumption using real-time data."
    DTDFVocab:provides EnergyOptimizationAction, SafetyAdjustmentAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service comparing simulated kinematic predictions with actual physical measurements to validate digital twin accuracy."
    DTDFVocab:provides ValidationAccuracyInsight, TrajectoryValidationAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization service representing the crane's state, data, and simulations in 3D CAD models and real-time graphics."
    DTDFVocab:provides CraneStateVisualizationInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Closed-loop control service enabling bidirectional communication between the digital twin and physical crane controller for adaptive control strategies."
    DTDFVocab:provides AdaptiveControlAction
]

instance GreenhouseBehavioralService : DTDFVocab:Service [
    base:desc "Self-adaptive service for the GreenhouseDT enabling behavioral adaptation of both physical greenhouse and its digital counterpart."
    DTDFVocab:provides GreenhouseAdaptationInsight
]

instance AirQualityPredictionService : DTDFVocab:Service [
    base:desc "Service leveraging AutomationML models to simulate and predict indoor air quality dynamics using Azure tools."
    DTDFVocab:provides AirQualityForecastInsight
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Service managing containerized deployment of digital twin components for reproducibility and scalability."
    DTDFVocab:provides DeploymentStatusInsight
]

instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service responsible for receiving and processing real-time data from physical sensors and interfaces."
    DTDFVocab:provides CraneOperationalStateDataTransmitted
]

instance VersionControlService : DTDFVocab:Service [
    base:desc "Service managing version control of source code, documentation, and configuration files for the digital twin system."
    DTDFVocab:provides DeploymentStatusInsight
]

// C17: Insights/Actions
instance CraneOperationalInsight : DTDFVocab:Insight [
    base:desc "Real-time insight into the physical crane's operational status including position, speed, load, and energy consumption."
]

instance HistoricalPerformanceInsight : DTDFVocab:Insight [
    base:desc "Historical analysis of crane performance trends and anomalies derived from TimeseriesOperationalData."
]

instance EnergyOptimizationAction : DTDFVocab:Action [
    base:desc "Automated adjustment of control parameters to minimize energy usage in crane operations."
    DTDFVocab:IsAutomatic true
]

instance SafetyAdjustmentAction : DTDFVocab:Action [
    base:desc "Dynamic adjustment of control parameters to ensure safe operation based on real-time data."
    DTDFVocab:IsAutomatic true
]

instance ValidationAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantitative measure of the digital twin's accuracy validated through continuous comparison of simulated vs. actual performance."
]

instance TrajectoryValidationAction : DTDFVocab:Action [
    base:desc "Automated validation of trajectory execution against simulated data to detect deviations."
    DTDFVocab:IsAutomatic true
]

instance CraneStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization of the crane's physical and digital states including real-time sensor data and simulation results."
]

instance AdaptiveControlAction : DTDFVocab:Action [
    base:desc "Bidirectional control signals sent from the digital twin to the physical crane's controller for real-time adjustments."
    DTDFVocab:IsAutomatic true
]

instance GreenhouseAdaptationInsight : DTDFVocab:Insight [
    base:desc "Insight into behavioral adaptation of the greenhouse system derived from prerecorded data and real-time monitoring."
]

instance AirQualityForecastInsight : DTDFVocab:Insight [
    base:desc "Predictive insights into indoor air quality dynamics based on AutomationML models and Azure simulations."
]

instance DeploymentStatusInsight : DTDFVocab:Insight [
    base:desc "Status information about the containerized deployment of digital twin components across environments."
]

// C1: Environments
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Research and education environment for the lab-scale gantry crane system, including physical crane and digital twin components."
    base:contains GantryCraneMotorController, SwingAngleEncoder, Anemometer, ArduinoMicrocontroller
]

instance GreenhouseEnvironment : DTDFVocab:Environment [
    base:desc "Low-cost greenhouse system environment with self-adaptive digital twin capabilities."
    base:contains GreenhouseEnvironmentController
]

instance AirQualityManagementEnvironment : DTDFVocab:Environment [
    base:desc "Indoor environment for air quality management featuring Raspberry Pi-based sensor network."
    base:contains RaspberryPiAirQualitySensorSet
]

// C6: Components
instance PhysicalCrane : DTDFVocab:Component [
    base:desc "Lab-scale gantry crane system including mechanical components such as beams, motors, and load-bearing structures for controlled movement."
]

instance Controller : DTDFVocab:Component [
    base:desc "Embedded or programmable logic controller managing the crane's motion, positioning, and operational logic."
]

instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Python program connecting the crane's controllers to the digital twin for data exchange and actuation."
    base:isContainedIn LabScaleGantryCraneEnvironment
]

instance LoggingApplication : DTDFVocab:Component [
    base:desc "Continuous logging application recording the crane's operational state into TimescaleDB database."
    base:isContainedIn LabScaleGantryCraneEnvironment
]

instance TrajectoryGeneratorService : DTDFVocab:Component [
    base:desc "Service supporting trajectory planning for puck movement and logistics optimization."
    base:isContainedIn LabScaleGantryCraneEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "
The **Virtual-to-Physical Interaction** in this system is governed by the **Control Application**, which generates and executes commands to control the physical gantry crane. Control flows are initiated by the **Trajectory Generator Service**, which uses a **kinematics model** of the crane to compute **optimal movement trajectories** (e.g., smooth paths with zero residual swinging at the end). These trajectories are then sent to the **Control Application** via the **MQTT Broker** for execution.

Key technical details include:
- **Command Types**: Position commands (X, Y, Z coordinates), velocity profiles, and acceleration constraints for the crane’s movement.
- **Control Message Formats**: Undisclosed, but likely **structured JSON or protocol buffers** over MQTT, given the system’s Python-based architecture.
- **Validation and Authentication Mechanisms**: No explicit mention of authentication; however, the **Continuous Validation Service** compares real-time trajectory execution against simulated trajectories to detect deviations. If a **distance metric threshold** is breached (e.g., positional error exceeds tolerance), operators are notified via the **Dashboard**.
- **Feedback Systems**: The **Logging Application** captures real-time sensor feedback (position/velocity) during execution, which is used by the **Continuous Validation Service** for post-hoc validation. No explicit closed-loop feedback mechanism is described for real-time correction.
- **Conflict Resolution**: Not explicitly addressed; however, the **MQTT Broker** ensures ordered delivery of commands, and the **Control Application** likely prioritizes the latest trajectory commands from the Trajectory Generator Service.
- **Command Execution Confirmation**: No explicit acknowledgment mechanism is described, but the **Continuous Validation Service** implicitly confirms execution by comparing simulated vs. real trajectories.
"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin systems in the documents follow **ad-hoc orchestration patterns** rather than standardized commercial frameworks. **GreenhouseDT** uses a **modular architecture** with **InfluxDB** for time-series data storage, **ActiveMQ** for message brokering, and **virtual machines** for deployment, enabling easy dissemination via containerization. The **Air Quality Management** exemplar integrates **Raspberry Pi sensors** with a **Microsoft Azure-based pipeline**, leveraging **AutomationML** for digital twin representation and **GitHub-hosted instructions** for setup. The **Lab Scale Gantry Crane** system is described using the **C4 Model**, implying a **component-based architecture** with potential for **service-oriented coordination**, though no explicit orchestration mechanisms (e.g., microservices, event-driven patterns) are detailed. All exemplars rely on **virtualization/containerization** for scalability and reproducibility, with no mention of cloud-native orchestration tools (e.g., Kubernetes, Docker Swarm)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
  **GreenhouseDT:**
  Not in Document

  **Air Quality Management:**
  Not in Document

  **Lab Scale Gantry Crane:**
  - **Model Fidelity Requirements:** The digital twin incorporates a **Continuous Validation Service** that continuously compares real-world measurements of executed trajectories (e.g., puck movements) with simulated trajectories to assess fidelity.
  - **Validation and Verification Methods:**
    - **Trajectory Comparison:** Executed trajectories are compared against simulated paths using distance metrics to quantify deviations.
    - **Confidence Bounds:** Simulation results are augmented with confidence bounds derived from uncertainty analysis, ensuring robustness in trajectory planning.
  - **Uncertainty Sources:** Environmental factors (e.g., wind speed from the anemometer) and sensor noise (e.g., encoder precision) are implicit sources of uncertainty.
  - **Error Detection and Correction:** The validation service likely triggers corrective actions (e.g., motor adjustments) if deviations exceed predefined thresholds.
  - **Quality Assurance Processes:** No explicit mention of formal QA processes, but the continuous validation service implies iterative refinement of models and control logic.
  "
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "
The digital twin’s technical network infrastructure is centered around an **MQTT Broker**, which facilitates bidirectional communication between services (e.g., **Trajectory Generator Service**, **Logging Application**, **Continuous Validation Service**). The **Physical Crane Interface** connects to the crane’s controllers, though the communication protocol (e.g., serial, USB, or Ethernet) is not specified. The architecture suggests a **star topology** with the MQTT Broker as the central hub, linking all digital twin services. **TimescaleDB** serves as the centralized data repository for logged crane states and trajectory data. No explicit bandwidth, latency, or redundancy requirements are mentioned, but the real-time nature of trajectory validation implies low-latency constraints. Security protocols are not addressed in the documents.
"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "
The **Digital Twin’s Hosting and Deployment** infrastructure is **on-premise** and tailored to the lab-scale gantry crane system. Key deployment details include:

- **Hosting Platform**: **On-premise** deployment, with no mention of cloud (e.g., AWS, Azure) or edge computing (e.g., Raspberry Pi clusters). The system is designed for **localized control and research**, prioritizing low-latency and data sovereignty.

- **Computational and Storage Requirements**:
  - **Computational**: The **Trajectory Generator Service**, **Simulation Service**, and **Continuous Validation Service** require moderate computational resources for kinematic modeling, simulation, and real-time validation. The **Logging Application** and **MQTT Broker** have lower computational demands.
  - **Storage**: **TimescaleDB** is used for storing sensor data, trajectories, and validation metrics. The database is likely deployed on a **dedicated server** with sufficient disk space for historical data retention (duration not specified).
  - **Scalability Mechanisms**: Not explicitly scalable; the system is designed for a **single gantry crane instance**. Horizontal scaling would require replicating services (e.g., MQTT brokers, databases) and is not addressed.

- **Deployment Models Supported**:
  - **Monolithic deployment** for the digital twin services, with clear containerization (using the **C4 Model’s container abstraction**) but no mention of **Docker** or orchestration tools (e.g., Kubernetes). Services are deployed as **standalone Python applications** with dependencies managed locally.
  - **Physical Crane Interface** and **Control Application** are tightly coupled to the hardware and run on the same local network.

- **Availability and Reliability Assurance**:
  - **High availability** is implied for critical services (e.g., Logging Application, Dashboard) due to continuous operation. However, no redundancy or failover mechanisms are described.
  - **Reliability** is partially ensured by the **Continuous Validation Service**, which monitors trajectory execution and alerts operators to deviations. The **Logging Application** provides data persistence, acting as a fallback for lost real-time data.
"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The **GreenhouseDT** system integrates with **InfluxDB** (time-series database) and **ActiveMQ** (message broker) for internal data exchange, but no external system dependencies or interoperability standards are specified. The **Air Quality Management** exemplar uses **Microsoft Azure tools** for pipeline implementation, implying integration with cloud-based services (e.g., Azure IoT Hub, Azure Functions), though no explicit protocols (e.g., MQTT, OPC UA) or enterprise system dependencies are mentioned. The **Lab Scale Gantry Crane** system lacks documentation on horizontal integration, but its **C4 Model architecture** suggests potential for **API-based or event-driven integration** with external systems. No AutomationML or other interoperability standards are referenced for cross-system communication."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "
The Lab Scale Gantry Crane Digital Twin system adopts an ad-hoc approach, avoiding commercial digital twin frameworks and standardized industry protocols. No explicit compliance with industry standards (e.g., ISO/IEC 42010, IEC 62264) or certification frameworks is documented. Interoperability is not explicitly addressed through standardized protocols; instead, the system integrates generic components such as Arduino and motor controllers without specifying communication protocols (e.g., Modbus, CAN bus). The architecture relies on custom-developed services (e.g., Trajectory Generator, Continuous Validation) without adherence to formal interoperability standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "
The Lab Scale Gantry Crane Digital Twin system incorporates a **Continuous Validation Service** that performs **distance metric calculations** to monitor operational safety. This service **notifies operators** in real-time when predefined thresholds are exceeded, ensuring compliance with safety-critical operational constraints. The system leverages **C4 Model-based architecture visualization** for transparency in system design, though explicit cybersecurity protocols (e.g., encryption, authentication, or access control mechanisms) are not detailed in the provided documents. The use of **InfluxDB** (for data storage) and **ActiveMQ** (for message brokering) in related exemplars (e.g., GreenhouseDT) suggests potential reliance on these technologies for data integrity, but no specific security hardening (e.g., TLS, role-based access control) is mentioned for the Gantry Crane exemplar. Fail-safe mechanisms are implied through the validation service’s threshold-based alerts, but no explicit compliance with standards (e.g., ISO 27001, IEC 62443) or regulatory frameworks (e.g., GDPR for data protection) is referenced."
]